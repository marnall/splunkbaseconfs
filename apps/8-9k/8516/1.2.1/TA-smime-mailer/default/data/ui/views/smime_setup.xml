<dashboard version="1.1" script="smime_setup.js" stylesheet="smime_configuration.css">
  <label>Mail Delivery Setup</label>
  <description>Configure outgoing mail transport (SMTP or Microsoft Graph API) for S/MIME email delivery.</description>

  <row>
    <panel>
      <html>
        <div id="smime-setup-app">

          <div class="smime-section">
            <h2>📬 Mail Delivery Configuration</h2>

            <div id="transport-indicator" class="smime-card" style="background:#e8f4fd; border-left:4px solid #0078d4; padding:12px 16px; margin-bottom:16px;">
              <strong id="transport-label">🔌 Transport: SMTP</strong>
              <span id="transport-desc" class="smime-help" style="display:inline; margin-left:10px;">Emails will be sent via direct SMTP connection.</span>
            </div>

            <div class="smime-card">
              <h3>Transport Method</h3>

              <div class="smime-form-row">
                <label for="smtp-auth-type">Delivery Method:</label>
                <select id="smtp-auth-type" class="smime-input" style="max-width:360px;">
                  <option value="basic">SMTP (Direct Connection)</option>
                  <option value="oauth2">Microsoft 365 Graph API (OAuth2)</option>
                </select>
              </div>
            </div>

            <div id="smtp-server-card" class="smime-card">
              <h3>SMTP Server</h3>
              <p class="smime-help">
                Configure the outgoing SMTP mail server.
                Supported modes: SMTP on port 25 (with optional STARTTLS upgrade), Submission on port 587,
                and SMTPS on port 465 (implicit TLS).
              </p>

              <div class="smime-form-row">
                <label for="smtp-host">SMTP Host:</label>
                <input type="text" id="smtp-host" class="smime-input" placeholder="mail.example.com" />
              </div>

              <div class="smime-form-row">
                <label for="smtp-port">SMTP Port:</label>
                <input type="number" id="smtp-port" class="smime-input" style="max-width:120px;" value="25" />
                <span class="smime-help" style="display:inline; margin-left:10px;">
                  Common: 25 (SMTP/STARTTLS), 465 (SMTPS), 587 (Submission/STARTTLS)
                </span>
              </div>

              <div class="smime-form-row">
                <label for="smtp-security">Connection Security:</label>
                <select id="smtp-security" class="smime-input" style="max-width:320px;">
                  <option value="starttls">STARTTLS (port 25 → upgrade to TLS)</option>
                  <option value="submission">STARTTLS Submission (port 587)</option>
                  <option value="ssl">SMTPS (implicit TLS, port 465)</option>
                  <option value="none">None (plain SMTP, no encryption)</option>
                </select>
              </div>
            </div>

            <div id="smtp-auth-card" class="smime-card">
              <h3>SMTP Authentication</h3>

              <div id="auth-basic-fields">
                <div class="smime-form-row">
                  <label for="smtp-user">SMTP Username (optional):</label>
                  <input type="text" id="smtp-user" class="smime-input" placeholder="username" />
                </div>

                <div class="smime-form-row">
                  <label for="smtp-password">SMTP Password (optional):</label>
                  <input type="password" id="smtp-password" class="smime-input" placeholder="password" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    Stored encrypted in Splunk's credential store.
                  </span>
                </div>
              </div>
            </div>

            <div id="auth-oauth2-card" class="smime-card" style="display:none;">
              <h3>Microsoft 365 — Graph API Settings</h3>
              <p class="smime-help">
                Emails are sent via <strong>Microsoft Graph API</strong> using the <code>Mail.Send</code> application permission.
                No SMTP server connection is needed. Requires an Azure AD App Registration with client credentials.
              </p>

              <div id="auth-oauth2-fields">
                <div class="smime-form-row">
                  <label for="smtp-user-oauth">Sender Mailbox (email):</label>
                  <input type="text" id="smtp-user-oauth" class="smime-input" placeholder="sender@example.com" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    The Microsoft 365 mailbox that will appear as the sender (must have Mail.Send permission).
                  </span>
                </div>

                <div class="smime-form-row">
                  <label for="oauth2-client-id">OAuth2 Client ID:</label>
                  <input type="text" id="oauth2-client-id" class="smime-input" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    Application (client) ID from Azure AD App Registration.
                  </span>
                </div>

                <div class="smime-form-row">
                  <label for="oauth2-client-secret">OAuth2 Client Secret:</label>
                  <input type="password" id="oauth2-client-secret" class="smime-input" placeholder="client secret" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    Stored encrypted in Splunk's credential store.
                  </span>
                </div>

                <div class="smime-form-row">
                  <label for="oauth2-tenant-id">Tenant ID (Azure AD):</label>
                  <input type="text" id="oauth2-tenant-id" class="smime-input" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    Azure AD Directory (tenant) ID. Used to auto-build the token URL.
                  </span>
                </div>

                <div class="smime-form-row">
                  <label for="oauth2-token-url">Token URL (optional override):</label>
                  <input type="text" id="oauth2-token-url" class="smime-input" placeholder="https://login.microsoftonline.com/{tenant}/oauth2/v2.0/token" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    Leave empty to auto-generate from Tenant ID. Set for non-Microsoft providers.
                  </span>
                </div>

                <div class="smime-form-row">
                  <label for="oauth2-scope">OAuth2 Scope:</label>
                  <input type="text" id="oauth2-scope" class="smime-input" value="https://graph.microsoft.com/.default" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    Default for M365 (Graph API): https://graph.microsoft.com/.default
                  </span>
                </div>
              </div>
            </div>

            <div class="smime-card">
              <h3>Sender Settings</h3>

              <div class="smime-form-row">
                <label for="sender-email">Default Sender Email:</label>
                <input type="text" id="sender-email" class="smime-input" placeholder="noreply@example.com" />
              </div>

              <div class="smime-form-row">
                <label for="sender-name">Sender Display Name:</label>
                <input type="text" id="sender-name" class="smime-input" placeholder="Splunk S/MIME Mailer" />
              </div>

              <div class="smime-form-row">
                <label for="splunk-hostname">Splunk Hostname (for email links):</label>
                <input type="text" id="splunk-hostname" class="smime-input" placeholder="https://splunk.example.com:8000" />
                <span class="smime-help" style="display:block; margin-top:4px;">
                  External base URL of this Splunk instance. Used in <em>View Alert</em> and
                  <em>View Results</em> links inside emails. Leave empty to use the URL
                  Splunk provides automatically (which may be an internal hostname).
                </span>
              </div>
            </div>

            <div class="smime-card">
              <h3>S/MIME Options</h3>

              <div class="smime-form-row">
                <label>
                  <input type="checkbox" id="use-signing" checked="checked" />
                  Enable S/MIME Signing
                </label>
                <span class="smime-help">Sign outgoing emails with the sender's certificate.</span>
              </div>

              <div class="smime-form-row">
                <label>
                  <input type="checkbox" id="use-encryption" checked="checked" />
                  Enable S/MIME Encryption
                </label>
                <span class="smime-help">Encrypt outgoing emails with recipient public certificates.</span>
              </div>

              <div class="smime-form-row">
                <label>
                  <input type="checkbox" id="verify-recipients" checked="checked" />
                  Require Valid Certificates for All Recipients
                </label>
                <span class="smime-help">
                  When enabled, emails will NOT be sent if ANY recipient is missing a 
                  valid public certificate. <strong>Required for ES integration.</strong>
                </span>
              </div>
            </div>

            <div id="hf-proxy-card" class="smime-card">
              <h3>🔀 Heavy Forwarder Proxy</h3>
              <p class="smime-help">
                Route email delivery through a Heavy Forwarder instead of sending directly from this
                Search Head. The HF must have the <strong>TA-smime-mailer-hf</strong> add-on installed.
                All configuration (SMTP settings, certificates, S/MIME options) stays on this Search Head —
                the HF acts only as a network relay.
              </p>

              <div class="smime-form-row">
                <label>
                  <input type="checkbox" id="use-hf-proxy" />
                  Route via Heavy Forwarder
                </label>
                <span class="smime-help">When enabled, the Search Head delegates SMTP delivery to the HF over port 8089.</span>
              </div>

              <div id="hf-proxy-fields" style="display:none;">
                <div class="smime-form-row">
                  <label for="hf-host">HF Hostname / IP:</label>
                  <input type="text" id="hf-host" class="smime-input" placeholder="heavyforwarder.example.com" />
                </div>

                <div class="smime-form-row">
                  <label for="hf-port">HF Management Port:</label>
                  <input type="number" id="hf-port" class="smime-input" style="max-width:120px;" value="8089" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    Default Splunk management port is 8089.
                  </span>
                </div>

                <div class="smime-form-row">
                  <label for="hf-token">HF Auth Token:</label>
                  <input type="password" id="hf-token" class="smime-input" placeholder="Splunk bearer token for HF" />
                  <span class="smime-help" style="display:inline; margin-left:10px;">
                    A Splunk authentication token created on the HF with access to the
                    <code>/services/smime_proxy/send</code> endpoint.
                    Stored encrypted in Splunk's credential store.
                  </span>
                </div>
              </div>
            </div>

            <div class="smime-form-actions">
              <button id="btn-save-smtp" class="btn btn-primary">Save Settings</button>
              <button id="btn-test-smtp" class="btn" title="Test the connection using the current settings">Test Connection</button>
              <span id="smtp-status" class="smime-status"></span>
            </div>

          </div>

          <!-- Port helper -->
          <div class="smime-section">
            <div class="smime-card">
              <h3>ℹ️ Port Reference</h3>
              <table class="smime-table" style="max-width:700px;">
                <thead>
                  <tr><th>Port</th><th>Protocol</th><th>Description</th></tr>
                </thead>
                <tbody>
                  <tr>
                    <td><strong>25</strong></td>
                    <td>SMTP</td>
                    <td>Standard SMTP. Optionally upgraded to TLS via STARTTLS command. 
                        Most common for internal mail relays.</td>
                  </tr>
                  <tr>
                    <td><strong>465</strong></td>
                    <td>SMTPS</td>
                    <td>Implicit TLS from connection start. Also known as "SMTP over SSL". 
                        Re-standardized in RFC 8314.</td>
                  </tr>
                  <tr>
                    <td><strong>587</strong></td>
                    <td>Submission</td>
                    <td>SMTP submission port with STARTTLS. Common for authenticated sending 
                        via external providers (Microsoft 365, Google Workspace, etc.).</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </html>
    </panel>
  </row>
</dashboard>
