<form version="1.1"
  stylesheet="splunk-innovators-toolkit:css/sit-panel-polish.css,splunk-innovators-toolkit:css/sit-text-whitelist.css,splunk-innovators-toolkit:themes/cyberpunk-neon.css,splunk-innovators-toolkit:backgrounds/cyberpunk-grid-pulse.css,splunk-innovators-toolkit:animations/hover-scale-lift.css"
  script="splunk-innovators-toolkit:backgrounds/background-helper.js,splunk-innovators-toolkit:toggles/dark-light-mode.js,splunk-innovators-toolkit:toggles/fullscreen-mode.js,splunk-innovators-toolkit:toggles/auto-refresh-countdown.js,splunk-innovators-toolkit:js/sit-remix-button.js">
  <label>Cyberpunk NOC</label>
  <description>Real-time Network Operations Center — event rates, queue health, forwarder status, error spikes. Powered by Innovators Toolkit.</description>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-4h@m</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <!-- Row 1: Critical KPIs + Live Clock -->
  <row>
    <panel>
      <title>Events Per Second</title>
      <single>
        <search>
          <query>index=_internal sourcetype=splunkd group=thruput name=thruput | eval eps=instantaneous_eps | stats avg(eps) as avg_eps | eval avg_eps=round(avg_eps,0)</query>
          <earliest>-5m@m</earliest>
          <latest>now</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0xDC3545","0xF7B500","0x00ff9f"]</option>
        <option name="rangeValues">[10,100]</option>
        <option name="useColors">1</option>
        <option name="underLabel">EPS (avg 5m)</option>
      </single>
    </panel>
    <panel>
      <title>Active Forwarders</title>
      <single>
        <search>
          <query>index=_internal sourcetype=splunkd group=tcpin_connections | stats dc(hostname) as forwarders | eval forwarders=if(isnull(forwarders),0,forwarders)</query>
          <earliest>-15m@m</earliest>
          <latest>now</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0xDC3545","0x00ff9f"]</option>
        <option name="rangeValues">[1]</option>
        <option name="useColors">1</option>
        <option name="underLabel">reporting in</option>
      </single>
    </panel>
    <panel>
      <title>Error Count</title>
      <single>
        <search>
          <query>index=_internal log_level=ERROR | stats count | eval count=if(isnull(count),0,count)</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x00ff9f","0xF7B500","0xDC3545"]</option>
        <option name="rangeValues">[10,100]</option>
        <option name="useColors">1</option>
        <option name="underLabel">total errors</option>
      </single>
    </panel>
    <panel>
      <title>Warning Count</title>
      <single>
        <search>
          <query>index=_internal log_level=WARN | stats count | eval count=if(isnull(count),0,count)</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x00ff9f","0xF7B500","0xDC3545"]</option>
        <option name="rangeValues">[50,500]</option>
        <option name="useColors">1</option>
        <option name="underLabel">total warnings</option>
      </single>
    </panel>
  </row>

  <!-- Row 2: Throughput + Queue Health -->
  <row>
    <panel>
      <title>Indexing Throughput (KB/sec)</title>
      <chart>
        <search>
          <query>index=_internal sourcetype=splunkd group=thruput name=thruput | timechart span=5m avg(instantaneous_kbps) as "KB/sec"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.text">KB/sec</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
    <panel>
      <title>Queue Fill Ratio (%)</title>
      <chart>
        <search>
          <query>index=_internal sourcetype=splunkd group=queue | eval fill=current_size_kb/max_size_kb*100 | timechart span=5m avg(fill) by name limit=5</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.text">Fill %</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
  </row>

  <!-- Row 3: Error Spikes + Event Distribution + Forwarder Volume -->
  <row>
    <panel>
      <title>Error Spike Detection</title>
      <chart>
        <search>
          <query>index=_internal log_level=ERROR | timechart span=10m count as errors | eval baseline=50 | fields _time, errors, baseline</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.overlayFields">baseline</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
    <panel>
      <title>Event Distribution by Sourcetype</title>
      <chart>
        <search>
          <query>index=_internal | stats count by sourcetype | sort -count | head 10</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.showPercent">1</option>
      </chart>
    </panel>
    <panel>
      <title>Forwarder Volume (Top 10)</title>
      <chart>
        <search>
          <query>index=_internal sourcetype=splunkd group=tcpin_connections | stats sum(kb) as total_kb by hostname | sort -total_kb | head 10 | eval total_mb=round(total_kb/1024,1) | fields hostname, total_mb</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.axisTitleX.text">MB</option>
      </chart>
    </panel>
  </row>

  <!-- Row 4: Detailed Tables + Scheduler + License -->
  <row>
    <panel>
      <title>Recent Critical Errors</title>
      <table>
        <search>
          <query>index=_internal log_level=ERROR | table _time, component, source, message | head 50 | rename component as "Component", source as "Source", message as "Error Message"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="wrap">true</option>
        <option name="drilldown">row</option>
      </table>
    </panel>
    <panel>
      <title>Scheduler Health</title>
      <chart>
        <search>
          <query>index=_internal sourcetype=scheduler | eval status_group=case(status="success", "Success", status="skipped", "Skipped", status="deferred", "Deferred", 1=1, "Other") | stats count by status_group</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.showPercent">1</option>
      </chart>
    </panel>
    <panel>
      <title>License Usage Today</title>
      <single>
        <search>
          <query>index=_internal source=*license_usage.log type=Usage | stats sum(b) as bytes | eval gb=round(bytes/1024/1024/1024,2) | eval gb=gb . " GB"</query>
          <earliest>@d</earliest>
          <latest>now</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x00ff9f","0xF7B500","0xDC3545"]</option>
        <option name="rangeValues">[1,5]</option>
        <option name="useColors">1</option>
        <option name="underLabel">ingested today</option>
      </single>
    </panel>
  </row>

</form>
