<dashboard version="1.1" theme="dark" stylesheet="css/sit-core.css,css/sit-components.css">
  <label>Getting Started</label>
  <description>Innovators Toolkit — make your dashboards look like a .conf presentation, no CSS or JS required</description>

  <!-- HERO -->
  <row>
    <panel>
      <html>
        <div class="sit-scope" style="padding: 40px 30px; text-align: center; background: linear-gradient(135deg, rgba(253,24,117,0.08), rgba(23,162,184,0.08)); border-radius: 12px;">
          <h1 style="font-size: 42px; margin-bottom: 12px; color: #FD1875; font-weight: 700; letter-spacing: -0.5px;">Polish Your Splunk Dashboards</h1>
          <p style="font-size: 20px; color: #b0b0b0; max-width: 780px; margin: 0 auto 8px;">
            Make your Classic Simple XML dashboards look like a .conf presentation.
          </p>
          <p style="font-size: 15px; color: #6c757d; max-width: 780px; margin: 0 auto 28px;">
            Premium themes, animated backgrounds, interactive controls — drop-in, no CSS or JS.
          </p>
          <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
            <a href="design_studio" class="sit-btn sit-btn-primary sit-btn-lg" style="text-decoration: none; font-size: 15px; padding: 12px 28px;">&#9998; Open Design Studio</a>
            <a href="demo_cyberpunk_noc" class="sit-btn sit-btn-outline sit-btn-lg" style="text-decoration: none; font-size: 15px; padding: 12px 28px;">&#128064; See Live Demo</a>
          </div>
        </div>
      </html>
    </panel>
  </row>

  <!-- CHOOSE YOUR PATH -->
  <row>
    <panel>
      <title>Pick Your Path</title>
      <html>
        <div class="sit-scope" style="padding: 20px;">
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">

            <!-- PATH 1: I have a dashboard -->
            <div class="sit-card" style="border: 1px solid rgba(253, 24, 117, 0.2); background: rgba(253, 24, 117, 0.04);">
              <div class="sit-card-body" style="padding: 22px;">
                <div style="font-size: 28px; margin-bottom: 12px;">&#128229;</div>
                <h4 style="color: #FD1875; margin-bottom: 10px; font-size: 17px;">I have a dashboard</h4>
                <p class="sit-text-secondary" style="margin-bottom: 16px; line-height: 1.5;">
                  Use <strong>Remix</strong> on any existing Classic dashboard to pull it into Design Studio.
                  Your SPL queries stay intact — you just add polish.
                </p>
                <a href="design_studio" class="sit-btn sit-btn-primary" style="text-decoration: none;">Open Design Studio</a>
              </div>
            </div>

            <!-- PATH 2: Starting fresh -->
            <div class="sit-card" style="border: 1px solid rgba(23, 162, 184, 0.2); background: rgba(23, 162, 184, 0.04);">
              <div class="sit-card-body" style="padding: 22px;">
                <div style="font-size: 28px; margin-bottom: 12px;">&#9889;</div>
                <h4 style="color: #17A2B8; margin-bottom: 10px; font-size: 17px;">Starting from scratch</h4>
                <p class="sit-text-secondary" style="margin-bottom: 16px; line-height: 1.5;">
                  Pick a pre-built <strong>template</strong> (SOC, Executive Report, Arctic Monitoring, etc.).
                  Tweak layout, swap themes, export XML.
                </p>
                <a href="design_studio" class="sit-btn sit-btn-outline" style="text-decoration: none;">Start from Template</a>
              </div>
            </div>

            <!-- PATH 3: Just browsing -->
            <div class="sit-card" style="border: 1px solid rgba(92, 192, 92, 0.2); background: rgba(92, 192, 92, 0.04);">
              <div class="sit-card-body" style="padding: 22px;">
                <div style="font-size: 28px; margin-bottom: 12px;">&#127919;</div>
                <h4 style="color: #5CC05C; margin-bottom: 10px; font-size: 17px;">Just curious</h4>
                <p class="sit-text-secondary" style="margin-bottom: 16px; line-height: 1.5;">
                  Browse <strong>13 polished demo dashboards</strong> built with the toolkit.
                  See what's possible, then remix any of them.
                </p>
                <a href="demo_cyberpunk_noc" class="sit-btn sit-btn-secondary" style="text-decoration: none;">View Demos</a>
              </div>
            </div>

          </div>
        </div>
      </html>
    </panel>
  </row>

