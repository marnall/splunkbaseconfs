<dashboard version="1.1">
  <label>Method Security Audit Log Inputs</label>
  <description>Configure Method Security Audit Log data inputs</description>
  <row>
    <panel>
      <html>
        <div style="margin: 20px;">
          <h2>Configure Data Inputs</h2>
          <p>To configure Method Security Audit Log inputs, navigate to:</p>
          <p><strong>Settings → Data inputs → Method Security Audit Log Ingestion</strong></p>
          <p>Or click the button below:</p>
          <p style="margin-top: 20px;">
            <a href="/manager/method-security-audit-ingestion/data/inputs/method_audit_logs" class="btn btn-primary">
              Configure Inputs
            </a>
          </p>
          <hr style="margin: 30px 0;" />
          <h3>Configuration Parameters</h3>
          <table class="table table-striped" style="margin-top: 15px;">
            <thead>
              <tr>
                <th>Parameter</th>
                <th>Required</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><code>start_time</code></td>
                <td>Yes</td>
                <td>Initial start time for audit log collection (Format: YYYY-MM-DD HH:MM:SS)</td>
              </tr>
              <tr>
                <td><code>timezone</code></td>
                <td>No</td>
                <td>Timezone for start_time (Default: UTC). Use IANA timezone names (e.g., America/New_York)</td>
              </tr>
              <tr>
                <td><code>base_url</code></td>
                <td>Yes</td>
                <td>Method Security API base URL (e.g., https://api.method.delivery)</td>
              </tr>
              <tr>
                <td><code>client_id</code></td>
                <td>Yes</td>
                <td>OAuth Client ID from Method Security</td>
              </tr>
              <tr>
                <td><code>client_secret</code></td>
                <td>Yes</td>
                <td>OAuth Client Secret from Method Security</td>
              </tr>
              <tr>
                <td><code>interval</code></td>
                <td>No</td>
                <td>Collection interval in seconds (Default: 300)</td>
              </tr>
              <tr>
                <td><code>index</code></td>
                <td>No</td>
                <td>Splunk index for events (Default: default)</td>
              </tr>
            </tbody>
          </table>
          <hr style="margin: 30px 0;" />
          <h3>Manual Configuration</h3>
          <p>You can also configure inputs manually by creating <code>local/inputs.conf</code>:</p>
          <pre style="background: #f5f5f5; padding: 15px; border-radius: 4px; overflow-x: auto;">
[method_audit_logs://my_input_name]
index = main
interval = 300
start_time = 2025-01-01 00:00:00
timezone = UTC
base_url = https://api.method.delivery
client_id = YOUR_CLIENT_ID
client_secret = YOUR_CLIENT_SECRET
disabled = 0
          </pre>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
