<dashboard version="1.1" theme="light" hideAppBar="true" hideSplunkBar="true" hideTitle="true" hideEdit="true" script="js/builder.js,js/feedback.js,js/favicon.js" stylesheet="css/brand.css,css/builder.css,css/preview.css,css/footer.css">
  <label>Builder</label>
  <description>Design CSS themes for Splunk classic XML dashboards with live preview. Upgrade to DASH for full export, 15 dashboards, and Gallery.</description>
  <row id="builder_header">
    <html>
    <div class="mb2-appbar">
      <a href="/app/dash_lite/builder" class="mb2-appbar-logo-link">
        <img src="/static/app/dash_lite/mb2/logos/symbol-light.png" alt="MB2" class="mb2-appbar-logo" />
      </a>
      <nav class="mb2-appbar-nav">
        <a href="/app/dash_lite/builder" class="mb2-appbar-nav-item active">Builder</a>
        <a href="/app/dash_lite/documentation" class="mb2-appbar-nav-item">Documentation</a>
        <a href="https://mb2analytics.com/apps/dash" target="_blank" rel="noopener" class="mb2-appbar-nav-item mb2-upgrade-cta">&#x2197; Get Full Version</a>
      </nav>
    </div>
  </html>
  </row>
  <row id="builder_body">
    <html>
    <div id="builder">
      <div id="live_preview" class="feature">
        <div class="style-manager-header">
          <h2>Live Preview</h2>
          <p>
            Preview your CSS theme across real dashboard layouts. Select a use case, navigate dashboards
            with the carousel, and see your style changes reflected instantly.
          </p>
          <a class="btn default" id="toggle_style_manager">Style Manager</a>
          <button id="toggleColors" class="btn default togglegraphcolors-btn">
            Toggle Graph Colors
          </button>
          <button id="enterFullscreenBtn" class="btn default fullscreen-btn">
            &#x2922; Fullscreen
          </button>
          <button id="startFreshBtn" class="btn default" style="display:none;">
            Start Fresh
          </button>
        </div>
        <div class="preview-nav-hint" id="preview_nav_hint">
          Switch between dashboards using the simulated app navbar.
        </div>
        <div id="preview">
          <button id="exitFullscreenBtn" class="close_button">
            <svg xmlns="http://www.w3.org/2000/svg" id="close_fullscreen_svg" focusable="false" height="13.0000px" width="13.0000px" viewBox="0 0 1500 1500" aria-hidden="true" preserveAspectRatio="xMidYMid" data-test="cross">
                <path d="M918.315 750.645L1500 1332.33 1332.33 1500 750.645 918.315 167.67 1500 0 1332.33l581.685-582.975L0 167.67 167.67 0l582.975 581.685L1332.33 0 1500 167.67"/>
              </svg>
          </button>
          <body class="preview_locale-en dashboard-dashboardpage">
            <header role="preview_header">
              <div id="preview_header">
                <div data-view="preview_views/shared/appbar/Master">
                  <div data-view="preview_views/shared/appbar/AppNav">
                    <div data-role="preview_app-nav-container" id="preview_nav_tabs">
                      <!-- Dynamically populated by builder.js -->
                    </div>
                  </div>
                  <div data-view="preview_views/shared/appbar/AppLabel">
                    <a>
                        <div data-role="app-logo" style="display: none;"/>
                        <div class="" data-role="app-name">
                            <div data-role="app-icon">
                            <img src="/static/app/dash_lite/appIcon.png" style="background-color: #0a4f5a;"/>
                          </div>
                            <span class="" data-role="app-label">
                                App Name
                            </span>
                        </div>
                    </a>
                  </div>
                </div>
              </div>
            </header>
            <div class="preview_main-section-body preview_dashboard-body">
              <div class="preview_dashboard preview_view-mode">
                <div class="preview_dashboard-header preview_dashboard-header-dashboardheader preview_has-description" style="display:block !important">
                  <h1 class="preview_dashboard-title preview_dashboard-header-title">Dashboard Title</h1>
                  <p class="preview_description preview_dashboard-header-description">Description</p>
                </div>
                <div class="preview_dashboard-layout-row-column preview_dashboard-layout-rowcolumn-rowcolumnlayout">
                  <div id="dashboard_content">
                    <!-- Dynamically populated by builder.js -->
                  </div>
                </div>
              </div>
            </div>
          </body>
        </div>
      </div>
      <div id="style_manager" class="feature" role="complementary" aria-label="Style Manager">
        <div id="close_button">
          <a id="style_manager_close" class="close_button" role="button" aria-label="Close Style Manager" tabindex="0">
            <svg xmlns="http://www.w3.org/2000/svg" focusable="false" height="13.0000px" width="13.0000px" viewBox="0 0 1500 1500" aria-hidden="true" preserveAspectRatio="xMidYMid" data-test="cross">
                <path d="M918.315 750.645L1500 1332.33 1332.33 1500 750.645 918.315 167.67 1500 0 1332.33l581.685-582.975L0 167.67 167.67 0l582.975 581.685L1332.33 0 1500 167.67"/>
              </svg>
          </a>
        </div>
        <div class="style-manager-header">
          <h2>Style Manager</h2>
          <p>
            Configure your app-wide CSS theme — colors, fonts, logos, and backgrounds.
          </p>
          <button id="undoBtn" class="btn default undo-redo-btn" disabled="disabled" title="Undo (Ctrl+Z)" aria-label="Undo last change">Undo</button>
          <button id="redoBtn" class="btn default undo-redo-btn" disabled="disabled" title="Redo (Ctrl+Y)" aria-label="Redo last change">Redo</button>
        </div>

        <!-- Theme Score — Always visible -->
        <div id="theme_score_container" role="status" aria-live="polite" aria-label="Theme consistency score">
          <div id="theme_score_ring" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="40" height="40">
              <circle cx="20" cy="20" r="17" fill="none" stroke="#eee" stroke-width="3"/>
              <circle id="theme_score_arc" cx="20" cy="20" r="17" fill="none" stroke="#2ca19b" stroke-width="3"
                      stroke-dasharray="0 107" stroke-linecap="round" transform="rotate(-90 20 20)"/>
            </svg>
            <span id="theme_score_value">--</span>
          </div>
          <span id="theme_score_label">Theme Score</span>
        </div>

        <form id="style_manager_form">
          <!-- Tab Bar -->
          <div class="sm-tabs" role="tablist">
            <button type="button" class="sm-tab active" role="tab" data-tab="design" aria-selected="true" aria-controls="sm-panel-design">Design</button>
            <button type="button" class="sm-tab" role="tab" data-tab="tables" aria-selected="false" aria-controls="sm-panel-tables">Tables</button>
            <button type="button" class="sm-tab" role="tab" data-tab="typography" aria-selected="false" aria-controls="sm-panel-typography">Aa</button>
          </div>

          <!-- Upgrade Comparison Card -->
          <div class="sm-upgrade-card" id="sm_upgrade_card">
            <div class="sm-upgrade-card-header" id="sm_upgrade_card_toggle">
              <span class="sm-upgrade-card-label">DASH Lite</span>
              <span class="sm-upgrade-card-action">See full version features &#x25BE;</span>
            </div>
            <div class="sm-upgrade-card-body" id="sm_upgrade_card_body" style="display:none;">
              <table class="sm-upgrade-table">
                <tr><td>Use case templates</td><td class="sm-col-lite">1</td><td class="sm-col-full">3</td></tr>
                <tr><td>Pre-built dashboards</td><td class="sm-col-lite">2</td><td class="sm-col-full">15</td></tr>
                <tr><td>Save &amp; browse designs</td><td class="sm-col-lite">&#x2014;</td><td class="sm-col-full">&#x2713;</td></tr>
                <tr><td>Style existing apps</td><td class="sm-col-lite">&#x2014;</td><td class="sm-col-full">&#x2713;</td></tr>
                <tr><td>Share style configs</td><td class="sm-col-lite">&#x2014;</td><td class="sm-col-full">&#x2713;</td></tr>
                <tr><td>Production CIM queries</td><td class="sm-col-lite">&#x2014;</td><td class="sm-col-full">&#x2713;</td></tr>
              </table>
              <a href="https://mb2analytics.com/apps/dash" target="_blank" rel="noopener" class="upgrade-cta-btn sm-upgrade-card-btn">Get Full Version</a>
            </div>
          </div>

          <!-- ==================== DESIGN TAB ==================== -->
          <div class="sm-tab-panel active" id="sm-panel-design" role="tabpanel" data-tab="design">

            <!-- General -->
            <fieldset>
              <legend>General</legend>
              <div class="general_options">
                <label for="app_title">App Title:</label>
                <input type="text" id="app_title" name="app_title" placeholder="My App"/>
              </div>
              <div class="general_options">
                <label for="use_case">Use Case:</label>
                <select id="use_case" name="use_case">
                  <option value="cybersecurity">Cybersecurity (SIEM)</option>
                  <option value="it_ops" disabled="disabled">IT Operations (5 dashboards) &#8212; Full Version</option>
                  <option value="apm" disabled="disabled">APM (5 dashboards) &#8212; Full Version</option>
                </select>
              </div>
              <div class="sm-locked-hint">
                <span>2 more use cases available</span>
                <a href="https://mb2analytics.com/apps/dash" target="_blank" rel="noopener">See all &#x2197;</a>
              </div>
              <div id="upload_images">
                <div class="general_options">
                  <label for="logo_upload">Logo:</label>
                  <input type="file" id="logo_upload" name="logo_upload" accept="image/*"/>
                </div>
                <div class="general_options">
                  <label for="background_upload">Background Image:</label>
                  <input type="file" id="background_upload" name="background_upload" accept="image/*"/>
                </div>
              </div>
            </fieldset>

            <!-- Color Scheme -->
            <fieldset>
              <legend>Color Scheme</legend>
              <div>
                <label for="color_preset">Preset:</label>
                <select id="color_preset">
                  <option value="">Custom</option>
                </select>
              </div>


              <!-- Primary Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="primary_color" title="Click to change Primary Color">
                  <span class="sm-swatch-preview" data-color="primary_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Primary Color</span>
                </div>
                <input type="color" id="primary_color" name="primary_color" value="#041a27" class="sm-color-input"/>
                <input type="range" id="primary_alpha" name="primary_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Secondary Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="secondary_color" title="Click to change Secondary Color">
                  <span class="sm-swatch-preview" data-color="secondary_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Secondary Color</span>
                </div>
                <input type="color" id="secondary_color" name="secondary_color" value="#0a4f5a" class="sm-color-input"/>
                <input type="range" id="secondary_alpha" name="secondary_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Accent Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="accent_color" title="Click to change Accent Color">
                  <span class="sm-swatch-preview" data-color="accent_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Accent Color</span>
                </div>
                <input type="color" id="accent_color" name="accent_color" value="#107174" class="sm-color-input"/>
                <input type="range" id="accent_alpha" name="accent_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Background Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="background_color" title="Click to change Background Color">
                  <span class="sm-swatch-preview" data-color="background_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Background Color</span>
                </div>
                <input type="color" id="background_color" name="background_color" value="#ffffff" class="sm-color-input"/>
                <input type="range" id="background_alpha" name="background_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Foreground Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="foreground_color" title="Click to change Foreground Color">
                  <span class="sm-swatch-preview" data-color="foreground_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Foreground Color</span>
                </div>
                <input type="color" id="foreground_color" name="foreground_color" value="#ffffff" class="sm-color-input"/>
                <input type="range" id="foreground_alpha" name="foreground_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Font Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="font_color" title="Click to change Font Color">
                  <span class="sm-swatch-preview" data-color="font_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Font Color</span>
                </div>
                <input type="color" id="font_color" name="font_color" value="#8dd6d1" class="sm-color-input"/>
                <input type="range" id="font_alpha" name="font_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Navbar Font Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="navbar_font_color" title="Click to change Navbar Font Color">
                  <span class="sm-swatch-preview" data-color="navbar_font_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Navbar Font Color</span>
                </div>
                <input type="color" id="navbar_font_color" name="navbar_font_color" value="#8dd6d1" class="sm-color-input"/>
                <input type="range" id="navbar_font_alpha" name="navbar_font_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>
            </fieldset>
          </div>

          <!-- ==================== TABLES TAB ==================== -->
          <div class="sm-tab-panel" id="sm-panel-tables" role="tabpanel" data-tab="tables">
            <fieldset>
              <legend>Tables Color Scheme</legend>

              <!-- Table Primary Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="table_primary_color" title="Click to change Table Primary Color">
                  <span class="sm-swatch-preview" data-color="table_primary_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Header Background</span>
                </div>
                <input type="color" id="table_primary_color" name="table_primary_color" value="#e1e6eb" class="sm-color-input"/>
                <input type="range" id="table_primary_alpha" name="table_primary_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Table Secondary Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="table_secondary_color" title="Click to change Table Secondary Color">
                  <span class="sm-swatch-preview" data-color="table_secondary_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Row Background</span>
                </div>
                <input type="color" id="table_secondary_color" name="table_secondary_color" value="#ffffff" class="sm-color-input"/>
                <input type="range" id="table_secondary_alpha" name="table_secondary_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Table Accent Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="table_accent_color" title="Click to change Table Accent Color">
                  <span class="sm-swatch-preview" data-color="table_accent_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Header Text</span>
                </div>
                <input type="color" id="table_accent_color" name="table_accent_color" value="#3c444d" class="sm-color-input"/>
                <input type="range" id="table_accent_alpha" name="table_accent_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>

              <!-- Table Border Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="table_border_color" title="Click to change Table Border Color">
                  <span class="sm-swatch-preview" data-color="table_border_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Cell Borders</span>
                </div>
                <input type="color" id="table_border_color" name="table_border_color" value="#ffffff" class="sm-color-input"/>
              </div>

              <!-- Table Font Color -->
              <div class="sm-color-card">
                <label class="sm-color-swatch" for="table_font_color" title="Click to change Table Font Color">
                  <span class="sm-swatch-preview" data-color="table_font_color"></span>
                </label>
                <div class="sm-color-info">
                  <span class="sm-color-label">Body Text</span>
                </div>
                <input type="color" id="table_font_color" name="table_font_color" value="#737373" class="sm-color-input"/>
                <input type="range" id="table_font_alpha" name="table_font_alpha" class="colors_alpha" min="0" max="1" step="0.01" value="1"/>
              </div>
            </fieldset>
          </div>

          <!-- ==================== TYPOGRAPHY TAB ==================== -->
          <div class="sm-tab-panel" id="sm-panel-typography" role="tabpanel" data-tab="typography">
            <fieldset>
              <legend>Typography</legend>
              <div>
                <label for="font_family">Font Family:</label>
                <select id="font_family" name="font_family">
                  <option value="unset">Default (Splunk)</option>
                  <option value="Arial" style="font-family: Arial;">Arial</option>
                  <option value="Helvetica" style="font-family: Helvetica;">Helvetica</option>
                  <option value="Verdana" style="font-family: Verdana;">Verdana</option>
                  <option value="Tahoma" style="font-family: Tahoma;">Tahoma</option>
                  <option value="'Trebuchet MS'" style="font-family: 'Trebuchet MS';">Trebuchet MS</option>
                  <option value="'Times New Roman'" style="font-family: 'Times New Roman';">Times New Roman</option>
                  <option value="Georgia" style="font-family: Georgia;">Georgia</option>
                  <option value="'Courier New'" style="font-family: 'Courier New';">Courier New</option>
                  <option value="'Lucida Console'" style="font-family: 'Lucida Console';">Lucida Console</option>
                </select>
              </div>
              <div>
                <label for="title_font_size">Title Font Size (px):</label>
                <input type="number" id="title_font_size" name="title_font_size" value="24" min="8" max="72"/>
              </div>
              <div>
                <label for="subtitle_font_size">Subtitle Font Size (px):</label>
                <input type="number" id="subtitle_font_size" name="subtitle_font_size" value="18" min="8" max="72"/>
              </div>
              <div>
                <label for="paragraph_font_size">Paragraph Font Size (px):</label>
                <input type="number" id="paragraph_font_size" name="paragraph_font_size" value="14" min="8" max="72"/>
              </div>
            </fieldset>
          </div>

          <!-- Sticky Action Bar -->
          <div class="sm-sticky-actions">
            <div id="announcements"/>
            <a class="btn primary" id="create_style_button">Create Styled App</a>
            <div class="sm-upgrade-bar">
              <p class="sm-upgrade-text">You're using DASH Lite &#8212; 1 use case, 2 dashboards.</p>
              <a href="https://mb2analytics.com/apps/dash" target="_blank" rel="noopener" class="btn primary upgrade-cta-btn">Unlock 15 Dashboards</a>
            </div>
          </div>
        </form>
</div>
    </div>
  </html>
  </row>
  <row id="builder_footer">
    <html>
      <div class="dash-footer" role="contentinfo">
        <p>Having issues with styles not updating? Try <a href="/_bump" target="_blank">clearing Splunk cache (bump)</a>, <a href="#" id="dash_hard_refresh">hard-refreshing the page</a>, or check the <a href="/app/dash_lite/documentation">Documentation</a> for troubleshooting tips.</p>
        <div class="footer-actions">
          <a class="btn default" id="open_feedback_form">Feedback</a>
        </div>
        <div class="footer-brand">
          <a href="https://mb2analytics.com" target="_blank" rel="noopener" class="footer-brand-link">
            <img src="/static/app/dash_lite/mb2/logos/symbol-dark.png" alt="MB2 Analytics" class="footer-brand-logo" />
            <span>mb2analytics.com</span>
          </a>
        </div>
      </div>
    </html>
  </row>
</dashboard>
