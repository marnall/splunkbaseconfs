<dashboard version="1.1" theme="light" script="cim_mapper.js" stylesheet="cim_mapper.css">
  <label>CIM Mapper</label>
  <description>Manage Splunk CIM field mappings for Nexthink data</description>
  
  <row>
    <panel>
      <html>
        <div class="cim-mapper-container">
          
          <!-- Existing Mappings Section -->
          <div class="cim-section">
            <h3>Existing CIM Mappings</h3>
            <p>View, edit, or delete existing CIM field mappings.</p>
            <table id="existing-mappings-table">
              <thead>
                <tr>
                  <th>Sourcetype</th>
                  <th>Fields</th>
                  <th>Mappings</th>
                  <th>Tags</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="existing-mappings-body">
                <tr><td colspan="5" class="text-center">Loading...</td></tr>
              </tbody>
            </table>
          </div>
          
          <!-- Create/Edit Form Section -->
          <div class="cim-section" id="form-section">
            <h3 id="form-title">Create New CIM Mapping</h3>
            
            <div class="form-group">
              <label>Sourcetype Suffix (nexthink:_____)</label>
              <input type="text" id="sourcetype-suffix" placeholder="e.g., alerts, inventory" />
            </div>
            
            <div class="form-group">
              <label><input type="checkbox" id="enable-cim" checked="checked" /> Enable CIM Mapping</label>
            </div>
            
            <button type="button" class="btn btn-secondary" id="cancel-edit-btn" style="display:none;">Cancel Edit</button>
          </div>
          
          <!-- NQL Query Section -->
          <div class="cim-section">
            <h3>Parse NQL Query (Optional)</h3>
            <p>Paste your NQL query to automatically extract field names, or add fields manually below.</p>
            <div class="form-group">
              <textarea id="nql-query" placeholder="devices | list device.name, device.entity, device.operating_system.name"></textarea>
            </div>
            <button type="button" class="btn btn-primary" id="parse-fields-btn">Parse Fields</button>
            <div id="parse-result" class="hidden"></div>
          </div>
          
          <!-- Mapping Section -->
          <div class="cim-section" id="mapping-section" style="display: none;">
            <h3>Field Mappings</h3>
            <p>Map Nexthink fields to CIM fields and assign tags.</p>
            <table id="cim-mapping-table">
              <thead>
                <tr>
                  <th>Source Field (Nexthink)</th>
                  <th>CIM Target Field</th>
                  <th>CIM Tags</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="mapping-tbody"></tbody>
            </table>
            <div style="margin-top: 15px;">
              <button type="button" class="btn btn-secondary" id="add-field-btn">+ Add Field Manually</button>
            </div>
          </div>
          
          <!-- Preview Section -->
          <div class="cim-section" id="preview-section" style="display: none;">
            <h3>Preview and Save</h3>
            <div class="form-group">
              <label>Event Preview</label>
              <pre id="cim-preview">// Configure mappings to see preview</pre>
            </div>
            <div class="form-group">
              <label>Mappings JSON</label>
              <textarea id="mappings-json" readonly="readonly"></textarea>
            </div>
            <button type="button" class="btn btn-primary" id="save-mappings-btn">Save CIM Mappings</button>
            <div id="save-result" class="hidden"></div>
          </div>
          
        </div>
      </html>
    </panel>
  </row>
</dashboard>
