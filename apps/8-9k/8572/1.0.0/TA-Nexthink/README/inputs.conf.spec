[nexthink_nql://<name>]
account = Select the Nexthink account to use.
index = (Default: main)
interval = Collection interval in seconds. Minimum: 1 second. (Default: 300)
query_id = The NQL API Query ID from Nexthink (e.g., '#splunk_alerts'). Must start with #.
sourcetype_suffix = Enter a UNIQUE sourcetype suffix. Full sourcetype will be 'nexthink:{your_value}'. (Default: nql)
