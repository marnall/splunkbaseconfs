<dashboard version="1.1" script="embedder_config.js" stylesheet="embedder_config.css">
  <label>Configure Embedding</label>
  <description>Configure native embedding settings and legacy inputs (embedder://)</description>
  
  <row>
    <panel>
      <title>Embedding Configuration</title>
      <html>
        <div id="embedder-config-container">
          <div class="embedder-header">
            <h2>Embedding Inputs (Legacy)</h2>
            <button id="embedder-add-btn" class="btn btn-primary">Add New Input</button>
          </div>
          
          <div id="embedder-loading" class="embedder-loading" style="display: none;">
            <span>Loading...</span>
          </div>
          
          <div id="embedder-error" class="embedder-error" style="display: none;"></div>

          <div class="embedder-embed-settings">
            <h3>Embedding Headers</h3>
            <p>Allow Splunk dashboards to render in iframes by updating Splunk Web headers.</p>
            <div class="embedder-embed-actions">
              <button id="embedder-headers-enable" class="btn btn-success">Enable embedding headers</button>
              <button id="embedder-headers-disable" class="btn btn-warning">Disable embedding headers</button>
            </div>
            <div id="embedder-headers-status" class="embedder-cookie-status"></div>
            <div class="embedder-embed-note">Restart Splunk after changing this setting.</div>

            <div class="embedder-embed-divider"></div>

            <h3>Embedding Cookie Mode</h3>
            <p>Set cookieSameSite for your Splunk Web protocol. Use "none" for HTTPS embedding, "not_specified" for HTTP logins.</p>
            <div class="embedder-embed-actions">
              <button id="embedder-cookie-https-btn" class="btn btn-success">Enable HTTPS embedding</button>
              <button id="embedder-cookie-http-btn" class="btn btn-warning">Allow HTTP login</button>
            </div>
            <div id="embedder-cookie-status" class="embedder-cookie-status"></div>
            <div class="embedder-embed-note">Restart Splunk after changing this setting.</div>

            <div class="embedder-embed-divider"></div>

            <h3>Secure Session Cookies (Reverse Proxy)</h3>
            <p>Use when TLS is terminated at a reverse proxy (nginx) to force Secure cookies.</p>
            <div class="embedder-embed-actions">
              <button id="embedder-secure-cookies-on" class="btn btn-success">Force Secure cookies</button>
              <button id="embedder-secure-cookies-off" class="btn btn-warning">Allow insecure cookies</button>
            </div>
            <div id="embedder-secure-cookies-status" class="embedder-cookie-status"></div>
            <div class="embedder-embed-note">Restart Splunk after changing this setting.</div>
          </div>
          
          <div id="embedder-inputs-list" class="embedder-inputs-list"></div>
          
          <!-- Add/Edit Modal -->
          <div id="embedder-modal" class="embedder-modal" style="display: none;">
            <div class="embedder-modal-content">
              <div class="embedder-modal-header">
                <h3 id="embedder-modal-title">Add Legacy Input</h3>
                <span class="embedder-modal-close">&#215;</span>
              </div>
              <div class="embedder-modal-body">
                <form id="embedder-input-form">
                  <div class="embedder-form-group">
                    <label for="embedder-input-name">Input Name *</label>
                    <input type="text" id="embedder-input-name" name="name" required="required" />
                    <small>Unique name for this input (e.g., "production_dashboard")</small>
                  </div>
                  
                  <!-- v3.0.0: Legacy Fields Removed (Native Embedding Mode) -->
                  <!-- Only Name is required for the placeholder input -->
                  
                  <div class="embedder-form-group">
                    <label for="embedder-disabled">Disabled</label>
                    <input type="checkbox" id="embedder-disabled" name="disabled" value="1" />
                    <small>Check to disable this input</small>
                  </div>
                  
                  <div class="embedder-form-actions">
                    <button type="button" id="embedder-save-btn" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-secondary embedder-modal-cancel">Cancel</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
