# Splunk Native Embedder Metadata Configuration
# Defines permissions and export settings for app components

# Application-level permissions
[]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = system

# Authorization config - must export to system
[authorize]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Modular input permissions
[inputs/embedder]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = system

# Data inputs - this is critical for the REST endpoint
[data/inputs/embedder]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = system

# REST endpoint permissions
[admin:embedder]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = system

[admin_external:embedder]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = system

# Script permissions
[script:embedder]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = system

# Views permissions
[views]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Navigation permissions
[nav]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# REST map
[restmap]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Web conf
[web]
access = read : [ * ], write : [ admin, sc_admin ]
export = system
