[userful_proxy://default]
*This is how the Userful proxy is configured

username = <value>
*This is the user that will connect to Splunk

connect_from = <value>
*This is the IP that is allowed to connect

port = <value>
*This is the port that is listening for connections

index = <value>
*Index to write proxy access logs (optional)

sourcetype = <value>
*Sourcetype for proxy access logs (optional)

python.version = <value>
*Runtime for the modular input (defaults to python3)
