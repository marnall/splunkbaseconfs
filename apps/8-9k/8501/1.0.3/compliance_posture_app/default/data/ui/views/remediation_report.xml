<dashboard version="1.1" theme="dark" hideTimeRangePicker="true">
  <label>Remediation Report</label>
  <description>Failed rules requiring remediation, grouped by benchmark section — shows latest scan per host/benchmark/profile only</description>

  <!-- BASE SEARCH: runs once, all panels post-process from this -->
  <search id="base_latest">
    <query>`ciscat_latest` | fields *</query>
    <earliest>0</earliest>
    <latest>now</latest>
  </search>

  <fieldset submitButton="false">
    <input type="dropdown" token="selected_host" searchWhenChanged="true">
      <label>Host</label>
      <choice value="*">All Hosts</choice>
      <default>*</default>
      <fieldForLabel>asset_hostname</fieldForLabel>
      <fieldForValue>asset_hostname</fieldForValue>
      <search base="base_latest">
        <query>| dedup asset_hostname | sort asset_hostname | table asset_hostname</query>
      </search>
    </input>
    <input type="dropdown" token="selected_benchmark" searchWhenChanged="true">
      <label>Benchmark</label>
      <choice value="*">All Benchmarks</choice>
      <default>*</default>
      <fieldForLabel>benchmark_title</fieldForLabel>
      <fieldForValue>benchmark_title</fieldForValue>
      <search base="base_latest">
        <query>| dedup benchmark_title | sort benchmark_title | table benchmark_title</query>
      </search>
    </input>
    <input type="dropdown" token="selected_result" searchWhenChanged="true">
      <label>Result Type</label>
      <choice value="(result=&quot;fail&quot; OR result=&quot;error&quot;)">Fail + Error</choice>
      <choice value="result=&quot;fail&quot;">Fail Only</choice>
      <choice value="result=&quot;error&quot;">Error Only</choice>
      <default>(result="fail" OR result="error")</default>
    </input>
  </fieldset>

  <!-- Row 1: Summary KPIs -->
  <row>
    <panel>
      <title>Total Failed Rules</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" $selected_result$ | stats count</query>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0x65a637","0xf7bc38","0xd93f3c"]</option>
        <option name="rangeValues">[0,25]</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Fail</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" result="fail" | stats count</query>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0x65a637","0xf7bc38","0xd93f3c"]</option>
        <option name="rangeValues">[0,15]</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Check Errors</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" result="error" | stats count</query>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0x65a637","0xf7bc38"]</option>
        <option name="rangeValues">[0]</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Sections with Failures</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" $selected_result$ | stats dc(rule_section)</query>
        </search>
        <option name="drilldown">none</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Affected Hosts</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" $selected_result$ | stats dc(asset_hostname)</query>
        </search>
        <option name="drilldown">none</option>
        <option name="height">120</option>
      </single>
    </panel>
  </row>

  <!-- Row 2: Failed Rules by Section (bar) -->
  <row>
    <panel>
      <title>Failed Rules by Benchmark Section</title>
      <chart>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" $selected_result$
| stats count by section_label
| sort - count</query>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.axisTitleX.text">Failed Rules</option>
        <option name="height">300</option>
      </chart>
    </panel>
    <panel>
      <title>Failures by Host</title>
      <chart>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" $selected_result$
| stats count by asset_hostname
| sort - count
| rename asset_hostname AS Host</query>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">none</option>
        <option name="height">300</option>
      </chart>
    </panel>
  </row>

  <!-- Row 3: Section Summary Table -->
  <row>
    <panel>
      <title>Failure Summary by Section</title>
      <table>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" $selected_result$
| stats count(eval(result="fail")) AS Fail,
        count(eval(result="error")) AS Error,
        count AS Total,
        dc(asset_hostname) AS Hosts
  by section_label, benchmark_title
| rename section_label AS Section, benchmark_title AS Benchmark
| sort - Total</query>
        </search>
        <option name="drilldown">row</option>
        <option name="count">20</option>
        <format type="color" field="Total">
          <colorPalette type="minMidMax" minColor="#FFFFFF" midColor="#F7BC38" maxColor="#D93F3C"></colorPalette>
          <scale type="minMidMax" minValue="0" midValue="5" maxValue="15"></scale>
        </format>
        <format type="color" field="Error">
          <colorPalette type="minMidMax" minColor="#FFFFFF" midColor="#F7BC38" maxColor="#D93F3C"></colorPalette>
          <scale type="minMidMax" minValue="0" midValue="1" maxValue="5"></scale>
        </format>
      </table>
    </panel>
  </row>

  <!-- Row 4: Remediation Detail Table — all failed rules grouped by section -->
  <row>
    <panel>
      <title>Remediation Detail — Failed Rules by Section</title>
      <table>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" $selected_result$
| eval Result=case(result=="fail", "Fail", result=="error", "Error — Check Failed to Execute", true(), result)
| table section_label, rule_id, rule_title, Result, asset_hostname, benchmark_title, profile
| rename section_label AS Section, rule_id AS "Rule ID", rule_title AS "Rule Title", asset_hostname AS Host, benchmark_title AS Benchmark, profile AS Profile
| sort Section, "Rule ID", Host</query>
        </search>
        <option name="drilldown">none</option>
        <option name="count">50</option>
        <option name="wrap">true</option>
        <format type="color" field="Result">
          <colorPalette type="map">{"Fail": "#D93F3C", "Error — Check Failed to Execute": "#F7BC38"}</colorPalette>
        </format>
      </table>
    </panel>
  </row>

</dashboard>
