<dashboard version="1.1" theme="dark" hideTimeRangePicker="true">
  <label>CIS Benchmark Overview</label>
  <description>Host-level CIS Benchmark compliance status — shows latest scan per host/benchmark/profile only</description>

  <!-- BASE SEARCH: runs once, all panels post-process from this -->
  <search id="base_latest">
    <query>`ciscat_latest` | fields *</query>
    <earliest>0</earliest>
    <latest>now</latest>
  </search>

  <fieldset submitButton="false">
    <input type="dropdown" token="selected_host" searchWhenChanged="true">
      <label>Host</label>
      <choice value="*">All Hosts</choice>
      <default>*</default>
      <fieldForLabel>asset_hostname</fieldForLabel>
      <fieldForValue>asset_hostname</fieldForValue>
      <search base="base_latest">
        <query>| dedup asset_hostname | sort asset_hostname | table asset_hostname</query>
      </search>
    </input>
    <input type="dropdown" token="selected_benchmark" searchWhenChanged="true">
      <label>Benchmark</label>
      <choice value="*">All Benchmarks</choice>
      <default>*</default>
      <fieldForLabel>benchmark_title</fieldForLabel>
      <fieldForValue>benchmark_title</fieldForValue>
      <search base="base_latest">
        <query>| dedup benchmark_title | sort benchmark_title | table benchmark_title</query>
      </search>
    </input>
    <input type="dropdown" token="selected_profile" searchWhenChanged="true">
      <label>Profile</label>
      <choice value="*">All Profiles</choice>
      <default>*</default>
      <fieldForLabel>profile</fieldForLabel>
      <fieldForValue>profile</fieldForValue>
      <search base="base_latest">
        <query>| dedup profile | sort profile | table profile</query>
      </search>
    </input>
  </fieldset>

  <!-- Row 1: KPI Singles -->
  <row>
    <panel>
      <title>Total Rules</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$" | stats count</query>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">none</option>
        <option name="useColors">0</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Pass</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$" result="pass" | stats count</query>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0x65a637","0x65a637"]</option>
        <option name="rangeValues">[0]</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Fail</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$" (result="fail" OR result="error") | stats count</query>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0x65a637","0xf7bc38","0xd93f3c"]</option>
        <option name="rangeValues">[0,25]</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Compliance Score</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$" | stats mean(compliance_score) AS score | eval score=round(score,1) | table score</query>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0.0</option>
        <option name="unit">%</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeColors">["0xd93f3c","0xf7bc38","0x65a637"]</option>
        <option name="rangeValues">[60,80]</option>
        <option name="height">120</option>
      </single>
    </panel>
    <panel>
      <title>Excluded (N/A + Manual)</title>
      <single>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$" (result="notapplicable" OR result="informational" OR rule_weight=0) | stats count</query>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">none</option>
        <option name="useColors">0</option>
        <option name="height">120</option>
      </single>
    </panel>
  </row>

  <!-- Row 2: Charts -->
  <row>
    <panel>
      <title>Results by Status</title>
      <chart>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$"
| eval result_display=case(
    result=="pass", "Pass",
    result=="fail", "Fail",
    result=="error", "Error",
    result=="notapplicable", "Not Applicable",
    result=="informational", "Manual Review",
    true(), result)
| stats count by result_display</query>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.showPercent">true</option>
        <option name="charting.fieldColors">{"Pass": 0x65A637, "Fail": 0xD93F3C, "Error": 0xF7BC38, "Not Applicable": 0x6DB7C6, "Manual Review": 0x8E929B}</option>
        <option name="charting.drilldown">none</option>
        <option name="height">280</option>
      </chart>
    </panel>
    <panel>
      <title>Failed Rules by Benchmark Section</title>
      <chart>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$" (result="fail" OR result="error")
| stats count by section_label
| sort - count
| head 10</query>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.axisTitleX.text">Failed Rules</option>
        <option name="height">280</option>
      </chart>
    </panel>
    <panel>
      <title>Compliance Score by Benchmark</title>
      <chart>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$"
| stats mean(compliance_score) AS score by benchmark_title
| eval score=round(score, 1)
| sort - score
| rename benchmark_title AS Benchmark, score AS "Compliance Score %"</query>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.axisTitleX.text">Compliance Score %</option>
        <option name="charting.axisY.minimumNumber">0</option>
        <option name="charting.axisY.maximumNumber">100</option>
        <option name="height">280</option>
      </chart>
    </panel>
  </row>

  <!-- Row 3: Compliance by Host + Benchmark table -->
  <row>
    <panel>
      <title>Compliance by Host and Benchmark</title>
      <table>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$"
| stats max(compliance_score) AS "Compliance Score %",
        count(eval(result="pass")) AS Pass,
        count(eval(result="fail")) AS Fail,
        count(eval(result="error")) AS Error,
        count(eval(result="notapplicable" OR result="informational")) AS Excluded,
        count AS Total
  by asset_hostname, asset_ip, benchmark_title, profile
| eval "Compliance Score %"=round('Compliance Score %', 1)
| rename asset_hostname AS Host, asset_ip AS "IP Address", benchmark_title AS Benchmark, profile AS Profile
| sort - "Compliance Score %"</query>
        </search>
        <option name="drilldown">row</option>
        <option name="count">20</option>
        <format type="color" field="Compliance Score %">
          <colorPalette type="minMidMax" minColor="#D93F3C" midColor="#F7BC38" maxColor="#65A637"></colorPalette>
          <scale type="minMidMax" minValue="60" midValue="80" maxValue="100"></scale>
        </format>
        <format type="color" field="Fail">
          <colorPalette type="minMidMax" minColor="#FFFFFF" midColor="#F7BC38" maxColor="#D93F3C"></colorPalette>
          <scale type="minMidMax" minValue="0" midValue="10" maxValue="30"></scale>
        </format>
        <format type="color" field="Error">
          <colorPalette type="minMidMax" minColor="#FFFFFF" midColor="#F7BC38" maxColor="#D93F3C"></colorPalette>
          <scale type="minMidMax" minValue="0" midValue="1" maxValue="5"></scale>
        </format>
      </table>
    </panel>
  </row>

  <!-- Row 4: Failed Rules Detail -->
  <row>
    <panel>
      <title>Failed Rules Detail</title>
      <input type="dropdown" token="sort_failed_by" searchWhenChanged="true">
        <label>Sort By</label>
        <choice value="section_label">Section</choice>
        <choice value="asset_hostname">Host</choice>
        <choice value="benchmark_title">Benchmark</choice>
        <default>section_label</default>
      </input>
      <table>
        <search base="base_latest">
          <query>| search asset_hostname="$selected_host$" benchmark_title="$selected_benchmark$" profile="$selected_profile$" (result="fail" OR result="error")
| eval Result=case(result=="fail", "Fail", result=="error", "Error", true(), result)
| table asset_hostname, benchmark_title, profile, section_label, rule_id, rule_title, Result
| rename asset_hostname AS Host, benchmark_title AS Benchmark, profile AS Profile, section_label AS Section, rule_id AS "Rule ID", rule_title AS "Rule Title"
| sort $sort_failed_by$, Host, "Rule ID"</query>
        </search>
        <option name="drilldown">none</option>
        <option name="count">25</option>
        <option name="wrap">true</option>
        <format type="color" field="Result">
          <colorPalette type="map">{"Fail": "#D93F3C", "Error": "#F7BC38"}</colorPalette>
        </format>
      </table>
    </panel>
  </row>

</dashboard>
