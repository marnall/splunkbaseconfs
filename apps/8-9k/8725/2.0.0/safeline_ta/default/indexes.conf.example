#
# Optional: dedicated index for SafeLine WAF events.
# Copy to your indexer's etc/system/local/indexes.conf or a separate index app.
# Do NOT enable this in a Search Head.
#

[waf]
homePath   = $SPLUNK_DB/waf/db
coldPath   = $SPLUNK_DB/waf/colddb
thawedPath = $SPLUNK_DB/waf/thaweddb
maxTotalDataSizeMB     = 102400
frozenTimePeriodInSecs = 7776000
