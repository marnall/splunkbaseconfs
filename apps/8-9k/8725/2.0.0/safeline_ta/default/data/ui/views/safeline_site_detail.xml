<form version="1.1" theme="dark">
  <label>SafeLine â€” Per-Site Deep Dive</label>
  <description>Pick one vhost and see everything: traffic, attacks, latency, attackers, paths.</description>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="tr">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="site_tok" searchWhenChanged="true">
      <label>Site (vhost)</label>
      <fieldForLabel>site_name</fieldForLabel>
      <fieldForValue>site_name</fieldForValue>
      <search>
        <query>`safeline_waf` site_url=* | stats count by site_name site_url site_uuid | sort - count</query>
        <earliest>$tr.earliest$</earliest>
        <latest>$tr.latest$</latest>
      </search>
      <default>*</default>
      <change>
        <condition match="$value$ == &quot;*&quot;">
          <set token="site_filter">site_url=*</set>
          <set token="site_label">All sites</set>
        </condition>
        <condition>
          <set token="site_filter">site_name="$value$"</set>
          <set token="site_label">$value$</set>
        </condition>
      </change>
    </input>
  </fieldset>

  <!-- Site identity -->
  <row>
    <panel depends="$site_filter$">
      <html>
        <h2 style="margin:0">$site_label$</h2>
      </html>
    </panel>
    <panel>
      <single>
        <title>site_uuid</title>
        <search>
          <query>`safeline_waf` $site_filter$ | stats values(site_uuid) AS u | eval u=mvjoin(u,", ")</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Configured URL</title>
        <search>
          <query>`safeline_waf` $site_filter$ | stats values(site_url) AS u | eval u=mvjoin(u,", ")</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </single>
    </panel>
  </row>

  <!-- KPI row -->
  <row>
    <panel>
      <single>
        <title>Requests</title>
        <search>
          <query>`safeline_waf` $site_filter$ | stats count</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Attacks</title>
        <search>
          <query>`safeline_waf` $site_filter$ is_attack=1 | stats count</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="rangeColors">["0x55c98f","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[1,100]</option>
        <option name="useColors">1</option>
        <option name="colorMode">block</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Blocked</title>
        <search>
          <query>`safeline_waf` $site_filter$ blocked=1 | stats count</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="rangeColors">["0x55c98f","0xdc4e41"]</option>
        <option name="rangeValues">[1]</option>
        <option name="useColors">1</option>
        <option name="colorMode">block</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Block rate (%)</title>
        <search>
          <query>`safeline_waf` $site_filter$ | stats count(eval(blocked=1)) AS b count | eval rate=round(b/count*100,1) | fields rate</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="unit">%</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Unique sources</title>
        <search>
          <query>`safeline_waf` $site_filter$ | stats dc(src_ip)</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Distinct paths</title>
        <search>
          <query>`safeline_waf` $site_filter$ | stats dc(urlpath)</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Avg latency (ms)</title>
        <search>
          <query>`safeline_waf` $site_filter$ total_duration_ms=* | stats avg(total_duration_ms) AS m | eval m=round(m,1)</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>P95 latency (ms)</title>
        <search>
          <query>`safeline_waf` $site_filter$ total_duration_ms=* | stats perc95(total_duration_ms) AS m | eval m=round(m,1)</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </single>
    </panel>
  </row>

  <!-- Time series -->
  <row>
    <panel>
      <chart>
        <title>Traffic by action</title>
        <search>
          <query>`safeline_waf` $site_filter$ | timechart count by action_cim</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.fieldColors">{"allowed":0x55c98f,"blocked":0xdc4e41}</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Attacks by severity</title>
        <search>
          <query>`safeline_waf` $site_filter$ is_attack=1 | timechart count by severity</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.fieldColors">{"critical":0x9c1f1f,"high":0xdc4e41,"medium":0xf1813f,"low":0xf8be34,"informational":0x6db7c6}</option>
      </chart>
    </panel>
  </row>

  <!-- Top breakdowns -->
  <row>
    <panel>
      <chart>
        <title>Top 10 source IPs</title>
        <search>
          <query>`safeline_waf` $site_filter$ | top limit=10 src_ip</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <drilldown>
          <link><![CDATA[search?q=`safeline_waf` $site_filter$ src_ip="$row.src_ip$"&earliest=$tr.earliest$&latest=$tr.latest$]]></link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Top countries</title>
        <search>
          <query>`safeline_waf` $site_filter$ src_country=* | top limit=10 src_country</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Attack types hitting this site</title>
        <search>
          <query>`safeline_waf` $site_filter$ is_attack=1 | top limit=10 attack_type</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>Status code mix</title>
        <search>
          <query>`safeline_waf` $site_filter$
| eval status_class = case(status_code&lt;200,"1xx",status_code&lt;300,"2xx",status_code&lt;400,"3xx",status_code&lt;500,"4xx",status_code&gt;=500,"5xx")
| timechart count by status_class</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.fieldColors">{"2xx":0x55c98f,"3xx":0x6db7c6,"4xx":0xf1813f,"5xx":0xdc4e41,"1xx":0xb3b3b3}</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Latency percentiles (ms)</title>
        <search>
          <query>`safeline_waf` $site_filter$ total_duration_ms=*
| timechart perc50(total_duration_ms) AS p50 perc90(total_duration_ms) AS p90 perc95(total_duration_ms) AS p95 perc99(total_duration_ms) AS p99</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>
  </row>

  <!-- Detail tables -->
  <row>
    <panel>
      <table>
        <title>Top URL paths</title>
        <search>
          <query>`safeline_waf` $site_filter$
| stats count AS hits
        count(eval(is_attack=1)) AS attacks
        count(eval(blocked=1)) AS blocked
        count(eval(status_code&gt;=400)) AS errors
        avg(total_duration_ms) AS avg_ms
        perc95(total_duration_ms) AS p95_ms
        dc(src_ip) AS sources
        values(method) AS methods
        by urlpath
| eval avg_ms=round(avg_ms,1), p95_ms=round(p95_ms,1)
| sort - hits
| head 30</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="drilldown">cell</option>
        <drilldown>
          <link><![CDATA[search?q=`safeline_waf` $site_filter$ urlpath="$row.urlpath$"&earliest=$tr.earliest$&latest=$tr.latest$]]></link>
        </drilldown>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <title>Top attackers (this site)</title>
        <search>
          <query>`safeline_waf` $site_filter$ is_attack=1
| stats count AS attacks
        count(eval(blocked=1)) AS blocked
        dc(attack_type) AS distinct_types
        values(attack_type) AS attack_types
        values(severity) AS severities
        latest(_time) AS last_seen
        by src_ip src_country src_city
| eval last_seen=strftime(last_seen,"%F %T")
| sort - attacks
| head 25</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top user agents</title>
        <search>
          <query>`safeline_waf` $site_filter$ user_agent=*
| stats count AS hits dc(src_ip) AS sources count(eval(is_attack=1)) AS attacks by user_agent
| sort - hits | head 25</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <title>Recent events</title>
        <search>
          <query>`safeline_waf` $site_filter$
| sort - _time
| head 100
| table _time src_ip src_country method urlpath status_code attack_type severity action rule_id total_duration_ms user_agent</query>
          <earliest>$tr.earliest$</earliest>
          <latest>$tr.latest$</latest>
        </search>
        <option name="count">25</option>
      </table>
    </panel>
  </row>

</form>
