#
# SafeLine WAF — sample inputs.
#
# DO NOT install these stanzas on a Splunk Cloud search head — Splunk Cloud
# rejects tcp://, udp://, and monitor:// inputs in apps. Inputs belong on a
# Heavy Forwarder (or a dedicated syslog server forwarding via HEC).
#
# To use:
#   1. On your Heavy Forwarder, create $SPLUNK_HOME/etc/apps/safeline_ta/local/inputs.conf
#   2. Copy the stanza that matches how SafeLine ships logs to you
#   3. Remove `disabled = true` and adjust port/path as needed
#   4. Restart the forwarder
#

# --- UDP syslog (RFC5424 — SafeLine's default output) ---
[udp://514]
disabled               = true
sourcetype             = safeline:waf
index                  = waf
no_appending_timestamp = true
connection_host        = ip
host                   = $decideOnStartup

# --- TCP syslog ---
[tcp://1514]
disabled               = true
sourcetype             = safeline:waf
index                  = waf
no_appending_timestamp = true
connection_host        = ip
host                   = $decideOnStartup

# --- File monitor (if SafeLine writes to a local file) ---
[monitor:///var/log/safeline/*.log]
disabled   = true
sourcetype = safeline:waf
index      = waf
host       = $decideOnStartup
