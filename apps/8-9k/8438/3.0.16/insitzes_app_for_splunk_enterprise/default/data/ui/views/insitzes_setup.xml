<dashboard version="1.1" theme="dark" script="insitzes_setup_3_0_16.js" stylesheet="insitzes_setup_3_0_16.css">
    <label>Setup</label>

    <row>
        <panel>
            <html>
                <div id="insitzes-setup-container">
                    <div class="setup-header">
                        <h2>Setup</h2>
                        <p>Configure the app for your Splunk Enterprise environment. Settings are saved to <code>local/macros.conf</code> and take effect immediately.</p>
                    </div>
                    <div id="setup-message" class="setup-message" style="display:none;"></div>

                    <div class="setup-section">
                        <h3>Feature Toggles</h3>
                        <div class="setup-field">
                            <label for="insitzes_has_wlm">Workload Management</label>
                            <input type="text" id="insitzes_has_wlm" value="0" />
                            <span class="field-help">1 = enabled (shows workload pool metrics), 0 = disabled (hides WLM panels)</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_has_smartstore">SmartStore</label>
                            <input type="text" id="insitzes_has_smartstore" value="0" />
                            <span class="field-help">1 = enabled (shows cache churn metrics), 0 = disabled (hides SmartStore panels)</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_has_cluster">Indexer Cluster</label>
                            <input type="text" id="insitzes_has_cluster" value="0" />
                            <span class="field-help">1 = enabled (checks replication/search factor health), 0 = disabled</span>
                        </div>

                    </div>

                    <div class="setup-section">
                        <h3>Cost Rates</h3>
                        <p class="section-help">Enter dollar rates to enable the Cost view toggles on the Compute tab. Leave blank to hide the toggle.</p>
                        <div class="setup-field">
                            <label for="insitzes_cost_per_svc">Cost per Compute Unit (SVC) ($)</label>
                            <input type="text" id="insitzes_cost_per_svc" />
                            <span class="field-help">e.g. 500.00 — used by the Compute tab's Cost toggle</span>
                        </div>
                    </div>

                    <div class="setup-section">
                        <h3>Alerting</h3>
                        <div class="setup-field">
                            <label for="insitzes_alert_email">Alert Email Distribution</label>
                            <input type="text" id="insitzes_alert_email" />
                            <span class="field-help">Email address or distribution list for all health check alerts</span>
                        </div>
                    </div>

                    <div class="setup-section">
                        <h3>Advanced</h3>
                        <div class="setup-field">
                            <label for="insitzes_exclude_system_users">System User Exclusions</label>
                            <input type="text" id="insitzes_exclude_system_users" />
                            <span class="field-help">e.g. NOT user IN ("splunk-system-user")</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_set_index_cmc_summary">Summary Index</label>
                            <input type="text" id="insitzes_set_index_cmc_summary" />
                            <span class="field-help">e.g. index=summary</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_rest_timeout">REST Timeout (seconds)</label>
                            <input type="text" id="insitzes_rest_timeout" value="30" />
                            <span class="field-help">Client-side timeout applied to Splunk REST API calls (macro reads, alert toggles, job polling). Default: 30</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_search_timeout">Search Timeout (seconds)</label>
                            <input type="text" id="insitzes_search_timeout" value="300" />
                            <span class="field-help">Client-side timeout applied to dashboard SPL searches. Raise this if long-running checks (Index Governance, sourcetype scans) hit the limit. Default: 300</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_debug_mode">Debug Mode</label>
                            <input type="text" id="insitzes_debug_mode" value="0" />
                            <span class="field-help">1 = enabled (shows error details on crash), 0 = disabled</span>
                        </div>
                    </div>

                    <div class="setup-actions">
                        <button id="setup-save-btn" class="btn btn-primary">Save Configuration</button>
                        <span id="setup-status"></span>
                    </div>

                    <div class="setup-section" style="margin-top: 20px;">
                        <h3>Data Backfill</h3>
                        <p class="section-help">Run a one-time backfill to populate lookups with historical data. Required after initial install for dashboards to show data.</p>
                        <div class="setup-actions">
                            <button id="backfill-svc-btn" class="btn btn-primary" style="background: #3B82F6;">Backfill SVC Estimation (24h)</button>
                            <span id="backfill-status"></span>
                        </div>
                    </div>
                </div>
            </html>
        </panel>
    </row>
</dashboard>
