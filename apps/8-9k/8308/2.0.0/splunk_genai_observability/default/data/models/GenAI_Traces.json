      "calculations": [
        {
          "calculationID": "calc_is_error_any",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "is_error_any",
              "owner": "GenAI_Span",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Is Error (any)",
              "comment": ""
            }
          ],
          "expression": "if(status=\"ERROR\" OR is_error=1, 1, 0)"
        },
        {
          "calculationID": "calc_total_tokens",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "total_tokens",
              "owner": "GenAI_Span",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Total Tokens",
              "comment": ""
            }
          ],
          "expression": "coalesce(input_tokens,0) + coalesce(output_tokens,0)"
        },
        {
          "calculationID": "calc_tokens_per_sec",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "tokens_per_sec",
              "owner": "GenAI_Span",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Output Tokens/sec",
              "comment": ""
            }
          ],
          "expression": "if(duration_ms > 0, round((output_tokens / (duration_ms / 1000)), 2), 0)"
        },
        {
          "calculationID": "calc_ttft_estimate",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "ttft_estimate",
              "owner": "GenAI_Span",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Est. TTFT (ms)",
              "comment": ""
            }
          ],
          "expression": "if(if(output_tokens > 0, duration_ms - (output_tokens * 20), duration_ms) < 0, 100, if(output_tokens > 0, duration_ms - (output_tokens * 20), duration_ms))"
        },
        {
          "calculationID": "calc_latency_bucket",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "latency_bucket",
              "owner": "GenAI_Span",
              "type": "string",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Latency Bucket",
              "comment": ""
            }
          ],
          "expression": "case(duration_ms < 500, \"<500ms\", duration_ms < 1000, \"500-1000ms\", duration_ms < 2000, \"1-2s\", duration_ms < 5000, \"2-5s\", duration_ms < 10000, \"5-10s\", true(), \">10s\")"
        },
        {
          "calculationID": "calc_token_bucket",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "token_bucket",
              "owner": "GenAI_Span",
              "type": "string",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Token Bucket",
              "comment": ""
            }
          ],
          "expression": "case((coalesce(input_tokens,0)+coalesce(output_tokens,0)) < 100, \"<100\", (coalesce(input_tokens,0)+coalesce(output_tokens,0)) < 500, \"100-500\", (coalesce(input_tokens,0)+coalesce(output_tokens,0)) < 1000, \"500-1K\", (coalesce(input_tokens,0)+coalesce(output_tokens,0)) < 5000, \"1K-5K\", (coalesce(input_tokens,0)+coalesce(output_tokens,0)) < 10000, \"5K-10K\", true(), \">10K\")"
        },
        {
          "calculationID": "calc_retrieval_latency",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "retrieval_latency",
              "owner": "GenAI_Span",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Retrieval Latency (ms)",
              "comment": ""
            }
          ],
          "expression": "if(span_type=\"RETRIEVER\", duration_ms, null())"
        },
        {
          "calculationID": "calc_generation_latency",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "generation_latency",
              "owner": "GenAI_Span",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Generation Latency (ms)",
              "comment": ""
            }
          ],
          "expression": "if(span_type=\"LLM\", duration_ms, null())"
        },
        {
          "calculationID": "calc_embedding_latency",
          "calculationType": "Eval",
          "owner": "GenAI_Span",
          "editable": true,
          "comment": "",
          "outputFields": [
            {
              "fieldName": "embedding_latency",
              "owner": "GenAI_Span",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Embedding Latency (ms)",
              "comment": ""
            }
          ],
          "expression": "if(span_type=\"EMBEDDING\", duration_ms, null())"
        }
      ]
