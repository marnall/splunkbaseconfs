<form version="1.1">
  <label>Intelligence Reports</label>
  <description>Brandefense Threat Intelligence Feed</description>

  <fieldset submitButton="true" autoRun="true">
    <input type="time" token="time_range" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Intelligence Reports Over Time</title>
      <chart>
        <search>
          <query>index=brandefense sourcetype="brandefense:intelligences" | dedup code | timechart count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.chart.showDataLabels">minmax</option>
      </chart>
    </panel>
    <panel>
      <title>Reports by Category</title>
      <chart>
        <search>
          <query>index=brandefense sourcetype="brandefense:intelligences" | dedup code | mvexpand categories | stats count by categories | sort - count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Intelligence Reports</title>
      <table>
        <search>
          <query>index=brandefense sourcetype="brandefense:intelligences" | dedup code | sort - _time | eval categories_str=mvjoin(categories, ", ") | eval countries_str=mvjoin(countries, ", ") | eval sectors_str=mvjoin(sectors, ", ") | table _time title categories_str countries_str sectors_str created_at source_url | rename title as "Title", categories_str as "Categories", countries_str as "Countries", sectors_str as "Sectors", created_at as "Created", source_url as source_url</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="count">20</option>
        <drilldown>
          <link target="_blank">$row.source_url$</link>
        </drilldown>
      </table>
    </panel>
  </row>
</form>
