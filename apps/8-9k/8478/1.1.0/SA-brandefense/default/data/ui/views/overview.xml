<dashboard version="1.1">
  <label>Overview</label>
  <description>Brandefense Digital Risk Protection Overview</description>

  <row>
    <panel>
      <title>Total Incidents</title>
      <single>
        <search>
          <query>index=brandefense sourcetype="brandefense:incidents" event_type="incident" | stats dc(code) as total</query>
          <earliest>-30d@d</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">true</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[10,50,100]</option>
      </single>
    </panel>
    <panel>
      <title>Total IOCs</title>
      <single>
        <search>
          <query>index=brandefense sourcetype="brandefense:iocs" | stats dc(data) as total</query>
          <earliest>-30d@d</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">true</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[100,500,1000]</option>
      </single>
    </panel>
    <panel>
      <title>Total Intelligence Reports</title>
      <single>
        <search>
          <query>index=brandefense sourcetype="brandefense:intelligences" | stats dc(code) as total</query>
          <earliest>-30d@d</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="colorMode">block</option>
        <option name="useColors">true</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[10,50,100]</option>
      </single>
    </panel>
    <panel>
      <title>Total Audit Events</title>
      <single>
        <search>
          <query>index=brandefense sourcetype="brandefense:audit:logs" | stats count as total</query>
          <earliest>-30d@d</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Incidents by Severity (Last 30 Days)</title>
      <chart>
        <search>
          <query>index=brandefense sourcetype="brandefense:incidents" event_type="incident" | stats dc(code) as count by severity | eval sort_order=case(severity=="CRITICAL",1, severity=="HIGH",2, severity=="MEDIUM",3, severity=="LOW",4, 1==1,5) | sort sort_order | fields - sort_order</query>
          <earliest>-30d@d</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"CRITICAL": 0xdc4e41, "HIGH": 0xf1813f, "MEDIUM": 0xf8be34, "LOW": 0x53a051}</option>
      </chart>
    </panel>
    <panel>
      <title>Recent High/Critical Incidents</title>
      <table>
        <search>
          <query>index=brandefense sourcetype="brandefense:incidents" event_type="incident" severity IN ("HIGH", "CRITICAL") | dedup code | sort - _time | table _time code title severity category organization_name url | rename code as "Code", title as "Title", severity as "Severity", category as "Category", organization_name as "Organization", url as "URL" | head 20</query>
          <earliest>-30d@d</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="count">10</option>
        <drilldown>
          <link target="_blank">$row.URL$</link>
        </drilldown>
      </table>
    </panel>
  </row>
</dashboard>
