<form version="1.1">
  <label>Audit Activity</label>
  <description>Brandefense Platform Audit Logs</description>

  <fieldset submitButton="true" autoRun="true">
    <input type="time" token="time_range" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Audit Events Over Time</title>
      <chart>
        <search>
          <query>index=brandefense sourcetype="brandefense:audit:logs" | timechart count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top Users</title>
      <chart>
        <search>
          <query>index=brandefense sourcetype="brandefense:audit:logs" | stats count by actor_name | sort - count | head 10</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
    <panel>
      <title>Top Actions</title>
      <chart>
        <search>
          <query>index=brandefense sourcetype="brandefense:audit:logs" | stats count by type | sort - count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Audit Log Details</title>
      <table>
        <search>
          <query>index=brandefense sourcetype="brandefense:audit:logs" | sort - _time | table _time actor_name actor_email type ip_address note created_at | rename actor_name as "User", actor_email as "Email", type as "Action", ip_address as "Source IP", note as "Note", created_at as "Created"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">20</option>
      </table>
    </panel>
  </row>
</form>
