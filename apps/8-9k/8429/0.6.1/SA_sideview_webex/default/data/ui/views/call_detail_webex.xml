<view isVisible="false" template="dashboard.html" stylesheet="custom.css,call_detail.css">
  <label>View call details (Webex)</label>
  <module name="TopNav" layoutPanel="appHeader" />
  <module name="AppNav" layoutPanel="appHeader" />

  <module name="URLLoader" layoutPanel="mainSearchControls">
    <param name="keepURLUpdated">True</param>

    <module name="Link" layoutPanel="viewHeader">
      <param name="label">Investigate Calls</param>
      <module name="Redirector">
        <param name="url">calls</param>
        <param name="arg.earliest">$bc_earliest$</param>
        <param name="arg.latest">$bc_latest$</param>
        <param name="arg.type">$bc_type$</param>
        <param name="arg.number">$bc_number$</param>
        <param name="arg.numberType">$bc_numberType$</param>
        <param name="arg.searchterms">$bc_searchterms$</param>
        <param name="arg.advancedSearchLanguage">$bc_advancedSearchLanguage$</param>
        <param name="arg.optionalHeadCommand">$bc_optionalHeadCommand$</param>
      </module>
    </module>

    <module name="HTML" layoutPanel="viewHeader">
      <param name="html"><![CDATA[
        <h1>&gt; Call Detail (Webex)</h1>
      ]]></param>
    </module>

    <module name="TextField">
      <param name="name">call_id</param>
      <param name="label">Call Id</param>
      <param name="template">$name$="$value$"</param>
      <param name="cssClass">callIdTextField</param>
      <param name="width">600px</param>

      <module name="Search">
        <param name="earliest">$search.timeRange.earliest$</param>
        <param name="latest">$search.timeRange.latest$</param>
        <param name="search"><![CDATA[
`custom_index` (sourcetype="cisco:webex:call:detailed_history" OR sourcetype="cisco:webex:meeting:qualities" OR sourcetype="cisco:webex:meetings") $call_id$ | fieldsummary | fields field count | search count>0
        ]]></param>

        <module name="CustomBehavior" layoutPanel="panel_row1_col1">
          <param name="customBehavior">onlySubmitIfFieldsAreSet</param>
          <param name="arg.requiredKey">call_id.rawValue</param>

          <module name="HTML">
            <param name="html"><![CDATA[
              <div id="viewerPageInstructions" style="display:none;clear:both;">
              <br>
              <br>
              <b>This view is normally reached by clicking a row from the <a href="calls">Investigate Calls</a> page.  <br>
              <br>
              However you can also use this view manually by simply entering a Webex Call Id in the field above and hitting Enter.</b>
              <br>
              <br>
              <br>
              <br>
              </div>
            ]]></param>
          </module>
        </module>
      </module>


      <module name="Search" layoutPanel="panel_row1_col1">
        <param name="earliest">$search.timeRange.earliest$</param>
        <param name="latest">$search.timeRange.latest$</param>
        <param name="search"><![CDATA[
`custom_index` (sourcetype="cisco:webex:call:detailed_history" OR sourcetype="cisco:webex:meeting:qualities" OR sourcetype="cisco:webex:meetings") $call_id$
        ]]></param>


        <module name="Fields" layoutPanel="panel_row2_col1">
          <param name="fields">duration type callingPartyName hardwareType cameraName microphoneName</param>
          <param name="hiddenFields">_time</param>

          <module name="Search">
            <param name="earliest">$search.timeRange.earliest$</param>
            <param name="latest">$search.timeRange.latest$</param>
            <param name="search"><![CDATA[
`custom_index` (sourcetype="cisco:webex:call:detailed_history" OR sourcetype="cisco:webex:meeting:qualities" OR sourcetype="cisco:webex:meetings") $call_id$
| table _time $results.fields$
| eval duration=replace(tostring(round(duration,3)),"000","")

| eval duration=tostring(duration,"duration")
            ]]></param>

            <pattern name="see_raw_search_syntax" />

            <module name="ValueSetter">
              <param name="name">legNoun</param>
              <param name="if.$results.count$=1">leg</param>
              <param name="default">legs</param>

              <module name="HTML">
                <param name="html"><![CDATA[
                  <h2>Showing $results.count$ $legNoun$ for call id $call_id.rawValue$</h2>
                ]]></param>
              </module>
            </module>


            <module name="ProgressIndicator" />

            <module name="Pager">
              <module name="Table" />
            </module>
          </module>
        </module>
      </module>



      <!-- gantt chart -->
      <module name="Search" layoutPanel="panel_row3_col1">
        <param name="earliest">$search.timeRange.earliest$</param>
        <param name="latest">$search.timeRange.latest$</param>
        <param name="search"><![CDATA[
`custom_index` (sourcetype="cisco:webex:call:detailed_history" OR sourcetype="cisco:webex:meeting:qualities" OR sourcetype="cisco:webex:meetings") $call_id$
| table _time duration callingPartyName
| eval end=_time+duration
| stats min(_time) as start max(end) as end values(duration) as duration by callingPartyName _time
| streamstats count as person_index
| eval duration=mvrange(0,duration+1)
| mvexpand duration
| eval _time=start+duration
| eventstats min(_time) as min_time max(_time) as max_time
| where _time<=max_time AND _time>=min_time
| timechart fixedrange=false bins=500 max(person_index) by callingPartyName limit=75
        ]]></param>

        <module name="ProgressIndicator"></module>

        <module name="SearchControls">
          <param name="sections">export</param>
        </module>



        <module name="ValueSetter">
          <param name="arg.charting.chart">line</param>
          <param name="arg.charting.axisLabelsY.majorLabelVisibility">hide</param>
          <param name="arg.charting.axisLabelsY.minorLabelVisibility">hide</param>
          <param name="arg.charting.legend.placement">right</param>
          <param name="arg.charting.axisTitleX.visibility">collapsed</param>
          <!--
          <param name="arg.charting.secondaryAxis.maximumNumber">$legs$</param>
        -->
          <param name="arg.charting.gridLinesX.showMajorLines">False</param>
          <param name="arg.charting.gridLinesY.showMajorLines">False</param>
          <param name="arg.charting.gridLinesX.showMinorLines">False</param>
          <param name="arg.charting.gridLinesY.showMinorLines">False</param>

          <module name="HTML">
            <param name="html"><![CDATA[
              <h2>Timeline of all participants</h2>
            ]]></param>
          </module>

          <module name="Chart" />
        </module>
      </module>

      <!-- this is just for the ALL POSSIBLE FIELDS panel -->
      <module name="Search" layoutPanel="panel_row3_col2">
        <param name="earliest">$search.timeRange.earliest$</param>
        <param name="latest">$search.timeRange.latest$</param>
        <param name="search"><![CDATA[
`custom_index` (sourcetype="cisco:webex:call:detailed_history" OR sourcetype="cisco:webex:meeting:qualities" OR sourcetype="cisco:webex:meetings") $call_id$
| table *
| fields - _*
| transpose 500
| rename column as field
| foreach row* [eval value=if(length('<<FIELD>>')>0, mvappend(value,'<<FIELD>>'),value)]
| eval value=mvjoin(mvdedup(value),", ")
        ]]></param>

        <module name="ProgressIndicator"></module>

        <module name="SearchControls">
          <param name="sections">export</param>
        </module>

        <module name="HTML">
          <param name="html"><![CDATA[
            <h2>All $results.count$ fields and values</h2>
          ]]></param>
        </module>


        <module name="Pager">
          <param name="count">20</param>

          <module name="Multiplexer">
            <param name="fields">field,value</param>

            <module name="HTML">
              <param name="html"><![CDATA[
              <b>$field$</b>: $value$
              ]]></param>
            </module>
          </module>
        </module>
      </module>



      <!-- Quality reports -->

      <module name="Search" layoutPanel="panel_row4_col1">
        <!-- get the fields dynamically in case webex adds more to the api output -->
        <param name="search"><![CDATA[
`custom_index` (sourcetype="cisco:webex:call:detailed_history" OR sourcetype="cisco:webex:meeting:qualities" OR sourcetype="cisco:webex:meetings")  $call_id$
| fieldsummary
| search field="audioIn*" OR field="audioOut*" OR field="videoIn*" OR field="videoOut*"  field!="*codec" field!="*transportType" field!="*endTime" field!="*startTime" field!="*samplingInterval" field!="*frameRate*"
| rex field="field" \w+\{\}\.(?P<stat>\w+)
| stats count by stat
| sort stat

        ]]></param>

        <module name="Pulldown">
          <param name="name">media</param>
          <param name="label">Show per-user statistics for</param>
          <param name="staticOptions">
            <list>
              <param name="value">audio</param>
            </list>
            <list>
              <param name="value">video</param>
            </list>
          </param>

          <module name="Pulldown">
            <param name="name">quality_field</param>
            <param name="label">Quality statistic</param>
            <param name="valueField">stat</param>
            <param name="staticOptions"></param>

            <module name="Search" layoutPanel="panel_row4_col1">
              <!-- get the fields dynamically in case webex adds more to the api output -->
              <param name="search"><![CDATA[
`custom_index` (sourcetype="cisco:webex:call:detailed_history" OR sourcetype="cisco:webex:meeting:qualities" OR sourcetype="cisco:webex:meetings")  $call_id$
| table callingPartyName $media$In{}.$quality_field${} $media$Out{}.$quality_field${}
| rename $media$In{}.$quality_field${} as in $media$Out{}.$quality_field${} as out
              ]]></param>

              <module name="ValueSetter">
                <param name="arg.charting.chart">line</param>
                <param name="arg.charting.axisLabelsX.axisVisibility">hide</param>
                <param name="arg.charting.legend.placement">none</param>

                <module name="Pager">
                  <module name="Table">
                    <module name="PostProcess" group="row.fields.in">
                      <param name="search"><![CDATA[
| search callingPartyName="$row.fields.callingPartyName$"
| mvexpand in
| table in
| eval foo="1"
| table foo in
                      ]]></param>
                      <module name="Chart">
                        <param name="height">200px</param>
                        <param name="width">400px</param>
                      </module>
                    </module>

                    <module name="PostProcess" group="row.fields.out">
                      <param name="search"><![CDATA[
| search callingPartyName="$row.fields.callingPartyName$"
| mvexpand out
| table out
| eval foo="1"
| table foo out
                      ]]></param>
                      <module name="Chart">
                        <param name="height">200px</param>
                        <param name="width">400px</param>
                      </module>
                    </module>

                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</view>
