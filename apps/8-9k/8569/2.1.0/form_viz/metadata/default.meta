[]
access = read : [ * ], write : [ sc_admin, admin ]

# Make lookup table files and transforms globally readable so Saved Search
# Review review_*.csv panels resolve the same way form_config does. Writes are
# restricted for shipped lookup files; form_responses has its own write stanza.
[lookups]
export = system
access = read : [ * ], write : [ sc_admin, admin ]

[transforms]
export = system

[visualizations/form_viz]
export = system

[collections/form_responses]
export = system
access = read : [ * ], write : [ sc_admin, admin, power, user ]

[transforms/form_responses]
export = system
access = read : [ * ], write : [ sc_admin, admin, power, user ]

[transforms/form_config]
export = system

[lookups/form_config]
export = system
access = read : [ * ], write : [ sc_admin, admin ]
