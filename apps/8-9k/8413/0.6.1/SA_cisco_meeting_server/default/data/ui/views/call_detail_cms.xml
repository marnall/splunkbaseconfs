<view isVisible="false" template="dashboard.html" stylesheet="custom.css,call_detail.css">
  <label>View call details (CMS)</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="URLLoader" layoutPanel="mainSearchControls">
    <param name="keepURLUpdated">True</param>

    <module name="Link" layoutPanel="viewHeader">
      <param name="label">Investigate Calls</param>
      <module name="Redirector">
        <param name="url">calls</param>
        <param name="arg.earliest">$bc_earliest$</param>
        <param name="arg.latest">$bc_latest$</param>
        <param name="arg.type">$bc_type$</param>
        <param name="arg.number">$bc_number$</param>
        <param name="arg.numberType">$bc_numberType$</param>
        <param name="arg.searchterms">$bc_searchterms$</param>
        <param name="arg.advancedSearchLanguage">$bc_advancedSearchLanguage$</param>
      </module>
    </module>

    <module name="HTML" layoutPanel="viewHeader">
      <param name="html"><![CDATA[
        <h1>&gt; Call Detail (CMS)</h1>
        ]]>
      </param>
    </module>

    <module name="TextField">
      <param name="name">call_id</param>
      <param name="label">Call Id</param>
      <param name="template">$name$="$value$"</param>
      <param name="cssClass">callIdTextField</param>


      <!-- a Sideview UI trick
      Using a Splunk Subsearch would subject us to some limits and performance problems.
      But we run a full dispatched search here to wash it through the format command ourselves
      so we can then use the ResultsValueSetter module to pull that huge SPL expression
      down to the client, as a simple token $call_id_search$ that we use in all the rest of
      the searches on this page.
      -->
      <module name="Search">
        <param name="earliest">$search.timeRange.earliest$</param>
        <param name="latest">$search.timeRange.latest$</param>
        <param name="search"><![CDATA[
`custom_index` sourcetype=cms_cdr $call_id$
| table callLegId
| dedup callLegId
| format "" "" "OR" "" "OR" ""
| eval call_id_search=search
        ]]></param>

        <module name="ResultsValueSetter">
          <param name="fields">call_id_search</param>



          <module name="Search">
            <param name="earliest">$search.timeRange.earliest$</param>
            <param name="latest">$search.timeRange.latest$</param>
            <param name="search"><![CDATA[
`custom_index` sourcetype=cms_cdr $call_id_search$
| fieldsummary
| fields field count
| search count>0
            ]]></param>


            <module name="CustomBehavior" layoutPanel="panel_row1_col1">
              <param name="customBehavior">onlySubmitIfFieldsAreSet</param>
              <param name="arg.requiredKey">call_id.rawValue</param>

              <module name="HTML">
                <param name="html"><![CDATA[
                  <div id="viewerPageInstructions" style="display:none;clear:both;">
                  <br>
                  <br>
                  <b>This view is normally reached by clicking a row from the <a href="calls">Investigate Calls</a> page.  <br>
                  <br>
                  However you can also use this view manually by simply entering a Meeting Server Call Id in the field above and hitting Enter.</b>
                  <br>
                  <br>
                  <br>
                  <br>
                  </div>
                ]]></param>
              </module>


              <module name="Fields">
                <param name="fields">_time duration type name recordType callingPartyName calledPartyName reason reasonDetails confirmationStatus localAddress remoteAddress ipAddress src_ip dest_ip</param>

                <module name="Search">
                  <param name="earliest">$search.timeRange.earliest$</param>
                  <param name="latest">$search.timeRange.latest$</param>
                  <param name="search"><![CDATA[
`custom_index` sourcetype=cms_cdr $call_id_search$
| eval sortOverride=case(recordType=="callStart",0,recordType=="callLegStart",1,recordType=="callLegUpdate",2, recordType=="callLegEnd",3, recordType=="callEnd",10,true(),1)
| sort 0 + _time sortOverride
| table _time $results.fields$
| eval duration=tostring(duration,"duration")
                  ]]></param>

                  <pattern name="see_raw_search_syntax" />

                  <module name="ValueSetter">
                    <param name="name">legNoun</param>
                    <param name="if.$results.count$=1">leg</param>
                    <param name="default">legs</param>

                    <module name="HTML">
                      <param name="html"><![CDATA[
                        <h2>Showing $results.count$ $legNoun$ for call id $call_id.rawValue$</h2>
                      ]]></param>
                    </module>
                  </module>


                  <module name="ProgressIndicator" />

                  <module name="Pager">
                    <module name="Table" />
                  </module>
                </module>
              </module>
            </module>

          </module>


          <module name="Search" layoutPanel="panel_row2_col1">
            <param name="earliest">$search.timeRange.earliest$</param>
            <param name="latest">$search.timeRange.latest$</param>
            <param name="search"><![CDATA[
`custom_index` sourcetype=cms_cdr $call_id_search$
| stats min(_time) as start max(_time) as end by callLegId callingPartyName
| sort 0 + start
| eventstats count as total_legs
| streamstats count as leg

| eval reverse_index=total_legs + 1 - leg
| eval times=mvrange(start,end+1)
| mvexpand times
| rename times as _time
| eval name=leg + " - " + callingPartyName
| timechart fixedrange=false span=1s max(reverse_index) by name limit=75
            ]]></param>
            <module name="ValueSetter">
              <param name="arg.charting.chart">line</param>
              <param name="arg.charting.chart.nullValueMode">connect</param>

              <!-- new key for our new Chart module -->
              <param name="arg.charting.axisLabelsY.axisVisibility">hide</param>

              <!-- legacy key for older Chart module versions -->
              <param name="arg.charting.axisLabelsY.majorLabelVisibility">hide</param>
              <param name="arg.charting.axisLabelsY.minorLabelVisibility">hide</param>

              <param name="arg.charting.legend.placement">right</param>
              <param name="arg.charting.axisTitleX.visibility">collapsed</param>

              <param name="arg.charting.secondaryAxis.maximumNumber">$legs$</param>
              <param name="arg.charting.gridLinesX.showMajorLines">False</param>
              <param name="arg.charting.gridLinesY.showMajorLines">False</param>
              <param name="arg.charting.gridLinesX.showMinorLines">False</param>
              <param name="arg.charting.gridLinesY.showMinorLines">False</param>

              <module name="HTML">
                <param name="html"><![CDATA[
                  <h2>Timeline of all $legs$ call legs</h2>
                  <br>
                ]]></param>
              </module>
              <pattern name="see_raw_search_syntax" />
              <module name="Chart" />

            </module>
          </module>


          <module name="Search" layoutPanel="panel_row3_col1">
            <param name="earliest">$search.timeRange.earliest$</param>
            <param name="latest">$search.timeRange.latest$</param>
            <param name="clearPostProcess">True</param>
            <param name="search"><![CDATA[
`custom_index` sourcetype=cms_cdr $call_id_search$
| table *
| fields - _*
| transpose 100
| rename column as field
| foreach row* [eval value=if(length('<<FIELD>>')>0, mvappend(value,'<<FIELD>>'),value)]
| eval value=mvjoin(mvdedup(value),", ")
| where isnotnull(value) AND value!=""

            ]]></param>

            <module name="SearchControls">
              <param name="sections">export</param>
            </module>

            <module name="HTML">
              <param name="html"><![CDATA[
                <h2>Showing all $results.count$ populated fields for this call</h2>
              ]]></param>
            </module>

            <module name="TextField">
              <param name="name">all_fields_filter</param>
              <param name="label">search</param>
              <param name="float">left</param>
              <param name="template">field="*$value$*" OR value="*$value$*"</param>

              <module name="Button">
                <param name="allowSoftSubmit">True</param>

                <module name="PostProcess">
                  <param name="search">search * $all_fields_filter$</param>

                  <module name="Pager">


                    <module name="Multiplexer">
                      <param name="fields">field,value</param>


                      <module name="HTML">
                        <param name="clear">left</param>
                        <param name="html"><![CDATA[
                        <b>$field$</b>: $value$
                        ]]></param>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>


          </module>


          <module name="Search" layoutPanel="panel_row4_col1">
            <param name="earliest">$search.timeRange.earliest$</param>
            <param name="latest">$search.timeRange.latest$</param>
            <param name="search"><![CDATA[
`custom_index` sourcetype=cms_cdr $call_id_search$
| eval sortOverride=case(recordType=="callStart",0,recordType=="callLegStart",1,recordType=="callLegUpdate",2, recordType=="callLegEnd",3, recordType=="callEnd",10,true(),1)
| sort 0 + _time sortOverride
| rename _raw as xml
| eval xml=replace(replace(xml,">","&gt;"),"<","&lt;")
            ]]></param>

            <module name="HTML">
              <param name="html"><![CDATA[
<h3>raw records</h3>
              ]]></param>
            </module>

            <module name="Multiplexer">
              <param name="fields">xml</param>

              <module name="HTML">
                <param name="html"><![CDATA[
    <pre style="white-space: pre-wrap;">$xml.rawValue$</pre>
                ]]></param>
              </module>
            </module>

          </module>

        </module>
      </module>
    </module>
  </module>
</view>
