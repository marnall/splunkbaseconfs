#
# Object permissions. Read for everyone, write for admins; objects are
# scoped to this app (export = none).
#
[]
access = read : [ * ], write : [ admin, sc_admin ]
export = none

[collections/splunkbase_catalog]
access = read : [ * ], write : [ admin, sc_admin ]
export = none

[transforms/splunkbase_catalog_lookup]
access = read : [ * ], write : [ admin, sc_admin ]
export = none
