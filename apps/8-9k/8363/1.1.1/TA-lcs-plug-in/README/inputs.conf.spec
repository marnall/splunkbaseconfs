[lcs_insights://<name>]
account = Select the Cisco CX Cloud account to use.
index = Default: default
interval = Time interval of input in seconds.
region = Select the Cisco CX Cloud region for your organization. US covers Americas; EMEA covers Europe, Middle East, and Africa.  Default: us
security_vulnerable_only = Only return the Vulnerable and Potentially Vulnerable items for Security Advisories and Field Notices.  Default: True
