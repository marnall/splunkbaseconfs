<dashboard version="1.1" script="setting.js" stylesheet="setting.css" theme="dark" hideEdit="true">
  <label>Setting Updated</label>
  <description>NetBrain Command Extension Settings</description>
  <row>
    <panel>
      <html>
        <h3>Settings</h3>
        <p>The following configuration information is used to call NetBrain Services APIs.</p>
        <div class="nb-form-item">
          <label>SericesAPI Endpoint:</label>
          <input type="text" id="ie_api_url"></input>
        </div>
        <div class="nb-form-item">
          <label>SericesAPI Account:</label>
          <input type="text" id="ie_username"></input>
        </div>
        <div class="nb-form-item">
          <label>SericesAPI Password:</label>
          <input type="password" id="ie_password"></input>
        </div>
        <div class="nb-form-item">
          <label>Tenant ID:</label>
          <input type="text" id="ie_tenant"></input>
        </div>
        <div class="nb-form-item">
          <label>Domain IDss:</label>
          <input type="text" id="ie_domain"></input>
        </div>
        <div class="nb-form-item">
          <label></label>
          <button class="btn btn-primary submit" id="btnSave">Save</button>
        </div>
        <div class="nb-form-item">
          <label></label>
          <label></label>
        </div>
      </html>
    </panel>
  </row>
</dashboard>