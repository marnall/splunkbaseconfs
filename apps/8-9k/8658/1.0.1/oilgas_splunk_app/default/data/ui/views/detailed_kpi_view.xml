<dashboard version="1.1"
           script="javascript/detailed_kpi_view.js"
           stylesheet="styles/detailed_kpi_view.css"
           theme="light">
    <label>KPI Details</label>
    <row>
        <panel>
            <html>
                <div id="detailed-kpi-container">
                    <p>Loading KPI trends...</p>
                </div>
            </html>
        </panel>
    </row>
    <row>
        <panel>
            <viz type="oilgas_splunk_app.ai_chat">
                <search>
                <query>| makeresults</query>
                <earliest>-24h@h</earliest>
                <latest>now</latest>
                </search>
                <option name="drilldown">none</option>
                <option name="height">0</option>
                <option name="oilgas_splunk_app.ai_chat.contextSearchIds"></option>
            </viz>
        </panel>
    </row>
</dashboard>
