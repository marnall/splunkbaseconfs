<dashboard script="javascript/thresholds_editor.js" theme="light" version="1.1">
  <label>Thresholds Editor</label>
  <description>Edit min/max thresholds for ESP and WELL metrics.</description>

  <row>
    <panel>
      <html>
        <h2>ESP Thresholds</h2>
        <div id="esp_table_container">Loading...</div>
        <button class="btn btn-primary" id="save_esp_btn" style="margin-top:10px;">Save ESP Thresholds</button>
      </html>
    </panel>
    
    <panel>
      <html>
        <h2>Well Thresholds</h2>
        <div id="well_table_container">Loading...</div>
        <button class="btn btn-primary" id="save_well_btn" style="margin-top:10px;">Save WELL Thresholds</button>
      </html>
    </panel>
  </row>

  <row>
    <panel>
      <html>
        <div class="success" style="color: green; margin-top: 10px; display: none;"></div>
        <div class="error" style="color: red; margin-top: 10px; display: none;"></div>
      </html>
    </panel>
  </row>
</dashboard>
