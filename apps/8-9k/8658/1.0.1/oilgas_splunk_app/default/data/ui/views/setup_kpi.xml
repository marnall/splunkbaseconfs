<dashboard isDashboard='false'
           script='javascript/setup_kpi.js'
           stylesheet='styles/setup_kpi.css'
           version='1.1'>
    <label>Setup KPI</label>
    <row>
        <panel>
           <html>
            <div id="main_container">
                <hr style="margin: 30px 0;"/>
                <div id="kpi_table_container">
                <p>Loading KPIs...</p>
                </div>

                <hr style="margin: 30px 0;"/>

                <div id="form_container">
                    <form id="add-kpi-form" class="form-inline">
                        <div class="form-group">
                            <label for="kpi_name_input">KPI Name:</label>
                            <input type="text" id="kpi_name_input" />
                        </div>
                        <div class="form-group">
                            <label for="search_query_input">Search Query:</label>
                            <textarea id="search_query_input" rows="4" style="width: 100%;"></textarea>
                        </div>
                        <div class="form-group">
                            <label for="description_input">Description:</label>
                            <textarea id="description_input" rows="2" style="width: 100%;"></textarea>
                        </div>
                        <div class="form-group">
                            <label for="earliest_time_input">Earliest Time:</label>
                            <input type="text" id="earliest_time_input" placeholder="e.g. -24h@h or -7d" value="-7d" />
                        </div>
                        <div class="form-group">
                            <label for="latest_time_input">Latest Time:</label>
                            <input type="text" id="latest_time_input" placeholder="e.g. now or @d" value="now" />
                        </div>
                        <div class="form-group">
                            <label for="kpi_url_input">URL:</label>
                            <input type="text" id="kpi_url_input" />
                        </div>
                        <div class="form-group">
                            <button id="submit_kpi_button" type="submit">Add KPI</button>
                        </div>
                    </form>
                    <div class="success" style="display:none;">KPI saved successfully.</div>
                    <div class="error" style="display:none;">Error saving KPI.</div>
                    <code id="error_details"></code>
                </div>
                <div class="disclaimer-box">
                    <p><strong>Note:</strong> The search query <u>must</u> return a numeric field named <code>kpi_value</code> for the KPI to be visualized.</p>
                    <p>It <u>should</u> also return a boolean <code>is_latest</code> field set to <code>"true"</code> for the most recent value, and a <code>_time</code> field for trend charts and sparklines.</p>
                    <p><strong>Example:</strong></p>
                    <pre>
                index=oil_gas earliest=-30d
                | bin _time span=1d
                | stats sum(ON_STREAM_HRS) as hours by _time
                | eval kpi_value = round(hours, 2)
                | eval is_latest = if(_time == relative_time(now(), "@d"), "true", "false")
                    </pre>
                </div>
                <div class="sample-kpi-section">
                    <h3>Sample KPIs</h3>
                    <p>Install sample KPIs for oil and gas operations monitoring.</p>
                    <p>The recommended first-run path is now the <a href="/app/oilgas_splunk_app/onboarding_guide" target="_blank">Onboarding Guide</a>, where this same installer is surfaced with setup instructions.</p>
                    <p>Use this page when you want to rerun the sample installer or manually maintain KPIs afterwards.</p>
                    <button id="install_samples_button" class="btn btn-primary">Install Sample KPIs</button>
                    <div class="install-status" style="display: none;"></div>
                </div>
            </div>
           </html>
        </panel>
    </row>
</dashboard>
