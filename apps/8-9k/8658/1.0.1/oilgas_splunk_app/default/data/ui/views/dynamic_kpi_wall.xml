<dashboard version="1.1" script="javascript/dynamic_kpi_wall.js,javascript/app_utils.js" stylesheet="styles/dynamic_kpi_wall.css" theme="light">
  <label>Dynamic KPIs</label>
  <row>
    <panel>
      <html>
                <div style="text-align: right; margin-bottom: 16px;">
                    <a id="detailed-link" class="btn view-detailed-btn" target="_blank">View Detailed Trends</a>
                </div>

                <div id="kpi-container">
                    <p>Loading KPIs...</p>
                </div>
                <div style="text-align: center; margin-top: 20px;">
                    <img src="/static/app/oilgas_splunk_app/oil_gas_data_flow_schema.png" alt="Data flow" style="width: auto; height: 500px;" />
                </div>
            </html>
    </panel>
  </row>
  <row>
    <panel>
      <viz type="oilgas_splunk_app.ai_chat">
        <search>
          <query>| makeresults</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="height">0</option>
        <option name="oilgas_splunk_app.ai_chat.contextSearchIds"></option>
        <option name="oilgas_splunk_app.ai_chat.height">400</option>
      </viz>
    </panel>
  </row>
</dashboard>