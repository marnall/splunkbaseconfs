<form version="1.1" theme="light" script="ai_chat_config.js" stylesheet="ai_chat_config.css">
  <label>AI Configuration</label>
  <description>
    Configure the external AI provider once for the app. Browser chat requests go to a Splunk REST relay,
    and only the relay talks to the external AI endpoint.
  </description>

  <row>
    <panel>
      <html>
        <div id="oilgas-ai-config-root" class="oilgas-ai-config-root">
          <div class="oilgas-ai-config-card">
            <div class="oilgas-ai-config-grid">
              <label for="oilgas-ai-provider-type">Provider Protocol</label>
              <select id="oilgas-ai-provider-type">
                <option value="openai_compatible">OpenAI Compatible</option>
                <option value="anthropic">Anthropic Messages</option>
                <option value="gemini">Google Gemini</option>
                <option value="ollama">Ollama</option>
              </select>

              <label for="oilgas-ai-endpoint-url">Endpoint URL</label>
              <input
                id="oilgas-ai-endpoint-url"
                type="text"
                placeholder="https://api.openai.com/v1/chat/completions"
              />

              <label for="oilgas-ai-model">Model / Deployment</label>
              <input id="oilgas-ai-model" type="text" placeholder="gpt-4.1-mini or local deployment name" />

              <label for="oilgas-ai-auth-mode">Auth Mode</label>
              <select id="oilgas-ai-auth-mode">
                <option value="bearer">Bearer Header</option>
                <option value="header_value">Raw Header Value</option>
                <option value="none">None</option>
              </select>

              <label for="oilgas-ai-auth-header-name">Auth Header Name</label>
              <input id="oilgas-ai-auth-header-name" type="text" placeholder="Authorization" />

              <label for="oilgas-ai-auth-header-prefix">Auth Header Prefix</label>
              <input id="oilgas-ai-auth-header-prefix" type="text" placeholder="Bearer " />

              <label for="oilgas-ai-api-key">API Key / Token</label>
              <div class="oilgas-ai-secret-row">
                <input
                  id="oilgas-ai-api-key"
                  type="password"
                  placeholder="Leave blank to keep the stored secret"
                />
                <label class="oilgas-ai-inline-toggle">
                  <input id="oilgas-ai-clear-secret" type="checkbox" />
                  <span>Clear stored secret</span>
                </label>
                <span id="oilgas-ai-secret-indicator" class="oilgas-ai-secret-indicator"></span>
              </div>

              <label for="oilgas-ai-request-timeout">Request Timeout (ms)</label>
              <input
                id="oilgas-ai-request-timeout"
                type="number"
                min="3000"
                max="180000"
                step="1000"
                placeholder="60000"
              />

              <label for="oilgas-ai-verify-tls">Verify TLS</label>
              <select id="oilgas-ai-verify-tls">
                <option value="true">Yes</option>
                <option value="false">No</option>
              </select>

              <label for="oilgas-ai-temperature">Temperature</label>
              <input
                id="oilgas-ai-temperature"
                type="number"
                min="0"
                max="2"
                step="0.1"
                placeholder="0.2"
              />

              <label for="oilgas-ai-max-tokens">Max Tokens</label>
              <input
                id="oilgas-ai-max-tokens"
                type="number"
                min="1"
                max="65536"
                step="1"
                placeholder="Optional"
              />

              <label for="oilgas-ai-extra-headers-json">Extra Headers (JSON object)</label>
              <textarea
                id="oilgas-ai-extra-headers-json"
                rows="5"
                placeholder='{"OpenAI-Beta":"assistants=v2"}'
              ></textarea>

              <label for="oilgas-ai-extra-params-json">Extra Request Params (JSON object)</label>
              <textarea
                id="oilgas-ai-extra-params-json"
                rows="7"
                placeholder='{"reasoning":{"effort":"medium"}}'
              ></textarea>
            </div>

            <div class="oilgas-ai-config-help">
              <div class="oilgas-ai-config-help-title">Provider Notes</div>
              <div id="oilgas-ai-provider-help" class="oilgas-ai-config-help-body"></div>
            </div>

            <div class="oilgas-ai-config-actions">
              <button id="oilgas-ai-load-settings" type="button">Reload</button>
              <button id="oilgas-ai-test-settings" type="button">Test Connection</button>
              <button id="oilgas-ai-save-settings" type="button">Save</button>
            </div>

            <div id="oilgas-ai-config-status" class="oilgas-ai-config-status"></div>
          </div>
        </div>
      </html>
    </panel>
  </row>
</form>
