# Application-level permissions

[]
access = read : [ * ], write : [ admin ]
export = system

[configs/conf-anyrun_settings]
access = read : [ * ], write : [ admin ]
export = system

[kvstore:anyrun_feed_ioc_ip]
access = read : [ * ], write : [ admin ]
export = system

[kvstore:anyrun_feed_ioc_domain]
access = read : [ * ], write : [ admin ]
export = system

[kvstore:anyrun_feed_ioc_url]
access = read : [ * ], write : [ admin ]
export = system

[kvstore:anyrun_sandbox_ioc_ip]
access = read : [ * ], write : [ admin, anyrun_user ]
export = system

[collections/anyrun_sandbox_ioc_ip]
access = read : [ * ], write : [ admin, anyrun_user ]
export = system

[kvstore:anyrun_sandbox_ioc_domain]
access = read : [ * ], write : [ admin, anyrun_user ]
export = system

[collections/anyrun_sandbox_ioc_domain]
access = read : [ * ], write : [ admin, anyrun_user ]
export = system

[kvstore:anyrun_sandbox_ioc_url]
access = read : [ * ], write : [ admin, anyrun_user ]
export = system

[collections/anyrun_sandbox_ioc_url]
access = read : [ * ], write : [ admin, anyrun_user ]
export = system

[restmap]
access = read : [ * ], write : [ admin ]
export = system


### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
access = read : [ * ], write : [ admin ]
export = system


### LOOKUPS

[lookups]
access = read : [ * ], write : [ admin ]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[workflow_actions/sandbox]
access = read : [ * ], write : [ admin ]
export = system

[workflow_actions/lookup_ip]
access = read : [ * ], write : [ admin ]
export = system

[workflow_actions/lookup_domain]
access = read : [ * ], write : [ admin ]
export = system

[workflow_actions/lookup_hash]
access = read : [ * ], write : [ admin ]
export = system

[workflow_actions/lookup_url]
access = read : [ * ], write : [ admin ]
export = system

[indexes/anyrun]
access = read : [ * ], write : [ admin, anyrun_user ]
export = system