<dashboard version="1.1" 
        hideEdit="true" 
        hideExport="true" 
        hideChrome="true" 
        script="js/lookup.js" 
        stylesheet="style/ti_feed.css"
        isDashboard="false">
    <label>Processing TI lookup</label>
    <row>
      <panel>
        <html>
            <style>
                .hidden {
                    display: none;
                }

                .block {
                    flex-direction: row;
                    display: flex;
                    justify-content: start;
                    align-items: center;
                    height: 100%;
                }

                .loader {
                    border: 6px solid #f3f3f3;
                    border-top: 6px solid #1a8929;
                    border-radius: 50%;
                    width: 10px;
                    height: 10px;
                    animation: spin 2s linear infinite;
                    margin-right: 10px;
                }

                a {
                    margin-left: 10px;
                }

                @keyframes spin {
                  0% { transform: rotate(0deg); }
                  100% { transform: rotate(360deg); }
                }
            </style>
            <div id="loading" class="block loading">
                <div class="loader"></div>
                <h2>Loading...</h2>
            </div>
            <div id="loaded" class="loaded hidden">
                <h2 id="header">Loaded successfully</h2>
                <a id="link"> Check</a>
            </div>

        </html>
      </panel>
    </row>
</dashboard>
