<dashboard 
        version="1.1" 
        hideEdit="true" 
        hideExport="true" 
        script="js/manage_configuration.js" 
        stylesheet="style/ti_feed.css" 
        isDashboard="false">
  <label>Configuration</label>
  <description>Configure the integration</description>
  <row>
    <panel>
        <html>
        <style>
            .sb_settings .formContainer {
                flex-direction: column;
            }


            .dashboard-row .dashboard-panel{
                min-height: 80% !important;
            }
            
            h2 {
                font-size: 1.5em !important;
                font-weight: bold !important;
            }

            #saveSettings {
                margin: 0;
                width: 200px;
            }

            #errorBlock,
            #successBlock,
            #errorBlockServiceAccount,
            #successBlockServiceAccount,
            #errorBlockSandbox,
            #successBlockSandbox,
            #errorBlockSandboxSubmission,
            #successBlockSandboxSubmission,
            #errorBlockLookup,
            #successBlockLookup,
            #errorBlockTiFeedToken,
            #successBlockTiFeedToken,
            #errorBlockTiFeedSettings,
            #successBlockTiFeedSettings {
                display: none;
                background-color: #f8d7da;
                color: #721c24;
                padding: 10px;
                margin-bottom: 15px;
                border: 1px solid #f5c6cb;
                border-radius: 4px;
                max-width: 600px;
            }
            #capabilityWarning {
                display: none;
                background-color: #fff3cd;
                color: #856404;
                padding: 10px;
                margin-bottom: 15px;
                border: 1px solid #ffeeba;
                border-radius: 4px;
                max-width: 800px;
                font-weight: bold;
            }
            .message-success {
                background-color: #e6ffed !important;
                color: #1a7f37 !important;
                border-color: #a1e3b4 !important;
            }
            .message-error {
                background-color: #f8d7da !important;
                color: #721c24 !important;
                border-color: #f5c6cb !important;
            }
            :root {
                --lightblue: #2a97fb;
                --surface-white: #FFFFFF;
                --text-default: #3c444d;
                --text-link: #006eaa;
                --component-border: #c3cbd4;
                --component-border-light: #E1E6EB;
                --state-error-background: #fcedec;
            }


            .dashboard-panel {
                display: flex;
                margin-left: auto !important;
                background-color: var(--surface-white);
                margin-right: auto !important;
                width: fit-content;
                min-height: 40vh;
                border-radius: 6px;
                border: 1px solid var(--component-border-light);
                padding: 20px;
                max-width: 1000px;
                min-width: 800px;
            }

            .formContainer {
                display: flex;
                gap: 10px;
                min-width: 700px;
                margin: 10px 0px;
            }
            /* Reduce default min-width constraints within rowGrid2 */
            .rowGrid2 .formContainer,
            .rowGrid2 .formBlock { min-width: 0 !important; }

            [type="checkbox"]:checked,
            [type="checkbox"]:not(:checked) {
                margin-right: 10px;
                margin-top: 0;
                width: 18px;
                height: 18px;
                accent-color: var(--lightblue);
            }

            input[type="checkbox"],
            input[type="radio"] {
                box-sizing: border-box;
                padding: 0;
            }
            
            input[type="radio"] {
                display: none;
            }
            
            input[type="checkbox"][readonly] {
                pointer-events: none;
                opacity: 30%;
            }

            [type="radio"]:checked+label,
            [type="radio"]:not(:checked)+label {
                position: relative;
                padding-left: 28px;
                cursor: pointer;
                line-height: 20px;
                display: inline-block;
                color: var(--text-default);
            }

            [type="radio"]:checked+label:before,
            [type="radio"]:not(:checked)+label:before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                width: 18px;
                height: 18px;
                border: 1px solid #777;
                border-radius: 100%;
                background: #fff;
            }

            [type="radio"]:checked+label:after,
            [type="radio"]:not(:checked)+label:after {
                content: '';
                width: 8px;
                height: 8px;
                background: var(--lightblue);
                position: absolute;
                top: 5px;
                left: 5px;
                border-radius: 100%;
                -webkit-transition: all 0.2s ease;
                transition: all 0.2s ease;
            }

            [type="radio"]:not(:checked)+label:after {
                opacity: 0;
                -webkit-transform: scale(0);
                transform: scale(0);
            }

            [type="radio"]:checked+label:after {
                opacity: 1;
                -webkit-transform: scale(1);
                transform: scale(1);
            }

            [type="button"],
            [type="submit"],
            button {
                -webkit-appearance: button;
                appearance: button;
            }

            [type="button"]:not(:disabled),
            [type="submit"]:not(:disabled),
            button:not(:disabled) {
                cursor: pointer;
            }

            [type="button"]::-moz-focus-inner,
            [type="submit"]::-moz-focus-inner,
            button::-moz-focus-inner {
                padding: 0;
                border-style: none;
            }

            input[type="checkbox"]:focus { outline: 0; }

            label {
                /* undo bootstrap-enterprise */
                margin-bottom: 4px !important;
                /* margin-right: 4px !important; */
            }

            input:disabled {
                outline: none;
                -webkit-box-shadow: none;
                box-shadow: none;
                background: #F2F2F2;
                color: var(--text-default);
            }

            input::placeholder { color: #888; }

            input[type="text"],
            input[type="password"] {
                /* undo bootstrap-enterprise */
                margin-bottom: unset;
            }

            input:not([value=""])[type="text"] {
                border-color: var(--component-border);
            }

            input:invalid {
                border-color: var(--state-error-background);
            }

            button { border-radius: 0; }

            button:focus {
                outline: 1px dotted;
                outline: 5px auto -webkit-focus-ring-color;
            }

            button,
            input,
            select {
                margin: 0;
                font-family: inherit;
                line-height: inherit;
            }

            button,
            input {
                overflow: visible;
            }

            button,
            select {
                text-transform: none;
            }

            input[type="checkbox"].toggle {
                height: 20px;
                width: 40px;
                border-radius: 16px;
                display: inline-block;
                position: relative;
                margin: 0;
                background-color: var(--component-border);
                transition: all .2s ease;
                -webkit-appearance: none;
                -moz-appearance: none;
                appearance: none;
                -webkit-tap-highlight-color: transparent;
                cursor: pointer;
            }

            input[type="checkbox"].toggle:after {
                content: '';
                position: absolute;
                top: -2.5px;
                left: -2px;
                width: 24px;
                height: 24px;
                border-radius: 50%;
                background: white;
                box-shadow: 0 2px 6px rgba(153, 153, 153, 0.75);
                transition: all .2s cubic-bezier(.5, .1, .75, 1.35);
            }

            input[type="checkbox"].toggle:checked {
                background-color: var(--lightblue);
            }

            input[type="checkbox"].toggle:checked::after {
                transform: translatex(20px);
            }

            input[type="checkbox"].toggle:focus {
                box-shadow: unset;
            }
            
            .form-label {
                margin-bottom: 4px;
                min-width: 170px;
            }

            input {
                margin: 0 3px;
            }

            #saveSettings {
                float: right;
            }

            .hidden {
                display: none;
            }

            .formBlock {
                display: flex;
                flex-direction: column;
            }

            /* Capability notice displayed only when unprivileged (toggled via JS) */
            .config-section { display: block; }

            .okblock {
                    border: 3px solid #1a8929;
                }
                .oktext {
                    color: #1a8929;
                }

                .errorblock {
                    border: 3px solid red;
                }
                .errortext {
                    color: red;
                }

                .unknownblock {
                    border: 3px solid gray;
                }
                .unknowntext {
                    color: gray;
                }


                /* Layout helpers for side-by-side sections */
                .rowGrid2 {
                    display: grid;
                    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
                    gap: 24px;
                    align-items: start;
                    width: 100%;
                }
                .rowGrid2.rowGrid2-fixed {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }
                .colFlex {
                    display: flex;
                    flex-direction: column;
                    min-width: 0;
                }
                .rowGrid2 .formContainer { min-width: 0 !important; }
                .rowGrid2 .formContainer.formBlock { min-width: 0 !important; }

                #apiKey {
                width: 300px;
                }
        </style>

        <div id="capabilityWarning">Connect to your administrator to change settings.</div>

        <div id="generalSettings" class="config-section">
          <div class="">
            <div id="errorBlock"></div>
            <div id="successBlock"></div>
            <h2>Common settings</h2>

          <span id="formContainer" class="formContainer">
            <div class="form-label">
            <label for="enableProxy">Enable Proxy</label>
            </div>
            <input type="checkbox" id="enableProxy" class="toggle" role="checkbox" aria-checked="false"></input>
          </span>

          <span id="proxyProtocolContainer" class="formContainer proxyProtocolContainer hidden">
            <div class="form-label">
            <label>Proxy Protocol</label>
            </div>
            <div style="display: flex; gap: 20px;">
              <input type="radio" id="proxyHttp" name="proxyProtocol" value="http" checked="true"></input>
              <label for="proxyHttp">HTTP</label>
              <input type="radio" id="proxyHttps" name="proxyProtocol" value="https" checked="false"></input>
              <label for="proxyHttps">HTTPS</label>
            </div>
          </span>

          <span id="proxyHostContainer" class="formContainer proxyHostContainer hidden">
            <div class="form-label">
            <label for="proxyHost">Proxy Server</label>
            </div>
            <input type="text" id="proxyHost" placeholder="Enter Proxy Host" style="width: 200px"></input>
            <p>:</p>
            <input type="number" id="proxyPort" placeholder="Enter Port" style="width: 150px"></input>
          </span>

          <span id="proxyAuthContainer" class="formContainer proxyAuthContainer hidden">
            <div class="form-label">
            <label for="proxyAuth">Authentication required</label>
            </div>
            <input type="checkbox" id="proxyAuth" class="toggle" role="checkbox" aria-checked="false"></input>
          </span>


          <span id="authenticationContainer" class="formContainer authenticationContainer hidden">
            <div class="form-label">
            <label for="proxyUsername">Authentication</label>
            </div>
            <input type="text" id="proxyUsername" placeholder="Enter Proxy Username" style="width: 200px"></input>
            <input type="password" id="proxyPassword" placeholder="Enter Proxy Password" style="width: 200px"></input>
          </span>

          <span id="formContainer" class="formContainer">
            <div class="form-label">
              <label for="logLevel">Log Level</label>
            </div>
              <select id="logLevel" style="width: 200px">
                  <option value="debug">DEBUG</option>
                  <option value="info" selected="true">INFO</option>
                  <option value="warning">WARNING</option>
                  <option value="error">ERROR</option>
                  <option value="critical">CRITICAL</option>
            </select>
          </span>

          <div class="formContainer">
              <button id="saveSettings" class="btn btn-primary">Save</button>
          </div>
          </div>

        </div>
        </html>
    </panel>
  </row>
  <row>
    <panel>
        <html>
        <div id="generalSettings" class="config-section">
          <div class="">
            <h2>Sandbox</h2>
            <a id="api_type" href="sb"></a>
            <div id="errorBlockSandbox"></div>
            <div id="successBlockSandbox"></div>
                <div class="formBlock formContainer">
                  <label for="apiKey">API Key</label>
                  <input type="password" id="apiKey" placeholder="22i8u4o5rCERaq..."></input>
                  <div id="apiKey-help" class="input-help">Enter your API Key to save the settings</div>

                  <button id="saveApiKeySandbox" class="btn btn-primary">Save</button>
                </div>
            </div>

          <hr/>

          <div class="sb_settings">
            <h2>Sandbox Submission Settings</h2>
            <div id="errorBlockSandboxSubmission"></div>
            <div id="successBlockSandboxSubmission"></div>
            <p style="margin-bottom: 10px; width: 32rem;">Use official documentation to set the values for the sandbox submission settings: <a href="https://any.run/api-documentation/#tag/analysis/post/v1/analysis" target="_blank">https://any.run/api-documentation/#tag/analysis/post/v1/analysis</a></p>

            <div class="formContainer formBlock" style="min-width: 0;">
              <div class="form-label">
                <label for="analysisDuration">Analysis duration (Max: 300s)</label>
              </div>
              <div class="input-group">
                  <input type="number" id="analysisDuration" placeholder="Enter Analysis Duration" value="120"></input>
                  <span class="input-group-text" id="basic-addon2">seconds</span>
              </div>
              <div id="analysisDuration-help" class="input-help">Set the analysis duration for the sandbox submissions</div>
            </div>

            <div class="formContainer formBlock" style="min-width: 0;">
              <div class="form-label">
                <label for="osLocale">Operating system's language (env_locale)</label>
              </div>
              <div class="input-group">
                  <input type="text" id="osLocale" placeholder="en-US" value="en-US" style="width: 5rem;"></input>
              </div>
              <div id="osLocale-help" class="input-help">Set the operating system's language for the sandbox submissions</div>
            </div>

            <div class="formContainer formBlock" style="min-width: 0;">
              <div class="form-label">
                <label for="analysisPrivacyType">Analysis privacy type (opt_privacy_type)</label>
              </div>
              <div class="input-group">
                <select id="analysisPrivacyType" style="width: 220px;">
                  <option value="Who has a link" selected="selected">Who has a link</option>
                  <option value="Only me">Only me</option>
                  <option value="Public">Public</option>
                  <option value="My ANY.RUN Team">My ANY.RUN Team</option>
                </select>
              </div>
              <div id="analysisPrivacyType-help" class="input-help">Set task privacy for sandbox submissions</div>
            </div>

            
            <!--
            <span id="formContainer" class="formContainer">
              <div class="form-label">
              <label for="elevated">Force the file to execute with elevated privileges (obj_force_elevation, run_as_root)</label>
              </div>
              <br/>
              <div class="input-group">
                <input type="checkbox" id="elevated" class="toggle" role="checkbox" aria-checked="false"></input>
              </div>
            </span>
            -->

            <span id="formContainer" class="formContainer">
              <div class="form-label">
              <label for="torBrowsing">TOR browsing (opt_network_tor)</label>
              </div>
              <br/>
              <div class="input-group">
                <input type="checkbox" id="torBrowsing" class="toggle" role="checkbox" aria-checked="false"></input>
              </div>
            </span>


            <span id="formContainer" class="formContainer">
              <div class="form-label">
              <label for="mitm">HTTPS Man-in-the-middle (MITM) proxy interception (opt_network_mitm)</label>
              </div>
              <br/>
              <div class="input-group">
                <input type="checkbox" id="mitm" class="toggle" role="checkbox" aria-checked="false"></input>
              </div>
            </span>

            <!--
            <span id="formContainer" class="formContainer">
              <div class="form-label">
              <label for="residentialProxy">Residential proxy (opt_network_residential_proxy)</label>
              </div>
              <br/>
              <div class="input-group">
                <input type="checkbox" id="residentialProxy" class="toggle" role="checkbox" aria-checked="false"></input>
              </div>
            </span>
            -->

            <button id="saveSandboxSubmissionSettings" class="btn btn-primary">Save</button>
          </div>

          </div>
        </html>
    </panel>
  </row>
  <row>
    <panel>
        <html>
        <div id="generalSettings" class="config-section">
          <div class="">
            <h2>Lookup</h2>
            <a id="api_type" href="lk"></a>
            <div id="errorBlockLookup"></div>
            <div id="successBlockLookup"></div>
            <div class="formContainer formBlock">
                  <label for="apiKey">API Key</label>
                  <input type="password" id="apiKey" placeholder="22i8u4o5rCERaq...">
                  </input>
                  <div id="apiKey-help" class="input-help">Enter your API Key to save the settings</div>

                </div>

                <div class="formContainer formBlock">
                  <div id="depthSelectorContainer">
                    <label for="depthSelector">Depth (days)</label>
                    <select id="depthSelector" style="width: 120px;">
                      <option value="180">180</option>
                      <option value="90">90</option>
                      <option value="60">60</option>
                      <option value="30">30</option>
                      <option value="14">14</option>
                      <option value="7">7</option>
                      <option value="3">3</option>
                      <option value="1">1</option>
                    </select>
                    
                    <input type="number" id="manualDepthInput" placeholder="Enter days" min="1" max="180" step="1" style="width: 100px; display: none; margin-left: 10px;" />
                    <div id="manualDepthError" class="input-help error" style="display:none; margin-left: 10px;"></div>
                    
                  </div>
                </div>
                <script>
                  // Show/hide manual input based on selector
                  document.addEventListener('DOMContentLoaded', function() {
                    var selector = document.getElementById('depthSelector');
                    var manualInput = document.getElementById('manualDepthInput');
                    var errorEl = document.getElementById('manualDepthError');

                    function clearError() {
                      errorEl.textContent = '';
                      errorEl.style.display = 'none';
                    }

                    function showError(message) {
                      errorEl.textContent = message;
                      errorEl.style.display = 'block';
                    }

                    function validateManualDepth() {
                      var value = manualInput.value.trim();
                      // If empty, don't show an error until user enters something
                      if (value === '') {
                        clearError();
                        return true;
                      }

                      // Allow only integers
                      var isInteger = /^\d+$/.test(value);
                      if (!isInteger) {
                        showError('Input is not a number. Enter number');
                        return false;
                      }

                      var numericValue = Number(value);
                      if (numericValue > 180) {
                        showError("You can't get data for more than 180 days");
                        return false;
                      }

                      clearError();
                      return true;
                    }

                    selector.addEventListener('change', function() {
                      if (selector.value === 'manual') {
                        manualInput.style.display = 'inline-block';
                        manualInput.focus();
                      } else {
                        manualInput.style.display = 'none';
                        manualInput.value = '';
                        clearError();
                      }
                    });

                    manualInput.addEventListener('input', validateManualDepth);
                    manualInput.addEventListener('blur', validateManualDepth);
                  });
                </script>


                <button id="saveApiKeyLookup" class="btn btn-primary">Save</button>

                <a id="api_type" href="lk"></a>
              </div>
            </div>
        </html>
    </panel>
  </row>
  <row>
    <panel>
        <html>
        <div id="generalSettings" class="config-section">
          <div class="">
            <h2>TI Feed</h2>
            <div id='formContainer' class="formContainer formBlock">
              <div id="errorBlockTiFeedToken"></div>
              <div id="successBlockTiFeedToken"></div>
              <label for="basicToken">API Key</label>
              <input type="password" id="basicToken" placeholder="22i8u4o5rCERaq...">
              </input>
              <div id="basicToken-help" class="input-help">Enter your API Key to save the settings</div>

            </div>
          </div>
        </div>
        
        <div id='threatIntelligenceFeedSettings' class="config-section">
            <div class="formContainer">
              <h2>Threat Intelligence Feed settings</h2>
            </div>
            <div id="errorBlockTiFeedSettings"></div>
            <div id="successBlockTiFeedSettings"></div>
            
            <div class="rowGrid2">
              <div class="colFlex">
                <div class="formContainer formBlock" style="min-width: 0;">
                  <label for="initialIngestingInterval">Ingesting depth</label>
                  <div class="input-group">
                      <input type="number" id="initialIngestingInterval" placeholder="Enter Ingesting depth" value="30"></input>
                      <span class="input-group-text" id="basic-addon2">days</span>
                  </div>
                  <div id="initialIngestingInterval-help" class="input-help">Set how many days of data will be ingested</div>
                </div>
              </div>
                <div class="colFlex">
                <div class="formContainer formBlock">
                <label for="interval">Update interval</label>
                <div class="input-group">
                  <input type="number" id="interval" placeholder="Enter Update interval" value="600"></input>
                  <span class="input-group-text" id="basic-addon2">minutes</span>
                </div>
                <div id="interval-help" class="input-help">Set how often the Threat Intelligence Feed will be updated</div>
              </div> 
              </div>
            </div>

            <button id="saveBasicToken" class="btn btn-primary">Save</button>
            <!-- <button id="saveThreatIntelligenceFeed" class="btn btn-primary">Save</button> -->
        </div>
        </html>
    </panel>
  </row>
</dashboard>