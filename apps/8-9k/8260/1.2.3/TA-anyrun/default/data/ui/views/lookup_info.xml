<dashboard version="1.1">
  <label>ANY.RUN TI Lookup</label>

  <row>
    <panel>
      <title>Verdicts distribution</title>
      <description>Distribution of verdicts over time</description>

      <input type="time" token="time_ioc_pie">
        <label>Time Range</label>
        <default>
          <earliest>-14d</earliest>
          <latest>now</latest>
        </default>
      </input>
      <chart>
        <search>
          <query>
            <![CDATA[
            index="anyrun" source="ANY.RUN TI Lookup" sourcetype="ANY.RUN"
            | table lookup_verdict 
            | where lookup_verdict != ""
            | rename lookup_verdict as verdict 
            | stats count by verdict
            ]]>
          </query>
          <earliest>$time_ioc_pie.earliest$</earliest>
          <latest>$time_ioc_pie.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
      </chart>
    </panel>

    <panel>
      <title>Daily Searches by Verdict</title>
      <description>Daily searches by verdict</description>
      <input type="time" token="verdict_time">
        <label>Time Range</label>
        <default>
          <earliest>-7d</earliest>
          <latest>now</latest>
        </default>
      </input>

      <chart>
        <search>
          <query>
            <![CDATA[
            index="anyrun" source="ANY.RUN TI Lookup" sourcetype="ANY.RUN"
            | where lookup_verdict != ""
            | timechart span=1d count BY lookup_verdict
            ]]>
          </query>
          <earliest>$verdict_time.earliest$</earliest>
          <latest>$verdict_time.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top 5 Industries</title>
      <description>Top 5 industries</description>
      <input type="time" token="time_ioc_types">
        <label>Time Range</label>
        <default>
          <earliest>-7d</earliest>
          <latest>now</latest>
        </default>
      </input>
      <chart>
        <search>
          <query>
            <![CDATA[
            index="anyrun" source="ANY.RUN TI Lookup" sourcetype="ANY.RUN"
            | spath path=industries{} output=industry
            | mvexpand industry
            | where industry != ""
            | stats count by industry
            | sort -count
            | head 5
            | rename count as "Count"
            | rename industry as "Industry"
            ]]>
          </query>
          <earliest>$time_ioc_types.earliest$</earliest>
          <latest>$time_ioc_types.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
      </chart>
    </panel>

    <panel>
      <title>Top 5 Tags</title>
      <description>Top 5 tags</description>
      <input type="time" token="time_ioc_types">
        <label>Time Range</label>
        <default>
          <earliest>-7d</earliest>
          <latest>now</latest>
        </default>
      </input>
      <chart>
        <search>
          <query>
            <![CDATA[
            index="anyrun" source="ANY.RUN TI Lookup" sourcetype="ANY.RUN"
            | spath path=lookup_tags{} output=tag
            | mvexpand tag
            | where tag != ""
            | stats count by tag
            | sort -count
            | head 5
            | rename count as "Count"
            | rename tag as "Tag"
            ]]>
          </query>
          <earliest>$time_ioc_types.earliest$</earliest>
          <latest>$time_ioc_types.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Table with main_object - lookup_verdict</title>
      <table>
        <search>
          <query>
            <![CDATA[
            index="anyrun" source="ANY.RUN TI Lookup" sourcetype="ANY.RUN"
            | table lookup_object, lookup_verdict, _time
            | where lookup_verdict != ""
            | sort -_time
            | head 10
            | convert timeformat="%Y-%m-%d %H:%M:%S" ctime(_time) AS lookup_date 
            | table lookup_object, lookup_verdict, lookup_date
            | rename lookup_object as "Lookup Object"
            | rename lookup_verdict as "Lookup Verdict"
            | rename lookup_date as "Lookup Date"
            ]]>
          </query>
        </search>
      </table>
    </panel>
  </row>

</dashboard>
