<?xml version="1.0"?>
<!--
  App-local mount of Splunk's built-in Search experience.  Mirrors the
  stock view at $SPLUNK_HOME/etc/apps/search/default/data/ui/views/search.xml
  so that /app/vh_enrichment_app/search renders the full omnibar + timeline
  + job inspector inside this app's context — keeping the VH Enrichment
  App nav, breadcrumbs, and dispatched-search namespace intact instead of
  punting the user out to /app/search/search.

  pages/search.html is a system template provided by search_mrsparkle, not
  an asset of the search app, so every app may declare this view.  The
  nav's search_view="search" attribute (default.xml) resolves to this view
  first, so implicit "open in search" links from dashboards in this app
  also stay in-app.
-->
<view template="pages/search.html" type="html" isDashboard="False">
    <label>Search</label>
</view>
