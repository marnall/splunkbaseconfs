<dashboard version="1.1" script="vh_enrichment_overview_v3.js">
  <label>Data Ingestion</label>

  <row>
    <panel>
      <title>Ingestion Status</title>
      <html>
        <div style="font-size:13px; line-height:2;">
          <table style="border-collapse:collapse;">
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Last action:</td>
              <td id="vh-status-last-action">—</td>
            </tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Last changed:</td>
              <td id="vh-status-updated-at">—</td>
            </tr>
            <tr><td colspan="2" style="padding:4px 0;border-top:1px solid #eee;"></td></tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Run status:</td>
              <td id="vh-status-run-status">—</td>
            </tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Current phase:</td>
              <td id="vh-status-current-phase">—</td>
            </tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Records inserted:</td>
              <td id="vh-status-records-inserted">—</td>
            </tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Last record count:</td>
              <td id="vh-status-last-record-count">—</td>
            </tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Last heartbeat:</td>
              <td id="vh-status-last-heartbeat">—</td>
            </tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Run started:</td>
              <td id="vh-status-run-started">—</td>
            </tr>
            <tr>
              <td style="font-weight:bold; padding-right:16px;">Run completed:</td>
              <td id="vh-status-run-completed">—</td>
            </tr>
          </table>
          <div id="vh-status-note" style="margin-top:8px; font-size:12px; color:#777;"></div>
          <div id="vh-status-run-error" style="margin-top:4px; font-size:12px; color:#c00; display:none;"></div>
          <div id="vh-status-loading" style="margin-top:4px; font-size:12px; color:#999;">Loading…</div>
          <div style="margin-top:10px; font-size:11px; color:#bbb;">
            Script: <span id="vh-js-indicator" style="color:#bbb;">not yet loaded</span>
          </div>
        </div>
      </html>
    </panel>

    <panel>
      <title>Actions</title>
      <html>
        <div style="line-height:2.4;">
          <button id="vh-btn-clear"   type="button" style="margin-right:6px;">Clear KV Store</button>
          <button id="vh-btn-run-now" type="button" style="margin-right:6px;">Run Now</button>
          <button id="vh-btn-stop"    type="button" style="margin-right:6px; display:none;">Stop Ingestion</button>
          <button id="vh-btn-refresh" type="button">Refresh Status</button>
          <div id="vh-action-result" style="margin-top:8px; font-size:13px; font-weight:bold;"></div>
          <div style="margin-top:6px; font-size:12px; color:#777;">
            Run Now downloads the latest snapshot and adds or updates records (matched by IP).
            It does not remove anything — Clear KV Store is the only action that empties the collection
            (and may take up to 2 minutes for large collections).
            Stop Ingestion preserves whatever has already been inserted.
          </div>
        </div>
      </html>
    </panel>
  </row>

  <row>
    <panel>
      <title>Scheduled Run</title>
      <html>
        <div style="font-size:13px;">
          <div style="margin-bottom:6px; font-size:12px; color:#777;">
            Run once daily at the configured time. Timezone defaults to your Splunk user preference.
            Use Run Now for an immediate ingestion (adds and updates records; never deletes).
          </div>
          <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
            <input id="vh-schedule-time" type="time"
                   style="height:30px; padding:0 8px; font-size:13px; border:1px solid #ccc;
                          border-radius:3px; box-sizing:border-box; margin-bottom:10px;" />
            <select id="vh-schedule-tz"
                    style="height:30px; padding:0 6px; font-size:13px; border:1px solid #ccc;
                           border-radius:3px; box-sizing:border-box; margin-bottom:10px;
                           max-width:260px;">
              <option value="UTC">UTC</option>
            </select>
            <button id="vh-btn-enable-schedule" type="button"
                    style="margin-bottom:10px;">Enable Schedule</button>
            <button id="vh-btn-save-schedule" type="button"
                    style="display:none; margin-bottom:10px;">Save Schedule</button>
            <button id="vh-btn-disable-schedule" type="button"
                    style="display:none; margin-bottom:10px;">Disable Schedule</button>
          </div>
          <div id="vh-schedule-result" style="font-size:13px; font-weight:bold; margin-top:2px;"></div>
        </div>
      </html>
    </panel>
  </row>

  <row>
    <panel>
      <title>KV Store Record Count</title>
      <table>
        <search>
          <query>| inputlookup vh_enrichment_lookup | stats count</query>
          <refresh>60s</refresh>
        </search>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Sample Data (first 10 records)</title>
      <table>
        <search>
          <query>| inputlookup vh_enrichment_lookup | head 10</query>
          <refresh>60s</refresh>
        </search>
      </table>
    </panel>
  </row>

</dashboard>
