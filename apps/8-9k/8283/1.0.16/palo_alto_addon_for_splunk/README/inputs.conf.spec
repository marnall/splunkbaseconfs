[palo_alto_input://<name>]
account = Account to use for this input.
api_endpoints = Configure API Endpoints from Configuration -> API Endpoints tab
index = 
index_type = Select whether data should be sent as events or metrics (Default: events)
interval = Time interval of the data input, in seconds. (Default: 300)
ip_address = Comma-separated list of IPv4 addresses (e.g., 192.168.1.1, 10.0.0.1, 172.16.0.1)
sourcetype = Select the sourcetype for ingested events (Default: pan:log)
