<form version="1.1" script="telegram_settings.js">
  <label>Telegram App Settings</label>
  <description>Global settings for Telegram alert action.</description>

  <fieldset submitButton="false">
  </fieldset>

  <row>
    <panel>
      <title>Proxy Settings</title>
      <html>
        <div style="padding: 15px;">
          <h2>Telegram Proxy Settings</h2>

          <p>
            Configure proxy settings used by Telegram alert action.
          </p>

          <table style="border-collapse: collapse; width: 650px;">
            <tr>
              <td style="padding: 8px; width: 220px;">Proxy enabled</td>
              <td style="padding: 8px;">
                <input type="checkbox" id="proxy_enabled" />
              </td>
            </tr>

            <tr>
              <td style="padding: 8px;">Proxy scheme</td>
              <td style="padding: 8px;">
                <select id="proxy_scheme" style="width: 310px;">
                  <option value="http">http</option>
                  <option value="https">https</option>
                </select>
              </td>
            </tr>

            <tr>
              <td style="padding: 8px;">Proxy host / IP</td>
              <td style="padding: 8px;">
                <input type="text" id="proxy_ip" placeholder="127.0.0.1" style="width: 300px;" />
              </td>
            </tr>

            <tr>
              <td style="padding: 8px;">Proxy port</td>
              <td style="padding: 8px;">
                <input type="text" id="proxy_port" placeholder="3128" style="width: 300px;" />
              </td>
            </tr>

            <tr>
              <td style="padding: 8px;">Request timeout</td>
              <td style="padding: 8px;">
                <input type="text" id="request_timeout" placeholder="10" style="width: 300px;" />
              </td>
            </tr>

            <tr>
              <td style="padding: 8px;">Verify SSL</td>
              <td style="padding: 8px;">
                <input type="checkbox" id="verify_ssl" checked="checked" />
              </td>
            </tr>
          </table>

          <br />

          <button class="btn btn-primary" id="save_settings">
            Save settings
          </button>

          <p id="status_message" style="margin-top: 15px;"></p>
        </div>
      </html>
    </panel>
  </row>
</form>
