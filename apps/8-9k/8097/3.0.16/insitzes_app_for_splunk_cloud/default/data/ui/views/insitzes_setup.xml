<dashboard version="1.1" theme="dark" script="insitzes_setup_3_0_16.js" stylesheet="insitzes_setup_3_0_16.css">
    <label>Setup</label>
    <row>
        <panel>
            <html>
                <div id="insitzes-setup-container">
                    <div class="setup-header">
                        <h2>Setup</h2>
                        <p>Configure the app for your Splunk Cloud environment. Settings are saved to <code>local/macros.conf</code> and take effect immediately.</p>
                    </div>
                    <div id="setup-message" class="setup-message" style="display:none;"></div>

                    <div class="setup-section">
                        <h3>Licensing</h3>
                        <div class="setup-field">
                            <label for="insitzes_licensing_model">Licensing Model</label>
                            <input type="text" id="insitzes_licensing_model" value="svc" />
                            <span class="field-help">svc or ingest — SVC shows compute metrics. Ingest shows license usage monitoring.</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_splunkcloud_domain">Splunk Cloud Domain</label>
                            <input type="text" id="insitzes_splunkcloud_domain" value="splunkcloud.com" />
                            <span class="field-help">splunkcloud.com or splunkcloudgc.com for GovCloud</span>
                        </div>
                    </div>

                    <div class="setup-section">
                        <h3>Feature Toggles</h3>
                        <div class="setup-field">
                            <label for="insitzes_has_ddaa">DDAA (Archive Storage)</label>
                            <input type="text" id="insitzes_has_ddaa" value="1" />
                            <span class="field-help">1 = enabled (shows archive storage panels), 0 = disabled</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_has_idm">IDM (Identity Management)</label>
                            <input type="text" id="insitzes_has_idm" value="0" />
                            <span class="field-help">1 = enabled (shows IDM panels, health check, and remediation guide), 0 = disabled</span>
                        </div>

                    </div>


                    <div class="setup-section">
                        <h3>Cost Rates</h3>
                        <p class="section-help">Enter dollar rates to enable the Cost view toggles on the Compute and Storage tabs. Leave blank to hide the toggle.</p>
                        <div class="setup-field">
                            <label for="insitzes_cost_per_svc">Cost per Compute Unit (SVC) ($)</label>
                            <input type="text" id="insitzes_cost_per_svc" />
                            <span class="field-help">e.g. 500.00 — used by the Compute tab's Cost toggle</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_cost_per_ddas_500gb">Cost per 500GB DDAS ($)</label>
                            <input type="text" id="insitzes_cost_per_ddas_500gb" />
                            <span class="field-help">e.g. 1500.00 — used by the Storage tab's Cost toggle for DDAS metrics</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_cost_per_ddaa_500gb">Cost per 500GB DDAA ($)</label>
                            <input type="text" id="insitzes_cost_per_ddaa_500gb" />
                            <span class="field-help">e.g. 500.00 — used by the Storage tab's Cost toggle for DDAA metrics</span>
                        </div>
                    </div>

                    <div class="setup-section">
                        <h3>Alerting</h3>
                        <div class="setup-field">
                            <label for="insitzes_alert_email">Alert Email Distribution</label>
                            <input type="text" id="insitzes_alert_email" />
                            <span class="field-help">Email address or distribution list to receive all health check alerts (e.g. ops-team@example.com). Alerts are disabled by default; enter an address and save to activate them.</span>
                        </div>
                    </div>

                    <div class="setup-section">
                        <h3>Advanced</h3>
                        <div class="setup-field">
                            <label for="insitzes_exclude_system_users">System User Exclusions</label>
                            <input type="text" id="insitzes_exclude_system_users" />
                            <span class="field-help">e.g. NOT user IN ("cmon_user", "internal_observability")</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_set_index_cmc_summary">Summary Indexes</label>
                            <input type="text" id="insitzes_set_index_cmc_summary" />
                            <span class="field-help">e.g. (index=_cmc_summary OR index=summary)</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_rest_timeout">REST Timeout (seconds)</label>
                            <input type="text" id="insitzes_rest_timeout" value="30" />
                            <span class="field-help">Client-side timeout applied to Splunk REST API calls (macro reads, alert toggles, job polling). Default: 30</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_search_timeout">Search Timeout (seconds)</label>
                            <input type="text" id="insitzes_search_timeout" value="300" />
                            <span class="field-help">Client-side timeout applied to dashboard SPL searches. Raise this if long-running checks (Index Governance, sourcetype scans) hit the limit. Default: 300</span>
                        </div>
                        <div class="setup-field">
                            <label for="insitzes_debug_mode">Debug Mode</label>
                            <input type="text" id="insitzes_debug_mode" value="0" />
                            <span class="field-help">1 = enabled (shows error details on crash), 0 = disabled</span>
                        </div>
                    </div>

                    <div class="setup-actions">
                        <button id="setup-save-btn" class="btn btn-primary">Save Configuration</button>
                        <span id="setup-status"></span>
                    </div>
                </div>
            </html>
        </panel>
    </row>
</dashboard>
