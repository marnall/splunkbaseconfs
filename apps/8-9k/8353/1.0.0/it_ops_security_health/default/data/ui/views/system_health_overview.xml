<dashboard theme="dark" version="1.1">
  <label>System Health Overview</label>
  <description>Turn the high Errors &amp; Warnings numbers from Home into actionable insights:</description>
  <row>
    <panel>
      <single>
        <search>
          <query>index=_internal sourcetype=splunkd log_level=ERROR earliest=-24h
| stats count AS value</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[10,50]</option>
        <option name="underLabel">System Errors (24h)</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <search>
          <query>index=_internal sourcetype=splunkd log_level=WARN earliest=-24h
| stats count AS value</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[100,1000]</option>
        <option name="underLabel">System Warnings (24h)</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <search>
          <query>index=_internal sourcetype=splunkd earliest=-24h
| eval error=if(log_level="ERROR",1,0)
| eval warn=if(log_level="WARN",1,0)
| stats sum(error) AS errors sum(warn) AS warnings
| eval ratio = if(warnings&gt;0, round(errors/warnings,2), errors)
| table ratio</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0.00</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[0.1,0.3]</option>
        <option name="underLabel">Error / Warning Ratio</option>
        <option name="useColors">1</option>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Error Trend (24h)</title>
        <search>
          <query>index=_internal sourcetype=splunkd log_level=ERROR earliest=-24h
| timechart span=1h count AS errors</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Warning Trend (24h)</title>
        <search>
          <query>index=_internal sourcetype=splunkd log_level=WARN earliest=-24h
| timechart span=1h count AS warnings</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Errors by Component</title>
        <search>
          <query>index=_internal sourcetype=splunkd log_level=ERROR earliest=-24h
| stats count AS errors BY component
| sort - errors
| head 10</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.placement">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Warnings by Component</title>
        <search>
          <query>index=_internal sourcetype=splunkd log_level=WARN earliest=-24h 
| stats count AS warnings BY component 
| sort - warnings 
| head 10</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
</dashboard>