<dashboard theme="dark" version="1.1">
  <label>Authentication Risk Overview</label>
  <description>Login failures and authentication risk analysis</description>
  <row>
    <panel>
      <single>
        <search>
          <query>index=_audit action=login_failure earliest=-24h
| stats count AS value</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="height">199</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[5,20]</option>
        <option name="underLabel">Failed Logins (24h)</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <chart>
        <title>Failed Login Trend (24h)</title>
        <search>
          <query>index=_audit action=login_failure earliest=-24h
| timechart span=1h count AS failures</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Top Users with Failed Logins</title>
        <search>
          <query>index=_audit action=login_failure earliest=-24h
| stats count AS failures BY user
| sort - failures</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Failed Logins by Source IP</title>
        <search>
          <query>index=_audit action=login_failure earliest=-24h
| stats count AS failures BY src
| sort - failures</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
</dashboard>