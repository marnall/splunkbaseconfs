<dashboard isDashboard='false'
           script='javascript/setup_page.js'
           stylesheet='styles/setup_page.css'
           hideTitle='true'
           version='1.1'>
    <row>
        <panel>
            <html>
                <div class='admin-dialog-content'>
                    <h3>Destination index for Kollective input data</h3>
                    <div class="content">
                        <label>
                            <input 
                                type="radio" 
                                id="radio-existing-index" 
                                name="radio-index" 
                                value="true"
                                checked="true">Use existing index</input>
                        </label>
                        <span class="span">Select an existing index:</span>
                        <select id="index-dropdown" token='index' style="width: 250px;"/>
                    </div>
                    <div class="content">
                        <label>
                            <input 
                                type="radio" 
                                id="radio-new-index" 
                                name="radio-index" 
                                value="false">Create new index</input>
                        </label>
                        <span class="span">Name of the new index:</span>
                        <input type="text" id="index-entry" token="new-index" style="width: 250px;"/>
                        <div class="text">
                        Note: Index will be created with the default settings.<br/>
                        For more information see <a 
                            href="https://docs.splunk.com/Documentation/Splunk/Latest/Indexer/Configureindexstorage"
                            target="_blank" 
                            rel="noopener noreferrer">
                        Configure index storage - Splunk Documentation
                        </a>
                        </div>
                    </div>
                </div>
                <div class='admin-dialog-tray'>
                    <button id='setup-button' class="splButton-primary">Complete Setup</button>
                    <div class='success'>Redirecting to Video Experience powered by Kollective...</div>
                    <div class='error'>Issue encountered during setup, details below:</div>
                    <code id='error_details'></code>
                </div>
            </html>
        </panel>
    </row>
</dashboard>
