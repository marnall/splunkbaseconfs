# @placement search-head
#
# Search assistant syntax definitions for Whisper Security TA.
#
# Provides inline help, auto-complete, and syntax validation
# for custom search commands in the Splunk search bar.
#

[whisperlookup-command]
syntax = <string> BNF syntax definition for the whisperlookup command.
alias = <string> Command aliases.
shortdesc = <string> Short description shown in search assistant.
description = <string> Full description of command behavior.
usage = <string> Usage visibility (public).
example1 = <string> First usage example.
comment1 = <string> Description of first example.
example2 = <string> Second usage example.
comment2 = <string> Description of second example.
tags = <string> Space-separated tags for search categorization.

[whisperlookup-command-type]
syntax = <string> BNF syntax for the type argument values.

