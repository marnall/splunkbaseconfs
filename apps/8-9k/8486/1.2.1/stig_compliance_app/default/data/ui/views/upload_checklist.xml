<dashboard version="1.1" theme="dark" script="upload_checklist.js">
  <label>Upload Checklist</label>
  <description>Upload .ckl or .cklb checklist files for compliance reporting</description>
  <row>
    <panel>
      <html>
        <style>
          .upload-container {
            max-width: 800px;
            margin: 20px auto;
            padding: 0 20px;
          }
          .upload-card {
            background-color: #1a1f28;
            border: 1px solid #2d343e;
            border-radius: 6px;
            padding: 30px;
            margin-bottom: 20px;
          }
          .upload-area {
            border: 2px dashed #3d4654;
            border-radius: 6px;
            padding: 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
            margin-bottom: 20px;
          }
          .upload-area:hover {
            border-color: #5b9bd5;
            background-color: #1e2530;
          }
          .upload-area.dragover {
            border-color: #5b9bd5;
            background-color: #1e2530;
          }
          .upload-area.has-file {
            border-color: #65a637;
            background-color: #1e2a1e;
          }
          .upload-icon {
            font-size: 48px;
            color: #5b9bd5;
            margin-bottom: 15px;
          }
          .upload-text {
            font-size: 16px;
            color: #c3cbd4;
            margin-bottom: 8px;
          }
          .upload-subtext {
            font-size: 13px;
            color: #8e929b;
          }
          .file-info {
            display: none;
            background-color: #222830;
            border-radius: 4px;
            padding: 12px 16px;
            margin-bottom: 20px;
          }
          .file-info.visible {
            display: flex;
            align-items: center;
          }
          .file-name {
            flex-grow: 1;
            font-size: 14px;
            color: #c3cbd4;
          }
          .file-size {
            font-size: 13px;
            color: #8e929b;
            margin-left: 15px;
          }
          .file-remove {
            color: #d93f3c;
            cursor: pointer;
            margin-left: 15px;
            font-size: 14px;
          }
          .file-remove:hover {
            color: #ff5753;
          }
          .btn-upload {
            background-color: #5b9bd5;
            color: #ffffff;
            border: none;
            border-radius: 4px;
            padding: 10px 24px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s ease;
            width: 100%;
          }
          .btn-upload:hover {
            background-color: #4a8bc4;
          }
          .btn-upload:disabled {
            background-color: #3d4654;
            color: #6c727d;
            cursor: not-allowed;
          }
          .progress-container {
            display: none;
            margin-top: 20px;
          }
          .progress-container.visible {
            display: block;
          }
          .progress-bar-bg {
            background-color: #2d343e;
            border-radius: 4px;
            height: 8px;
            overflow: hidden;
          }
          .progress-bar-fill {
            background-color: #5b9bd5;
            height: 100%;
            width: 0%;
            transition: width 0.3s ease;
            border-radius: 4px;
          }
          .progress-text {
            font-size: 13px;
            color: #8e929b;
            margin-top: 8px;
          }
          .result-container {
            display: none;
            margin-top: 20px;
            padding: 20px;
            border-radius: 6px;
          }
          .result-container.visible {
            display: block;
          }
          .result-success {
            background-color: #1e2a1e;
            border: 1px solid #2d5a2d;
          }
          .result-error {
            background-color: #2a1e1e;
            border: 1px solid #5a2d2d;
          }
          .result-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 10px;
          }
          .result-success .result-title {
            color: #65a637;
          }
          .result-error .result-title {
            color: #d93f3c;
          }
          .result-detail {
            font-size: 14px;
            color: #c3cbd4;
            margin-bottom: 6px;
          }
          .result-actions {
            margin-top: 15px;
          }
          .result-actions a {
            color: #5b9bd5;
            text-decoration: none;
            margin-right: 20px;
            font-size: 14px;
          }
          .result-actions a:hover {
            text-decoration: underline;
          }
          .instructions {
            background-color: #1a1f28;
            border: 1px solid #2d343e;
            border-radius: 6px;
            padding: 20px;
          }
          .instructions h3 {
            font-size: 16px;
            color: #ffffff;
            margin-top: 0;
            margin-bottom: 12px;
          }
          .instructions ol {
            padding-left: 20px;
            margin: 0;
          }
          .instructions li {
            font-size: 14px;
            color: #c3cbd4;
            margin-bottom: 8px;
            line-height: 1.5;
          }
          .instructions .note {
            font-size: 13px;
            color: #8e929b;
            margin-top: 12px;
            font-style: italic;
          }
          #stigFileInput {
            display: none;
          }
        </style>

        <div class="upload-container">
          <div class="upload-card">
            <div class="upload-area" id="stigDropZone">
              <div class="upload-icon">&#128196;</div>
              <div class="upload-text">Drag and drop a checklist file here, or click to browse</div>
              <div class="upload-subtext">Supports DISA STIG Viewer checklist files (.ckl and .cklb)</div>
            </div>

            <input type="file" id="stigFileInput" accept=".ckl,.cklb" />

            <div class="file-info" id="stigFileInfo">
              <span class="file-name" id="stigFileName"></span>
              <span class="file-size" id="stigFileSize"></span>
              <span class="file-remove" id="stigFileRemove">✕ Remove</span>
            </div>

            <button class="btn-upload" id="stigUploadBtn" disabled="disabled">Upload and Process</button>

            <div class="progress-container" id="stigProgressContainer">
              <div class="progress-bar-bg">
                <div class="progress-bar-fill" id="stigProgressBar"></div>
              </div>
              <div class="progress-text" id="stigProgressText">Uploading...</div>
            </div>

            <div class="result-container" id="stigResultContainer"></div>
          </div>

          <div class="instructions">
            <h3>How it works</h3>
            <ol>
              <li>Open DISA STIG Viewer and complete your checklist assessment</li>
              <li>Save the checklist as a .ckl file (STIG Viewer 2.x) or .cklb file (STIG Viewer 3.x)</li>
              <li>Upload the file using the form above — both formats are supported</li>
              <li>The app parses the checklist and ingests it into Splunk automatically</li>
              <li>View results in the STIG Compliance Overview dashboard</li>
            </ol>
            <div class="note">
              Note: When uploading a new checklist for the same host and STIG, the dashboards automatically display only the latest data. Each upload is timestamped for historical tracking.
            </div>
          </div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
