# Application-level permissions
[]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system
[viewstates]
access = read : [ * ], write : [ * ]
export = system
[views]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system
[admin:stig_upload]
access = read : [ admin, sc_admin, power ], write : [ admin, sc_admin, power ]
export = system
# Explicit macro permissions so GUI edits preserve global sharing
[macros]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system
# KV store collection permissions
[collections/stig_upload_hashes]
access = read : [ admin, sc_admin, power ], write : [ admin, sc_admin, power ]
export = system
