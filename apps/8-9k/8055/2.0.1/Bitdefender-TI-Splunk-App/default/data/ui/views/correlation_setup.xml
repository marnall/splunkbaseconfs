<dashboard version="1.1" script="javascript/correlations_dashboard.js">
  <label>Correlation Searches</label>
  <row>
    <panel>
      <html>
        <div id="correlation-search-table" class="table-container"></div>
        <div style="text-align: right; margin-top: 10px;">
        </div>
      </html>
    </panel>
  </row>
 
  <row>
    <panel>
      <html>
        <div id="edit-modal" class="modal-container" style="display:none;">
          <div class="modal-box">
            <div class="modal-content">
              <h3>Edit Correlation Search</h3>
              <div class="form-group">
                <label for="impact-score" title="Set the rule impact score between 1-100. Higher scores indicate greater potential impact">Rule impact Score (1 to 100)<span class="required">*</span></label>
                <input type="number" id="impact-score" class="form-control" min="1" max="100" title="Enter a value between 1 and 100 to indicate the potential impact of this correlation"/>
              </div>
              <div class="form-group">
                <label for="confidence-score" title="Set the rule confidence score between 1-100. Higher scores indicate greater rule confidence in the correlation">Rule confidence Score (1 to 100)<span class="required">*</span></label>
                <input type="number" id="confidence-score" class="form-control" min="1" max="100" title="Enter a value between 1 and 100 to indicate the confidence level of this correlation"/>
              </div>
              <div class="form-group">
                <label for="index-dropdown" title="Select one or multiple indexes to search through">Indexes List<span class="required">*</span></label>
                <select id="index-dropdown" class="form-control" multiple="multiple" title="Hold Ctrl/Cmd to select multiple indexes"></select>
              </div>
              <div class="form-group">
                <label for="field-input" title="Specify the fields to correlate">Event Fields<span class="required">*</span></label>
                <input type="text" id="field-input" class="form-control" placeholder="Comma Separated List" title="Enter field names (e.g. src_ip, dst_ip)"/>
              </div>
              <div class="modal-footer">
                <button id="save-changes" class="btn btn-save" title="Save your changes">Save</button>
                <button id="cancel-edit" class="btn btn-cancel" title="Discard your changes">Cancel</button>
              </div>
            </div>
          </div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
