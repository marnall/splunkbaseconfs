<!--
Both of the <dashboard> element's `stylesheet` and `script` attribute search for
files in $SPLUNK_HOME/etc/apps/<app_id>/appserver/static/*
See: https://docs.splunk.com/Documentation/Splunk/latest/Viz/PanelreferenceforSimplifiedXML#dashboard_or_form
-->
<dashboard isDashboard="false"
           script="javascript/setup_page.js"
           stylesheet="styles/setup_page.css"
           hideTitle="true"
           version="1.1">
    <label>Setup</label>
    <row>
        <panel>
            <html>
                <div id="main_container">
                    <h3>Resecurity Add-on Setup</h3>

                    <div class="text">
                        <span>Base URL:</span>
                        <input type="text" id="url_input" placeholder="https://example.com/"/>
                    </div>

                    <div class="text">
                        <span>API Root:</span>
                        <input type="text" id="api_root_input" placeholder=""/>
                    </div>

                    <div class="text">
                        <span>Username:</span>
                        <input type="text" id="username_input" placeholder="user@example.com"></input>
                    </div>
                    <div class="text">
                        <span>Password/Token:</span>
                        <input type="password" id="password_input" placeholder="Enter password or token"></input>
                    </div>

                    <div class="text">
                        <span>Verify SSL:</span>
                        <input type="checkbox" id="verify_ssl_input" checked="true"/>
                    </div>

                    <!-- Save button will call completeSetup() in javascript/setup_page.js -->
                    <button id="setup_button">Save</button>

                    <div class="success" style="display:none;">Settings saved successfully, redirecting to app...</div>
                    <div class="error" style="display:none;">Issue encountered during setup, details below:</div>
                    <code id="error_details" style="display:none;"></code>
                </div>
            </html>
        </panel>
    </row>
</dashboard>