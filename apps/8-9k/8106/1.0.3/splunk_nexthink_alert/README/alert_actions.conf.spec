[remote_action_alert]
param.account = <list> Select Account. It's a required parameter.
param.remote_action_id = <list> Remote Action. It's a required parameter.
param.device_uid_field = <string> Device UID field.  It's default value is uid.
param.params = <string> Params.
param.reason = <string> Reason.
param.external_source = <string> External Source.  It's default value is Splunk.
param.expires_in_minutes = <string> Expires in minutes.
param.external_reference = <string> External references.
