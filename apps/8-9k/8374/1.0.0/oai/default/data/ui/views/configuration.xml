<?xml version="1.0"?>
<dashboard isDashboard="false" version="1.1" script="javascript/views/setup_page.js" theme="dark">
  <label>Configuration</label>
  <description>Configure Ollama Integration Settings</description>
  <row>
    <panel>
      <html>
        <div id="setup-container">
          <h2>OAI (Ollama AI) Configuration</h2>
          <p>Configure the connection to your local Ollama instance.</p>
          
          <div class="form-group" style="margin: 15px 0;">
            <label for="base_url_input" style="display: block; margin-bottom: 5px; font-weight: bold;">Ollama Base URL</label>
            <input type="text" id="base_url_input" value="http://localhost:11434" style="width: 300px; padding: 5px;"/>
            <div style="color: #999; font-size: 12px;">Typically http://localhost:11434 or the host where Ollama runs. If your Ollama deployment supports TLS, set the URL to https://host:port here.</div>
          </div>
          
          <div class="form-group" style="margin: 15px 0;">
            <label for="default_model_input" style="display: block; margin-bottom: 5px; font-weight: bold;">Default Model</label>
            <select id="default_model_input" style="width: 300px; padding: 5px;">
              <option value="qwen2.5:1.5b-instruct" selected="selected">qwen2.5:1.5b-instruct</option>
            </select>
            <div style="color: #999; font-size: 12px;">Models will be populated from Ollama if available.</div>
          </div>
          
          <div class="form-group" style="margin: 15px 0;">
            <label for="log_level_input" style="display: block; margin-bottom: 5px; font-weight: bold;">Log Level</label>
            <select id="log_level_input" style="width: 300px; padding: 5px;">
              <option value="DEBUG" selected="selected">DEBUG</option>
              <option value="INFO">INFO</option>
              <option value="WARNING">WARNING</option>
              <option value="ERROR">ERROR</option>
            </select>
          </div>
          
          <div class="form-group" style="margin: 15px 0;">
            <label for="timeout_input" style="display: block; margin-bottom: 5px; font-weight: bold;">Timeout (seconds)</label>
            <input type="number" id="timeout_input" value="60" min="1" max="600" style="width: 100px; padding: 5px;"/>
          </div>
          
          <div class="form-group" style="margin: 15px 0;">
            <label for="persist_index_input" style="display: block; margin-bottom: 5px; font-weight: bold;">Persist Index</label>
            <input type="text" id="persist_index_input" value="oai" style="width: 300px; padding: 5px;"/>
            <div style="color: #999; font-size: 12px;">Default index for storing AI responses when persist=true. Can be any valid Splunk index.</div>
          </div>
          
          <div class="form-group" style="margin: 15px 0;">
            <label style="display: block; margin-bottom: 5px; font-weight: bold;">Verify SSL</label>
            <label style="margin-right: 15px;"><input type="radio" name="verify_ssl" value="1" checked="checked"/> Yes</label>
            <label><input type="radio" name="verify_ssl" value="0"/> No</label>
            <div style="color: #999; font-size: 12px;">Disable only if connecting to HTTPS Ollama with self-signed certs.</div>
          </div>
          
          <div style="margin-top: 20px;">
            <button class="btn btn-primary" id="save_config" style="padding: 8px 20px;">Save Configuration</button>
          </div>
          <div id="save_status" style="margin-top: 10px;"></div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>