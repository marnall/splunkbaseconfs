<form version="1.1">
  <init>
    <set token="kvNotAnnouncedCost">0</set>
    <set token="kvAnnouncedCost">0</set>
    <set token="kvEoSaleCost">0</set>
    <set token="kvEoSWMCost">0</set>
    <set token="kvEoRFACost">0</set>
    <set token="kvEoVSSCost">0</set>
    <set token="kvEoSCRCost">0</set>
    <set token="kvLDoSCost">0</set>
    <set token="DontShowPanel">1</set>
    <set token="kvDevices">0</set>
  </init>
  <label>Hardware End of Life Details</label>
  <description>Promoting base searches to hidden panels with loadjob, optimizing &lt;init&gt;</description>
  <fieldset submitButton="false" autoRun="true">
    <input type="dropdown" token="cpyKey" depends="$HideThis$">
      <label>Hidden Customer</label>
      <choice value="0">Default</choice>
      <default>0</default>
      <initialValue>0</initialValue>
    </input>
    <input type="dropdown" token="groupIdSelected" searchWhenChanged="true">
      <label>GROUP</label>
      <search>
        <query>`cisco_oi_index("$cpyKey$")` sourcetype::cisco:bcs:devicegroup
| mvexpand groupName 
| dedup groupName
| table groupName
| sort groupName</query>
        <earliest>-1w@w</earliest>
        <latest>now</latest>
      </search>
      <fieldForLabel>groupName</fieldForLabel>
      <fieldForValue>groupName</fieldForValue>
      <change>
        <condition match="match( value, &quot;_default_&quot;)">
          <set token="groupSelector"></set>
          <set token="singleLineGroupSelector">where 1=1</set>
        </condition>
        <condition>
          <set token="groupSelector">[| tstats values(deviceId) as deviceId WHERE ( `cisco_oi_index($cpyKey$)` sourcetype::cisco:bcs:devicegroupmember groupName="$groupIdSelected$")]</set>
          <set token="singleLineGroupSelector">search [| tstats values(deviceId) as deviceId WHERE ( `cisco_oi_index($cpyKey$)` sourcetype::cisco:bcs:devicegroupmember groupName="$groupIdSelected$")]</set>
        </condition>
      </change>
      <choice value="_default_">No group filtering</choice>
      <default>_default_</default>
      <initialValue>_default_</initialValue>
    </input>
    <input type="dropdown" token="typeSelector">
      <label>Physical Type</label>
      <choice value="physicalAssetType=Chassis">Chassis</choice>
      <choice value="physicalAssetType=Chassis OR assetType=Module">Chassis &amp; Module</choice>
      <choice value="physicalAssetType=*">Chassis, Module, Fan, PwrSply</choice>
      <choice value="physicalAssetType=Fan">Fan</choice>
      <choice value="physicalAssetType=Module">Module</choice>
      <choice value="physicalAssetType=&quot;Power Supply&quot;">Power Supply</choice>
      <initialValue>physicalAssetType=Chassis</initialValue>
      <default>physicalAssetType=Chassis</default>
    </input>
    <input type="dropdown" token="productCategory">
      <label>Not EoX Zoom</label>
      <choice value="productFamily">Product Family</choice>
      <choice value="productType">Product Type</choice>
      <default>productFamily</default>
      <initialValue>productFamily</initialValue>
    </input>
    <input type="dropdown" token="eoxRollup">
      <label>EoX Zoom</label>
      <choice value="productId, replacementPid">PID, Replacement</choice>
      <choice value="productFamily">Product Family</choice>
      <choice value="productType">ProductType</choice>
      <default>productId, replacementPid</default>
      <initialValue>productId, replacementPid</initialValue>
    </input>
    <input type="time" token="inputTimeRange">
      <label>Date &amp; Time Range</label>
      <default>
        <earliest>-7d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row depends="$NEVER_SHOW$">
    <panel>
      <title>ANNOUNCED_BASE_SEARCH</title>
      <table>
        <search>
          <query>
((`cisco_oi_index("$cpyKey$")` sourcetype=cisco:bcs:asset ($typeSelector$)) OR (`cisco_oi_index("$cpyKey$")` sourcetype=cisco:bcs:hardwareendoflife ($typeSelector$))) deviceId IN (*)
| stats values(deviceName) as deviceName values(hardwareEndOfLifeId) as hardwareEndOfLifeId values(productFamily) as productFamily values(productType) as productType values(currentEndOfLifeMilestone) as currentEndOfLifeMilestone by deviceId physicalAssetId productId 
| dedup physicalAssetId 
| $singleLineGroupSelector$
| eval currentEndOfLifeMilestone = if(like(currentEndOfLifeMilestone, "EoRFA%"), "EoRFA", currentEndOfLifeMilestone) 
| eval currentEndOfLifeMilestone = if(like(currentEndOfLifeMilestone, "EoSWM%"), "EoSWM", currentEndOfLifeMilestone)
          </query>
          <earliest>$inputTimeRange.earliest$</earliest>
          <latest>$inputTimeRange.latest$</latest>
          <sampleRatio>1</sampleRatio>
          <done>
            <set token="ANNOUNCED_BASE_SEARCH">$job.sid$</set>
          </done>
        </search>
      </table>
    </panel>
    <panel>
      <title>NOT_ANNOUNCED_BASE_SEARCH</title>
      <table>
        <search>
          <query>
((`cisco_oi_index("$cpyKey$")` sourcetype=cisco:bcs:asset ($typeSelector$)) OR (`cisco_oi_index("$cpyKey$")` sourcetype=cisco:bcs:hardwareendoflife ($typeSelector$))) deviceId IN (*)
| stats values(deviceName) as deviceName values(hardwareEndOfLifeId) as hardwareEndOfLifeId values(productFamily) as productFamily values(productType) as productType values(currentEndOfLifeMilestone) as currentEndOfLifeMilestone by deviceId physicalAssetId productId 
| dedup physicalAssetId 
| fillnull value=0 hardwareEndOfLifeId
| search hardwareEndOfLifeId=0
| $singleLineGroupSelector$
| eval currentEndOfLifeMilestone = if(like(currentEndOfLifeMilestone, "EoRFA%"), "EoRFA", currentEndOfLifeMilestone) 
| eval currentEndOfLifeMilestone = if(like(currentEndOfLifeMilestone, "EoSWM%"), "EoSWM", currentEndOfLifeMilestone)
          </query>
          <earliest>$inputTimeRange.earliest$</earliest>
          <latest>$inputTimeRange.latest$</latest>
          <sampleRatio>1</sampleRatio>
          <done>
            <set token="NOT_ANNOUNCED_BASE_SEARCH">$job.sid$</set>
          </done>
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel rejects="$DontShowPanel$">
      <title>Components in Selected Group and Physical Type</title>
      <viz type="horseshoe_meter_app.horseshoe_meter">
        <title># Components in current filter</title>
        <search>
          <finalized>
            <condition match=" 'job.resultCount' != 0">
              <set token="kvDevices">$result.Devices$</set>
            </condition>
          </finalized>
          <query>`cisco_oi_index("$cpyKey$")` sourcetype::cisco:bcs:asset
| search $typeSelector$
| fields deviceId, physicalAssetId 
| dedup physicalAssetId 
| $singleLineGroupSelector$
| stats dc(physicalAssetId) as Devices</query>
          <earliest>$inputTimeRange.earliest$</earliest>
          <latest>$inputTimeRange.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="height">150</option>
        <option name="horseshoe_meter_app.horseshoe_meter.backgroundColor">#FFF</option>
        <option name="horseshoe_meter_app.horseshoe_meter.caption">Components</option>
        <option name="horseshoe_meter_app.horseshoe_meter.dialColor">#d0d5d9</option>
        <option name="horseshoe_meter_app.horseshoe_meter.maxRangeColor">#b44441</option>
        <option name="horseshoe_meter_app.horseshoe_meter.maxRangeThreshold">80</option>
        <option name="horseshoe_meter_app.horseshoe_meter.maxValue">100</option>
        <option name="horseshoe_meter_app.horseshoe_meter.midRangeColor">#fbcd2f</option>
        <option name="horseshoe_meter_app.horseshoe_meter.midRangeThreshold">55</option>
        <option name="horseshoe_meter_app.horseshoe_meter.minRangeColor">#3fc77a</option>
        <option name="horseshoe_meter_app.horseshoe_meter.minValue">0</option>
        <option name="horseshoe_meter_app.horseshoe_meter.thresholdStyle">percentage</option>
        <option name="horseshoe_meter_app.horseshoe_meter.useRangemap">false</option>
        <option name="horseshoe_meter_app.horseshoe_meter.valueColor">#555</option>
        <option name="refresh.display">preview</option>
      </viz>
    </panel>
  </row>
