      <title>Announced by $eoxRollup$</title>
      <table>
        <search>
          <query>| loadjob $ANNOUNCED_BASE_SEARCH$ | search currentEndOfLifeMilestone=Announced 
| lookup local=true bu_replacement_pids bulletinProductId as productId OUTPUT replacementProductId as replacementPid 
| fields deviceName physicalAssetId hwEoxId productId replacementPid productFamily productType
| fillnull value="null" replacementPid 
| table deviceName physicalAssetId productId replacementPid productFamily productType
| stats count as Devices by $eoxRollup$ 
| sort -Devices 
| appendpipe 
    [ stats count 
    | where count=0]</query>
          <earliest>$inputTimeRange.earliest$</earliest>
