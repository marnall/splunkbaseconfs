# This file contains an example inputs.conf.

[agent_management_versioned_app_retrieval_add_on]
interval = 0 * * * *
python.version = python3.9
max_file_size = 500
timeout = 15
max_retries = 5

[agent_management_versioned_app_retrieval_add_on://app-name-1]
repository_type = jfrog
address = https://valid.url.com
repository_name = my-repository
path = path/to/file
artifact_name = dummy_name
auth_header_type = Bearer
extract_path = $SPLUNK_HOME/etc/deployment-apps
extension = .tar.gz
secrets_storage_user = jfrog-user

[agent_management_versioned_app_retrieval_add_on://app-name-2]
repository_type = gitlab
address = https://my.base.address.example.com
project_id = 1234567
auth_header_type = Bearer
extract_path = $SPLUNK_HOME/etc/apps
extension = .zip
branch = v1.0.0
secrets_storage_user = gitlab-user

[agent_management_versioned_app_retrieval_add_on://app-name-3]
repository_type = github
address = https://github.example.com
repository_name = https://my.base.address.example.com
owner = 1234567
auth_header_type = Bearer
extract_path = $SPLUNK_HOME/etc/apps
extension = .tar.gz
branch = feature/test
secrets_storage_user = github-user

[agent_management_versioned_app_retrieval_add_on://app-name-4]
repository_type = nexus
address = https://nexus.example.com
repository_name = my-repository
path = path/to/file
artifact_name = dummy_name_*
auth_header_type = Basic
extract_path = $SPLUNK_HOME/etc/deployment-apps
extension = .tar.gz
secrets_storage_user = nexus-user
