    "tasks": null,
    "incompatibleApps": null,
    "platformRequirements": {
        "splunk": { "Enterprise": "*" }
    },
    "supportedDeployments": ["_standalone", "_search_head_clustering"],
    "targetWorkloads": ["_search_heads"]
