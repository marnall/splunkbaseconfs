# App metadata. Views and nav stay APP-SCOPED (no global export) so our `home`
# view never collides with another app's `home`. Only the alert action (and the
# KV lookup, for convenience) are shared globally.

[]
access = read : [ * ], write : [ admin, sc_admin, power ]

# The custom alert action must be visible to alerts in any app.
[alert_actions/render_viz_email]
export = system

# KV store collection (read by the UI and the alert action via app-scoped REST).
[collections/alert_viz_configs]
access = read : [ * ], write : [ admin, sc_admin, power ]

# Lookup over the collection, so `| inputlookup alert_viz_configs` works anywhere.
[transforms/alert_viz_configs]
export = system

[alert_actions/render_and_notify]
export = system
