# enrollment.conf.spec
# Configuration spec for Deslicer AI Insights enrollment.

[enrollment]
token = <string>
* Enrollment token issued by the Deslicer AI portal.
* Used for zero-touch enrollment of Insights Nodes.

observer_api_url = <string>
* URL of the Deslicer Automation Platform (Observer API).
* Example: https://dap-eu-s1t8vn.deslicer.ai
