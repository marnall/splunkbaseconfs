        {
            "action": "alerts - update alert status",
            "identifier": "update_alert_status",
            "description": "Update the status of one or more alerts",
            "type": "generic",
            "read_only": false,
            "parameters": {
                "Alert_Ref_IDs": {
                    "description": "Comma-separated list of alert reference IDs to update",
                    "data_type": "string",
                    "required": true,
                    "order": 0
                },
                "Status": {
                    "description": "The new status for the alerts",
                    "data_type": "string",
                    "required": true,
                    "order": 1,
                    "value_list": [
                        "open",
                        "acknowledged",
                        "closed"
                    ]
                },
                "Closure_Reason": {
                    "description": "The reason for closing the alert",
                    "data_type": "string",
                    "required": false,
                    "order": 2,
                    "value_list": [
                        "resolved",
                        "irrelevant",
                        "false_positive",
                        "irrelevant_alert_subtype",
                        "no_longer_a_threat",
                        "asset_should_not_be_monitored",
                        "asset_belongs_to_my_organization",
                        "asm_no_longer_detected",
                        "asm_manually_closed",
                        "other"
                    ]
                },
                "Reason_Description": {
                    "description": "A description for the closure reason",
                    "data_type": "string",
                    "required": false,
                    "order": 3
                }
            },
            "output": [
                {
                    "data_path": "action_result.parameter.Alert_Ref_IDs",
                    "data_type": "string"
                },
