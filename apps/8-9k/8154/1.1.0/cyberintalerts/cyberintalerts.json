    "configuration": {
        "base_url": {
            "description": "Cyberint API URL on which the services run (e.g. https://your-company.cyberint.io)",
            "data_type": "string",
            "required": true,
            "order": 0,
            "name": "Cyberint API URL"
        },
        "access_token": {
            "description": "Cyberint API access token",
            "data_type": "password",
            "required": true,
            "order": 1,
            "name": "Cyberint Access Token"
        },
        "customer_name": {
            "description": "Company name associated with Cyberint instance",
            "data_type": "string",
            "required": true,
            "order": 2,
            "name": "Company Name"
        },
        "fetch_severity": {
            "description": "Comma-separated list of severities to fetch. Supported values: low, medium, high, very_high. If empty, all severity levels will be returned",
            "data_type": "string",
            "required": false,
            "order": 3,
            "name": "Fetch Severity"
        },
        "fetch_status": {
            "description": "Comma-separated list of statuses to fetch. Supported values: open, acknowledged, closed. If empty, all statuses will be returned",
            "data_type": "string",
            "required": false,
            "order": 4,
            "name": "Fetch Status"
        },
        "fetch_environment": {
            "description": "Environments to fetch (comma separated). If empty, all available environments will be returned",
            "data_type": "string",
            "required": false,
            "order": 5,
            "name": "Fetch Environment"
        },
        "fetch_type": {
            "description": "Comma-separated alert types to fetch. See API docs for supported types. If empty, all types will be returned",
            "data_type": "string",
            "required": false,
            "order": 6,
            "name": "Fetch Type"
        },
        "start_time": {
            "description": "Starting time frame for initial data retrieval. If not set, alerts from the last 24 hours will be fetched",
            "data_type": "string",
            "required": false,
            "order": 7,
            "name": "Start Time",
            "value_list": [
                "Last 1 Hour",
                "Last 24 Hours",
                "Last 7 Days",
                "Last 30 Days",
                "Last 90 Days"
            ],
            "default": "Last 24 Hours"
        },
        "max_fetch": {
            "description": "Max number of alerts per fetch. Default is 10, max is 100",
            "data_type": "numeric",
            "required": false,
            "order": 8,
            "name": "Fetch Limit",
            "default": 10
        },
        "include_csv": {
            "description": "Include CSV attachments as JSON content in alert data",
            "data_type": "boolean",
            "required": false,
            "order": 9,
            "name": "Include CSV Attachments",
            "default": false
        }
    },
