                },
                {
                    "data_path": "action_result.parameter.Closure_Reason",
                    "data_type": "string"
                },
                {
                    "data_path": "action_result.parameter.Reason_Description",
                    "data_type": "string"
                },
                {
                    "data_path": "action_result.message",
                    "data_type": "string"
                },
                {
                    "data_path": "summary.total_objects",
                    "data_type": "numeric"
                },
                {
                    "data_path": "summary.total_objects_successful",
                    "data_type": "numeric"
                },
                {
                    "data_path": "action_result.status",
                    "data_type": "string"
                }
            ],
            "versions": "EQ(*)",
            "render": {
                "type": "custom",
                "view": "cyberintalerts_view.update_alert_status_view",
                "title": "Update Alert Status"
            }
