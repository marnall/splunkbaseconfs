#
# Export the lookups and transforms globally so Splunk Enterprise Security
# and other apps can reference them. The modular input itself is app-scoped.
#

[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/usom_ip_intel]
export = system

[transforms/usom_ip6_intel]
export = system

[transforms/usom_ip6net_intel]
export = system

[transforms/usom_domain_intel]
export = system

[transforms/usom_url_intel]
export = system

[lookups/usom_ip_intel.csv]
export = system

[lookups/usom_ip6_intel.csv]
export = system

[lookups/usom_ip6net_intel.csv]
export = system

[lookups/usom_domain_intel.csv]
export = system

[lookups/usom_url_intel.csv]
export = system

[props/ta_usom_cti:log]
export = system

[props/usom_ti:stats]
export = system
