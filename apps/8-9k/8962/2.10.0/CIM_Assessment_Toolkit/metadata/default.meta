##############################################################################
# CIM Assessment Toolkit v2.0 — Metadata
# Machine Data Insights Inc.
#
# Uses sc_admin alongside admin for Splunk Cloud compatibility.
# The admin role does not exist on Splunk Cloud — sc_admin is the
# equivalent administrator role on that platform.
##############################################################################

[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[views]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[savedsearches]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[macros]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/lookups]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[lookups]
access = read : [ * ], write : [ admin, sc_admin ]
export = system
