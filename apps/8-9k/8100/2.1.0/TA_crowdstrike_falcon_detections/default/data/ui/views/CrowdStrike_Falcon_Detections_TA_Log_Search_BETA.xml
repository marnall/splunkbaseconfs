<form version="1.1" theme="dark" stylesheet="dashboard.css">
  <label>CrowdStrike Falcon Detections: TA Log Search - BETA</label>
  <description>This is for customer use only - DO NOT SEND THIS DATA TO CROWDSTRIKE SUPPORT UNLESS REQUESTED</description>
  <fieldset submitButton="true" autoRun="true">
    <input type="time" token="time_frame" searchWhenChanged="false">
      <label>Select Time</label>
      <default>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="input" searchWhenChanged="false">
      <label>Select Input</label>
      <change>
        <set token="input_selection">$label$</set>
      </change>
      <choice value="%">All</choice>
      <fieldForLabel>Input_Name</fieldForLabel>
      <fieldForValue>Input_Name</fieldForValue>
      <search>
        <query>`cs_falcon_detections_logs`  earliest="$time_frame.earliest$" latest="$time_frame.latest$" | rex field=_raw "\d[[:punct:]]\d[[:punct:]]\d\s(?&lt;Input_Name&gt;[^\s:]+)\s:" | dedup Input_Name</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <prefix>"</prefix>
      <suffix>"</suffix>
      <default>%</default>
      <initialValue>%</initialValue>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Showing Logs For $input_selection$</title>
      <event>
        <search>
          <query>`cs_falcon_detections_logs` | rex field=_raw "\d[[:punct:]]\d[[:punct:]]\d\s(?&lt;Input_Name&gt;[^\s:]+)\s:" | where like(Input_Name,$input$)</query>
          <earliest>$time_frame.earliest$</earliest>
          <latest>$time_frame.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">50</option>
        <option name="list.drilldown">none</option>
        <option name="list.wrap">1</option>
        <option name="maxLines">5</option>
        <option name="raw.drilldown">full</option>
        <option name="refresh.display">progressbar</option>
        <option name="rowNumbers">0</option>
        <option name="table.drilldown">all</option>
        <option name="table.sortDirection">asc</option>
        <option name="table.wrap">1</option>
        <option name="type">list</option>
      </event>
    </panel>
  </row>
</form>