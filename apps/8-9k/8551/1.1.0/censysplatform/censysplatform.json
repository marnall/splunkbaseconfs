        {
            "action": "live rescan",
            "identifier": "live_rescan",
            "description": "Initiate a live rescan and wait for completion, then return a baseline-vs-post change log",
            "type": "generic",
            "read_only": false,
            "parameters": {
                "ip": {
                    "data_type": "string",
                    "description": "Service target IP address",
                    "required": false,
                    "primary": true,
                    "contains": [
                        "ip"
                    ],
                    "order": 0
                },
                "hostname": {
                    "data_type": "string",
                    "description": "Web target hostname",
                    "required": false,
                    "contains": [
                        "domain",
                        "ip"
                    ],
                    "order": 1
                },
                "port": {
                    "data_type": "numeric",
                    "description": "Target port",
                    "required": true,
                    "order": 2
                },
                "protocol": {
                    "data_type": "string",
                    "description": "Service protocol (required for service target)",
                    "required": false,
                    "order": 3
                },
                "transport_protocol": {
                    "data_type": "string",
                    "description": "Service transport protocol (unknown, tcp, udp, icmp, quic) for service target",
                    "required": false,
                    "default": "tcp",
                    "order": 4
                },
                "target_type": {
                    "data_type": "string",
                    "description": "Optional explicit target type override: service_id or web_origin",
                    "required": false,
                    "order": 5
                },
                "wait_timeout_seconds": {
                    "data_type": "numeric",
                    "description": "Maximum wait time before polling times out",
                    "required": false,
                    "default": 900,
                    "order": 6
                },
                "max_diff_entries": {
                    "data_type": "numeric",
                    "description": "Maximum number of diff rows to include in the change log",
                    "required": false,
                    "default": 200,
                    "order": 7
                }
            },
            "output": [
                {
                    "data_path": "action_result.status",
                    "data_type": "string"
