<form script="setup_page/setup_page.js" stylesheet="setup_page/setup_page.css" version="1.1">
  <label>Configuration</label>
  <row>
    <panel>
      <html>
        <div id="main_container">
          <h2>Apex Add-on Setup</h2>
          <div id="loading-spinner" class="loading-spinner hidden">
            <div class="spinner-icon"></div>
            <div class="spinner-text">Loading...</div>
          </div>
          <div id="message-container" class="message-container"></div>
          <form id="setup-form">
            <div class="form-group">
              <label for="hec_token_name">HEC Token Name</label>
              <input type="text" class="form-control" id="hec_token_name"
                required="true" />
            </div>
            <div class="form-group">
              <label for="index">Index</label>
              <input type="text" class="form-control" id="index" value="main"
                required="true" />
            </div>
            <div class="form-group">
              <label for="source">Source</label>
              <input type="text" class="form-control" id="source"
                value="apex_event_receiver" required="true" />
            </div>
            <div class="form-group">
              <label for="ssl_cert_path">SSL Certificate Path (Optional)</label>
              <input type="text" 
                     class="form-control" 
                     id="ssl_cert_path" 
                     placeholder="Enter the full path to your SSL certificate file (e.g., /path/to/cert.pem)"
              />
            </div>
            <div class="form-group">
            <label for="hostname">Hostname (Optional)</label>
                <input type="text" class="form-control" id="hostname" placeholder= "Enter hostname (defaults to serverName in server.conf if not provided). This should match your certificate CN"/>
            </div>
            <button id="save_button" type="submit" class="btn btn-primary">Save</button>
            <button id="reset_button" type="button" class="btn btn-secondary">Reset</button>
          </form>
        </div>
      </html>
    </panel>
  </row>
</form>