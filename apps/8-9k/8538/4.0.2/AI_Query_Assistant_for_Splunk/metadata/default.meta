[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[views]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# KV store collections must be mutated through REST handlers (which validate
# input + license). Block direct lookup writes — REST handlers run as nobody
# and have their own ACLs.
[collections/mcp_query_history]
access = read : [ * ], write : [ nobody ]
export = system

[collections/mcp_query_templates]
access = read : [ * ], write : [ nobody ]
export = system

[collections/mcp_ai_providers]
access = read : [ admin, sc_admin ], write : [ nobody ]
export = system

[collections/mcp_license_status]
access = read : [ admin, sc_admin ], write : [ nobody ]
export = system

[collections/mcp_security_config]
access = read : [ admin, sc_admin ], write : [ nobody ]
export = system

[collections/mcp_integration_config]
access = read : [ admin, sc_admin ], write : [ nobody ]
export = system

[collections/mcp_usage]
access = read : [ admin, sc_admin ], write : [ nobody ]
export = system

[collections/mcp_provider_presets]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# v4: conversation thread metadata + per-thread message rows. The agentic
# pipeline writes via SplunkKVConversationStore (running as the calling user);
# admins can see all threads via scope=all but regular users only see their
# own through the mcp_conversations REST handler. Direct KV writes are
# blocked — go through the handler.
[collections/mcp_conversation_threads]
access = read : [ * ], write : [ nobody ]
export = system

[collections/mcp_conversation_messages]
access = read : [ * ], write : [ nobody ]
export = system

[transforms/mcp_conversation_threads]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/mcp_conversation_messages]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/mcp_provider_presets]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/mcp_query_history]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/mcp_query_templates]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/mcp_ai_providers]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = system
