<dashboard version="1.1" script="license_guard.js,mcp_templates.js,aiqa_i18n_dom.js">
  <label>Query Templates</label>
  <description>Manage reusable query templates</description>

  <!--
    NOTE: id="templates_table" on <table> is officially undocumented in
    SimpleXML 10.2 but works on Splunk 8/9/10 because the table still
    registers as an MVC Component. mcp_templates.js has a defensive
    fallback (Components.getInstances() scan + a delegated DOM click
    handler on .splunk-datatable tbody tr) so row-click still works
    even if a future Splunk release stops registering the id. If that
    fallback ever stops working too, migrate this view to the same
    JS-driven REST pattern as mcp_history.xml.
  -->
  <row>
    <panel id="templates_panel">
      <title>Available Templates</title>
      <table id="templates_table">
        <search>
          <query>
| inputlookup mcp_query_templates
| table name description natural_language category created_by
| rename name as "Name", description as "Description", natural_language as "Query", category as "Category", created_by as "Created By"
          </query>
        </search>
        <option name="drilldown">row</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Create New Template</title>
      <html>
        <form id="template_form">
          <div class="form-group">
            <label><span class="aiqa-i18n" data-key="templates.field.name">Template Name</span></label>
            <input type="text" class="form-control" id="template_name" required="required"/>
          </div>
          <div class="form-group">
            <label><span class="aiqa-i18n" data-key="templates.field.desc">Description</span></label>
            <textarea class="form-control" id="template_description" rows="2"></textarea>
          </div>
          <div class="form-group">
            <label><span class="aiqa-i18n" data-key="templates.field.query">Natural Language Query</span></label>
            <textarea class="form-control" id="template_query" rows="3" required="required"></textarea>
          </div>
          <div class="form-group">
            <label><span class="aiqa-i18n" data-key="templates.field.category">Category</span></label>
            <select class="form-control" id="template_category">
              <option value="Security">Security</option>
              <option value="Performance">Performance</option>
              <option value="Audit">Audit</option>
              <option value="Troubleshooting">Troubleshooting</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary aiqa-i18n" data-key="templates.btn.create">Create Template</button>
        </form>
      </html>
    </panel>
  </row>
</dashboard>
