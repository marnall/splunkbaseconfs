<dashboard version="1.1" script="license_guard.js,mcp_provider_presets.js,aiqa_i18n_dom.js" hideEdit="true">
  <label>Manage Provider Presets</label>
  <description>Add, edit, or remove the AI provider presets that appear in the Setup / Providers dropdown. Admin only.</description>

  <!--
    Issue #18 caveat (UI): instead of forcing admins to learn `inputlookup
    mcp_provider_presets | outputlookup ...` SPL to add a new model, this
    view drives the same KV collection through the standard
    admin/mcp_provider_presets REST handler (CRUD).

    All cell content rendered into innerHTML flows through
    mcpUtils.escapeHtml() because preset records can contain user-supplied
    values (model names, URLs).
  -->

  <row>
    <panel>
      <title>Provider Presets</title>
      <html>
        <div id="aiqa-presets-app">
          <div style="margin-bottom:12px;">
            <button class="btn btn-primary aiqa-i18n" id="aiqa-preset-new" data-key="presets.btn.new">+ New Preset</button>
            <button class="btn btn-default aiqa-i18n" id="aiqa-preset-refresh" data-key="presets.btn.refresh" style="margin-left:8px;">Refresh</button>
            <span id="aiqa-preset-source" style="margin-left:12px; color:#666; font-size:12px;"></span>
          </div>
          <div id="aiqa-preset-table-container">
            <div style="color:#888; padding:12px;"><span class="aiqa-i18n" data-key="presets.loading">Loading presets...</span></div>
          </div>

          <div id="aiqa-preset-editor" style="display:none; margin-top:20px; padding:14px; border:1px solid #ddd; border-radius:4px; background:#fafafa;">
            <h3 id="aiqa-preset-editor-title" style="font-size:18px; margin-top:0;">Edit Preset</h3>
            <div class="form-group" style="margin-bottom:8px;">
              <label style="display:block;"><span class="aiqa-i18n" data-key="presets.field.id">Preset ID</span> <small style="color:#888;"><span class="aiqa-i18n" data-key="presets.field.idHint">(letters/digits/_-., max 100; immutable after create)</span></small></label>
              <input type="text" class="form-control" id="aiqa-preset-id" style="max-width:360px;"/>
            </div>
            <div class="form-group" style="margin-bottom:8px;">
              <label style="display:block;"><span class="aiqa-i18n" data-key="presets.field.label">Display Label</span></label>
              <input type="text" class="form-control" id="aiqa-preset-label" style="max-width:360px;"/>
            </div>
            <div class="form-group" style="margin-bottom:8px;">
              <label style="display:block;"><span class="aiqa-i18n" data-key="presets.field.backend">Backend</span></label>
              <select class="form-control" id="aiqa-preset-backend" style="max-width:240px;">
                <option value="openai_compatible">OpenAI-compatible</option>
                <option value="anthropic">Anthropic</option>
              </select>
            </div>
            <div class="form-group" style="margin-bottom:8px;">
              <label style="display:block;"><span class="aiqa-i18n" data-key="presets.field.url">Base URL</span></label>
              <input type="text" class="form-control" id="aiqa-preset-url" placeholder="https://..." style="max-width:520px;"/>
            </div>
            <div class="form-group" style="margin-bottom:8px;">
              <label style="display:block;"><span class="aiqa-i18n" data-key="presets.field.models">Models</span> <small style="color:#888;"><span class="aiqa-i18n" data-key="presets.field.modelsHint">(comma- or newline-separated)</span></small></label>
              <textarea class="form-control" id="aiqa-preset-models" rows="3" style="max-width:520px;"></textarea>
            </div>
            <div class="form-group" style="margin-bottom:8px;">
              <label style="display:block;"><span class="aiqa-i18n" data-key="presets.field.defaultModel">Default Model</span> <small style="color:#888;"><span class="aiqa-i18n" data-key="presets.field.defaultModelHint">(blank = first in list)</span></small></label>
              <input type="text" class="form-control" id="aiqa-preset-default-model" style="max-width:360px;"/>
            </div>
            <div style="margin-top:12px;">
              <button class="btn btn-primary aiqa-i18n" id="aiqa-preset-save" data-key="presets.btn.save">Save</button>
              <button class="btn btn-default aiqa-i18n" id="aiqa-preset-cancel" data-key="presets.btn.cancel" style="margin-left:8px;">Cancel</button>
              <span id="aiqa-preset-editor-status" style="margin-left:12px; color:#666;"></span>
            </div>
          </div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
