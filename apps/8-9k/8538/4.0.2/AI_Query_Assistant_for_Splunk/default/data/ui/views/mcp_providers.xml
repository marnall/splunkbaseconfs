<dashboard version="1.1" script="license_guard.js,mcp_providers.js,aiqa_i18n_dom.js" hideEdit="true">
  <label>AI Providers</label>
  <description>Manage AI Provider configurations</description>

  <row>
    <panel>
      <html>
        <h3><span class="aiqa-i18n" data-key="providers.list.title">Configured Providers</span></h3>
        <p class="helpText">
          <span class="aiqa-i18n" data-key="providers.help1">API keys are encrypted and stored securely using Splunk's</span> <code>storage/passwords</code>.<br/>
          <span class="aiqa-i18n" data-key="providers.help2">To use an encrypted credential from the Setup page, enter it as</span> <code>{encrypted:somekey}</code> <span class="aiqa-i18n" data-key="providers.help3">in the API Key field.</span>
        </p>
        <table class="table table-striped" id="providers_table">
          <thead>
            <tr>
              <th><span class="aiqa-i18n" data-key="providers.col.name">Name</span></th>
              <th><span class="aiqa-i18n" data-key="providers.col.type">Type</span></th>
              <th><span class="aiqa-i18n" data-key="providers.col.url">Base URL</span></th>
              <th><span class="aiqa-i18n" data-key="providers.col.model">Model</span></th>
              <th><span class="aiqa-i18n" data-key="providers.col.default">Default</span></th>
              <th><span class="aiqa-i18n" data-key="providers.col.actions">Actions</span></th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="6" style="text-align:center;"><span class="aiqa-i18n" data-key="common.loading">Loading...</span></td></tr>
          </tbody>
        </table>
      </html>
    </panel>
  </row>

  <row>
    <panel>
      <html>
        <div id="provider_form" style="padding:15px; border:1px solid #ccc; border-radius:4px;">
          <h4 id="provider_form_title"><span class="aiqa-i18n" data-key="providers.form.addTitle">Add Provider</span></h4>
          <div style="margin-bottom:8px;">
            <label><span class="aiqa-i18n" data-key="providers.field.name">Name</span></label><br/>
            <input type="text" id="provider_name" style="width:300px;" />
          </div>
          <div style="margin-bottom:8px;">
            <label><span class="aiqa-i18n" data-key="providers.field.type">Type</span></label><br/>
            <select id="provider_type" style="width:300px;">
              <optgroup label="International Vendors">
                <option value="openai">OpenAI</option>
                <option value="anthropic">Anthropic (Claude)</option>
                <option value="google">Google (Gemini)</option>
                <option value="mistral">Mistral AI</option>
                <option value="cohere">Cohere</option>
              </optgroup>
              <optgroup label="Domestic Vendors (China)">
                <option value="deepseek">DeepSeek</option>
                <option value="doubao">Doubao (ByteDance)</option>
                <option value="kimi">Kimi (Moonshot AI)</option>
                <option value="qwen">Qwen (Alibaba Cloud)</option>
                <option value="zhipu">Zhipu ChatGLM</option>
                <option value="baichuan">Baichuan AI</option>
                <option value="minimax">MiniMax</option>
                <option value="yi">Yi (01.AI)</option>
                <option value="stepfun">Step (StepFun)</option>
                <option value="spark">Spark (iFlytek)</option>
              </optgroup>
              <optgroup label="Other">
                <option value="openai_compatible">OpenAI Compatible (Custom)</option>
              </optgroup>
            </select>
            <span id="provider_type_hint" style="margin-left:10px; font-size:12px; color:#888;"></span>
          </div>
          <div style="margin-bottom:8px;">
            <label><span class="aiqa-i18n" data-key="providers.field.url">Base URL</span></label><br/>
            <input type="text" id="provider_base_url" style="width:500px;" placeholder="Auto-filled after selecting vendor, can be manually modified" />
          </div>
          <div style="margin-bottom:8px;">
            <label><span class="aiqa-i18n" data-key="providers.field.model">Model</span></label><br/>
            <input type="text" id="provider_model" style="width:300px;" placeholder="Auto-filled with recommended model after selecting vendor" />
          </div>
          <div style="margin-bottom:8px;">
            <label><span class="aiqa-i18n" data-key="providers.field.apiKey">API Key</span></label><br/>
            <input type="password" id="provider_api_key" style="width:500px;" />
          </div>
          <div style="margin-bottom:8px;">
            <label><input type="checkbox" id="provider_is_default" /> <span class="aiqa-i18n" data-key="providers.field.setDefault">Set as Default Provider</span></label>
          </div>
          <input type="hidden" id="provider_edit_key" value="" />
          <button class="btn btn-primary aiqa-i18n" id="btn_save_provider" data-key="providers.btn.save">Save Provider</button>
          <button class="btn aiqa-i18n" id="btn_test_provider" data-key="providers.btn.test">Test Connection</button>
          <button class="btn aiqa-i18n" id="btn_cancel_edit" data-key="providers.btn.cancel" style="display:none;">Cancel</button>
          <span id="provider_status" style="margin-left:10px;"></span>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
