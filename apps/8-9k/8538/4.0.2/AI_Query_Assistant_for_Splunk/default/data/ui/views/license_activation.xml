<dashboard version="1.1" script="license_activation.js,aiqa_i18n_dom.js" hideEdit="true">
  <label>License Activation</label>
  <description>Activate your AI Query Assistant for Splunk license</description>

  <!--
    Issue #27: every user-visible inline string here is wrapped in
    <span class="aiqa-i18n" data-key="license.xxx"> markers; the DOM hook
    aiqa_i18n_dom.js (loaded above) swaps innerText via mcpUtils.t(key) at
    page load. The default-language English text is kept inline so the
    page still renders if JS is disabled or a key is missing from the
    dictionary.

    The textarea placeholder cannot be wrapped in a span — license_activation.js
    swaps it explicitly via mcpUtils.t('license.activate.placeholder').
  -->


  <row>
    <panel>
      <html>
        <div id="license_app">

        <div id="license_status_section">
          <h3><span class="aiqa-i18n" data-key="license.status.title">License Status</span></h3>
          <div id="license_loading" style="color:#888;"><span class="aiqa-i18n" data-key="license.status.loading">Checking license status...</span></div>
          <div id="license_info" style="display:none;">
            <table class="table table-bordered" style="max-width:500px;">
              <tr><td style="width:140px;"><strong><span class="aiqa-i18n" data-key="license.field.status">Status</span></strong></td><td id="info_status"></td></tr>
              <tr><td><strong><span class="aiqa-i18n" data-key="license.field.type">License Type</span></strong></td><td id="info_type"></td></tr>
              <tr><td><strong><span class="aiqa-i18n" data-key="license.field.email">Email</span></strong></td><td id="info_email"></td></tr>
              <tr><td><strong><span class="aiqa-i18n" data-key="license.field.expiry">Expiry Date</span></strong></td><td id="info_expiry"></td></tr>
              <tr><td><strong><span class="aiqa-i18n" data-key="license.field.days">Days Remaining</span></strong></td><td id="info_days"></td></tr>
              <tr><td><strong><span class="aiqa-i18n" data-key="license.field.id">License ID</span></strong></td><td id="info_license_id"></td></tr>
            </table>
          </div>
        </div>

        <hr/>

        <div id="activation_section">
          <h3><span class="aiqa-i18n" data-key="license.activate.title">Activate License</span></h3>
          <p><span class="aiqa-i18n" data-key="license.activate.intro">Paste your license key below and click Activate.</span></p>
          <div style="margin-bottom:10px;">
            <textarea id="license_key_input" rows="4" style="width:100%; max-width:700px; font-family:monospace; font-size:12px;" placeholder="Paste your license key here (format: payload.signature)"></textarea>
          </div>
          <button class="btn btn-primary aiqa-i18n" data-key="license.activate.button" id="btn_activate">Activate License</button>
          <span id="activation_status" style="margin-left:10px;"></span>
        </div>

        <hr/>

        <div id="trial_section">
          <h3><span class="aiqa-i18n" data-key="license.trial.title">Request a Trial License</span></h3>
          <p>
            <span class="aiqa-i18n" data-key="license.trial.intro">To request a 7-day trial license, please contact us via your enterprise email.</span>
          </p>
          <p>
            <span class="aiqa-i18n" data-key="license.trial.applyPrefix">You may also click</span> <strong><a href="http://marketplace.reallysec.com" target="_blank"><span class="aiqa-i18n" data-key="license.trial.applyLink">Apply for a Trial License</span></a></strong> <span class="aiqa-i18n" data-key="license.trial.applySuffix">to submit your request directly.</span>
          </p>
          <p>
            <span class="aiqa-i18n" data-key="license.trial.includeIntro">Include the following information:</span>
          </p>
          <ul>
            <li><span class="aiqa-i18n" data-key="license.trial.item.email">Your enterprise email address</span></li>
            <li><span class="aiqa-i18n" data-key="license.trial.item.company">Company name and intended use case</span></li>
          </ul>
        </div>

        </div>
      </html>
    </panel>
  </row>
</dashboard>
