<dashboard version="1.1" script="license_guard.js,setup_page.js,aiqa_i18n_dom.js" stylesheet="setup_page.css" hideEdit="true">

 <label>Setup</label>
    <row>
        <panel>
            <html>


              <!-- Issue #26: in-panel <h1>/<h2> demoted by one level
                   so they don't compete with the dashboard's own page <h1>. -->
              <h2 style="font-size:20px;"><span class="aiqa-i18n" data-key="setup.title">Encryption Of Credentials</span></h2>

              <p>
                  <span class="aiqa-i18n" data-key="setup.intro1">If you require an encrypted credential in your configuration, then you can enter it here.</span><br/>
                  <span class="aiqa-i18n" data-key="setup.intro2">Then in your AI Provider configuration, refer to it in the format</span> <code>{encrypted:somekey}</code><br/>
                  <span class="aiqa-i18n" data-key="setup.intro3">Where</span> <code>somekey</code> <span class="aiqa-i18n" data-key="setup.intro4">is any value you choose to enter on this setup page as your credential key.</span>
              </p>


               <hr/>
                <h3><span class="aiqa-i18n" data-key="setup.enter">Enter Your Credentials To Encrypt</span></h3>

              <form>
                <div class="ck_div_input_fields">
                  <p class="helpText"><a href="#" class="add_credential_keys aiqa-i18n" data-key="setup.addRow">Click to add more Credentials</a></p>

                         <!-- form fields dynamically added here -->

                   </div>

                   <div id="ck_form_buttons">

                      <button type="button" id="ck_cancel_button" class="aiqa-i18n" data-key="setup.cancel"> Cancel </button>
                      <button type="button" id="ck_submit_button" class="aiqa-i18n" data-key="setup.save"> Save </button>

                   </div>

                </form>


            </html>
        </panel>
    </row>
</dashboard>
