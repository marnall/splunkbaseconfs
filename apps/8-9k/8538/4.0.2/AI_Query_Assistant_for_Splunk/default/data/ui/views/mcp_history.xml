<dashboard version="1.1" script="license_guard.js,mcp_history.js,aiqa_i18n_dom.js" hideEdit="true">
  <label>Query History</label>
  <description>View past natural language queries (your queries; admins can view all)</description>

  <!--
    NOTE: This view is JS-driven (see appserver/static/mcp_history.js).
    It calls the REST handler at bin/mcp_history_handler.py which performs
    server-side per-user filtering via userName. The earlier inputlookup +
    $env:user$ token approach was brittle: if the env token wasn't expanded
    on a given Splunk version every user could see everyone's history.
    The Scope dropdown, Prev/Next paging and table rendering are all
    handled in mcp_history.js. The Query Statistics chart from the old
    XML was removed because there is no clean way to scope inputlookup
    server-side per-user; if needed we'd add a dedicated stats handler.
  -->

  <row>
    <panel id="history_panel">
      <title>Recent Queries</title>
      <html>
        <div id="aiqa-history-controls" style="margin:8px 0;">
          <label for="aiqa-history-scope" style="margin-right:6px;">Scope:</label>
          <select id="aiqa-history-scope" class="form-control" style="display:inline-block; width:auto; margin-right:12px;">
            <option value="mine" selected="selected" class="aiqa-i18n" data-key="history.scope.mine">My queries</option>
            <option value="all" class="aiqa-i18n" data-key="history.scope.all">All users (admin)</option>
          </select>
          <button class="btn btn-default btn-sm aiqa-i18n" id="aiqa-history-prev" data-key="history.prev" disabled="disabled">&#171; Prev</button>
          <button class="btn btn-default btn-sm aiqa-i18n" id="aiqa-history-next" data-key="history.next" style="margin-left:6px;" disabled="disabled">Next &#187;</button>
          <span id="aiqa-history-pageinfo" style="margin-left:12px; color:#666;"></span>
        </div>
        <div id="aiqa-history-table-container">
          <div style="color:#888; padding:12px;">Loading history...</div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
