  <row>
    <panel id="value">
      <single id="sv_days_start">
        <title>Completed contest days</title>
        <search>
          <query>index=checkin_values_index sourcetype=gtks:clicks
  | search action="validated"
  | dedup id
  | stats count as total_records min(_time) as start_date
  | eval date = tostring(round((now() - start_date) / 86400, 0) + 1)
  | eval result = if(total_records = 0, "No records yet", date)
  | table result</query>
          <earliest>0</earliest>
          <latest></latest>
          <refresh>30s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="drilldown">none</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </single>
    </panel>
    <panel id="graph">
      <chart>
        <title>Total Registrations per day</title>
        <search>
          <query>index=checkin_values_index sourcetype=gtks:clicks
| search action="validated"
| dedup id
| bin _time span=1d
| stats count as Registrations by _time
| sort _time</query>
          <earliest>0</earliest>
          <latest></latest>
          <refresh>30s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">-45</option>
        <option name="charting.axisLabelsY.majorUnit">1</option>
        <option name="charting.backgroundColor">transparent</option>
        <option name="charting.chart">column</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">top</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel></panel>
    <panel></panel>
  </row>
  <row>
    <panel id="value1">
      <single>
        <title>Participating cities</title>
        <search>
          <query>index=checkin_values_index sourcetype=gtks:clicks
| search action="validated"
| dedup id
| iplocation ip
| stats dc(City) as total_cities</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
        <option name="drilldown">none</option>
        <option name="height">250</option>
        <option name="refresh.display">progressbar</option>
      </single>
    </panel>
    <panel id="pie_cities">
      <chart>
        <title>Top 10 Cities with more registrations</title>
        <search>
          <query>index=checkin_values_index sourcetype=gtks:clicks 
  | search action="validated" 
  | dedup id 
  | iplocation ip 
  | where isnotnull(City) 
  | stats count as clicks by City 
  | sort - clicks 
  | streamstats count as rank 
  | eval City = if(rank &lt;= 10, City, "Others") 
  | stats sum(clicks) as clicks by City 
  | sort - clicks 
  | appendpipe[ 
      stats count 
      | where count=0 
      | head 1 
  ]</query>
          <earliest>0</earliest>
          <latest></latest>
          <refresh>30s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisY.abbreviation">none</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.backgroundColor">transparent</option>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel></panel>
    <panel></panel>
  </row>
  <row>
    <panel id="value2">
      <single>
        <title>Predicted days to draw</title>
        <search>
          <query>| makeresults
  | eval days_until_finish="⏳"
  | append [
      search index=checkin_values_index sourcetype=gtks:clicks action="validated"
      | dedup id
      | timechart span=1d dc(email) as daily_users
      | eventstats count as total_days
      | where total_days &gt;= 2
      | predict daily_users future_timespan=2000 holdback=0
      | eval predicted_users='prediction(daily_users)'
      | eval predicted_users=if(predicted_users&lt;0,0,predicted_users)
      | eval daily_users=coalesce(daily_users,predicted_users)
      | accum daily_users as cumulative_users
      | where cumulative_users &gt;= 2000
      | eval days_until_finish=ceil((_time-now())/86400)
      | head 1
      | table days_until_finish
  ]
  | tail 1
  | table days_until_finish</query>
          <earliest>0</earliest>
          <latest></latest>
          <refresh>30s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="drilldown">none</option>
        <option name="height">250</option>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="refresh.display">none</option>
        <option name="useThousandSeparators">1</option>
      </single>
    </panel>
    <panel id="graph2">
      <chart>
        <title>Predicted Registrations until draw</title>
        <search>
          <query>index=checkin_values_index sourcetype=gtks:clicks action="validated"
| dedup id
| timechart span=1d dc(email) as Registrations
| predict Registrations future_timespan=2000 holdback=0 as "Predicted Registrations"
| where _time &lt;= strptime("2026-12-31", "%Y-%m-%d")
| appendpipe [
    stats count
    | where count=0
    | eval _time=now(), Registrations=0, "Predicted Registrations"=0
    | fields - count
]</query>
          <earliest>0</earliest>
          <latest></latest>
          <refresh>30s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.axisY.abbreviation">none</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.backgroundColor">transparent</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel></panel>
    <panel></panel>
  </row>
</dashboard>