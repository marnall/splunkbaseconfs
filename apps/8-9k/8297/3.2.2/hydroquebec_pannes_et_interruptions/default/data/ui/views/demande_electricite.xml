<form version="1.1" theme="dark">
  <label>Demande d'électricité</label>
  <description>Surveillance en temps réel de la demande d'électricité au Québec</description>
  <!-- Ligne 1: Indicateurs clés -->
  <!-- Ligne 2: Graphique principal -->
  <!-- Ligne 3: Comparaison horaire et statistiques -->
  <!-- Ligne 4: Tableau des données récentes -->
  <!-- Ligne 5: Statistiques détaillées -->
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time_range">
      <label>Période</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <single>
        <title>Demande Actuelle (MW)</title>
        <search>
          <query>index=hydroquebec sourcetype=hydroquebec:demande 
| stats latest(demande_mw) as demande_actuelle
| eval demande_actuelle_fmt = demande_actuelle." MW"
| fields demande_actuelle_fmt</query>
          <earliest>-60m@m</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x65a637","0xf7bc38","0xd93f3c"]</option>
        <option name="rangeValues">[30000,38000]</option>
        <option name="refresh.display">progressbar</option>
        <option name="underLabel">Dernière mesure</option>
        <option name="useColors">1</option>
        <option name="useThousandSeparators">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Demande Moyenne (24h)</title>
        <search>
          <query>
index=hydroquebec sourcetype=hydroquebec:demande earliest=-24h
| stats avg(demande_mw) as demande_avg
| eval demande_avg_fmt = round(demande_avg, 0)." MW"
| fields demande_avg_fmt
          </query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="underLabel">Moyenne</option>
        <option name="useThousandSeparators">1</option>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <single>
        <title>Demande Maximale (24h)</title>
        <search>
          <query>
index=hydroquebec sourcetype=hydroquebec:demande earliest=-24h
| stats max(demande_mw) as demande_max
| eval demande_max_fmt = demande_max." MW"
| fields demande_max_fmt
          </query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="underLabel">Pointe</option>
        <option name="useThousandSeparators">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Demande Minimale (24h)</title>
        <search>
          <query>
index=hydroquebec sourcetype=hydroquebec:demande earliest=-24h
| stats min(demande_mw) as demande_min
| eval demande_min_fmt = demande_min." MW"
| fields demande_min_fmt
          </query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="underLabel">Creux</option>
        <option name="useThousandSeparators">1</option>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Évolution de la Demande d'Électricité</title>
        <search>
          <query>
index=hydroquebec sourcetype=hydroquebec:demande 
| timechart span=15m latest(demande_mw) as "Demande (MW)"
| eval "Demande (MW)"=round('Demande (MW)', 0)
          </query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">-45</option>
        <option name="charting.axisTitleX.text">Temps</option>
        <option name="charting.axisTitleY.text">Demande (MW)</option>
        <option name="charting.chart">column</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"Demande (MW)": 0x1E88E5}</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.lineWidth">2</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
</form>