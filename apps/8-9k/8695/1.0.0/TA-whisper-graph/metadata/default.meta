# Note: [indexes] stanza removed -- TA does not ship index definitions.
# Splunk Cloud Victoria prohibits app-shipped indexes.conf entirely.
# Customers must create the "whisper" index via:
#   - Splunk Cloud Victoria: ACS API or Cloud Console
#   - Splunk Cloud Classic: Splunk Web -> Settings -> Indexes
#   - Splunk Enterprise / on-prem: `splunk add index whisper ...` or Settings -> Indexes
# See docs/getting-started/installation.md for full instructions.

[lookups]
export = system
