[list_1password_users://<name>]
address = 1Password Address. E.g. companyname.1password.com
email = Email address of the account used
index = (Default: default)
interval = Time interval of input in seconds.
password = Password of the account used
path_to_op_binary = Path to the 1Password CLI binary (Default: /usr/bin/op)
secret_key = Secret key of the account used
user_id = User ID of the account used. Can be retrieved from the URL when viewing the user page on the 1Password website

