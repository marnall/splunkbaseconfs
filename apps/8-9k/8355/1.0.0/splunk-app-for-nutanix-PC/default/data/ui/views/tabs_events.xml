<dashboard version="1.1" hideSplunkBar="False" hideTitle="True" hideEdit="True" stylesheet="nutanix.css" script="nutanix.js">
    <label>Events</label>

    <init>
        <set token="pc_ip">all</set>
        <set token="cluster_name">all</set>
    </init>
    <search id="events_tab_base" ref="Events tab base"/>
    <search id="select_prism_central" ref="Select Prism Central"/>

    <fieldset>
        <input type="dropdown" token="pc_ip" searchWhenChanged="true">
            <label>Select Prism Central</label>
            <choice value="all">All</choice>
            <default>all</default>
            <search base="select_prism_central" />
            <fieldForValue>pc_ip</fieldForValue>
            <fieldForLabel>name</fieldForLabel>
            <selectFirstChoice>true</selectFirstChoice>
        </input>
        <input type="dropdown" token="cluster_name" searchWhenChanged="true">
            <label>Select Cluster Name</label>
            <choice value="all">All</choice>
            <default>all</default>
            <search>
                <query>
                    | savedsearch "Select Cluster Name"
                    | search `get_clusters($pc_ip$)`
                </query>
            </search>
            <fieldForValue>extId</fieldForValue>
            <fieldForLabel>name</fieldForLabel>
            <selectFirstChoice>true</selectFirstChoice>
        </input>
    </fieldset>
    <row>
        <panel>
            <table id="events_table">
                <search base="events_tab_base">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterUUID="$cluster_name$")
                        | table  Title, "Event Type", "Created Time", Cluster
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
    </row>
</dashboard>