<dashboard version="1.1" hideSplunkBar="False" hideTitle="True" hideEdit="True" stylesheet="nutanix.css" script="nutanix.js">
    <label>Host NICs</label>
    <search id="clusters_request" ref="Clusters" />
    <search id="hosts_info_table" ref="Hosts Info Table" />
    <search id="hosts_performance_base" ref="Hosts Performance Base" />
    <search id="host_nics_base" ref="Host NICs base" />
    <row id="hosts_pc_cluster_table">
        <panel id="pc_panel_short">
            <title>Prism Centrals</title>
            <table id="PC">
                <search ref="Prism Centrals">
                    <done>
                        <set token="pc_ip">$result.pc_ip$</set>
                    </done>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">6</option>
                <option name="drilldown">cell</option>
                <fields>Name</fields>
                <drilldown>
                    <set token="pc_ip">$row.pc_ip$</set>
                </drilldown>
            </table>
        </panel>
        <panel id="cluster_panel_short">
            <title>Clusters</title>
            <table id="Clusters">
                <search base="clusters_request">
                    <query>search pc_ip="$pc_ip$"</query>
                    <done>
                        <set token="cluster_name">$result.extId$</set>
                    </done>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">6</option>
                <option name="drilldown">cell</option>
                <fields>Name</fields>
                <drilldown>
                    <set token="cluster_name">$row.extId$</set>
                </drilldown>
            </table>
        </panel>
        <panel id="hosts_table">
            <title>Hosts Info</title>
            <table id="hosts_nic_table_data">
                <search base="hosts_info_table">
                    <query>
                        | search ClusterUUID="$cluster_name$"
                    </query>
                    <done>
                        <set token="host_extId">$result.extId$</set>
                    </done>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">6</option>
                <fields>"Host name", "Node serial", "Type", "Memory (GB)", "Usage", "CPU HGz", "Block Model", "Block Serial"</fields>
                <option name="drilldown">cell</option>
                <drilldown>
                    <set token="host_extId">$row.extId$</set>
                </drilldown>
            </table>
        </panel>
    </row>
    <row>
        <panel>
            <table id="nics_table">
                <search base="host_nics_base">
                    <query> | search nodeUuid="$host_extId$"
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <fields>"Host NIC", "Speed in GB", "MAC Address", "Rx Pkts", "Tx Pkts"</fields>
                <option name="count">10</option>
            </table>
        </panel>
    </row>
</dashboard>
