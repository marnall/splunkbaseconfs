<dashboard version="1.1" hideSplunkBar="False" hideTitle="True" hideEdit="True" stylesheet="nutanix.css" script="nutanix.js">
    <label>VMs</label>

    <search id="clusters_request" ref="Clusters"/>
    <search id="vms_info_table" ref="VMS Info Table"/>
    <search id="vms_performance_base" ref="VMs Performance Base"/>
    <search id="vms_storage_performance_base" ref="VMs Storage Performance Base"/>

    <row id="vm_pc_cluster_table">
        <panel id="pc_panel_short">
            <table id="PC">
                <title>Prism Centrals</title>
                <search ref="Prism Centrals">
                    <done>
                        <set token="pc_ip">$result.pc_ip$</set>
                    </done>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
                <option name="drilldown">cell</option>
                <fields>Name</fields>
                <drilldown>
                    <set token="pc_ip">$row.pc_ip$</set>
                </drilldown>
            </table>
        </panel>
        <panel id="cluster_panel_short">
            <table id="Clusters">
                <title>Clusters</title>
                <search base="clusters_request">
                    <query>search pc_ip="$pc_ip$"</query>
                    <done>
                        <set token="cluster_name">$result.extId$</set>
                    </done>
                </search>

                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
                <option name="drilldown">cell</option>
                <fields>Name</fields>
                <drilldown>
                    <set token="cluster_name">$row.extId$</set>
                </drilldown>
            </table>
        </panel>
        <panel id="vms_table">
            <table id="vms_table_data">
                <title>VMs info</title>
                <search base="vms_info_table">
                    <query>
                        | search ClusterUUID="$cluster_name$"
                    </query>
                    <done>
                        <set token="vm_extId">$result.extId$</set>
                    </done>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
                <fields>"Name", "vCPUs", "Memory (GB)", Usage, "IP Address", "Power State"</fields>
                <option name="drilldown">cell</option>
                <drilldown>
                    <set token="vm_extId">$row.extId$</set>
                </drilldown>
            </table>
        </panel>
    </row>
    <row id="storage_vm_top_data">
        <panel>
            <chart>
                <title>Storage usage</title>
                <search base="vms_storage_performance_base">
                    <query>                        
                        | search extId="$vm_extId$" | fields value
                    </query>
                </search>
                <option name="height">200</option>
                <option name="charting.chart">markerGauge</option>
                <option name="charting.chart.orientation">x</option>

                <option name="charting.chart.showLabels">true</option>
                <option name="charting.chart.showMajorTicks">true</option>
                <option name="charting.chart.showMinorTicks">true</option>
                <option name="charting.chart.showValue">true</option>
                <option name="charting.chart.showRangeBand">true</option>

                <option name="charting.chart.style">minimal</option>
                <option name="charting.chart.majorUnit">10</option>

                <option name="charting.chart.rangeValues">[0,70,90,100]</option>
                <option name="charting.gaugeColors">[0x76EA73,0xF5B53F,0xDF564D]</option>

                <option name="charting.chart.usePercentageValue">true</option>
                <option name="charting.chart.usePercentageRange">true</option>

            </chart>
        </panel>
        <panel>
            <title>Top 5 VMs by Memory Usage</title>
            <table>
                <search base="vms_performance_base">
                    <query>                        
                        | search cluster=$cluster_name$ 
                        | sort - "Memory usage %"
                        | head 5
                        | table Name, "Memory usage %"
                    </query>
                </search>
                <option name="count">5</option>
                <option name="dataOverlayMode">none</option>
                <option name="wrap">false</option>
                <option name="drilldown">none</option>
            </table>
        </panel>
        <panel>
            <title>Top 5 VMs by CPU usage</title>
            <table>
                <search base="vms_performance_base">
                    <query>                        
                        | search cluster=$cluster_name$ 
                        | sort - "CPU Usage %"
                        | head 5
                        | table Name, "CPU Usage %"
                    </query>
                </search>
                <option name="count">5</option>
                <option name="wrap">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="drilldown">none</option>
            </table>
        </panel>
    </row>
    <row id="vm_top_data">
        <panel>
            <title>Top 5 VMs by AVG IO Latency</title>
            <table>
                <search base="vms_performance_base">
                    <query> 
                        | search cluster=$cluster_name$
                        | eval "Avg IO Latency" =  round(ioLatencyMs, 2)
                        | sort - "Avg IO Latency"
                        | head 5
                        | table Name, "Avg IO Latency"
                    </query>
                </search>
                <option name="count">5</option>
                <option name="wrap">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="drilldown">none</option>
            </table>
        </panel>
        <panel>
            <title>Top 5 VMs by AVG IOPS</title>
            <table>
                <search base="vms_performance_base">
                    <query>                        
                        | search cluster=$cluster_name$
                        | eval "Avg IOPS" =  round(iops, 2)
                        | sort - "Avg IOPS"
                        | head 5
                        | table Name, "Avg IOPS"
                    </query>
                </search>
                <option name="count">5</option>
                <option name="wrap">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="drilldown">none</option>
            </table>
        </panel>
        <panel>
            <title>Top 5 VMs by IO Bandwidth</title>
            <table>
                <search base="vms_performance_base">
                    <query>                        
                        | search cluster=$cluster_name$
                        | eval "Avg IO Bandwidth" =  round(ioBandwidthKBps, 2)
                        | sort - "Avg IO Bandwidth"
                        | head 5
                        | table Name, "Avg IO Bandwidth"
                    </query>
                </search>
                <option name="count">5</option>
                <option name="wrap">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="drilldown">none</option>
            </table>
        </panel>
    </row>
</dashboard>