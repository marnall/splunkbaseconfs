<dashboard version="1.1" hideSplunkBar="False" hideTitle="True" hideEdit="True" stylesheet="nutanix.css" script="nutanix.js">
    <label>Alerts</label>
    <init>
        <set token="pc_ip">all</set>
        <set token="cluster_name">all</set>
    </init>
    <search id="alerts_tab_base_critical" ref="Alerts tab base critical"/>
    <search id="select_prism_central" ref="Select Prism Central"/>

    <search id="alerts_tab_base_all" ref="Alerts tab base all"/>
    <search id="alerts_tab_base_info" ref="Alerts tab base info"/>
    <search id="alerts_tab_base_warning" ref="Alerts tab base warning"/>
    <search id="alerts_tab_base_resolved" ref="Alerts tab base resolved"/>

    <fieldset>
        <input type="dropdown" token="pc_ip" searchWhenChanged="true" tokenDependencies="false">
            <label>Select Prism Central</label>
            <search base="select_prism_central" />
            <fieldForValue>pc_ip</fieldForValue>
            <fieldForLabel>name</fieldForLabel>
            <selectFirstChoice>true</selectFirstChoice>
            <choice value="all">All</choice>
        </input>
        <input type="dropdown" token="cluster_name" searchWhenChanged="true">
            <label>Select Cluster Name</label>
            <choice value="all">All</choice>
            <default>all</default>
            <search>
                <query>
                    | savedsearch "Select Cluster Name"
                    | search `get_clusters($pc_ip$)`
                </query>
            </search>
            <fieldForValue>extId</fieldForValue>
            <fieldForLabel>name</fieldForLabel>
            <selectFirstChoice>true</selectFirstChoice>
        </input>
        <input type="dropdown" token="tokShowHidePanel" searchWhenChanged="true">
            <label>Select Alert Type</label>
            <choice value="all">All</choice>
            <choice value="info">Info</choice>
            <choice value="warning">Warning</choice>
            <choice value="critical">Critical</choice>
            <choice value="resolved">Resolved</choice>
            <default>critical</default>
            <change>
                <condition value="all">
                    <set token="tokShowAll">true</set>
                    <unset token="tokShowInfo"></unset>
                    <unset token="tokShowWarning"></unset>
                    <unset token="tokShowCritical"></unset>
                    <unset token="tokShowResolved"></unset>
                </condition>
                <condition value="info">
                    <set token="tokShowInfo">true</set>
                    <unset token="tokShowAll"></unset>
                    <unset token="tokShowWarning"></unset>
                    <unset token="tokShowCritical"></unset>
                    <unset token="tokShowResolved"></unset>
                </condition>
                <condition value="warning">
                    <set token="tokShowWarning">true</set>
                    <unset token="tokShowInfo"></unset>
                    <unset token="tokShowAll"></unset>
                    <unset token="tokShowCritical"></unset>
                    <unset token="tokShowResolved"></unset>
                </condition>
                <condition value="critical">
                    <set token="tokShowCritical">true</set>
                    <unset token="tokShowInfo"></unset>
                    <unset token="tokShowWarning"></unset>
                    <unset token="tokShowAll"></unset>
                    <unset token="tokShowResolved"></unset>
                </condition>
                <condition value="resolved">
                    <set token="tokShowResolved">true</set>
                    <unset token="tokShowInfo"></unset>
                    <unset token="tokShowWarning"></unset>
                    <unset token="tokShowCritical"></unset>
                    <unset token="tokShowAll"></unset>
                </condition>
            </change>
        </input>
    </fieldset>
       <row>
        <panel depends="$tokShowAll$">
            <title>All</title>
            <table>
                <search base="alerts_tab_base_all">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterUUID="$cluster_name$")
                        | table Title, "Source Entity", "Impact Type", Severity, "Created Time", "Last Occurred", Cluster
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel depends="$tokShowInfo$">
            <title>Info</title>
            <table>
                <search base="alerts_tab_base_info">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterUUID="$cluster_name$")
                        | table Title, "Source Entity", "Impact Type", Severity, "Created Time", "Last Occurred", Cluster
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel depends="$tokShowWarning$">
            <title>Warning</title>
            <table>
                <search base="alerts_tab_base_warning">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterUUID="$cluster_name$")
                        | table Title, "Source Entity", "Impact Type", Severity, "Created Time", "Last Occurred", Cluster
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel depends="$tokShowResolved$">
            <title>Resolved</title>
            <table>
                <search base="alerts_tab_base_resolved">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterUUID="$cluster_name$")
                        | table Title, "Source Entity", "Impact Type", Severity, "Created Time", "Last Occurred", Cluster
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel depends="$tokShowCritical$">
            <title>Critical</title>
            <table>
                <search base="alerts_tab_base_critical">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterUUID="$cluster_name$")
                        | table Title, "Source Entity", "Impact Type", Severity, "Created Time", "Last Occurred", Cluster
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
    </row>
</dashboard>