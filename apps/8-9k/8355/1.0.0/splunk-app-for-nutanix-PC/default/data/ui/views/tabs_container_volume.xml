<dashboard version="1.1" hideSplunkBar="False" hideEdit="True" stylesheet="nutanix.css" script="nutanix.js">
    <label>Container &amp; volume group</label>

    <init>
        <set token="pc_ip">all</set>
        <set token="cluster_name">all</set>
    </init>

    <search id="volume_groups_table_base" ref="Volume groups table base"/>
    <search id="storage_containers_groups_table_base" ref="Storage Containers Groups table base"/>
    <search id="select_prism_central" ref="Select Prism Central"/>

    <fieldset>
        <input type="dropdown" token="pc_ip" searchWhenChanged="true">
            <label>Select Prism Central</label>
            <choice value="all">All</choice>
            <default>all</default>
            <search base="select_prism_central" />
            <fieldForValue>pc_ip</fieldForValue>
            <fieldForLabel>name</fieldForLabel>
            <selectFirstChoice>true</selectFirstChoice>
        </input>
        <input type="dropdown" token="cluster_name" searchWhenChanged="true">
            <label>Select Cluster Name</label>
            <choice value="all">All</choice>
            <default>all</default>
            <search>
                <query>
                    | savedsearch "Select Cluster Name"
                    | search `get_clusters($pc_ip$)`
                </query>
            </search>
            <fieldForValue>extId</fieldForValue>
            <fieldForLabel>name</fieldForLabel>
            <selectFirstChoice>true</selectFirstChoice>
        </input>
    </fieldset>
    <row>
        <panel>
            <title>Storage Containers Groups</title>
            <table id="containers_groups_table">
                <search base="storage_containers_groups_table_base">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterExtId="$cluster_name$")
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
                <fields>Name, "Total Capacity (TB)", "Cluster Fault Tolerance", "Replication Factor", "Compression", "Capacity Deduplication", "Erasure Coding"</fields>
            </table>
        </panel>
    </row>
    <row>
        <panel>
            <title>Volume Groups</title>
            <table id="volume_groups_table">
                <search base="volume_groups_table_base">
                    <query> 
                        | where ("$pc_ip$"="all" OR pc_ip="$pc_ip$")
                        | where ("$cluster_name$"="all" OR clusterReference="$cluster_name$")
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <fields>"Volume Group Name", "Sharing Status", "Load Balance VM Attachments", "Cluster Name", "Usage Type",  "Controller User Bytes (GB)"</fields>
                <option name="count">10</option>
            </table>
        </panel>
    </row>
</dashboard>