<dashboard version="1.1" stylesheet="nutanix.css" script="nutanix.js" hideSplunkBar="False" hideTitle="True" hideEdit="True">
    <label>Prism Central</label>

    <search id="clusters_request" ref="Clusters"/>
    <search id="critical_base_part" ref="Critical base part"/>
    <search id="warning_base_part" ref="Warning base part"/>
    <search id="info_base_part" ref="Info base part"/>

    <search id="events_base" ref="Events base"/>
    <search id="top5_base" ref="Top5 clusters base"/>

    <search id="cluster_storage_usage_search" ref="Cluster Storage Usage sparkline"/>
    <search id="cluster_memory_usage_search" ref="Cluster Memory Usage sparkline"/>
    <search id="cluster_cpu_usage_search" ref="Cluster CPU Usage sparkline"/>
    <search id="cluster_IOPS_usage_search" ref="Cluster IOPS sparkline"/>
    <search id="cluster_Bandwidth_usage_search" ref="Cluster Bandwidth sparkline"/>
    <search id="cluster_IO_Latency_usage_search" ref="Cluster IO Latency sparkline"/>

    <row id="pc_alert_event">
        <panel id="prism_central_data">
            <table id="PC">
                <title>Prism Centrals</title>
                <search ref="Prism Centrals">
                    <done>
                        <set token="pc_ip">$result.pc_ip$</set>
                    </done>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">5</option>
                <option name="drilldown">cell</option>
                <fields>Name</fields>
                <drilldown>
                    <set token="pc_ip">$row.pc_ip$</set>
                </drilldown>
            </table>
        </panel>

        <panel id="alerts_panel_main">
            <title>Alerts (last 24 hours)</title>
            <single id="critical">
                <title>Critical</title>
                <search base="critical_base_part">
                    <query>
                        | search pc_ip="$pc_ip$"
                        | timechart span=1h dc(extId) as value
                    </query>
                </search>
                <option name="drilldown">all</option>
                <drilldown>
                    <link> tabs_alerts?form.alert_type=critical&amp;form.cluster_name=all&amp;form.pc_ip=$pc_ip$
                    </link>
                </drilldown>

                <option name="showSparkline">1</option>
                <option name="showTrendIndicator">1</option>
                <option name="trendDisplayMode">absolute</option>
                <option name="trendInterval">auto</option>

                <option name="colorBy">trend</option>
                <option name="useColors">1</option>
                <option name="rangeColors">["0x65a637","0x6db7c6","0xf7bc38","0xf58f39","0xd93f3c"]</option>
                <option name="rangeValues">[0,30,70,100]</option>

                <option name="useThousandSeparators">1</option>
                <option name="height">150</option>
            </single>
            <single id="warning">
                <title>Warning</title>
                <search base="warning_base_part">
                    <query>
                        | search pc_ip="$pc_ip$"
                        | timechart span=1h dc(extId) as value
                    </query>
                </search>
                <option name="drilldown">all</option>
                <drilldown>
                    <link> tabs_alerts?form.alert_type=warning&amp;form.cluster_name=all&amp;form.pc_ip=$pc_ip$
                    </link>
                </drilldown>

                <option name="showSparkline">1</option>
                <option name="showTrendIndicator">1</option>
                <option name="trendDisplayMode">absolute</option>
                <option name="trendInterval">auto</option>

                <option name="colorBy">trend</option>
                <option name="useColors">1</option>
                <option name="rangeColors">["0x65a637","0x6db7c6","0xf7bc38","0xf58f39","0xd93f3c"]</option>
                <option name="rangeValues">[0,30,70,100]</option>

                <option name="useThousandSeparators">1</option>
                <option name="height">150</option>
            </single>
            <single id="info">
                <title>Info</title>
                <search base="info_base_part">
                    <query>
                        | search pc_ip="$pc_ip$"
                        | timechart span=1h dc(extId) as value
                    </query>
                </search>
                <option name="drilldown">all</option>
                <drilldown>
                    <link> tabs_alerts?form.alert_type=info&amp;form.cluster_name=all&amp;form.pc_ip=$pc_ip$
                    </link>
                </drilldown>

                <option name="showSparkline">1</option>
                <option name="showTrendIndicator">1</option>
                <option name="trendDisplayMode">absolute</option>
                <option name="trendInterval">auto</option>

                <option name="colorBy">trend</option>
                <option name="useColors">1</option>
                <option name="rangeColors">["0x65a637","0x6db7c6","0xf7bc38","0xf58f39","0xd93f3c"]</option>
                <option name="rangeValues">[0,30,70,100]</option>

                <option name="useThousandSeparators">1</option>
                <option name="height">150</option>
            </single>
        </panel>
        <panel id="events_panel_main">
            <title>Events</title>
            <single id="events">
                <title>.</title>
                <search base="events_base">
                    <query>
                        | search pc_ip="$pc_ip$"
                        | stats dc(extId) as value, latest(timestamp_epoch) as last_time
                        | eval hours_ago = round((now() - last_time) / 3600, 0)
                        | eval underLabel = "Last event: " . hours_ago . " hours ago"
                    </query>
                    <progress>
                        <set token="events_under_label">-</set>
                    </progress>
                    <done>
                        <set token="events_under_label">$result.underLabel$</set>
                    </done>
                </search>
                <option name="drilldown">all</option>
                <drilldown>
                    <link> tabs_events?form.cluster_name=all&amp;form.pc_ip=$pc_ip$
                    </link>
                </drilldown>

                <option name="useThousandSeparators">1</option>
                <option name="underLabel">$events_under_label$</option>
            </single>
        </panel>
    </row>
    <row id="cluster_top_data">
        <panel>
            <title>Clusters</title>
            <table id="Clusters">
                <search base="clusters_request">
                    <query>search pc_ip="$pc_ip$"</query>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">5</option>
                <option name="drilldown">cell</option>
                <fields>Name,Nodes,VMs</fields>
                <drilldown>
                    <link> tabs_cluster?form.cluster_name=$row.extId$&amp;form.pc_ip=$pc_ip$
                    </link>
                </drilldown>
            </table>
        </panel>
        <panel>
            <title>Top Clusters by CPU usage</title>
            <table>
                <search base="top5_base">
                    <query>
                        | search pc_ip="$pc_ip$" 
                        | sort - "CPU Usage %"
                        | head 5
                        | table Name, "CPU Usage %"
                    </query>
                </search>

                <option name="count">5</option>
                <option name="wrap">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="drilldown">none</option>
            </table>
        </panel>
        <panel>
            <title>Top Clusters by Memory usage</title>
            <table>
                <search base="top5_base">
                    <query>
                        | search pc_ip="$pc_ip$" 
                        | sort - "Memory Usage %"
                        | head 5
                        | table Name, "Memory Usage %"
                    </query>
                </search>

                <option name="count">5</option>
                <option name="wrap">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="drilldown">none</option>
            </table>
        </panel>
    </row>
    <row id="sparkline_charts1">
        <panel>
            <title>Cluster Storage Usage</title>
            <table id="cluster_storage_usage">
                <search base="cluster_storage_usage_search">
                    <query>| eval storageUsageGB = round(storageUsageBytes / (1024 * 1024 * 1024), 2) | stats values(pc_ip) as pc_ip, sparkline(avg(storageUsageGB)) as "Storage Usage, GB", values(name) as "Name" by extId 
                        | where pc_ip="$pc_ip$" 
                        | table Name "Storage Usage, GB"</query>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="drilldown">none</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel>
            <title>Cluster Memory Usage</title>
            <table id="cluster_memory_usage">
                <search base="cluster_memory_usage_search">
                    <query>| eval overallMemoryUsagGB = round(overallMemoryUsageBytes / (1024 * 1024 * 1024), 2) | stats values(pc_ip) as pc_ip, sparkline(avg(overallMemoryUsagGB)) as "Memory Usage, GB", values(name) as "Name" by extId
                        | where pc_ip="$pc_ip$" 
                        | table Name "Memory Usage, GB"</query>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="drilldown">none</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel>
            <title>Cluster CPU Usage</title>
            <table id="cluster_cpu_usage">
                <search base="cluster_cpu_usage_search">
                    <query>|eval hypervisorCpuUsagePercent = hypervisorCpuUsagePpm / 10000 | stats values(pc_ip) as pc_ip, sparkline(avg(hypervisorCpuUsagePercent)) as "CPU Usage, %", values(name) as "Name" by extId
                        | where pc_ip="$pc_ip$" 
                        | table Name "CPU Usage, %"</query>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="drilldown">none</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
    </row>
    <row id="sparkline_charts2">
        <panel>
            <title>IOPS (by hour)</title>
            <table id="iops">
                <search base="cluster_IOPS_usage_search">
                    <query>| stats values(pc_ip) as pc_ip, sparkline(avg(controllerNumIops)) as "IOPS", values(name) as "Name" by extId 
                        | where pc_ip="$pc_ip$" 
                        | table Name "IOPS"</query>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="drilldown">none</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel>
            <title>IO Bandwidth (by hour)</title>
            <table id="bandwidth">
                <search base="cluster_Bandwidth_usage_search">
                    <query>|eval ioBandwidthMBps = ioBandwidthKbps / 8 / 1024 | stats values(pc_ip) as pc_ip, sparkline(avg(ioBandwidthMBps)) as "IO Bandwidth, MB/s", values(name) as "Name" by extId
                        | where pc_ip="$pc_ip$" 
                        | table Name "IO Bandwidth, MB/s"</query>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="drilldown">none</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
        <panel>
            <title>IO Latency</title>
            <table id="IOLatency">
                <search base="cluster_IO_Latency_usage_search">
                    <query>| eval controllerAvgIoLatencyUsecs = controllerAvgIoLatencyUsecs / 1000 
                        |stats values(pc_ip) as pc_ip, sparkline(avg(controllerAvgIoLatencyUsecs)) as "IO Latency, ms", values(name) as "Name" by extId
                        | where pc_ip="$pc_ip$" 
                        | table Name "IO Latency, ms"</query>
                </search>
                <option name="wrap">false</option>
                <option name="rowNumbers">false</option>
                <option name="drilldown">none</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
            </table>
        </panel>
    </row>
</dashboard>