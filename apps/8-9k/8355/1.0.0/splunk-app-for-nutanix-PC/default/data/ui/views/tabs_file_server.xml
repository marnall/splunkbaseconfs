<dashboard version="1.1" hideSplunkBar="False" hideTitle="True" hideEdit="True" stylesheet="nutanix.css" script="nutanix.js">
    <label>File server</label>

    <search id="file_server_info_base" ref="File server info base"/>

    <row id="file_server_row">
        <panel id="pc_panel_short">
            <table id="PC">
                <title>Prism Centrals</title>
                <search ref="Prism Centrals">
                    <done>
                        <set token="pc_ip">$result.pc_ip$</set>
                    </done>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">10</option>
                <option name="drilldown">cell</option>
                <fields>Name</fields>
                <drilldown>
                    <set token="pc_ip">$row.pc_ip$</set>
                </drilldown>
            </table>
        </panel>

        <panel id="file_sever_table">
            <title>File server Info</title>
            <table>
                <search base="file_server_info_base">
                    <query> | search pc_ip="$pc_ip$"
                    </query>
                </search>
                <option name="wrap">true</option>
                <option name="rowNumbers">false</option>
                <option name="dataOverlayMode">none</option>
                <option name="count">6</option>
                <fields>"Name"</fields>
                <option name="drilldown">cell</option>
                <drilldown>
                    <set token="file_sever_extId">$row.extId$</set>
                </drilldown>
            </table>
        </panel>
    </row>
</dashboard>