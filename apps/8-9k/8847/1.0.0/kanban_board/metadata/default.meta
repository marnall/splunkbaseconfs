[]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = none

# Viz usable from dashboards in any app (Studio dashboards usually live in search)
[visualizations]
export = system

# Lookups must resolve from other app contexts (demo searches, user dashboards)
[transforms]
export = system

[collections]
export = system

# kanbanwrite must be callable from dashboards in any app (e.g. search)
[commands]
export = system
