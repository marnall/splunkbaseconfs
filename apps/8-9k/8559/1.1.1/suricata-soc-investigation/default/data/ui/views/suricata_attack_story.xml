<dashboard version="1.1">
    <label>Incident Timeline</label>

    <search>
        <query>
            | inputlookup suricata_settings.csv
            | stats latest(eval(if(setting="search_scope", value, null()))) as search_scope latest(eval(if(setting="time_choice", value, null()))) as time_choice
            | eval search_scope=coalesce(search_scope, "index=suricata")
            | eval time_choice=coalesce(time_choice, "24h")
            | eval earliest_tok=case(time_choice=="7d", "-7d@d", time_choice=="30d", "-30d@d", time_choice=="all", "0", true(), "-24h@h")
            | eval latest_tok="now"
        </query>
        <done>
            <set token="search_scope">$result.search_scope$</set>
            <set token="form.search_scope">$result.search_scope$</set>
            <set token="time_choice">$result.time_choice$</set>
            <set token="form.time_choice">$result.time_choice$</set>
            <set token="earliest_tok">$result.earliest_tok$</set>
            <set token="latest_tok">$result.latest_tok$</set>
        </done>
    </search>

    <fieldset submitButton="false">
        <input type="dropdown" token="time_choice">
            <label>Time Range</label>
            <choice value="24h">Last 24 hours</choice>
            <choice value="7d">Last 7 days</choice>
            <choice value="30d">Last 30 days</choice>
            <choice value="all">All time</choice>
            <default>24h</default>
            <initialValue>24h</initialValue>
            <change>
                <condition value="24h">
                    <set token="earliest_tok">-24h@h</set>
                    <set token="latest_tok">now</set>
                </condition>
                <condition value="7d">
                    <set token="earliest_tok">-7d@d</set>
                    <set token="latest_tok">now</set>
                </condition>
                <condition value="30d">
                    <set token="earliest_tok">-30d@d</set>
                    <set token="latest_tok">now</set>
                </condition>
                <condition value="all">
                    <set token="earliest_tok">0</set>
                    <set token="latest_tok">now</set>
                </condition>
            </change>
        </input>

        <input type="text" token="search_scope">
            <label>Search Scope</label>
            <default>index=suricata</default>
            <initialValue>index=suricata</initialValue>
        </input>

        <input type="dropdown" token="src_select">
            <label>Source IP (Quick Select)</label>
            <choice value="">-- Select --</choice>
            <search>
                <query>
                    $search_scope$ event_type=alert
                    | stats count by src_ip
                    | sort - count
                    | head 20
                </query>
                <earliest>$earliest_tok$</earliest>
                <latest>$latest_tok$</latest>
            </search>
            <fieldForLabel>src_ip</fieldForLabel>
            <fieldForValue>src_ip</fieldForValue>

            <change>
                <set token="src">$value$</set>
            </change>
        </input>

        <input type="text" token="src">
            <label>Source IP</label>
        </input>
    </fieldset>

    <row>
        <panel>
            <title>Attack Sessions</title>

            <table>
                <search>
                    <query>
                        $search_scope$ event_type=alert
                        | search src_ip="$src$"
                        | transaction src_ip dest_ip maxspan=5m
                        | eval session_start=_time
                        | eval session_end=_time + duration
                        | eval alert_count=eventcount
                        | eval ports=mvjoin(mvdedup(dest_port), ", ")
                        | eval signatures=mvjoin(mvdedup('alert.signature'), ", ")
                        | convert ctime(session_start)
                        | convert ctime(session_end)
                        | table src_ip dest_ip session_start session_end alert_count ports
                        signatures
                        | sort - session_start
                    </query>
                    <earliest>$earliest_tok$</earliest>
                    <latest>$latest_tok$</latest>
                </search>
            </table>

        </panel>
    </row>

</dashboard>
