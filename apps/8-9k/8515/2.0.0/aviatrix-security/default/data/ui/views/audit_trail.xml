<form version="1.1" theme="dark">
  <label>Audit Trail</label>
  <description>Aviatrix Controller change tracking and audit log analysis</description>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-7d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="result" searchWhenChanged="true">
      <label>Result</label>
      <choice value="*">All</choice>
      <choice value="Success">Success</choice>
      <choice value="failure">Failure</choice>
      <default>*</default>
    </input>
    <input type="text" token="user" searchWhenChanged="false">
      <label>User Filter</label>
      <default>*</default>
    </input>
    <input type="text" token="action_filter" searchWhenChanged="false">
      <label>Action Filter</label>
      <default>*</default>
    </input>
  </fieldset>

  <!-- KPI Row -->
  <row>
    <panel>
      <title>Total Changes</title>
      <single>
        <search>
          <query>`aviatrix_audit` username=$user$
| search action=$action_filter$
| where "$result$"="*" OR result="$result$" OR (result!="Success" AND "$result$"="failure")
| stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="useThousandSeparators">1</option>
      </single>
    </panel>
    <panel>
      <title>Successful Operations</title>
      <single>
        <search>
          <query>`aviatrix_audit` username=$user$ result="Success"
| search action=$action_filter$
| stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">all</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53a051","0x53a051"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
        <drilldown>
          <set token="form.result">Success</set>
        </drilldown>
      </single>
    </panel>
    <panel>
      <title>Failed Operations</title>
      <single>
        <search>
          <query>`aviatrix_audit` username=$user$ result!="Success"
| search action=$action_filter$
| stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">all</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[0,5]</option>
        <option name="useColors">1</option>
        <drilldown>
          <set token="form.result">failure</set>
        </drilldown>
      </single>
    </panel>
    <panel>
      <title>Unique Users</title>
      <single>
        <search>
          <query>`aviatrix_audit` username=$user$
| search action=$action_filter$
| where "$result$"="*" OR result="$result$" OR (result!="Success" AND "$result$"="failure")
| stats dc(username)</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>

  <!-- Timeline -->
  <row>
    <panel>
      <title>Activity Over Time</title>
      <chart>
        <search>
          <query>`aviatrix_audit` username=$user$
| search action=$action_filter$
| where "$result$"="*" OR result="$result$" OR (result!="Success" AND "$result$"="failure")
| eval status=if(result="Success", "Success", "Failed")
| timechart count by status</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.fieldColors">{"Success": 0x53A051, "Failed": 0xDC4E41}</option>
        <option name="height">200</option>
      </chart>
    </panel>
  </row>

  <!-- User and Action Analysis -->
  <row>
    <panel>
      <title>Activity by User</title>
      <chart>
        <search>
          <query>`aviatrix_audit` username=$user$
| eval username=if(match(username, "^%\{"), "unknown", username)
| search action=$action_filter$
| where "$result$"="*" OR result="$result$" OR (result!="Success" AND "$result$"="failure")
| stats count by username
| sort - count
| head 10</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.legend.placement">none</option>
        <option name="height">250</option>
        <drilldown>
          <set token="form.user">$click.value$</set>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Action Types</title>
      <chart>
        <search>
          <query>`aviatrix_audit` username=$user$
| search action=$action_filter$
| where "$result$"="*" OR result="$result$" OR (result!="Success" AND "$result$"="failure")
| rex field=action "^(?&lt;action_type&gt;[^/]+)"
| stats count by action_type
| sort - count
| head 15</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="height">250</option>
        <drilldown>
          <set token="form.action_filter">*$click.value$*</set>
        </drilldown>
      </chart>
    </panel>
  </row>

  <!-- Policy Changes -->
  <row>
    <panel>
      <title>Policy/Security Changes</title>
      <table>
        <search>
          <query>`aviatrix_audit` username=$user$ (action="*microseg*" OR action="*policy*" OR action="*rule*" OR action="*firewall*")
| eval username=if(match(username, "^%\{"), "unknown", username)
| search action=$action_filter$
| where "$result$"="*" OR result="$result$" OR (result!="Success" AND "$result$"="failure")
| table _time, username, action, result, reason
| head 100
| rename username as User, action as Action, result as Result, reason as Details</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="drilldown">row</option>
        <option name="wrap">true</option>
        <format type="color" field="Result">
          <colorPalette type="map">{"Success": 0x53A051}</colorPalette>
        </format>
      </table>
    </panel>
  </row>

  <!-- Detailed Audit Log -->
  <row>
    <panel>
      <title>Audit Log Events</title>
      <table>
        <search>
          <query>`aviatrix_audit` username=$user$
| eval username=if(match(username, "^%\{"), "unknown", username)
| search action=$action_filter$
| where "$result$"="*" OR result="$result$" OR (result!="Success" AND "$result$"="failure")
| table _time, username, action, result, reason
| head 500
| rename username as User, action as Action, result as Result, reason as Details</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">row</option>
        <option name="wrap">true</option>
        <format type="color" field="Result">
          <colorPalette type="map">{"Success": 0x53A051, "201 CREATED": 0x53A051, "200 OK": 0x53A051}</colorPalette>
        </format>
        <drilldown>
          <link target="_blank">/app/$env:app$/search?q=search%20%60aviatrix_audit%60%20username%3D%22$row.User$%22%20action%3D%22$row.Action$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </table>
    </panel>
  </row>
</form>
