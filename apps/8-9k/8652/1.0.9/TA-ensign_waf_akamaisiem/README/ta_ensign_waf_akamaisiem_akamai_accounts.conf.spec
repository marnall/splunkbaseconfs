[<name>]
account_enabled = Enable or disable this Akamai account. Only enabled accounts can be selected when creating inputs. (Default: 1)
akamai_host = The Akamai EdgeGrid API hostname (e.g., akab-xxxxx.luna.akamaiapis.net). Do NOT include https://.
client_token = Akamai EdgeGrid Client Token from your API credential.
client_secret = Akamai EdgeGrid Client Secret from your API credential.
access_token = Akamai EdgeGrid Access Token from your API credential.
disable_ssl = Check to disable SSL certificate verification. When unchecked, you must provide a CA certificate path below. (Default: 0)
cert_location = Absolute path to the CA certificate file for SSL verification (e.g., /opt/splunk/etc/auth/ca_cert.pem).
