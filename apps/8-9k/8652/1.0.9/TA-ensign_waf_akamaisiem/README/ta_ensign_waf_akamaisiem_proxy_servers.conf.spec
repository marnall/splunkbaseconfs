[<name>]
proxy_enabled = Enable or disable this proxy configuration. (Default: 1)
proxy_type = The proxy protocol type. Supported values: http, https, socks4, socks5. (Default: http)
proxy_url = The proxy server hostname or IP address.
proxy_port = The proxy server port number.
proxy_username = Username for proxy authentication (optional).
proxy_password = Password for proxy authentication (optional).
proxy_rdns = Enable remote DNS resolution via the proxy server. (Default: 0)
