<dashboard version="1.1" theme="dark" stylesheet="vdconnect.css" script="vdconnect.js">
  <label>Identities</label>
  <description>Manage stored credentials for vector database access</description>
  <row>
    <panel>
      <html>
        <div class="vd-hdr">
          <div><h2>Identities</h2><p>Manage stored credentials for vector database access</p></div>
          <button class="vd-btn vd-btn-p" id="vd-id-new-btn">+ New Identity</button>
        </div>
        <div id="vd-id-list"></div>

        <div id="vd-id-ov" class="vd-ov">
          <div class="vd-md">
            <div class="vd-md-h">
              <h3 id="vd-id-title">New Identity</h3>
              <button class="vd-md-x vd-id-close">&#x2715;</button>
            </div>
            <div class="vd-md-b">
              <div class="vd-fg"><label class="vd-lb">Identity Name</label><input class="vd-in" id="vd-id-name" placeholder="e.g. prod_milvus_svc"/></div>
              <div class="vd-g2">
                <div class="vd-fg"><label class="vd-lb">Auth Type</label>
                  <select class="vd-sl" id="vd-id-auth">
                    <option value="api_key">API Key</option>
                    <option value="basic">Username / Password</option>
                    <option value="token">Bearer Token</option>
                  </select>
                </div>
                <div class="vd-fg"><label class="vd-lb">Database Type</label>
                  <select class="vd-sl" id="vd-id-db">
                    <option value="milvus">Milvus</option><option value="pinecone">Pinecone</option>
                    <option value="weaviate">Weaviate</option><option value="chromadb">ChromaDB</option>
                    <option value="qdrant">Qdrant</option><option value="pgvector">pgvector</option>
                  </select>
                </div>
              </div>
              <div id="vd-id-secret-wrap">
                <div class="vd-fg"><label class="vd-lb" id="vd-id-secret-label">API Key</label><input class="vd-in" id="vd-id-secret" type="password" placeholder="Paste key or token here"/></div>
              </div>
              <div id="vd-id-basic-wrap" style="display:none">
                <div class="vd-fg"><label class="vd-lb">Username</label><input class="vd-in" id="vd-id-user" placeholder="database_user"/></div>
                <div class="vd-fg"><label class="vd-lb">Password</label><input class="vd-in" id="vd-id-pass" type="password" placeholder="password"/></div>
              </div>
              <div class="vd-ft">
                <button class="vd-btn vd-btn-o vd-id-close">Cancel</button>
                <button class="vd-btn vd-btn-g" id="vd-id-save-btn">Create Identity</button>
              </div>
            </div>
          </div>
        </div>
        <div id="vd-toast" class="vd-toast"></div>
      </html>
    </panel>
  </row>
</dashboard>
