<dashboard version="1.1" theme="dark" stylesheet="vdconnect.css" script="vdconnect.js">
  <label>Connections</label>
  <description>Manage vector database connections</description>
  <row>
    <panel>
      <html>
        <div class="vd-hdr">
          <div><h2>Connections</h2><p>Manage vector database connections</p></div>
          <button class="vd-btn vd-btn-p" id="vd-conn-new-btn">+ New Connection</button>
        </div>
        <div id="vd-conn-list"></div>

        <div id="vd-conn-ov" class="vd-ov">
          <div class="vd-md">
            <div class="vd-md-h">
              <h3 id="vd-conn-title">New Connection</h3>
              <button class="vd-md-x vd-conn-close">&#x2715;</button>
            </div>
            <div class="vd-md-b">
              <input type="hidden" id="vd-conn-dbtype" value="milvus"/>
              <div class="vd-fg"><label class="vd-lb">Connection Name</label><input class="vd-in" id="vd-conn-name" placeholder="e.g. Prod Milvus Cluster"/></div>
              <div class="vd-fg"><label class="vd-lb">Database Type</label><div class="vd-dbg" id="vd-conn-dbgrid"></div></div>
              <div class="vd-g21">
                <div class="vd-fg"><label class="vd-lb">Host</label><input class="vd-in" id="vd-conn-host" placeholder="hostname or IP address"/></div>
                <div class="vd-fg"><label class="vd-lb">Port</label><input class="vd-in" id="vd-conn-port" value="19530"/></div>
              </div>
              <div class="vd-fg"><label class="vd-lb">Identity</label>
                <select class="vd-sl" id="vd-conn-identity"><option value="">Select identity</option></select>
                <div class="vd-hn">Select a stored identity from the Identities page</div>
              </div>
              <div class="vd-fg"><label class="vd-cbx"><input type="checkbox" id="vd-conn-ssl"/><span>Enable SSL/TLS encryption</span></label></div>
              <div class="vd-ft">
                <button class="vd-btn vd-btn-o vd-conn-close">Cancel</button>
                <button class="vd-btn vd-btn-g" id="vd-conn-save">Create Connection</button>
              </div>
            </div>
          </div>
        </div>
        <div id="vd-toast" class="vd-toast"></div>
      </html>
    </panel>
  </row>
</dashboard>
