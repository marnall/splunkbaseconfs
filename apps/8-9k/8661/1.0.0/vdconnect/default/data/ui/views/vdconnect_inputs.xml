<dashboard version="1.1" theme="dark" stylesheet="vdconnect.css" script="vdconnect.js">
  <label>Data Inputs</label>
  <description>Configure log collection from vector database collections</description>
  <row>
    <panel>
      <html>
        <div class="vd-hdr">
          <div><h2>Data Inputs</h2><p>Configure log collection from vector database collections</p></div>
          <button class="vd-btn vd-btn-p" id="vd-inp-new-btn">+ New Input</button>
        </div>
        <div id="vd-inp-list"></div>

        <div id="vd-inp-ov" class="vd-ov">
          <div class="vd-md" style="width:620px">
            <div class="vd-md-h">
              <h3 id="vd-inp-title">New Data Input</h3>
              <button class="vd-md-x vd-inp-close">&#x2715;</button>
            </div>
            <div class="vd-md-b">
              <div class="vd-fg"><label class="vd-lb">Input Name</label><input class="vd-in" id="vd-inp-name" placeholder="e.g. milvus_error_logs (no spaces)"/><div class="vd-hn">Unique name — use underscores, no spaces</div></div>
              <div class="vd-fg"><label class="vd-lb">Connection</label>
                <select class="vd-sl" id="vd-inp-conn"><option value="">Select connection</option></select>
                <div class="vd-hn">Select a connection from the Connections page</div>
              </div>
              <div class="vd-fg"><label class="vd-lb">Collection / Index / Class Name</label><input class="vd-in" id="vd-inp-coll" placeholder="e.g. error_logs"/><div class="vd-hn">Name of the collection in the vector database</div></div>
              <div class="vd-fg"><label class="vd-lb">Output Fields</label><input class="vd-in" id="vd-inp-fields" value="*" placeholder="log_text, timestamp, severity (* for all)"/></div>
              <div class="vd-g2">
                <div class="vd-fg"><label class="vd-lb">Collection Mode</label>
                  <select class="vd-sl" id="vd-inp-mode">
                    <option value="rising_column">Rising Column (incremental)</option>
                    <option value="batch">Batch (full dump)</option>
                    <option value="tail">Tail (continuous)</option>
                  </select>
                </div>
                <div class="vd-fg"><label class="vd-lb">Rising Column</label><input class="vd-in" id="vd-inp-rcol" value="timestamp" placeholder="timestamp or ID field"/></div>
              </div>
              <div class="vd-g3">
                <div class="vd-fg"><label class="vd-lb">Interval (seconds)</label><input class="vd-in" id="vd-inp-int" type="number" value="300"/></div>
                <div class="vd-fg"><label class="vd-lb">Splunk Index</label><input class="vd-in" id="vd-inp-idx" value="vdconnect_logs"/></div>
                <div class="vd-fg"><label class="vd-lb">Sourcetype</label><input class="vd-in" id="vd-inp-stype" value="vdconnect:milvus"/></div>
              </div>
              <div class="vd-fg"><label class="vd-lb">Max Rows per Cycle</label><input class="vd-in" id="vd-inp-max" type="number" value="10000"/></div>
              <div class="vd-ft">
                <button class="vd-btn vd-btn-o vd-inp-close">Cancel</button>
                <button class="vd-btn vd-btn-g" id="vd-inp-save">Create Input</button>
              </div>
            </div>
          </div>
        </div>
        <div id="vd-toast" class="vd-toast"></div>
      </html>
    </panel>
  </row>
</dashboard>
