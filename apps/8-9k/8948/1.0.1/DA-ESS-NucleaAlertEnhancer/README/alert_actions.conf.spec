

[enhance_alert_with_gemini_ai]
python.version = python3
param._cam = <json> Active response parameters.
param.model_name = <string> Model name.  It's default value is gemini-2.5-flash.
param.temperature = <list> Temperature.  It's default value is 2.
param.output_format = <list> Output format.  It's default value is md.
param.response_language = <list> Response language.  It's default value is PT_BR.
param.max_output_tokens = <string> Max output tokens. It's a required parameter. It's default value is 3000.
param.fields = <string> Fields.
param.prompt = <string> Prompt.
param.index = <string> Index. It's a required parameter. It's default value is summary.
param.sourcetype = <string> Sourcetype. It's a required parameter. It's default value is stash_hec.

