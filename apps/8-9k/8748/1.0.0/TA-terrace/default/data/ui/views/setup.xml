<form version="1.1" script="setup.js" hideEdit="true" hideAppBar="true" hideChrome="false">
  <label>Terrace Networks Add-on Setup</label>
  <row>
    <panel>
      <html>
        <div id="terrace-setup">
          <h2>Terrace Networks API Configuration</h2>
          <p>
            Enter your Terrace Networks API key to enable search commands, the
            modular input, and the adaptive response action.
          </p>
          <p>
            Generate an API key from the
            <a href="https://dashboard.terracenetworks.com" target="_blank" rel="noopener">Terrace Networks dashboard</a>
            under <strong>Settings &gt; Credentials</strong>. The key format is
            <code>KeyID.KeySecret</code> (two KSUIDs separated by a dot).
          </p>
          <form id="terrace-setup-form" autocomplete="off">
            <div class="control-group">
              <label class="control-label" for="terrace-api-key">API Key</label>
              <div class="controls">
                <input type="password" id="terrace-api-key" name="api_key"
                       placeholder="KeyID.KeySecret" autocomplete="off"
                       style="width: 420px;" required="required" />
              </div>
            </div>
            <div class="control-group">
              <div class="controls">
                <button type="submit" id="terrace-save-btn" class="btn btn-primary">Save</button>
                <span id="terrace-setup-status" style="margin-left: 12px;"></span>
              </div>
            </div>
          </form>
        </div>
      </html>
    </panel>
  </row>
</form>
