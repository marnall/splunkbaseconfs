<form version="1.1" theme="dark">
  <label>Data Dictionary</label>
  <search id="base1">
    <query>index IN $index$</query>
    <earliest>$time1.earliest$</earliest>
    <latest>$time1.latest$</latest>
  </search>
  <search base="base1" id="base2">
    <query>search sourcetype IN $sourcetype$</query>
  </search>
  <search base="base2" id="base3">
    <query>search source IN $source$</query>
  </search>
  <search base="base3" id="base4">
    <query>search host IN $host$ | table * </query>
  </search>
  <search base="base4" id="base5">
    <query>search dd IN $app$</query>
  </search>
  <fieldset submitButton="false">
    <input type="multiselect" token="app" searchWhenChanged="true">
      <label>App</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <delimiter>, </delimiter>
      <fieldForLabel>dd</fieldForLabel>
      <fieldForValue>dd</fieldForValue>
      <search>
        <query>index IN $index$, sourcetype IN $sourcetype$, source IN $source$, host IN $host$
| fields dd
| dedup dd
| table dd</query>
      </search>
    </input>
    <input type="multiselect" token="host" searchWhenChanged="true">
      <label>Host</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <delimiter>, </delimiter>
      <fieldForLabel>host</fieldForLabel>
      <fieldForValue>host</fieldForValue>
      <search base="base3">
        <query>
| fields host
| dedup host
| table host</query>
      </search>
    </input>
    <input type="multiselect" token="source" searchWhenChanged="true">
      <label>Source</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <delimiter>, </delimiter>
      <fieldForLabel>source</fieldForLabel>
      <fieldForValue>source</fieldForValue>
      <search base="base2">
        <query>
| fields source
| dedup source
| table source</query>
      </search>
    </input>
    <input type="multiselect" token="sourcetype" searchWhenChanged="true">
      <label>Sourcetype</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <delimiter>, </delimiter>
      <fieldForLabel>sourcetype</fieldForLabel>
      <fieldForValue>sourcetype</fieldForValue>
      <search base="base1">
        <query>
| fields sourcetype
| dedup sourcetype
| table sourcetype</query>
      </search>
    </input>
    <input type="multiselect" token="index" searchWhenChanged="true">
      <label>Index</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <delimiter>, </delimiter>
      <fieldForLabel>index</fieldForLabel>
      <fieldForValue>index</fieldForValue>
      <search>
        <query>index=* OR index=_*
| fields index
| dedup index
| table index</query>
        <earliest>$time1.earliest$</earliest>
        <latest>$time1.latest$</latest>
      </search>
    </input>
    <input type="time" token="time1">
      <label></label>
      <default>
        <earliest>-15m</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <table>
        <search id="table1">
          <query>index IN $index$, sourcetype IN $sourcetype$, source IN $source$, host IN $host$, dd IN $app$ | stats values(host) as host, values(source) as source, values(sourcetype) as sourcetype, values(index) as index by dd
| rename dd as app</query>
          <earliest>$time1.earliest$</earliest>
          <latest>$time1.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="refresh.display">progressbar</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
</form>