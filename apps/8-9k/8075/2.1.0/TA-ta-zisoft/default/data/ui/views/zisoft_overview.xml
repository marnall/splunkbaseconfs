<dashboard version="1.1">
  <label>Zisoft Security Awareness</label>
  <description>Monitor phishing simulations and user engagement.</description>
  
  <row>
    <panel>
      <chart>
        <search>
          <query>`zisoft_base_search` | stats count by action</query>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>

    <panel>
      <single>
        <search>
          <query>`zisoft_base_search` | stats count as total_events</query>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeColors">["#65a637", "#f7bc38", "#d93f3c"]</option>
        <option name="rangeValues">[100, 500]</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <search>
          <query>`zisoft_base_search` | table _time user_email src_ip action </query>
        </search>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
</dashboard>
