{
  "modelName": "Airia_Platform",
  "displayName": "Airia Platform Analytics",
  "description": "Comprehensive data model for Airia Platform AI operations, costs, and performance metrics",
  "objectSummary": {
    "Event-Based": 3,
    "Transaction-Based": 0,
    "Search-Based": 0
  },
  "objects": [
    {
      "objectName": "AI_Executions",
      "displayName": "AI Executions",
      "parentName": "BaseEvent",
      "comment": "All Airia Platform executions with success tracking",
      "fields": [
        {
          "fieldName": "_time",
          "owner": "BaseEvent",
          "type": "timestamp",
          "fieldSearch": "",
          "required": false,
          "multivalue": false,
          "hidden": false,
          "editable": true,
          "displayName": "_time",
          "comment": ""
        },
        {
          "fieldName": "execution_id",
          "owner": "AI_Executions",
          "type": "string",
          "fieldSearch": "execution_id=*",
          "required": false,
          "multivalue": false,
          "hidden": false,
          "editable": true,
          "displayName": "Execution ID",
          "comment": "Unique execution identifier"
        },
        {
          "fieldName": "Success",
          "owner": "AI_Executions",
          "type": "string",
          "fieldSearch": "Success=*",
          "required": false,
          "multivalue": false,
          "hidden": false,
          "editable": true,
          "displayName": "Success Status",
          "comment": "Boolean success indicator"
        },
        {
          "fieldName": "duration",
          "owner": "AI_Executions",
          "type": "string",
          "fieldSearch": "duration=*",
          "required": false,
          "multivalue": false,
          "hidden": false,
          "editable": true,
          "displayName": "Duration",
          "comment": "Total execution duration"
        },
        {
          "fieldName": "step_type",
          "owner": "AI_Executions",
          "type": "string",
          "fieldSearch": "step_type=*",
          "required": false,
          "multivalue": true,
          "hidden": false,
          "editable": true,
          "displayName": "Step Type",
          "comment": "Type of execution step"
        },
        {
          "fieldName": "completion_status",
          "owner": "AI_Executions",
          "type": "number",
          "fieldSearch": "completion_status=*",
          "required": false,
          "multivalue": false,
          "hidden": false,
          "editable": true,
          "displayName": "Completion Status",
          "comment": "Numeric completion status code"
        }
      ],
      "calculations": [
        {
          "calculationID": "duration_seconds",
          "calculationType": "Eval",
          "outputFields": [
            {
              "fieldName": "duration_seconds",
              "owner": "AI_Executions",
              "type": "number",
              "fieldSearch": "",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Duration (Seconds)",
              "comment": "Duration converted to seconds"
            }
          ],
          "expression": "tonumber(replace(duration, \"^00:00:([0-9]+\\\\.?[0-9]*).*\", \"\\\\1\"))",
          "comment": ""
        }
      ],
      "constraints": [
        {
          "search": "`airia_base`",
          "owner": "AI_Executions"
        }
      ],
      "children": [
        {
          "objectName": "AI_Operations",
          "displayName": "AI Model Operations",
          "parentName": "AI_Executions",
          "comment": "Executions involving AI model calls with cost and token tracking",
          "fields": [
            {
              "fieldName": "model_name",
              "owner": "AI_Operations",
              "type": "string",
              "fieldSearch": "model_name=*",
              "required": true,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Model Name",
              "comment": "AI model identifier"
            },
            {
              "fieldName": "model_display",
              "owner": "AI_Operations",
              "type": "string",
              "fieldSearch": "model_display=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Model Display Name",
              "comment": "Friendly model name"
            },
            {
              "fieldName": "provider",
              "owner": "AI_Operations",
              "type": "string",
              "fieldSearch": "provider=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Provider",
              "comment": "Model provider (Anthropic, Google, OpenAI)"
            },
            {
              "fieldName": "cost_numeric",
              "owner": "AI_Operations",
              "type": "number",
              "fieldSearch": "cost_numeric=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Cost",
              "comment": "Numeric cost value"
            },
            {
              "fieldName": "tokens_numeric",
              "owner": "AI_Operations",
              "type": "number",
              "fieldSearch": "tokens_numeric=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Total Tokens",
              "comment": "Total token count"
            },
            {
              "fieldName": "input_tokens_numeric",
              "owner": "AI_Operations",
              "type": "number",
              "fieldSearch": "input_tokens_numeric=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Input Tokens",
              "comment": "Input token count"
            },
            {
              "fieldName": "output_tokens_numeric",
              "owner": "AI_Operations",
              "type": "number",
              "fieldSearch": "output_tokens_numeric=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Output Tokens",
              "comment": "Output token count"
            },
            {
              "fieldName": "prompt_name",
              "owner": "AI_Operations",
              "type": "string",
              "fieldSearch": "prompt_name=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Prompt Name",
              "comment": "Prompt template name"
            },
            {
              "fieldName": "is_dlp_blocked",
              "owner": "AI_Operations",
              "type": "string",
              "fieldSearch": "is_dlp_blocked=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "DLP Blocked",
              "comment": "Whether request was blocked by DLP"
            }
          ],
          "calculations": [
            {
              "calculationID": "cost_per_token",
              "calculationType": "Eval",
              "outputFields": [
                {
                  "fieldName": "cost_per_token",
                  "owner": "AI_Operations",
                  "type": "number",
                  "fieldSearch": "",
                  "required": false,
                  "multivalue": false,
                  "hidden": false,
                  "editable": true,
                  "displayName": "Cost Per Token",
                  "comment": "Cost divided by tokens"
                }
              ],
              "expression": "if(tokens_numeric>0, cost_numeric/tokens_numeric, 0)",
              "comment": ""
            },
            {
              "calculationID": "provider_model",
              "calculationType": "Eval",
              "outputFields": [
                {
                  "fieldName": "provider_model",
                  "owner": "AI_Operations",
                  "type": "string",
                  "fieldSearch": "",
                  "required": false,
                  "multivalue": false,
                  "hidden": false,
                  "editable": true,
                  "displayName": "Provider - Model",
                  "comment": "Combined provider and model name"
                }
              ],
              "expression": "provider + \" - \" + model_display",
              "comment": ""
            }
          ],
          "constraints": [
            {
              "search": "model_name=* cost_numeric>=0",
              "owner": "AI_Operations"
            }
          ],
          "children": []
        },
        {
          "objectName": "DLP_Events",
          "displayName": "DLP Blocked Events",
          "parentName": "AI_Executions",
          "comment": "Events blocked by Data Loss Prevention policies",
          "fields": [
            {
              "fieldName": "ai_completion_status",
              "owner": "DLP_Events",
              "type": "number",
              "fieldSearch": "ai_completion_status=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "AI Completion Status",
              "comment": "AI operation completion status"
            },
            {
              "fieldName": "ai_completion_status_name",
              "owner": "DLP_Events",
              "type": "string",
              "fieldSearch": "ai_completion_status_name=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Status Name",
              "comment": "Human-readable status"
            },
            {
              "fieldName": "user_input",
              "owner": "DLP_Events",
              "type": "string",
              "fieldSearch": "user_input=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "User Input",
              "comment": "User's input that triggered DLP"
            },
            {
              "fieldName": "prompt_name",
              "owner": "DLP_Events",
              "type": "string",
              "fieldSearch": "prompt_name=*",
              "required": false,
              "multivalue": false,
              "hidden": false,
              "editable": true,
              "displayName": "Prompt Name",
              "comment": "Associated prompt template"
            }
          ],
          "calculations": [],
          "constraints": [
            {
              "search": "is_dlp_blocked=true",
              "owner": "DLP_Events"
            }
          ],
          "children": []
        }
      ]
    }
  ],
  "acceleration": {
    "enabled": true,
    "earliest_time": "-7d",
    "cron_schedule": "*/5 * * * *",
    "max_concurrent": 2,
    "backfill_time": "-7d",
    "max_time": 3600
  }
}
