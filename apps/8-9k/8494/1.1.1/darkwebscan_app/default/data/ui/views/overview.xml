<form version="1.1" theme="dark">
  <label>Overview</label>
  <description>Find out if your data is leaked on the dark web and see what cybercriminals can find out about your company in seconds.</description>
  <fieldset submitButton="false">
    <input type="dropdown" token="cid">
      <label>Select company</label>
      <fieldForLabel>companyName</fieldForLabel>
      <fieldForValue>companyId</fieldForValue>
      <search>
        <query>| darkwebscangetcompanies</query>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <viz type="darkwebscan_app.darkwebscan_osint_viz">
        <search>
          <query>| darkwebscanosint companyId=$cid$ | table countEmailAddresses,countSubdomains,industry,externalSecurityScore,domain,emailAddressPattern,companyId</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="drilldown">none</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="height">450</option>
      </viz>
    </panel>
    <panel>
      <title>Latest Leaked Credentials</title>
      <table>
        <search>
          <query>| darkwebscanfindcompromised companyId=$cid$ | eval Date=strftime(_time, "%Y-%m-%d") | table Date, domain</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">20</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Email Security</title>
      <viz type="darkwebscan_app.darkwebscan_emailsecurity_viz">
        <search>
          <query>| darkwebscanemailsecurity companyId=$cid$ | table warning,warningColor,summary,parts,spfRecord,dmarcRecord,emailHosts,companyId</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="drilldown">none</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="height">450</option>
      </viz>
    </panel>
    <panel>
      <title>WAF</title>
      <viz type="darkwebscan_app.darkwebscan_waf_viz">
        <search>
          <query>| darkwebscanwaf companyId=$cid$ | table warning,warningColor,summary,product,companyId</query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="drilldown">none</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="height">450</option>
      </viz>
    </panel>
  </row>
</form>