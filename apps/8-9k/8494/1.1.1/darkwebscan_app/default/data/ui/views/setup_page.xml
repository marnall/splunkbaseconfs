<dashboard isDashboard="false" version="1.1" script="javascript/setup_page.js" stylesheet="styles/setup_page.css">
  <label>Setup</label>
  
  <row>
    <panel>
      <html>
        <div id='dwsa_container'>
            <h3>Let's setup your darkwebscan.app</h3>
            <div>
                <div class="dwsa_already_configured_warning">
                  You have already configured this app. Please only provide new settings if you know what you are doing.
                </div>
                <div class='dwsa_setup_setting'>
                    <span>API Key</span><br />
                    <input type='text' id='apikey_input'></input>
                </div>

                <div class='dwsa_setup_setting'>
                    <span>Additional headers</span><br />
                    <textarea id="additional_headers_input" 
                      rows="4" 
                      cols="40"
                      placeholder="headerName:value, one header per line"></textarea>
                </div>

                <!--<div class='dwsa_setup_setting'>
                    <span>Use system-wide proxy for API communication</span><br />

                    <div class="dwsa_radio_selector">
                      <input type="radio" id="proxy_yes" name="dwsa_proxy" value="yes" />
                      <label for="proxy_yes">Yes</label>

                      <input type="radio" id="proxy_no" name="dwsa_proxy" value="no" checked="checked" />
                      <label for="proxy_yes">No</label>
                    </div>
                </div>-->
                <!-- Complete Setup button will call the completeSetup() function
                      within javascript/setup_page.js -->
                <button id='setup_button'>Complete Setup</button>
                <div class='success'>Configuration saved successfully, redirecting to app...</div>
                <div class='error'>Issue encountered during setup, details below:</div>
                <code id='error_details'></code>
            </div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
