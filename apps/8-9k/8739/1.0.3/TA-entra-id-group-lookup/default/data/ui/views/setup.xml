<form version="1.1" script="javascript/setup.js" stylesheet="styles/setup.css">
  <label>Microsoft Entra ID Group Lookup Setup</label>
  <fieldset submitButton="false"></fieldset>
  <row>
    <panel>
      <html>
        <div id="setup-container" class="entra-setup">
          <h2>Microsoft Graph credentials</h2>
          <p>Configure the Microsoft Entra app registration used by the external lookup. The client secret is written to Splunk's native <code>storage/passwords</code> endpoint.</p>
          <div class="setup-grid">
            <label for="tenant_id">Tenant ID</label>
            <input id="tenant_id" type="text" autocomplete="off" />

            <label for="client_id">Client ID</label>
            <input id="client_id" type="text" autocomplete="off" />

            <label for="client_secret">Client Secret</label>
            <input id="client_secret" type="password" autocomplete="new-password" placeholder="Leave blank to keep existing secret" />

            <label for="membership_type">Membership Type</label>
            <select id="membership_type">
              <option value="transitive">Transitive groups</option>
              <option value="direct">Direct groups only</option>
            </select>

            <label for="authority_host">Authority Host</label>
            <input id="authority_host" type="text" value="https://login.microsoftonline.com" />

            <label for="graph_host">Graph Host</label>
            <input id="graph_host" type="text" value="https://graph.microsoft.com" />
          </div>
          <div class="setup-actions">
            <button id="save_config" class="btn btn-primary" type="button">Save configuration</button>
            <span id="setup_status" role="status"></span>
          </div>
        </div>
      </html>
    </panel>
  </row>
</form>
