{"alert_action_builder": {"modular_alerts": [{"description": "Open a Request in Manage Engine", "largeIcon": "", "smallIcon": "", "label": "ManageEngine", "short_name": "open_a_request_in_manage_engine", "parameters": [{"format_type": "text", "required": true, "name": "manageengine_url", "label": "ManageEngine URL", "default_value": "yourdomain.com", "help_string": "", "type": "", "value": "genie.jiostar.com"}, {"format_type": "text", "required": true, "name": "subject", "label": "Subject", "default_value": "Splunk Citadel: $name$", "help_string": "", "type": "", "value": "Splunk Citadel: Test"}, {"format_type": "text", "required": true, "name": "description", "label": "Description", "default_value": "None", "help_string": "", "type": "", "value": "Test"}, {"format_type": "text", "required": true, "name": "category", "label": "Category", "default_value": "", "help_string": "", "type": "", "value": "SOC"}, {"format_type": "text", "required": true, "name": "subcategory", "label": "Subcategory", "default_value": "", "help_string": "", "type": "", "value": "Email"}, {"format_type": "text", "required": true, "name": "group", "label": "Group", "default_value": "", "help_string": "", "type": "", "value": "SOC"}, {"format_type": "text", "required": true, "name": "requester", "label": "Requester", "default_value": "", "help_string": "", "type": "", "value": "Splunk, Citadel (STAR-India)"}, {"format_type": "dropdownlist", "required": true, "name": "priority", "label": "Priority", "default_value": "low", "help_string": "", "possible_values": {"Critical": "critical", "High": "high", "Medium": "medium", "Low": "low"}, "type": "", "value": "medium"}, {"format_type": "dropdownlist", "required": true, "name": "request_type", "label": "Request Type", "default_value": "info", "help_string": "", "possible_values": {"Request For Information": "info", "Incident": "inc", "CR": "cr"}, "type": "", "value": "info"}], "code": "from urllib.error import URLError, HTTPError\nfrom urllib.parse import urlencode\nfrom urllib.request import urlopen, Request\nimport json\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the setup parameters and prints them to the log\n    auth_token = helper.get_global_setting(\"auth_token\")\n    helper.log_info(\"auth_token={}\".format(auth_token))\n\n    # The following example gets the alert action parameters and prints them to the log\n    manageengine_url = helper.get_param(\"manageengine_url\")\n    helper.log_info(\"manageengine_url={}\".format(manageengine_url))\n\n    subject = helper.get_param(\"subject\")\n    helper.log_info(\"subject={}\".format(subject))\n\n    description = helper.get_param(\"description\")\n    helper.log_info(\"description={}\".format(description))\n\n    category = helper.get_param(\"category\")\n    helper.log_info(\"category={}\".format(category))\n\n    subcategory = helper.get_param(\"subcategory\")\n    helper.log_info(\"subcategory={}\".format(subcategory))\n\n    group = helper.get_param(\"group\")\n    helper.log_info(\"group={}\".format(group))\n\n    requester = helper.get_param(\"requester\")\n    helper.log_info(\"requester={}\".format(requester))\n\n    priority = helper.get_param(\"priority\")\n    helper.log_info(\"priority={}\".format(priority))\n\n    request_type = helper.get_param(\"request_type\")\n    helper.log_info(\"request_type={}\".format(request_type))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action open_a_request_in_manage_engine started.\")\n    manageengine_url = helper.get_param(\"manageengine_url\")\n    api_url = f\"https://{manageengine_url}/api/v3/requests\"  # URL for the REST API\n    \n    api_key = helper.get_global_setting(\"auth_token\")  # Getting input\n    \n    alert_description = helper.get_param(\"description\")\n    alert_subject = helper.get_param(\"subject\")\n    alert_category = helper.get_param(\"category\")\n    alert_subcategory = helper.get_param(\"subcategory\")\n    alert_priority = helper.get_param(\"priority\")\n    request_type = helper.get_param(\"request_type\")\n    group = helper.get_param(\"group\")\n    \n    # Replacing alert_priority string values with numericals\n    priority_mapping = {\n        \"low\": \"4. Low\",\n        \"medium\": \"3. Medium\",\n        \"high\": \"2. High\",\n        \"critical\": \"1. Critical\"\n    }\n    \n    alert_p = priority_mapping.get(alert_priority, alert_priority)  # Default to the original if not found\n    \n    request_type_mapping = {\n        \"info\": \"Request For Information\",\n        \"inc\": \"Incident\",\n        \"cr\": \"CR\"\n    }\n    \n    req_type = request_type_mapping.get(request_type, request_type)  # Default to the original if not found\n    \n    # Headers\n    headers = {\n        \"Accept\": \"application/vnd.manageengine.sdp.v3+json\",\n        \"Content-Type\": \"application/x-www-form-urlencoded\",  # URL encoded data type\n        \"authtoken\": api_key\n    }\n    \n    # Payload with original format\n    input_data = {\n        \"request\": {\n            \"subject\": alert_subject,\n            \"description\": f\"<p>{alert_description}</p>\",\n            \"requester\": {\n                \"name\": \"Splunk, Citadel (STAR-India)\"\n            },\n            \"priority\": {\n                \"name\": alert_p\n            },\n            \"category\": {\n                \"name\": alert_category\n            },\n            \"mode\": {\n                \"name\": \"Splunk\"\n            },\n            \"request_type\": {\n                \"name\": req_type\n            },\n            \"group\": {\n                \"name\": group\n            },\n            \"subcategory\": {\n                \"name\": alert_subcategory\n            }\n        }\n    }\n    \n    json_data = json.dumps(input_data)  # Convert the dictionary to a JSON string\n\n    # Encode the JSON string for URL encoding\n    urlencoded_data = urlencode({\"input_data\": json_data})\n\n    # Log the urlencoded_data for debugging purposes\n    helper.log_info(f\"Payload: {urlencoded_data}\")\n\n    data = urlencoded_data.encode('utf-8')  # Encode the string to bytes\n    httprequest = Request(api_url, headers=headers, data=data, method=\"POST\")\n\n    try:\n        with urlopen(httprequest) as response:\n            response_data = response.read().decode('utf-8')\n            helper.log_info(f\"API response: {response_data}\")\n    except HTTPError as e:\n        error_message = e.read().decode()\n        helper.log_error(f\"HTTPError: {e.code}, {e.reason}, {error_message}\")\n    except URLError as e:\n        helper.log_error(f\"URLError: {e.reason}\")\n    except Exception as e:\n        helper.log_error(f\"Exception: {str(e)}\")\n\n    return 0\n", "uuid": "c93b45759ab2491a84ae074dce0ab571"}]}, "basic_builder": {"appname": "TA-manageengine-alert-action", "friendly_name": "ManageEngine Alert Action", "version": "1.0.0", "author": "Lognalytics Technology", "description": "ManageEngine Alert Action for Splunk is an alert action which creates Support ticket, when an alert is triggered in Splunk.", "theme": "#38b8bf", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 4}, "global_settings_builder": {"global_settings": {"customized_settings": [{"format_type": "password", "required": true, "name": "auth_token", "label": "Auth Token", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1763532698_31"}}