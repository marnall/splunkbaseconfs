
[open_a_request_in_manage_engine]
python.version = python3
param.manageengine_url = <string> ManageEngine URL. It's a required parameter. It's default value is yourdomain.com.
param.subject = <string> Subject. It's a required parameter. It's default value is Splunk Citadel: $name$.
param.description = <string> Description. It's a required parameter. It's default value is None.
param.category = <string> Category. It's a required parameter.
param.subcategory = <string> Subcategory. It's a required parameter.
param.group = <string> Group. It's a required parameter.
param.requester = <string> Requester. It's a required parameter.
param.priority = <list> Priority. It's a required parameter. It's default value is low.
param.request_type = <list> Request Type. It's a required parameter. It's default value is info.

