<form version="1.1">
  <label>Endpoint Information</label>

  <description>
	Endpoint device information synced from ClearPass.
  </description>

  <fieldset autoRun="True" submitButton="false">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>-7d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <row>
    <panel>
      <single>
        <search><query>sourcetype=Aruba:CPPM:MDM | dedup mac_address | stats count</query></search>
        <option name="drilldown">all</option>
        <option name="underLabel">Endpoints</option>
      </single>
    </panel>
    <panel>
      <chart>
        <title>Endpoint Records by Status</title>
        <search>
          <query>sourcetype=Aruba:CPPM:MDM | dedup mac_address | stats count by status</query>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Endpoint Device Sources</title>
        <search>
          <query>sourcetype=Aruba:CPPM:MDM | dedup mac_address | rename extracted_Source as source | stats count by source</query>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>Endpoint Records by Day</title>
        <search>
          <query>sourcetype=Aruba:CPPM:MDM | timechart dc(mac_address) as Devices span=1d</query>
          <earliest>$earliest$</earliest>
          <latest>$latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Endpoint Record Sources by Day</title>
        <search>
          <query>sourcetype=Aruba:CPPM:MDM | rename extracted_Source as source | timechart dc(mac_address) as Devices by source span=1d usenull=false</query>
          <earliest>$earliest$</earliest>
          <latest>$latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <!--panel>
      <table>
        <search><query>sourcetype=Aruba:CPPM:MDM | dedup mac_address | rename extracted_Source as source | table mac_address status source "*Status*"</query></search>
        <title>Endpoint Devices</title>
      </table>
    </panel-->
  </row>
</form>
