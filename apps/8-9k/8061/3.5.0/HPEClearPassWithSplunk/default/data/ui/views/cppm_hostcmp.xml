<form version="1.1">
  <label>Compare Servers</label>

  <fieldset autoRun="True" submitButton="false">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="checkbox" token="servers">
      <label>ClearPass Servers</label>
      <default>*</default>
      <delimiter> OR </delimiter>
      <valuePrefix>cphost=</valuePrefix>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <fieldForValue>cphost</fieldForValue>
      <fieldForLabel>cphost</fieldForLabel>
      <search>
        <query><![CDATA[eventtype=cppm | stats count by cphost]]></query>
      </search>
    </input>
  </fieldset>
  
  <row>
    <chart>
      <title>Logins by Server</title>
      <search><query>eventtype=cppm-authentication $servers$ | stats count by cphost</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Failures by Server</title>
      <search><query>eventtype=cppm-fail-authentication $servers$ | stats count by cphost</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Protocol by Server</title>
      <search><query>eventtype=cppm-pass-authentication $servers$ | eval host_req=req_source +" Auth on "+ cphost | stats count by host_req </query></search>
      <option name="charting.chart">bar</option>
    </chart>

    <table>
      <title>Services by Server</title>
      <search><query>eventtype=cppm-radius $servers$ | stats count by cphost,service_name </query></search>
      <option name="charting.chart">bar</option>
    </table>

  </row>
  <row>
    <table>
      <title>Health Status by Server</title>
      <search><query>eventtype=cppm-posture $servers$ | stats count by cphost, spt</query></search>
      <option name="charting.chart">pie</option>
    </table>

    <chart>
      <title>NAS Devices by Server</title>
      <search><query>eventtype=cppm-pass-authentication $servers$ | dedup nas_ip | stats count by cphost</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Unique MACs by Server</title>
      <search><query>eventtype=cppm-pass-authentication $servers$ | dedup mac_address | stats count by cphost</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Unique Users by Server</title>
      <search><query>eventtype=cppm-pass-authentication $servers$ | dedup user_name | stats count by cphost</query></search>
      <option name="charting.chart">pie</option>
    </chart>

  </row>


</form>