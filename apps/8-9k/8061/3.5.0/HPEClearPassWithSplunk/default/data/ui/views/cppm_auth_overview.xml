<form version="1.1">
  <label>Authentication Overview</label>

  <fieldset autoRun="True" submitButton="false">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>-24h</earliest>
        <latest>now</latest>
      </default>
    </input>
   <input type="dropdown" token="server">
      <label>ClearPass Server</label>
      <default>*</default>
      <choice value="*">All</choice>
      <fieldForValue>cphost</fieldForValue>
      <fieldForLabel>cphost</fieldForLabel>
      <search>
        <query><![CDATA[eventtype=cppm | stats count by cphost]]></query>
      </search>
    </input>
  </fieldset>

 <row>
    <single>
      <search><query> eventtype=cppm-authentication cphost=$server$ | stats count</query></search>
      <option name="underLabel">Total Auths</option>
    </single>
    <single>
      <search><query> eventtype=cppm-pass-authentication cphost=$server$ | stats count</query></search>
      <option name="underLabel">Total Successful Auths</option>
    </single>
    <single>
      <search><query> eventtype=cppm-pass-authentication cphost=$server$ | dedup user_name | stats count</query></search>
      <option name="underLabel">Total Users</option>
    </single>
    <single>
      <search><query> eventtype=cppm-pass-authentication cphost=$server$ | dedup mac_address | stats count</query></search>
      <option name="underLabel">Total Endpoints</option>
    </single>  
    <single>
      <search><query> eventtype=cppm-pass-authentication cphost=$server$ | dedup service_name | stats count</query></search>
      <option name="underLabel">Total Services</option>
    </single>
    <single>
      <search><query> eventtype=cppm-pass-authentication cphost=$server$ | dedup nas_ip | stats count</query></search>
      <option name="underLabel">NAS Used</option>
    </single>  
 </row>

  
  <row>
    <chart>
      <title>Incoming Auth Requests</title>
      <search><query>
       eventtype=cppm-authentication cphost=$server$ | timechart count 
      </query></search>
      <option name="charting.chart">area</option>
      <option name="charting.seriesColors">["0x4572a7"]</option>
    </chart>

    <chart>
      <title>Auth Failures</title>
      <search><query>
       eventtype=cppm-fail-authentication cphost=$server$ | timechart count 
      </query></search>
      <option name="charting.chart">area</option>
      <option name="charting.seriesColors">["0xaa4643"]</option>
    </chart>

    <chart>
      <title>Service Categorization</title>
      <search><query>
        eventtype="cppm-pass-authentication" service_name="*" cphost=$server$ |chart count by service_name
      </query></search>
      <option name="charting.chart">pie</option>
    </chart>
  </row>
   
  <row>
    <table>
      <title>Top 10 User Auths</title>
      <search><query>
       eventtype=cppm-pass-authentication cphost=$server$ | top limit=10 user_name
      </query></search>
    </table>

    <table>
      <title>Top 10 Services Used</title>
      <search><query>
       eventtype=cppm-pass-authentication cphost=$server$ | top limit=10 service_name 
      </query></search>
    </table>

    <table>
      <title>Top 10 Alerts Raised</title>
      <search><query>
       eventtype=cppm-alert cphost=$server$ | top limit=10 alert 
      </query></search>
    </table>

    <table>
      <title>Top 10 Incoming Client MAC</title>
      <search><query>
       eventtype=cppm-pass-authentication cphost=$server$ | top limit=10 mac_address 
      </query></search>
    </table>

    <table>
      <title>Top 10 IP Used</title>
      <search><query>
       eventtype=cppm-radius cphost=$server$ | top limit=10 ip_address 
      </query></search>
    </table>
  </row>

</form>