<form version="1.1">
  <label>Compare NAS Devices</label>

  <fieldset autoRun="true" submitButton="false">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="checkbox" token="nas_ips">
      <label>NAS Devices</label>
      <default>*</default>
      <delimiter> OR </delimiter>
      <valuePrefix>nas_ip=</valuePrefix>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <fieldForValue>nas_ip</fieldForValue>
      <fieldForLabel>nas_ip</fieldForLabel>
      <search>
        <query><![CDATA[eventtype=cppm | stats count by nas_ip]]></query>
      </search>
    </input>
  </fieldset>
  
  <row>
    <chart>
      <title>Logins by NAS Devices</title>
      <search><query>eventtype=cppm-authentication $nas_ips$ | stats count by nas_ip</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Failures by NAS Device</title>
      <search><query>eventtype=cppm-fail-authentication $nas_ips$ | stats count by nas_ip</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Protocol by NAS Device</title>
      <search><query>eventtype=cppm-pass-authentication $nas_ips$ | eval host_req=req_source +" Auth on "+ nas_ip | stats count by host_req</query></search>
      <option name="charting.chart">bar</option>
    </chart>

    <table>
      <title>Services by NAS Device</title>
      <search><query>eventtype=cppm-radius $nas_ips$ | stats count by nas_ip,service_name</query></search>
    </table>

  </row>
  <row>
    <table>
      <title>Auth Source by NAS Device</title>
      <search><query>eventtype=cppm-radius $nas_ips$ | stats count by nas_ip, auth_source</query></search>
    </table>

    <table>
      <title>Auth Method by NAS Device</title>
      <search><query>eventtype=cppm-radius $nas_ips$ | stats count by nas_ip, auth_method</query></search>
    </table>

    <chart>
      <title>NAS Port Type  by NAS Devices</title>
      <search><query>eventtype=cppm-radius $nas_ips$ | eval port_type_req=nas_port_type +":"+ nas_ip | stats count by port_type_req</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Service Type by NAS Devices</title>
      <search><query>eventtype=cppm-radius $nas_ips$ | eval service_type_req=service_type +":"+ nas_ip | stats count by service_type_req</query></search>
      <option name="charting.chart">pie</option>
    </chart>

  </row>

  <row>

    <chart>
      <title>ClearPass Servers by NAS Devices</title>
      <search><query>eventtype=cppm-pass-authentication $nas_ips$ | dedup cphost | stats count by nas_ip</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Unique MACs by NAS Device</title>
      <search><query>eventtype=cppm-pass-authentication $nas_ips$ | dedup mac_address | stats count by nas_ip</query></search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Unique Users by NAS Device</title>
      <search><query>eventtype=cppm-pass-authentication $nas_ips$ | dedup user_name | stats count by nas_ip</query></search>
      <option name="charting.chart">pie</option>
    </chart>
  </row>
  
</form>