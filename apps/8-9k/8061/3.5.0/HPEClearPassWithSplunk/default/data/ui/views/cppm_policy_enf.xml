<form version="1.1">
  <label>Policy Enforcement</label>

  <fieldset autoRun="True" submitButton="true">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>-24h</earliest>
        <latest>now</latest>
      </default>
    </input>
   <input type="dropdown" token="server">
      <label>ClearPass Server</label>
      <default>*</default>
      <choice value="*">All</choice>
      <fieldForValue>cphost</fieldForValue>
      <fieldForLabel>cphost</fieldForLabel>
      <search>
        <query><![CDATA[eventtype=cppm | stats count by cphost]]></query>
      </search>
    </input>
  </fieldset>

  <search><query>eventtype=cppm-posture cphost=$server$</query></search>

 <row>
    <single>
      <search><query> eventtype=cppm-posture cphost=$server$ | stats count </query></search>
      <option name="underLabel">Total Policy Enforcements</option>
    </single>
    <single>
      <search><query> eventtype=cppm-posture cphost=$server$ enf_profiles="*"| dedup enf_profiles | stats count</query></search>
      <option name="underLabel">Total Enforcement Profiles</option>
    </single>
    <single>
      <search><query> eventtype=cppm-posture cphost=$server$ roles="*" |dedup roles | stats count</query></search>
      <option name="underLabel">Total Roles</option>
    </single>
    <single>
      <search><query> eventtype=cppm-posture cphost=$server$ spt!="HEALTHY" | stats count</query></search>
      <option name="underLabel">UnHealthy Sessions</option>
    </single>
 </row>

  <row>
    <chart>
      <title>Top 10 Roles Assigned</title>
      <search><query> eventtype=cppm-posture cphost=$server$ | chart count by roles |sort by -count|head 10 </query></search>
      <option name="charting.chart">bar</option>
    </chart>

    <chart>
      <title>Top 10 Enforcement Profiles</title>
      <search><query> eventtype=cppm-posture cphost=$server$ | chart count by enf_profiles |sort by -count|head 10</query></search>
      <option name="charting.chart">bar</option>
    </chart>

    <chart>
      <title>Health Status</title>
      <search><query> eventtype=cppm-posture cphost=$server$ | chart count by spt </query></search>
      <option name="charting.chart">pie</option>
    </chart>
  </row>
   
  <row>
    <chart>
      <title>Policy Enforcements</title>
      <search><query> eventtype=cppm-posture cphost=$server$ |timechart usenull=f count</query></search>
      <option name="charting.chart">line</option>
    </chart>

  </row>
   
</form>