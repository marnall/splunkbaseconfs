<form version="1.1">
  <label>Insight Dashboard Server Compare</label>

  <fieldset autoRun="True" submitButton="false">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  
  <row>
    <chart>
      <title>Logins by Server</title>
      <search>
        <query>eventtype=cppm-authentication | stats count by cphost</query>
      </search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Failure by Server</title>
      <search>
        <query>eventtype=cppm-fail-authentication | stats count by cphost</query>
      </search>
      <option name="charting.chart">pie</option>
    </chart>
  </row>
  <row>
    <chart>
      <title>RADIUS Protocol by Server</title>
      <search>
        <query>eventtype=cppm-radius | stats count by cphost</query>
      </search>
      <option name="charting.chart">bar</option>
    </chart>

    <chart>
      <title>Employee Role Distribution</title>
      <search>
        <query>eventtype=cppm | where match(roles, "Employee") | stats count by cphost</query>
      </search>
      <option name="charting.chart">pie</option>
    </chart>

    <chart>
      <title>Healthy Percent Distribution</title>
      <search>
        <query>eventtype=cppm-pass-authentication | where spt="HEALTHY" | stats count by cphost</query>
      </search>
      <option name="charting.chart">pie</option>
    </chart>
  </row>
</form>