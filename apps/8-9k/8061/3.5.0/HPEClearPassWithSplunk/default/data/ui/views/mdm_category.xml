<form version="1.1">
  <label>MDM Category Charts</label>

  <description>
	MDM Details
  </description>

  <fieldset autoRun="True">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
   <input type="dropdown" token="ownership">
      <label>Ownership</label>
      <default>*</default>
      <choice value="*">All</choice>
      <choice value="Corporate">Corporate</choice>
      <choice value="Employee">Employee</choice>
    </input>
  </fieldset>


  <row>
    <chart>
      <search><query>sourcetype=Aruba:CPPM:MDM status=known | dedup mac_address | stats count by Ownership</query></search>
      <title>Distribution by Ownership</title>
      <option name="charting.chart">pie</option>
    </chart>
    <chart>
      <search><query>sourcetype=Aruba:CPPM:MDM status=known Ownership=$ownership$ | dedup macAddress | stats count by Compromised</query></search>
      <title>Compromised Devices</title>
      <option name="charting.chart">pie</option>
    </chart>
    <chart>
      <search><query>sourcetype=Aruba:CPPM:MDM status=known Ownership=$ownership$ | dedup macAddress | stats count by Encryption_Enabled</query></search>
      <title>Encryption Enabled</title>
      <option name="charting.chart">pie</option>
    </chart>
  </row>

  <row>
    <chart>
      <search><query>sourcetype=Aruba:CPPM:MDM  status=known Ownership=$ownership$ |dedup macAddress |stats count by Model</query></search>
      <title>Distribution by Model</title>
      <option name="charting.chart">pie</option>
    </chart>
    <chart>
      <search><query>sourcetype=Aruba:CPPM:MDM  status=known Ownership=$ownership$ |dedup macAddress |stats count by Manufacturer</query></search>
      <title>Distribution by Manufacturer</title>
      <option name="charting.chart">pie</option>
    </chart>
    <chart>
      <search><query>sourcetype=Aruba:CPPM:MDM  status=known Ownership=$ownership$ |dedup macAddress |stats count by OS_Version</query></search>
      <title>Distribution by OS Version</title>
      <option name="charting.chart">pie</option>
    </chart>
  </row>

</form>