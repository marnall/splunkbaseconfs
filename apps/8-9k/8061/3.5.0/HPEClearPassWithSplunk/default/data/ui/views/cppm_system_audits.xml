<form version="1.1">
  <label>Audit Records</label>

  <fieldset autoRun="True" submitButton="false">
    <input type="time" searchWhenChanged="true">
      <default>
        <earliest>@d</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="server">
      <label>ClearPass Server</label>
      <default>*</default>
      <choice value="*">All</choice>
      <fieldForValue>cphost</fieldForValue>
      <fieldForLabel>cphost</fieldForLabel>
      <search>
        <query><![CDATA[eventtype=cppm | stats count by cphost]]></query>
      </search>
    </input>
  </fieldset>
  
    <row> 
    <table>
      <title>Audit Records</title>
      <search><query>
 	eventtype=cppm CPPM_AUDIT_Record cphost=$server$ | fields _time, Source, Action, Category User |fields - _raw
      </query></search>
    </table>
    </row>

</form>
