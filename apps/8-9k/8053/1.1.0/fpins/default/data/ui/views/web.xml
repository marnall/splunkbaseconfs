<form theme="dark"
      version="1.1">
  <label>Web Analysis</label>
  <!-- First row of a single comment -->
  <!-- Second row of 2 panels -->
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="selectedtime" searchWhenChanged="true">
      <label>Time selector</label>
      <default>
        <earliest>-30d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="selectedaction" searchWhenChanged="true">
      <label>Action</label>
      <choice value="*">Any</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <fieldForLabel>action</fieldForLabel>
      <fieldForValue>action</fieldForValue>
      <search>
        <query>source=fpins ppcode=SSE action =* | stats count by action | table action</query>
        <earliest>-30d@h</earliest>
        <latest>now</latest>
      </search>
    </input>
  </fieldset>
  <row>

    <panel>
      <title>Top 10 Users with most Blocked URLs</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=SWG AND username=* AND action=Denied
| eval user = userfirstname." ".userlastname." (".username.")"
| top user
| fields user, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>

    <panel>
      <title>Top 10 Categories</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=SWG AND webbrowsingcategories=*
| top webbrowsingcategories
| fields webbrowsingcategories, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>

  </row>
  <row>

    <panel>
      <title>Top 10 Blocked URLs</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=SWG AND domain=* AND uripath=*
| eval url = domain.uripath
| top url
| fields url, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>

  </row>

  <row>

    <panel>
      <title>Top 10 Blocked URLs in WEB DLP</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=SWG [ search source=fpins ppcode=SSE type=DLP | fields requestid | format ] AND domain=* AND uripath=*
| eval url = domain.uripath
| top url
| fields url, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>

  </row>
  <row>

    <panel>
      <title>Top 10 Devices in WEB DLP</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=SWG [ search source=fpins ppcode=SSE type=DLP | fields requestid | format ] AND hostname=*
| top hostname
| fields hostname, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>

  </row>
  <row>

    <panel>
      <title>Top 10 Users in WEB DLP</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=SWG [ search source=fpins ppcode=SSE type=DLP | fields requestid | format ] AND username=* AND action=*
| eval user = userfirstname." ".userlastname." (".username.") / enterpriseappscore: ".enterpriseappscore
| top user
| fields user, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>

    <panel>
      <title>Top 10 Patterns in WEB DLP</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=DLP AND proxytype=SWG AND allpatterns=* AND action=* 
| top allpatterns
| fields allpatterns, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>

  </row>

</form>