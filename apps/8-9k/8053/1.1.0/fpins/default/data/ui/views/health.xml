  <!-- </row> -->
  <row>
    <panel>
      <title>Top 10 Activity per Application for API</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE logtype=APIHealth AND type=Health
| eval Activity = activity." per ".applicationname
| top Activity
| fields Activity, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Top 10 Response Code per Application for API</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE logtype=APIHealth AND type=Health
| eval "Response Code" = responsecode." per ".applicationname
| top "Response Code"
| fields "Response Code", count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Top 10 Activity per Application for SYSTEM</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE logtype=SystemHealth AND type=Health
| eval Activity = activity." per ".applicationname
| top Activity
| fields Activity, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Top 10 Response Code per Application for SYSTEM</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE logtype=SystemHealth AND type=Health
| eval "Response Code" = responsecode." per ".applicationname
| top "Response Code"
| fields "Response Code", count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Top 10 Users</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE (logtype=APIHealth OR logtype=SystemHealth) AND type=Health
| eval usr = userfullname." (".username.")"
| top usr
| fields usr, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
    <panel>
      <title>Top 10 Locations</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE logtype=SystemHealth AND type=Health
| top city
| fields city, count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
</form>