      version="1.1">
  <label>Health Analysis</label>
  <!-- First row of a single comment -->
  <!-- Second row of 2 panels -->
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="selectedtime" searchWhenChanged="true">
      <label>Time selector</label>
      <default>
        <earliest>-30d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
