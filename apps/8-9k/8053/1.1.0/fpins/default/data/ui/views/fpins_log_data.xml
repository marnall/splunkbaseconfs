  <row>
    <panel>
      <title>Total file events of type $selectedsourcetype$</title>
      <single>
        <search>
          <query>source=fpins ppcode=SSE type!=bitglass2 type=$selectedsourcetype$ AND (file=* OR filename=*)| search [| makeresults | eval filter=if("$selectedsourcetype$"="DLP","proxytype!=SWG","") | return $filter] | stats count</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="drilldown">all</option>
        <option name="refresh.display">progressbar</option>
      </single>
    </panel>
    <panel>
      <title>Maximum occurrence of one file per day - $selectedsourcetype$</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type!=bitglass2 type=$selectedsourcetype$ (file=* OR filename=*)
| search [| makeresults | eval filter=if("$selectedsourcetype$"="DLP","proxytype!=SWG","") | return $filter]
| bin _time span=1d
| eval FILE=if(isnotnull(filename), filename, file)
| stats count by FILE, _time
| eventstats MAX(count) AS COUNT by _time
| eval maxer=if(COUNT==count,"True","False")
| search maxer=True
| dedup _time
| timechart values(COUNT) AS OCCURRANCES span=1d</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Actions over time - $selectedsourcetype$</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=$selectedsourcetype$ AND (file=* OR filename=*) AND action=*
| search [| makeresults | eval filter=if("$selectedsourcetype$"="DLP","proxytype!=SWG","") | return $filter]
| timechart count by action</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.axisLabelsX.majorUnit">1</option>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisEnd</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top file sizes over time</title>
      <chart>
        <search>
          <query>source=fpins ppcode=SSE type=$selectedsourcetype$ AND filename=* AND (filesize=* OR bytesreceived=*)
| search [| makeresults | eval filter=if("$selectedsourcetype$"="DLP","proxytype!=SWG","") | return $filter]
| bin _time span=1d
| eval SIZE=coalesce(filesize, bytesreceived)
| stats MAX(SIZE) AS SIZE by _time</query>
          <earliest>$selectedtime.earliest$</earliest>
          <latest>$selectedtime.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
