{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "Send dashboard PDF", "short_name": "send_dashboard_pdf", "parameters": [{"format_type": "text", "required": true, "name": "app", "label": "App", "default_value": "search", "help_string": "App where dashboard lives", "type": "", "value": "search"}, {"format_type": "text", "required": true, "name": "dashboard_id", "label": "Dashboard", "default_value": "", "help_string": "Dashboard internal name", "type": "", "value": "test_send_dashboard_ds"}, {"format_type": "text", "required": true, "name": "owner", "label": "Owner", "default_value": "nobody", "help_string": "Dashboard owner", "type": "", "value": "nobody"}, {"format_type": "text", "required": true, "name": "token_map_json", "label": "Tokens", "default_value": "{}", "help_string": "Token and result field mapping in JSON format.\n{\"token1\":\"field1\",\"token2\":\"field2\"}", "type": "", "value": "{\"tk_app\":\"app\",\"tk_timepicker.earliest\":\"earliest\",\"tk_timepicker.latest\":\"latest\"}"}, {"format_type": "text", "required": true, "name": "mail_to", "label": "Mail to", "default_value": "", "help_string": "", "type": "", "value": "javier.oshiro@hctint.com"}, {"format_type": "text", "required": false, "name": "mail_cc", "label": "Mail cc", "default_value": "", "help_string": "", "type": "", "value": "splunkgroup@hctint.com"}, {"format_type": "text", "required": true, "name": "mail_subject", "label": "Mail subject", "default_value": "Dashboard PDF", "help_string": "", "type": "", "value": "Dashboard PDF: prueba"}, {"format_type": "text", "required": true, "name": "splunkd_url", "label": "Splunk URL", "default_value": "https://127.0.0.1:8089", "help_string": "Splunk server", "type": "", "value": "https://127.0.0.1:8089"}], "code": "# encoding = utf-8\nimport traceback\nimport json, re, time, uuid\nfrom time import sleep\nfrom urllib.parse import urlparse, urlencode\nimport splunklib.client as client\nimport splunklib.results as results\n\ndef create_service(helper):\n    # Creates the splunkd service using the current session\n    session_key = helper.session_key\n    base_url = helper.get_param(\"splunkd_url\")\n    u = urlparse(base_url)\n    return client.Service(token=session_key, scheme=u.scheme,\n                          host=u.hostname, port=u.port)\n\ndef get_event_fields(helper):\n    # Gets the token values from the alert results\n    events = helper.get_events()\n    res = []\n    for event in events:\n        res.append(event)\n    return res[0]\n\ndef build_tokens(helper):\n    # Parses the token values\n    row = get_event_fields(helper)\n    mapping = json.loads(helper.get_param(\"token_map_json\"))\n    \n    tokens = {}\n    for token, field in mapping.items():\n        if field in row:\n            tokens[token] = str(row[field])\n    return tokens\n\ndef get_dashboard_view(service, app, owner, dashboard):\n    # Gets the dashboard XML\n    job = service.jobs.oneshot(f\"| rest /servicesNS/{owner}/{app}/data/ui/views/{dashboard}\")\n    res = results.ResultsReader(job)\n    \n    event = []\n    for item in res:\n        event.append(item)\n\n    return str(event[0][\"eai:data\"])\n\ndef edit_dashboard_tokens(view_str, tokens):\n    # Replaces the token as hardcoded strings in the dashboard XML\n    def rep(m):\n        name = m.group(1)\n        return tokens.get(name, m.group(0))\n    return re.sub(r\"\\$(.+?)\\$\", rep, view_str)\n\ndef create_dashboard(service, app, owner, name, view_str):\n    # Creates a unique temporal dashboard\n    body = {\"name\": name, \"eai:data\": view_str, \"output_mode\":\"json\"}\n    res = service.request(f\"/servicesNS/{owner}/{app}/data/ui/views\",\n                    method=\"POST\",\n                    headers=[(\"Content-Type\",\"application/x-www-form-urlencoded\")],\n                    body=body)\n                    \n    if res.status >= 400:\n        raise RuntimeError(f\"POST view status {res.status}\")\n    return name\n\ndef delete_dashboard(service, app, owner, name):\n    # Deletes the temporal dashboard\n    service.request(f\"/servicesNS/{owner}/{app}/data/ui/views/{name}\", method=\"DELETE\")\n\ndef send_email(service, app, owner, tmp_dashboard, mail_to, mail_cc, mail_subject):\n    # Creates a job that runs a SPL with sendemail \n    body = {\"search\": f'| makeresults | sendemail to=\"{mail_to}\" cc=\"{mail_cc}\" subject=\"{mail_subject}\" sendpdf=true pdfview=\"{tmp_dashboard}\" papersize=\"a4\"'}\n    res = service.request(f\"/servicesNS/{owner}/{app}/search/jobs\",\n                    method=\"POST\",\n                    headers=[(\"Content-Type\",\"application/x-www-form-urlencoded\")],\n                    body=body)\n                    \n    if res.status >= 400:\n        raise RuntimeError(f\"POST view status {res.status}\")\n\ndef render_and_send(helper):\n    service = create_service(helper)\n    app = helper.get_param(\"app\")\n    owner = helper.get_param(\"owner\")\n    dashboard_id = helper.get_param(\"dashboard_id\")\n    if not dashboard_id:\n        raise ValueError(\"Missing parameter 'dashboard_id'.\")\n\n    tokens = build_tokens(helper)\n    \n    # Gets the current dashboard and edits the tokens\n    view_str = get_dashboard_view(service, app, owner, dashboard_id)\n    edited_dashboard = edit_dashboard_tokens(view_str, tokens)\n\n    # Creates the temporal XML dashboard with the hardcoded tokens\n    tmp_dashboard = f\"tmp_{dashboard_id}_{int(time.time())}_{uuid.uuid4().hex[:8]}\"\n    create_dashboard(service, app, owner, tmp_dashboard, edited_dashboard)\n    \n    try:\n        # Gets the email parameters\n        to_addr = helper.get_param(\"mail_to\")\n        cc_addr = helper.get_param(\"mail_cc\")\n        if not to_addr:\n            raise ValueError(\"Missing parameter 'mail_to'.\")\n        subject = helper.get_param(\"mail_subject\")\n\n        # Sends the email with the attached PDF\n        send_email(service, app, owner, tmp_dashboard, to_addr, cc_addr, subject)\n    finally:\n        # Waits for sendemail and then cleans the temps\n        sleep(10)\n        delete_dashboard(service, app, owner, tmp_dashboard)\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the alert action parameters and prints them to the log\n    app = helper.get_param(\"app\")\n    helper.log_info(\"app={}\".format(app))\n\n    dashboard_id = helper.get_param(\"dashboard_id\")\n    helper.log_info(\"dashboard_id={}\".format(dashboard_id))\n\n    owner = helper.get_param(\"owner\")\n    helper.log_info(\"owner={}\".format(owner))\n\n    token_map_json = helper.get_param(\"token_map_json\")\n    helper.log_info(\"token_map_json={}\".format(token_map_json))\n\n    mail_to = helper.get_param(\"mail_to\")\n    helper.log_info(\"mail_to={}\".format(mail_to))\n\n    mail_cc = helper.get_param(\"mail_cc\")\n    helper.log_info(\"mail_cc={}\".format(mail_cc))\n\n    mail_subject = helper.get_param(\"mail_subject\")\n    helper.log_info(\"mail_subject={}\".format(mail_subject))\n\n    splunkd_url = helper.get_param(\"splunkd_url\")\n    helper.log_info(\"splunkd_url={}\".format(splunkd_url))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    try:\n        render_and_send(helper)\n        return 0\n    except Exception as e:\n        helper.log_error(\"ERROR: {} | {}\".format(e, traceback.format_exc()))\n        return 1\n        ", "uuid": "1571d69f94754488805a5ccdecad04f5"}]}, "basic_builder": {"appname": "TA-send-dashboard-alert-action", "friendly_name": "Send dashboard alert action", "version": "1.0.2", "author": "HCT", "description": "Alert action that sends dashboard PDF over email", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 11}, "validation": {}}