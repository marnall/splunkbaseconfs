
[send_dashboard_pdf]
python.version = python3
param.app = <string> App. It's a required parameter. It's default value is search.
param.dashboard_id = <string> Dashboard. It's a required parameter.
param.owner = <string> Owner. It's a required parameter. It's default value is nobody.
param.token_map_json = <string> Tokens. It's a required parameter. It's default value is {}.
param.mail_to = <string> Mail to. It's a required parameter.
param.mail_cc = <string> Mail cc.
param.mail_subject = <string> Mail subject. It's a required parameter. It's default value is Dashboard PDF.
param.splunkd_url = <string> Splunk URL. It's a required parameter. It's default value is https://127.0.0.1:8089.

