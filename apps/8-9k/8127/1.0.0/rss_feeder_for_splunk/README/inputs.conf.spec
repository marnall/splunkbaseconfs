[rss_feeder://default]
rss_url = <string>   # required
history_size = <string>   # default: 500
verify_ssl = <string>     # default: true
user_agent = <string>     # default: RSSFeeder/1.0 (+Splunk Modular Input)
proxy = <string>        # default:
timeout = <string>        # default: 20
clean_summary = <string>  # default: true
include_raw_summary = <string>  # default: false
python.version = python3