<endpoint name="data/inputs/rss_feeder">
  <header>RSS Feeder Input</header>
  <elements>
    <element name="inputFields" type="fieldset">
      <view name="list"/>
      <view name="edit"/>
      <view name="create"/>
      <elements>

        <!-- Stanza name -->
        <element name="name" label="Name">
          <view name="list"/>
          <view name="create"/>
        </element>

        <!-- Custom args -->
        <element name="rss_url" type="textfield" label="RSS/Atom URL">
          <view name="create"/>
          <view name="edit"/>
          <!-- no default, must be provided -->
        </element>

        <element name="history_size" type="textfield" label="Checkpoint history size">
          <view name="create"/>
          <view name="edit"/>
          <default>500</default>
        </element>

        <element name="verify_ssl" type="textfield" label="Verify SSL (true/false)">
          <view name="create"/>
          <view name="edit"/>
          <default>true</default>
        </element>

        <element name="user_agent" type="textfield" label="HTTP User-Agent">
          <view name="create"/>
          <view name="edit"/>
          <default>RSSFeeder/1.0 (+Splunk Modular Input)</default>
        </element>

        <element name="proxy" type="textfield" label="HTTP proxy (host:port)">
          <view name="create"/>
          <view name="edit"/>
          <!-- no default -->
        </element>

        <element name="timeout" type="textfield" label="HTTP timeout (seconds)">
          <view name="create"/>
          <view name="edit"/>
          <default>20</default>
        </element>

        <element name="clean_summary" type="textfield" label="Strip HTML from summary (true/false)">
          <view name="create"/>
          <view name="edit"/>
          <default>true</default>
        </element>

        <element name="include_raw_summary" type="textfield" label="Include raw HTML summary (true/false)">
          <view name="create"/>
          <view name="edit"/>
          <default>false</default>
        </element>

        <!-- Reserved args -->
        <element name="interval" type="textfield" label="Interval (seconds)">
          <view name="create"/>
          <view name="edit"/>
          <default>300</default> <!-- example: poll every 5 minutes -->
        </element>

        <element name="index" type="select" label="Index">
          <view name="create"/>
          <view name="edit"/>
          <default>main</default>
          <key name="dynamicOptions" type="dict">
            <key name="keyName">title</key>
            <key name="keyValue">title</key>
            <key name="splunkSource">/data/indexes</key>
            <key name="splunkSourceParams" type="dict">
              <key name="search">'isInternal=false disabled=false'</key>
              <key name="count">-1</key>
            </key>
          </key>
        </element>

        <element name="sourcetype" type="textfield" label="Sourcetype">
          <view name="create"/>
          <view name="edit"/>
          <default>rss:feed</default>
        </element>

      </elements>
    </element>
  </elements>
</endpoint>
