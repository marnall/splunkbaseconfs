`custom_index` ( sourcetype="cube_cdr" OR sourcetype="cube_cdr_compact ")
| eval {type}_call_id = call_id
| eval {activity}_call_id = call_id
| eval external_party_number = case(type=="incoming",callingPartyNumber,type=="outgoing",calledPartyNumber,true(),null())
| eval internal_party_number = case(type=="incoming",calledPartyNumber,type=="outgoing",callingPartyNumber,true(),null())

| fields *_call_id call_id *_party_number

| stats dc(call_id) as total dc(*_call_id) as * dc(*_party_number) as *
| table  total incoming outgoing "two way call" "call forward all" "blind transfer" * internal external
