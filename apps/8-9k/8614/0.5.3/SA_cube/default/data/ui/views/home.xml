    <module name="Search">
      <param name="search"><![CDATA[
| rest /services/apps/local splunk_server=local
| search title="cisco_cdr"
| stats count last(title) as appContext
| fillnull appContext value="$sideview.currentApp$"
      ]]></param>

      <module name="ResultsValueSetter" layoutPanel="viewHeader">
        <param name="fields">appContext</param>



        <module name="Search">
          <param name="search"><![CDATA[
| rest /servicesNS/-/-/configs/conf-app splunk_server=local
| rename eai:acl.app as app
| search app="$sideview.currentApp$"
| stats last(build) as build last(version) as version last(description) as description
| appendcols [
  | rest /services/apps/local splunk_server=local
  | search title="cisco_cdr"
  | stats count
  | eval installation_state=if("$test_cisco_cdr_not_installed$_foo"=="1_foo" OR count=0,"cisco_cdr_not_installed","cisco_cdr_is_installed")
  | table installation_state
]
| appendcols [
  | inputlookup data_types
  | search app="$sideview.currentApp$"
  | stats count
  | eval data_type_enabled=if(count==0,0,1)
]
| eval installation_state=if(installation_state=="cisco_cdr_is_installed" AND data_type_enabled==0,"cisco_cdr_installed_but_data_table_not_enabled", installation_state)

          ]]></param>
