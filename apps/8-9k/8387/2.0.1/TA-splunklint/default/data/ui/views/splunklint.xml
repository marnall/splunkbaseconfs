<dashboard version="1.1" script="splunklint.js" stylesheet="splunklint.css">
  <label>SplunkLint - Advanced Dashboard Toolkit</label>
  <description>Validate, Analyze, Optimize, and Convert Splunk Dashboards</description>
  <row>
    <panel>
      <html>
        <div id="splunklint-app">
          <!-- Tab Navigation -->
          <div class="sl-tabs">
            <button class="sl-tab active" data-tab="validate" type="button">🔍 Validate</button>
            <button class="sl-tab" data-tab="analyze" type="button">📊 Complexity</button>
            <button class="sl-tab" data-tab="optimize" type="button">⚡ SPL Optimizer</button>
            <button class="sl-tab" data-tab="tokens" type="button">🔗 Token Flow</button>
            <button class="sl-tab" data-tab="convert" type="button">🔄 Convert</button>
            <button class="sl-tab" data-tab="compare" type="button">⚖️ Compare</button>
            <button class="sl-tab" data-tab="docs" type="button">📝 Generate Docs</button>
            <button class="sl-tab" data-tab="accessibility" type="button">♿ A11y Check</button>
          </div>

          <!-- Validate Tab -->
          <div class="sl-tab-content active" id="tab-validate">
            <div class="sl-toolbar">
              <div class="sl-dropdown" id="examplesDropdown">
                <button class="sl-dropdown-button" type="button">📋 Load Example</button>
                <div class="sl-dropdown-content" id="examplesContent"></div>
              </div>
              <button class="sl-btn sl-btn-secondary" id="formatBtn" type="button">✨ Format XML</button>
              <button class="sl-btn sl-btn-secondary" id="downloadBtn" disabled="disabled" type="button">⬇️ Download</button>
              <button class="sl-btn sl-btn-secondary" id="exportBtn" disabled="disabled" type="button">📊 Export Report</button>
            </div>
            
            <div class="sl-container">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Dashboard XML Input</span>
                  <span class="sl-shortcut-hint">Ctrl/Cmd + Enter to validate</span>
                </div>
                <div class="sl-panel-content">
                  <div class="sl-editor-wrapper">
                    <div class="sl-line-numbers" id="lineNumbers">1</div>
                    <textarea id="xmlInput" spellcheck="false" placeholder="Paste your Splunk dashboard XML here or load an example..."></textarea>
                  </div>
                  <div class="sl-button-group">
                    <button class="sl-btn sl-btn-primary" id="validateBtn" type="button">🔍 Validate XML</button>
                    <button class="sl-btn sl-btn-purple" id="analyzeSPLBtn" disabled="disabled" type="button">🔬 Analyze SPL</button>
                    <button class="sl-btn sl-btn-secondary" id="clearBtn" type="button">🗑️ Clear</button>
                  </div>
                </div>
              </div>
              
              <div class="sl-panel sl-results">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Validation Results</span>
                  <span id="statusBadge"></span>
                </div>
                <div class="sl-panel-content" id="resultsContent">
                  <p class="sl-placeholder-text">Paste your XML and click "Validate XML" to check for issues.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Complexity Analyzer Tab -->
          <div class="sl-tab-content" id="tab-analyze">
            <div class="sl-full-panel">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Dashboard Complexity Analyzer</span>
                </div>
                <div class="sl-panel-content">
                  <p class="sl-description">Analyze your dashboard's complexity, identify performance bottlenecks, and get optimization recommendations.</p>
                  <button class="sl-btn sl-btn-primary" id="analyzeComplexityBtn" type="button">📊 Analyze Complexity</button>
                  <div id="complexityResults" class="sl-results-area"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- SPL Optimizer Tab -->
          <div class="sl-tab-content" id="tab-optimize">
            <div class="sl-full-panel">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">SPL Query Optimizer</span>
                </div>
                <div class="sl-panel-content">
                  <p class="sl-description">Get optimized versions of your SPL queries with automatic rewrite suggestions.</p>
                  <div class="sl-input-group">
                    <label class="sl-label">Enter SPL Query:</label>
                    <textarea id="splInput" class="sl-textarea-small" placeholder="index=main sourcetype=access_combined | stats count by host | sort -count"></textarea>
                  </div>
                  <button class="sl-btn sl-btn-primary" id="optimizeSPLBtn" type="button">⚡ Optimize Query</button>
                  <button class="sl-btn sl-btn-secondary" id="extractFromXMLBtn" type="button">📥 Extract from XML</button>
                  <div id="optimizeResults" class="sl-results-area"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Token Flow Tab -->
          <div class="sl-tab-content" id="tab-tokens">
            <div class="sl-full-panel">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Token Flow Analyzer</span>
                </div>
                <div class="sl-panel-content">
                  <p class="sl-description">Visualize how tokens flow through your dashboard, identify dependencies and potential issues.</p>
                  <button class="sl-btn sl-btn-primary" id="analyzeTokensBtn" type="button">🔗 Analyze Token Flow</button>
                  <div id="tokenResults" class="sl-results-area"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Convert Tab -->
          <div class="sl-tab-content" id="tab-convert">
            <div class="sl-full-panel">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Dashboard Converter</span>
                </div>
                <div class="sl-panel-content">
                  <p class="sl-description">Convert Simple XML dashboards to Dashboard Studio JSON format for modern Splunk deployments.</p>
                  <div class="sl-convert-options">
                    <button class="sl-btn sl-btn-primary" id="convertToStudioBtn" type="button">🔄 Convert to Dashboard Studio</button>
                    <button class="sl-btn sl-btn-secondary" id="convertToSimpleBtn" type="button">📄 Minify XML</button>
                  </div>
                  <div id="convertResults" class="sl-results-area">
                    <div class="sl-code-output" id="convertOutput"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Compare Tab -->
          <div class="sl-tab-content" id="tab-compare">
            <div class="sl-full-panel">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Dashboard Diff Tool</span>
                </div>
                <div class="sl-panel-content">
                  <p class="sl-description">Compare two dashboard XMLs to see what changed between versions.</p>
                  <div class="sl-compare-container">
                    <div class="sl-compare-side">
                      <label class="sl-label">Original Dashboard:</label>
                      <textarea id="compareXml1" class="sl-textarea-medium" placeholder="Paste original dashboard XML..."></textarea>
                    </div>
                    <div class="sl-compare-side">
                      <label class="sl-label">Modified Dashboard:</label>
                      <textarea id="compareXml2" class="sl-textarea-medium" placeholder="Paste modified dashboard XML..."></textarea>
                    </div>
                  </div>
                  <button class="sl-btn sl-btn-primary" id="compareDashboardsBtn" type="button">⚖️ Compare Dashboards</button>
                  <div id="compareResults" class="sl-results-area"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Documentation Generator Tab -->
          <div class="sl-tab-content" id="tab-docs">
            <div class="sl-full-panel">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Documentation Generator</span>
                </div>
                <div class="sl-panel-content">
                  <p class="sl-description">Auto-generate comprehensive documentation from your dashboard XML.</p>
                  <div class="sl-doc-options">
                    <label class="sl-label">Output Format:</label>
                    <select id="docFormat" class="sl-select">
                      <option value="markdown">Markdown</option>
                      <option value="html">HTML</option>
                      <option value="confluence">Confluence Wiki</option>
                    </select>
                  </div>
                  <button class="sl-btn sl-btn-primary" id="generateDocsBtn" type="button">📝 Generate Documentation</button>
                  <button class="sl-btn sl-btn-secondary" id="copyDocsBtn" type="button" disabled="disabled">📋 Copy to Clipboard</button>
                  <div id="docsResults" class="sl-results-area">
                    <pre id="docsOutput" class="sl-docs-output"></pre>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Accessibility Tab -->
          <div class="sl-tab-content" id="tab-accessibility">
            <div class="sl-full-panel">
              <div class="sl-panel">
                <div class="sl-panel-header">
                  <span class="sl-panel-title">Accessibility Checker</span>
                </div>
                <div class="sl-panel-content">
                  <p class="sl-description">Check your dashboard for accessibility issues including color contrast, missing labels, and WCAG compliance.</p>
                  <button class="sl-btn sl-btn-primary" id="checkA11yBtn" type="button">♿ Check Accessibility</button>
                  <div id="a11yResults" class="sl-results-area"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Export Modal -->
          <div class="sl-modal" id="exportModal">
            <div class="sl-modal-content">
              <div class="sl-modal-header">
                <h3 class="sl-modal-title">Export Validation Report</h3>
                <button class="sl-modal-close" id="closeModal" type="button">×</button>
              </div>
              <div class="sl-modal-body">
                <div class="sl-export-option" data-format="json">
                  <div class="sl-export-option-title">JSON Format</div>
                  <div class="sl-export-option-desc">Machine-readable format for CI/CD integration</div>
                </div>
                <div class="sl-export-option" data-format="text">
                  <div class="sl-export-option-title">Text Report</div>
                  <div class="sl-export-option-desc">Human-readable format for documentation</div>
                </div>
                <div class="sl-export-option" data-format="html">
                  <div class="sl-export-option-title">HTML Report</div>
                  <div class="sl-export-option-desc">Styled report with syntax highlighting</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
