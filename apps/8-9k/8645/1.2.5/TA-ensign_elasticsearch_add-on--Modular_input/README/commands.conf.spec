[escheck_connection]
filename = <string> Python script filename for the connection check command. Default: escheck_connection.py.
chunked = <boolean> Whether the chunked protocol is used. Default: true.
python.version = <string> Python version. Valid values: python3. Default: python3.

[escheck_config]
filename = <string> Python script filename for the config check command. Default: escheck_config.py.
chunked = <boolean> Whether the chunked protocol is used. Default: true.
python.version = <string> Python version. Valid values: python3. Default: python3.

[escheck_indexes]
filename = <string> Python script filename for the index listing command. Default: escheck_indexes.py.
chunked = <boolean> Whether the chunked protocol is used. Default: true.
python.version = <string> Python version. Valid values: python3. Default: python3.
