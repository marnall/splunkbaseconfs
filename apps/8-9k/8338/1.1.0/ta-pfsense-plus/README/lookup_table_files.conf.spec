# lookup_table_files.conf.spec
# Specification for lookup table file definitions.

[<lookup_name>]
* filename = <string>
* description = <string>
* case_sensitive_match = <boolean>
* match_type = <string>
* min_matches = <integer>
* max_matches = <integer>
* output_default = <string>
* external_cmd = <string>
* external_cmd_timeout = <integer>
