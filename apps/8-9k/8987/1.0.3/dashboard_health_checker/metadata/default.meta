## Default object permissions for Dashboard Health Checker.
## Read for everyone, write for admin/power. Exported app-wide so the
## scheduled searches and KV lookups resolve in every app context.

[]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

[views]
export = system

[nav]
export = system

[savedsearches]
export = system

[macros]
export = system

[transforms]
export = system

[props]
export = system

[eventtypes]
export = system

## KV store collections
[collections/dashboard_health_inventory]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

[collections/dashboard_health_findings]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

[collections/dashboard_health_scores]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

## KV lookup transforms
[transforms/dashboard_health_inventory]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

[transforms/dashboard_health_findings]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

[transforms/dashboard_health_scores]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system
