<dashboard version="1.1" theme="dark">
  <label>Workflow &amp; JIT</label>
  <description>Access Requests, Approvals, JIT Duration Tracking</description>
  <fieldset submitButton="false">
    <input type="time" token="time_range" searchWhenChanged="true"><label>Time Range</label><default><earliest>-7d@d</earliest><latest>now</latest></default></input>
  </fieldset>
  <row>
    <panel><single><title>Total Requests</title><search><query>`asger_workflow` action="request" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search></single></panel>
    <panel><single><title>Approved</title><search><query>`asger_workflow` device_action="allow" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="colorMode">block</option><option name="rangeColors">["#53a051","#53a051"]</option><option name="useColors">true</option></single></panel>
    <panel><single><title>Denied</title><search><query>`asger_workflow` device_action="deny" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="colorMode">block</option><option name="rangeColors">["#dc4e41","#dc4e41"]</option><option name="useColors">true</option></single></panel>
    <panel><single><title>Expired</title><search><query>`asger_workflow` action="expire" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="colorMode">block</option><option name="rangeColors">["#ed8440","#ed8440"]</option><option name="useColors">true</option></single></panel>
  </row>
  <row>
    <panel><chart><title>Workflow Outcomes Over Time</title><search><query>`asger_workflow` | timechart span=1d count by device_action</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="charting.chart">column</option><option name="charting.chart.stackMode">stacked</option></chart></panel>
  </row>
  <row>
    <panel><table><title>Workflow Request Log</title><search><query>`asger_workflow` | table _time, user, privileged_account, app, action, device_action, outcome, reason, session_id | sort -_time</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="count">25</option></table></panel>
  </row>
</dashboard>
