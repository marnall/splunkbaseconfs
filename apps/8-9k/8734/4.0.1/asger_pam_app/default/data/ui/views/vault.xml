<dashboard version="1.1" theme="dark">
  <label>Vault</label>
  <description>Credential Access, Rotation, Checkout Tracking</description>
  <fieldset submitButton="false">
    <input type="time" token="time_range" searchWhenChanged="true"><label>Time Range</label><default><earliest>-24h@h</earliest><latest>now</latest></default></input>
  </fieldset>
  <row>
    <panel><single><title>Credential Retrievals</title><search><query>`asger_vault` (action="retrieve" OR action="copy") | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="colorMode">block</option><option name="rangeColors">["#f8be34","#f8be34"]</option><option name="useColors">true</option></single></panel>
    <panel><single><title>Password Rotations</title><search><query>`asger_vault` action="rotate" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search></single></panel>
    <panel><single><title>Active Checkouts</title><search><query>`asger_vault` action="checkout" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search></single></panel>
    <panel><single><title>Rotation Failures</title><search><query>`asger_vault` action="rotate" outcome="failure" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="colorMode">block</option><option name="rangeColors">["#dc4e41","#dc4e41"]</option><option name="useColors">true</option></single></panel>
  </row>
  <row>
    <panel><chart><title>Vault Access Over Time</title><search><query>`asger_vault` | timechart span=1h count by action</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="charting.chart">area</option><option name="charting.chart.stackMode">stacked</option></chart></panel>
    <panel><chart><title>Top Users by Vault Access</title><search><query>`asger_vault` | top limit=10 user</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="charting.chart">bar</option></chart></panel>
  </row>
  <row>
    <panel><table><title>Vault Activity Log</title><search><query>`asger_vault` | table _time, user, action, app, resource_name, privileged_account, outcome, reason, session_id | sort -_time</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="count">25</option></table></panel>
  </row>
</dashboard>
