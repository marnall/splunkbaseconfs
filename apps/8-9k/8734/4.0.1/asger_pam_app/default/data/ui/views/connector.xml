<dashboard version="1.1" theme="dark">
  <label>Connector (ZTNA)</label>
  <description>External Access, Posture Compliance, JIT Authorization</description>
  <fieldset submitButton="false">
    <input type="time" token="time_range" searchWhenChanged="true"><label>Time Range</label><default><earliest>-24h@h</earliest><latest>now</latest></default></input>
  </fieldset>
  <row>
    <panel><single><title>Authorized Sessions</title><search><query>`asger_events` audit_type="connector" device_action="allow" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="colorMode">block</option><option name="rangeColors">["#53a051","#53a051"]</option><option name="useColors">true</option></single></panel>
    <panel><single><title>Denied Access</title><search><query>`asger_events` audit_type="connector" device_action="deny" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="colorMode">block</option><option name="rangeColors">["#dc4e41","#dc4e41"]</option><option name="useColors">true</option></single></panel>
    <panel><single><title>Posture Checks</title><search><query>`asger_events` audit_type="connector" action="posture_check" | stats count</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search></single></panel>
    <panel><single><title>Avg Compliance Score</title><search><query>`asger_events` audit_type="connector" action="posture_check" | rex field=reason "score=(?&lt;score_val&gt;\d+)" | stats avg(score_val) as avg_score | eval avg_score=round(avg_score,1)</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search></single></panel>
  </row>
  <row>
    <panel><chart><title>Connector Activity Over Time</title><search><query>`asger_events` audit_type="connector" | timechart span=1h count by device_action</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="charting.chart">area</option><option name="charting.chart.stackMode">stacked</option></chart></panel>
  </row>
  <row>
    <panel><table><title>Connector Event Log</title><search><query>`asger_events` audit_type="connector" | table _time, user, protocol, target_host, action, device_action, outcome, reason | sort -_time</query><earliest>$time_range.earliest$</earliest><latest>$time_range.latest$</latest></search><option name="count">25</option></table></panel>
  </row>
</dashboard>
