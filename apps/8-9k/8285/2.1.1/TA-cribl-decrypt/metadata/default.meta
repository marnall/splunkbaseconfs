
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = system

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[commands/cribldecrypt]
access = read : [ * ], write : [ * ]
export = system

[commands/cribldecryptv2]
access = read : [ * ], write : [ * ]
export = system
