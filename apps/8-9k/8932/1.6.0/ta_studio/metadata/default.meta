######################################################
# TA Studio — default permissions
######################################################

[]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

# Restrict write access to the restmap configuration itself (not the API
# calls — those are governed by restmap.conf capability.* stanzas).
[restmap/ta_studio_api]
access = read : [ * ], write : [ admin, sc_admin ]
export = system
