#
# Metadata file for TA-nucleus-logs
# Technology Add-on for ingesting Nucleus Security audit logs into Splunk
#
# This file controls permissions and export settings for objects in this app.
# For Technology Add-ons, objects are typically exported to 'system' to be
# available to all apps.
#

# Set access controls on the app containing this metadata file.
# All users can read the app's contents, only admin can write/modify
[]
access = read : [ * ], write : [ admin ]
export = system

# Input configurations
[inputs]
access = read : [ * ], write : [ admin ]
export = system

# Props configurations (field extractions, source type definitions)
[props]
access = read : [ * ], write : [ admin ]
export = system

# Transforms configurations (field transformations, lookups)
[transforms]
access = read : [ * ], write : [ admin ]
export = system

# Event types
[eventtypes]
access = read : [ * ], write : [ admin ]
export = system

# Tags
[tags]
access = read : [ * ], write : [ admin ]
export = system

# Saved searches
[savedsearches]
access = read : [ * ], write : [ admin ]
export = system

# Views and dashboards
[views]
access = read : [ * ], write : [ admin ]
export = system

# Lookups
[lookups]
access = read : [ * ], write : [ admin ]
export = system

# Field aliases
[fieldaliases]
access = read : [ * ], write : [ admin ]
export = system

# Field extractions
[extractions]
access = read : [ * ], write : [ admin ]
export = system

