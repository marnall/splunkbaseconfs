{"basic_builder": {"appname": "TA-bloodhound-enterprise", "friendly_name": "BloodHound Enterprise", "version": "1.1.0", "author": "BloodHound Enterprise", "description": "", "theme": "#ffffff", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.0", "tab_build_no": "0", "build_no": 51}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "attack_paths", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "attack_paths", "title": "Attack Paths", "description": "", "type": "customized", "parameters": [{"name": "bloodhound_account", "label": "BloodHound Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "bloodhound_account", "title": "BloodHound Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import json\nfrom rest_client import header_generator, fetch_data \n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    # try:\n    #     return True\n    #     opt_bloodhound_account = definition.parameters.get('bloodhound_account',None)\n    #     method = 'GET'\n    #     uri = '/api/v2/available-domains'\n        \n    #     if opt_bloodhound_account :\n    #         token_key = opt_bloodhound_account.get('token_key', None)\n    #         token_id = opt_bloodhound_account.get('token_id', None)\n    #         domain_name = opt_bloodhound_account.get('domain_name', None)\n        \n    #     if token_key and token_id and domain_name:\n    #         headers = header_generator( token_id, token_key, method, uri)\n    #         r_domains = fetch_data(helper, ew, headers, domain_name, uri)\n        \n    #         if r_domains:\n    #             return True\n    #         else :\n    #             return False \n    #     else:\n    #         return False\n    # except Exception as e:\n    #     raise Exception(f'{str(e)')\n    pass\n        \ndef collect_events(helper, ew):\n    try:\n        opt_bloodhound_account = helper.get_arg('bloodhound_account')\n        method = 'GET'\n        uri = '/api/v2/available-domains'\n        token_key = opt_bloodhound_account['token_key']\n        token_id = opt_bloodhound_account['token_id']\n        domain_name = opt_bloodhound_account['domain_name']\n\n        #Get Domains\n        headers = header_generator( token_id, token_key, method, uri)\n        r_domains = fetch_data(helper, ew, headers, domain_name, uri)\n        available_domains = [item[\"id\"] for item in r_domains[\"data\"]]\n\n        #find_types for domain\n        available_types = dict()\n        for domain in available_domains:\n            uri = f\"/api/v2/domains/{domain}/available-types\"\n            headers_domain = header_generator(token_id, token_key, method, uri)\n            r_availtypes = fetch_data(helper, ew, headers_domain, domain_name, uri)\n            available_types[domain] = r_availtypes[\"data\"]\n\n        sourcetype = \"BHE:attack_paths\"\n\n        # find_attack_paths\n        for dom, avail_types in available_types.items():\n            for type in avail_types:\n                uri = f\"/api/v2/domains/{dom}/details?finding={type}\"\n                headers_path = header_generator(token_id, token_key, method, uri)\n                r_attackpaths = fetch_data(helper, ew, headers_path, domain_name, uri)\n                attack_paths = r_attackpaths[\"data\"]\n\n                for item in attack_paths:\n                    event = helper.new_event(json.dumps(item), time=None, host=None, index=None, source=None, sourcetype=sourcetype, done=True, unbroken=True)\n                    ew.write_event(event)\n    except Exception as e:\n        sourcetype = \"BHE:error\"\n        data = str(e)\n        event = helper.new_event(source=None, index=\"main\", sourcetype=sourcetype, data=data)\n        ew.write_event(event)\n", "customized_options": [{"name": "bloodhound_account", "value": ""}], "uuid": "1cce7aa67f4c47ebaf23673acbb92df9", "sample_count": 0}, {"index": "default", "sourcetype": "posture_statistics", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "posture_statistics", "title": "Posture_Statistics", "description": "", "type": "customized", "parameters": [{"name": "bloodhound_account", "label": "BloodHound Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "bloodhound_account", "title": "BloodHound Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import json \nfrom rest_client import header_generator, fetch_data\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    # opt_bloodhound_account = helper.get_arg('bloodhound_account')\n    # method = 'GET'\n    # uri = '/api/v2/posture-stats'\n    # token_key = opt_bloodhound_account['token_key']\n    # token_id = opt_bloodhound_account['token_id']\n    # domain_name = opt_bloodhound_account['domain_name']\n    # headers = header_generator(token_id,token_key, method, uri)\n    # r_json = fetch_data(helper, ew, headers, domain_name, uri)\n\n    # if r_json:\n    #     return True\n    # else:\n    #     return False\n    pass\n\ndef collect_events(helper, ew):\n    try:\n        opt_bloodhound_account = helper.get_arg('bloodhound_account')\n        method = 'GET'\n        uri = '/api/v2/posture-stats'\n        token_key = opt_bloodhound_account['token_key']\n        token_id = opt_bloodhound_account['token_id']\n        domain_name = opt_bloodhound_account['domain_name']\n        \n        headers = header_generator(token_id,token_key, method, uri)\n        r_json = fetch_data(helper, ew, headers, domain_name, uri)\n        postureStats = r_json[\"data\"]\n        \n        sourcetype = \"BHE:Posture_stats\"\n        for item in postureStats:\n            event = helper.new_event(json.dumps(item), time=None, host=None, index=helper.get_output_index(), source=None, sourcetype=sourcetype, done=True, unbroken=True)\n            ew.write_event(event)\n    except Exception as e:\n        sourcetype = \"BHE:error\"\n        data = str(e)\n        event = helper.new_event(source=None, index=\"main\", sourcetype=sourcetype, data=data)", "customized_options": [{"name": "bloodhound_account", "value": ""}], "uuid": "996587fe2a644936ac714f9a7f9e519b", "sample_count": 0}, {"index": "default", "sourcetype": "audit_logs", "interval": "900", "use_external_validation": true, "streaming_mode_xml": true, "name": "audit_logs", "title": "Audit Logs", "description": "", "type": "customized", "parameters": [{"required": true, "name": "bloodhound_account", "label": "BloodHound Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": ""}, {"required": false, "name": "historical_polling_days", "label": "Historical Polling Days", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "bloodhound_account", "title": "BloodHound Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "historical_polling_days", "title": "Historical Polling Days", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "import time\nimport json \nimport re \n\nfrom rest_client import save_state, load_state, header_generator, fetch_data\nfrom splunk.appserver.mrsparkle.lib.util import make_splunkhome_path\n_APP_NAME = 'TA-bloodhound-enterprise'\n\nlog_location = make_splunkhome_path(['var', 'log', 'splunk', _APP_NAME])\n\ndef validate_input(helper, definition):\n    # opt_bloodhound_account = helper.get_arg('bloodhound_account')\n    # method = 'GET'\n    # token_key = opt_bloodhound_account['token_key']\n    # token_id = opt_bloodhound_account['token_id']\n    # domain_name = opt_bloodhound_account['domain_name']\n    # uri = f\"/api/v2/audit?limit=0\"\n    # headers = header_generator(token_id, token_key, method, uri)\n    # r_json = fetch_data(helper, ew, headers, domain_name, uri)\n\n    # if r_json:\n    #     return True\n    # else :\n    #     return False\n    pass\n\n\ndef convert_to_rfc(days: int) -> str:\n    current_time = time.time()\n    start_time = current_time - days * 24 * 3600\n    result = time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime(start_time))\n    return result\n\ndef extract_domain_name(domain: str) -> str:\n    pattern = r'https?://([a-zA-Z0-9.-]+)'\n    match = re.search(pattern,domain)\n    return match.group(1)\n\ndef collect_events(helper, ew):\n    try:\n        opt_bloodhound_account = helper.get_arg('bloodhound_account')\n        if (helper.get_arg('historical_polling_days')) != None:\n            days = int(helper.get_arg('historical_polling_days'))\n        else :\n            days = 0\n\n        after = convert_to_rfc(days)\n        method = 'GET'\n        token_key = opt_bloodhound_account['token_key']\n        token_id = opt_bloodhound_account['token_id']\n        domain_name = opt_bloodhound_account['domain_name']\n        uname = extract_domain_name(domain_name)\n        state = load_state(log_location, uname)\n        if state: \n            if \"last_event_timestamp\" in state:\n                earliest_timestamp = state[\"last_event_timestamp\"]\n            if \"first_event_timestamp\" in state:\n                latest_timestamp = state[\"first_event_timestamp\"]\n        else :\n            earliest_timestamp = convert_to_rfc(0)\n            latest_timestamp = \"1970-01-01T00:00:00Z\"\n\n        sourcetype = \"BHE:audit_logs\"\n        skip: int = 0\n\n        while True:\n            if days != 0:\n                uri = f\"/api/v2/audit?after={after}&skip={skip}\"\n            else :\n                uri = f\"/api/v2/audit?skip={skip}\"\n            headers = header_generator(token_id, token_key, method, uri)\n            r_json = fetch_data(helper, ew, headers, domain_name, uri)\n            audit_logs = r_json[\"data\"][\"logs\"]\n            skip = skip + len(audit_logs)\n            if len(audit_logs) == 0:\n                break\n\n            for item in audit_logs:\n                created_at = item[\"created_at\"]\n                if created_at < earliest_timestamp or created_at > latest_timestamp:\n                    event_data = json.dumps(item)\n                    event = helper.new_event(\n                        event_data, time=None, host=None, index=helper.get_output_index(),\n                        source=None, sourcetype=sourcetype, done=True, unbroken=True\n                    )\n                    ew.write_event(event)\n                \n                if created_at < earliest_timestamp:\n                    earliest_timestamp = created_at\n                if created_at > latest_timestamp:\n                    latest_timestamp = created_at\n\n            save_state({\n                \"first_event_timestamp\": latest_timestamp,\n                \"last_event_timestamp\" : earliest_timestamp\n            },log_location,uname)\n\n        state = {\n            \"first_event_timestamp\": latest_timestamp,\n            \"last_event_timestamp\": earliest_timestamp\n        }\n        save_state(state, log_location, uname)\n    \n    except Exception as e:\n        sourcetype = \"BHE:error\"\n        data = str(e)\n        event = helper.new_event(source=None, index=\"main\", sourcetype=sourcetype, data=data)\n        ew.write_event(event)", "customized_options": [{"name": "bloodhound_account", "value": ""}, {"name": "historical_polling_days", "value": ""}], "uuid": "ded1998c02fb4fafa53999c0d3b82c26", "sample_count": 0}, {"index": "default", "sourcetype": "tier_zero_assets", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "tier_zero_assets", "title": "Tier Zero Assets", "description": "", "type": "customized", "parameters": [{"name": "bloodhound_account", "label": "BloodHound Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "bloodhound_account", "title": "BloodHound Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import json \nfrom rest_client import header_generator, fetch_data\n\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    # opt_bloodhound_account = helper.get_arg('bloodhound_account')\n    # method = 'GET'\n    # uri = f'/api/v2/asset-groups?tag=eq%3Aadmin_tier_0'\n    # token_key = opt_bloodhound_account['token_key']\n    # token_id = opt_bloodhound_account['token_id']\n    # domain_name = opt_bloodhound_account['domain_name']\n\n    # headers = header_generator(token_id,token_key, method, uri)\n    # r_json = fetch_data(helper, ew, headers, domain_name, uri)\n\n    # if r_json:\n    #     return True\n    # else :\n    #     return False\n    pass\n\ndef collect_events(helper, ew):\n    try:\n        opt_bloodhound_account = helper.get_arg('bloodhound_account')\n        method = 'GET'\n        token_key = opt_bloodhound_account['token_key']\n        token_id = opt_bloodhound_account['token_id']\n        domain_name = opt_bloodhound_account['domain_name']\n        uri = '/api/v2/asset-groups?tag=eq%3Aadmin_tier_0'\n        headers = header_generator(token_id,token_key,method, uri)\n        r_json = fetch_data(helper, ew, headers, domain_name, uri)\n        asset_group_ids = [ group['id'] for group in r_json['data']['asset_groups'] ]\n\n        for id in asset_group_ids:\n            uri = f'/api/v2/asset-groups/{id}/members'\n\n            headers = header_generator(token_id,token_key, method, uri)\n            r_json = fetch_data(helper, ew, headers, domain_name, uri)\n            assetMembers = r_json[\"data\"][\"members\"]\n            sourcetype = \"BHE:asset_groups\"\n\n            for item in assetMembers:\n                event = helper.new_event(json.dumps(item), time=None, host=None, index=helper.get_output_index(), source=None, sourcetype=sourcetype, done=True, unbroken=True)\n                ew.write_event(event)\n    except Exception as e:\n        sourcetype = \"BHE:error\"\n        data = str(e)\n        event = helper.new_event(source=None, index=\"main\", sourcetype=sourcetype, data=data)\n        ew.write_event(event)\n", "customized_options": [{"name": "bloodhound_account", "value": ""}], "uuid": "e62497b8bd7e41d68777de57fc756cc8", "sample_count": 0}]}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}, "credential_settings": []}}, "sourcetype_builder": {"attack_paths": {"metadata": {"event_count": 0, "data_input_name": "attack_paths", "extractions_count": 0, "cims_count": 0}}, "audit_logs": {"metadata": {"event_count": 0, "data_input_name": "audit_logs", "extractions_count": 0, "cims_count": 0}}, "tier_zero_assets": {"metadata": {"event_count": 0, "data_input_name": "tier_zero_assets", "extractions_count": 0, "cims_count": 0}}, "posture_statistics": {"metadata": {"event_count": 0, "data_input_name": "posture_statistics", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1742539507_5"}}