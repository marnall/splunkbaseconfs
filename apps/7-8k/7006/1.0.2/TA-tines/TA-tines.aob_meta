{"basic_builder": {"appname": "TA-tines", "friendly_name": "tines", "version": "1.0.2", "author": "", "description": "This technical add-on is designed to normalize Tines data at both search time and index time in Splunk Enterprise. In addition to these features, it also incorporates customized webhook alert actions for enhanced usability and functionality.", "theme": "#8578e6", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.3", "tab_build_no": "0", "build_no": 3}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "tines:cases", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "tines_case", "title": "tines:cases", "description": "", "type": "customized", "parameters": [{"name": "per_page", "label": "per_page", "help_string": "", "required": false, "format_type": "text", "default_value": "500", "placeholder": "", "type": "text", "value": "500"}], "data_inputs_options": [{"type": "customized_var", "name": "per_page", "title": "per_page", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "500", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport datetime\nimport json\nimport os\n\n\ndef collect_events(helper, ew):\n    global_tines_tenant_url = helper.get_global_setting(\"tines_tenant_url\")\n    global_tines_user_email_address = helper.get_global_setting(\"tines_user_email_address\")\n    global_tines_api_key = helper.get_global_setting(\"tines_api_key\")\n    start_date = helper.get_global_setting(\"start_date\")\n\n    headers = {\n        \"accept\": \"application/json\",\n        \"content-type\": \"application/json\",\n        \"x-user-token\": global_tines_api_key,\n        \"x-user-email\": global_tines_user_email_address\n    }\n\n    url = global_tines_tenant_url + \"/api/v1/cases\"\n    # data = []\n\n    # The following examples send rest requests to some endpoint.\n    start_date = helper.get_check_point(\"cases\")\n\n    if start_date is None:\n        start_date = helper.get_global_setting(\"start_date\")\n\n    payload = {\n        \"per_page\": 500,\n        \"filters\": {\n            \"start_date\": start_date\n        }\n    }\n\n    # Set the cursor for the next time this code executes so there are no duplicate values\n    helper.save_check_point(\"cases\", datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'))\n    \n\n    while True:\n        response = helper.send_http_request(url, \"get\", parameters=None, payload=payload, headers=headers, cookies=None,\n                                            verify=True, cert=None, timeout=None, use_proxy=True)\n\n        resp = json.loads(response.text)\n        for item in resp[\"cases\"]:\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(),\n                                     sourcetype=helper.get_sourcetype(), data=json.dumps(item))\n            ew.write_event(event)\n\n        url = resp[\"meta\"][\"next_page\"]\n        if url is None:\n            break\n\n", "customized_options": [{"name": "per_page", "value": "500"}], "uuid": "ecac3d42261d42a0b442c1e46c2dbb39", "sample_count": 0}, {"index": "default", "sourcetype": "tines:audit", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "tines_audit", "title": "tines:audit", "description": "", "type": "customized", "parameters": [{"name": "per_page", "label": "per_page", "help_string": "", "required": false, "format_type": "text", "default_value": "500", "placeholder": "", "type": "text", "value": "500"}], "data_inputs_options": [{"type": "customized_var", "name": "per_page", "title": "per_page", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "500", "placeholder": ""}], "code": "# encoding = utf-8\\\nimport datetime\nimport json\n\ndef collect_events(helper, ew):\n    global_tines_tenant_url = helper.