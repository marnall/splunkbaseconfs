{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "__settings__.logging.loglevel",
        "__settings__.additional_parameters.tines_tenant_url",
        "__settings__.additional_parameters.tines_user_email_address",
        "__settings__.additional_parameters.tines_api_key",
        "cases"
    ],
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": [
                    {
                        "input": [
                            "{{cases}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_cases"
                    }
                ]
            },
            "request": {
                "url": "{{__settings__.additional_parameters.tines_tenant_url}}/api/v1/cases",
                "method": "GET",
                "headers": {
                    "x-user-email": "{{__settings__.additional_parameters.tines_user_email_address}}",
                    "x-user-token": "{{__settings__.additional_parameters.tines_api_key}}"
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.cases[*]"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.cases[*].case_id"
                        ],
                        "method": "json_path",
                        "output": "cases"
                    },
                    {
                        "input": [
                            "{{cases != ''}}",
                            "The value of token 'cases' extracted from response cannot be empty!"
                        ],
                        "method": "assert_true"
                    },
                    {
                        "input": [
                            "{{cases == _raw_cases}}"
                        ],
                        "method": "exit_if_true"
                    },
                    {
                        "input": [
                            "{{cases}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_cases"
                    },
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.cases[*]"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "100",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.cases[*]"
                        ],
                        "method": "json_empty"
                    }
                ]
            },
            "checkpoint": {
                "content": {
                    "cases": "{{_raw_cases}}"
                }
            }
        }
    ]
}