{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "__settings__.logging.loglevel",
        "__settings__.additional_parameters.tines_tenant_url",
        "__settings__.additional_parameters.tines_user_email_address",
        "__settings__.additional_parameters.tines_api_key"
    ],
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": []
            },
            "request": {
                "url": "{{__settings__.additional_parameters.tines_tenant_url}}/api/v1/reporting/time_saved\n",
                "method": "GET",
                "headers": {
                    "x-user-email": "{{__settings__.additional_parameters.tines_user_email_address}}",
                    "x-user-token": "{{__settings__.additional_parameters.tines_api_key}}"
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.time_saved[*]"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.time_saved[*]"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "1",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.time_saved[*]"
                        ],
                        "method": "json_empty"
                    }
                ]
            }
        }
    ]
}