# Application-level permissions

[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[viewstates]
access = read : [ * ], write : [ * ]
export = system

# Prevent exporting lookups to other apps to prevent potential conflicts with ES, for example.
[lookups/nist.csv]
access = read : [ * ], write : [ admin, sc_admin ]
export = none

# Prevent exporting transforms to other apps to prevent potential conflicts with ES, for example.
[transforms/nist_lookup]
access = read : [ * ], write : [ admin, sc_admin ]
export = none