{"basic_builder": {"appname": "TA-threatworx-add-on", "friendly_name": "ThreatWorx Add-on", "version": "1.1.2", "author": "ThreatWorx", "description": "ThreatWorx Add-on", "theme": "#3c6188", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.0", "tab_build_no": "0", "build_no": 2}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "threatworx:threat", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "threatworx_threat", "title": "ThreatWorx Threat", "description": "Ingest Threat data from ThreatWorx platform into Splunk", "type": "customized", "parameters": [{"required": false, "name": "only_impacting_threats", "label": "Only Impacting Threats", "default_value": false, "help_string": "If checked then only Threats which are impacting organizational assets will be ingested.", "type": "checkbox", "format_type": "checkbox", "value": false}], "data_inputs_options": [{"type": "customized_var", "name": "only_impacting_threats", "title": "Only Impacting Threats", "description": "If checked then only Threats which are impacting organizational assets will be ingested.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": false}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # only_impacting_threats = definition.parameters.get('only_impacting_threats', None)\n    pass\n\ndef tw_transform_threat_event(threat):\n    # Cleanup unwanted fields\n    threat.pop('tags')\n\ndef collect_events(helper, ew):\n    \n    # get user provided values\n    opt_only_impacting_threats = helper.get_arg('only_impacting_threats')\n    \n    helper.log_debug(\"Started new run for Threat ingestion\")\n    helper.log_debug(\"User provided input for only impacting threats: %s\" % opt_only_impacting_threats)\n    \n    \"\"\"\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    \"\"\"\n    # get global variable configuration\n    global_threatworx_instance = helper.get_global_setting(\"threatworx_instance\")\n    global_threatworx_handle = helper.get_global_setting(\"threatworx_handle\")\n    global_threatworx_api_key = helper.get_global_setting(\"threatworx_api_key\")\n    \n    # Make API call to TW to get filtered Threat data\n    url = \"https://\" + global_threatworx_instance + \"/api/v1/threats/?\"\n    bearer_auth = \"Bearer \" + global_threatworx_api_key\n    method = \"POST\"\n    payload = { }\n    filters_list = ['recent']\n    if opt_only_impacting_threats == True:\n        filters_list.append('impacting')\n    payload['filters'] = filters_list\n    payload['window_start'] = \"30\"\n    payload['window_end'] = \"0\"\n    # Note since we are using 'recent' filter we don't need to move/update offset progressively\n    payload['offset'] = 0\n    payload['limit'] = 100\n\n    helper.log_debug(\"Threat API payload: %s\" % payload)\n    total_threats = 0    \n    while True:\n        response = helper.send_http_request(url, method, parameters=None, payload=payload,\n                                        headers={\"Content-Type\": \"application/json\", \"Authorization\": bearer_auth}, cookies=None, verify=True, cert=None,\n                                        timeout=300, use_proxy=True)\n        helper.log_debug(\"Threat API response status code: %s\" % response.status_code)\n        if response.status_code != 200:\n            helper.log_debug(\"API response text: %s\" % response.text)\n            # check the response status, if the status is not sucessful, raise requests.HTTPError\n            response.raise_for_status()\n\n        r_json = response.json()\n        helper.log_debug(\"Number of Threats in API response: %s\" % r_json[\"total\"])\n\n        threats = r_json[\"threats\"]\n        for threat in threats:\n            tw_transform_threat_event(threat)\n            # Always create a new event in Splunk\n            event = helper.new_event(data=json.dumps(threat), time=None, host=None, index=helper.get_output_index(), source=\"ThreatWorx\", sourcetype=\"threatworx:threat\", done=True, unbroken=True)\n            ew.write_event(event)\n            \n        total_threats = total_threats + r_json['total']\n        if r_json[\"total\"] != payload['limit']:\n            helper.log_debug(\"Processed total [%s] Threats. Run completed.\" % total_threats)\n            # last page processed, so break from the while loop\n            break\n        \n", "customized_options": [{"name": "only_impacting_threats", "value": false}], "uuid": "0dc6504491bc4cc585b1d9f692a1a8ae"}, {"index": "default", "sourcetype": "threatworx:vulnerability:impact", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "threatworx_vulnerability_impact", "title": "ThreatWorx Vulnerability Impact", "description": "Ingest vulnerability impacts from ThreatWorx platform into Splunk", "type": "customized", "parameters": [{"required": true, "name": "priority", "label": "Priority", "default_value": ["DoNow"], "help_string": "Specify the priority of the vulnerability impacts for filtering. It is recommended to filter and ingest \"Do Now\" priority impacts in to Splunk.", "placeholder": "", "possible_values": [{"value": "DoNow", "label": "Do Now"}, {"value": "DoLater", "label": "Do Later"}], "type": "multi_dropdownlist", "format_type": "multi_dropdownlist", "value": ["DoNow"]}, {"required": true, "name": "rating", "label": "Rating", "default_value": ["5", "4"], "help_string": "Specify the rating of the vulnerability impacts for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" impacts in to Splunk.", "placeholder": "", "possible_values": [{"value": "5", "label": "Urgent"}, {"value": "4", "label": "Critical"}, {"value": "3", "label": "Severe"}, {"label": "Medium", "value": "2"}, {"label": "Low", "value": "1"}], "type": "multi_dropdownlist", "format_type": "multi_dropdownlist", "value": ["5", "4"]}, {"required": false, "name": "asset_tags", "label": "Asset Tags", "default_value": "", "placeholder": "", "help_string": "Specify a comma separated list of asset tags for filtering. It is recommended to specify appropriate asset tags.", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "asset_tags_match_criteria", "label": "Asset Tags match criteria", "default_value": "any", "help_string": "Specify asset tags matching criteria", "possible_values": [{"value": "all", "label": "All"}, {"value": "any", "label": "Any"}], "type": "radiogroup", "format_type": "radiogroup", "value": "any"}], "data_inputs_options": [{"type": "customized_var", "name": "priority", "title": "Priority", "description": "Specify the priority of the vulnerability impacts for filtering. It is recommended to filter and ingest \"Do Now\" priority impacts in to Splunk.", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "DoNow", "label": "Do Now"}, {"value": "DoLater", "label": "Do Later"}], "format_type": "multi_dropdownlist", "default_value": ["DoNow"], "placeholder": ""}, {"type": "customized_var", "name": "rating", "title": "Rating", "description": "Specify the rating of the vulnerability impacts for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" impacts in to Splunk.", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "5", "label": "Urgent"}, {"value": "4", "label": "Critical"}, {"value": "3", "label": "Severe"}, {"label": "Medium", "value": "2"}, {"label": "Low", "value": "1"}], "format_type": "multi_dropdownlist", "default_value": ["5", "4"], "placeholder": ""}, {"type": "customized_var", "name": "asset_tags", "title": "Asset Tags", "description": "Specify a comma separated list of asset tags for filtering. It is recommended to specify appropriate asset tags.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "asset_tags_match_criteria", "title": "Asset Tags match criteria", "description": "Specify asset tags matching criteria", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "all", "label": "All"}, {"value": "any", "label": "Any"}], "format_type": "radiogroup", "default_value": "any"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport base64\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # priority = definition.parameters.get('priority', None)\n    # rating = definition.parameters.get('rating', None)\n    # asset_tags = definition.parameters.get('asset_tags', None)\n    pass\n\ndef tw_transform_impact_event(impact):\n    # Cleanup unwanted fields\n    impact.pop('base_id')\n    impact.pop('base_tw_id')\n    impact.pop('related_threats')\n    impact.pop('reported_by')\n    #impact.pop('resolve_comment')\n    #impact.pop('resolve_timestamp')\n    impact.pop('vuln_exploitability_score')\n    \ndef collect_events(helper, ew):\n\n    # get user provided values\n    opt_priority = helper.get_arg('priority')\n    if opt_priority == ['[]']:\n        # In Test mode, we get list, but in actual deployed run we get list as string\n        opt_priority = []\n    opt_asset_tags = helper.get_arg('asset_tags')\n    if opt_asset_tags is None:\n        opt_asset_tags = \"\"\n    opt_asset_tags_match_criteria = helper.get_arg('asset_tags_match_criteria')\n    opt_rating = helper.get_arg('rating')\n    if opt_rating == ['[]']:\n        # In Test mode, we get list, but in actual deployed run we get list as string\n        opt_rating = []\n\n    helper.log_debug(\"Started new run\")\n    helper.log_debug(\"User provided Priority: %s\" % opt_priority)\n    helper.log_debug(\"User provided Rating: %s\" % opt_rating)\n    helper.log_debug(\"User provided Asset Tags: %s\" % opt_asset_tags)\n    helper.log_debug(\"User provided Asset Tag Match Criteria: %s\" % opt_asset_tags_match_criteria)\n\n    \"\"\"\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    \"\"\"\n    # get global variable configuration\n    global_threatworx_instance = helper.get_global_setting(\"threatworx_instance\")\n    global_threatworx_handle = helper.get_global_setting(\"threatworx_handle\")\n    global_threatworx_api_key = helper.get_global_setting(\"threatworx_api_key\")\n    \n    # Make API call to TW to get filtering vulnerability impacts\n    #url = \"https://\" + global_threatworx_instance + \"/api/v1/impacts/?handle=\" + global_threatworx_handle + \"&token=\" + global_threatworx_api_key\n    url = \"https://\" + global_threatworx_instance + \"/api/v1/impacts/?\"\n    bearer_auth = \"Bearer \" + global_threatworx_api_key\n    method = \"POST\"\n    payload = { }\n    payload['status'] = ['open', 'resolved', 'ignored']\n    payload['filters'] = ['recent']\n    payload['window_start'] = \"30\"\n    payload['window_end'] = \"0\"\n    # Note since we are using 'recent' filter we don't need to move/update offset progressively\n    payload['offset'] = 0\n    payload['limit'] = 100\n\n    if len(opt_priority) > 0:\n        payload[\"action_buckets\"] = opt_priority\n    if len(opt_rating) > 0:\n        payload[\"ratings\"] = opt_rating\n    if len(opt_asset_tags) > 0:\n        asset_tags = []\n        for tag in opt_asset_tags.split(','):\n            asset_tags.append(tag.strip())\n        payload[\"asset_tags\"] = asset_tags\n        payload[\"tags_condition\"] = opt_asset_tags_match_criteria\n\n    helper.log_debug(\"API payload: %s\" % payload)\n    total_impacts = 0    \n    while True:\n        response = helper.send_http_request(url, method, parameters=None, payload=payload,\n                                        headers={\"Content-Type\": \"application/json\", \"Authorization\": bearer_auth}, cookies=None, verify=True, cert=None,\n                                        timeout=300, use_proxy=True)\n        helper.log_debug(\"API response status code: %s\" % response.status_code)\n        if response.status_code != 200:\n            helper.log_debug(\"API response text: %s\" % response.text)\n            # check the response status, if the status is not sucessful, raise requests.HTTPError\n            response.raise_for_status()\n\n        r_json = response.json()\n        helper.log_debug(\"Number of impacts in API response: %s\" % len(r_json[\"impacts\"]))\n\n        impacts = r_json[\"impacts\"]\n        for impact in impacts:\n            tw_transform_impact_event(impact)\n            # Always create a new event in Splunk\n            event = helper.new_event(data=json.dumps(impact), time=None, host=None, index=helper.get_output_index(), source=\"ThreatWorx\", sourcetype=\"threatworx:vulnerability:impact\", done=True, unbroken=True)\n            ew.write_event(event)\n            \n        total_impacts = total_impacts + len(r_json['impacts'])\n        if len(r_json[\"impacts\"]) != payload['limit']:\n            helper.log_debug(\"Processed total [%s] impacts. Run completed.\" % total_impacts)\n            # last page processed, so break from the while loop\n            break\n\n", "customized_options": [{"name": "priority", "value": ["DoNow"]}, {"name": "rating", "value": ["5", "4"]}, {"name": "asset_tags", "value": ""}, {"name": "asset_tags_match_criteria", "value": "any"}], "uuid": "7a8207fbab0f4314b4a11db4b34de380", "sample_count": 0}, {"index": "default", "sourcetype": "threatworx:sast", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "threatworx_sast", "title": "ThreatWorx SAST", "description": "Ingest SAST vulnerabilities from ThreatWorx platform into Splunk", "type": "customized", "parameters": [{"name": "rating", "label": "Rating", "help_string": "Specify the rating of the SAST vulnerabilities for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" SAST vulnerabilities in to Splunk.", "required": true, "possible_values": [{"value": "5", "label": "Urgent"}, {"value": "4", "label": "Critical"}, {"value": "3", "label": "Severe"}, {"label": "Medium", "value": "2"}, {"label": "Low", "value": "1"}], "format_type": "multi_dropdownlist", "default_value": ["5", "4"], "placeholder": "", "type": "multi_dropdownlist", "value": ["5", "4"]}, {"name": "asset_tags", "label": "Asset Tags", "help_string": "Specify a comma separated list of asset tags for filtering. It is recommended to specify appropriate asset tags.", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "asset_tags_match_criteria", "label": "Asset Tags match criteria", "help_string": "Specify asset tags matching criteria", "required": false, "possible_values": [{"value": "all", "label": "All"}, {"value": "any", "label": "Any"}], "format_type": "radiogroup", "default_value": "any", "type": "radiogroup", "value": "any"}], "data_inputs_options": [{"type": "customized_var", "name": "rating", "title": "Rating", "description": "Specify the rating of the SAST vulnerabilities for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" SAST vulnerabilities in to Splunk.", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "5", "label": "Urgent"}, {"value": "4", "label": "Critical"}, {"value": "3", "label": "Severe"}, {"label": "Medium", "value": "2"}, {"label": "Low", "value": "1"}], "format_type": "multi_dropdownlist", "default_value": ["5", "4"], "placeholder": ""}, {"type": "customized_var", "name": "asset_tags", "title": "Asset Tags", "description": "Specify a comma separated list of asset tags for filtering. It is recommended to specify appropriate asset tags.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "asset_tags_match_criteria", "title": "Asset Tags match criteria", "description": "Specify asset tags matching criteria", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "all", "label": "All"}, {"value": "any", "label": "Any"}], "format_type": "radiogroup", "default_value": "any"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport base64\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # priority = definition.parameters.get('priority', None)\n    # rating = definition.parameters.get('rating', None)\n    # asset_tags = definition.parameters.get('asset_tags', None)\n    pass\n\ndef tw_transform_sast_event(impact):\n    # Cleanup unwanted fields\n    pass\n\ndef collect_events(helper, ew):\n\n    # get user provided values\n    opt_asset_tags = helper.get_arg('asset_tags')\n    if opt_asset_tags is None:\n        opt_asset_tags = \"\"\n    opt_asset_tags_match_criteria = helper.get_arg('asset_tags_match_criteria')\n    opt_rating = helper.get_arg('rating')\n    if opt_rating == ['[]']:\n        # In Test mode, we get list, but in actual deployed run we get list as string\n        opt_rating = []\n\n    helper.log_debug(\"Started new run to ingest SAST issues\")\n    helper.log_debug(\"User provided Rating: %s\" % opt_rating)\n    helper.log_debug(\"User provided Asset Tags: %s\" % opt_asset_tags)\n    helper.log_debug(\"User provided Asset Tag Match Criteria: %s\" % opt_asset_tags_match_criteria)\n\n    \"\"\"\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    \"\"\"\n    # get global variable configuration\n    global_threatworx_instance = helper.get_global_setting(\"threatworx_instance\")\n    global_threatworx_handle = helper.get_global_setting(\"threatworx_handle\")\n    global_threatworx_api_key = helper.get_global_setting(\"threatworx_api_key\")\n    \n    # Make API call to TW to get filtering vulnerability impacts\n    url = \"https://\" + global_threatworx_instance + \"/api/v1/assets/sast/?\"\n    bearer_auth = \"Bearer \" + global_threatworx_api_key\n    method = \"POST\"\n    payload = { }\n    payload['status'] = ['open', 'resolved', 'ignored']\n    payload['filters'] = ['recent']\n    # Note since we are using 'recent' filter we don't need to move/update offset progressively\n    payload['offset'] = 0\n    payload['limit'] = 100\n\n    if len(opt_rating) > 0:\n        payload[\"ratings\"] = opt_rating\n    if len(opt_asset_tags) > 0:\n        asset_tags = []\n        for tag in opt_asset_tags.split(','):\n            asset_tags.append(tag.strip())\n        payload[\"tags\"] = asset_tags\n        payload[\"tags_condition\"] = opt_asset_tags_match_criteria\n\n    helper.log_debug(\"API payload: %s\" % payload)\n    total_issues = 0    \n    while True:\n        response = helper.send_http_request(url, method, parameters=None, payload=payload,\n                                        headers={\"Content-Type\": \"application/json\", \"Authorization\": bearer_auth}, cookies=None, verify=True, cert=None,\n                                        timeout=300, use_proxy=True)\n        helper.log_debug(\"API response status code: %s\" % response.status_code)\n        if response.status_code != 200:\n            helper.log_debug(\"API response text: %s\" % response.text)\n            # check the response status, if the status is not sucessful, raise requests.HTTPError\n            response.raise_for_status()\n\n        r_json = response.json()\n        helper.log_debug(\"Number of SAST issues in API response: %s\" % len(r_json[\"issues\"]))\n\n        issues = r_json[\"issues\"]\n        for issue in issues:\n            tw_transform_sast_event(issue)\n            # Always create a new event in Splunk\n            event = helper.new_event(data=json.dumps(issue), time=None, host=None, index=helper.get_output_index(), source=\"ThreatWorx\", sourcetype=\"threatworx:sast\", done=True, unbroken=True)\n            ew.write_event(event)\n            \n        total_issues = total_issues + len(r_json['issues'])\n        if len(r_json[\"issues\"]) != payload['limit']:\n            helper.log_debug(\"Processed total [%s] SAST issues. Run completed.\" % total_issues)\n            # last page processed, so break from the while loop\n            break\n\n", "customized_options": [{"name": "rating", "value": ["5", "4"]}, {"name": "asset_tags", "value": ""}, {"name": "asset_tags_match_criteria", "value": "any"}], "uuid": "77f740e243334cd79541d147e388c593", "sample_count": 0}, {"index": "default", "sourcetype": "threatworx:secret", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "threatworx_secret", "title": "ThreatWorx Secret", "description": "Ingest code secrets from ThreatWorx platform into Splunk", "type": "customized", "parameters": [{"name": "rating", "label": "Rating", "help_string": "Specify the rating of the code secrets for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" code secrets in to Splunk.", "required": true, "possible_values": [{"value": "5", "label": "Urgent"}, {"value": "4", "label": "Critical"}, {"value": "3", "label": "Severe"}, {"label": "Medium", "value": "2"}, {"label": "Low", "value": "1"}], "format_type": "multi_dropdownlist", "default_value": ["5", "4"], "placeholder": "", "type": "multi_dropdownlist", "value": ["5", "4"]}, {"name": "secret_detection_method", "label": "Secret detection method", "help_string": "Specify the secret detection method for filtering. It is recommended to ingest secrets detected using regular expression and entropy based detection methods.", "required": false, "possible_values": [{"value": "REGEX", "label": "Regular Expression"}, {"value": "ENTROPY_BASE64", "label": "Base64 Entropy"}, {"value": "ENTROPY_HEX", "label": "Hex Entropy"}, {"label": "Common Password", "value": "COMMON_PASSWORD"}], "format_type": "multi_dropdownlist", "default_value": ["REGEX", "ENTROPY_BASE64", "ENTROPY_HEX"], "placeholder": "", "type": "multi_dropdownlist", "value": ["REGEX", "ENTROPY_BASE64", "ENTROPY_HEX"]}, {"name": "asset_tags", "label": "Asset Tags", "help_string": "Specify a comma separated list of asset tags for filtering. It is recommended to specify appropriate asset tags.", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "asset_tags_match_criteria", "label": "Asset Tags match criteria", "help_string": "Specify asset tags matching criteria", "required": false, "possible_values": [{"value": "all", "label": "All"}, {"value": "any", "label": "Any"}], "format_type": "radiogroup", "default_value": "any", "type": "radiogroup", "value": "any"}], "data_inputs_options": [{"type": "customized_var", "name": "rating", "title": "Rating", "description": "Specify the rating of the code secrets for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" code secrets in to Splunk.", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "5", "label": "Urgent"}, {"value": "4", "label": "Critical"}, {"value": "3", "label": "Severe"}, {"label": "Medium", "value": "2"}, {"label": "Low", "value": "1"}], "format_type": "multi_dropdownlist", "default_value": ["5", "4"], "placeholder": ""}, {"type": "customized_var", "name": "secret_detection_method", "title": "Secret detection method", "description": "Specify the secret detection method for filtering. It is recommended to ingest secrets detected using regular expression and entropy based detection methods.", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "REGEX", "label": "Regular Expression"}, {"value": "ENTROPY_BASE64", "label": "Base64 Entropy"}, {"value": "ENTROPY_HEX", "label": "Hex Entropy"}, {"label": "Common Password", "value": "COMMON_PASSWORD"}], "format_type": "multi_dropdownlist", "default_value": ["REGEX", "ENTROPY_BASE64", "ENTROPY_HEX"], "placeholder": ""}, {"type": "customized_var", "name": "asset_tags", "title": "Asset Tags", "description": "Specify a comma separated list of asset tags for filtering. It is recommended to specify appropriate asset tags.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "asset_tags_match_criteria", "title": "Asset Tags match criteria", "description": "Specify asset tags matching criteria", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "all", "label": "All"}, {"value": "any", "label": "Any"}], "format_type": "radiogroup", "default_value": "any"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport base64\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # priority = definition.parameters.get('priority', None)\n    # rating = definition.parameters.get('rating', None)\n    # asset_tags = definition.parameters.get('asset_tags', None)\n    pass\n\ndef tw_transform_secret_event(impact):\n    # Cleanup unwanted fields\n    pass\n    \ndef collect_events(helper, ew):\n\n    # get user provided values\n    opt_asset_tags = helper.get_arg('asset_tags')\n    if opt_asset_tags is None:\n        opt_asset_tags = \"\"\n    opt_asset_tags_match_criteria = helper.get_arg('asset_tags_match_criteria')\n    opt_rating = helper.get_arg('rating')\n    if opt_rating == ['[]']:\n        # In Test mode, we get list, but in actual deployed run we get list as string\n        opt_rating = []\n    opt_secret_detection_method = helper.get_arg('secret_detection_method')\n    if opt_secret_detection_method == ['[]']:\n        opt_secret_detection_method = []\n\n    helper.log_debug(\"Started new run to ingest secrets\")\n    helper.log_debug(\"User provided Rating: %s\" % opt_rating)\n    helper.log_debug(\"User provided Asset Tags: %s\" % opt_asset_tags)\n    helper.log_debug(\"User provided Asset Tag Match Criteria: %s\" % opt_asset_tags_match_criteria)\n\n    \"\"\"\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    \"\"\"\n    # get global variable configuration\n    global_threatworx_instance = helper.get_global_setting(\"threatworx_instance\")\n    global_threatworx_handle = helper.get_global_setting(\"threatworx_handle\")\n    global_threatworx_api_key = helper.get_global_setting(\"threatworx_api_key\")\n    \n    # Make API call to TW to get filtering vulnerability impacts\n    url = \"https://\" + global_threatworx_instance + \"/api/v1/assets/secrets/?\"\n    bearer_auth = \"Bearer \" + global_threatworx_api_key\n    method = \"POST\"\n    payload = { }\n    payload['status'] = ['open', 'resolved', 'ignored']\n    payload['filters'] = ['recent']\n    # Note since we are using 'recent' filter we don't need to move/update offset progressively\n    payload['offset'] = 0\n    payload['limit'] = 100\n\n    if len(opt_rating) > 0:\n        payload[\"ratings\"] = opt_rating\n    if len(opt_secret_detection_method) > 0:\n        payload[\"discovered_using\"] = opt_secret_detection_method\n    if len(opt_asset_tags) > 0:\n        asset_tags = []\n        for tag in opt_asset_tags.split(','):\n            asset_tags.append(tag.strip())\n        payload[\"tags\"] = asset_tags\n        payload[\"tags_condition\"] = opt_asset_tags_match_criteria\n\n    helper.log_debug(\"API payload: %s\" % payload)\n    total_secrets = 0    \n    while True:\n        response = helper.send_http_request(url, method, parameters=None, payload=payload,\n                                        headers={\"Content-Type\": \"application/json\", \"Authorization\": bearer_auth}, cookies=None, verify=True, cert=None,\n                                        timeout=300, use_proxy=True)\n        helper.log_debug(\"API response status code: %s\" % response.status_code)\n        if response.status_code != 200:\n            helper.log_debug(\"API response text: %s\" % response.text)\n            # check the response status, if the status is not sucessful, raise requests.HTTPError\n            response.raise_for_status()\n\n        r_json = response.json()\n        helper.log_debug(\"Number of secrets in API response: %s\" % len(r_json[\"secrets\"]))\n\n        secrets = r_json[\"secrets\"]\n        for secret in secrets:\n            tw_transform_secret_event(secret)\n            # Always create a new event in Splunk\n            event = helper.new_event(data=json.dumps(secret), time=None, host=None, index=helper.get_output_index(), source=\"ThreatWorx\", sourcetype=\"threatworx:secret\", done=True, unbroken=True)\n            ew.write_event(event)\n            \n        total_secrets = total_secrets + len(r_json['secrets'])\n        if len(r_json[\"secrets\"]) != payload['limit']:\n            helper.log_debug(\"Processed total [%s] secrets. Run completed.\" % total_secrets)\n            # last page processed, so break from the while loop\n            break\n\n", "customized_options": [{"name": "rating", "value": ["5", "4"]}, {"name": "secret_detection_method", "value": ["REGEX", "ENTROPY_BASE64", "ENTROPY_HEX"]}, {"name": "asset_tags", "value": ""}, {"name": "asset_tags_match_criteria", "value": "any"}], "uuid": "5c793a412b984f6c9b758286d4e49581", "sample_count": 0}, {"index": "default", "sourcetype": "threatworx:misconfiguration", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "threatworx_misconfiguration", "title": "ThreatWorx Misconfiguration", "description": "Ingest misconfigurations from ThreatWorx platform into Splunk", "type": "customized", "parameters": [{"name": "rating", "label": "Rating", "help_string": "Specify the rating of the misconfigurations for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" misconfigurations in to Splunk.", "required": true, "possible_values": [{"value": "5", "label": "Urgent"}, {"value": "4", "label": "Critical"}, {"value": "3", "label": "Severe"}, {"label": "Medium", "value": "2"}, {"label": "Low", "value": "1"}], "format_type": "multi_dropdownlist", "default_value": ["5", "4"], "placeholder": "", "type": "multi_dropdownlist", "value": ["5", "4"]}, {"name": "asset_tags", "label": "Asset Tags", "help_string": "Specify a comma separated list of asset tags for filtering. It is recommended to specify appropriate asset tags.", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "asset_tags_match_criteria", "label": "Asset Tags match criteria", "help_string": "Specify asset tags matching criteria", "required": false, "possible_values": [{"value": "all", "label": "All"}, {"value": "any", "label": "Any"}], "format_type": "radiogroup", "default_value": "any", "type": "radiogroup", "value": "any"}], "data_inputs_options": [{"type": "customized_var", "name": "rating", "title": "Rating", "description": "Specify the rating of the misconfigurations for filtering. It is recommended to filter and ingest \"Urgent\" and \"Critical\" misconfigurations in to Splunk.", "required_on_edit": false, "required_on_create": true, "possible_v