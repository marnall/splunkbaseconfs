ontent-Type': 'application/json',\n    #     'Api-Key': opt_api_key,\n    #     'SiteId': opt_siteid,\n    # }\n    \n    \n    # response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    # response_token_json=response_token.json()\n    # token=\"\"\n    # for i in response_token_json:\n    #     token=response_token_json[\"AccessToken\"]\n        \n    ##\n    url_locations= \"https://api.mindbodyonline.com/public/v6/site/locations\"\n\n    headers_locations = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid,\n    }\n    \n    response_locations= requests.request(\"GET\", url_locations, headers=headers_locations)\n    response_locations_json=response_locations.json()\n    \n    \n    # final_result = []\n    total_result = response_locations_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count=0\n    while offset <= total_result:\n        url_location=f\"https://api.mindbodyonline.com/public/v6/site/locations?limit=200&offset={offset}\"\n        response_location= requests.request(\"GET\", url_location, headers=headers_locations)\n        response_location_json=response_location.json()\n        for i in response_location_json[\"Locations\"]:\n            state = helper.get_check_point(str(i[\"Address\"]+i[\"Address2\"]))\n            if state is None:\n                # final_result.append(i)\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n                helper.save_check_point(str(i[\"Address\"]+i[\"Address2\"]), \"Indexed\")\n            # helper.delete_check_point(str(i[\"Address\"]+i[\"Address2\"]))\n        offset+=200\n        \n    status = response_locations.status_code\n    # count = len(final_result)\n    status = \"The API=\"+str(url_locations)+\"  | response_code=\"+str(status)+\"  | number_of_