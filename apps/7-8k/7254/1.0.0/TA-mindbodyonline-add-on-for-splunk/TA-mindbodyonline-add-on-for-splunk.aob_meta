opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n   \n        \n    ##\n    url_packages = \"https://api.mindbodyonline.com/public/v6/sale/packages\"\n\n    headers_packages = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n    }\n    \n    response_packages = requests.request(\"GET\", url_packages, headers=headers_packages)\n    response_packages_json=response_packages.json()\n    \n    \n    final_result = []\n    total_result = response_packages_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    while offset <= total_result:\n        url_package = f\"https://api.mindbodyonline.com/public/v6/sale/packages?limit=200&offset={offset}\"\n        offset +=200\n        response_package = requests.request(\"GET\", url_package, headers=headers_packages)\n        response_package_json=response_package.json()\n        for i in response_package_json[\"Packages\"]:\n            final_result.append(i)\n        state = helper.get_check_point(str(i[\"Id\"]))\n        if state is None:\n            final_result.append(i)\n            helper.save_check_point(str(i[\"Id\"]), \"Indexed\")\n        # helper.delete_check_point(str(i[\"Id\"]))\n    status = response_packages.status_code\n    count = len(final_result)\n    status = \"The API=\"+str(url_packages)+\"  | response_code=\"+str(status)+\"  | number_of_events=\"+str(count)\n    helper.log_info(status)\n    event = helper.new_event(json.dumps(final_result))\n    ew.write_event(event)\n    \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Sale-Packages"}], "uuid": "d2b0ee5bbfd248acad7ffb481316ef0b", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:sale:productsinventory", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_sales_products_inventory", "title": "Sales-Products Inventory", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Sales-Products Inventory ", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Sales-Products Inventory "}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Sales-Products Inventory ", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    \n    \n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ##\n    url_productsinventory = \"https://api.mindbodyonline.com/public/v6/sale/productsinventory\"\n\n\n\n    headers_productsinventory = {\n        'User-Agent': opt_app_source_name,\n        'Authorization': token,\n        'Api-Key': opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n    }\n    \n    response_productsinventory = requests.request(\"GET\", url_productsinventory, headers=headers_productsinventory)\n    response_productsinventory_json=response_productsinventory.json()\n    \n    \n     # final_result = []\n    total_result = response_productsinventory_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count = 0\n    while offset <= total_result:\n        url_productsinventory_offset = f\"https://api.mindbodyonline.com/public/v6/sale/productsinventory?limit=200&offset={offset}\"\n        response_productsinventory_offset = requests.request(\"GET\", url_productsinventory_offset, headers=headers_productsinventory)\n        response_productsinventory_offset_json=response_productsinventory_offset.json()\n        for i in response_productsinventory_offset_json[\"ProductsInventory\"]:\n            state = helper.get_check_point(str(i[\"ProductId\"]+i[\"LocationId\"]))\n            if state is None:\n                # final_result.append(i)\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n                helper.save_check_point(str(i[\"ProductId\"]+i[\"LocationId\"]), \"Indexed\")\n            #helper.delete_check_point(str(i[\"ProductId\"]+i[\"LocationId\"]))\n        offset+=200\n        \n    \n    status = response_productsinventory.status_code\n    # count = len(final_result)\n    status = \"API=\"+str(url_productsinventory)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n    helper.log_info(status)\n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    # final_result = []\n    # for i in  response_productsinventory_json[\"ProductsInventory\"]:\n    #     state = helper.get_check_point(str(i[\"ProductId\"]+i[\"LocationId\"]))\n    #     if state is None:\n    #         final_result.append(i)\n    #         helper.save_check_point(str(i[\"ProductId\"]+i[\"LocationId\"]), \"Indexed\")\n    #     helper.delete_check_point(str(i[\"ProductId\"]+i[\"LocationId\"]))\n    \n    # status = response_productsinventory.status_code\n    # count = len(final_result)\n    # status = \"The API=\"+str(url_productsinventory)+\"  | response_code= \"+str(status)+\"  | number_of_events=\"+str(count)\n    # helper.log_info(status)\n    \n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Sales-Products Inventory "}], "uuid": "774f6ed23cff4eecad74165c36680fa4", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:enrollment:enrollments", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_enrollments", "title": "Enrollments", "description": "", "type": "customized", "parameters": [{"name": "endpoint", "label": "Endpoint", "help_string": "", "required": false, "format_type": "text", "default_value": "Enrollments", "placeholder": "", "type": "text", "value": "Enrollments"}, {"required": false, "name": "start_date", "label": "Start Date", "default_value": "", "placeholder": "Example: 2021-11-01T00:00:00 ( Default- Today\u2019s Date)", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "end_date", "label": "End Date", "default_value": "", "placeholder": "Example: 2022-02-01T00:00:00 (Default-Start Date)", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Enrollments", "placeholder": ""}, {"type": "customized_var", "name": "start_date", "title": "Start Date", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Example: 2021-11-01T00:00:00 ( Default- Today\u2019s Date)"}, {"type": "customized_var", "name": "end_date", "title": "End Date", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Example: 2022-02-01T00:00:00 (Default-Start Date)"}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nfrom datetime import datetime\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    start_date = helper.get_arg('start_date')\n    end_date = helper.get_arg('end_date')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    \n    ########################### Getting Token ######################################################\n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ############################### Enrollments API #########################################################\n\n    headers_enrollments = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n    }\n    \n    \n    url_enrollments = \"https://api.mindbodyonline.com/public/v6/enrollment/enrollments\"\n    response_enroll = requests.request(\"GET\", url_enrollments, headers=headers_enrollments)\n    response_enroll_json=response_enroll.json()\n    total_result = response_enroll_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    # final_result = []\n    status = \"\"\n    count = 0\n    \n    # def getData(api_url):\n    #     even = helper.new_event(\"p\")\n    #     ew.write_event(even)\n    #     response_enrollments = requests.request(\"GET\", api_url, headers=headers_enrollments)\n    #     enrollments_json=response_enrollments.json()\n    #     for i in  enrollments_json[\"Enrollments\"]:\n    #         # final_result.append(i)\n    #         event = helper.new_event(json.dumps(i,indent=2))\n    #         ew.write_event(event)\n    #         count+=1\n    #         # state = helper.get_check_point(str(i[\"StartDate\"]+i[\"EndDate\"]))\n    #         # if state is None:\n    #         #     final_result.append(i)\n    #         #     helper.save_check_point(str(i[\"StartDate\"]+i[\"EndDate\"]), \"Indexed\")\n    #         # helper.delete_check_point(str(i[\"StartDate\"]+i[\"EndDate\"]))\n    #     offset+=200\n    #     status = response_enrollments.status_code\n    #     # count = len(final_result)\n    #     status = \"API=\"+str(api_url)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n    #     helper.log_info(status)\n    #     # event = helper.new_event(json.dumps(final_result))\n    #     # ew.write_event(event)\n        \n    while offset <= total_result:\n        if start_date and end_date:\n            url_enrollments_with_date = f\"https://api.mindbodyonline.com/public/v6/enrollment/enrollments?limit=200&offset=0?startDate={start_date}&endDate={end_date}\"\n            response_enrollments_with_date = requests.request(\"GET\", url_enrollments_with_date, headers=headers_enrollments)\n            enrollments_json_with_date=response_enrollments_with_date.json()\n            for i in  enrollments_json_with_date[\"Enrollments\"]:\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n            offset+=200\n            status = response_enrollments_with_date.status_code\n            status = \"API=\"+str(url_enrollments_with_date)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n            helper.log_info(status)\n            # getData(url_enrollments_with_date)\n        elif(not start_date and end_date):\n            now = datetime.now()\n            start_date = now.strftime(\"%Y-%m-%dT\"+\"00:00:00\")\n            url_enrollments_with_end_date = f\"https://api.mindbodyonline.com/public/v6/enrollment/enrollments?limit=200&offset=0?startDate={start_date}&endDate={end_date}\"\n            response_enrollments_with_end_date = requests.request(\"GET\", url_enrollments_with_end_date, headers=headers_enrollments)\n            enrollments_json_with_end_date=response_enrollments_with_end_date.json()\n            for i in  enrollments_json_with_end_date[\"Enrollments\"]:\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n            offset+=200\n            status = response_enrollments_with_end_date.status_code\n            status = \"API=\"+str(url_enrollments_with_end_date)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n            helper.log_info(status)\n            # getData(url_enrollments_with_end_date)\n        elif(not end_date and start_date):\n            now = datetime.now()\n            end_date = now.strftime(\"%Y-%m-%dT\"+\"23:59:59\")\n            url_enrollments_with_start_date = f\"https://api.mindbodyonline.com/public/v6/enrollment/enrollments?limit=200&offset=0?startDate={start_date}&endDate={end_date}\"\n            response_enrollments_with_start_date = requests.request(\"GET\", url_enrollments_with_start_date, headers=headers_enrollments)\n            enrollments_json_with_start_date=response_enrollments_with_start_date.json()\n            for i in  enrollments_json_with_start_date[\"Enrollments\"]:\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n            offset+=200\n            status = response_enrollments_with_start_date.status_code\n            status = \"API=\"+str(url_enrollments_with_start_date)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n            helper.log_info(status)\n            # getData(url_enrollments_with_start_date)\n        else:\n            url_enrollments_with_no_date = f\"https://api.mindbodyonline.com/public/v6/enrollment/enrollments?limit=200&offset=0\"\n            response_enrollments_with_no_date = requests.request(\"GET\", url_enrollments_with_no_date, headers=headers_enrollments)\n            enrollments_json_with_no_date=response_enrollments_with_no_date.json()\n            for i in  enrollments_json_with_no_date[\"Enrollments\"]:\n                \n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n            offset+=200\n            status = response_enrollments_with_no_date.status_code\n            status = \"API=\"+str(url_enrollments_with_no_date)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n            helper.log_info(status)\n            # getData(url_enrollments_with_no_date)\n      \n   \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Enrollments"}, {"name": "start_date", "value": ""}, {"name": "end_date", "value": ""}], "uuid": "91339876a3944fe396e4b10016dab83b", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:sale:acceptedcardtypes", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_sale_acceptedcardstypes", "title": "Sale-AcceptedCardsTypes", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Sale-AcceptedCardsTypes", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Sale-AcceptedCardsTypes"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Sale-AcceptedCardsTypes", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    # url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    # payload_token = json.dumps({\n    #     \"Username\": opt_username,\n    #     \"Password\": opt_password\n    # })\n    # headers_token = {\n    #     'User-Agent': opt_app_source_name,\n    #     'Content-Type': 'application/json',\n    #     'Api-Key': opt_api_key,\n    #     'SiteId': opt_siteid,\n    # }\n    \n    \n    # response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    # response_token_json=response_token.json()\n    # token=\"\"\n    # for i in response_token_json:\n    #     token=response_token_json[\"AccessToken\"]\n        \n    ##\n    \n\n\n    headers_acceptedcardtypes = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n    }\n    try:\n        url_acceptedcardtypes = \"https://api.mindbodyonline.com/public/v6/sale/acceptedcardtypes\"\n        response_acceptedcardtypes = requests.request(\"GET\", url_acceptedcardtypes, headers=headers_acceptedcardtypes)\n        response_acceptedcardtypes_json=response_acceptedcardtypes.json()\n        \n        final_result = []\n        count=0\n        for i in  response_acceptedcardtypes_json:\n            final_result.append(i)\n            count+=1\n\n        \n        status = response_acceptedcardtypes.status_code\n        # count = len(final_result)\n        status=f\"API={url_acceptedcardtypes} | response_code={status} | number_of_events={count}\"\n        helper.log_info(status)\n    except Exception as e:\n        helper.log_info(e)\n    event = helper.new_event(json.dumps(final_result))\n    ew.write_event(event)\n    \n    \n  \n", "customized_options": [{"name": "endpoint", "value": "Sale-AcceptedCardsTypes"}], "uuid": "d6c1d6f161e440458512b81cf7c8d2d0", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:client:clientvisits", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_client_clientvisits", "title": "Client-ClientVisits", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Client-ClientVisits", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Client-ClientVisits"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Client-ClientVisits", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    # start_date = helper.get_arg('start_date')\n    # end_date = helper.get_arg('end_date')\n    \n    \n    ########################### Getting Token ######################################################\n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ############################### Client Visit API #########################################################\n\n    headers_client = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Authorization': token,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n    }\n    \n    \n    url_client = \"https://api.mindbodyonline.com/public/v6/client/clients\"\n    response_client = requests.request(\"GET\", url_client, headers=headers_client)\n    response_client_json=response_client.json()\n    total_result = response_client_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count=0\n    Id=[]\n    \n    while offset <= total_result:\n        url_clients = \"https://api.mindbodyonline.com/public/v6/client/clients?limit=200&offset=\"+str(offset)\n        response_clients = requests.request(\"GET\", url_clients, headers=headers_client)\n        response_clients_json=response_clients.json()\n        offset+=200\n        for j in response_clients_json[\"Clients\"]:\n            Id.append(str(j[\"Id\"]))\n            \n    for i in Id:\n        try:\n            url_client_visits = \"https://api.mindbodyonline.com/public/v6/client/clientvisits?ClientId=\"+i\n            response_client_visits = requests.request(\"GET\", url_client_visits, headers=headers_client)\n            response_client_visits_json=response_client_visits.json()\n            for j in response_client_visits_json[\"Visits\"]:\n                state = helper.get_check_point(str(j['Id']))\n                if state is None:\n                    event = helper.new_event(json.dumps(j,indent=2))\n                    ew.write_event(event)\n                    count+=1\n                    helper.save_check_point(str(j['Id']), \"Indexed\")\n                # helper.delete_check_point(str(j['Id']))\n        except Exception as e:\n            pass\n   \n \n    status = response_client_visits.status_code\n    status = \"API=\"+\"https://api.mindbodyonline.com/public/v6/client/clientvisits\"+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n    helper.log_info(status)\n\n", "customized_options": [{"name": "endpoint", "value": "Client-ClientVisits"}], "uuid": "0c1141cf7a6f4527a5286d172861f1f8", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:site:sessiontypes", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_site_sessiontypes", "title": "Site-SessionTypes", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Site-SessionTypes", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Site-SessionTypes"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Site-SessionTypes", "placeholder": ""}], "code": "\n# encoding = utf-8\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    \n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    \n    \n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ##\n    url_sessiontypes = \"https://api.mindbodyonline.com/public/v6/site/sessiontypes\"\n\n    headers_sessiontypes  = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Authorization': token,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid,\n    }\n    \n    response_sessiontypes  = requests.request(\"GET\", url_sessiontypes , headers=headers_sessiontypes )\n    response_sessiontypes_json=response_sessiontypes.json()\n    \n    # final_result = []\n    total_result = response_sessiontypes_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count = 0\n    while offset <= total_result:\n        url_sessiontypes_offset = f\"https://api.mindbodyonline.com/public/v6/site/sessiontypes?limit=200&offset={offset}\"\n        response_sessiontypes_offset = requests.request(\"GET\", url_sessiontypes_offset, headers=headers_sessiontypes)\n        response_sessiontypes_offset_json=response_sessiontypes_offset.json()\n        for i in response_sessiontypes_offset_json[\"SessionTypes\"]:\n            state = helper.get_check_point(str(i[\"Id\"]))\n            if state is None:\n                # final_result.append(i)\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n                helper.save_check_point(str(i[\"Id\"]), \"Indexed\")\n            #helper.delete_check_point(str(i[\"Id\"]))\n        offset+=200\n        \n    \n    status = response_sessiontypes.status_code\n    # count = len(final_result)\n    status = \"API=\"+str(url_sessiontypes)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n    helper.log_info(status)\n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \n    # final_result = []\n    # for i in response_sessiontypes_json[\"SessionTypes\"]:\n    #     state = helper.get_check_point(str(i[\"Id\"]))\n    #     if state is None:\n    #         final_result.append(i)\n    #         helper.save_check_point(str(i[\"Id\"]), \"Indexed\")\n    #     # helper.delete_check_point(str(i[\"Id\"]))\n    # status = response_sessiontypes.status_code\n    # count = len(final_result)\n    # status = \"The API=\"+str(url_sessiontypes)+\"  | response_code= \"+str(status)+\"  | number_of_events=\"+str(count)\n    # helper.log_info(status)\n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Site-SessionTypes"}], "uuid": "4e115aee968b4249a63259a5198102a2", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:sale:custompaymentmethods", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_sale_custompaymentmethods", "title": "Sale-CustomPaymentMethods", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Sale-CustomPaymentMethods", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Sale-CustomPaymentMethods"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Sale-CustomPaymentMethods", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    # url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    # payload_token = json.dumps({\n    #     \"Username\": opt_username,\n    #     \"Password\": opt_password\n    # })\n    # headers_token = {\n    #     'User-Agent': opt_app_source_name,\n    #     'Content-Type': 'application/json',\n    #     'Api-Key': opt_api_key,\n    #     'SiteId': opt_siteid,\n    # }\n    \n    \n    # response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    # response_token_json=response_token.json()\n    # token=\"\"\n    # for i in response_token_json:\n    #     token=response_token_json[\"AccessToken\"]\n        \n    ##\n    \n\n\n\n    headers_custompaymentmethods = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n    }\n    \n    url_custompaymentmethods = \"https://api.mindbodyonline.com/public/v6/sale/custompaymentmethods\"\n    response_custompaymentmethods = requests.request(\"GET\", url_custompaymentmethods, headers=headers_custompaymentmethods)\n    response_custompaymentmethods_json=response_custompaymentmethods.json()\n    \n    # final_result = []\n    total_result = response_custompaymentmethods_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count = 0\n    while offset <= total_result:\n        url_custompaymentmethod = f\"https://api.mindbodyonline.com/public/v6/sale/custompaymentmethods?limit=200&offset={offset}\"\n        response_custompaymentmethod = requests.request(\"GET\", url_custompaymentmethod, headers=headers_custompaymentmethods)\n        response_custompaymentmethod_json=response_custompaymentmethod.json()\n        for i in  response_custompaymentmethod_json[\"PaymentMethods\"]:\n            state = helper.get_check_point(str(i[\"Id\"])+i[\"Name\"])\n            if state is None:\n                # final_result.append(i)\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n                helper.save_check_point(str(i[\"Id\"])+i[\"Name\"], \"Indexed\")\n            # helper.delete_check_point(str(i[\"Id\"])+i[\"Name\"])\n        offset+=200\n    status = response_custompaymentmethods.status_code\n    # count = len(final_result)\n    status = \"The API=\"+str(url_custompaymentmethods)+\"  | response_code=\"+str(status)+\"  | number_of_events=\"+str(count)\n    helper.log_info(status)\n    \n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Sale-CustomPaymentMethods"}], "uuid": "dc9b163d4d6b41ad8f73abb097ca0f4d", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:sale:sales", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_sale_sales", "title": "Sale-Sales", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Sale-Sales", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Sale-Sales"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Sale-Sales", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    api_count=0\n    \n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    api_count=api_count+1\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    \n    \n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ##\n    url_sales = \"https://api.mindbodyonline.com/public/v6/sale/sales\"\n    api_count=api_count+1\n\n    headers_sales = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Authorization': token,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid,\n    }\n    \n    response_sales = requests.request(\"GET\", url_sales, headers=headers_sales)\n    response_sales_json=response_sales.json()\n    \n    \n    # final_result = []\n    total_result = response_sales_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count=0\n    \n    while offset <= total_result:\n        url_sale = f\"https://api.mindbodyonline.com/public/v6/sale/sales?limit=200&offset={offset}\"\n        api_count=api_count+1\n        response_sale = requests.request(\"GET\", url_sale, headers=headers_sales)\n        response_sale_json=response_sale.json()\n        for i in response_sale_json[\"Sales\"]:\n            # OriginalSaleDateTime = i[\"OriginalSaleDateTime\"]\n            # convert_to_epoch=datetime.datetime.strptime(OriginalSaleDateTime, \"%Y-%m-%dT%H:%M:%SZ\").timestamp()\n            state = helper.get_check_point(str(i[\"Id\"])+i[\"OriginalSaleDateTime\"])\n            if state is None:\n                # final_result.append(i)\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n                helper.save_check_point(str(i[\"Id\"])+i[\"OriginalSaleDateTime\"], \"Indexed\")\n            #helper.delete_check_point(str(i[\"Id\"])+i[\"OriginalSaleDateTime\"])\n        offset +=200\n        \n    status = response_sales.status_code\n    # count = len(final_result)\n    # status = \"The API=\"+str(url_sales)+\"  | response_code= \"+str(status)+\"  | number_of_events=\"+str(count)\n    status = f\"The API={url_sales}  | response_code={status}  | number_of_events={count} | API_Hit_Count={api_count}\"\n    helper.log_info(status)\n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Sale-Sales"}], "uuid": "a95d642eda0246c19e8a49344e8ed2f3", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:sale:contracts", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_sale_contracts", "title": "Sale-Contracts", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Sale-Contracts", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Sale-Contracts"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Sale-Contracts", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n\n    \n    \n    ########################### Getting Token ######################################################\n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ############################### Enrollments API #########################################################\n\n    headers_client = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Authorization': token,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n    }\n    url_client = \"https://api.mindbodyonline.com/public/v6/site/locations\"\n    response_client = requests.request(\"GET\", url_client, headers=headers_client)\n    response_client_json=response_client.json()\n    # total_result = response_client_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    total_result= 200\n    count=0\n    # Id=[]\n    status=0\n    flag=0\n    for j in range(0,total_result,200):\n        try:\n            url_clients = \"https://api.mindbodyonline.com/public/v6/site/locations?limit=200&offset=\"+str(offset)\n            response_clients = requests.request(\"GET\", url_clients, headers=headers_client)\n            response_clients_json=response_clients.json()\n            offset+=200\n            for k in response_clients_json[\"Locations\"]:\n                try:\n                    url_clientcompleteinfo = \"https://api.mindbodyonline.com/public/v6/sale/contracts?locationId=\"+str(k[\"Id\"])\n                    response_clientcompleteinfo = requests.request(\"GET\", url_clientcompleteinfo, headers=headers_client)\n                    response_clientcompleteinfo_json=response_clientcompleteinfo.json()\n                    \n                    total_result1 = response_clientcompleteinfo_json.get(\"PaginationResponse\").get(\"TotalResults\")\n                    offset1 = 0\n                    for j in range(0,total_result1,200):\n                        url_clientcompleteinfo1 = \"https://api.mindbodyonline.com/public/v6/sale/contracts?limit=200&offset=\"+str(offset1)+\"&locationId=\"+str(k[\"Id\"])\n                        response_clientcompleteinfo1 = requests.request(\"GET\", url_clientcompleteinfo1, headers=headers_client)\n                        response_clientcompleteinfo_json1=response_clientcompleteinfo1.json()\n                        \n                        for v in response_clientcompleteinfo_json1[\"Contracts\"]:\n                            event = helper.new_event(json.dumps(v,indent=2))\n                            ew.write_event(event)\n                            count+=1\n                        offset1+=200  \n                    # status = response_clientcompleteinfo.status_code\n                    # if(status==200):\n                    #     checkpoint=str(response_clientcompleteinfo_json.get('Client')['UniqueId'])+ str(response_clientcompleteinfo_json.get('Client')['LastModifiedDateTime'])\n                    #     state = helper.get_check_point(str(checkpoint))\n                    #     flag=1\n                    #     if state is None:\n                    #         event = helper.new_event(json.dumps(response_clientcompleteinfo_json,indent=2))\n                    #         ew.write_event(event)\n                    #         count+=1\n                    #         helper.save_check_point(str(checkpoint), \"Indexed\")\n                    #     helper.delete_check_point(str(checkpoint))\n                    # else:\n                    #     pass\n                except Exception as e:\n                    pass  \n        except Exception as e:\n            pass\n    \n    # eve = helper.new_event(str(count))\n    # ew.write_event(eve)\n    \n    # if(flag==1):\n    #     status=200\n    # else:\n    status = response_clientcompleteinfo1.status_code\n        \n    status = f\"The API=https://api.mindbodyonline.com/public/v6/sale/contracts | response_code={status} | number_of_events={count}\"\n    helper.log_info(status)\n    \n    \n    # for j in range(0,total_result,200):\n    #     try:\n    #         url_clients = f\"https://api.mindbodyonline.com/public/v6/client/clients?limit=200&offset={offset}\"\n    #         response_clients = requests.request(\"GET\", url_clients, headers=headers_client)\n    #         response_clients_json=response_clients.json()\n    #         offset+=200\n            \n    #         for k in response_clients_json[\"Clients\"]:\n    #             Id.append(str(k[\"UniqueId\"]))\n    #     except Exception as e:\n    #         pass\n            \n  \n    # IdLength = len(Id)\n    # increment=0\n        \n    # for l in range(0,IdLength):\n    #     try:\n    #         url_clientcompleteinfo = f\"https://api.mindbodyonline.com/public/v6/client/clientcompleteinfo?ClientId={Id[increment]}\"\n    #         response_clientcompleteinfo = requests.request(\"GET\", url_clientcompleteinfo, headers=headers_client)\n    #         response_clientcompleteinfo_json=response_clientcompleteinfo.json()\n    #         increment+=1\n    #         checkpoint=str(response_clientcompleteinfo_json.get('Client')['UniqueId'])+ str(response_clientcompleteinfo_json.get('Client')['LastModifiedDateTime'])\n            # state = helper.get_check_point(str(checkpoint))\n            # if state is None:\n            #     event = helper.new_event(json.dumps(response_clientcompleteinfo_json,indent=2))\n            #     ew.write_event(event)\n            #     count+=1\n            #     helper.save_check_point(str(checkpoint), \"Indexed\")\n            # helper.delete_check_point(str(checkpoint))\n    #     except Exception as e:\n    #         pass\n        \n    # even = helper.new_event(str(count))\n    # ew.write_event(even)\n            \n    # status = response_clientcompleteinfo.status_code\n    # status = f\"The API=https://api.mindbodyonline.com/public/v6/client/clientcompleteinfo | response_code={status} | number_of_events={count}\"\n    # helper.log_info(status)\n        \n        \n   \n\n      \n   ", "customized_options": [{"name": "endpoint", "value": "Sale-Contracts"}], "uuid": "05a20440f21b42b4bb1475e740baf99f", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:client:clients", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_client_clients", "title": "Client-Clients", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Client-Clients", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Client-Clients"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Client-Clients", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    \n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    \n    \n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ##\n    url_client = \"https://api.mindbodyonline.com/public/v6/client/clients\"\n\n    headers_client = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Authorization': token,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid,\n    }\n    \n    response_client = requests.request(\"GET\", url_client, headers=headers_client)\n    response_client_json=response_client.json()\n    \n    \n    # final_result = []\n    \n    total_result = response_client_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    while offset <= total_result:\n        url_clients = f\"https://api.mindbodyonline.com/public/v6/client/clients?limit=200&offset={offset}\"\n        response_clients = requests.request(\"GET\", url_clients, headers=headers_client)\n        response_clients_json=response_clients.json()\n        for i in response_clients_json[\"Clients\"]:\n            event = helper.new_event(json.dumps(i,indent=2))\n            ew.write_event(event)\n        offset +=200\n        # final_result.append(i)\n        # state = helper.get_check_point(i[\"Id\"] + i[\"LastModifiedDateTime\"])\n        # if state is None:\n        #     final_result.append(i)\n        #     helper.save_check_point(str(i[\"Id\"] + i[\"LastModifiedDateTime\"]), \"Indexed\")\n        # helper.delete_check_point(str(i[\"Id\"] + i[\"LastModifiedDateTime\"]))\n    \n    status = response_client.status_code\n    # count = len(final_result)\n    # status = \"The API=\"+str(url_client)+\"  | response_code= \"+str(status)+\"  | number_of_events=\"+total_result\n    status = f\"The API={url_client} | response_code={status} | number_of_events={total_result}\"\n    helper.log_info(status)\n\n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Client-Clients"}], "uuid": "8b00ec9111e24581a89afaf7a4d70931", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:client:contactlogtypes", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_clients_contactlogtypes", "title": "Clients-ContactLogTypes", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "Clients-ContactLogTypes", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Clients-ContactLogTypes"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Clients-ContactLogTypes", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    \n    \n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ##\n    url_contactlogtypes = \"https://api.mindbodyonline.com/public/v6/client/contactlogtypes\"\n\n\n\n    headers_contactlogtypes = {\n        'User-Agent':opt_app_source_name,\n        'Authorization': token,\n        'Api-Key':opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': '-99',\n    }\n    response_contactlogtypes = requests.request(\"GET\", url_contactlogtypes, headers=headers_contactlogtypes)\n    response_contactlogtypes_json=response_contactlogtypes.json()\n        \n    \n     # final_result = []\n    total_result = response_contactlogtypes_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count = 0\n    while offset <= total_result:\n        url_contactlogtypes_offset = f\"https://api.mindbodyonline.com/public/v6/client/contactlogtypes?limit=200&offset={offset}\"\n        response_contactlogtypes_offset = requests.request(\"GET\", url_contactlogtypes_offset, headers=headers_contactlogtypes)\n        response_contactlogtypes_offset_json=response_contactlogtypes_offset.json()\n        for i in response_contactlogtypes_offset_json[\"ContactLogTypes\"]:\n            state = helper.get_check_point(str(i[\"Id\"])+i[\"Name\"])\n            if state is None:\n                # final_result.append(i)\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count+=1\n                helper.save_check_point(str(i[\"Id\"])+i[\"Name\"], \"Indexed\")\n            #helper.delete_check_point(str(i[\"Id\"])+i[\"Name\"])\n        offset+=200\n        \n    \n    status = response_contactlogtypes.status_code\n    # count = len(final_result)\n    status = \"API=\"+str(url_contactlogtypes)+\" | response_code=\"+str(status)+\" | number_of_events=\"+str(count)\n    helper.log_info(status)\n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \n    # final_result = []\n    # for i in response_contactlogtypes_json[\"ContactLogTypes\"]:\n    #     state = helper.get_check_point(str(i[\"Id\"])+i[\"Name\"])\n    #     if state is None:\n    #         final_result.append(i)\n    #         helper.save_check_point(str(i[\"Id\"])+i[\"Name\"], \"Indexed\")\n    #     helper.delete_check_point(str(i[\"Id\"])+i[\"Name\"])\n    # status = response_contactlogtypes.status_code\n    # count = len(final_result)\n    # status = \"The API=\"+str(url_contactlogtypes)+\"  | response_code= \"+str(status)+\"  | number_of_events=\"+str(count)\n    # helper.log_info(status)\n    # event = helper.new_event(json.dumps(final_result))\n    # ew.write_event(event)\n    \n    \n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_user_agent = helper.get_arg('user_agent')\n    opt_api_key = helper.get_arg('api_key')\n    opt_siteid = helper.get_arg('siteid')\n    opt_password = helper.get_arg('password')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_username = helper.get_arg('username', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n    opt_user_agent = helper.get_arg('user_agent', stanza_name)\n    opt_api_key = helper.get_arg('api_key', stanza_name)\n    opt_siteid = helper.get_arg('siteid', stanza_name)\n    opt_password = helper.get_arg('password', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "endpoint", "value": "Clients-ContactLogTypes"}], "uuid": "e8bda856a79247ae8b63e863b25c14fb", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:client:clients-v3", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_client_clients_v3", "title": "client-clients_v3", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "client-clients_v3", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "client-clients_v3"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "client-clients_v3", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport hashlib\nimport re\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # user_agent = definition.parameters.get('user_agent', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # siteid = definition.parameters.get('siteid', None)\n    # password = definition.parameters.get('password', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_username = helper.get_global_setting('username')\n    opt_password = helper.get_global_setting('password')\n    opt_app_source_name = helper.get_global_setting('app_source_name')\n    opt_api_key = helper.get_global_setting('api_key')\n    opt_siteid = helper.get_global_setting('siteid')\n    key = helper.get_global_setting('activation_key')\n    app=\"Mindbodyonline Add-on for Splunk\"\n    if key:\n        try:\n            app_md =hashlib.md5(app.encode('utf-8'))\n            app_hex=app_md.hexdigest().upper()\n            app_dec = int(app_hex,16)\n            app_dec_sum=sum([int(x) for x in str(int(app_dec))])\n            key_time = key[-10:]\n            key_time= key_time[::-1]\n            match_key=re.search('[a-zA-Z]', key_time)\n            key = key[:-10]\n            vbits = key[:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    \n    api_count=0\n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    api_count=api_count+1\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    \n    \n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    ##\n    url_client = \"https://api.mindbodyonline.com/public/v6/client/clients\"\n    api_count=api_count+1\n\n    headers_client = {\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Authorization': token,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid,\n    }\n    \n    response_client = requests.request(\"GET\", url_client, headers=headers_client)\n    response_client_json=response_client.json()\n    \n    total_result = response_client_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count=0\n    \n    for j in range(0,total_result,200):\n        try:\n            url_clients = \"https://api.mindbodyonline.com/public/v6/client/clients?limit=200&offset=\"+str(offset)\n            api_count=api_count+1\n            response_clients = requests.request(\"GET\", url_clients, headers=headers_client)\n            response_clients_json=response_clients.json()\n            offset+=200\n            for k in response_clients_json[\"Clients\"]:\n                try:\n                    checkpoint=str(k[\"UniqueId\"])+str(k[\"FirstAppointmentDate\"])\n                    state = helper.get_check_point(str(checkpoint))\n                    if state is None:\n                        event = helper.new_event(json.dumps(k,indent=2))\n                        ew.write_event(event)\n                        count+=1\n                        helper.save_check_point(str(checkpoint), \"Indexed\")\n                    # helper.delete_check_point(str(checkpoint))\n                except Exception as e:\n                    pass\n        except Exception as e:\n            pass\n\n    # while offset <= total_result:\n    #     url_clients = f\"https://api.mindbodyonline.com/public/v6/client/clients?limit=200&offset={offset}\"\n    #     response_clients = requests.request(\"GET\", url_clients, headers=headers_client)\n    #     response_clients_json=response_clients.json()\n    #     offset +=200\n    #     try:\n    #         for j in response_clients_json[\"Clients\"]:\n    #             state = helper.get_check_point(str(j[\"Id\"])+j[\"LastModifiedDateTime\"])\n    #             if state is None:\n    #                 event = helper.new_event(json.dumps(j,indent=2))\n    #                 ew.write_event(event)\n    #                 count+=1\n    #                 helper.save_check_point(str(j[\"Id\"]+j[\"LastModifiedDateTime\"]), \"Indexed\")\n    #             helper.delete_check_point(str(j[\"Id\"]+j[\"LastModifiedDateTime\"]))\n    #     except Exception as e:\n    #         pass\n    \n    status = response_client.status_code\n    status = f\"The API={url_client} | response_code={status} | number_of_events={count} | API_Hit_Count={api_count}\"\n    helper.log_info(status)\n\n\n    \n    \n    ", "customized_options": [{"name": "endpoint", "value": "client-clients_v3"}], "uuid": "e330b1b5fbef4fe59c4c62bdfe8e7bb6", "sample_count": 0}, {"index": "default", "sourcetype": "mbo:client:clients-v2", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mbo_client_clients_v2", "title": "client-clients_v2", "description": "", "type": "customized", "parameters": [{"required": false, "name": "endpoint", "label": "Endpoint", "default_value": "client-clients_v2", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "client-clients_v2"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "client-clients_v2", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimp