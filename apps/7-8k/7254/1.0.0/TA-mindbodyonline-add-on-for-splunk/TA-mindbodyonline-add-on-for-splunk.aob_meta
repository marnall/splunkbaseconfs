:-32]\n            key = key[-32:]\n            dec = int(key, 16)\n            li=[int(x) for x in str(int(dec))]\n            s=sum(list(li))\n            current_ts = time.time()\n            if len(key)!=32 or match_key:\n                helper.log_info(\"Actvation Key did not matched, kindly check if you have entered the correct key\")\n                sys.exit(2)\n            else:\n                if current_ts-int(key_time)>7776000:\n                    helper.log_info(\"kindly check if you have entered the correct key OR Activation Key has expired, kindly get a new one\")\n                    sys.exit(2)\n                if not int(s)+int(app_dec_sum)==int(vbits):\n                    helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n                    sys.exit(2)\n            helper.log_info(\"Activation Key Successfullly Entered\")\n        except Exception as e:\n            helper.log_info(\"Actvation Key did not matched, kindly check if you have entered correct key\")\n            sys.exit(2)\n    else:\n        helper.log_info(\"Enter the Activation Key in Configuration>Add-on Settings\")\n        sys.exit(2)\n    api_count=0\n    \n    url_token = \"https://api.mindbodyonline.com/public/v6/usertoken/issue\"\n    api_count=api_count+1\n    payload_token = json.dumps({\n        \"Username\": opt_username,\n        \"Password\": opt_password\n    })\n    headers_token = {\n        'User-Agent': opt_app_source_name,\n        'Content-Type': 'application/json',\n        'Api-Key': opt_api_key,\n        'SiteId': opt_siteid,\n    }\n    \n    \n    response_token = requests.request(\"POST\", url_token, headers=headers_token, data=payload_token)\n    response_token_json=response_token.json()\n    token=\"\"\n    for i in response_token_json:\n        token=response_token_json[\"AccessToken\"]\n        \n    url_transactions = \"https://api.mindbodyonline.com/public/v6/sale/transactions\"\n    api_count=api_count+1\n\n \n    headers_transactions = {\n\n        'User-Agent': opt_app_source_name,\n        'Api-Key': opt_api_key,\n        'Content-Type': 'application/json',\n        'SiteId': opt_siteid\n\n    }\n\n \n\n    response_transactions = requests.request(\"GET\", url_transactions, headers=headers_transactions)\n\n    response_transactions_json=response_transactions.json()   \n    \n    # final_result = []\n    # count=0\n    # for i in  response_transactions_json[\"Transactions\"]:\n    #     final_result.append(i)\n    #     count+=1\n        \n    final_result = []\n    total_result = response_transactions_json.get(\"PaginationResponse\").get(\"TotalResults\")\n    offset = 0\n    count=0\n    while offset <= total_result:\n        url_transaction = f\"https://api.mindbodyonline.com/public/v6/sale/transactions?limit=200&offset={offset}\"\n        api_count=api_count+1\n        offset +=200\n        response_transaction = requests.request(\"GET\", url_transaction, headers=headers_transactions)\n        response_transaction_json=response_transaction.json()\n        \n        for i in response_transaction_json[\"Transactions\"]:\n            state = helper.get_check_point(str(i[\"TransactionId\"]))\n            if state is None:\n                final_result.append(i)\n                helper.save_check_point(str(i[\"TransactionId\"]), \"Indexed\")\n                count+=1\n            # helper.delete_check_point(str(i[\"TransactionId\"]))\n        \n    status = response_transactions.status_code\n        # count = len(final_result)\n    status=f\"API={url_transactions} | response_code={status} | number_of_events={count} | API_Hit_Count={api_count}\"\n    helper.log_info(status)\n    \n    event = helper.new_event(json.dumps(final_result))\n    ew.write_event(event)\n        \n        \n        \n        \n        ", "customized_options": [{"name": "endpoint", "value": "Sale-Transactions "}], "uuid": "517c73b037bf423aa7cea5e4c9b1cb4b", "sample_count": 0}, {"index":