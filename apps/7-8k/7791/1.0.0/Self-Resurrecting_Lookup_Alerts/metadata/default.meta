# Application-level permissions

[]
access = read : [ * ], write : [ sc_admin, admin, power ]

### EVENT TYPES
[eventtypes]
export = system
owner = nobody

### MACROS
[macros]
export = system
owner = nobody

### LOOKUPS
[lookups]
export = system
owner = nobody

### PROPS
[props]
export = system
owner = nobody

### SAVEDSEARCHES
[savedsearches]
export = system
owner = nobody

### TRANSFORMS
[transforms]
export = system
owner = nobody

### VIEWSTATES: even normal users should be able to create shared viewstates
[viewstates]
access = read : [ * ], write : [ * ]
export = system
