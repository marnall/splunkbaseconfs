{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "vsp1oalerts", "short_name": "vsp1oalerts", "parameters": [], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets and sets the log level\n    helper.set_log_level(helper.log_level)\n\n    # The following example gets the setup parameters and prints them to the log\n    access_token_url = helper.get_global_setting(\"access_token_url\")\n    helper.log_info(\"access_token_url={}\".format(access_token_url))\n    client_id = helper.get_global_setting(\"client_id\")\n    helper.log_info(\"client_id={}\".format(client_id))\n    client_secret = helper.get_global_setting(\"client_secret\")\n    helper.log_info(\"client_secret={}\".format(client_secret))\n    prometheus_base_url = helper.get_global_setting(\"prometheus_base_url\")\n    helper.log_info(\"prometheus_base_url={}\".format(prometheus_base_url))\n    prometheus_region = helper.get_global_setting(\"prometheus_region\")\n    helper.log_info(\"prometheus_region={}\".format(prometheus_region))\n    prometheus_cluster_name = helper.get_global_setting(\"prometheus_cluster_name\")\n    helper.log_info(\"prometheus_cluster_name={}\".format(prometheus_cluster_name))\n    csrf_token_generation_url = helper.get_global_setting(\"csrf_token_generation_url\")\n    helper.log_info(\"csrf_token_generation_url={}\".format(csrf_token_generation_url))\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action vsp1oalerts started.\")\n\n    # TODO: Implement your alert action logic here\n    return 0\n", "uuid": "3de8eb09af1a4299a87fa71f09b58f5d"}]}, "basic_builder": {"appname": "TA-hitachi-vsp-one-object", "friendly_name": "Hitachi VSP One Object", "version": "1.0.2", "author": "Karthik Raja Balasubramanian, Raghavi Manga", "description": "This Splunk add-on is designed to collect Prometheus metrics from VSP One Object storage systems, enabling real-time threat detection and monitoring within the Splunk platform.", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.4.1", "tab_build_no": "0", "build_no": 3}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "VSPOneObject", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "vsp1o", "title": "VSP1O", "description": "Collecting the Prometheus Metrics from Hitachi VSP One Object Storage v3.x", "type": "customized", "parameters": [{"name": "polling_interval", "label": "Polling Interval", "help_string": "", "required": true, "format_type": "text", "default_value": "30", "placeholder": "", "type": "text", "value": "30"}, {"name": "prometheus_query", "label": "Prometheus Query", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "scrape_samples_scraped"}], "data_inputs_options": [{"type": "customized_var", "name": "polling_interval", "title": "Polling Interval", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "30", "placeholder": ""}, {"type": "customized_var", "name": "prometheus_query", "title": "Prometheus Query", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "#!/usr/bin/env python3\r\nimport requests\r\nimport json\r\nimport logging\r\nfrom urllib.parse import urlparse\r\n\r\ndef mask_sensitive_data(text, mask_char='*'):\r\n    \"\"\"Mask sensitive data in logs.\"\"\"\r\n    return mask_char * 8 if text else ''\r\n\r\ndef collect_events(helper, ew):\r\n    \"\"\"\r\n    Retrieves an access token from the token endpoint, then uses the CSRF token URL\r\n    to obtain the CSRF token and session cookies. Finally, it queries the Prometheus API.\r\n    \"\"\"\r\n\r\n    # Set up Splunk logging\r\n    logger = logging.getLogger('splunk')\r\n    logger.setLevel(logging.INFO)\r\n\r\n    # Retrieve global settings and input parameters\r\n    REGION = helper.get_global_setting(\"prometheus_region\").strip()\r\n    CLUSTER_NAME = helper.get_global_setting(\"prometheus_cluster_name\").strip()\r\n    helper.log_info(\"CLUSTER_NAME: \" + CLUSTER_NAME)\r\n    CLIENT_ID = helper.get_global_setting(\"client_id\").strip()\r\n    helper.log_info(\"CLIENT_ID: \" + CLIENT_ID)\r\n    CLIENT_SECRET = helper.get_global_setting(\"client_secret\").strip()\r\n    helper.log_info(\"CLIENT_SECRET: [REDACTED]\")\r\n    PROM_QUERY = helper.get_arg(\"prometheus_query\").strip()\r\n    helper.log_info(\"PROM_QUERY: \" + PROM_QUERY)\r\n\r\n    # Validate required values\r\n    if not (REGION and CLUSTER_NAME and CLIENT_ID and CLIENT_SECRET and PROM_QUERY):\r\n        raise Exception(\"One or more required global settings or input parameters are missing.\")\r\n\r\n    # Construct token endpoint using the GMS domain.\r\n    token_endpoint = f\"https://admin.gms.{CLUSTER_NAME}/ui/auth/realms/vsp-object/protocol/openid-connect/token\"\r\n    logger.info(\"token endpoint: \" + token_endpoint)\r\n    helper.log_info(\"Constructed token endpoint: \" + token_endpoint)\r\n\r\n    # Construct CSRF token URL\r\n    csrf_token_url_template = helper.get_global_setting(\"csrf_token_generation_url\").strip()\r\n    helper.log_info(\"csrf_token_url_template: \" + csrf_token_url_template)\r\n    csrf_token_url = csrf_token_url_template.replace(\"{{prometheus_region}}\", REGION).replace(\"{{cluster_name}}\", CLUSTER_NAME)\r\n    helper.log_info(\"Constructed CSRF token URL: \" + csrf_token_url)\r\n\r\n    # HTTPS Scheme Validation for CSRF URL (Line ~90 Fix)\r\n    if urlparse(csrf_token_url).scheme.lower() != 'https':\r\n        helper.log_error(\"Invalid csrf_token_generation_url: HTTPS scheme is required.\")\r\n        raise ValueError(\"csrf_token_generation_url must use HTTPS\")\r\n\r\n    # Construct Prometheus query endpoint\r\n    prometheus_base_url_template = helper.get_global_setting(\"prometheus_base_url\").strip()\r\n    prometheus_base_url = (prometheus_base_url_template\r\n                          .replace(\"{{prometheus_region}}\", REGION)\r\n                          .replace(\"{{cluster_name}}\", CLUSTER_NAME))\r\n    prom_endpoint = f\"{prometheus_base_url}{PROM_QUERY}\"\r\n    helper.log_info(\"Constructed Prometheus endpoint: \" + prom_endpoint)\r\n\r\n    # HTTPS Scheme Validation for Prometheus URL (Line ~113 Fix)\r\n    if urlparse(prometheus_base_url).scheme.lower() != 'https':\r\n        helper.log_error(\"Invalid prometheus_base_url: HTTPS scheme is required.\")\r\n        raise ValueError(\"prometheus_base_url must use HTTPS\")\r\n\r\n    #############################################\r\n    # 1. Get the Access (Bearer) Token\r\n    #############################################\r\n    token_payload = (\r\n        \"grant_type=client_credentials\"\r\n        \"&client_id=\" + CLIENT_ID +\r\n        \"&client_secret=\" + mask_sensitive_data(CLIENT_SECRET)\r\n    )\r\n    helper.log_info(\"Payload: \" + token_payload)\r\n\r\n    token_headers = {\r\n        \"Content-Type\": \"application/x-www-form-urlencoded\",\r\n        \"Accept\": \"application/json\",\r\n        \"User-Agent\": \"Mozilla/5.0\"\r\n    }\r\n\r\n    helper.log_info(\"Requesting access token from token endpoint...\")\r\n    token_response = requests.post(token_endpoint, data=token_payload.replace(mask_sensitive_data(CLIENT_SECRET), CLIENT_SECRET), headers=token_headers, verify=True)\r\n    helper.log_info(\"Token response status code: \" + str(token_response.status_code))\r\n\r\n    if token_response.status_code != 200:\r\n        raise Exception(\"Failed to get token: \" + token_response.text)\r\n\r\n    token_json = token_response.json()\r\n    access_token = token_json.get(\"access_token\")\r\n\r\n    if not access_token:\r\n        raise Exception(\"Access token not found in token response.\")\r\n    helper.log_info(\"Access token obtained: \" + mask_sensitive_data(access_token))\r\n\r\n    #############################################\r\n    # 2. Get the CSRF Token and Session Cookies\r\n    #############################################\r\n    session_obj = requests.Session()  # Create a session to persist cookies\r\n    helper.log_info(\"Retrieving CSRF token and session cookies from: \" + csrf_token_url)\r\n\r\n    csrf_response = session_obj.get(csrf_token_url, verify=True)\r\n\r\n    if csrf_response.status_code != 200:\r\n        helper.log_error(\"Failed to get CSRF token: \" + csrf_response.text)\r\n        raise Exception(\"Failed to get CSRF token: \" + csrf_response.text)\r\n\r\n    xsrf_token = session_obj.cookies.get(\"XSRF-TOKEN\")\r\n    vertx_session = session_obj.cookies.get(\"vertx-web.session\")\r\n    helper.log_info(\"XSRF Token: \" + mask_sensitive_data(xsrf_token))\r\n    helper.log_info(\"Vertx Session: \" + mask_sensitive_data(vertx_session))\r\n\r\n    #############################################\r\n    # 3. Query the Prometheus Endpoint\r\n    #############################################\r\n    query_headers = {\r\n        \"Authorization\": f\"Bearer {access_token}\",\r\n        \"Accept\": \"application/json\"\r\n    }\r\n\r\n    if xsrf_token:\r\n        query_headers[\"X-XSRF-TOKEN\"] = xsrf_token\r\n\r\n    helper.log_info(\"Querying Prometheus API at: \" + prom_endpoint)\r\n    prom_response = session_obj.get(prom_endpoint, headers=query_headers, verify=True, allow_redirects=True)\r\n    helper.log_info(\"Response Status: \" + str(prom_response.status_code))\r\n\r\n    content_type = prom_response.headers.get(\"Content-Type\", \"\").lower()\r\n    helper.log_info(\"Content Type: \" + content_type)\r\n\r\n    if \"application/json\" not in content_type:\r\n        helper.log_error(\"Received non-JSON response. Response body: [REDACTED]\")\r\n        raise Exception(\"Received non-JSON response, expected JSON. Check if the endpoint supports API access with your token.\")\r\n\r\n    try:\r\n        prom_data = prom_response.json()\r\n        helper.log_info(\"Prometheus API returned JSON: [REDACTED]\")\r\n\r\n        event = helper.new_event(\r\n            source=helper.get_input_type(),\r\n            index=helper.get_output_index(),\r\n            sourcetype=helper.get_sourcetype(),\r\n            data=json.dumps(prom_data)\r\n        )\r\n        helper.log_info(\"Index: \" + helper.get_output_index())\r\n        helper.log_info(\"Source Type: \" + helper.get_sourcetype())\r\n\r\n        ew.write_event(event)\r\n        helper.log_info(\"Successfully ingested Prometheus data into Splunk. Query: \" + PROM_QUERY)\r\n\r\n    except json.JSONDecodeError as e:\r\n        helper.log_error(\"Error decoding JSON: \" + str(e))\r\n        helper.log_error(\"Raw response: [REDACTED]\")\r\n        raise\r\n\r\nif __name__ == '__main__':\r\n    print(\"This script is intended to be run as a Splunk modular input.\")", "customized_options": [{"name": "polling_interval", "value": "30"}, {"name": "prometheus_query", "value": "scrape_samples_scraped"}], "uuid": "bccc73f271ab4bf89b61bf79abcc2bab", "sample_count": "30"}]}, "field_extraction_builder": {"prometheusmetrics": {"is_parsed": true, "data_format": "json"}, "VSPOneObject": {"data_format": "unstructured_data"}}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": true, "name": "access_token_url", "label": "Access Token URL", "default_value": "https://admin.gms.{{cluster_name}}/ui/auth/realms/vsp-object/protocol/openid-connect/token", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "https://admin.gms.{{cluster_name}}/ui/auth/realms/vsp-object/protocol/openid-connect/token"}, {"required": true, "name": "client_id", "label": "Client ID", "default_value": "vsp-object-client", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "vsp-object-client"}, {"required": true, "name": "client_secret", "label": "Client Secret", "placeholder": "", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}, {"required": true, "name": "prometheus_base_url", "label": "Prometheus Base URL", "default_value": "https://admin.{{prometheus_region}}.{{cluster_name}}/ui/prometheus/api/v1/query?query=", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "https://admin.{{prometheus_region}}.{{cluster_name}}/ui/prometheus/api/v1/query?query="}, {"required": true, "name": "prometheus_region", "label": "Prometheus Region", "default_value": "us-east-1", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "us-east-1"}, {"required": true, "name": "prometheus_cluster_name", "label": "Prometheus Cluster Name", "default_value": "vsp1o.vspoc.sea.gpsecontent.local", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "vsp1o.vspoc.sea.gpsecontent.local"}, {"required": true, "name": "csrf_token_generation_url", "label": "CSRF Token Generation URL", "default_value": "https://admin.{{prometheus_region}}.{{cluster_name}}/mapi/v1/csrf", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "https://admin.{{prometheus_region}}.{{cluster_name}}/mapi/v1/csrf"}]}}, "sourcetype_builder": {"VSPOneObject": {"metadata": {"event_count": 0, "data_input_name": "vsp1o", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1745259853_86"}}