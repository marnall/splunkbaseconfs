# Example configuration for SOCRadar TAXII 2.1 Collector
# Copy this to local/inputs.conf and update with your settings

[socradar_taxii21]
index = default
start_by_shell = false
python.version = python3
sourcetype = socradar:taxii
interval = 30

# Example input configuration
# [socradar_taxii21://your_input_name_here]
# api_root = radar_alpha
# collection_ids = your-collection-id-here
# index = socradar_taxii21
# interval = 86400
# disabled = 0