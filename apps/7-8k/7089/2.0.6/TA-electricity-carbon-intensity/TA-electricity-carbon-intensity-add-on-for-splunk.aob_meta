{"basic_builder": {"appname": "TA-electricity-carbon-intensity", "friendly_name": "Splunk Add-on for Electricity Carbon Intensity", "version": "2.0.0", "author": "Sebastian Schimper", "description": "", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.3", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "EM:carbonintensity", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "electricity_maps_carbon_intensity_latest", "title": "Electricity Maps Carbon Intensity - Latest", "description": "Gets data for the current hour, for the specified zone(s).", "type": "customized", "parameters": [{"name": "electricity_maps_account", "label": "Electricity Maps Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": ""}, {"name": "zone_s_", "label": "Zone(s)", "help_string": "Please enter a list, separated by a comma. For a list of available zones, please run the following command: \"curl 'https://api.electricitymap.org/v3/zones'\"", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "electricity_maps_account", "title": "Electricity Maps Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "zone_s_", "title": "Zone(s)", "description": "Please enter a list, separated by a comma. For a list of available zones, please run the following command: \"curl 'https://api.electricitymap.org/v3/zones'\"", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport requests\nimport json\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # api_key = definition.parameters.get('api_key', None)\n    # zone = definition.parameters.get('zone', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n\n    # get user args\n    opt_electricity_maps_account = helper.get_arg(\"electricity_maps_account\")\n    opt_alternative_base_url = opt_electricity_maps_account.get(\"username\")\n    opt_zones = helper.get_arg(\"zone_s_\")\n\n    zones = opt_zones.split(\",\")\n    \n    url = \"https://api.electricitymap.org/v3/carbon-intensity/latest\"\n    \n    if(opt_alternative_base_url and len(opt_alternative_base_url) != 0):\n        url = opt_alternative_base_url + \"/carbon-intensity/latest\"\n\n    headers = {\n        \"X-BLOBR-KEY\": opt_electricity_maps_account.get(\"password\")\n    }\n\n    for zone in zones:\n        params = {\"zone\" : zone.strip()}\n        data = ut.make_api_call(url=url, params=params, headers=headers, helper=helper)\n        if(ut.electricity_maps_response_is_valid(data, helper)):\n            timestamp = ut.em_convert_event_timestamp_to_total_seconds(data[\"datetime\"], helper)\n            ut.write_event_to_splunk(ew, json.dumps(data), timestamp, helper)", "customized_options": [{"name": "electricity_maps_account", "value": ""}, {"name": "zone_s_", "value": ""}], "uuid": "c1a2e7f90a944e7caf63c589fd1387bb"}, {"index": "default", "sourcetype": "EM:carbonintensity:forecast", "interval": "43200", "use_external_validation": true, "streaming_mode_xml": true, "name": "electricity_maps_carbon_intensity_forecast", "title": "Electricity Maps Carbon Intensity - Forecast", "description": "Gets data for the next 48h for the specified zone.", "type": "customized", "parameters": [{"required": true, "name": "electricity_maps_account", "label": "Electricity Maps Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": ""}, {"required": true, "name": "zone_s_", "label": "Zone(s)", "default_value": "", "placeholder": "", "help_string": "Please enter a list, separated by a comma. For a list of available zones, please run the following command: \"curl 'https://api.electricitymap.org/v3/zones'\"", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "electricity_maps_account", "title": "Electricity Maps Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "zone_s_", "title": "Zone(s)", "description": "Please enter a list, separated by a comma. For a list of available zones, please run the following command: \"curl 'https://api.electricitymap.org/v3/zones'\"", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport requests\nimport json\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # api_key = definition.parameters.get('api_key', None)\n    # zone = definition.parameters.get('zone', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n\n    # get user args\n    opt_electricity_maps_account = helper.get_arg(\"electricity_maps_account\")\n    opt_alternative_base_url = opt_electricity_maps_account.get(\"username\")\n    opt_zones = helper.get_arg(\"zone_s_\")\n    \n    url = \"https://api.electricitymap.org/v3/carbon-intensity/forecast\"\n    \n    if(opt_alternative_base_url and len(opt_alternative_base_url) != 0):\n        url = opt_alternative_base_url + \"/carbon-intensity/forecast\"\n    \n    zones = opt_zones.split(\",\")\n\n    headers = {\n        \"X-BLOBR-KEY\": opt_electricity_maps_account.get(\"password\")\n    }\n\n    for zone in zones:\n        params = {\"zone\" : zone.strip()}\n        data = ut.make_api_call(url=url, params=params, headers=headers, helper=helper)\n        if (ut.electricity_maps_response_is_valid(data, helper)):\n            timestamp = ut.em_convert_event_timestamp_to_total_seconds(data[\"updatedAt\"], helper)\n            ut.write_event_to_splunk(ew, json.dumps(data), timestamp, helper)", "customized_options": [{"name": "electricity_maps_account", "value": ""}, {"name": "zone_s_", "value": ""}], "uuid": "628a04ffc017480f89592ee975dbd962"}, {"index": "default", "sourcetype": "NG:carbonintensity", "interval": "1800", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_national", "title": "National Grid Carbon Intensity API - National", "description": "Gets data for the current half hour, for Great Britain at a national level.", "type": "customized", "parameters": [{"name": "placeholder", "label": "Placeholder", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "placeholder", "title": "Placeholder", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # placeholder = definition.parameters.get('placeholder', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n    import json\n\n    url = \"https://api.carbonintensity.org.uk/intensity\"\n    response = ut.make_api_call(url=url, params=None, headers=None, helper=helper)\n\n    data = response.get(\"data\")\n    if not data:\n        return\n    data = data.pop()\n    timestamp = ut.ng_convert_event_timestamp_to_total_seconds(data.get(\"from\"), helper)\n\n    ut.write_event_to_splunk(ew, json.dumps(data), timestamp, helper)", "customized_options": [{"name": "placeholder", "value": ""}], "uuid": "724d6a13757f44d58900e08b4faa6e00"}, {"index": "default", "sourcetype": "NG:carbonintensity:regional", "interval": "1800", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_regional", "title": "National Grid Carbon Intensity API - Regional", "description": "Gets data for the current half hour for all Great Britain regions.", "type": "customized", "parameters": [{"required": false, "name": "placeholder", "label": "Placeholder", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "placeholder", "title": "Placeholder", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # placeholder = definition.parameters.get('placeholder', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n    import json\n\n    url = \"https://api.carbonintensity.org.uk/regional\"\n    response = ut.make_api_call(url=url, params=None, headers=None, helper=helper)\n\n    data = response.get(\"data\")\n    if not data:\n        return\n    data = data.pop()\n\n    regions_list = data[\"regions\"]\n    from_data = data[\"from\"]\n    to_data = data[\"to\"]\n\n    for region in regions_list:\n        region[\"from\"] = from_data\n        region[\"to\"] = to_data\n        timestamp = ut.ng_convert_event_timestamp_to_total_seconds(region[\"from\"], helper) # TODO clarify \"to\" \"from\"\n        ut.write_event_to_splunk(ew, json.dumps(region), timestamp, helper)", "customized_options": [{"name": "placeholder", "value": ""}], "uuid": "99d5ffd737dc443bab66b6839fbe4fad"}, {"index": "default", "sourcetype": "NG:carbonintensity:postcode", "interval": "1800", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_post_code_s_", "title": "National Grid Carbon Intensity API - Post Code(s)", "description": "Gets data for the current half hour for one or more Great Britain Post Codes.", "type": "customized", "parameters": [{"required": true, "name": "uk_post_code_s_", "label": "UK Post Code(s)", "default_value": "", "placeholder": "", "help_string": "Comma delimited list of UK outward postcodes i.e. RG41 or SW1A or TF8", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "uk_post_code_s_", "title": "UK Post Code(s)", "description": "Comma delimited list of UK outward postcodes i.e. RG41 or SW1A or TF8", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # post_code_s_ = definition.parameters.get('post_code_s_', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n\n    opt_uk_postcodes = helper.get_arg(\"uk_post_code_s_\")\n    \n    base_url = \"https://api.carbonintensity.org.uk/regional\"\n    headers = {\"Accept\": \"appliaction/json\"}\n    \n    post_codes = opt_uk_postcodes.split(\",\")\n        \n    for code in post_codes:\n        url = base_url + f\"/postcode/{code.strip()}\"\n        response = ut.make_api_call(url=url, params=None, headers=headers, helper=helper)\n        data = response.get(\"data\")\n        if(data is None):\n            helper.log_debug(f\"API Call to {base_url} made but 'None' received.\")\n            continue\n        \n        data = data.pop()\n        regionid = data[\"regionid\"]\n        dnoregion = data[\"dnoregion\"]\n        shortname = data[\"shortname\"]\n        \n        carbon_data = data[\"data\"].pop()\n        carbon_data[\"regionid\"] = regionid\n        carbon_data[\"postcode\"] = code.strip()\n        carbon_data[\"dnoregion\"] = dnoregion\n        carbon_data[\"shortname\"] = shortname\n\n        timestamp = ut.ng_convert_event_timestamp_to_total_seconds(carbon_data[\"from\"], helper)\n\n        ut.write_event_to_splunk(ew, json.dumps(carbon_data), timestamp, helper)", "customized_options": [{"name": "uk_post_code_s_", "value": "rg6, W2, RG1, E14, b1, M1, ls1, EH1"}], "uuid": "49921dfbaf4e426081982fea34612bd4"}, {"index": "default", "sourcetype": "NG:carbonintensity:CHANGEME", "interval": "300000", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_national_backfill", "title": "National Grid Carbon Intensity API - National - Backfill", "description": "Gets historic data in half hour increments, for Great Britain at a national level.\n\nThis input is intended to be used only for a single time. If it is used continuously, duplicates will be written to Splunk.", "type": "customized", "parameters": [{"name": "start_date", "label": "Start Date", "help_string": "Start datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "2023-08-01T00:00Z"}, {"name": "end_date", "label": "End Date", "help_string": "End datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "2023-08-02T00:00Z"}], "data_inputs_options": [{"type": "customized_var", "name": "start_date", "title": "Start Date", "description": "Start datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "end_date", "title": "End Date", "description": "End datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    import input_module_utils as ut\n\n    start_date = definition.parameters.get('start_date', None)\n    end_date = definition.parameters.get('end_date', None)\n    \n    ut.validate_dates(start_date=start_date, end_date=end_date, day_threshold=30)\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n\n    opt_start_date = helper.get_arg(\"start_date\")\n    opt_end_date = helper.get_arg(\"end_date\")\n    \n    url = f\"https://api.carbonintensity.org.uk/intensity/{opt_start_date}/{opt_end_date}\"\n    headers = {\"Accept\": \"appliaction/json\"}\n    \n    response = ut.make_api_call(url=url, params=None, headers=headers, helper=helper)\n    data = response.get(\"data\")\n    if(data is None):\n        helper.log_info(f\"{url} called, but empty response received\")\n        return\n\n    for period in data:\n        timestamp = ut.ng_convert_event_timestamp_to_total_seconds(period[\"from\"], helper) # TODO clarify \"from\" \"to\"\n        ut.write_event_to_splunk(ew, json.dumps(period), timestamp, helper)", "customized_options": [{"name": "start_date", "value": "2023-08-01T00:00Z"}, {"name": "end_date", "value": "2023-08-02T00:00Z"}], "uuid": "44d524f35c514cefab606e2189bb8571", "sample_count": 0}, {"index": "default", "sourcetype": "NG:carbonintensity:regional:CHANGEME", "interval": "300000", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_regional_backfill", "title": "National Grid Carbon Intensity API - Regional - Backfill", "description": "Get historic data in half hour increments, for all Great Britain regions.\n\nThis input is intended to be used only for a single time. If it is used continuously, duplicates will be written to Splunk.", "type": "customized", "parameters": [{"required": true, "name": "start_date", "label": "Start Date", "default_value": "", "placeholder": "", "help_string": "Start datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "end_date", "label": "End Date", "default_value": "", "placeholder": "", "help_string": "End datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "start_date", "title": "Start Date", "description": "Start datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "end_date", "title": "End Date", "description": "End datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    import input_module_utils as ut\n    \n    start_date = definition.parameters.get('start_date', None)\n    end_date = definition.parameters.get('end_date', None)\n\n    ut.validate_dates(start_date=start_date, end_date=end_date, day_threshold=14)\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n\n    opt_start_date = helper.get_arg(\"start_date\")\n    opt_end_date = helper.get_arg(\"end_date\")\n    \n    url = f\"https://api.carbonintensity.org.uk/regional/intensity/{opt_start_date}/{opt_end_date}\"\n    headers = {\"Accept\": \"appliaction/json\"}\n    \n    response = ut.make_api_call(url=url, params=None, headers=headers, helper=helper)\n    data = response.get(\"data\")\n    if(data is None):\n        helper.log_info(f\"{url} called, but empty response received\")\n        return\n    \n    for period in data:\n        timestamp = ut.ng_convert_event_timestamp_to_total_seconds(period[\"from\"], helper) \n        ut.write_event_to_splunk(ew, json.dumps(period), timestamp, helper)", "customized_options": [{"name": "start_date", "value": "2023-08-01T00:00Z"}, {"name": "end_date", "value": "2023-08-02T00:00Z"}], "uuid": "75cf5d08292544d28bc97ffda2661d24"}, {"index": "default", "sourcetype": "NG:carbonintensity:postcode:CHANGEME", "interval": "300000", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_post_code_s_backfill", "title": "National Grid Carbon Intensity API - Post Code(s) - Backfill", "description": "Gets historic data in half hour increments, for one or more Great Britain Post Codes.\n\nThis input is intended to be used only for a single time. If it is used continuously, duplicates will be written to Splunk.", "type": "customized", "parameters": [{"name": "start_date", "label": "Start Date", "help_string": "Start datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "end_date", "label": "End Date", "help_string": "End datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "uk_post_code_s_", "label": "UK Post Code(s)", "help_string": "Comma delimited list of UK outward postcodes i.e. RG41 or SW1A or TF8.", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "rg6, W2, RG1, E14, b1, M1, ls1, EH1"}], "data_inputs_options": [{"type": "customized_var", "name": "start_date", "title": "Start Date", "description": "Start datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "end_date", "title": "End Date", "description": "End datetime in ISO8601 format YYYY-MM-DDThh:mmZ e.g. 2023-08-01T12:35Z. Note the time range is inclusive, so use 2023-07-15T00:00Z to 2023-07-15T23:59Z for 1 day.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "uk_post_code_s_", "title": "UK Post Code(s)", "description": "Comma delimited list of UK outward postcodes i.e. RG41 or SW1A or TF8.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    import input_module_utils as ut\n    start_date = definition.parameters.get('start_date', None)\n    end_date = definition.parameters.get('end_date', None)\n\n    ut.validate_dates(start_date=start_date, end_date=end_date, day_threshold=14)\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n\n    opt_uk_postcodes = helper.get_arg(\"uk_post_code_s_\")\n    opt_start_date = helper.get_arg(\"start_date\")\n    opt_end_date = helper.get_arg(\"end_date\")\n    \n    base_url = f\"https://api.carbonintensity.org.uk/regional/intensity/{opt_start_date}/{opt_end_date}\"\n    headers = {\"Accept\": \"appliaction/json\"}\n    \n    post_codes = opt_uk_postcodes.split(\",\")\n    \n    for code in post_codes:\n        url = base_url + f\"/postcode/{code.strip()}\"\n        response = ut.make_api_call(url=url, params=None, headers=headers, helper=helper)\n        data = response.get(\"data\")\n\n        if(data is None):\n            helper.log_debug(f\"API Call to {url} made but 'None' received.\")\n            continue\n        \n        regionid = data[\"regionid\"]\n        shortname = data[\"shortname\"]\n        postcode = data[\"postcode\"]\n        \n        for period in data[\"data\"]:\n            period[\"regionid\"] = regionid\n            period[\"shortname\"] = shortname\n            period[\"postcode\"] = postcode\n            timestamp = ut.ng_convert_event_timestamp_to_total_seconds(period[\"from\"], helper) #TODO clarify \"from\" \"to\"\n            ut.write_event_to_splunk(ew, json.dumps(period), timestamp, helper)", "customized_options": [{"name": "start_date", "value": "2023-08-01T12:35Z"}, {"name": "end_date", "value": "2023-08-02T12:35Z"}, {"name": "uk_post_code_s_", "value": "rg6, W2, RG1, E14, b1, M1, ls1, EH1"}], "uuid": "32a590b359df4f50abbf8e699fd95d5e"}, {"index": "default", "sourcetype": "NG:carbonintensity:forecast", "interval": "43200", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_national_forecast", "title": "National Grid Carbon Intensity API - National Forecast", "description": "Gets data for the next 48h, for Great Britain at a national level.", "type": "customized", "parameters": [{"required": false, "name": "placeholder", "label": "Placeholder", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "placeholder", "title": "Placeholder", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # placeholder = definition.parameters.get('placeholder', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n    import json\n\n    time_now = datetime.datetime.now()\n    time_now_string = time_now.strftime(\"%Y-%m-%dT%H:%M\")\n    \n    url = f\"https://api.carbonintensity.org.uk/intensity/{time_now_string}/fw48h\"\n    response = ut.make_api_call(url=url, params=None, headers=None, helper=helper)\n\n    data = response.get(\"data\")\n    if not data:\n        return\n    data = data.pop()\n    timestamp = ut.ng_convert_event_timestamp_to_total_seconds(data.get(\"from\"), helper)\n    ut.write_event_to_splunk(ew, json.dumps(data), timestamp, helper)", "customized_options": [{"name": "placeholder", "value": ""}], "uuid": "8a213fbd6b5e40ebbcecc27b98530e63"}, {"index": "default", "sourcetype": "NG:carbonintensity:regional:forecast", "interval": "43200", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_regional_forecast", "title": "National Grid Carbon Intensity API - Regional Forecast", "description": "Gets data for the next 48h for all Great Britain regions.", "type": "customized", "parameters": [{"required": false, "name": "placeholder", "label": "Placeholder", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "placeholder", "title": "Placeholder", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # placeholder = definition.parameters.get('placeholder', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n    import json\n\n    time_now = datetime.datetime.now()\n    time_now_string = time_now.strftime(\"%Y-%m-%dT%H:%M\")\n    \n    url = f\"https://api.carbonintensity.org.uk/regional/intensity/{time_now_string}/fw48h\"\n    response = ut.make_api_call(url=url, params=None, headers=None, helper=helper)\n\n    data = response.get(\"data\")\n    if not data:\n        return\n    data = data.pop()\n    from_date = data.get(\"from\")\n    to_date = data.get(\"to\")\n    regions = data.get(\"regions\")\n    \n    for region in regions:\n        timestamp = ut.ng_convert_event_timestamp_to_total_seconds(from_date, helper)\n        region[\"from\"] = from_date\n        region[\"to\"] = to_date\n        ut.write_event_to_splunk(ew, json.dumps(region), timestamp, helper)", "customized_options": [{"name": "placeholder", "value": ""}], "uuid": "235e848b15b74b94aebd81d7296d90f8"}, {"index": "default", "sourcetype": "NG:carbonintensity:postcode:forecast", "interval": "43200", "use_external_validation": true, "streaming_mode_xml": true, "name": "ng_carbon_intensity_api_post_code_s_forecast", "title": "National Grid Carbon Intensity API - Post Code(s) Forecast", "description": "Gets data for the next 48h for one or more Great Britain Post Codes.", "type": "customized", "parameters": [{"required": true, "name": "uk_post_code_s_", "label": "UK Post Code(s)", "default_value": "", "placeholder": "", "help_string": "Comma delimited list of UK outward postcodes i.e. RG41 or SW1A or TF8.", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "uk_post_code_s_", "title": "UK Post Code(s)", "description": "Comma delimited list of UK outward postcodes i.e. RG41 or SW1A or TF8.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # placeholder = definition.parameters.get('placeholder', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n    import json\n\n    time_now = datetime.datetime.now()\n    time_now_string = time_now.strftime(\"%Y-%m-%dT%H:%MZ\")\n    \n    opt_uk_postcodes = helper.get_arg(\"uk_post_code_s_\")\n    \n    base_url = f\"https://api.carbonintensity.org.uk/regional/intensity/{time_now_string}/fw48h\"\n    headers = {\"Accept\": \"appliaction/json\"}\n\n    post_codes = opt_uk_postcodes.split(\",\")\n    for code in post_codes:\n        url = base_url + f\"/postcode/{code.strip()}\"\n        response = ut.make_api_call(url=url, params=None, headers=headers, helper=helper)\n        data = response.get(\"data\")\n\n        if(data is None):\n            helper.log_debug(f\"API Call to {url} made but 'None' received.\")\n            continue\n        \n        timestamp = ut.ng_convert_event_timestamp_to_total_seconds(time_now_string, helper) \n        ut.write_event_to_splunk(ew, json.dumps(data), timestamp, helper)", "customized_options": [{"name": "uk_post_code_s_", "value": "rg6, W2, RG1, E14, b1, M1, ls1, EH1"}], "uuid": "f841e36b516d463f857c626b84e92fa0"}, {"index": "default", "sourcetype": "EM:carbonintensity:CHANGEME", "interval": "300000", "use_external_validation": true, "streaming_mode_xml": true, "name": "electricity_maps_carbon_intensity_history", "title": "Electricity Maps Carbon Intensity - History", "description": "Time range is limited to 10 days. \n\nThis input is intended to be used only for a single time. If it is used continuously, duplicates will be written to Splunk.", "type": "customized", "parameters": [{"name": "electricity_maps_account", "label": "Electricity Maps Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": ""}, {"name": "zone_s_", "label": "Zone(s)", "help_string": "Please enter a list, separated by a comma. For a list of available zones, please run the following command: \"curl 'https://api.electricitymap.org/v3/zones'\"", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"required": true, "name": "start_date", "label": "Start Date", "default_value": "", "placeholder": "", "help_string": "Date in ISO8601 format YYYY-MM-DDThh:mm:ssZ, e.g., 2017-08-25T12:35:00Z.\nThe time range is limited to 10 days.", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "end_date", "label": "End Date", "default_value": "", "placeholder": "", "help_string": "Date in ISO8601 format YYYY-MM-DDThh:mm:ssZ, e.g., 2017-08-25T12:35:00Z.\nThe time range is limited to 10 days.\n", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "electricity_maps_account", "title": "Electricity Maps Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "zone_s_", "title": "Zone(s)", "description": "Please enter a list, separated by a comma. For a list of available zones, please run the following command: \"curl 'https://api.electricitymap.org/v3/zones'\"", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "start_date", "title": "Start Date", "description": "Date in ISO8601 format YYYY-MM-DDThh:mm:ssZ, e.g., 2017-08-25T12:35:00Z.\nThe time range is limited to 10 days.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "end_date", "title": "End Date", "description": "Date in ISO8601 format YYYY-MM-DDThh:mm:ssZ, e.g., 2017-08-25T12:35:00Z.\nThe time range is limited to 10 days.\n", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "customized_options": [{"name": "electricity_maps_account", "value": ""}, {"name": "zone_s_", "value": ""}, {"name": "start_date", "value": ""}, {"name": "end_date", "value": ""}], "code": "\n# encoding = utf-8\n\nimport requests\nimport json\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # api_key = definition.parameters.get('api_key', None)\n    # zone = definition.parameters.get('zone', None)\n    pass\n\ndef collect_events(helper, ew):\n    import input_module_utils as ut\n\n    opt_electricity_maps_account = helper.get_arg(\"electricity_maps_account\")\n    opt_alternative_base_url = opt_electricity_maps_account.get(\"username\")\n    opt_zones = helper.get_arg(\"zone_s_\")\n    \n    url = \"https://api.electricitymap.org/v3/carbon-intensity/history\"\n    \n    if(opt_alternative_base_url and len(opt_alternative_base_url) != 0):\n        url = opt_alternative_base_url + \"/carbon-intensity/history\"\n    \n    zones = opt_zones.split(\",\")\n\n    headers = {\n        \"X-BLOBR-KEY\": opt_electricity_maps_account.get(\"password\")\n    }\n\n    for zone in zones:\n        params = {\"zone\" : zone.strip()}\n        data = ut.make_api_call(url=url, params=params, headers=headers, helper=helper)\n        if(ut.electricity_maps_response_is_valid(data, helper)):\n            for entry in data[\"history\"]:\n                timestamp = ut.em_convert_event_timestamp_to_total_seconds(entry[\"datetime\"], helper)\n                ut.write_event_to_splunk(ew, json.dumps(entry), timestamp, helper)", "uuid": "60d8e4aa173c4211afd4e3775105f4df", "sample_count": 0}]}, "global_settings_builder": {"global_settings": {"log_settings": {}, "credential_settings": []}}, "sourcetype_builder": {"EM:carbonintensity": {"metadata": {"event_count": 0, "data_input_name": "electricity_maps_carbon_intensity_latest", "extractions_count": 0, "cims_count": 0}}, "EM:carbonintensity:forecast": {"metadata": {"event_count": 0, "data_input_name": "electricity_maps_carbon_intensity_forecast", "extractions_count": 0, "cims_count": 0}}, "EM:carbonintensity:CHANGEME": {"metadata": {"event_count": 0, "data_input_name": "electricity_maps_carbon_intensity_history", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_national", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:regional": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_regional", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:postcode": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_post_code_s_", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:CHANGEME": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_national_backfill", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:regional:CHANGEME": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_regional_backfill", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:postcode:CHANGEME": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_post_code_s_backfill", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:forecast": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_national_forecast", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:regional:forecast": {"metadata": {"event_count": 0, "data_input_name": "ng_carbon_intensity_api_regional_forecast", "extractions_count": 0, "cims_count": 0}}, "NG:carbonintensity:postcode:forecast": {"metadata": {"ev