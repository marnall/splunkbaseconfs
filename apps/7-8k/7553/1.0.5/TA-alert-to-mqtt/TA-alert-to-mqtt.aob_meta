{"alert_action_builder": {"modular_alerts": [{"description": "This alert action allows you to send data to an MQTT broker", "smallIcon": "", "largeIcon": "", "label": "Alert to MQTT", "short_name": "alert_to_mqtt", "parameters": [{"format_type": "text", "required": false, "name": "mqtt_topic", "label": "MQTT Topic", "default_value": "", "help_string": "Topic on MQTT Broker", "type": "", "value": "/test"}, {"format_type": "text", "required": false, "name": "mqtt_message", "label": "Message", "default_value": "", "help_string": "Splunk alert token/s", "type": "", "value": "test"}, {"format_type": "dropdownlist", "required": false, "name": "mqtt_version", "label": "MQTT Protocol Version", "default_value": "MQTTv31", "help_string": "Select Protocol to use", "possible_values": {"MQTTv3.1": "MQTTv31", "MQTTv3.1.1": "MQTTv311", "MQTTv5": "MQTTv5"}, "type": "", "value": "MQTTv31"}], "code": "\n# encoding = utf-8\n\nimport paho.mqtt.client as mqtt\nfrom paho.mqtt.packettypes import PacketTypes\nfrom paho.mqtt.properties import Properties\n\nimport ssl\nimport os\nimport random\nimport string\n\n# Alphanumeric 6 char uuid\ndef generate_alphanumeric_uuid(length=6):\n    # Creates a combination of uppercase ASCII letters and digits\n    characters = string.ascii_uppercase + string.digits\n    # Randomly chooses `length` characters from the combined string\n    result_str = ''.join(random.choices(characters, k=length))\n    return result_str\n\n# paho mqtt callbacks dont work well with helper i found during debug/testing so they are removed\n        \n# This is the main function to process the MQTT event        \ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets and sets the log level\n    helper.set_log_level(helper.log_level)\n\n    # The following example gets the setup parameters and prints them to the log\n    mqtt_server = helper.get_global_setting(\"mqtt_server\")\n    helper.log_info(\"mqtt_server={}\".format(mqtt_server))\n    mqtt_port = helper.get_global_setting(\"mqtt_port\")\n    helper.log_info(\"mqtt_port={}\".format(mqtt_port))\n    mqtt_user = helper.get_global_setting(\"mqtt_user\")\n    helper.log_info(\"mqtt_user={}\".format(mqtt_user))\n    mqtt_password = helper.get_global_setting(\"mqtt_password\")\n    helper.log_info(\"mqtt_password={}\".format(mqtt_password))\n    mqtt_keepalive = helper.get_global_setting(\"mqtt_keepalive\")\n    helper.log_info(\"mqtt_keepalive={}\".format(mqtt_keepalive))\n    use_ssl = helper.get_global_setting(\"use_ssl\")\n    helper.log_info(\"use_ssl={}\".format(use_ssl))\n    cert_path = helper.get_global_setting(\"cert_path\")\n    helper.log_info(\"cert_path={}\".format(cert_path))\n    cert_key = helper.get_global_setting(\"cert_key\")\n    helper.log_info(\"cert_key={}\".format(cert_key))\n    ca_cert = helper.get_global_setting(\"ca_cert\")\n    helper.log_info(\"ca_cert={}\".format(ca_cert))\n\n    # The following example gets the alert action parameters and prints them to the log\n    mqtt_topic = helper.get_param(\"mqtt_topic\")\n    helper.log_info(\"mqtt_topic={}\".format(mqtt_topic))\n\n    mqtt_message = helper.get_param(\"mqtt_message\")\n    helper.log_info(\"mqtt_message={}\".format(mqtt_message))\n\n    mqtt_version = helper.get_param(\"mqtt_version\")\n    helper.log_info(\"mqtt_version={}\".format(mqtt_version))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action alert_to_mqtt started.\")\n\n    # Retrieve MQTT configuration settings - setup \n    mqtt_server = helper.get_global_setting(\"mqtt_server\")\n    mqtt_port = helper.get_global_setting(\"mqtt_port\")\n    mqtt_user = helper.get_global_setting(\"mqtt_user\")\n    mqtt_keepalive = helper.get_global_setting(\"mqtt_keepalive\")\n    mqtt_password = helper.get_global_setting(\"mqtt_password\")\n    use_ssl = helper.get_global_setting(\"use_ssl\")\n    helper.log_info(\"use_ssl={}\".format(use_ssl))\n    cert_path = helper.get_global_setting(\"cert_path\")            # Path to the CA certificate\n    cert_key = helper.get_global_setting(\"cert_key\") \n    ca_cert = helper.get_global_setting(\"ca_cert\")\n\n    # Retrieve MQTT configuration settings - action\n    mqtt_topic = helper.get_param(\"mqtt_topic\")\n    mqtt_message = helper.get_param(\"mqtt_message\")\n    mqtt_version = helper.get_param(\"mqtt_version\")  # Optionally set by user\n\n    # Default MQTT protocol to 3.1\n    mqtt_protocol = mqtt.MQTTv31\n\n    # Check the mqtt_version and set the protocol\n    if mqtt_version == \"MQTTv311\":\n        mqtt_protocol = mqtt.MQTTv311\n    elif mqtt_version == \"MQTTv5\":\n        mqtt_protocol = mqtt.MQTTv5\n    helper.log_info(\"protocol version selected={}\".format(mqtt_protocol))\n    # Check keepalive set if mt\n    if mqtt_keepalive == \"\":\n        mqtt_keepalive = 60\n        helper.log_info(\"keepalive not set so set it to={}\".format(mqtt_keepalive))\n    #\n    # setup some client side defaults and stuff - maybe i'll make this configurable later\n    # QoS 2 - becoz - It is critical to your application to receive all messages exactly once.\n    #\n    mqtt_qos = 2 \n    uuid = generate_alphanumeric_uuid()\n    client_id_uuid = \"Splunk_TA_7553_Alert_to_MQTT_\" + uuid\n    use_clean_session = True \n    helper.log_info(\"Clean session set and client id used is={}\".format(client_id_uuid))\n    # Initialize MQTT client with the chosen protocol and clean_session\n    if mqtt_protocol != 5:\n        client = mqtt.Client(client_id=client_id_uuid, protocol=mqtt_protocol, clean_session=use_clean_session)\n        client.username_pw_set(username=mqtt_user, password=mqtt_password)\n        helper.log_info(\"Username and Password set\")\n        #client.on_connect = on_connect\n        #helper.log_info(\"Callback to connect completed\")\n    elif mqtt_protocol == 5: \n        client = mqtt.Client(client_id=client_id_uuid, protocol=mqtt.MQTTv5)\n        client.username_pw_set(username=mqtt_user, password=mqtt_password)\n        helper.log_info(\"Username and Password set\")\n        #client.on_connect = on_connect_v5\n        #helper.log_info(\"Callback to connect completed\")        \n        \n    #\n    # Set the SSL/TLS certificate and key\n    # certfile should be a 'cert.pem' and keyfile='privkey.pem' a private key, these should have full path names - log some info here.\n\n    # Configure SSL/TLS settings if use_ssl is enabled - turn off if selfsigned issues with mosquitto\n    if bool(use_ssl) == True and len(cert_path) > 0  and len(cert_key) > 0:\n        client.tls_set(certfile=cert_path, keyfile=cert_key, cert_reqs=ssl.CERT_REQUIRED, tls_version=ssl.PROTOCOL_TLS)\n        client.tls_insecure_set(False)\n        helper.log_info(\"cert_path={}\".format(cert_path))\n        helper.log_info(\"cert_key={}\".format(cert_key))\n    elif bool(use_ssl) == True and len(ca_cert) > 0:\n        client.tls_set(ca_certs=ca_cert)\n        client.tls_insecure_set(False)\n        helper.log_info(\"ca_cert={}\".format(ca_cert))\n        \n    # Attempt to connect to the MQTT broker\n    try:\n        client.connect(mqtt_server, int(mqtt_port), keepalive=int(mqtt_keepalive))\n        helper.log_info(f\"Connected to MQTT broker at {mqtt_server}:{mqtt_port}.\")\n        client.loop_start()\n\n        try:\n            if mqtt_protocol != 5:\n                info = client.publish(mqtt_topic, str(mqtt_message), qos=mqtt_qos)\n            else:\n                publish_properties = Properties(PacketTypes.PUBLISH)\n                # Set properties ...\n                info = client.publish(mqtt_topic, str(mqtt_message), qos=mqtt_qos, properties=publish_properties)\n            \n            # Wait for the message to be published if necessary\n            info.wait_for_publish()\n            if info.rc != mqtt.MQTT_ERR_SUCCESS:\n                helper.log_error(f\"Publish failed with result code {info.rc}\")\n                return 1  # Non-zero return code for failure\n\n        except Exception as ex:\n            helper.log_error(f\"An exception occurred while trying to publish to the MQTT topic: {str(ex)}\")\n            return 1  # Non-zero return code for failure\n\n    except Exception as ex:\n        helper.log_error(f\"An exception occurred while trying to connect to the MQTT broker: {str(ex)}\")\n        return 1  # Non-zero return code for failure\n    finally:\n        # Stop the network loop and disconnect properly\n        client.loop_stop()\n        client.disconnect()\n\n    helper.log_info(f\"Message published to MQTT topic {mqtt_topic}\")\n    return 0\n", "uuid": "453c45c8693b4fbc9b79d91937b373b9"}]}, "basic_builder": {"appname": "TA-alert-to-mqtt", "friendly_name": "Alert to MQTT Broker", "version": "1.0.5", "author": "Gary Croker", "description": "Send splunk alert results to MQTT Broker.", "theme": "#4fa484", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 6}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "INFO"}, "customized_settings": [{"format_type": "text", "required": true, "name": "mqtt_server", "label": "MQTT Server", "default_value": "", "help_string": "Hostname of MQTT server to connect with", "internal_name": "", "type": "text", "value": "192.168.0.120"}, {"format_type": "text", "required": true, "name": "mqtt_port", "label": "MQTT Port", "default_value": "1883", "help_string": "Port number to connect on 1883 / 8883", "internal_name": "", "type": "text", "value": "1883"}, {"format_type": "text", "required": true, "name": "mqtt_user", "label": "MQTT Username", "default_value": "", "help_string": "The username to use for connecting to Broker", "internal_name": "", "type": "text", "value": "home"}, {"format_type": "password", "required": true, "name": "mqtt_password", "label": "MQTT Password", "default_value": "", "help_string": "The password credential", "internal_name": "", "type": "password", "value": ""}, {"format_type": "text", "required": false, "name": "mqtt_keepalive", "label": "MQTT Keepalive value", "default_value": "60", "help_string": "Value to keep connection alive common values are 60, 120, 180", "internal_name": "", "type": "text", "value": "120"}, {"format_type": "checkbox", "required": false, "name": "use_ssl", "label": "Use SSL", "default_value": 0, "help_string": "Use SSL Connection", "internal_name": "", "type": "checkbox", "value": 0}, {"format_type": "text", "required": false, "name": "cert_path", "label": "Certificate Path", "default_value": "", "help_string": "Required for SSL. Place full path and filename here.", "internal_name": "", "type": "text", "value": ""}, {"format_type": "text", "required": false, "name": "cert_key", "label": "Certificate Key Path", "default_value": "", "help_string": "Certificate key file path, required for SSL", "internal_name": "", "type": "text", "value": ""}, {"format_type": "text", "required": false, "name": "ca_cert", "label": "CA Cert Path", "default_value": "", "help_string": "If your using a cloud service provider that supplies just a CA Cert, place here and tick SSL. Leave other 2 fields above empty", "internal_name": "", "type": "text", "value": "/opt/splunk/etc/apps/TA-alert-to-mqtt/local/emqxsl-ca.crt"}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1759562070_12"}}