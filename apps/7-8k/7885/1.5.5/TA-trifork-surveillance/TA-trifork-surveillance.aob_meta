 = helper.get_arg('check_port')\n    opt_check_timeout = helper.get_arg('check_timeout')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_check_host = helper.get_arg('check_host', stanza_name)\n    opt_check_port = helper.get_arg('check_port', stanza_name)\n    opt_check_timeout = helper.get_arg('check_timeout', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_executor_kv = helper.get_global_setting(\"executor_kv\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n\n\n    #connect to splunk\n    scheme, netloc, _, _, _ = urlsplit(helper.context_meta['server_uri'], allow_fragments=False)\n    splunkd_host, splunkd_port = netloc.split(':')\n    service = client.connect(scheme=scheme, host=splunkd_host, port=splunkd_port, token=helper.context_meta['session_key'], owner=\"nobody\")\n    \n    #variables\n    myHostname = service.settings.content['host']  \n    myRole = myKvRole(helper,service)\n    \n    check_host = helper.get_arg('check_host')  \n    check_port = int(helper.get_arg('check_port'))\n    check_timeout = int(helper.get_arg('check_timeout'))\n    \n    executer = \"thisServer\"\n    if (helper.get_global_setting('executer_kv')):\n      executer = \"kv\"\n      \n    if (executer == \"kv\" and myRole.lower() != \"kv store captain\"):\n      helper.log_info(\"Only kvstore captain can run this, and thats not me, skipping\")\n      return   \n    \n    helper.log_info(\"TCP - Checking: {}:{}, results to index: {}\".format(check_host, check_port, helper.get_output_index()))\n    \n    s = socket.socket()\n    try:\n    \n      start = time.perf_counter()\n      \n      s.connect((check_host, check_port)) \n      s.settimeout(check_timeout)\n      s.close()\n      \n      duration = time.perf_counter()-start\n      error = \"\";\n      status = \"success\"\n    except Exception as e: \n      error = e\n      duration = 0\n      status = \"failed\"\n    finally:\n      s.close()   \n      \n    \n    \n    data = { \"entity\": check_host, \"port\": check_port, \"timeout\": check_timeout, \"error\": str(error), \"duration\": duration, \"status\": status }\n    \n    helper.log_info(data)\n        \n    event = helper.new_event(source=\"triforksurveillance\", index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=json.dumps(data))\n    ew.write_event(event)   \n    \ndef myKvRole(helper,service):\n  try:\n    data = service.request(\"/services/kvstore/status\", method='GET')\n    root = ET.fromstring(data.body.read())\n    helper.log_info(root)\n    replicationStatus = root.xpath('//*[local-name()=\"key\" and @name=\"current\"]//*[local-name()=\"key\" and @name=\"replicationStatus\"]/text()')\n    return replicationStatus[0]\n    \n  except Exception as e:\n    helper.log_info(\"Error when trying to get my role from url /services/kvstore/status: {}\".format(e))\n    return False\n", "uuid": "23cbd29738064fd9ada9e8cbdd024003", "sample_count": 0}, {"index": "default", "sourcetype": "ts_surveillance_icmp", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "icmp_check", "title": "ICMP Check", "description": "", "type": "customized", "parameters": [{"required": true, "name": "check_host", "label": "IP / HOST", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "check_count", "label": "Count", "default_value": "5", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "5"}], "data_inputs_options": [{"type": "customized_var", "name": "check_host", "title": "IP / HOST", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "check_count", "title": "Count", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "5", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport lxml.etree as ET\nfrom urllib.parse import urlsplit\nimport splunklib.client as client\nfrom icmplib import ping\nimport json \n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # check_host = definition.parameters.get('check_host', None)\n    # check_count = definition.parameters.get('check_count', None)\n    pass\n\ndef collect_events(helper, ew):\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_check_host = helper.get_arg('check_host')\n    opt_check_count = helper.get_arg('check_count')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_check_host = helper.get_arg('check_host', stanza_name)\n    opt_check_count = helper.get_arg('check_count', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_executor_kv = helper.get_global_setting(\"executor_kv\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n    #connect to splunk\n    scheme, netloc, _, _, _ = urlsplit(helper.context_meta['server_uri'], allow_fragments=False)\n    splunkd_host, splunkd_port = netloc.split(':')\n    service = client.connect(scheme=scheme, host=splunkd_host, port=splunkd_port, token=helper.context_meta['session_key'], owner=\"nobody\")\n    \n    #variables\n    myHostname = service.settings.content['host']  \n    myRole = myKvRole(helper,service)\n    \n    check_host = helper.get_arg('check_host')  \n    check_count = int(helper.get_arg('check_count'))\n    \n    executer = \"thisServer\"\n    if (helper.get_global_setting('executer_kv')):\n      executer = \"kv\"\n      \n    if (executer == \"kv\" and myRole.lower() != \"kv store captain\"):\n      helper.log_info(\"Only kvstore captain can run this, and thats not me, skipping\")\n      return\n    \n    helper.log_info(\"ICMP - Checking: {}, results to index: {}\".format(check_host, helper.get_output_index()))\n    \n    try:\n      host = ping(check_host, count=check_count, privileged=False)\n      \n      rtts = host.rtts\n      sent = host.packets_sent\n      received = host.packets_received\n      alive = host.is_alive\n      error = \"\"\n    except Exception as e:\n      error = e   \n      rtts = \"\"\n      sent = \"\"\n      received = \"\"\n      alive = False\n      \n    data = { \"entity\": check_host, \"count\": check_count, \"alive\": alive, \"rtts\": rtts, \"sent\": sent, \"received\": received, \"error\": str(error) }\n    \n    helper.log_info(data)\n    \n    event = helper.new_event(source=\"triforksurveillance\", index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=json.dumps(data))\n    ew.write_event(event)   \n    \ndef myKvRole(helper,service):\n  try:\n    data = service.request(\"/services/kvstore/status\", method='GET')\n    root = ET.fromstring(data.body.read())\n    helper.log_info(root)\n    replicationStatus = root.xpath('//*[local-name()=\"key\" and @name=\"current\"]//*[local-name()=\"key\" and @name=\"replicationStatus\"]/text()')\n    return replicationStatus[0]\n    \n  except Exception as e:\n    helper.log_info(\"Error when trying to get my role from url /services/kvstore/status: {}\".format(e))\n    return False\n", "customized_options": [{"name": "check_host", "value": ""}, {"name": "check_count", "value": "5"}], "uuid": "15bce4d4d534429b94dad1036a8d506e", "sample_count": 0}, {"index": "default", "sourcetype": "ts_surveillance_http", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "http_check", "title": "HTTP Check", "description": "", "type": "customized", "parameters": [{"name": "check_url", "label": "URL / Splunk Search", "help_string": "Either input a url to probe, or input a splunk search SPL that outputs a url field", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "index=_internal earliest=-1d | eval url=\"https://boot.dk\" | head 2"}, {"required": false, "name": "is_splunk_search", "label": "Is Splunk Search", "default_value": false, "help_string": "", "type": "checkbox", "format_type": "checkbox", "value": true}, {"name": "check_timeout", "label": "Timeout", "help_string": "", "required": true, "format_type": "text", "default_value": "5", "placeholder": "", "type": "text", "value": "5"}, {"name": "check_sslverify", "label": "Verify SSL Verification", "help_string": "", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": false}, {"name": "check_follow", "label": "Follow Redirects", "help_string": "", "required": false, "format_type": "checkbox", "default_value": false, "type": "checkbox", "value": false}], "data_inputs_options": [{"type": "customized_var", "name": "check_url", "title": "URL / Splunk Search", "description": "Either input a url to probe, or input a splunk search SPL that outputs a url field", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "is_splunk_search", "title": "Is Splunk Search", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": false}, {"type": "customized_var", "name": "check_timeout", "title": "Timeout", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "5", "placeholder": ""}, {"type": "customized_var", "name": "check_sslverify", "title": "Verify SSL Verification", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "check_follow", "title": "Follow Redirects", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": false}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nfrom datetime import datetime\nimport lxml.etree as ET\nfrom urllib.parse import urlsplit\nfrom urllib.parse import urlparse\nfrom urllib.request import Request, urlopen, ssl, socket\nimport splunklib.client as client\nimport splunklib.results\nimport requests\nimport json\n\n\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # check_url = definition.parameters.get('check_url', None)\n    # check_timeout = definition.parameters.get('check_timeout', None)\n    # check_disablessverify = definition.parameters.get('check_disablessverify', None)\n    pass\n\ndef collect_events(helper, ew):\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_check_url = helper.get_arg('check_url')\n    opt_check_timeout = helper.get_arg('check_timeout')\n    opt_check_disablessverify = helper.get_arg('check_disablessverify')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_check_url = helper.get_arg('check_url', stanza_name)\n    opt_check_timeout = helper.get_arg('check_timeout', stanza_name)\n    opt_check_disablessverify = helper.get_arg('check_disablessverify', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_executor_kv = helper.get_global_setting(\"executor_kv\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n    \n    #connect to splunk\n    scheme, netloc, _, _, _ = urlsplit(helper.context_meta['server_uri'], allow_fragments=False)\n    splunkd_host, splunkd_port = netloc.split(':')\n    service = client.connect(scheme=scheme, host=splunkd_host, port=splunkd_port, token=helper.context_meta['session_key'], owner=\"nobody\")\n    \n    #variables\n    myHostname = service.settings.content['host']  \n    myRole = myKvRole(helper,service)\n    \n    check_url = helper.get_arg('check_url')  \n    check_timeout = int(helper.get_arg('check_timeout'))\n    check_sslverify = helper.get_arg('check_sslverify')\n    check_follow = helper.get_arg('check_follow')\n    is_splunk_search = helper.get_arg('is_splunk_search');\n    \n    executer = \"thisServer\"\n    if (helper.get_global_setting('executer_kv')):\n      executer = \"kv\"\n      \n    if (executer == \"kv\" and myRole.lower() != \"kv store captain\"):\n      helper.log_info(\"Only kvstore captain can run this, and thats not me, skipping\")\n      return\n\n    if not is_splunk_search:\n      checkurl(helper, ew, check_url, check_timeout, check_sslverify, check_follow)\n    else:\n      search = splunksearch(helper,ew,service,check_url)\n\n\ndef splunksearch(helper,ew,service,check_url):\n    options = {\"exec_mode\": \"blocking\", \"field_list\":\"url\"}\n    jobs = service.jobs\n     \n    if check_url[0] != \"|\":\n        check_url = \"search \"+check_url\n    \n    job = jobs.create(str(check_url), **options)\n\n    if job['resultCount'] == \"0\":\n        helper.log_info(\"No results returned, skipping further parsing\")\n        return\n    \n    result_stream = job.results(count=0)\n    reader = splunklib.results.ResultsReader(result_stream)\n    for item in reader:\n        if \"url\" in item:\n            checkurl(helper,ew,item[\"url\"].strip(),int(helper.get_arg('check_timeout')), helper.get_arg('check_sslverify'),helper.get_arg('check_follow'))\n        \n    \ndef checkurl(helper, ew, check_url, check_timeout=5, check_sslverify=True, check_follow=False):\n    helper.log_info(\"HTTP - Checking: {}, results to index: {}\".format(check_url, helper.get_output_index()))\n    try:\n      check = requests.get(check_url, timeout=check_timeout, verify=check_sslverify, allow_redirects=check_follow)\n    \n      statusCode = check.status_code\n      duration = check.elapsed.total_seconds()\n      error = \"\"\n    except Exception as e:\n      statusCode = 9999\n      duration = 0\n      error = str(e)\n      helper.log_error(error)\n      \n    expiry = \"\"\n    if statusCode != 9999:\n      try:\n        url = urlparse(check_url)\n        port = 443;\n        if url.port:\n          port = url.port\n        expiry = get_https_expiry_date(url.hostname,port,check_timeout)\n      except Exception as e:\n        helper.log_error(e)\n      \n    data = { \"url\": check_url, \"statusCode\": statusCode, \"duration\": duration, \"error\": error, \"sslExpireDate\": expiry  } \n    helper.log_info(data)\n    event = helper.new_event(source=\"triforksurveillance\", index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=json.dumps(data))\n    k = ew.write_event(event)\n\n\ndef get_https_expiry_date(hostname, port, timeout) -> datetime:\n  context = ssl.create_default_context()\n  with socket.create_connection((hostname, 443), timeout=timeout) as sock:\n    with context.wrap_socket(sock, server_hostname=hostname) as ssock:\n      data = ssock.getpeercert()\n      expiry_date = datetime.strptime(data['notAfter'], \"%b %d %H:%M:%S %Y %Z\").timestamp()\n      return expiry_date\n      \n  return false\n\n\ndef myKvRole(helper,service):\n  try:\n    data = service.request(\"/services/kvstore/status\", method='GET')\n    root = ET.fromstring(data.body.read())\n    replicationStatus = root.xpath('//*[local-name()=\"key\" and @name=\"current\"]//*[local-name()=\"key\" and @name=\"replicationStatus\"]/text()')\n    return replicationStatus[0]\n    \n  except Exception as e:\n    helper.log_info(\"Error when trying to get my role from url /services/kvstore/status: {}\".format(e))\n    return False", "customized_options": [{"name": "check_url", "value": "index=_internal earliest=-1d | eval url=\"https://boot.dk\" | head 1"}, {"name": "is_splunk_search", "value": true}, {"name": "check_timeout", "value": "5"}, {"name": "check_sslverify", "value": false}, {"name": "check_follow", "value": false}], "uuid": "e946e7a5aab54fc491f1cc08ffe78c1b", "sample_count": 0}]}, "field_extraction_builder": {"ts_surveillance_http": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": false, "name": "executor_kv", "label": "KV Store Captain is executor", "default_value": false, "help_string": "If running in a SH-Cluster, this should be enabled, this will do so only the KV Store Captain is running checks", "type": "checkbox", "format_type": "checkbox", "value": false}]}}, "sourcetype_builder": {"ts_surveillance_http": {"metadata": {"event_count": 0, "data_input_name": "http_check", "extractions_count": 0, "cims_count": 0}}, "ts_surveillance_tcp": {"metadata": {"event_count": 0, "data_input_name": "tcp_check", "extractions_count": 0, "cims_count": 0}}, "ts_surveillance_dns": {"metadata": {"event_count": 0, "data_input_name": "dns_check", "extractions_count": 0, "cims_count": 0}}, "ts_surveillance_icmp": {"metadata": {"event_count": 0, "data_input_name": "icmp_check", "extractions_count": 0, "cims_count": 0}}, "ts_surveillance_ntp": {"metadata": {"event_count": 0, "data_input_name": "ntp_check", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1758696571_38"}}