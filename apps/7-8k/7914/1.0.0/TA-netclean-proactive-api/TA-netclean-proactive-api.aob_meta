{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "Netclean Proactive API", "short_name": "netclean_proactive_api", "parameters": [{"format_type": "text", "required": true, "name": "hash_field", "label": "Hash Field", "default_value": "admin", "help_string": "", "type": "", "value": "hash"}], "code": "# encoding = utf-8\n\nimport sys\nimport json\nimport requests\nimport time\nfrom splunklib.searchcommands import dispatch, GeneratingCommand, Configuration, Option\nfrom splunklib.binding import HTTPError\nfrom splunklib.client import connect\nfrom urllib.parse import quote\n\n\nclass NetCleanOAuth2TokenManager:\n    def __init__(self, helper):\n        self.helper = helper\n        self.client_id = helper.get_global_setting(\"client_id\")\n        self.client_secret = helper.get_global_setting(\"client_secret\")\n        self.tenant_id = helper.get_global_setting(\"tenant_id\")\n        self.scope = \"https://netcleansaasportal.onmicrosoft.com/db80b3d5-101a-42da-9108-d058539f498b/.default\"\n        self.token_url = f\"https://login.microsoftonline.com/{self.tenant_id}/oauth2/v2.0/token\"\n        self.access_token = None\n        self.expires_at = 0\n        self.KV_STORE_COLLECTION = \"netclean_oauth_tokens\"\n        self.KEY_NAME = \"access_token\"  # Only 1 entry needed\n\n        # Connect to Splunk service\n        self.service = connect(\n            token=self.helper.session_key,\n            app=helper.proactive_app_name,\n            autologin=True\n        )\n        try:\n            self.store = self.service.kvstore[self.KV_STORE_COLLECTION]\n        except Exception as e:\n            self.helper.log_error(f\"Failed to access KV Store collection '{self.KV_STORE_COLLECTION}': {e}\")\n            raise\n\n    def get_token(self):\n        try:\n            records = list(self.store.data.query(query=json.dumps({\"_key\": \"cached_token\"})))\n            if records:\n                record = records[0]\n                if time.time() < record.get(\"expires_at\", 0):\n                    self.helper.log_info(\"Using cached OAuth token from KV Store.\")\n                    return record[\"token\"]\n                else:\n                    self.helper.log_info(\"Cached token expired. Requesting new one.\")\n        except Exception as e:\n            self.helper.log_info(f\"Could not read token from KV Store: {e}\")\n\n        # No valid token; fetch a new one\n        token_data = self._request_token()\n        access_token = token_data[\"access_token\"]\n        expires_at = time.time() + token_data.get(\"expires_in\", 3600) - 60\n        \n        self.helper.log_debug(f\"Access token: {access_token}\")\n\n        self._store_token(access_token, expires_at)\n        return access_token\n\n    def _store_token(self, token, expires_at):\n        payload = {\n            \"token\": token,\n            \"expires_at\": expires_at\n        }\n\n        try:\n            self.store.data.update(\"cached_token\", json.dumps(payload))\n            self.helper.log_info(\"OAuth token successfully updated in KV Store.\")\n        except Exception as e:\n            self.helper.log_info(f\"Update failed for token, trying insert: {e}\")\n            try:\n                payload[\"_key\"] = \"cached_token\"\n                self.store.data.insert(json.dumps(payload))\n                self.helper.log_info(\"OAuth token inserted into KV Store.\")\n            except Exception as insert_e:\n                self.helper.log_error(f\"Insert also failed for token: {insert_e}\")\n\n    def _request_token(self):\n        headers = {\"Content-Type\": \"application/x-www-form-urlencoded\"}\n        data = {\n            'grant_type': 'client_credentials',\n            'client_id': self.client_id,\n            'client_secret': self.client_secret,\n            'scope': self.scope\n        }\n\n        self.helper.log_debug(\"Requesting new access token.\")\n        response = requests.post(self.token_url, headers=headers, data=data)\n\n        if response.status_code != 200:\n            self.helper.log_error(f\"Failed to get token: HTTP {response.status_code} - {response.text}\")\n            raise Exception(\"Token request failed\")\n\n        return response.json()\n        \n    def _clear_auth_token_from_kvstore(self):\n        \"\"\"\n        Deletes the cached OAuth token from the KV Store.\n        \"\"\"\n        try:\n            # Delete the token entry with _key = \"cached_token\"\n            self.store.data.delete_by_id(\"cached_token\")\n            self.helper.log_info(\"Successfully deleted cached token from KV Store.\")\n        except Exception as e:\n            self.helper.log_error(f\"Failed to delete cached token from KV Store: {e}\")\n        \n\nclass NetCleanAPI:\n    def __init__(self, helper, token_manager):\n        self.helper = helper\n        self.token_manager = token_manager\n        self.api_url = \"https://api.service.netclean.com/api/v1/verifyhashes\"\n\n    def verify_hashes(self, hashes, test_mode=False, response_mode=\"Content\"):\n        if not hashes:\n            self.helper.log_error(\"No hashes provided for verification.\")\n            raise ValueError(\"Hash list cannot be empty.\")\n\n        if any(len(h) != 40 or not h.isalnum() for h in hashes):\n            self.helper.log_error(\n                \"Invalid hash detected. Ensure all hashes are 40-character alphanumeric SHA-1 strings.\")\n            raise ValueError(\"Each hash must be a 40-character alphanumeric SHA-1 string.\")\n\n        if len(hashes) > 2000:\n            self.helper.log_error(\"Too many hashes provided. Limit is 2000 per request.\")\n            raise ValueError(\"Maximum of 2000 hashes per request allowed.\")\n\n        token = self.token_manager.get_token()\n\n        headers = {\n            \"Authorization\": f\"Bearer {token}\",\n            \"Content-Type\": \"application/json\",\n            \"Response-Mode-When-No-Hit\": \"Content\",\n            \"User-Agent\": f\"Splunk-TA-netclean-proactive-api/1.0\"\n        }\n\n        params = {\"test\": str(test_mode).lower()}\n        body = {\"hashes\": hashes}\n\n        self.helper.log_debug(f\"Request Headers: {headers}\")\n        self.helper.log_debug(f\"Request Body: {body}\")\n\n        try:\n            response = requests.post(self.api_url, headers=headers, json=body)\n\n            if response.status_code == 200:\n                self.helper.log_info(\"Hash verification successful.\")\n                return response.json()\n\n            elif response.status_code == 204:\n                self.helper.log_info(\"No content returned. No matches found for provided hashes.\")\n                return {}\n\n            else:\n                try:\n                    content = response.text\n                    self.helper.log_error(f\"API call failed: HTTP {response.status_code} - Response content: {content}\")\n                except Exception as log_err:\n                    self.helper.log_error(\n                        f\"API call failed: HTTP {response.status_code} - Unable to decode response text: {log_err}\")\n                raise Exception(f\"API error: {response.status_code}\")\n\n\n        except requests.exceptions.RequestException as e:\n            self.helper.log_error(f\"Exception during API call: {str(e)}\")\n            raise\n\n\ndef resolve_macro(helper, macro_name):\n    try:\n        uri = f\"{helper.settings.get('server_uri')}/servicesNS/nobody/{helper.settings.get('app')}/admin/macros/{macro_name}?output_mode=json\"\n        headers = {\"Authorization\": f\"Splunk {helper.session_key}\"}\n        response = requests.get(uri, headers=headers, verify=False)\n        if response.status_code == 200:\n            result = response.json()\n            definition = result['entry'][0]['content']['definition']\n            helper.log_info(f\"Resolved macro `{macro_name}` to `{definition}`.\")\n            return definition\n        else:\n            helper.log_error(f\"Failed to resolve macro {macro_name}: {response.text}\")\n    except Exception as e:\n        helper.log_error(f\"Exception while resolving macro {macro_name}: {e}\")\n\n    return \"netclean_proactive\"\n\n\ndef get_search_metadata_from_sid(helper):\n    if not all([helper.settings.get(\"sid\"), helper.settings.get('server_uri')]):\n        helper.log_error(\"Missing one or more required values to retrieve search metadata.\")\n        return None\n\n    try:\n        url = f\"{helper.settings.get('server_uri')}/services/search/jobs/{helper.settings.get('sid')}?output_mode=json\"\n        headers = {\"Authorization\": f\"Splunk {helper.session_key}\"}\n        response = requests.get(url, headers=headers, verify=False)\n\n        if response.status_code != 200:\n            helper.log_error(f\"Failed to fetch search metadata (status {response.status_code}): {response.text}\")\n            return None\n\n        content = response.json()[\"entry\"][0][\"content\"]\n        return {\n            \"search\": content.get(\"search\", \"\"),\n            \"earliest_time\": content.get(\"searchEarliestTime\", \"\"),\n            \"latest_time\": content.get(\"searchLatestTime\", \"\")\n        }\n\n    except Exception as e:\n        helper.log_error(f\"Exception while fetching search metadata: {e}\")\n        return None\n\n\ndef build_search_alert_link(helper, hash_value):\n    metadata = get_search_metadata_from_sid(helper)\n\n    helper.log_info(f\"Search Meta: {json.dumps(metadata)}\")\n\n    if not metadata or not metadata.get(\"search\"):\n        helper.log_error(\"No search metadata available to build alert link.\")\n        return \"\"\n\n    # raw_query = metadata[\"search\"]\n    query = f\"{metadata['search']} | search {helper.get_param('hash_field')}={hash_value}\"\n    helper.log_info(f\"Search Query: {query}\")\n    earliest = metadata.get(\"earliest_time\", \"now\")\n    latest = metadata.get(\"latest_time\", \"now\")\n    app = helper.settings.get(\"app\", \"search\")\n\n    encoded_query = quote(query)\n\n    return f\"/app/{app}/search?earliest={earliest}&latest={latest}&q={encoded_query}\"\n\n\ndef write_results_to_index(helper, results, alert_name):\n    index = resolve_macro(helper, \"netclean_proactive_index\")\n    sourcetype = \"netclean:hashcheck\"\n    source = f\"{alert_name}\"\n    host = helper.settings.get(\"host\")\n\n    for result in results.get(\"results\", []):\n        alert_link = build_search_alert_link(helper, result.get(\"hash\"))\n\n        event = {\n            \"_time\": time.time(),\n            \"alert_name\": alert_name,\n            \"hash\": result.get(\"hash\"),\n            \"hit\": result.get(\"hit\"),\n            \"sources\": \", \".join(result.get(\"sources\", [])),\n            \"app_name\": helper.settings.get(\"app\"),\n            \"alert_link\": alert_link\n        }\n\n        try:\n            url = f\"{helper.settings.get('server_uri')}/services/receivers/simple?index={index}&sourcetype={sourcetype}&host=localhost&source={source}\"\n\n            headers = {\n                \"Authorization\": f\"Splunk {helper.session_key}\",\n                \"Content-Type\": \"text/plain\"\n            }\n\n            # Send the raw JSON event\n            response = requests.post(url, headers=headers, data=json.dumps(event), verify=False)\n\n            if response.status_code == 200:\n                helper.log_info(f\"Posted event to index {index}: {event['hash']}\")\n            else:\n                helper.log_error(f\"Failed to post event: HTTP {response.status_code} - {response.text}\")\n\n        except Exception as e:\n            helper.log_error(f\"Exception posting event for hash {event['hash']}: {e}\")\n\n\ndef get_hashes_from_field_name(helper, field_name):\n    \"\"\"\n    Extracts valid hashes from a field in events.\n    Queries KV store and splits into:\n    - uncached_hashes: not found in KV\n    - cached_hashes_with_hit_status: dict of {hash: hit}\n    \"\"\"\n    events = list(helper.get_events())\n    all_hashes = []\n\n    for event in events:\n        value = event.get(field_name)\n        if isinstance(value, str) and len(value) == 40 and value.isalnum():\n            all_hashes.append(value)\n        else:\n            helper.log_info(f\"Skipping invalid or missing {field_name} in event: {event}\")\n\n    helper.log_info(f\"Total hashes extracted from field '{field_name}': {len(all_hashes)}\")\n\n    cached = {}\n    uncached = []\n\n    try:\n        service = connect(token=helper.session_key, app=helper.settings.get(\"app\"), autologin=True)\n        store = service.kvstore[\"netclean_hash_hits\"]\n    except Exception as e:\n        helper.log_error(f\"Failed to access KV Store: {e}\")\n        return all_hashes, {}  # fallback: treat all as uncached\n\n    for h in all_hashes:\n        try:\n            result = store.data.query(query=json.dumps({\"_key\": h}))\n            if result:\n                hit = result[0].get(\"hit\", False)\n                cached[h] = hit\n            else:\n                uncached.append(h)\n        except Exception as e:\n            helper.log_info(f\"KV store query failed for hash {h}: {e}\")\n            uncached.append(h)\n\n    helper.log_info(f\"Cached hashes: {len(cached)} | Uncached hashes: {len(uncached)}\")\n    return uncached, cached\n\n\ndef validate_index_exists(helper):\n    try:\n        service = connect(token=helper.session_key, app=helper.settings.get(\"app\"), autologin=True)\n        index_name = resolve_macro(helper, \"netclean_proactive_index\")\n        index = service.indexes[index_name]\n        \n        if index:\n            helper.log_info(f\"Validated index '{index_name}' exists.\")\n            return True\n    except HTTPError as e:\n        if e.status == 404:\n            helper.log_error(f\"Index '{index_name}' does not exist.\")\n        else:\n            helper.log_error(f\"Error checking index '{index_name}': {e}\")\n    except Exception as ex:\n        helper.log_error(f\"Unexpected error validating index '{index_name}': {ex}\")\n    return False\n\n\n\ndef update_hash_kvstore(helper, results, write_all=True):\n    try:\n        service = connect(token=helper.session_key, app=helper.settings.get(\"app\"), autologin=True)\n        store = service.kvstore[\"netclean_hash_hits\"]\n    except Exception as e:\n        helper.log_error(f\"Could not connect to KV Store: {e}\")\n        return\n\n    try:\n        expiry_offset = int(helper.get_global_setting(\"default_hash_expiry\"))\n    except Exception as e:\n        helper.log_error(f\"Missing or invalid 'default_hash_expiry' setting: {e}\")\n        return\n\n    current_time = int(time.time())\n    updated = 0\n\n    for result in results.get(\"results\", []):\n        hash_val = result.get(\"hash\")\n        hit_status = result.get(\"hit\", False)\n\n        if not hash_val:\n            continue\n        if not write_all and not hit_status:\n            continue\n\n        hash_expiry = result.get(\"hash_expiry\")\n        if hash_expiry is None:\n            hash_expiry = current_time + expiry_offset\n\n        payload = {\n            \"_key\": hash_val,\n            \"hit\": hit_status,\n            \"hash_expiry\": hash_expiry,\n            \"updated\": current_time\n        }\n\n        try:\n            store.data.update(hash_val, json.dumps(payload))\n            helper.log_info(f\"Updated hash in KV Store: {hash_val}\")\n            updated += 1\n        except Exception as e:\n            helper.log_info(f\"Update failed for hash {hash_val}, trying insert: {e}\")\n            try:\n                store.data.insert(json.dumps(payload))\n                helper.log_info(f\"Inserted new hash into KV Store: {hash_val}\")\n                updated += 1\n            except Exception as insert_e:\n                helper.log_error(f\"Insert also failed for hash {hash_val}: {insert_e}\")\n\n    helper.log_info(f\"Total hashes written to KV Store: {updated}\")\n\n\ndef chunk_list(lst, chunk_size):\n    for i in range(0, len(lst), chunk_size):\n        yield lst[i:i + chunk_size]\n\n\ndef process_event(helper, *args, **kwargs):\n\n    helper.log_info(\"Alert action netclean_proactive_api started.\")\n\n    # variables - need to move to init\n    helper.proactive_app_name = \"TA-netclean-proactive-api\"\n\n    try:\n        if not validate_index_exists(helper):\n            helper.log_error(f\"Aborting event writing. Index '{index}' not found.\")\n            return\n        \n        \n        field_name = helper.get_param(\"hash_field\")\n        if not field_name:\n            helper.log_error(\"Field name was not provided in 'Hash Field' parameter.\")\n            return\n\n        # Step 1: Extract hashes and split cached vs uncached\n        uncached_hashes, cached_hashes = get_hashes_from_field_name(helper, field_name)\n\n        if not uncached_hashes and not cached_hashes:\n            helper.log_info(\"No hashes to process (all invalid or missing).\")\n            return\n\n        # Step 2: Initialize results container & token manager\n        results = {\"results\": []}\n        token_manager = NetCleanOAuth2TokenManager(helper)\n        \n        # Step 3: Validate if adhoc or test connection\n        # if true: reset auth cache\n        if helper.action_mode==\"adhoc\" or helper.settings.get(\"search_name\")==\"Netclean Proactive | Test Connection\":\n            token_manager._clear_auth_token_from_kvstore()\n\n        # Step 4: Call NetClean API for uncached hashes\n        \n        if uncached_hashes:\n            netclean_api = NetCleanAPI(helper, token_manager)\n\n            api_result = netclean_api.verify_hashes(uncached_hashes)\n            if api_result and \"results\" in api_result:\n                #results.extend(api_results[\"results\"])\n                results[\"results\"].extend(api_result[\"results\"])\n                update_hash_kvstore(helper, api_result, write_all=True)\n            else:\n                helper.log_info(\"No API results returned or no matches found.\")\n\n        # Step 5: Add cached hashes to results\n        for h, hit, sources in cached_hashes.items():\n            results[\"results\"].append({\n                \"hash\": h,\n                \"hit\": hit,\n                \"sources\": sources\n            })\n\n        if not results[\"results\"]:\n            helper.log_info(\"No hash results to write after API and cache check.\")\n            return\n\n        # Step 6: Index the results\n        if helper.settings.get(\"search_name\"):\n            source_value = helper.settings.get(\"search_name\")\n        elif helper.action_mode==\"adhoc\":\n            source_value = helper.action_mode\n        else:\n            source_value = \"Unknown\"\n            \n        write_results_to_index(helper, results, source_value)\n\n\n    except Exception as e:\n        helper.log_error(f\"Unexpected error during alert processing: {str(e)}\")\n\n    return 0\n", "uuid": "76e6b5df8b79489fa844f558f7eccc4f"}]}, "basic_builder": {"appname": "TA-netclean-proactive-api", "friendly_name": "Netclean Proactive API", "version": "1.0.0", "author": "Dan Reeder", "description": "This technical add-on allows users to interface with the Netclean Proactive API using an alert action.", "theme": "#0e2343", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.0", "tab_build_no": "0", "build_no": 1}, "field_extraction_builder": {"netclean:hashcheck": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {}, "customized_settings": [{"format_type": "text", "required": false, "name": "tenant_id", "label": "Tenant ID", "default_value": "0437858c-d28b-46b1-a0ce-3878715c9b5d", "help_string": "", "internal_name": "", "type": "text", "value": "0437858c-d28b-46b1-a0ce-3878715c9b5d"}, {"format_type": "password", "required": true, "name": "client_id", "label": "Client ID", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}, {"format_type": "password", "required": true, "name": "client_secret", "label": "Client Secret", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}, {"format_type": "text", "required": true, "name": "default_hash_expiry", "label": "Default Hash Expiry", "default_value": "86400", "help_string": "", "internal_name": "", "type": "text", "value": "86400"}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1751359284_29", "progress": 0.7857142857142857}}