
# Application-level permissions

[]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

[alert_actions/thousandeyes_forward_splunk_events]
access = read : [ itoa_admin, itoa_team_admin, itoa_analyst ], write : [ itoa_admin, itoa_team_admin ], delete: [ itoa_admin, itoa_team_admin ]
export = system

[collections/itsi_episodes]
access = read : [ * ], write : [ admin ]
export = system
