

[send_to_adx]
python.version = python3
param.cluster_url = <string> Azure Data Explorer Cluster Ingestion URL. It's a required parameter.
param.app_id = <string> Azure Application Client Id. It's a required parameter.
param.app_secret = <string> Azure Application Secret. It's a required parameter.
param.tenant_id = <string> Azure Application Tenant Id. It's a required parameter.
param.database_name = <string> Azure Data Explorer Database Name. It's a required parameter.
param.table_name = <string> Azure Data Explorer Table Name. It's a required parameter.
param.table_mapping_name = <string> Azure Data Explorer Table Mapping Name.
param.remove_extra_fields = <list> Remove Extra Fields.  It's default value is 0.
param.durable_mode = <list> Durable Mode.  It's default value is 0.

