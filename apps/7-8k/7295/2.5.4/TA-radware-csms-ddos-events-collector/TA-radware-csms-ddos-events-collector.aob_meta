{"basic_builder": {"appname": "TA-radware-csms-ddos-events-collector", "friendly_name": "Radware CSMS DDoS Events Collector", "version": "2.5.2", "author": "Yuval Moran", "description": "Splunk for Radware Cloud DDoS Event Collector allows Splunk to collect security events on Radware's Cloud DDoS portal Please note that this plugin is supported by Radware Cloud Automation team. Any request for support or integration: https://support.radware.com/app/ask", "theme": "#000000", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.2.0", "tab_build_no": "0", "build_no": 13}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "CSMS_Radware_DDoS_API", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "csms_radware_ddos_api", "title": "CSMS_Radware_DDoS_API", "description": "Data Puller", "type": "customized", "parameters": [{"name": "account_id", "label": "Account ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "5f38d24a1b0e007ca95b762f"}, {"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "eyJhbGciOiJIUzM4NCJ9.eyJyb2xlSWRzIjpbInJvbF96cUlrbmpjQ3dKY205OXRGIl0sImlkIjp7InZhbHVlIjoiNjYwYTY5YmJmYTgyNTAwZTdlNjNiYTlkIn0sImFjY291bnRJZCI6eyJ2YWx1ZSI6IjY0MjJmMzNiZmU0MTJiNzc4ZDUzYmI5MSJ9fQ.k711DTGchSLHME4B4qh0eiC--Xot1xsTtQNhvje-HycvzbYIW679ZZN57EOipnqy"}], "data_inputs_options": [{"type": "customized_var", "name": "account_id", "title": "Account ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}], "code": "# encoding = utf-8\n\n\n\nimport os\n\nimport sys\n\nimport time\n\nimport datetime\n\nimport json\n\nimport http.client, urllib.parse, urllib.request\n\nimport re\n\nimport requests\n\n\n\n\n\ndef validate_input(helper, definition):\n\n    pass\n\n\ndef getActionAttack(numAction):\n\n    actions =  [\n        {\n          \"enum\": 0,\n          \"text\": \"Unknown\"\n        },\n        {\n          \"enum\": 1,\n          \"text\": \"Forward\"\n        },\n        {\n          \"enum\": 2,\n          \"text\": \"Proxy\"\n        },\n        {\n          \"enum\": 3,\n          \"text\": \"Drop\"\n        },\n        {\n          \"enum\": 4,\n          \"text\": \"Source Reset\"\n        },\n        {\n          \"enum\": 5,\n          \"text\": \"Destination Reset\"\n        },\n        {\n          \"enum\": 6,\n          \"text\": \"Source Destination Reset\"\n        },\n        {\n          \"enum\": 7,\n          \"text\": \"Bypass\"\n        },\n        {\n          \"enum\": 8,\n          \"text\": \"Challenge\"\n        },\n        {\n          \"enum\": 9,\n          \"text\": \"Quarantine\"\n        },\n        {\n          \"enum\": 10,\n          \"text\": \"Drop and Quarantine\"\n        },\n        {\n          \"enum\": 11,\n          \"text\": \"Http 200 Ok\"\n        },\n        {\n          \"enum\": 12,\n          \"text\": \"Http 200 Ok Reset Dest\"\n        },\n        {\n          \"enum\": 13,\n          \"text\": \"Http 403 Forbidden\"\n        },\n        {\n          \"enum\": 14,\n          \"text\": \"Http 403 Forbidden Reset Dest\"\n        }\n      ]\n    for i in actions:\n        if i[\"enum\"] == int(numAction):\n            return i[\"text\"]\n\n\n\ndef getSecurityEvents(helper, api_key, timelower, timeupper, account_id):\n\n\n\n    events = {}\n\n\n\n    hdrs = {\"x-api-key\": api_key}\n\n\n\n    url = f\"https://api.radwarecloud.app/api/alerts/events/?type=account&id={account_id}&from={timelower}&to={timeupper}&severity=HIGH,MEDIUM,LOW,INFO\"\n\n    response = requests.get(url, headers=hdrs, verify=False)\n\n    events = response\n\n\n\n    if response.status_code != 200:\n\n        raise Exception(\n\n            f\"{response.status_code}, {response.reason}, {api_key}, {account_id}\"\n\n        )\n\n\n\n    return json.dumps(events.json())\n\n\n\n\n\ndef getOperationalEvents(helper, api_key, timelower, timeupper, account_id):\n\n\n\n    events = {}\n\n\n\n    hdrs = {\"x-api-key\": api_key}\n\n\n\n    url = f\"https://api.radwarecloud.app/api/alerts/operational/?type=account&id={account_id}&from={timelower}&to={timeupper}&severity=HIGH,MEDIUM\"\n\n\n\n    response = requests.get(url, headers=hdrs, verify=False)\n\n    events = response\n\n\n\n    if response.status_code != 200:\n\n        raise Exception(\n\n            f\"{response.status_code}, {response.reason}, {api_key}, {account_id}\"\n\n        )\n\n\n\n    return json.dumps(events.json())\n\n\n\ndef format_speed(mbps):\n    \"\"\"\n    Formats a speed given in Mbps to a string representation using Kbps, Mbps, or Gbps.\n    \n    Args:\n    - mbps (float): The speed in Mbps.\n    \n    Returns:\n    - str: The formatted speed string.\n    \"\"\"\n    if mbps >= 1000:  # Convert to Gbps\n        return f\"{mbps / 1000:.3f} Gbps\"\n    elif mbps >= 1:  # Keep as Mbps\n        return f\"{mbps:.3f} Mbps\"\n    else:  # Convert to Kbps\n        return f\"{mbps * 1000:.3f} Kbps\"\n\n\ndef format_event(helper, ew, dict_events):\n\n    item = 0\n\n    build_event = \"\"\n\n\n\n    while item < len(dict_events[\"security\"]):\n\n        build_event = (\n\n            \"_time=\"\n\n            + str(dict_events[\"security\"][item][\"timestamp\"][\"_date_time\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"type=\"\n\n            + str(dict_events[\"security\"][item][\"attack\"][\"type\"])\n\n            + \",\"\n\n        )\n\n\n\n        build_event = (\n\n            build_event + \"origin=\" + str(dict_events[\"security\"][item][\"origin\"]) + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"site_name=\"\n\n            + str(dict_events[\"security\"][item][\"acc_site_name\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"policy_name=\"\n\n            + str(dict_events[\"security\"][item][\"policy_name\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"device_name=\"\n\n            + str(dict_events[\"security\"][item][\"device_name\"])\n\n            + \",\"\n\n        )\n\n\n\n        if dict_events[\"security\"][item][\"sources\"] != \"Unknown\":\n\n            build_event = (\n\n                build_event\n\n                + \"srcIP=\"\n\n                + dict_events[\"security\"][item][\"attack\"][\"source_addr\"]\n\n                + \",srcPort=\"\n\n                + dict_events[\"security\"][item][\"attack\"][\"source_port\"]\n\n                + \",\"\n\n            )\n\n        else:\n\n            build_event = (\n\n                build_event + \"srcIP=\" + \"Multiple\" + \",srcPort=\" + \"Multiple\" + \",\"\n\n            )\n\n\n\n        build_event = (\n\n            build_event\n\n            + \"attack_action=\"\n\n            + str(getActionAttack(dict_events[\"security\"][item][\"attack\"][\"action\"]))\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"account_name=\"\n\n            + str(dict_events[\"security\"][item][\"account_name\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"category=\"\n\n            + str(dict_events[\"security\"][item][\"attack\"][\"name\"])\n\n            + \",\"\n\n        )\n\n\n\n        if dict_events[\"security\"][item][\"targets\"][0] != \"Multiple\":\n\n            build_event = (\n\n                build_event\n\n                + \"dstIP=\"\n\n                + dict_events[\"security\"][item][\"attack\"][\"target_addr\"]\n\n                + \",dstPort=\"\n\n                + dict_events[\"security\"][item][\"attack\"][\"target_port\"]\n\n                + \",\"\n\n            )\n\n        else:\n\n            build_event = build_event + \"dstIP=Multiple,dstPort=Multiple,\"\n\n\n\n        build_event = (\n\n            build_event\n\n            + \"bw_pps=\"\n\n            + str(dict_events[\"security\"][item][\"attack\"][\"maxAttackPacketRatePps\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"report_id=\"\n\n            + str(dict_events[\"security\"][item][\"attack\"][\"report_id\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"type=\"\n\n            + str(dict_events[\"security\"][item][\"attack\"][\"type\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"risk=\"\n\n            + str(dict_events[\"security\"][item][\"attack\"][\"risk\"])\n\n            + \",\"\n\n        )\n\n\n\n        if re.match(\n\n            r\"[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\+.*\",\n\n            dict_events[\"security\"][item][\"start_time\"][\"_date_time\"],\n\n        ):\n\n            begins = (\n\n                int(\n\n                    time.mktime(\n\n                        datetime.datetime.strptime(\n\n                            dict_events[\"security\"][item][\"start_time\"][\"_date_time\"],\n\n                            \"%Y-%m-%dT%H:%M:%S%z\",\n\n                        ).timetuple()\n\n                    )\n\n                )\n\n                * 1000\n\n            )\n\n        else:\n\n            begins = (\n\n                int(\n\n                    time.mktime(\n\n                        datetime.datetime.strptime(\n\n                            dict_events[\"security\"][item][\"start_time\"][\"_date_time\"],\n\n                            \"%Y-%m-%dT%H:%M:%S.%f%z\",\n\n                        ).timetuple()\n\n                    )\n\n                )\n\n                * 1000\n\n            )\n\n\n\n        build_event = (\n\n            build_event\n\n            + \"name=\"\n\n            + str(dict_events[\"security\"][item][\"attack\"][\"name\"])\n\n            + \",\"\n\n        )\n\n        if re.match(\n\n            r\"[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\+.*\",\n\n            dict_events[\"security\"][item][\"end_time\"][\"_date_time\"],\n\n        ):\n\n            ends = (\n\n                int(\n\n                    time.mktime(\n\n                        datetime.datetime.strptime(\n\n                            dict_events[\"security\"][item][\"end_time\"][\"_date_time\"],\n\n                            \"%Y-%m-%dT%H:%M:%S%z\",\n\n                        ).timetuple()\n\n                    )\n\n                )\n\n                * 1000\n\n            )\n\n        else:\n\n            ends = (\n\n                int(\n\n                    time.mktime(\n\n                        datetime.datetime.strptime(\n\n                            dict_events[\"security\"][item][\"end_time\"][\"_date_time\"],\n\n                            \"%Y-%m-%dT%H:%M:%S.%f%z\",\n\n                        ).timetuple()\n\n                    )\n\n                )\n\n                * 1000\n\n            )\n\n\n        build_event = (\n\n            build_event + \"attack_bw=\" + format_speed(dict_events[\"security\"][item][\"attack\"][\"maxAttackRateBps\"]) + \",duration=\" + str(dict_events[\"security\"][item][\"attack\"][\"duration\"])\n\n        )\n\n\n\n        event = helper.new_event(\n\n            source=helper.get_input_type(),\n\n            index=helper.get_output_index(),\n\n            sourcetype=helper.get_sourcetype(),\n\n            data=build_event,\n\n        )\n\n        ew.write_event(event)\n\n\n\n        item += 1\n\n\n\n    item = 0\n\n    build_event = \"\"\n\n\n\n    while item < len(dict_events[\"operational\"]):\n\n        build_event = (\n\n            \"_time=\"\n\n            + str(dict_events[\"operational\"][item][\"timestamp\"][\"_date_time\"])\n\n            + \",\"\n\n        )\n\n        build_event = (\n\n            build_event + \"type=\" + dict_events[\"operational\"][item][\"type\"] + \",\"\n\n        )\n\n        build_event = (\n\n            build_event + \"origin=\" + dict_events[\"operational\"][item][\"origin\"] + \",\"\n\n        )\n\n        build_event = (\n\n            build_event + \"code=\" + dict_events[\"operational\"][item][\"code\"] + \",\"\n\n        )\n\n        build_event = (\n\n            build_event + \"id=\" + dict_events[\"operational\"][item][\"_id\"][\"_oid\"] + \",\"\n\n        )\n\n        build_event = (\n\n            build_event\n\n            + \"severity=\"\n\n            + str(dict_events[\"operational\"][item][\"severity\"])\n\n            + \",\"\n\n        )\n\n        if \"site_name\" in dict_events[\"operational\"][item][\"metadata\"]:\n\n            build_event = (\n\n                build_event\n\n                + \"site_name=\"\n\n                + dict_events[\"operational\"][item][\"metadata\"][\"site_name\"]\n\n                + \",\"\n\n            )\n\n        build_event = (\n\n            build_event\n\n            + \"description=\"\n\n            + dict_events[\"operational\"][item][\"metadata\"][\"description\"]\n\n        )\n\n\n\n        event = helper.new_event(\n\n            source=helper.get_input_type(),\n\n            index=helper.get_output_index(),\n\n            sourcetype=helper.get_sourcetype(),\n\n            data=build_event,\n\n        )\n\n        ew.write_event(event)\n\n        item += 1\n\n\n\n\n\ndef collect_events(helper, ew):\n\n\n\n    stanza = helper.get_input_stanza()\n\n\n\n    for key in stanza:\n\n        interval = int(stanza[key][\"interval\"])\n\n        pass\n\n    now = int(round(time.time() * 1000))\n\n    past = now - (interval * 1000)\n\n\n\n    credentials = {}\n\n    dict_events = {}\n\n    credentials[\"account_id\"] = helper.get_arg(\"account_id\")\n\n    credentials[\"api_key\"] = helper.get_arg(\"api_key\")\n\n\n\n    security_events = getSecurityEvents(\n\n        helper, credentials[\"api_key\"], past, now, credentials[\"account_id\"]\n\n    )\n\n\n\n    dict_events[\"security\"] = json.loads(security_events)[\"reply\"]\n\n\n\n    operational_events = getOperationalEvents(\n\n        helper, credentials[\"api_key\"], past, now, credentials[\"account_id\"]\n\n    )\n\n    dict_events[\"operational\"] = json.loads(operational_events)[\"reply\"]\n\n    \n\n    format_event(helper, ew, dict_events)\n\n\n\n", "customized_options": [{"name": "account_id", "value": ""}], "uuid": "0845e06bcf554a5792f327954b547194", "sample_count": "107"}]}, "field_extraction_builder": {"CSMS_Radware_DDoS_API": {"data_format": "unstructured_data"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http", "proxy_enabled": false}, "log_settings": {"log_level": "DEBUG"}}}, "sourcetype_builder": {"CSMS_Radware_DDoS_API": {"metadata": {"event_count": 0, "data_input_name": "csms_radware_ddos_api", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1759659185_16", "progress": 1.0}}