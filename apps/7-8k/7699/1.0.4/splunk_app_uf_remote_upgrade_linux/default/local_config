# Splunk updater configurations

# *DO NOT* update this file. Copy and create another "local_config" file
# to the ./local/packages folder, and customize configurations there. This file will
# be delivered to the Remote Updater when the app is deployed by DS. The Updater
# will merge this file and its own ./config/local_config, then apply the changes.

# DO NOT set SPLUNK_HOME from monitored dir, unless Upgrader is running as ROOT,
# otherwise Splunk cannot start after upgrade due to lack of permissions for
# the new SPLUNK_HOME
# SPLUNK_HOME=<path-to-splunk-home-dir>


MONITOR_PKG_INTERVAL_SEC=5    # range [5, 300]
FWD_UPGRADE_TIMEOUT_SEC=300   # range [60, 600]

# set it to 0 to not retry when UF upgrade fails
FWD_UPGRADE_MAX_RETRY=3       # range [0, 100]

# set it to 0 to just keep one last history dir
ROTATE_HISTORY_LOG_DAYS=30    # range [0, 360]

