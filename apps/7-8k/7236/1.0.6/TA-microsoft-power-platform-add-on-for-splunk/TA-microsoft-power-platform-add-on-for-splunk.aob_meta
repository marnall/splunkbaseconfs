{"basic_builder": {"appname": "TA-microsoft-power-platform-add-on-for-splunk", "friendly_name": "Microsoft Power Platform Add-on for Splunk", "version": "1.0.0", "author": "Spex", "description": "This add-on enables users to create a persistent connection to Microsoft 365 APIs so that Power Platform logs can be continually streamed to the Splunk environment. This connection enables admins to use the power of the Splunk to effectively monitor Power Automate executions, statuses errors and threshold limits within Microsoft 365.", "theme": "#fa4c06", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.4", "tab_build_no": "0", "build_no": 3}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "o365:powerplatform:environments", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "o365_power_platform_environments", "title": "O365 Power Platform Environments", "description": "", "type": "customized", "parameters": [{"required": true, "name": "tenant_id", "label": "Tenant ID", "default_value": "", "placeholder": "Enter Tenant ID here...", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "client_id", "label": "Client ID", "default_value": "", "placeholder": "Enter Client ID here...", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "client_secret", "label": "Client Secret", "placeholder": "Enter Client Secret here...", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "tenant_id", "title": "Tenant ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Enter Tenant ID here..."}, {"type": "customized_var", "name": "client_id", "title": "Client ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Enter Client ID here..."}, {"type": "customized_var", "name": "client_secret", "title": "Client Secret", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": "Enter Client Secret here..."}], "code": "\r\n# encoding = utf-8\r\n\r\nimport os\r\nimport sys\r\nimport time\r\nimport json\r\nimport datetime\r\nimport requests\r\n\r\nfrom o365_power_platform_main import get_access_token, get_api_data, API_VERSION\r\n\r\n\r\nRESOURCE = \"https://api.bap.microsoft.com\"\r\nSCOPE = f'{RESOURCE}/.default'\r\n\r\ndef validate_input(helper, definition):\r\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\r\n    # This example accesses the modular input variable\r\n    # scope = definition.parameters.get('scope', None)\r\n    # client_id = definition.parameters.get('client_id', None)\r\n    # tenant_id = definition.parameters.get('tenant_id', None)\r\n    # client_secret = definition.parameters.get('client_secret', None)\r\n    pass\r\n\r\ndef collect_events(helper, ew):\r\n    opt_client_id = helper.get_arg('client_id')\r\n    opt_tenant_id = helper.get_arg('tenant_id')\r\n    opt_client_secret = helper.get_arg('client_secret')\r\n    \r\n    ms_url = f\"https://login.microsoftonline.com/{opt_tenant_id}/oauth2/v2.0/token\"\r\n\r\n\r\n    url = f\"{RESOURCE}/providers/Microsoft.BusinessAppPlatform/scopes/admin/environments?api-version={API_VERSION}\"#&$expand=properties.capacity,properties.addons\"\r\n    \r\n    data = {\r\n        'client_id': opt_client_id,\r\n        'client_secret': opt_client_secret,\r\n        'grant_type': 'client_credentials',\r\n        'scope': SCOPE\r\n    }\r\n\r\n    # generate access token\r\n    token = get_access_token(data, ms_url)\r\n    # get and transform data\r\n    env_data = get_api_data(token, url)\r\n    env_data = json.loads(env_data)\r\n\r\n    final_result = []\r\n    \r\n    for env in env_data[\"value\"]:\r\n        state = helper.get_check_point(str(env[\"name\"]))\r\n        if state is None:\r\n            final_result.append(env)\r\n            helper.save_check_point(str(env[\"name\"]), \"Indexed\")\r\n        #helper.delete_check_point(env[\"name\"])\r\n    \r\n    res = json.dumps(final_result)\r\n    # To create a splunk event\r\n    event = helper.new_event(res, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\r\n    ew.write_event(event)", "customized_options": [{"name": "tenant_id", "value": "038ce046-a09c-46cc-bab4-07b103fc4e00"}, {"name": "client_id", "value": "74494f4e-c584-43a8-8f34-2d7c109d91b3"}], "uuid": "7b833d4c8e5b44c3bda3a55443d87577"}, {"index": "default", "sourcetype": "o365:powerplatform:flows", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "o365_power_platform_flows", "title": "O365 Power Platform Flows", "description": "", "type": "customized", "parameters": [{"required": true, "name": "tenant_id", "label": "Tenant ID", "default_value": "", "placeholder": "Enter Tenant ID here...", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "client_id", "label": "Client ID", "default_value": "", "placeholder": "Enter Client ID here...", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "client_secret", "label": "Client Secret", "placeholder": "Enter Client Secret here...", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "tenant_id", "title": "Tenant ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Enter Tenant ID here..."}, {"type": "customized_var", "name": "client_id", "title": "Client ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Enter Client ID here..."}, {"type": "customized_var", "name": "client_secret", "title": "Client Secret", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": "Enter Client Secret here..."}], "code": "\r\n# encoding = utf-8\r\n\r\nimport os\r\nimport sys\r\nimport time\r\nimport json\r\nimport datetime\r\nimport requests\r\n\r\nfrom o365_power_platform_main import get_access_token, get_api_data, API_VERSION\r\n\r\n\r\ndef validate_input(helper, definition):\r\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\r\n    # This example accesses the modular input variable\r\n    # scope = definition.parameters.get('scope', None)\r\n    # client_id = definition.parameters.get('client_id', None)\r\n    # tenant_id = definition.parameters.get('tenant_id', None)\r\n    # client_secret = definition.parameters.get('client_secret', None)\r\n    pass\r\n\r\ndef collect_events(helper, ew):\r\n    opt_client_id = helper.get_arg('client_id')\r\n    opt_tenant_id = helper.get_arg('tenant_id')\r\n    opt_client_secret = helper.get_arg('client_secret')\r\n    \r\n    ms_url = f\"https://login.microsoftonline.com/{opt_tenant_id}/oauth2/v2.0/token\"\r\n    resource = \"https://service.flow.microsoft.com\"\r\n    scope = resource + \"/.default\"\r\n    \r\n    data = {\r\n        'client_id': opt_client_id,\r\n        'client_secret': opt_client_secret,\r\n        'grant_type': 'client_credentials',\r\n        'scope': scope\r\n    }\r\n    \r\n    def get_env_ids():\r\n        ms_url = f\"https://login.microsoftonline.com/{opt_tenant_id}/oauth2/v2.0/token\"\r\n        resource = \"https://api.bap.microsoft.com\"\r\n        scope = resource + \"/.default\"\r\n    \r\n        url = f\"{resource}/providers/Microsoft.BusinessAppPlatform/scopes/admin/environments?api-version={API_VERSION}\"#&$expand=properties.capacity,properties.addons\"\r\n        \r\n        data = {\r\n            'client_id': opt_client_id,\r\n            'client_secret': opt_client_secret,\r\n            'grant_type': 'client_credentials',\r\n            'scope': scope\r\n        }\r\n    \r\n        # generate access token\r\n        token = get_access_token(data, ms_url)\r\n        # get and transform data\r\n        env_data = get_api_data(token, url)\r\n        env_data = json.loads(env_data)\r\n        \r\n        environments = []\r\n        \r\n        for env in env_data[\"value\"]:\r\n            environments.append(env[\"name\"])\r\n        \r\n        return environments\r\n            \r\n    envs = get_env_ids()\r\n    \r\n    final_result = []\r\n\r\n    # generate access token\r\n    token = get_access_token(data, ms_url)\r\n\r\n    for env_id in envs:\r\n        url = f\"https://api.flow.microsoft.com/providers/Microsoft.ProcessSimple/scopes/admin/environments/{env_id}/flows?api-version={API_VERSION}\"\r\n        \r\n        # get and transform data\r\n        env_data = get_api_data(token, url)\r\n        env_data = json.loads(env_data)\r\n        \r\n        for flow in env_data[\"value\"]:\r\n            flow_id = flow[\"id\"]\r\n            \r\n            # Check if the event is already indexed\r\n            state = helper.get_check_point(flow_id)\r\n            if state is None:\r\n                final_result.append(flow)\r\n                \r\n                # Save the checkpoint to mark the event as indexed\r\n                helper.save_check_point(flow_id, \"Indexed\")\r\n\r\n            #helper.delete_check_point(flow_id)\r\n            \r\n    # Create a Splunk event\r\n    res = json.dumps(final_result)\r\n    event = helper.new_event(res, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\r\n    ew.write_event(event)", "customized_options": [{"name": "tenant_id", "value": "038ce046-a09c-46cc-bab4-07b103fc4e00"}, {"name": "client_id", "value": "74494f4e-c584-43a8-8f34-2d7c109d91b3"}], "uuid": "9d14a0099edb4b7c8dcd204e73c06633"}, {"index": "default", "sourcetype": "o365:powerplatform:flowruns", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "o365_power_platform_flow_runs", "title": "O365 Power Platform Flow Runs", "description": "", "type": "customized", "parameters": [{"required": true, "name": "tenant_id", "label": "Tenant ID", "default_value": "", "placeholder": "Enter Tenant ID here...", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "client_id", "label": "Client ID", "default_value": "", "placeholder": "Enter Client ID here...", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "client_secret", "label": "Client Secret", "placeholder": "Enter Client Secret here...", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "tenant_id", "title": "Tenant ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Enter Tenant ID here..."}, {"type": "customized_var", "name": "client_id", "title": "Client ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Enter Client ID here..."}, {"type": "customized_var", "name": "client_secret", "title": "Client Secret", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": "Enter Client Secret here..."}], "code": "\r\n# encoding = utf-8\r\n\r\nimport os\r\nimport sys\r\nimport time\r\nimport json\r\nimport datetime\r\nimport requests\r\n\r\nfrom o365_power_platform_main import get_access_token, get_api_data, API_VERSION\r\n\r\n\r\ndef validate_input(helper, definition):\r\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\r\n    pass\r\n\r\ndef collect_events(helper, ew):\r\n    opt_client_id = helper.get_arg('client_id')\r\n    opt_tenant_id = helper.get_arg('tenant_id')\r\n    opt_client_secret = helper.get_arg('client_secret')\r\n    \r\n    ms_url = f\"https://login.microsoftonline.com/{opt_tenant_id}/oauth2/v2.0/token\"\r\n    resource = \"https://service.flow.microsoft.com\"\r\n    scope = f\"{resource}/.default\"\r\n\r\n    data = {\r\n        'client_id': opt_client_id,\r\n        'client_secret': opt_client_secret,\r\n        'grant_type': 'client_credentials',\r\n        'scope': scope\r\n    }\r\n    \r\n    def get_env_ids():\r\n        ms_url = f\"https://login.microsoftonline.com/{opt_tenant_id}/oauth2/v2.0/token\"\r\n        resource = \"https://api.bap.microsoft.com\"\r\n        scope = f\"{resource}/.default\"\r\n    \r\n        url = f\"{resource}/providers/Microsoft.BusinessAppPlatform/scopes/admin/environments?api-version={API_VERSION}\"\r\n        \r\n        data = {\r\n            'client_id': opt_client_id,\r\n            'client_secret': opt_client_secret,\r\n            'grant_type': 'client_credentials',\r\n            'scope': scope\r\n        }\r\n    \r\n        token = get_access_token(data, ms_url)\r\n        env_data = get_api_data(token, url)\r\n        env_data = json.loads(env_data)\r\n        \r\n        envs = []\r\n        \r\n        for env in env_data[\"value\"]:\r\n            envs.append(env[\"name\"])\r\n        \r\n        return envs\r\n    \r\n    def get_flow_runs(env_id, flow_id):\r\n        if not flow_id:\r\n            # Skip if flow_id is blank\r\n            return []\r\n\r\n        url = f\"https://api.flow.microsoft.com/providers/Microsoft.ProcessSimple/scopes/admin/environments/{env_id}/flows/{flow_id}/runs?api-version={API_VERSION}\"\r\n        token = get_access_token(data, ms_url)\r\n        flow_runs_data = get_api_data(token, url)\r\n        flow_runs_data = json.loads(flow_runs_data)\r\n        return flow_runs_data.get(\"value\", [])\r\n\r\n            \r\n    envs = get_env_ids()\r\n\r\n    token = get_access_token(data, ms_url)\r\n    \r\n    final_result = []\r\n\r\n    for env_id in envs:\r\n        url = f\"https://api.flow.microsoft.com/providers/Microsoft.ProcessSimple/scopes/admin/environments/{env_id}/flows?api-version={API_VERSION}\"\r\n\r\n        env_data = get_api_data(token, url)\r\n        env_data = json.loads(env_data)\r\n\r\n        for flow in env_data[\"value\"]:\r\n            flow_id = flow[\"name\"]\r\n\r\n            flow_runs = get_flow_runs(env_id, flow_id)\r\n\r\n            for flow_run in flow_runs:\r\n                # Process flow run data as needed\r\n                flow_run_id = flow_run[\"id\"]\r\n\r\n                # Check if the event is already indexed\r\n                state = helper.get_check_point(flow_run_id)\r\n                if state is None:\r\n                    final_result.append(flow_run)\r\n                    # Save the checkpoint to mark the event as indexed\r\n                    helper.save_check_point(flow_run_id, \"Indexed\")\r\n\r\n                # Cleanup - delete checkpoint for the last environment\r\n                #helper.delete_check_point(flow_run_id)\r\n\r\n    # Create a Splunk event for each flow run\r\n    res = json.dumps(final_result)\r\n    event = helper.new_event(res, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\r\n    ew.write_event(event)\r\n", "customized_options": [{"name": "tenant_id", "value": "038ce046-a09c-46cc-bab4-07b103fc4e00"}, {"name": "client_id", "value": "74494f4e-c584-43a8-8f34-2d7c109d91b3"}], "uuid": "00a9a729738e4bf49d588de812d8dcb2"}]}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "sourcetype_builder": {"o365:powerplatform:environments": {"metadata": {"event_count": 0, "data_input_name": "o365_power_platform_environments", "extractions_count": 0, "cims_count": 0}}, "o365:powerplatform:flows": {"metadata": {"event_count": 0, "data_input_name": "o365_power_platform_flows", "extractions_count": 0, "cims_count": 0}}, "o365:powerplatform:flowruns": {"metadata": {"event_count": 0, "data_input_name": "o365_power_platform_flow_runs", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1709210617_49", "progress": 1.0}}