[tenant://<name>]
tenant_url = The URL of a ForgeRock Identity Cloud tenant, e.g., https://openam-splunk.forgeblocks.com
api_key_id = The tenant log API key
api_key_secret = The matching API secret for the tenant API key
log_sources = A comma separated list of ForgeRock log sources. See https://backstage.forgerock.com/docs/idcloud/latest/tenants/audit-debug-logs.html
log_filter = A ForgeRock log query filter. See https://backstage.forgerock.com/docs/idcloud/latest/tenants/audit-debug-logs.html#filter-log-results