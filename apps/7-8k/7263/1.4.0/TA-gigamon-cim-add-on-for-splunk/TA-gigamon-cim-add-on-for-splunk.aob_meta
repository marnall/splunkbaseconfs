{"basic_builder": {"appname": "TA-gigamon-cim-add-on-for-splunk", "friendly_name": "Gigamon CIM Add-on for splunk", "version": "1.4.0", "author": "", "description": "The Gigamon CIM  Add-On is a specialized extension for Splunk designed to streamline the integration and normalization of Gigamon data within the Common Information Model (CIM). This add-on facilitates the mapping of Gigamon-specific fields to the corresponding CIM data model, enhancing the overall visibility and comprehension of Gigamon-generated data within the Splunk platform.", "theme": "#f07a35", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.4", "tab_build_no": "0", "build_no": 7}, "field_extraction_builder": {"gigamontraffic": {"data_format": "unstructured_data"}, "gigamon:traffic": {"is_parsed": true, "data_format": "json"}}, "sourcetype_builder": {"gigamon:traffic": {"metadata": {"event_count": 0, "data_input_name": null, "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1721661201_70"}}