[bugfender_app_issues://<name>]
app_id = 
bugfender_account = 
index = (Default: default)
initial_start_date = Provide Initial Start date. This is only used for the first time, the input is run. The next inputs are using a saved timestamp. Must be formatted as RFC3339 string, e.g. 2023-08-15T00:00:00Z.
interval = Time interval of input in seconds.
issue_status = (Default: issue_status_closed)

