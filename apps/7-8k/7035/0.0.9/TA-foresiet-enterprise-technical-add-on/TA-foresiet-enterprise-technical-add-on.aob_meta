{"basic_builder": {"appname": "TA-foresiet-enterprise-technical-add-on", "friendly_name": "Foresiet Enterprise Technical Add-on", "version": "0.0.9", "author": "Foresiet Team", "description": "The technical add-on allows Foresiet customers to periodically retrieve attack surface visibility, brand intelligence, threat intelligence data from the Foresiet API and ingest that data into their Splunk Environment. This enables organizations to leverage Foresiet's industry leading intelligence to provide security context to the rest of their machine data.", "theme": "#3c444d", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.4", "tab_build_no": "0", "build_no": 11}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "foresiet:digirisk:sgam", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "foresiet_application_misconfiguration", "title": "Foresiet SurfaceGuard \u2013 Application misconfiguration", "description": "Ingest attack surface application misconfiguration data into your Splunk Environment.", "type": "customized", "parameters": [{"name": "foresiet_api_key", "label": "Foresiet Enterprise API Key", "help_string": "Use Foresiet Enterprise API Key", "required": true, "format_type": "text", "default_value": "", "placeholder": "Provide Foresiet Enterprise API Key", "type": "text", "value": ""}, {"name": "foresiet_client_secret", "label": "Foresiet Enterprise Client Key", "help_string": "Use Foresiet Enterprise Client Key", "required": true, "format_type": "text", "default_value": "", "placeholder": "Provide Foresiet Enterprise Client Key", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "foresiet_api_key", "title": "Foresiet Enterprise API Key", "description": "Use Foresiet Enterprise API Key", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Provide Foresiet Enterprise API Key"}, {"type": "customized_var", "name": "foresiet_client_secret", "title": "Foresiet Enterprise Client Key", "description": "Use Foresiet Enterprise Client Key", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Provide Foresiet Enterprise Client Key"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n\n# For advanced users, if you want to create single instance mod input, uncomment this method.\n# def use_single_instance_mode():\n#     return True\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    foresiet_api_key        = definition.parameters.get('foresiet_api_key', None)\n    foresiet_client_secret  = definition.parameters.get('foresiet_client_secret', None)\n    interval                = definition.parameters.get('interval',None)\n    \n    if interval is not None:\n        helper.log_debug(\"Interval input is - {}\".format(interval))\n        try:\n            if int(interval) < 3600:\n                raise ValueError(\"The interval need to be greater than 3600 seconds (60 Minutes)\")  \n        except ValueError:\n            raise ValueError(\"The interval need to be greater than 3600 seconds (60 Minutes\")    \n        \n    if foresiet_api_key is not None:\n        helper.log_debug(\"Length of API key input is - {}\".format(len(foresiet_api_key)))\n        if len(foresiet_api_key) != 32:\n            raise ValueError(\"API key must be with a maximum length of 32 characters.\")\n    \n    if foresiet_client_secret is not None:\n        helper.log_debug(\"Length of Client Secret input is - {}\".format(len(foresiet_client_secret)))\n        if len(foresiet_client_secret) != 10:\n            raise ValueError(\"Client key must be with a maximum length of 10 characters.\")        \n        \n\ndef collect_events(helper, ew):\n    # Setting for input type \n    stanza_name = \"foresiet_app_misconfiguration\"\n    index = helper.get_output_index()\n    source = helper.get_input_type()\n    sourcetype = helper.get_sourcetype()\n    \n    url = \"https://ext.foresiet.com/digirisk/api/v1/vulnerability/misconfiguration/list\"\n    current_page_number = 1\n\n    \n    # Get the API key and Client secret key\n    opt_foresiet_api_key = helper.get_arg('foresiet_api_key')\n    opt_foresiet_client_secret = helper.get_arg('foresiet_client_secret')\n\n    # Set log level as per the global level seeting\n    log_level = helper.get_log_level()\n    helper.set_log_level(log_level)\n    headers     = { \"Authorization\": opt_foresiet_api_key, \"X-Client-Key\": opt_foresiet_client_secret, \"User-Agent\":\"ForesietSplunkAddon/0.0.6\" }\n    method      = \"GET\"\n    \n    \n    \n    while not current_page_number is None: \n        parameters  = { \"page\" : current_page_number}\n        helper.log_info(\"Fetching results from {} page.\".format( current_page_number ))\n        # The following examples send rest requests to some endpoint.\n        response = helper.send_http_request(\n                                            url         =   url, \n                                            method      =   method, \n                                            parameters  =   parameters, \n                                            payload     =   None,\n                                            headers     =   headers, \n                                            cookies     =   None, \n                                            verify      =   True, \n                                            cert        =   None,\n                                            timeout     =   None, \n                                            use_proxy   =   True\n                                        )\n        # get the response headers\n        r_headers = response.headers\n    \n        # get response status code\n        r_status = response.status_code\n        \n        \n        # get response body as json. If the body text is not a json string, raise a ValueError\n        r_json = response.json()\n        \n        # check the response status, if the status is not sucessful, raise requests.HTTPError    \n        if r_status not in  [ 200 ]:\n            helper.log_error(\"Error while fetching information from the API. HTTP Status code - {}\".format(r_status))\n            \n            if r_status == 403:\n                 helper.log_error(\"Error while fetching information from the API. Authentication Failed. HTTP Status code - {}\".format(r_status))\n                 \n            if r_status == 429:\n                wait_for_seconds = r_headers.get('X-Throttle-Wait-Seconds',None)\n                \n                if not wait_for_seconds is None:\n                    helper.log_warning(\"HTTP Status code - {}. Too Many Requests, Rate limited by the API. Waiting for {} seconds \".format(r_status, wait_for_seconds ))\n                    time.sleep(wait_for_seconds)\n            \n            #response.raise_for_status()\n        else:\n            \n    \n            results_to_push = []\n            \n            \n            for data in r_json[\"results\"][\"data\"]:\n                # Key name for the checkpoint\n                key = \"{}_{}\".format(\"misconfig\",data['_id'])\n        \n                if helper.get_check_point(key) is None:\n                    results_to_push.append(data)\n                    helper.save_check_point(key, \"Indexed\")\n                   \n                # Comment out for production build \n                # helper.delete_check_point(key)\n            \n            if not len(results_to_push):\n                helper.log_info(\"No results are pending to ingest into {} index.\".format(  index ))\n                current_page_number = None\n                break\n            else:\n                helper.log_info(\"Ingesting {} data into {} index.\".format(len(results_to_push), index ))\n                \n                # To create a splunk event\n                event = helper.new_event(\n                            data        =   json.dumps(results_to_push), \n                            time        =   None, \n                            host        =   None, \n                            index       =   index,\n                            source      =   source, \n                            sourcetype  =   sourcetype,\n                            done        =   True, \n                            unbroken    =   True\n                        )\n                ew.write_event(event)  \n            \n                current_page_number = r_json['next']\n            \n        time.sleep(30)\n", "customized_options": [{"name": "foresiet_api_key", "value": ""}, {"name": "foresiet_client_secret", "value": ""}], "uuid": "7b6f0a6748584392b2223695bcce8a62", "sample_count": "10"}, {"index": "default", "sourcetype": "foresiet:digirisk:sgsi", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "foresiet_ssl_issues", "title": "Foresiet SurfaceGuard \u2013 SSL Issues", "description": "Ingest attack surface SSL certificate issues data into your Splunk Environment.", "type": "customized", "parameters": [{"name": "foresiet_api_key", "label": "Foresiet Enterprise API Key", "help_string": "Use Foresiet Enterprise API Key", "required": true, "format_type": "text", "default_value": "", "placeholder": "Provide Foresiet Enterprise API Key", "type": "text", "value": ""}, {"name": "foresiet_client_secret", "label": "Foresiet Enterprise Client Key", "help_string": "Use Foresiet Enterprise Client Key", "required": true, "format_type": "text", 