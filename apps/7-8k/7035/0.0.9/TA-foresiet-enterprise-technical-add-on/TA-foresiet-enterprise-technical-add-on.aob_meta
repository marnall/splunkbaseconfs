er.log_debug(\"Length of API key input is - {}\".format(len(foresiet_api_key)))\n        if len(foresiet_api_key) != 32:\n            raise ValueError(\"API key must be with a maximum length of 32 characters.\")\n    \n    if foresiet_client_secret is not None:\n        helper.log_debug(\"Length of Client Secret input is - {}\".format(len(foresiet_client_secret)))\n        if len(foresiet_client_secret) != 10:\n            raise ValueError(\"Client key must be with a maximum length of 10 characters.\")     \n\ndef collect_events(helper, ew):\n    # Setting for input type \n    stanza_name = \"foresiet_fake_domains\"\n    index = helper.get_output_index()\n    source = helper.get_input_type()\n    sourcetype = helper.get_sourcetype()\n    \n    url = \"https://ext.foresiet.com/digirisk/api/v1/brand/domain/list\"\n    current_page_number = 1\n\n    \n    # Get the API key and Client secret key\n    opt_foresiet_api_key = helper.get_arg('foresiet_api_key')\n    opt_foresiet_client_secret = helper.get_arg('foresiet_client_secret')\n\n    # Set log level as per the global level seeting\n    log_level = helper.get_log_level()\n    helper.set_log_level(log_level)\n    headers     = { \"Authorization\": opt_foresiet_api_key, \"X-Client-Key\": opt_foresiet_client_secret, \"User-Agent\":\"ForesietSplunkAddon/0.0.6\" }\n    method      = \"GET\"\n    \n    \n    \n    while not current_page_number is None: \n        parameters  = { \"page\" : current_page_number}\n        helper.log_info(\"Fetching results from {} page.\".format( current_page_number ))\n        # The following examples send rest requests to some endpoint.\n        response = helper.send_http_request(\n                                            url         =   url, \n                                            method      =   method, \n                                            parameters  =   parameters, \n                                            payload     =   None,\n                                            headers     =   headers, \n                                            cookies     =   None, \n                                            verify      =   True, \n                                            cert        =   None,\n                                            timeout     =   None, \n                                            use_proxy   =   True\n                                        )\n        # get the response headers\n        r_headers = response.headers\n    \n        # get response status code\n        r_status = response.status_code\n        \n        \n        # get response body as json. If the body text is not a json string, raise a ValueError\n        r_json = response.json()\n        \n        # check the response status, if the status is not sucessful, raise requests.HTTPError    \n        if r_status not in  [ 200 ]:\n            helper.log_error(\"Error while fetching information from the API. HTTP Status code - {}\".format(r_status))\n            \n            if r_status == 403:\n                 helper.log_error(\"Error while fetching information from the API. Authentication Failed. HTTP Status code - {}\".format(r_status))\n                 \n            if r_status == 429:\n                wait_for_seconds = r_headers.get('X-Throttle-Wait-Seconds',None)\n                \n                if not wait_for_seconds is None:\n                    helper.log_warning(\"HTTP Status code - {}. Too Many Requests, Rate limited by the API. Waiting for {} seconds \".format(r_status, wait_for_seconds ))\n                    time.sleep(wait_for_seconds)\n            \n            #response.raise_for_status()\n        else:\n            \n    \n            results_to_push = []\n            \n            \n            for data in r_json[\"results\"][\"data\"]:\n                # Key name for the checkpoint\n                key = \"{}_{}\".format(\"domains\",data['_id'])\n        \n                if helper.get_check_point(key) is None:\n                    results_to_push.append(data)\n                    helper.save_check_point(key, \"Indexed\")\n                   \n                # Comment out for production build \n                # helper.delete_check_point(key)\n            \n            if not len(results_to_push):\n                helper.log_info(\"No results are pending to ingest into {} index.\".format(  index ))\n                current_page_number = None\n                break\n            else:\n                helper.log_info(\"Ingesting {} data into {} index.\".format(len(results_to_push), index ))\n                \n                # To create a splunk event\n                event = helper.new_event(\n                            data        =   json.dumps(results_to_push), \n                            time        =   None, \n                            host        =   None, \n                            index       =   index,\n                            source      =   source, \n                            sourcetype  =   sourcetype,\n                            done        =   True, \n                            unbroken    =   True\n                        )\n                ew.write_event(event)  \n            \n                current_page_number = r_json['next']\n                \n        time.sleep(30)\n", "customized_options": [{"name": "foresiet_api_key", "value": ""}, {"name": "foresiet_client_secret", "value": ""}], "uuid": "19ceb5d5cc1e46ffb5f7b13fa78e6306", "sample_count": "10"}, {"index": "default", "sourcetype": "foresiet:brandinsight:sm", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "foresiet_social_media", "title": "Foresiet BrandInsight - Social media", "description": "Ingest brand reputation social media data into your Splunk Environment.", "type": "customized", "parameters": [{"name": "foresiet_api_key", "label": "Foresiet Enterprise API Key", "help_string": "User Foresiet Enterprise API Key", "required": true, "format_