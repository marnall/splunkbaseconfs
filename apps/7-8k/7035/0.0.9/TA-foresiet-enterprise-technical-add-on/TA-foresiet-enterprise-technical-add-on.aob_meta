ults_to_push), index ))\n                \n                # To create a splunk event\n                event = helper.new_event(\n                            data        =   json.dumps(results_to_push), \n                            time        =   None, \n                            host        =   None, \n                            index       =   index,\n                            source      =   source, \n                            sourcetype  =   sourcetype,\n                            done        =   True, \n                            unbroken    =   True\n                        )\n                ew.write_event(event)  \n            \n                current_page_number = r_json['next']\n            \n        time.sleep(30)\n", "customized_options": [{"name": "foresiet_api_key", "value": ""}, {"name": "foresiet_client_secret", "value": ""}], "uuid": "012455ffca984bc28df73ffefaf8ff35", "sample_count": "10"}, {"index": "default", "sourcetype": "foresiet:threataware:ti", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "foresiet_threat_intel", "title": "Foresiet Threat Intel", "description": "Ingest threat intelligence data into their Splunk Environment.", "type": "customized", "parameters": [{"name": "foresiet_api_key", "label": "Foresiet Enterprise API Key", "help_string": "Use Foresiet enterprise API key", "required": true, "format_type": "password", "default_value": "", "placeholder": "Provide Foresiet enterprise API key", "type": "password", "value": ""}, {"name": "foresiet_client_secret", "label": "Foresiet Enterprise Client Key", "help_string": "Use Foresiet enterprise client key", "required": true, "format_type": "password", "default_value": "", "placeholder": "Provide Foresiet enterprise client key", "type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "foresiet_api_key", "title": "Foresiet Enterprise API Key", "description": "Use Foresiet enterprise API key", "requir