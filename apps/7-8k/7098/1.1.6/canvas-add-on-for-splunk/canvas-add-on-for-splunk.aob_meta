.send_http_request(url, \"get\", parameters=parameters, headers=headers)\n    \n    response.raise_for_status()\n    data = response.json()\n    \n    \n    try:\n        for item in data:\n            \n        # Check if id is already ingested\n            event_id = str(item[\"id\"])\n            key_state = helper.get_check_point(event_id)\n            if key_state is not None:\n                helper.log_debug(\"Already ingested key '{0}', skipping.\".format(event_id))\n                continue\n\n            stanza_name = helper.get_input_stanza_names()\n            \n            \n            event = helper.new_event(json.dumps(item), source=helper.get_input_type(), \n                                    index=helper.get_output_index(stanza_name), \n                                    sourcetype=helper.get_sourcetype())\n            ew.write_event(event)\n            helper.log_debug(\"Just indexed event with id {0}\".format(event_id))\n            helper.save_check_point(event_id, \"ingested\")    \n        helper.log_debug(\"Done with event list\")\n    \n    except KeyError as key_e:\n        helper.log_critical(\"Key {0} not found at data parsing\".format(key_e))\n        ", "customized_options": [{"name": "add_on_setup_parameter_setting", "value": "subdomain 4"}, {"name": "subdomain", "value": "apacdemo"}, {"name": "access_token", "value": "12954~MGtTtOy3F7pBHETOU2fs3WWPLwsjaOCf3fiZBwVIDdqLsZ5O7Q1UOq5Y88WEnzgF"}, {"name": "override", "value": true}], "uuid": "5a465d66b01f49eab0152e986a6c5b6d", "sample_count": 0}, {"index": "default", "sourcetype": "canvas:fileuploaded", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "file_uploaded", "title": "File Uploaded", "description": "Gets file details per course periodically.", "type": "customized", "parameters": [{"name": "add_on_setup_parameter_setting", "label": "Add-on Setup Parameter Setting", "help_string": "Maximum of 4 settings are allowed. (Use a custom Subdomain and