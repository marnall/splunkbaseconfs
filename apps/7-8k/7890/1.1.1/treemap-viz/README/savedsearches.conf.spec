[default]
# General
default.visualizations.custom.treemap-viz.treemap-viz.showBreadcrumbs = true|false
default.visualizations.custom.treemap-viz.treemap-viz.breadcrumbsPosition = top|bottom
default.visualizations.custom.treemap-viz.treemap-viz.allowZoom = true|false
default.visualizations.custom.treemap-viz.treemap-viz.allowPan = true|false
default.visualizations.custom.treemap-viz.treemap-viz.grouping = 1,2,3
default.visualizations.custom.treemap-viz.treemap-viz.cornerRadius = 5
default.visualizations.custom.treemap-viz.treemap-viz.panelBorder = <number>
default.visualizations.custom.treemap-viz.treemap-viz.panelGap = <number>
default.visualizations.custom.treemap-viz.treemap-viz.renderAs = svg|canvas
# Labels
default.visualizations.custom.treemap-viz.treemap-viz.showParentLabels = true|false
default.visualizations.custom.treemap-viz.treemap-viz.fontSizeLabel = <number>
default.visualizations.custom.treemap-viz.treemap-viz.fontSizeValue = <number>
default.visualizations.custom.treemap-viz.treemap-viz.valuePrefix = <String>
default.visualizations.custom.treemap-viz.treemap-viz.valueSuffix = <String>
default.visualizations.custom.treemap-viz.treemap-viz.numDecimalPlaces =No Change|0|1|2|3|4
default.visualizations.custom.treemap-viz.treemap-viz.thousandsSeparator = true|false

# Colors

default.visualizations.custom.treemap-viz.treemap-viz.colorBy = category|value
default.visualizations.custom.treemap-viz.treemap-viz.categoryPalette = custom|bright|blues|colorblind|nature|autumn|mint|pink
default.visualizations.custom.treemap-viz.treemap-viz.customPalette = #1E88E5, #43A047, #F4511E, #FB8C00, #8E24AA, #00ACC1, #FDD835
default.visualizations.custom.treemap-viz.treemap-viz.colorByValueMinColor = <color>
default.visualizations.custom.treemap-viz.treemap-viz.minValue = auto|<number>
default.visualizations.custom.treemap-viz.treemap-viz.colorByValueMaxColor = <color>
default.visualizations.custom.treemap-viz.treemap-viz.maxValue = auto|<number>
default.visualizations.custom.treemap-viz.treemap-viz.showScale = true|false
default.visualizations.custom.treemap-viz.treemap-viz.pattern = none|circle|rectangle|triangle|diamond|pin|arrow
#Tokens
default.visualizations.custom.treemap-viz.treemap-viz.tok_label = "tm_label"
default.visualizations.custom.treemap-viz.treemap-viz.tok_value = "tm_value"
default.visualizations.custom.treemap-viz.treemap-viz.tok_path = "tok_et_tm_pathlabel"
default.visualizations.custom.treemap-viz.treemap-viz.tok_parent = "tm_parent"


