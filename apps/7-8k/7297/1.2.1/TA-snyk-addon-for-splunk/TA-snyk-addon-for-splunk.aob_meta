{"basic_builder": {"appname": "TA-snyk-addon-for-splunk", "friendly_name": "Snyk Add-On for Splunk", "version": "1.2.1", "author": "hn07er", "description": "Modular inputs and sourcetypes for Snyk platform data", "theme": "#3c6188", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 8}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "snyk:issue", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "snyk_issues", "title": "Snyk Issues", "description": "Imports all open issues from Snyk projects", "type": "customized", "parameters": [{"required": true, "name": "api_region", "label": "Region", "default_value": "https://api.snyk.io", "placeholder": "", "help_string": "", "possible_values": [{"value": "https://api.snyk.io", "label": "SNYK-US-01"}, {"value": "https://api.us.snyk.io", "label": "SNYK-US-02"}, {"value": "https://api.eu.snyk.io", "label": "SNYK-EU-01"}, {"label": "SNYK-AU-01", "value": "https://api.au.snyk.io"}], "type": "dropdownlist", "format_type": "dropdownlist", "value": "https://api.snyk.io"}, {"name": "organization_id", "label": "Organization ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "0050a4d3-0dc0-40e5-b4b3-728cd1bc8477"}, {"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "api_region", "title": "Region", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "https://api.snyk.io", "label": "SNYK-US-01"}, {"value": "https://api.us.snyk.io", "label": "SNYK-US-02"}, {"value": "https://api.eu.snyk.io", "label": "SNYK-EU-01"}, {"label": "SNYK-AU-01", "value": "https://api.au.snyk.io"}], "format_type": "dropdownlist", "default_value": "https://api.snyk.io", "placeholder": ""}, {"type": "customized_var", "name": "organization_id", "title": "Organization ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # organization_id = definition.parameters.get('organization_id', None)\n    # api_key = definition.parameters.get('api_key', None)\n    pass\n\ndef collect_events(helper, ew):\n    import requests\n    import json\n    import re\n    \n    org_id = helper.get_arg('organization_id')\n    api_key = helper.get_arg('api_key')\n    api_region = helper.get_arg('api_region')\n    url = api_region+\"/rest/orgs/\"+org_id+\"/issues\"\n    next_url = 0\n    flag = 0\n    \n    while flag==0:\n        \n        if next_url==0:\n            url = url\n        else:\n            url = api_region+next_url\n            next_url = 0\n    \n        params = {\n            \"version\": \"2024-10-15\",\n            \"limit\": 100,\n            \"status\": \"open\"\n        }\n    \n        headers = {\n            \"accept\": \"application/vnd.api+json\",\n            \"authorization\": api_key\n        }\n    \n        response = requests.get(url, params=params, headers=headers)\n    \n        if response.status_code == 200:\n            # Process the response data (e.g., print or parse JSON)\n            #print(response.json())\n            json_data = json.loads(response.content)\n            \n            try:\n                next_page = json_data['links']['next']\n                next_url = re.sub('limit=\\d+&|&status=open&.*$', '', next_page, 2)\n            except:\n                flag = 1\n    \n            for item in json_data['data']:\n                item = json.dumps(item)\n                event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=item)\n                ew.write_event(event)\n           \n        else:\n            print(f\"Error: {response.status_code} - {response.text}\")\n    \n    \n", "customized_options": [{"name": "api_region", "value": "https://api.snyk.io"}, {"name": "organization_id", "value": "0050a4d3-0dc0-40e5-b4b3-728cd1bc8477"}], "uuid": "45119ea683d44cbbb8afde6ed0787c55", "sample_count": 0}, {"index": "default", "sourcetype": "snyk:org", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "snyk_orgs", "title": "Snyk Orgs", "description": "Imports org list from Snyk group", "type": "customized", "parameters": [{"required": true, "name": "api_region", "label": "Region", "default_value": "https://api.snyk.io", "placeholder": "", "help_string": "", "possible_values": [{"value": "https://api.snyk.io", "label": "SNYK-US-01"}, {"value": "https://api.us.snyk.io", "label": "SNYK-US-02"}, {"value": "https://api.eu.snyk.io", "label": "SNYK-EU-01"}, {"label": "SNYK-AU-01", "value": "https://api.au.snyk.io"}], "type": "dropdownlist", "format_type": "dropdownlist", "value": "https://api.snyk.io"}, {"required": true, "name": "group_id", "label": "Group ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "api_key", "label": "API Key", "placeholder": "", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "api_region", "title": "Region", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "https://api.snyk.io", "label": "SNYK-US-01"}, {"value": "https://api.us.snyk.io", "label": "SNYK-US-02"}, {"value": "https://api.eu.snyk.io", "label": "SNYK-EU-01"}, {"label": "SNYK-AU-01", "value": "https://api.au.snyk.io"}], "format_type": "dropdownlist", "default_value": "https://api.snyk.io", "placeholder": ""}, {"type": "customized_var", "name": "group_id", "title": "Group ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # api_region = definition.parameters.get('api_region', None)\n    # group_id = definition.parameters.get('group_id', None)\n    # api_key = definition.parameters.get('api_key', None)\n    pass\n\ndef collect_events(helper, ew):\n    import requests\n    import json\n    import re\n\n    group_id = helper.get_arg('group_id')\n    api_key = helper.get_arg('api_key')\n    api_region = helper.get_arg('api_region')\n    url = api_region+\"/rest/groups/\"+group_id+\"/orgs\"\n    next_url = 0\n    flag = 0\n    \n    while flag==0:\n        \n        if next_url==0:\n            url = url\n        else:\n            url = api_region+next_url\n            next_url = 0\n    \n        params = {\n            \"version\": \"2024-10-15\",\n            \"limit\": 100\n        }\n    \n        headers = {\n            \"accept\": \"application/vnd.api+json\",\n            \"authorization\": api_key\n        }\n    \n        response = requests.get(url, params=params, headers=headers)\n    \n        if response.status_code == 200:\n            # Process the response data (e.g., print or parse JSON)\n            #print(response.json())\n            json_data = json.loads(response.content)\n            \n            try:\n                next_page = json_data['links']['next']\n                next_url = re.sub('version=.*?&|limit=100&', '', next_page, 2)\n            except:\n                flag = 1\n    \n            for item in json_data['data']:\n                item = json.dumps(item)\n                event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=item)\n                ew.write_event(event)\n            \n        else:\n            print(f\"Error: {response.status_code} - {response.text}\")\n", "customized_options": [{"name": "api_region", "value": "https://api.snyk.io"}, {"name": "group_id", "value": "8e23a0b4-6ce4-48ac-82bb-ff6468980b8c"}], "uuid": "da42687ba91f4105849365e95d14ca21"}, {"index": "default", "sourcetype": "snyk:project", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "snyk_projects", "title": "Snyk Projects", "description": "Imports all project data from Snyk org", "type": "customized", "parameters": [{"name": "api_region", "label": "Region", "help_string": "", "required": true, "possible_values": [{"value": "https://api.snyk.io", "label": "SNYK-US-01"}, {"value": "https://api.us.snyk.io", "label": "SNYK-US-02"}, {"value": "https://api.eu.snyk.io", "label": "SNYK-EU-01"}, {"label": "SNYK-AU-01", "value": "https://api.au.snyk.io"}], "format_type": "dropdownlist", "default_value": "https://api.snyk.io", "placeholder": "", "type": "dropdownlist", "value": "https://api.snyk.io"}, {"name": "organization_id", "label": "Organization ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "0050a4d3-0dc0-40e5-b4b3-728cd1bc8477"}, {"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "api_region", "title": "Region", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "https://api.snyk.io", "label": "SNYK-US-01"}, {"value": "https://api.us.snyk.io", "label": "SNYK-US-02"}, {"value": "https://api.eu.snyk.io", "label": "SNYK-EU-01"}, {"label": "SNYK-AU-01", "value": "https://api.au.snyk.io"}], "format_type": "dropdownlist", "default_value": "https://api.snyk.io", "placeholder": ""}, {"type": "customized_var", "name": "organization_id", "title": "Organization ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # organization_id = definition.parameters.get('organization_id', None)\n    # api_key = definition.parameters.get('api_key', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    import requests\n    import json\n    import re\n    \n    org_id = helper.get_arg('organization_id')\n    api_key = helper.get_arg('api_key')\n    api_region = helper.get_arg('api_region')\n    url = api_region+\"/rest/orgs/\"+org_id+\"/projects\"\n    next_url = 0\n    flag = 0\n    \n    while flag==0:\n        \n        if next_url==0:\n            url = url\n        else:\n            url = api_region+next_url\n            next_url = 0\n    \n        params = {\n            \"version\": \"2024-10-15\",\n            \"limit\": 100\n        }\n    \n        headers = {\n            \"accept\": \"application/vnd.api+json\",\n            \"authorization\": api_key\n        }\n    \n        response = requests.get(url, params=params, headers=headers)\n    \n        if response.status_code == 200:\n            # Process the response data (e.g., print or parse JSON)\n            #print(response.json())\n            json_data = json.loads(response.content)\n            \n            try:\n                next_page = json_data['links']['next']\n                next_url = re.sub('version=.*?&|limit=100&', '', next_page, 2)\n            except:\n                flag = 1\n    \n            for item in json_data['data']:\n                item = json.dumps(item)\n                event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=item)\n                ew.write_event(event)\n           \n        else:\n            print(f\"Error: {response.status_code} - {response.text}\")\n    \n", "customized_options": [{"name": "api_region", "value": "https://api.snyk.io"}, {"name": "organization_id", "value": "0050a4d3-0dc0-40e5-b4b3-728cd1bc8477"}], "uuid": "c8175719ab774f499d532f7fab59d423", "sample_count": 0}]}, "field_extraction_builder": {"snyk:issue": {"is_parsed": true, "data_format": "json"}, "snyk:project": {"is_parsed": true, "data_format": "json"}, "snyk:org": {"is_parsed": true, "data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "sourcetype_builder": {"snyk:issue": {"metadata": {"event_count": 0, "data_input_name": "snyk_issues", "extractions_count": 0, "cims_count": 0}}, "snyk:project": {"metadata": {"event_count": 0, "data_input_name": "snyk_projects", "extractions_count": 0, "cims_count": 0}}, "snyk:org": {"metadata": {"event_count": 0, "data_input_name": "snyk_orgs", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1778204412_21"}}