
[send_logs_to_aws_s3_bucket]
python.version = python3
param.aws_access_key = <string> AWS Access Key. It's a required parameter.
param.aws_secret_key = <string> AWS Secret Key. It's a required parameter.
param.s3_bucket_name = <string> S3 Bucket name. It's a required parameter.
param.aws_region = <string> AWS Region. It's a required parameter.
param.file_prefix = <string> File Prefix.  It's default value is splunk_logs.

