{"alert_action_builder": {"modular_alerts": [{"description": "Once the alert is triggered, a log file is generated and this is uploaded to the S3 Bucket.", "largeIcon": "", "smallIcon": "", "label": "Send Logs to AWS S3 Bucket", "short_name": "send_logs_to_aws_s3_bucket", "parameters": [{"format_type": "text", "required": true, "name": "aws_access_key", "label": "AWS Access Key", "default_value": "", "help_string": "", "type": "", "value": "AKIATCKARMHF7OYJX24S"}, {"format_type": "text", "required": true, "name": "aws_secret_key", "label": "AWS Secret Key", "default_value": "", "help_string": "", "type": "", "value": "5esg1OlBwAPjSydEfDTaXDg+bzqczVlrBUNwGeJK"}, {"format_type": "text", "required": true, "name": "s3_bucket_name", "label": "S3 Bucket name", "default_value": "", "help_string": "", "type": "", "value": "justiceleague123"}, {"format_type": "text", "required": true, "name": "aws_region", "label": "AWS Region", "default_value": "", "help_string": "", "type": "", "value": "us-east-1"}, {"format_type": "text", "required": false, "name": "file_prefix", "label": "File Prefix", "default_value": "splunk_logs", "help_string": "", "type": "", "value": "splunk_logs"}], "code": "# encoding = utf-8\n\nimport boto3\nimport datetime\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    Upload events to S3\n    \"\"\"\n\n    helper.log_info(\"Alert action S3 Upload started.\")\n\n    # Variables \n    aws_access_key = helper.get_param(\"aws_access_key\")\n    aws_secret_key = helper.get_param(\"aws_secret_key\")\n    aws_region     = helper.get_param(\"aws_region\")\n    bucket_name    = helper.get_param(\"s3_bucket_name\")\n    file_prefix    = helper.get_param(\"file_prefix\")\n\n    # Validations\n    if not all([aws_access_key, aws_secret_key, bucket_name]):\n        helper.log_error(\"Missing Parameters: aws_access_key, aws_secret_key o bucket_name\")\n        return 1\n\n    # Get Events\n    events = helper.get_events()\n    if not events:\n        helper.log_info(\"No Events to Upload.\")\n        return 0\n\n    # Build log file\n    lines = []\n    for ev in events:\n        lines.append(str(ev))\n\n    file_content = \"\\n\".join(lines)\n\n    timestamp = datetime.datetime.utcnow().isoformat(timespec='milliseconds')\n    file_name = f\"{file_prefix}_{timestamp}.log\"\n\n    # Connection to S3\n    try:\n        s3 = boto3.client(\n            \"s3\",\n            aws_access_key_id=aws_access_key,\n            aws_secret_access_key=aws_secret_key,\n            region_name=aws_region\n        )\n\n        # Upload to S3\n        s3.put_object(\n            Bucket=bucket_name,\n            Key=file_name,\n            Body=file_content.encode('utf-8'),\n            ContentType=\"text/plain\"\n        )\n        helper.log_info(f\"Archivo {file_name} subido correctamente al bucket {bucket_name}.\")\n        return 0\n\n    except Exception as e:\n        helper.log_error(f\"Error al subir a S3: {e}\")\n        return 1\n", "uuid": "25951538231d425eb639d50363821fa6"}]}, "basic_builder": {"appname": "TA-s3-sync-alert-action", "friendly_name": "S3 Sync Alert Action", "version": "1.0.0", "author": "BitsIO", "description": "", "theme": "#a65c7d", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.4.1", "tab_build_no": "0", "build_no": 2}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1748618994_28", "progress": 1.0}}