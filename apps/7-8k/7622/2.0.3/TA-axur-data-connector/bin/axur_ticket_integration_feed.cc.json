{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "integration_feed_id"
    ],
    "global_settings": {
        "logging": {
            "level": "INFO"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": []
            },
            "request": {
                "url": "https://api.axur.com/gateway/1.0/api/integration-feed/feeds/feed/{{integration_feed_id}}?dry-run={{__settings__.additional_parameters.test_mode}}",
                "method": "GET",
                "headers": {
                    "Authorization": "Bearer {{__settings__.additional_parameters.api_token}}"
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.collectionData.tickets[*]"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.collectionData.tickets[*]"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "1",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.collectionData.tickets[*]"
                        ],
                        "method": "json_empty"
                    }
                ]
            }
        }
    ]
}