[cluster_status_pve://<name>]
account = The Proxmox user which should be used for authentification.
index = Default: proxmox
interval = Time interval of the data input, in seconds.  Default: 60
pveserver = The Proxmox VE (Proxmox Virtual Environment) server from which the data is to be retrieved.

[cluster_log_pve://<name>]
account = The Proxmox user which should be used for authentification.
index = Default: proxmox
interval = Time interval of the data input, in seconds.  Default: 60
maxfetch = Entries to fetch from Proxmox PVE Server  Default: 100
pveserver = The Proxmox VE (Proxmox Virtual Environment) server from which the data is to be retrieved.

