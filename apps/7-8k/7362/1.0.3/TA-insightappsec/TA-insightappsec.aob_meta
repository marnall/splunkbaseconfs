{"basic_builder": {"appname": "TA-insightappsec", "friendly_name": "Rapid7 InsightAppSec Technology Add-On for Splunk", "version": "1.0.3", "author": "hn07er", "description": "Modular Inputs for Rapid7 InsightAppSec platform", "theme": "#f07a35", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 7}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "rapid7:insightappsec:app", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "insightappsec_apps", "title": "InsightAppSec Applications", "description": "Application information from InsightAppSec", "type": "customized", "parameters": [{"required": true, "name": "api_endpoint", "label": "API Endpoint", "default_value": "https://us.api.insight.rapid7.com", "placeholder": "https://us.api.insight.rapid7.com", "help_string": "", "type": "text", "format_type": "text", "value": "https://us.api.insight.rapid7.com"}, {"required": true, "name": "api_key", "label": "API Key", "placeholder": "", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "api_endpoint", "title": "API Endpoint", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "https://us.api.insight.rapid7.com", "placeholder": "https://us.api.insight.rapid7.com"}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # api_endpoint = definition.parameters.get('api_endpoint', None)\n    # api_key = definition.parameters.get('api_key', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    import requests\n    import json\n    \n    api_endpoint = helper.get_arg('api_endpoint')\n    api_key = helper.get_arg('api_key')\n    index=0\n    flag=1\n    \n    while(flag == 1):\n        url = api_endpoint+\"/ias/v1/search?index=\"+str(index)+\"&size=100\"\n    \n        payload = json.dumps({\n        \"query\": \"app.name IS NOT NULL\",\n        \"type\": \"APP\"\n        })\n        headers = {\n        'Content-Type': 'application/json',\n        'Accept': 'application/json',\n        'X-Api-Key': api_key\n        }\n    \n        response = requests.request(\"POST\", url, headers=headers, data=payload)\n        \n        if response.status_code == 200:\n            # Process the response data (e.g., print or parse JSON)\n            json_data = json.loads(response.content)\n            \n            try:\n                total_pages = json_data['metadata']['total_pages']\n                if(index+1 == total_pages):\n                    flag=0\n                else:\n                    index=index+1\n            except:\n                flag = 0\n    \n            for item in json_data['data']:\n                item=json.dumps(item)\n                event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=item)\n                ew.write_event(event)\n        else:\n            print(f\"Error: {response.status_code} - {response.text}\")", "customized_options": [{"name": "api_endpoint", "value": "https://us.api.insight.rapid7.com"}], "uuid": "086a485407f04f8c80554c018e8e351f"}, {"index": "default", "sourcetype": "rapid7:insightappsec:app:vulnerability_finding", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "insightappsec_findings", "title": "InsightAppSec Findings", "description": "Vulnerability data from InsightAppSec", "type": "customized", "parameters": [{"name": "api_endpoint", "label": "API Endpoint", "help_string": "", "required": true, "format_type": "text", "default_value": "https://us.api.insight.rapid7.com", "placeholder": "https://us.api.insight.rapid7.com", "type": "text", "value": "https://us.api.insight.rapid7.com"}, {"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "f1eed80b-c89c-47c1-9f34-75622aaec2e4"}, {"name": "vulnerability_status", "label": "Vulnerability Status", "help_string": "", "required": true, "possible_values": [{"value": "UNREVIEWED", "label": "Unreviewed"}, {"value": "IGNORED", "label": "Ignored"}, {"value": "FALSE POSITIVE", "label": "False Positive"}, {"label": "Verified", "value": "VERIFIED"}, {"label": "Remediated", "value": "REMEDIATED"}, {"label": "Duplicate", "value": "DUPLICATE"}], "format_type": "multi_dropdownlist", "default_value": ["VERIFIED", "UNREVIEWED"], "placeholder": "", "type": "multi_dropdownlist", "value": ["DUPLICATE"]}], "data_inputs_options": [{"type": "customized_var", "name": "api_endpoint", "title": "API Endpoint", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "https://us.api.insight.rapid7.com", "placeholder": "https://us.api.insight.rapid7.com"}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "vulnerability_status", "title": "Vulnerability Status", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "UNREVIEWED", "label": "Unreviewed"}, {"value": "IGNORED", "label": "Ignored"}, {"value": "FALSE POSITIVE", "label": "False Positive"}, {"label": "Verified", "value": "VERIFIED"}, {"label": "Remediated", "value": "REMEDIATED"}, {"label": "Duplicate", "value": "DUPLICATE"}], "format_type": "multi_dropdownlist", "default_value": ["VERIFIED", "UNREVIEWED"], "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # api_endpoint = definition.parameters.get('api_endpoint', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # vulnerability_status = definition.parameters.get('vulnerability_status', None)\n    pass\n\ndef collect_events(helper, ew):\n    import requests\n    import json\n    import re\n    \n    api_endpoint = helper.get_arg('api_endpoint')\n    api_key = helper.get_arg('api_key')\n    opt_vulnerability_status = helper.get_arg('vulnerability_status')\n    index=0\n    flag=1\n    vuln_types=\"\"\n\n    for item in opt_vulnerability_status:\n        vuln_types=vuln_types+\"|vulnerability.status = '\"+item+\"'\"\n    \n    vuln_types = re.sub(r\"^\\|\", \"\", vuln_types)\n    vuln_types = re.sub(r\"\\|\", \" || \", vuln_types)\n    \n    while(flag == 1):\n        url = api_endpoint+\"/ias/v1/search?index=\"+str(index)+\"&size=100\"\n    \n        payload = json.dumps({\n        \"query\": vuln_types,\n        \"type\": \"VULNERABILITY\"\n        })\n        headers = {\n        'Content-Type': 'application/json',\n        'Accept': 'application/json',\n        'X-Api-Key': api_key\n        }\n        \n        response = requests.request(\"POST\", url, headers=headers, data=payload)\n        \n        if response.status_code == 200:\n            # Process the response data (e.g., print or parse JSON)\n            json_data = json.loads(response.content)\n            \n            try:\n                total_pages = json_data['metadata']['total_pages']\n                if(index+1 == total_pages):\n                    flag=0\n                else:\n                    index=index+1\n            except:\n                flag = 0\n    \n            for item in json_data['data']:\n                item=json.dumps(item)\n                event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=item)\n                ew.write_event(event)\n        else:\n            item=\"Error: \"+str(response.status_code)+\" - \"+response.text\n            event = helper.new_event(source=helper.get_input_type(), index=\"_internal\", sourcetype=\"rapid7:insightappsec:error\", data=item)\n            ew.write_event(event)\n", "customized_options": [{"name": "api_endpoint", "value": "https://us.api.insight.rapid7.com"}, {"name": "vulnerability_status", "value": ["DUPLICATE", "VERIFIED"]}], "uuid": "31d70c353a4a4e38b43d1f492ebb5912", "sample_count": "124"}]}, "field_extraction_builder": {"rapid7:insightappsec:app": {"is_parsed": true, "data_format": "json"}, "rapid7:insightappsec:app:vulnerability_finding": {"is_parsed": true, "data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "sourcetype_builder": {"rapid7:insightapp