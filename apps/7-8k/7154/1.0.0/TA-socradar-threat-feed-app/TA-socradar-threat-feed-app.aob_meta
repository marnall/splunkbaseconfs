{"basic_builder": {"appname": "TA-socradar-threat-feed-app", "friendly_name": "SOCRadar Threat Feed App", "version": "1.0.0", "author": "SOCRadar Cyber Intelligence", "description": "SOCRadar is a cloud-based, AI-powered Digital Risk Protection Platform enhanced by cyber threat intelligence capabilities. This App provides SOCRadar Threat Feed IoCS Data.", "theme": "#FFFFFF", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.4", "tab_build_no": "0", "build_no": 2}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "socradarthreatfeed", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "socradarthreatfeeddata", "title": "socradarthreatfeeddata", "description": "", "type": "customized", "parameters": [{"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "cddb294c6e654713846410a2cc9745740d47910a6b3f4a8082ad4db8bb559c4e"}], "data_inputs_options": [{"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\n\nfrom datetime import datetime, timedelta\ndef validate_input(helper, definition):\n    pass\ndef collect_events(helper, ew):\n    opt_api_key = helper.get_arg('api_key')\n    threatfeed_collection_dict = { \"0cb06558728b4dc296019c93b78360d1\": \"SOCRadar-APT-Recommended-Block-Hash\",\"e89ab3b58e174b8c82767088d8e66cae\": \"SOCRadar-Attackers-Recommended-Block-IP\", \"03cc11380b5d4a77a0d0cc2a7c568230\": \"SOCRadar-Recommended-Phishing-Global\", \"606a83358bbe466d8c3885e37fa595b7\": \"SOCRadar-Attackers-Recommended-Block-Domain\", \"8742cab86cc4414092217f87298e94a1\": \"SOCRadar-Recommended-Block-Hash\",\"4d7a69ce6e7c49ff8c916da5d7343916\": \"SOCRadar-APT-Recommended-Block-IP\", \"9079dcc2f96e4835bb807026d4cdcc86\": \"SOCRadar-APT-Recommended-Block-Domain\"}\n    \n    for threatfeed_uuid, threatfeed_name in threatfeed_collection_dict.items():\n        url =f\"https://platform.socradar.com/api/threat/intelligence/feed_list/{threatfeed_uuid}.json?key={opt_api_key}&v=2\"\n        response = helper.send_http_request(url, 'GET', parameters=None, payload=None,headers=None, cookies=None, verify=True, cert=None,timeout=None, use_proxy=True)\n       # feedlist=[]\n       # for feed in response.json():\n        #    f={}\n         #   f['feed']=feed['feed']\n          #  f['maintainer_name']=threatfeed_name\n           # f['latest_seen_date']=feed['latest_seen_date']\n            #feedlist.append(f)\n       # event = helper.new_event(json.dumps(feedlist), time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n        f=\"\"\n        for feed in response.json():\n            f=feed['feed'] +\",\"+threatfeed_name+\",\"+feed['latest_seen_date']\n            event = helper.new_event(f, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n            ew.write_event(event)\n        time.sleep(1)\n        #helper.delete_check_point(str(alarm[\"id\"]))    ", "customized_options": [], "uuid": "4b7c969e67c84750ab2a07852b4837cb", "sample_count": "12570372"}]}, "field_extraction_builder": {"socradarthreatfeed": {"is_parsed": true, "data_format": "tabular", "table_results": {"delim": ",", "header": ["Feed", "Maintainer", "Last_Seen_Date"]}}}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "sourcetype_builder": {"socradarthreatfeed": {"metadata": {"event_count": 0, "data_input_name": "socradarthreatfeeddata", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_17