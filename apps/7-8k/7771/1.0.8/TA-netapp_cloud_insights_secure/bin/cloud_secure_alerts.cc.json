{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "__settings__.logging.loglevel",
        "__settings__.proxy.proxy_enabled",
        "__settings__.proxy.proxy_url",
        "__settings__.proxy.proxy_port",
        "__settings__.proxy.proxy_type",
        "__settings__.proxy.proxy_username",
        "__settings__.proxy.proxy_rdns",
        "__settings__.proxy.proxy_password",
        "rest_url",
        "x_cloudinsights_apikey",
        "alerttimestamp"
    ],
    "global_settings": {
        "proxy": {
            "enabled": "{{__settings__.proxy.proxy_enabled}}",
            "host": "{{__settings__.proxy.proxy_url}}",
            "port": "{{__settings__.proxy.proxy_port}}",
            "username": "{{__settings__.proxy.proxy_username}}",
            "password": "{{__settings__.proxy.proxy_password}}",
            "rdns": "{{__settings__.proxy.proxy_rdns}}",
            "type": "{{__settings__.proxy.proxy_type}}"
        },
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": [
                    {
                        "input": [
                            "{{alerttimestamp}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_alerttimestamp"
                    },
                    {
                        "input": [
                            "{{alerttimestamp}}",
                            "%s",
                            "%s"
                        ],
                        "method": "time_str2str",
                        "output": "alerttimestamp"
                    }
                ]
            },
            "request": {
                "url": "{{rest_url}}?limit=1000&timeRange=ONE_WEEK&sort=alertTimestamp",
                "method": "GET",
                "headers": {
                    "X-CloudInsights-ApiKey": "{{x_cloudinsights_apikey}}"
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.results[*]"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.results..alertTimestamp"
                        ],
                        "method": "json_path",
                        "output": "alerttimestamp"
                    },
                    {
                        "input": [
                            "{{alerttimestamp != ''}}",
                            "The value of token 'alerttimestamp' extracted from response cannot be empty!"
                        ],
                        "method": "assert_true"
                    },
                    {
                        "input": [
                            "{{alerttimestamp == _raw_alerttimestamp}}"
                        ],
                        "method": "exit_if_true"
                    },
                    {
                        "input": [
                            "{{alerttimestamp}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_alerttimestamp"
                    },
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.results[*]"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "100",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$.results[*]"
                        ],
                        "method": "json_empty"
                    }
                ]
            },
            "checkpoint": {
                "content": {
                    "alerttimestamp": "{{_raw_alerttimestamp}}"
                }
            }
        }
    ]
}