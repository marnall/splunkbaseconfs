{
  "Legal": {
    "OwnCopyright": "Copyright © Veeam Software Group GmbH.",
    "OwnCopyrightPattern" : "Copyright\\s(\\(c\\)|©)\\sVeeam\\sSoftware\\sGroup\\sGmbH\\.",
    "ThirdPartyCopyrightPattern": "(copyright|Copyright|\\(c\\)\\s[0-9]{4}|©|\bcopyright\b)|(©)|(.gnu.org/)|(MIT license)|(.apache.org/)"
  },
  
  "FileDiscovery": {
    "DefaultProfile": "vspc",
    "Profiles": [
        {
            "Name": "siem",
            "UseGitIgnore": "false",
            "Include": [
              "\\.(js)$"
            ],
            "Exclude": [
              "\\.(md)$",
              "(\\\\|/)\\.git(\\\\|/)",
              "(\\\\|/)\\.gitignore(\\\\|/)"
            ]
        }
    ]
  },
  "FileModify": {
    "Profiles": [
      {
        "Name": "csharp",
        "FileExtensions": ".cs;.cake",
        "CommentTemplate": "// {0}\r\n\r\n",
        "DefaultEncoding": "utf-8"
      },
      {
        "Name": "vb",
        "FileExtensions": ".vb",
        "CommentTemplate": "' {0}\r\n\r\n"
      },
      {
        "Name": "sql",
        "FileExtensions": ".sql",
        "CommentTemplate": "-- {0}\r\n\r\n"
      },
      {
        "Name": "cpp",
        "FileExtensions": ".cpp;.hpp;.c;.h",
        "CommentTemplate": "// {0}\r\n\r\n",
        "DefaultEncoding": "windows-1252"
      },
      {
        "Name": "js",
        "FileExtensions": ".js",
        "CommentTemplate": "// {0}\r\n\r\n"
      },
      {
        "Name": "bat",
        "FileExtensions": ".bat",
        "CommentTemplate": "@rem {0}\r\n\r\n",
        "DefaultEncoding": "windows-1252"
      },
      {
        "Name": "xml",
        "FileExtensions": ".xaml;.xslt;.xml",
        "CommentTemplate": "<!-- {0} --> \r\n\r\n"
      },
      {
        "Name": "powershell",
        "FileExtensions": ".ps1",
        "CommentTemplate": "<# {0} #> \r\n\r\n"
      },
      {
        "Name": "razor",
        "FileExtensions": ".cshtml",
        "CommentTemplate": "@* {0} *@ \r\n\r\n"
      },
      {
        "Name": "python",
        "FileExtensions": ".py",
        "CommentTemplate": "# {0}\r\n\r\n",
        "SkipFirstLinePatterns": [ "#!", "# -*-" ]
      }
    ]
  }
}