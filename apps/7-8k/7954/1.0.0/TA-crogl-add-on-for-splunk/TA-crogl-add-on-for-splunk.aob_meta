{"basic_builder": {"appname": "TA-crogl-add-on-for-splunk", "friendly_name": "Crogl Add-on for Splunk", "version": "1.0.0", "author": "Anthony Tellez, Crogl", "description": "The Crogl Add-on for Splunk enables basic integration with Crogl\u2019s security automation platform. It verifies that a Crogl instance is operational (online and reachable) and provides reference documentation for integrating Crogl with Splunk searches, alerts, and workflows.\n\nUse this add-on as a starting point for validating connectivity and understanding how Crogl fits into your detection and response pipeline.", "theme": "#070B29", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.3.0", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "crogl:healthcheck", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "crogl_health_check", "title": "Crogl Health Check", "description": "Input checks the current status of your crogl instance to verify it's currently online and actively able to query splunk.", "type": "rest", "parameters": [{"name": "base_url", "label": "Crogl URL or IP Address", "help_string": "Set the url of your crogl instance", "required": true, "format_type": "text", "default_value": "https://127.0.0.1", "placeholder": "", "type": "text", "value": "https://127.0.0.1"}], "data_inputs_options": [{"name": "_rest_api_url", "rest_header": false, "description": "url", "value": "{{ base_url }}"}, {"name": "_rest_api_method", "rest_header": false, "description": "method", "value": "GET"}, {"type": "event_json_path_key", "name": "_event_json_path_key", "value": ""}, {"type": "ckpt_enable", "name": "_ckpt_enable", "value": false}, {"type": "ckpt_var_name", "name": "_ckpt_var_name", "value": ""}, {"type": "ckpt_json_path_key", "name": "_ckpt_json_path_key", "value": ""}, {"type": "ckpt_initial_value", "name": "_ckpt_initial_value", "value": ""}, {"type": "ckpt_source_time_format", "name": "_ckpt_source_time_format", "value": ""}, {"type": "ckpt_target_time_format", "name": "_ckpt_target_time_format", "value": ""}, {"type": "customized_var", "name": "base_url", "title": "Crogl URL or IP Address", "description": "Set the url of your crogl instance", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "https://127.0.0.1", "placeholder": ""}], "use_basic_auth": false, "customized_options": [{"name": "base_url", "value": "https://demo.crogl.com"}], "uuid": "9345e25030ce4a36aa7cf3ce57f3d9b5", "sample_count": 0}]}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}}}, "sourcetype_builder": {"crogl:healthcheck": {"metadata": {"event_count": 0, "data_input_name": "crogl_health_check", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1753839976_85"}}