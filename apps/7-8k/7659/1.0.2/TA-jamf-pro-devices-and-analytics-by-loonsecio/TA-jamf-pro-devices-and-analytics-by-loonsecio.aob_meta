{"basic_builder": {"appname": "TA-jamf-pro-devices-and-analytics-by-loonsecio", "friendly_name": "Jamf Pro Devices and Analytics by LoonSecIO", "version": "1.0.2", "author": "LoonSec.IO", "description": "https://loonsecio.com\n\nAn add-on builder built service that translates Jamf Pro Inventory services and Server information into Splunk items.=", "theme": "#3c6188", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.2.0", "tab_build_no": "0", "build_no": 3}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "Jamf_MacOS_Devices", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "jamf_mac_devices", "title": "Jamf Mac devices", "description": "", "type": "customized", "parameters": [{"name": "jamf_pro_url", "label": "Jamf Pro URL", "help_string": "<yourServer>.jamfcloud.com", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "loonsecio.jamfcloud.com"}, {"name": "client_id", "label": "Client Id / Username", "help_string": "Client id for the API or Username", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "50d5cc4d-3485-41e1-9a65-bd6439e2dd70"}, {"name": "client_secret", "label": "Client Secret / Password", "help_string": "Client Secret or the API Password", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "59v8XdR1P7nRzWswraS3KYjdD6Kyocqj_c07jb8o-GjMjxgstL2CxSyv_pQ978YF"}, {"name": "device_management_status", "label": "Device Management Status", "help_string": "", "required": false, "possible_values": [{"value": "MANAGED", "label": "Managed"}, {"value": "NOTMANAGED", "label": "Not Managed"}], "format_type": "multi_dropdownlist", "default_value": ["MANAGED", "NOTMANAGED"], "placeholder": "", "type": "multi_dropdownlist", "value": ["MANAGED", "NOTMANAGED"]}, {"name": "limit_inventory_time", "label": "Limit Inventory Time", "help_string": "Time limit for devices that haven't inventories. 0 = Unlimited, 1 = 1 day ago, 14 = 2 weeks", "required": true, "format_type": "text", "default_value": "30", "placeholder": "", "type": "text", "value": "0"}, {"name": "api_sections", "label": "Sections", "help_string": "", "required": false, "possible_values": [{"value": "GENERAL", "label": "General"}, {"value": "APPLICATIONS", "label": "Applications"}, {"value": "GROUP_MEMBERSHIPS", "label": "Groups"}, {"label": "Extension Attributes", "value": "EXTENSION_ATTRIBUTES"}, {"label": "Purchasing", "value": "PURCHASING"}, {"label": "Hardware", "value": "HARDWARE"}, {"label": "Users and Location", "value": "USER_AND_LOCATION"}, {"label": "Security", "value": "SECURITY"}, {"label": "Configuration Profiiles", "value": "CONFIGURATION_PROFILES"}, {"label": "Disk Encryption", "value": "DISK_ENCRYPTION"}, {"label": "Storage", "value": "STORAGE"}, {"label": "Operating System", "value": "OPERATING_SYSTEM"}, {"label": "Printers", "value": "PRINTERS"}, {"label": "User Account", "value": "LOCAL_USER_ACCOUNTS"}], "format_type": "multi_dropdownlist", "default_value": ["DISK_ENCRYPTION", "GROUP_MEMBERSHIPS", "APPLICATIONS", "GENERAL", "STORAGE", "CONFIGURATION_PROFILES", "SECURITY", "EXTENSION_ATTRIBUTES", "PURCHASING", "HARDWARE", "OPERATING_SYSTEM", "PRINTERS", "LOCAL_USER_ACCOUNTS", "USER_AND_LOCATION"], "placeholder": "Sections To write to the API", "type": "multi_dropdownlist", "value": ["option11"]}, {"name": "meta_builder", "label": "Meta Builder", "help_string": "Leave blank for the default value", "required": false, "format_type": "text", "default_value": "", "placeholder": "Used to adjust the \"device_meta\"", "type": "text", "value": ""}, {"name": "application_patching", "label": "Application Patching", "help_string": "Select Patching Guidance Feeds, Empty list means don't include the data. If empty no patch guidance given", "required": false, "possible_values": [{"value": "JAMFPATCH", "label": "Jamf Patch Feed"}, {"value": "LOONSECIO", "label": "LoonSecIO Feed"}], "format_type": "multi_dropdownlist", "default_value": ["JAMFPATCH", "LOONSECIO"], "placeholder": "", "type": "multi_dropdownlist", "value": ["LOONSECIO"]}, {"name": "share_analytics", "label": "Share Analytics", "help_string": "Shares the Analytics information, refer to documentation", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "vulnerability_detections", "label": "Vulnerability Detections", "help_string": "Add vulnerability information for the devices", "required": false, "possible_values": [{"value": "apps", "label": "Applications"}, {"value": "os", "label": "Operating System"}, {"value": "common_ea", "label": "Common EA"}], "format_type": "multi_dropdownlist", "default_value": ["apps", "os"], "placeholder": "", "type": "multi_dropdownlist", "value": ["apps", "os"]}, {"name": "vulnerability_requirements", "label": "Vulnerability Requirements", "help_string": "Refer to https://loonsecio.com/resources\nVulnerabilities must match this criteria\n\nEmpty list requires all", "required": false, "possible_values": [{"value": "vuln_dispute", "label": "Vulnerability Not Disputed"}, {"value": "vuln_impact", "label": "Valid Impact Stateement"}, {"value": "vuln_config", "label": "Valid Configurations"}], "format_type": "multi_dropdownlist", "default_value": [], "placeholder": "", "type": "multi_dropdownlist", "value": []}], "data_inputs_options": [{"type": "customized_var", "name": "jamf_pro_url", "title": "Jamf Pro URL", "description": "<yourServer>.jamfcloud.com", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "client_id", "title": "Client Id / Username", "description": "Client id for the API or Username", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "client_secret", "title": "Client Secret / Password", "description": "Client Secret or the API Password", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "device_management_status", "title": "Device Management Status", "description": "", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "MANAGED", "label": "Managed"}, {"value": "NOTMANAGED", "label": "Not Managed"}], "format_type": "multi_dropdownlist", "default_value": ["MANAGED", "NOTMANAGED"], "placeholder": ""}, {"type": "customized_var", "name": "limit_inventory_time", "title": "Limit Inventory Time", "description": "Time limit for devices that haven't inventories. 0 = Unlimited, 1 = 1 day ago, 14 = 2 weeks", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "30", "placeholder": ""}, {"type": "customized_var", "name": "api_sections", "title": "Sections", "description": "", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "GENERAL", "label": "General"}, {"value": "APPLICATIONS", "label": "Applications"}, {"value": "GROUP_MEMBERSHIPS", "label": "Groups"}, {"label": "Extension Attributes", "value": "EXTENSION_ATTRIBUTES"}, {"label": "Purchasing", "value": "PURCHASING"}, {"label": "Hardware", "value": "HARDWARE"}, {"label": "Users and Location", "value": "USER_AND_LOCATION"}, {"label": "Security", "value": "SECURITY"}, {"label": "Configuration Profiiles", "value": "CONFIGURATION_PROFILES"}, {"label": "Disk Encryption", "value": "DISK_ENCRYPTION"}, {"label": "Storage", "value": "STORAGE"}, {"label": "Operating System", "value": "OPERATING_SYSTEM"}, {"label": "Printers", "value": "PRINTERS"}, {"label": "User Account", "value": "LOCAL_USER_ACCOUNTS"}], "format_type": "multi_dropdownlist", "default_value": ["DISK_ENCRYPTION", "GROUP_MEMBERSHIPS", "APPLICATIONS", "GENERAL", "STORAGE", "CONFIGURATION_PROFILES", "SECURITY", "EXTENSION_ATTRIBUTES", "PURCHASING", "HARDWARE", "OPERATING_SYSTEM", "PRINTERS", "LOCAL_USER_ACCOUNTS", "USER_AND_LOCATION"], "placeholder": "Sections To write to the API"}, {"type": "customized_var", "name": "meta_builder", "title": "Meta Builder", "description": "Leave blank for the default value", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Used to adjust the \"device_meta\""}, {"type": "customized_var", "name": "application_patching", "title": "Application Patching", "description": "Select Patching Guidance Feeds, Empty list means don't include the data. If empty no patch guidance given", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "JAMFPATCH", "label": "Jamf Patch Feed"}, {"value": "LOONSECIO", "label": "LoonSecIO Feed"}], "format_type": "multi_dropdownlist", "default_value": ["JAMFPATCH", "LOONSECIO"], "placeholder": ""}, {"type": "customized_var", "name": "share_analytics", "title": "Share Analytics", "description": "Shares the Analytics information, refer to documentation", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "vulnerability_detections", "title": "Vulnerability Detections", "description": "Add vulnerability information for the devices", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "apps", "label": "Applications"}, {"value": "os", "label": "Operating System"}, {"value": "common_ea", "label": "Common EA"}], "format_type": "multi_dropdownlist", "default_value": ["apps", "os"], "placeholder": ""}, {"type": "customized_var", "name": "vulnerability_requirements", "title": "Vulnerability Requirements", "description": "Refer to https://loonsecio.com/resources\nVulnerabilities must match this criteria\n\nEmpty list requires all", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "vuln_dispute", "label": "Vulnerability Not Disputed"}, {"value": "vuln_impact", "label": "Valid Impact Stateement"}, {"value": "vuln_config", "label": "Valid Configurations"}], "format_type": "multi_dropdownlist", "default_value": [], "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport hashlib\nimport json\nimport uuid\nimport traceback\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # text = definition.parameters.get('text', None)\n    pass\n\n\ndef collect_events(helper, ew):\n    __version__ = \"1.0.2\"\n    try:\n        from .ls_tools import JamfPatch, JamfSplunkPatchSync, RoutineJamfPatchSync, JamfProSDK, JamfProMacUAPIDevice\n        from .ls_tools import JamfProMacApplications, LSIO\n    except ImportError:\n        from ls_tools import JamfPatch, JamfSplunkPatchSync, RoutineJamfPatchSync, JamfProSDK, JamfProMacUAPIDevice\n        from ls_tools import JamfProMacApplications, LSIO\n\n    run_id = uuid.uuid4().hex\n\n    settings = {\n        \"jamf_pro_url\": helper.get_arg(\"jamf_pro_url\", None),\n        \"client_id\": helper.get_arg(\"client_id\", None),\n        \"client_secret\": helper.get_arg(\"client_secret\", None),\n        \"exclude_unmanaged\": helper.get_arg(\"exclude_unmanaged\", None),\n        \"limit_inventory_time\": helper.get_arg(\"limit_inventory_time\", None),\n        \"api_sections\": helper.get_arg(\"api_sections\", None),\n        \"meta_builder\": helper.get_arg(\"meta_builder\", None),\n        \"application_patching\": helper.get_arg(\"application_patching\", None),\n        \"share_analytics\": helper.get_arg(\"share_analytics\", None),\n        \"vulnerability_detections\": helper.get_arg(\"vulnerability_detections\", None),\n        \"vulnerability_requirements\": helper.get_arg(\"vulnerability_requirements\", None),\n        \"loonsecio_base_url\": helper.get_arg(\"loonsecio_base_url\", None),\n        \"loonsecio_client_id\": helper.get_arg(\"loonsecio_client_id\", None),\n        \"loonsecio_client_secret\": helper.get_arg(\"loonsecio_client_secret\", None),\n        \"sla_days_critical\": helper.get_arg(\"sla_days_critical\", None),\n        \"sla_days_high\": helper.get_arg(\"sla_days_high\", None),\n        \"sla_days_medium\": helper.get_arg(\"sla_days_medium\", None),\n        \"sla_days_low\": helper.get_arg(\"sla_days_low\", None),\n        \"headers\": {\n            \"User-Agent\": f\"loonsecio splunkbase {__version__}\"\n        }\n    }\n\n    # Check Jamf Pro for Token, error out on failure\n    try:\n        jpro_api = JamfProSDK(helper=helper, ew=ew, jamf_pro_url=settings.get(\"jamf_pro_url\"), settings=settings, client_id=settings.get('client_id'), client_secret=settings.get('client_secret'))\n    except:\n        helper.log_critical(msg=\"Failed Initial tests, unable to get Jamf Pro Access Token\")\n\n        return None\n    # Load Jamf Patch Data\n    if 'JAMFPATCH' in settings.get(\"application_patching\", []):\n        try:\n            RoutineJamfPatchSync(helper, ew).run()\n        except Exception as E:\n            msg = {'error': 'error in updating Jamf Patch Title', 'error_s': str(E),\n                   '_time': time.time(), 'execution_id': run_id}\n            ew.write_event(helper.new_event(data=json.dumps(msg),\n                                            index=helper.get_output_index(),\n                                            sourcetype=\"lsio:jamfDevices:error_msg\",\n                                            done=True,\n                                            unbroken=True))\n    start_time = time.time()\n    try:\n        groups = jpro_api.get_groups()\n    except Exception as E:\n        msg = {'error': 'error in updating Jamf Groups', 'error_s': str(E),\n               '_time': time.time(), 'execution_id': run_id}\n        ew.write_event(helper.new_event(data=json.dumps(msg),\n                                        index=helper.get_output_index(),\n                                        sourcetype=\"lsio:jamfDevices:error_msg\",\n                                        done=True,\n                                        unbroken=True))\n        groups = []\n\n    try:\n        departments = jpro_api.get_departments()\n    except Exception as E:\n        msg = {'error': 'error in updating Jamf Departments', 'error_s': str(E),\n               '_time': time.time(), 'execution_id': run_id}\n        ew.write_event(helper.new_event(data=json.dumps(msg),\n                                        index=helper.get_output_index(),\n                                        sourcetype=\"lsio:jamfDevices:error_msg\",\n                                        done=True,\n                                        unbroken=True))\n        departments = []\n\n    try:\n        buildings = jpro_api.get_buildings()\n    except Exception as E:\n        msg = {'error': 'error in updating Jamf Buildings', 'error_s': str(E),\n               '_time': time.time(), 'execution_id': run_id}\n        ew.write_event(helper.new_event(data=json.dumps(msg),\n                                        index=helper.get_output_index(),\n                                        sourcetype=\"lsio:jamfDevices:error_msg\",\n                                        done=True,\n                                        unbroken=True))\n        buildings = []\n\n    apps_hash = []\n    try:\n        lsio_vulns = LSIO.JamfMacAppVulns(splunk_helper=helper, lsio_url=settings['loonsecio_base_url'],\n                                          lsio_api_client=settings['loonsecio_client_id'],\n                                          lsio_api_secret=settings['loonsecio_client_secret']\n                                          )\n        apps = JamfProMacApplications(lsio_vulns=lsio_vulns)\n\n    except Exception as E:\n        msg = {'error': 'Fatal Error Setting up Apps', 'error_s': str(E),\n               '_time': time.time(), 'execution_id': run_id}\n        ew.write_event(helper.new_event(data=json.dumps(msg),\n                                        index=helper.get_output_index(),\n                                        sourcetype=\"lsio:jamfDevices:error_msg\",\n                                        done=True,\n                                        unbroken=True))\n\n    finished_computers = False\n    page_count = 0\n    try:\n        while not finished_computers:\n            apps_hash_run = {}\n            computer_page = jpro_api.get_computers_page(page_size=200, page_number=page_count)\n\n            for computer in computer_page['results']:\n                for application in computer['applications']:\n                    app_md5_s = f\"{application['name']}{application['version']}{application['bundleId']}\"\n                    app_md5 = hashlib.md5(app_md5_s.encode()).hexdigest()\n                    apps_hash_run[app_md5] = application\n            cache_list = []\n\n            for key in apps_hash_run.keys():\n                if key not in apps_hash:\n                    cache_list.append(key)\n            lsio_vulns.get_app_vulns_api(app_list=cache_list)\n            # Here goes the Requested Data\n            apps_hash.extend(apps_hash_run.keys())\n            # Here goes the Requested Data\n            for computer in computer_page['results']:\n                this_computer = JamfProMacUAPIDevice(jamf_device=computer, departments=departments, buildings=buildings,\n                                                     groups=groups, app_details=apps)\n                splunk_events = this_computer.get_splunk_events()\n                for splunk_event in splunk_events:\n                    ew.write_event(helper.new_event(json.dumps(splunk_event.get('event', {})), sourcetype=splunk_event.get('sourcetype', 'unknown'), index=helper.get_output_index(), done=True, unbroken=True))\n            if len(computer_page['results']) == 0:\n                finished_computers = True\n            else:\n                page_count += 1\n    except Exception as E:\n        msg = {'error': 'Fatal Error Collecting Devices', 'error_s': str(E), 'trace': str(traceback.format_exc()),\n               '_time': time.time(), 'execution_id': run_id}\n        ew.write_event(helper.new_event(data=json.dumps(msg),\n                                        index=helper.get_output_index(),\n                                        sourcetype=\"lsio:jamfDevices:error_msg\",\n                                        done=True,\n                                        unbroken=True))\n\n", "customized_options": [{"name": "jamf_pro_url", "value": "loonsecio.jamfcloud.com"}, {"name": "client_id", "value": "50d5cc4d-3485-41e1-9a65-bd6439e2dd70"}, {"name": "device_management_status", "value": ["MANAGED", "NOTMANAGED"]}, {"name": "limit_inventory_time", "value": "0"}, {"name": "api_sections", "value": ["option11"]}, {"name": "meta_builder", "value": ""}, {"name": "application_patching", "value": ["LOONSECIO", "JAMFPATCH"]}, {"name": "share_analytics", "value": true}, {"name": "vulnerability_detections", "value": ["apps", "os"]}, {"name": "vulnerability_requirements", "value": []}], "uuid": "d4f015df007747af85ba36c54fb423de", "sample_count": "0"}]}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": false, "name": "loonsecio_base_url", "label": "Loonsecio base URL ", "default_value": "api.loonsec.io", "placeholder": "", "help_string": "Only change if asked, used if on a beta track or for testing", "type": "text", "format_type": "text", "value": "api.loonsec.io"}, {"required": false, "name": "loonsecio_client_id", "label": "LoonSecIO Client ID", "default_value": "", "placeholder": "", "help_string": "LoonSecIO Client ID ", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "loonsecio_client_secret", "label": "LoonSecIO Client Secret", "placeholder": "", "default_value": "", "help_string": "LoonSecIO Client Secret, Request at www.loonsecio.com", "type": "password", "format_type": "password", "value": ""}, {"required": false, "name": "sla_days_critical", "label": "SLA Days Critical", "default_value": "30", "placeholder": "", "help_string": "Number of days for SLA, -1 means ignore", "type": "text", "format_type": "text", "value": "30"}, {"required": false, "name": "sla_days_high", "label": "SLA Days High", "default_value": "30", "placeholder": "", "help_string": "Number of days for SLA, -1 means ignore", "type": "text", "format_type": "text", "value": "30"}, {"required": false, "name": "sla_days_medium", "label": "SLA Days Medium", "default_value": "90", "placeholder": "", "help_string": "Number of days for SLA, -1 means ignore", "type": "text", "format_type": "text", "value": "90"}, {"required": false, "name": "sla_days_low", "label": "SLA Days Low", "default_value": "180", "placeholder": "", "help_string": "Number of days for SLA, -1 means ignore", "type": "text", "format_type": "text", "value": "180"}, {"required": false, "name": "kv_store_pre_pend", "label": "KV PrePend", "default_value": "", "placeholder": "", "help_string": "If left blank, the Input name will be used for KV/Checkpoints. Adjust if you want multiple inputs to share a KV Store", "type": "text", "format_type": "text", "value": ""}]}}, "sourcetype_builder": {"Jamf_MacOS_Devices": {"metadata": {"event_count": 0, "data_input_name": "jamf_mac_devices", "extractions_count": 0, "cims_count": 0}}, "Jamf_Mobile_Devices": {"metadata": {"event_count": 0, "data_input_name": null, "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1733593532_24"}}