{"basic_builder": {"appname": "TA-onetrust_assessments", "friendly_name": "OneTrust Assessments", "version": "2.0.0", "author": "morethanyell", "description": "Utilizes OneTrust API to collect OneTrust Assessments as JSON events", "theme": "#468254", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.0", "tab_build_no": "0", "build_no": 2}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "onetrust_assessment_collection", "interval": "14400", "use_external_validation": true, "streaming_mode_xml": true, "name": "collect_assessments", "title": "Collect Assessments", "description": "Collects OneTrust Assessments and configure them into three sourcetypes: Summary, Detail, and QnA", "type": "customized", "parameters": [{"name": "base_url", "label": "Base URL", "help_string": "Learn: https://developer.onetrust.com/onetrust/reference/url-variables-for-apis-sdks", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "https://app-de.onetrust.com"}, {"name": "api_token", "label": "API Token", "help_string": "Learn: https://developer.onetrust.com/onetrust/reference/oauth-20-scopes", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "MzlmZTA3NWMyNjM0NDFjM2EzZTkzZTIxMTYwODdhOTc6ZW12dnBiRmwydUFzdWp6MW5lNE5peU9jU1NvTXRLQ28="}, {"name": "assessment_archival_state", "label": "Assessment Archival State", "help_string": "Parameter to retrieve a list of Active/Archived or\nboth Active and Archived assessments.", "required": true, "possible_values": [{"value": "NON_ARCHIVED", "label": "Non-Archived"}, {"value": "ALL", "label": "All"}, {"value": "ARCHIVED", "label": "ARCHIVED"}], "format_type": "dropdownlist", "default_value": "NON_ARCHIVED", "placeholder": "", "type": "dropdownlist", "value": "NON_ARCHIVED"}, {"name": "created_since", "label": "Created Since", "help_string": "Filter assessments created after this date (YYYY-MM-DD HH:MM:SS). Invalid dates default to 30 days ago.", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "2025-08-10 00:00:00"}, {"name": "template_name_filter", "label": "Template Name Filter", "help_string": "A valid regular expression or exact match for template", "required": false, "format_type": "text", "default_value": ".*", "placeholder": "", "type": "text", "value": "GLB\\:\\sSecurity\\sException\\sForm\\s\\(SEF\\)"}, {"name": "exclude_skipped_questions", "label": "Exclude Skipped Questions", "help_string": "", "required": false, "possible_values": [{"value": "True", "label": "True"}, {"value": "False", "label": "False"}], "format_type": "dropdownlist", "default_value": "True", "placeholder": "", "type": "dropdownlist", "value": "True"}], "data_inputs_options": [{"type": "customized_var", "name": "base_url", "title": "Base URL", "description": "Learn: https://developer.onetrust.com/onetrust/reference/url-variables-for-apis-sdks", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_token", "title": "API Token", "description": "Learn: https://developer.onetrust.com/onetrust/reference/oauth-20-scopes", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "assessment_archival_state", "title": "Assessment Archival State", "description": "Parameter to retrieve a list of Active/Archived or\nboth Active and Archived assessments.", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "NON_ARCHIVED", "label": "Non-Archived"}, {"value": "ALL", "label": "All"}, {"value": "ARCHIVED", "label": "ARCHIVED"}], "format_type": "dropdownlist", "default_value": "NON_ARCHIVED", "placeholder": ""}, {"type": "customized_var", "name": "created_since", "title": "Created Since", "description": "Filter assessments created after this date (YYYY-MM-DD HH:MM:SS). Invalid dates default to 30 days ago.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "template_name_filter", "title": "Template Name Filter", "description": "A valid regular expression or exact match for template", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": ".*", "placeholder": ""}, {"type": "customized_var", "name": "exclude_skipped_questions", "title": "Exclude Skipped Questions", "description": "", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "True", "label": "True"}, {"value": "False", "label": "False"}], "format_type": "dropdownlist", "default_value": "True", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport requests\nimport json\nimport asyncio\nfrom onetrust_assessments_collector_engine import OneTrustArchivalState, OneTrustAssessmentsCollector\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    pass\n\nasync def ot_engine_start(helper, ew, otcollector_instance):\n    async for a in otcollector_instance.start():\n        data = json.dumps(a, separators=(',', ':'))\n        event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=a.get(\"sourceType\", \"onetrust_assessment_collection\"), data=data)\n        ew.write_event(event)\n    \ndef collect_events(helper, ew):\n    \n    opt_base_url = helper.get_arg('base_url')\n    opt_api_token = helper.get_arg('api_token')\n    opt_assessment_archival_state = helper.get_arg('assessment_archival_state')\n    opt_created_since = helper.get_arg('created_since')\n    opt_template_name_filter = helper.get_arg('template_name_filter')\n    opt_exclude_skipped_questions = helper.get_arg('exclude_skipped_questions')\n    \n    esq = {\"true\": True, \"false\": False}[opt_exclude_skipped_questions.lower()]\n    \n    otcollector = OneTrustAssessmentsCollector(base_url=opt_base_url, \n                                               api_key=opt_api_token, \n                                               archival_state=OneTrustArchivalState(opt_assessment_archival_state),\n                                               template_name=opt_template_name_filter, \n                                               created_since=opt_created_since,\n                                               exc_skipped_q=esq)\n    \n    asyncio.run(ot_engine_start(helper, ew, otcollector))\n    ", "customized_options": [{"name": "base_url", "value": "https://app-de.onetrust.com"}, {"name": "assessment_archival_state", "value": "NON_ARCHIVED"}, {"name": "created_since", "value": "2025-08-10 00:00:00"}, {"name": "template_name_filter", "value": "GLB\\:\\sSecurity\\sException\\sForm\\s\\(SEF\\)"}, {"name": "exclude_skipped_questions", "value": "True"}], "uuid": "9b1f5fb8fa7f4e2db18cc16a40358fee", "sample_count": 0}]}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}}}, "sourcetype_builder": {}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1754999227_30", "progress": 0.75}}