# Application-level permissions

[]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system


[views]
access = read : [ * ], write : [ admin, sc_admin ]



### LOOKUPS

[lookups]
export = system


### Set the owner for the kvstore collection
[collections]
owner = nobody
export = system

### EVENT TYPES
[eventtypes]
export = system

### PROPS
[props]
export = system

### TRANSFORMS
[transforms]
export = system

### VIEWSTATES: even normal users should be able to create shared viewstates
[viewstates]
access = read : [ * ], write : [ * ]
export = system

### SAVED SEARCHES
[savedsearches]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

### MACROS - Set macro access for all ThreatMon macros
[macros]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system
owner = nobody

### REST ENDPOINTS
[restmap]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system