{"basic_builder": {"appname": "TA-shopify-add-on-for-splunk", "friendly_name": "Shopify Add-On for Splunk", "version": "1.0.0", "author": "Avotrix", "description": "", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.0", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "shopify:ListOfInventoryLevels", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "shopify_listofinventorylevels", "title": "ListOfInventoryLevels", "description": "", "type": "customized", "parameters": [{"name": "account", "label": "Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "start_date", "label": "Start Date", "help_string": "Format: YYYY-MM-DD\n(Refer to the documentation to know more about the start date)", "required": false, "format_type": "text", "default_value": "", "placeholder": "Example: 2022-06-24", "type": "text", "value": "2020-01-01"}, {"name": "end_date", "label": "End Date", "help_string": "Format: YYYY-MM-DD\n(Refer to the documentation to know more about the start date)", "required": false, "format_type": "text", "default_value": "", "placeholder": "Example: 2022-06-24", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "account", "title": "Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "start_date", "title": "Start Date", "description": "Format: YYYY-MM-DD\n(Refer to the documentation to know more about the start date)", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Example: 2022-06-24"}, {"type": "customized_var", "name": "end_date", "title": "End Date", "description": "Format: YYYY-MM-DD\n(Refer to the documentation to know more about the start date)", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Example: 2022-06-24"}], "code": "\n# encoding = utf-8\n\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport re\nfrom datetime import datetime, timedelta\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # account = definition.parameters.get('account', None)\n    # start_date = definition.parameters.get('start_date', None)\n    # end_date = definition.parameters.get('end_date', None)\n    pass\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('account')\n    username = global_account['username']\n    password= global_account['password']\n    start_date = helper.get_arg('start_date')\n    end_date = helper.get_arg('end_date')\n    \n    \n    if(start_date and end_date):\n        \n        \n        url1 = f\"{username}/admin/api/2022-07/products.json?limit=250&created_at_min={start_date}&created_at_max={end_date}\"\n        \n        headers = {\n           'X-Shopify-Access-Token': f'{password}'\n             }\n    \n        response = requests.request(\"GET\", url1, headers=headers)\n        response1 = requests.head( url1, headers=headers)\n        \n        \n        r = response.json()\n    #print(json.dumps(r,indent=2))\n        count=0\n        li=[]\n        for i in r[\"products\"]:\n            \n            li.append(i[\"variants\"][0][\"inventory_item_id\"])\n            # count=count+1\n            \n            \n        while(True):\n            \n            try:\n                abc = (response1.headers[\"Link\"])\n                abc1 = re.findall(r'([\\w+,.,-/,:,]*\\/\\w+.\\w+\\?\\w+=\\d+&\\w+=\\w+)>;\\srel=\\\"next\\\"', abc)\n                abc2=(\" \".join(map(str,abc1)))\n                if(abc2==\"\"):\n                    break\n                        \n                url2 = abc2\n                headers = {\n                    'X-Shopify-Access-Token': f'{password}'\n                }\n                response2 = requests.request(\"GET\", url2, headers=headers)\n                response1 = requests.head( url2, headers=headers)\n                r2 = response.json()\n                for i in r2[\"products\"]:\n                    li.append(i[\"variants\"][0][\"inventory_item_id\"])\n                    # count=count+1\n       \n                \n            except(KeyError):\n                break\n                       \n            \n            \n            \n            \n        id = li\n        for j in id:\n            #print(j)\n            url3 = f\"{username}/admin/api/2022-07/inventory_levels.json?inventory_item_ids={j}\"\n            headers = {\n            'X-Shopify-Access-Token': f'{password}'\n            }\n            response3 = requests.request(\"GET\", url3, headers=headers) \n            r3 = response3.json()\n            # print(json.dumps(r3,indent=2))\n            #count=0\n            for i in r3[\"inventory_levels\"]:\n                state = helper.get_check_point(str(i[\"updated_at\"])+str(i[\"inventory_item_id\"])+str(i[\"location_id\"]))\n                if state is None:\n                    event = helper.new_event(json.dumps(i,indent=2))\n                    ew.write_event(event)\n                    count=count+1\n                    helper.save_check_point(str(i[\"updated_at\"])+str(i[\"inventory_item_id\"])+str(i[\"location_id\"]),\"Indexed\")\n                        \n                # helper.delete_check_point(str(i[\"updated_at\"])+str(i[\"inventory_item_id\"])+str(i[\"location_id\"]))\n                \n        status = response.status_code\n        url4 = f\"{username}/admin/api/2022-07/inventory_levels.json\"\n        status = \"API=\"+str(url4)+\"| response_code=\"+str(status)+\"| number_of_events=\"+str(count)\n        helper.log_info(status)                         \n\n    \n        \n    elif(start_date and not end_date):\n        # now = datetime.now()\n        # end_date = now.strftime(\"%Y-%m-%d\")\n        # print(end_date)\n        today = datetime.now()\n        yesterday = today \n        end_date = yesterday.strftime(\"%Y-%m-%d\")\n        \n        url1 = f\"{username}/admin/api/2022-07/products.json?limit=250&created_at_min={start_date}&created_at_max={end_date}\"\n    \n        headers = {\n           'X-Shopify-Access-Token': f'{password}'\n             }\n    \n        response = requests.request(\"GET\", url1, headers=headers)\n        response1 = requests.head( url1, headers=headers)\n        r = response.json()\n    #print(json.dumps(r,indent=2))\n        count=0\n        li=[]\n        for i in r[\"products\"]:\n            \n            li.append(i[\"variants\"][0][\"inventory_item_id\"])\n            # count=count+1\n            \n            \n        while(True):\n            \n            try:\n                abc = (response1.headers[\"Link\"])\n                abc1 = re.findall(r'([\\w+,.,-/,:,]*\\/\\w+.\\w+\\?\\w+=\\d+&\\w+=\\w+)>;\\srel=\\\"next\\\"', abc)\n                abc2=(\" \".join(map(str,abc1)))\n                if(abc2==\"\"):\n                    break\n                        \n                url2 = abc2\n                headers = {\n                    'X-Shopify-Access-Token': f'{password}'\n                }\n                response2 = requests.request(\"GET\", url2, headers=headers)\n                response1 = requests.head( url2, headers=headers)\n                r2 = response.json()\n                for i in r2[\"products\"]:\n                    li.append(i[\"variants\"][0][\"inventory_item_id\"])\n                    # count=count+1\n       \n            except(KeyError):\n                break\n                       \n            \n            \n            \n            \n        id = li\n        for j in id:\n            #print(j)\n            url3 = f\"{username}/admin/api/2022-07/inventory_levels.json?inventory_item_ids={j}\"\n            headers = {\n            'X-Shopify-Access-Token': f'{password}'\n            }\n            response3 = requests.request(\"GET\", url3, headers=headers) \n            r3 = response3.json()\n            # print(json.dumps(r3,indent=2))\n            # count=0\n            for i in r3[\"inventory_levels\"]:\n                state = helper.get_check_point(str(i[\"updated_at\"])+str(i[\"inventory_item_id\"])+str(i[\"location_id\"]))\n                if state is None:\n                    event = helper.new_event(json.dumps(i,indent=2))\n                    ew.write_event(event)\n                    count=count+1\n                    helper.save_check_point(str(i[\"updated_at\"])+str(i[\"inventory_item_id\"])+str(i[\"location_id\"]),\"Indexed\")\n                        \n                # helper.delete_check_point(str(i[\"updated_at\"])+str(i[\"inventory_item_id\"])+str(i[\"location_id\"]))\n            \n        status = response.status_code\n        url4 = f\"{username}/admin/api/2022-07/inventory_levels.json\"\n        status = \"API=\"+str(url4)+\"| response_code=\"+str(status)+\"| number_of_events=\"+str(count)\n        helper.log_info(status)    \n            \n            \n            \n    \n        \n    else:\n        today = datetime.now()\n        yesterday = today \n        end_date = yesterday.strftime(\"%Y-%m-%d\")\n        yesterday1 = today - time