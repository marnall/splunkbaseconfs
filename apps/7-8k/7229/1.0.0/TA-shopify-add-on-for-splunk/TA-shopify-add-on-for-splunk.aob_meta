ccount')\n    username = global_account['username']\n    password= global_account['password']\n    start_date = helper.get_arg('start_date')\n    end_date = helper.get_arg('end_date')\n    \n    \n    if(start_date and end_date):\n        \n        \n        url1 = f\"{username}/admin/api/2022-07/products.json?limit=250&created_at_min={start_date}&created_at_max={end_date}\"\n        \n        headers = {\n           'X-Shopify-Access-Token': f'{password}'\n             }\n    \n        response = requests.request(\"GET\", url1, headers=headers)\n        response1 = requests.head( url1, headers=headers)\n        \n        \n        r = response.json()\n    #print(json.dumps(r,indent=2))\n        count=0\n        li=[]\n        for i in r[\"products\"]:\n            \n            li.append(i[\"variants\"][0][\"inventory_item_id\"])\n            # count=count+1\n            \n            \n        while(True):\n            \n            try:\n                abc = (response1.headers[\"Link\"])\n                abc1 = re.findall(r'([\\w+,.,-/,:,]*\\/\\w+.\\w+\\?\\w+=\\d+&\\w+=\\w+)>;\\srel=\\\"next\\\"', abc)\n                abc2=(\" \".join(map(str,abc1)))\n                if(abc2==\"\"):\n                    break\n                        \n                url2 = abc2\n                headers = {\n                    'X-Shopify-Access-Token': f'{password}'\n                }\n                response2 = requests.request(\"GET\", url2, headers=headers)\n                response1 = requests.head( url2, headers=headers)\n                r2 = response.json()\n                for i in r2[\"products\"]:\n                    li.append(i[\"variants\"][0][\"inventory_item_id\"])\n                    # count=count+1\n       \n                \n            except(KeyError):\n                break\n                       \n            \n            \n            \n            \n        id = li\n        for j in id:\n            #print(j)\n            url3 = f\"{username}/admin/api/2022-07/inventory_items.json?ids={j}\"\n            headers = {\n            'X-Shopify-Access-Token': f'{password}'\n            }\n            response3 = requests.request(\"GET\", url3, headers=headers) \n            r3 = response3.json()\n            # print(json.dumps(r3,indent=2))\n            #count=0\n            for i in r3[\"inventory_items\"]:\n                state = helper.get_check_point(str(i[\"updated_at\"])+str(i[\"id\"]))\n                if state is None:\n                    event = helper.new_event(json.dumps(i,indent=2))\n                    ew.write_event(event)\n                    count=count+1\n                    helper.save_check_point(str(i[\"updated_at\"])+str(i[\"id\"]),\"Indexed\")\n                        \n                # helper.delete_check_point(str(i[\"updated_at\"])+str(i[\"id\"]))\n                \n        status = response.status_code\n        url4 = f\"{username}/admin/api/2022-07/inventory_items.json\"\n        status = \"API=\"+str(url4)+\"| response_code=\"+str(status)+\"| number_of_events=\"+str(count)\n        helper.log_info(status)                         \n\n    \n        \n    elif(start_date and not end_date):\n        # now = datetime.now()\n        # end_date = now.strftime(\"%Y-%m-%d\")\n        # print(end_date)\n        today = datetime.now()\n        yesterday = today \n        end_date = yesterday.strftime(\"%Y-%m-%d\")\n        \n        url1 = f\"{username}/admin/api/2022-07/products.json?limit=250&created_at_min={start_date}&created_at_max={end_date}\"\n    \n        headers = {\n           'X-Shopify-Access-Token': f'{password}'\n             }\n    \n        response = requests.request(\"GET\", url1, headers=headers)\n        response1 = requests.head( url1, headers=headers)\n        r = response.json()\n    #print(json.dumps(r,indent=2))\n        count=0\n        li=[]\n        for i in r[\"products\"]:\n            \n            li.append(i[\"variants\"][0][\"inventory_item_id\"])\n            #