ion):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # global_account = definition.parameters.get('global_account', None)\n    pass\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('account')\n    username = global_account['username']\n    password= global_account['password']\n    start_date = helper.get_arg('start_date')\n    end_date = helper.get_arg('end_date')\n    \n    if(start_date and end_date):\n        \n        url1 = f\"{username}/admin/api/2022-07/events.json?limit=250&created_at_min={start_date}&created_at_max={end_date}\"\n        headers = {\n        'X-Shopify-Access-Token': f'{password}'\n        }\n    \n        response = requests.request(\"GET\", url1, headers=headers)\n        response1 = requests.head( url1, headers=headers)\n        # print(response1.headers)\n        r = response.json()\n        count=0\n        for i in r[\"events\"]:\n            \n            state = helper.get_check_point(str(i[\"id\"])+str(i[\"created_at\"]))\n            if state is None:\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count=count+1\n                helper.save_check_point(str(i[\"id\"])+str(i[\"created_at\"]), \"Indexed\")\n            # helper.delete_check_point(str(i[\"id\"])+str(i[\"created_at\"])) \n        \n                    \n            \n        \n        while(True):\n            try:\n                abc = (response1.headers[\"Link\"])\n                #print(abc)\n                abc1 = re.findall(r'([\\w+,.,-/,:,]*\\/\\w+.\\w+\\?\\w+=\\d+&\\w+=\\w+)>;\\srel=\\\"next\\\"', abc)\n                abc2=(\" \".join(map(str,abc1)))\n                #print(abc2)\n                if(abc2==\"\"):\n                    break\n                url = abc2\n                headers = {\n                'X-Shopify-Access-Token': f'{password}'\n                }\n            \n                response = requests.request(\"GET\", url, headers=headers)\n                response1 = requests.head( url, headers=headers)\n                r = response.json()\n                for i in r[\"events\"]:\n                \n                    state = helper.get_check_point(str(i[\"id\"])+str(i[\"created_at\"]))\n                    if state is None:\n                        event = helper.new_event(json.dumps(i,indent=2))\n                        ew.write_event(event)\n                        count=count+1\n                        helper.save_check_point(str(i[\"id\"])+str(i[\"created_at\"]), \"Indexed\")\n                    # helper.delete_check_point(str(i[\"id\"])+str(i[\"created_at\"])) \n               \n                \n            except(KeyError):\n                break\n            \n        status = response.status_code\n        status = \"API=\"+str(url1)+\"| response_code=\"+str(status)+\"| number_of_events=\"+str(count)\n        helper.log_info(status)\n        \n        \n    elif(start_date and not end_date):\n        \n       \n        today = datetime.now()\n        yesterday = today\n        end_date = yesterday.strftime(\"%Y-%m-%d\")\n        \n        url1 = f\"{username}/admin/api/2022-07/events.json?limit=250&created_at_min={start_date}&created_at_max={end_date}\"\n        headers = {\n        'X-Shopify-Access-Token': f'{password}'\n        }\n    \n        response = requests.request(\"GET\", url1, headers=headers)\n        response1 = requests.head( url1, headers=headers)\n        # print(response1.headers)\n        r = response.json()\n        count=0\n        for i in r[\"events\"]:\n            \n            state = helper.get_check_point(str(i[\"id\"])+str(i[\"created_at\"]))\n            if state is None:\n                event = helper.new_event(json.dumps(i,indent=2))\n                ew.write_event(event)\n                count=count+1\n                helper.save_check_point(str(i[\"id\"])+str(i[\"created_at\"]), \"Indexed\")\n            # helper.delete_check_point(str(i[\"id\"])+str(i[\"created_at\"])) \n        \n                    \n            \n        \n        while(True):\n            try:\n                abc = (response1.headers[\"Link\"])\n                #print(abc)\n                abc1 = re.findall(r'([\\w+,.,-/,:,]*\\/\\w+.\\w+\\?\\w+=\\d+&\\w+=\\w+)>;\\srel=\\\"next\\\"', abc)\n                abc2=(\" \".join(map(str,abc1)))\n                #print(abc2)\n                if(abc2==\"\"):\n                    break\n                url = abc2\n                headers = {\n                'X-Shopify-Access-Token': f'{password}'\n                }\n            \n                response = requests.request(\"GET\", url, headers=headers)\n                response1 = requests.head( url, headers=headers)\n                r = response.json()\n                for i in r[\"events\"]:\n                \n                    state = helper.get_check_point(str(i[\"id\"])+str(i[\"created_at\"]))\n                    if state is None:\n                        event = helper.new_event(json.dumps(i,indent=2))\n                        ew.write_event(event)\n                        count=count+1\n                        helper.save_check_point(str(i[\"id\"])+str(i[\"created_at\"]), \"Indexed\")\n                    # helper.delete_check_point(str(i[\"id\"])+str(i[\"created_at\"])) \n               \n                \n            except(KeyError):\n                break\n            \n        status = response.status_code\n        status = \"API=\"+str(url1)+\"| response_code=\"+str(status)+\"| number_of_events=\"+str(count)\n        helper.log_info(status)\n        \n    else:\n        today = datetime.now()\n        yesterday = today \n        end_date = yesterday.strftime(\"%Y-%m-%d\")\n        yesterday1 = today - timedelta(days=1)\n        start_date = yesterday1.strftime(\"%Y-%m-%d\")\n        \n        url1 = f\"{username}/admin/api/2022-07/even