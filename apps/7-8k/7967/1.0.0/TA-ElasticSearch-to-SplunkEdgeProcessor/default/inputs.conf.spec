[elasticsearch_to_edge://<unique_name>]
server_url = <Elasticsearch server URL>
index_pattern = <Elasticsearch index pattern>
username = <Elasticsearch username>
password = <Elasticsearch password>
hec_url = <Splunk HEC URL>
hec_token = <Splunk HEC Token>
environment = <Comma-separated environments, e.g., prod,staging>
verify_tls = <true|false>
ca_bundle_path = <Optional path to CA bundle>
http_proxy = <Optional HTTP proxy>
https_proxy = <Optional HTTPS proxy>