<setup>
  <block title="Elasticsearch to Edge Processor">
    <text>Configure connection to Elasticsearch and Splunk Edge HEC</text>
    <input field="server_url" label="Elasticsearch URL" type="text" required="true"/>
    <input field="index_pattern" label="Index Pattern" type="text" required="true" default=".ds-logs-*"/>
    <input field="username" label="Elasticsearch Username" type="text" required="true"/>
    <input field="password" label="Elasticsearch Password" type="password" required="true"/>
    <input field="hec_url" label="HEC URL" type="text" required="true"/>
    <input field="hec_token" label="HEC Token" type="password" required="true"/>
    <input field="environment" label="Environments (comma-separated)" type="text" required="true" default="prod,staging"/>
    <input field="verify_tls" label="Verify TLS?" type="dropdown" required="false">
      <option value="true">true</option>
      <option value="false">false</option>
    </input>
    <input field="ca_bundle_path" label="CA Bundle Path (optional)" type="text" required="false"/>
    <input field="http_proxy" label="HTTP Proxy (optional)" type="text" required="false"/>
    <input field="https_proxy" label="HTTPS Proxy (optional)" type="text" required="false"/>
  </block>
</setup>