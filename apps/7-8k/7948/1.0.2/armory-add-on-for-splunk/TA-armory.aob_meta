{"basic_builder": {"appname": "armory-add-on-for-splunk", "friendly_name": "Armory Add-on for Splunk", "version": "1.0.0", "author": "Armory", "description": "", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.3.0", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "armory:vulnerabilities", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "vulnerabilities", "title": "Vulnerabilities", "description": "", "type": "customized", "parameters": [{"name": "account_key", "label": "Account Key", "help_string": "AWS Account Key ID", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "AKIAS3HZXVNK7XIPNSTX"}, {"name": "secret_key", "label": "Secret Key", "help_string": "AWS Account Secret Key", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "mKG/Z9aps8vDX6G8yXYEf7pje+DiNXvKzeXO61pV"}, {"name": "aws_region", "label": "AWS Region", "help_string": "", "required": true, "format_type": "text", "default_value": "us-east-1", "placeholder": "", "type": "text", "value": "ap-south-1"}, {"name": "sqs_queue_name", "label": "SQS Queue Name", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "s3_test"}], "data_inputs_options": [{"type": "customized_var", "name": "account_key", "title": "Account Key", "description": "AWS Account Key ID", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "secret_key", "title": "Secret Key", "description": "AWS Account Secret Key", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "aws_region", "title": "AWS Region", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "us-east-1", "placeholder": ""}, {"type": "customized_var", "name": "sqs_queue_name", "title": "SQS Queue Name", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "import boto3\r\nimport gzip\r\nimport io\r\nimport json\r\nimport urllib.parse\r\nfrom botocore.config import Config\r\n\r\n\r\ndef validate_input(helper, definition):\r\n    pass  # No input validation needed\r\n\r\n\r\ndef collect_events(helper, ew):\r\n    aws_key = helper.get_arg('account_key')\r\n    aws_secret = helper.get_arg('secret_key')\r\n    aws_region = helper.get_arg('aws_region')\r\n    sqs_queue_name = helper.get_arg('sqs_queue_name')\r\n\r\n    # Get proxy configuration\r\n    proxy = helper.get_proxy()\r\n    proxies = None\r\n    if proxy:\r\n        proxy_url = proxy.get(\"proxy_url\")\r\n        proxy_port = proxy.get(\"proxy_port\")\r\n        proxy_username = proxy.get(\"proxy_username\")\r\n        proxy_password = proxy.get(\"proxy_password\")\r\n        if proxy_url and proxy_port:\r\n            if proxy_username and proxy_password:\r\n                auth = f\"{proxy_username}:{proxy_password}@\"\r\n            else:\r\n                auth = \"\"\r\n            full_proxy_url = f\"http://{auth}{proxy_url}:{proxy_port}\"\r\n            proxies = {\r\n                'http': full_proxy_url,\r\n                'https': full_proxy_url\r\n            }\r\n    boto_config = Config(proxies=proxies)\r\n\r\n    # AWS Clients\r\n    session = boto3.Session(\r\n        aws_access_key_id=aws_key,\r\n        aws_secret_access_key=aws_secret,\r\n        region_name=aws_region\r\n    )\r\n\r\n    sqs = session.client('sqs', config=boto_config)\r\n    s3 = session.client('s3', config=boto_config)\r\n\r\n    # Get SQS Queue URL\r\n    queue_url = sqs.get_queue_url(QueueName=sqs_queue_name)['QueueUrl']\r\n    while True:\r\n        resp = sqs.receive_message(\r\n            QueueUrl=queue_url,\r\n            MaxNumberOfMessages=10,\r\n            WaitTimeSeconds=10\r\n        )\r\n\r\n        messages = resp.get(\"Messages\", [])\r\n        if not messages:\r\n            helper.log_info(\"No SQS messages received.\")\r\n            return\r\n\r\n        for msg in messages:\r\n            try:\r\n                body = json.loads(msg[\"Body\"])\r\n                if \"Message\" in body:\r\n                    body = json.loads(body[\"Message\"])\r\n                records = body.get(\"Records\", [])\r\n                for record in records:\r\n                    bucket = record[\"s3\"][\"bucket\"][\"name\"]\r\n                    key = urllib.parse.unquote_plus(\r\n                        record[\"s3\"][\"object\"][\"key\"])\r\n                    helper.log_info(\r\n                        f\"Processing S3 object: s3://{bucket}/{key}\")\r\n                    obj = s3.get_object(Bucket=bucket, Key=key)\r\n                    raw_data = obj[\"Body\"].read()\r\n\r\n                    # Decompress if needed\r\n                    if key.endswith('.gz'):\r\n                        with gzip.GzipFile(fileobj=io.BytesIO(raw_data)) as gz:\r\n                            file_content = gz.read().decode('utf-8')\r\n                    else:\r\n                        file_content = raw_data.decode('utf-8')\r\n\r\n                    # Try to parse as JSON\r\n                    try:\r\n                        json_data = json.loads(file_content)\r\n                        if isinstance(json_data, dict) and \"Records\" in json_data:\r\n                            for rec in json_data[\"Records\"]:\r\n                                event = helper.new_event(\r\n                                    data=json.dumps(rec),\r\n                                    source=key,\r\n                                    sourcetype=helper.get_sourcetype(),\r\n                                    index=helper.get_output_index()\r\n                                )\r\n                                ew.write_event(event)\r\n                        else:\r\n                            event = helper.new_event(\r\n                                data=json.dumps(json_data),\r\n                                source=key,\r\n                                sourcetype=helper.get_sourcetype(),\r\n                                index=helper.get_output_index()\r\n                            )\r\n                            ew.write_event(event)\r\n                    except json.JSONDecodeError:\r\n                        for line in file_content.splitlines():\r\n                            if line.strip():\r\n                                event = helper.new_event(\r\n                                    data=line,\r\n                                    source=key,\r\n                                    sourcetype=helper.get_sourcetype(),\r\n                                    index=helper.get_output_index()\r\n                                )\r\n                                ew.write_event(event)\r\n\r\n                    # Delete the processed message from SQS\r\n                    sqs.delete_message(QueueUrl=queue_url,\r\n                                       ReceiptHandle=msg[\"ReceiptHandle\"])\r\n            except Exception as e:\r\n                helper.log_error(f\"Failed to process SQS message: {e}\")\r\n", "customized_options": [{"name": "aws_region", "value": "ap-south-1"}, {"name": "sqs_queue_name", "value": "s3_test"}], "uuid": "21e58329ec7342ae9359dcfbc53ead61", "sample_count": 0}]}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http", "proxy_enabled": true, "proxy_url": "52.66.245.50", "proxy_port": "3128", "proxy_username": "testuser"}, "log_settings": {"log_level": "DEBUG"}}}, "sourcetype_builder": {"armory:vulnerabilities": {"metadata": {"event_count": 0, "data_input_name": "vulnerabilities", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1752764202_37", "progress": 1.0}}