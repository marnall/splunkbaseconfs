{"basic_builder": {"appname": "TA-simple-snmp-getter", "friendly_name": "Simple SNMP Getter", "version": "1.0.2", "author": "Leonardo Armesto", "description": "SNMP Getter Splunk queries remote devices for software/hardware configurations via SNMP protocol with just one or more object identifiers (OIDs) given as arguments.", "theme": "#708794", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.0.0", "tab_build_no": "0", "build_no": 4}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "snmp", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "snmp", "title": "snmp", "description": "", "type": "customized", "parameters": [{"name": "device_ip", "label": "Device IP", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "0.0.0.0", "type": "text", "value": "192.168.0.7"}, {"name": "port", "label": "Port #", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "161", "type": "text", "value": "161"}, {"name": "community", "label": "Community", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "oids", "label": "OIDs", "help_string": "Comma-separated OIDs to retrieve (Or just one)", "required": true, "format_type": "text", "default_value": "", "placeholder": "1.3.6.1.2.1.1.3.0,1.3.6.1.2.1.1.3.1,1.3.6.1.2.1.1.3.2", "type": "text", "value": "1.3.6.1.2.1.1.3.0,1.3.6.1.4.1.8072.1.3.2.3.1.1.7.99.112.117.116.101.109.112,1.3.6.1.4.1.8072.1.3.2.3.1.1.5.116.101.115.116.49"}, {"name": "oids_value_separator", "label": "OIDs value Separator", "help_string": "Separator character (comma, semicolon,pipe, etc) or whatever symbol you consider appropiate", "required": true, "format_type": "text", "default_value": "", "placeholder": ",", "type": "text", "value": "|"}, {"name": "src_type", "label": "Custom Source Type", "help_string": "Default is: snmp", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "raspberry_oids"}], "data_inputs_options": [{"type": "customized_var", "name": "device_ip", "title": "Device IP", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "0.0.0.0"}, {"type": "customized_var", "name": "port", "title": "Port #", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "161"}, {"type": "customized_var", "name": "community", "title": "Community", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "oids", "title": "OIDs", "description": "Comma-separated OIDs to retrieve (Or just one)", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "1.3.6.1.2.1.1.3.0,1.3.6.1.2.1.1.3.1,1.3.6.1.2.1.1.3.2"}, {"type": "customized_var", "name": "oids_value_separator", "title": "OIDs value Separator", "description": "Separator character (comma, semicolon,pipe, etc) or whatever symbol you consider appropiate", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ","}, {"type": "customized_var", "name": "src_type", "title": "Custom Source Type", "description": "Default is: snmp", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport datetime\nimport time\nimport logging as Log\n\nfrom pysnmp.hlapi import *\n\ndef getOids(host, port, community, oids):\n    data = []\n    for oid in oids:\n        for (errorIndication,\n            errorStatus,\n            errorIndex,\n            varBinds) in getCmd(SnmpEngine(),\n                                CommunityData(community),\n                                UdpTransportTarget((host, port)),\n                                ContextData(),\n                                ObjectType(ObjectIdentity(oid)),\n                                lookupMib=False,\n                                lexicographicMode=False):\n\n            if errorIndication:\n                print(errorIndication, file=sys.stderr)\n                break\n\n            elif errorStatus:\n                print('%s at %s' % (errorStatus.prettyPrint(),\n                                    errorIndex and varBinds[int(errorIndex) - 1][0] or '?'), file=sys.stderr)\n                break\n\n            else:\n                for varBind in varBinds:\n                    data.append(varBind)\n    return data\n\ndef validate_input(helper, definition):\n    device_ip = definition.parameters.get('device_ip', None)\n    port = definition.parameters.get('port', None)\n    community = definition.parameters.get('community', None)\n    oids = definition.parameters.get('oids', None)\n    oids_value_separator = definition.parameters.get('oids_value_separator', None)\n    src_type = definition.parameters.get('src_type', None)\n\ndef collect_events(helper, ew):\n    opt_device_ip = helper.get_arg('device_ip')\n    opt_port = helper.get_arg('port')\n    opt_community = helper.get_arg('community')\n    opt_oids = helper.get_arg('oids')\n    opt_oids_value_separator = helper.get_arg('oids_value_separator')\n    opt_src_type = helper.get_arg('src_type')\n    \n    if opt_src_type == '':\n        opt_src_type = 'snmp'\n\n    oids = opt_oids.split(\",\")\n    data = ''\n\n    try:\n        varBinds = getOids(opt_device_ip, opt_port, opt_community, oids)\n\n        data = opt_oids_value_separator.join([str(varBind[1]) for varBind in varBinds])\n    \n        event = helper.new_event(data, host=None, source=None, sourcetype=opt_src_type, done=True, unbroken=True)\n        ew.write_event(event)\n    \n    except Exception as e:\n        Log.error(e)", "customized_options": [{"name": "device_ip", "value": "192.168.1.33"}, {"name": "port", "value": "161"}, {"name": "oids", "value": "iso.3.6.1.2.1.1.1.0,iso.3.6.1.2.1.1.5.0"}, {"name": "oids_value_separator", "value": "|"}, {"name": "src_type", "value": "raspberry_oids"}], "uuid": "f629b6244638407bac97d7c3add4b17d", "sample_count": 0}]}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "sourcetype_builder": {"snmp": {"metadata": {"event_count": 0, "data_input_name": "snmp", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1629993351_45", "progress": 0.39285714285714285}}