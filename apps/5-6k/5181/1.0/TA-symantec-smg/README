#The below is reference from sysmantec used to extract fields

event_id,description,transforms_stanza
ACCEPT,Accepted From,"smg_accept,"
ATTACH,Identified attachment(s),"smg_attach,"
ATTACHFILTER,Attachment file name that was filtered,"smg_attachfilter,"
AUTH,Authenticated username,"smg_auth,"
DELETE,Logs if message is deleted manually,"smg_delete,"
DELIVER,Delivered To,"smg_deliver,"
DELIVERY_FAILURE,Delivery Failure,"smg_delivery_failure,"
DKIM,DKIM,"smg_dkim,"
DMARC,DMARC verification results,"smg_dmarc,"
EHLO,EHLO string provided at sender connection,"smg_ehlo,"
FIRED,Verdict,"smg_fired,"
IRCPTACTION,Intended Recipient/[Actions taken,"smg_ircptaction,"
LOGICAL_IP,Logical IP,"smg_logical_ip,"
MSG_SIZE,Size of original message,"smg_msg_size,"
MSGID,Message-ID,"smg_msgid,"
ORCPTS,Original recipients,"smg_orcpts,"
PMC,Potentially malicious content (likely attachment filename containing PMC),"smg_pmc,"
RECEIVED,Time message is completely received,"smg_received,"
RESUBMIT,Resubmission action (e.g. bypass),"smg_resubmit,"
SENDER,Sender,"smg_sender,"
SENDERID,Senderid verification results,"smg_senderid,"
SOURCE,Direction (i.e. external inbound / internal outbound),"smg_source,"
SPF,SPF verification results,"smg_spf,"
SUBJECT,Original Subject,"smg_subject,"
TD_RESULT,Threat Defense result,"smg_td_result,"
TLS_DELIVERY,Delivered with TLS,"smg_tls_delivery,"
TLS_RECEIVED,Logs if message was received with TLS,"smg_tls_received,"
TRACKERID,Tracker ID,"smg_trackerid,"
TRANS_FAILURE,Transient Delivery Attempts,"smg_trans_failure,"
UNSCANNABLE,Reason for unscannable verdict,"smg_unscannable,"
UNTESTED,Untested verdicts,"smg_untested,"
VERDICT,Verdict (one entry per verdict) recipient | verdict | policy group | filter policy,"smg_verdict,"
VIRUS,Name of virus detected,"smg_virus,"

