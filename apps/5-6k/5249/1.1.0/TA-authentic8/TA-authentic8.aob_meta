{"basic_builder": {"appname": "TA-authentic8", "friendly_name": "Authentic8", "version": "1.1.0", "author": "Authentic8", "description": "Authentic8 Add-on for Splunk", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "3.0.1", "tab_build_no": "2", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "Authentic8", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "authentic8", "title": "Authentic8", "description": "Splunk addon for Authentic8", "type": "customized", "parameters": [{"name": "authentic8_api_url", "label": "Authentic8 API URL", "help_string": "Please enter Authentic8 API URL.", "required": true, "format_type": "text", "default_value": "https://extapi.authentic8.com/api/", "placeholder": "", "type": "text", "value": "https://extapi.authentic8.com/api/"}, {"name": "auth_token", "label": "Auth Token", "help_string": "Please enter auth token for Authentic8 API.", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "organization_name", "label": "Organization Name", "help_string": "Please enter your organization name", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "log_type", "label": "Log Type", "help_string": "Please enter the log types you want fetched. By default, all log types will be fetched. For specific logs, enter the log type (for a single type) or provide a comma-separated list of log types.", "required": false, "format_type": "text", "default_value": "all", "placeholder": "", "type": "text", "value": "all"}], "data_inputs_options": [{"type": "customized_var", "name": "authentic8_api_url", "title": "Authentic8 API URL", "description": "Please enter Authentic8 API URL.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "https://extapi.authentic8.com/api/", "placeholder": ""}, {"type": "customized_var", "name": "auth_token", "title": "Auth Token", "description": "Please enter auth token for Authentic8 API.", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "organization_name", "title": "Organization Name", "description": "Please enter your organization name", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "log_type", "title": "Log Type", "description": "Please enter the log types you want fetched. By default, all log types will be fetched. For specific logs, enter the log type (for a single type) or provide a comma-separated list of log types.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "all", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport datetime,sys\nfrom config import FIELDS, log_type_list, enc_type_list, DAYS\nfrom splunk_utils import extract_input_fields\nfrom utils import processing_auth8_logs\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    pass\n\n\ndef collect_events(helper, ew):\n    \"\"\"Implement your data collection logic here.\n    :param helper: Splunk helper object through logger and user input will be accessed.\n    :param ew: Event writer object for writing in splunk.\n\n    \"\"\"\n    helper.log_info(\"Process started at {}.\".format(datetime.datetime.now()))\n    for i in range(1, 91):\n        try:\n            if helper.get_global_setting(\"name_{}\".format(i)):\n                key_name = helper.get_global_setting(\"name_{}\".format(i))\n                pvt_key = helper.get_global_setting(\"ip_{}\".format(i))\n                helper.save_check_point(key_name, pvt_key)\n            else:\n                continue\n        except Exception as e:\n            helper.log_info(\"data not found from global setting\")\n\n    options = extract_input_fields(helper, FIELDS)\n    if isinstance(options[\"log_type\"], list):\n        for each in options[\"log_type\"]:\n            log_type = each.upper()\n            helper.log_info(\"Processing user input and log type is {} \".format(each))\n            if log_type in log_type_list:\n                processing_auth8_logs(log_type, options, helper, ew)\n                # Checking the key for older logs.\n                if log_type == \"ENC\":\n                    processing_auth8_older_logs(log_type, options, helper, ew)\n            else:\n                helper.log_info(\"Invalid input is {} .\".format(each))\n\n    elif options['log_type'] and options['log_type'].lower() == \"all\":\n        helper.log_info(\"Processing all input\")\n        for each in log_type_list:\n            log_type = each.upper()\n            processing_auth8_logs(log_type, options, helper, ew)\n            if log_type == \"ENC\":\n                processing_auth8_older_logs(log_type, options, helper, ew)\n    else:\n        helper.log_info(\"Invalid input-- {}.\".format(options[\"log_type\"]))\n\n    helper.log_info(\"Process completed.\")\n\n\ndef processing_auth8_older_logs(log_type, options, helper, ew):\n    unprocessed_keys = helper.get_check_point('lost_key')\n    if unprocessed_keys:\n        for key in unprocessed_keys:\n            helper.log_info(\"Processing older key {}\".format(key))\n            pvt_key = helper.get_check_point(key)\n            helper.log_info(\"Private key of older  key is {}\".format(pvt_key))\n            if pvt_key:\n                processing_auth8_logs(log_type, options, helper, ew, start_seq_flag=1, old_key_name=key)\n                new_lost_keys = unprocessed_keys.pop(unprocessed_keys.index(key))\n                helper.save_check_point('lost_ley', new_lost_keys)\n            else:\n                helper.log_debug(\"Pvt key not found for old key_name{}\".format(key))\n\n\n", "customized_options": [{"name": "authentic8_api_url", "value": "https://extapi.authentic8.com/api/"}, {"name": "organization_name", "value": ""}, {"name": "log_type", "value": "all"}], "uuid": "388bd8f4f0db4fb8a246f3746da1c67f", "sample_count": "2744"}]}, "field_extraction_builder": {"Authentic8": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}, "credential_settings": [], "customized_settings": [{"required": false, "name": "pkey_90", "label": "PKey 90", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "pkey_89", "label": "PKey 89", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "pkey_88", "label": "PKey 88", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "pkey_87", "label": "PKey 87", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "pkey_86", "label": "PKey 86", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "pkey_85", "label": "PKey 85", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "name": "pkey_84", "label": "PKey 84", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": false, "nam