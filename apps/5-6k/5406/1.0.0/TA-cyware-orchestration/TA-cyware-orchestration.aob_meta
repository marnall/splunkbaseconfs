{"alert_action_builder": {"modular_alerts": [{"description": "This action will send Alert Event to Cyware Orchestration", "largeIcon": "", "smallIcon": "", "label": "Push Alert Event to Cyware Orchestration", "short_name": "push_alert_event_to_cyware_orchestration", "active_response": {"technology": [{"vendor": "Cyware Labs", "product": "Cyware Orchestration", "version": ["1.0.0"]}], "supports_adhoc": true, "category": ["Information Gathering"], "task": ["create"], "subject": ["source event"]}, "parameters": [], "code": "import os\nimport sys\nimport time\nimport datetime\nimport hmac\nimport hashlib\nimport time\nimport base64\nimport json\nimport requests\n\ndef generate_signature(expires, access_id, secret_key):\n    to_sign = '{}\\n{}'.format(access_id, expires)\n    signature = base64.b64encode(\n        hmac.new(\n            secret_key.encode('utf-8'),\n            to_sign.encode('utf-8'),\n            hashlib.sha1\n        ).digest()\n    ).decode(\"utf-8\")\n    return signature\n\ndef process_event(helper, *args, **kwargs):\n    try:\n        helper.log_info(\"INFO: Initiated sending events to Cyware products\")\n        # Setting variables\n        app_identifier = \"splunk-app\"\n        action_identifier = \"splunk-event\"\n        cyware_orchestration_url = helper.get_global_setting(\"cyware_url\")\n        cyware_orchestration_access_key = helper.get_global_setting(\"cyware_access_key\")\n        cyware_orchestration_secret_key = helper.get_global_setting(\"cyware_secret_key\")\n        # Setting variable to override system proxy settings\n        verify = helper.get_global_setting(\"verify_tls_certificate\")\n        print(verify)\n        if (str(verify) == \"1\" and verify) or verify is True:\n            verify = True\n            helper.log_debug(\"Debug: Setting TLS certificate to True\")\n        else:\n            helper.log_debug(\"Debug: Setting TLS certificate to False\")\n            verify = False\n\n        helper.log_debug(\"Alert action csol_push_alerts started.\")\n        alert_data = {}\n        alert_data[\"sid\"] = helper.sid\n        alert_data[\"search_name\"] = helper.search_name\n        try:\n            alert_data[\"events\"] = []\n            alert_data[\"event_config\"] = helper.configuration\n            for event in helper.get_events():\n                alert_data[\"events\"].append(event)\n        except Exception as e:\n            helper.log_error(\"ERROR: Events not found: {}\".format(str(e)))\n            return 0\n            \n        data = {\n            \"title\": \"Splunk Event Data\",\n            \"app_identifier\": app_identifier,\n            \"action_identifier\": action_identifier,\n            \"data\": alert_data,\n        }\n        # Formulating request data\n        expires = int(time.time() + 300)\n        sec_params = {}\n        sec_params[\"AccessID\"] = cyware_orchestration_access_key\n        sec_params[\"Expires\"] = expires\n        try:\n            sec_params[\"Signature\"] = generate_signature(expires, cyware_orchestration_access_key, cyware_orchestration_secret_key)\n        except Exception as e:\n            helper.log_error(\"Fatal Error: Caught an exception while generating Authentication Signature: {}\".format(e))\n            return 0\n        else:\n            helper.log_debug(\"Authentication Signature Generated Successfully\")\n        endpoint = \"{0}/v1/events/\".format(cyware_orchestration_url.rstrip('/'))\n        try:\n            response =  helper.send_http_request(endpoint, \"POST\", parameters=sec_params, payload=data, verify=verify)\n            status_code = response.status_code\n\n            if status_code < 300:\n                helper.log_info(\"Created Source Event Successfully\")\n                return 1\n            else:\n                helper.log_error(\"Unable to create source event! Status Code: {0}\".format(status_code))\n                \n        except requests.exceptions.RequestException as e:\n            helper.log_error(\"Fatal Error: Encountered Error while pushing data to Cyware Orchestration. \\nException Encountered: {}\".format(e))\n        \n    except Exception as e:\n        helper.log_error(\"ERROR: App error {}\".format(str(e)))\n        return 0\n    \n    return 1\n", "uuid": "11cd1746971542a6841c56af7f7497b6"}]}, "basic_builder": {"appname": "TA-cyware-orchestration", "friendly_name": "Cyware Orchestration Add-on for Splunk", "version": "1.0.0", "author": "Cyware Labs", "description": "This action will send Alert Event to Cyware Orchestration Add-on for Splunk", "theme": "#177FDE", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "3.0.1", "tab_build_no": "2", "build_no": 1}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}, "customized_settings": [{"format_type": "text", "required": true, "name": "cyware_url", "label": "Cyware URL", "default_value": "", "help_string": "https://<csolhost>.<tld>/soarapi/openapi/", "internal_name": "", "type": "text", "value": ""}, {"format_type": "text", "required": true, "name": "cyware_access_key", "label": "Cyware Access Key", "default_value": "", "help_string": "", "internal_name": "", "type": "text", "value": ""}, {"format_type": "password", "required": true, "name": "cyware_secret_key", "label": "Cyware Secret Key", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}, {"format_type": "checkbox", "required": false, "name": "verify_tls_certificate", "label": "Verify TLS Certificate", "default_value": 0, "help_string": "", "internal_name": "", "type": "checkbox", "value": 0}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1611149286_42", "progress": 1.0}}