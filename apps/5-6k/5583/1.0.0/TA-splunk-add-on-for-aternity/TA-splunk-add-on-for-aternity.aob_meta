{"basic_builder": {"appname": "TA-splunk-add-on-for-aternity", "friendly_name": "Splunk Add-on for Aternity", "version": "1.0.0", "author": "", "description": "This add-on helps in getting insights via Aternity Rest APIs in Splunk.", "theme": "#297ba5", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "3.0.1", "tab_build_no": "2", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "aternity:api:summary", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "aternity_api_summary", "title": "aternity:api:summary", "description": "Get insights in Splunk directly from Aternity Rest APIs.", "type": "rest", "parameters": [{"name": "aternity_domain_name", "label": "Aternity Domain name", "help_string": "Example: If your URL is <https://my-aternity.aternity.com>, then only input \"my-aternity\" in this field", "required": true, "format_type": "text", "default_value": "", "placeholder": "my-aternity", "type": "text", "value": "evaluation"}, {"name": "rest_api_name", "label": "REST API Name", "help_string": "Quick-Tip: For the latest version of Aternity APIs list please visit <https://help.aternity.com/restapi>", "required": true, "format_type": "text", "default_value": "", "placeholder": "<REST API Name>", "type": "text", "value": "DEVICE_INVENTORY"}, {"name": "global_account", "label": "Global Account", "help_string": "Username (must have the OData REST API role) and its password. You can find this by selecting User icon > REST API Access.", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}], "data_inputs_options": [{"name": "_rest_api_url", "rest_header": false, "description": "url", "value": "https://${aternity_domain_name}-odata.aternity.com/aternity.odata/latest/${rest_api_name}"}, {"name": "_rest_api_method", "rest_header": false, "description": "method", "value": "GET"