[proxy]
proxy_enabled = Should the proxy be enabled or not.(Value should be bool True or False)
proxy_type = Type of the proxy from http, socks4 or socks5.
proxy_url = Url of the proxy server.
proxy_port = Port of the proxy server.
proxy_username = Username of proxy user.
proxy_password = Password of the proxy user.
proxy_rdns = Remote DNS resolution for proxy.

[logging]
loglevel = Level of logging from debug, info, warning, error or critical.

[purestorage_additional_parameters]
verify_ssl = Please enter True if to verify the ssl certificate while requesting data or False to send request without verifying ssl certificate.