[purestorage_unified_input://<name>]
interval = Interval for collecting the data
index = Name of Index to store data.
global_account = Select the account for which you want to collect data.
input_type = Select input type from flashblade, flasharray or pure1.
start_date = Date and time from which you want to fetch events. Enter the value in 'YYYY-MM-DDTHH:mm:ss' format e.g. 2013-04-17T09:12:36. TimeZone will be set to UTC TimeZone.
python.version = Select which Python version to use. {default|python|python2|python3}
historical_data = Checkbox to collect historical data for flasharray and flashblade.