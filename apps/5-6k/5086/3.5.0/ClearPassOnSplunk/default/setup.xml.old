<setup>
    <block title="ClearPass Host Configuration" endpoint="configs/conf-cppm" entity="config">
        <input field="cppm_host">
            <label>ClearPass Hostname or IP Address</label>
            <type>text</type>
        </input>
        <input field="disable_ssl">
            <label>Disable SSL Validation</label>
            <type>bool</type>
        </input>
        <input field="endpoint_filter">
            <label>MDM Import Filter</label>
            <type>text</type>
        </input>
    </block>
    <block title="ClearPass REST API Configuration" endpoint="storage/passwords" entity="_new">
        <input field="name">
            <label>Client Name</label>
            <type>text</type>
        </input>
        <input field="password">
            <label>Client Secret/Password</label>
            <type>password</type>
        </input>
    </block>
    <block title="Enable MDM Input" endpoint="data/inputs/script" entity=".%252Fbin%252Fmdm-sync.py">
        <input field="interval">
            <label>Interval</label>
            <type>text</type>
        </input>
        <input field="enabled">
            <label>Enable</label>
            <type>bool</type>
        </input>
    </block>
</setup>