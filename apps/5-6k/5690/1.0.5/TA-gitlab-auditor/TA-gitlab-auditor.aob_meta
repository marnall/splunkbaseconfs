{"basic_builder": {"appname": "TA-gitlab-auditor", "friendly_name": "GitLab Auditor", "version": "1.0.5", "author": "Leonardo Armesto", "description": "GitLab Auditor Add-On is a tool for GitLab owners and administrators to track important events such as who performed certain actions and the time they happened.", "theme": "#4d4f53", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.0.0", "tab_build_no": "0", "build_no": 5}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "gitlabapi", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "gitlabapi", "title": "GitLab logs", "description": "", "type": "customized", "parameters": [{"name": "gitlab_url", "label": "GitLab URL:", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://gitlab.<YOUR_COMPANY>.com", "type": "text", "value": "https://gitlab.naranja.dev"}, {"name": "token", "label": "Access Token:", "help_string": "You can generate a personal access token for each application you use that needs access to the GitLab API", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "HoHBR3ysmuHKCWTxdqAf"}, {"name": "endpoint", "label": "Endpoint:", "help_string": "", "required": true, "possible_values": [{"value": "commits", "label": "Commits"}, {"value": "events", "label": "Events"}, {"value": "jobs", "label": "Jobs (Project ID is mandatory)"}, {"label": "Users", "value": "users"}], "format_type": "radiogroup", "default_value": "events", "type": "radiogroup", "value": "commits"}, {"name": "created_after", "label": "Created After:", "help_string": "Return events created after the given date", "required": true, "format_type": "text", "default_value": "", "placeholder": "YYYY-MM-DD", "type": "text", "value": "2019-01-01"}, {"name": "project_id", "label": "Project ID:", "help_string": "Optional, otherwise returns all available events within the projects", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "1510"}], "data_inputs_options": [{"type": "customized_var", "name": "gitlab_url", "title": "GitLab URL:", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://gitlab.<YOUR_COMPANY>.com"}, {"type": "customized_var", "name": "token", "title": "Access Token:", "description": "You can generate a personal access token for each application you use that needs access to the GitLab API", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "endpoint", "title": "Endpoint:", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "commits", "label": "Commits"}, {"value": "events", "label": "Events"}, {"value": "jobs", "label": "Jobs (Project ID is mandatory)"}, {"label": "Users", "value": "users"}], "format_type": "radiogroup", "default_value": "events"}, {"type": "customized_var", "name": "created_after", "title": "Created After:", "description": "Return events created after the given date", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "YYYY-MM-DD"}, {"type": "customized_var", "name": "project_id", "title": "Project ID:", "description": "Optional, otherwise returns all available events within the projects", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport os.path\nimport gitlab\n\ndef isCheckpoint(check_file, chkpntID):\n    file_exists = os.path.isfile(check_file) \n    if file_exists:\n        with open(check_file, 'r') as file:\n            chkpntID_list = file.read().splitlines()\n    else:\n        with open(check_file, 'w+') as file:\n            chkpntID_list = file.read().splitlines()\n\n    return (chkpntID in chkpntID_list)\n\ndef write2Checkpoint(check_file, log):\n    with open(check_file,'a') as file:\n        file.writelines(log + '\\n')\n        \ndef write2Splunk(helper, ew, data):\n    event = helper.new_event(data, host=None, done=True, unbroken=True)\n\n    try:\n        ew.write_event(event)\n    except Exception as e:\n        raise e\n\ndef validate_input(helper, definition):\n    gitlab_url = definition.parameters.get('gitlab_url', None)\n    token = definition.parameters.get('token', None)\n    endpoint = definition.parameters.get('endpoint', None)\n    created_after = definition.parameters.get('created_after', None)\n    project_id = definition.parameters.get('project_id', None)\n\ndef collect_events(helper, ew):\n    opt_gitlab_url = helper.get_arg(\"gitlab_url\")\n    opt_token = helper.get_arg(\"token\")\n    opt_endpoint = helper.get_arg(\"endpoint\")\n    opt_created_after = helper.get_arg(\"created_after\")\n    opt_project_id = helper.get_arg(\"project_id\")\n\n    # Path para el archivo de checkpoint utilizado (se crea un archivo por fecha YYYYMMDD)\n    dtFile = str(datetime.datetime.now().strftime(\"%Y%m%d\"))\n    check_file = os.path.join('/', os.path.dirname(os.path.abspath(__file__)), 'checkpoint', dtFile + '-gitlab')\n\n    gl = gitlab.Gitlab(opt_gitlab_url, opt_token, per_page=100)\n    \n    if (opt_project_id):\n        projects = gl.projects.get(opt_project_id)\n        \n        if opt_endpoint == 'events':\n            for l in projects.events.list(after=opt_created_after):\n                data = json.dumps(l.attributes)\n\n                # Creates checkpoint ID for Event\n                chkpntID = 'evt-' + str(l.attributes[\"project_id\"]) + \"|\" + l.attributes[\"action_name\"] + \"|\" + str(l.attributes[\"author_id\"]) + \"|\" + l.attributes[\"created_at\"] + \"|\" + l.attributes[\"author_username\"]\n                \n                if not isCheckpoint(check_file, chkpntID):\n                    # Write to Checkpoint File\n                    write2Checkpoint(check_file, chkpntID)\n                    # Write to Splunk\n                    write2Splunk(helper, ew, data)\n        elif opt_endpoint == 'jobs':\n            for p in projects.pipelines.list():\n                pipeline = projects.pipelines.get(p.attributes[\"id\"])\n                jobs = pipeline.jobs.list()\n                for j in jobs:\n                    data = json.dumps(j.attributes)\n                    \n                    # Creates checkpoint ID for Job\n                    chkpntID = 'job-' + str(j.attributes[\"id\"]) + \"|\" + str(j.attributes[\"status\"]) + \"|\" + str(j.attributes[\"stage\"]) + \"|\" + str(j.attributes[\"ref\"]) + \"|\" + str(j.attributes[\"created_at\"]) + \"|\" + str(j.attributes[\"started_at\"]) + \"|\" + str(j.attributes[\"finished_at\"]) + \"|\" + str(j.attributes[\"duration\"]) + \"|\" + str(j.attributes[\"project_id\"]) + \"|\" + str(j.attributes[\"pipeline_id\"])\n                    \n                    if not isCheckpoint(check_file, chkpntID):\n                        # Write to Checkpoint File\n                        write2Checkpoint(check_file, chkpntID)\n                        # Write to Splunk\n                        write2Splunk(helper, ew, data)\n        else:\n            for c in projects.commits.list(since=opt_created_after):\n                data = json.dumps(c.attributes)\n\n                # Creates checkpoint ID for Event\n                chkpntID = 'com-' + str(c.attributes[\"id\"]) + \"|\" + c.attributes[\"short_id\"] + \"|\" + str(c.attributes[\"created_at\"]) + \"|\" + c.attributes[\"author_email\"] + \"|\" + c.attributes[\"authored_date\"] + \"|\" + c.attributes[\"committer_email\"] + \"|\" + c.attributes[\"committed_date\"] + \"|\" + str(c.attributes[\"project_id\"])\n\n                if not isCheckpoint(check_file, chkpntID):\n                    # Write to Checkpoint File\n                    write2Checkpoint(check_file, chkpntID)\n                    # Write to Splunk\n                    write2Splunk(helper, ew, data)\n                \n    else:\n        if opt_endpoint == 'users':\n            # List all Users\n            users = gl.users.list()\n            \n            for u in users:\n                data = json.dumps(u.attributes)\n                \n                # Creates checkpoint ID\n                chkpntID = 'usr-' + str(u.attributes[\"id\"]) + \"|\" + str(u.attributes[\"username\"]) + \"|\" + str(u.attributes[\"state\"]) + \"|\" + str(u.attributes[\"created_at\"]) + \"|\" + str(u.attributes[\"last_sign_in_at\"]) + \"|\" + str(u.attributes[\"confirmed_at\"]) + \"|\" + str(u.attributes[\"last_activity_on\"]) + \"|\" + str(u.attributes[\"email\"]) + \"|\" + str(u.attributes[\"projects_limit\"]) + \"|\" + str(u.attributes[\"current_sign_in_at\"]) + \"|\" + str(u.attributes[\"can_create_group\"]) + \"|\" + str(u.attributes[\"external\"]) + \"|\" + str(u.attributes[\"two_factor_enabled\"]) + \"|\" + str(u.attributes[\"private_profile\"]) + \"|\" + str(u.attributes[\"is_admin\"])\n                \n                if not isCheckpoint(check_file, chkpntID):\n                    # Write to Checkpoint File\n                    write2Checkpoint(check_file, chkpntID)\n                    # Write to Splunk\n                    write2Splunk(helper, ew, data)\n        else:\n            # List all the projects\n            projects = gl.projects.list(as_list=False, all=True)\n            \n            if opt_endpoint == 'events':\n                for project in projects:\n                    for l in project.events.list(after=opt_created_after):\n                        data = json.dumps(l.attributes)\n    \n                        # Creates checkpoint ID\n                        chkpntID = 'evt-' + str(l.attributes[\"project_id\"]) + \"|\" + l.attributes[\"action_name\"] + \"|\" + str(l.attributes[\"author_id\"]) + \"|\" + l.attributes[\"created_at\"] + \"|\" + l.attributes[\"author_username\"]\n                        \n                        if not isCheckpoint(check_file, chkpntID):\n                            # Write to Checkpoint File\n                            write2Checkpoint(check_file, chkpntID)\n                            # Write to Splunk\n                            write2Splunk(helper, ew, data)\n            \n            elif opt_endpoint == 'commits':\n                for project in projects:\n                    for c in project.commits.list(since=opt_created_after):\n                        data = json.dumps(c.attributes)\n    \n                        # Creates checkpoint ID for Event\n                        chkpntID = 'com-' + str(c.attributes[\"id\"]) + \"|\" + c.attributes[\"short_id\"] + \"|\" + str(c.attributes[\"created_at\"]) + \"|\" + c.attributes[\"author_email\"] + \"|\" + c.attributes[\"authored_date\"] + \"|\" + c.attributes[\"committer_email\"] + \"|\" + c.attributes[\"committed_date\"] + \"|\" + str(c.attributes[\"project_id\"])\n    \n                        if not isCheckpoint(check_file, chkpntID):\n                            # Write to Checkpoint File\n                            write2Checkpoint(check_file, chkpntID)\n                            # Write to Splunk\n                            write2Splunk(helper, ew, data)", "customized_options": [{"name": "gitlab_url", "value": "https://gitlab.naranja.dev"}, {"name": "endpoint", "value": "users"}, {"name": "created_after", "value": "2021-01-01"}, {"name": "project_id", "value": ""}], "uuid": "a8cfaca8987d48f4be7fc8041a22e095", "sample_count": 0}]}, "field_extraction_builder": {"gitlabapi": {"regex_results_temp": {"status": {"finished": true, "progress": 1.0}, "groups": [{"group_id": "pattern_0", "seed": {"raw": "{\"project_id\": 1514, \"action_name\": \"pushed new\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": 189, \"target_title\": null, \"created_at\": \"2021-08-05T14:46:55.037Z\", \"author\": {\"id\": 189, \"name\": \"Pablo Felitti\", \"username\": \"pablo.felitti\", \"state\": \"active\", \"avatar_url\": \"https://gitlab.naranja.dev/uploads/-/system/user/avatar/189/avatar.png\", \"web_url\": \"https://gitlab.naranja.dev/pablo.felitti\"}, \"push_data\": {\"commit_count\": 1, \"action\": \"created\", \"ref_type\": \"branch\", \"commit_from\": null, \"commit_to\": \"3123f3055f891d148a681e6c23617433cc3565ab\", \"ref\": \"master\", \"commit_title\": \"Add README.md\"}, \"author_username\": \"pablo.felitti\"}", "token": "\\{\"project_id\": 1514, \"action_name\": \"pushed new\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": 189, \"target_title\": null, \"created_at\": \"2021-08-05T14:46:55\\.037Z\", \"author\": \\{\"id\": 189, \"name\": \"Pablo Felitti\", \"username\": \"pablo\\.felitti\", \"state\": \"active\", \"avatar_url\": \"\\$\\$url\\$\\$ \"web_url\": \"\\$\\$url\\$\\$ \"push_data\": \\{\"commit_count\": 1, \"action\": \"created\", \"ref_type\": \"branch\", \"commit_from\": null, \"commit_to\": \"3123f3055f891d148a681e6c23617433cc3565ab\", \"ref\": \"master\", \"commit_title\": \"Add \\$\\$domain_name\\$\\$\"\\}, \"author_username\": \"pablo\\.felitti\"\\}", "words": ["{", "\"", "project_id", "\"", ":", " ", "1514", ",", " ", "\"", "action_name", "\"", ":", " ", "\"", "pushed", " ", "new", "\"", ",", " ", "\"", "target_id", "\"", ":", " ", "null", ",", " ", "\"", "target_iid", "\"", ":", " ", "null", ",", " ", "\"", "target_type", "\"", ":", " ", "null", ",", " ", "\"", "author_id", "\"", ":", " ", "189", ",", " ", "\"", "target_title", "\"", ":", " ", "null", ",", " ", "\"", "created_at", "\"", ":", " ", "\"", "2021-08-05T14", ":", "46", ":", "55", ".", "037Z", "\"", ",", " ", "\"", "author", "\"", ":", " ", "{", "\"", "id", "\"", ":", " ", "189", ",", " ", "\"", "name", "\"", ":", " ", "\"", "Pablo", " ", "Felitti", "\"", ",", " ", "\"", "username", "\"", ":", " ", "\"", "pablo", ".", "felitti", "\"", ",", " ", "\"", "state", "\"", ":", " ", "\"", "active", "\"", ",", " ", "\"", "avatar_url", "\"", ":", " ", "\"", "$$url$$", " ", "\"", "web_url", "\"", ":", " ", "\"", "$$url$$", " ", "\"", "push_data", "\"", ":", " ", "{", "\"", "commit_count", "\"", ":", " ", "1", ",", " ", "\"", "action", "\"", ":", " ", "\"", "created", "\"", ",", " ", "\"", "ref_type", "\"", ":", " ", "\"", "branch", "\"", ",", " ", "\"", "commit_from", "\"", ":", " ", "null", ",", " ", "\"", "commit_to", "\"", ":", " ", "\"", "3123f3055f891d148a681e6c23617433cc3565ab", "\"", ",", " ", "\"", "ref", "\"", ":", " ", "\"", "master", "\"", ",", " ", "\"", "commit_title", "\"", ":", " ", "\"", "Add", " ", "$$domain_name$$", "\"", "}", ",", " ", "\"", "author_username", "\"", ":", " ", "\"", "pablo", ".", "felitti", "\"", "}"]}, "regex": {"regex": "\\{\"project_id\": 1514, \"action_name\": \"pushed ([\\s\\S]*)\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": ([\\s\\S]*), \"target_title\": null, \"created_at\": \"([\\s\\S]*)\", \"author\": \\{\"id\": ([\\s\\S]*), \"name\": \"([\\s\\S]*)\", \"username\": \"([\\s\\S]*)\", \"state\": \"active\", \"avatar_url\": \"(?P<url_1>https?:\\/\\/\\S+) \"web_url\": \"(?P<url_2>https?:\\/\\/\\S+) \"push_data\": \\{\"commit_count\": 1, \"action\": \"([\\s\\S]*)\", \"ref_type\": \"branch\", \"commit_from\": ([\\s\\S]*), \"commit_to\": \"([\\s\\S]*)\", \"ref\": \"([\\s\\S]*)\", \"commit_title\": \"([\\s\\S]*)\"\\}, \"author_username\": \"([\\s\\S]*)\"\\}[\\s\\r\\n\\t]*$", "enabled": true, "regex_with_possible_values": "\\{\"project_id\": 1514, \"action_name\": \"pushed (?P<field_1>new|to)\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": (?P<field_2>189|392), \"target_title\": null, \"created_at\": \"(?P<field_3>2021-08-05T14:46:55\\.037Z|2021-08-05T15:05:17\\.614Z|2021-08-05T17:06:41\\.489Z|2021-08-06T14:40:42\\.897Z)\", \"author\": \\{\"id\": (?P<field_4>189|392), \"name\": \"(?P<field_5>Pablo Felitti|alejandro\\.rizzuto)\", \"username\": \"(?P<field_6>pablo\\.felitti|alejandro\\.rizzuto)\", \"state\": \"active\", \"avatar_url\": \"(?P<url_1>https?:\\/\\/\\S+) \"web_url\": \"(?P<url_2>https?:\\/\\/\\S+) \"push_data\": \\{\"commit_count\": 1, \"action\": \"(?P<action_1>created|pushed)\", \"ref_type\": \"branch\", \"commit_from\": (?P<field_7>null|\"fe15e25d0502f7911aba072382bf44ecd54ad62c\"|\"bb857d4206d6cf705601e76b7cc13d6f8c8fffb9\"), \"commit_to\": \"(?P<field_8>3123f3055f891d148a681e6c23617433cc3565ab|fe15e25d0502f7911aba072382bf44ecd54ad62c|bb857d4206d6cf705601e76b7cc13d6f8c8fffb9|7ad7cca493cd695932d5ffd579ea29de71daef58)\", \"ref\": \"(?P<field_9>master|dev)\", \"commit_title\": \"(?P<field_10>Add (?P<domain_name_1>[a-zA-Z0-9](?:[a-zA-Z0-9-]{1,61}\\.)+[a-zA-Z]{2,6})|NCA-829: Creacion de proyecto y gitignore|NCA-829: Creacion de estructura de proyecto|NCA-829: application properties \\+ automation values)\"\\}, \"author_username\": \"(?P<field_11>pablo\\.felitti|alejandro\\.rizzuto)\"\\}[\\s\\r\\n\\t]*$"}, "event_count": 4, "sample_rate": 0.8}, {"group_id": "pattern_2", "seed": {"raw": "{\"project_id\": 1514, \"action_name\": \"created\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": 392, \"target_title\": null, \"created_at\": \"2021-08-05T14:06:18.897Z\", \"author\": {\"id\": 392, \"name\": \"alejandro.rizzuto\", \"username\": \"alejandro.rizzuto\", \"state\": \"active\", \"avatar_url\": \"https://gitlab.naranja.dev/uploads/-/system/user/avatar/392/avatar.png\", \"web_url\": \"https://gitlab.naranja.dev/alejandro.rizzuto\"}, \"author_username\": \"alejandro.rizzuto\"}", "token": "\\{\"project_id\": 1514, \"action_name\": \"created\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": 392, \"target_title\": null, \"created_at\": \"2021-08-05T14:06:18\\.897Z\", \"author\": \\{\"id\": 392, \"name\": \"alejandro\\.rizzuto\", \"username\": \"alejandro\\.rizzuto\", \"state\": \"active\", \"avatar_url\": \"\\$\\$url\\$\\$ \"web_url\": \"\\$\\$url\\$\\$ \"author_username\": \"alejandro\\.rizzuto\"\\}", "words": ["{", "\"", "project_id", "\"", ":", " ", "1514", ",", " ", "\"", "action_name", "\"", ":", " ", "\"", "created", "\"", ",", " ", "\"", "target_id", "\"", ":", " ", "null", ",", " ", "\"", "target_iid", "\"", ":", " ", "null", ",", " ", "\"", "target_type", "\"", ":", " ", "null", ",", " ", "\"", "author_id", "\"", ":", " ", "392", ",", " ", "\"", "target_title", "\"", ":", " ", "null", ",", " ", "\"", "created_at", "\"", ":", " ", "\"", "2021-08-05T14", ":", "06", ":", "18", ".", "897Z", "\"", ",", " ", "\"", "author", "\"", ":", " ", "{", "\"", "id", "\"", ":", " ", "392", ",", " ", "\"", "name", "\"", ":", " ", "\"", "alejandro", ".", "rizzuto", "\"", ",", " ", "\"", "username", "\"", ":", " ", "\"", "alejandro", ".", "rizzuto", "\"", ",", " ", "\"", "state", "\"", ":", " ", "\"", "active", "\"", ",", " ", "\"", "avatar_url", "\"", ":", " ", "\"", "$$url$$", " ", "\"", "web_url", "\"", ":", " ", "\"", "$$url$$", " ", "\"", "author_username", "\"", ":", " ", "\"", "alejandro", ".", "rizzuto", "\"", "}"]}, "regex": {"regex": "\\{\"project_id\": 1514, \"action_name\": \"([\\s\\S]*)\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": 392, \"target_title\": null, \"created_at\": \"2021-08-05T14:06:18\\.897Z\", \"author\": \\{\"id\": 392, \"name\": \"alejandro\\.rizzuto\", \"username\": \"alejandro\\.rizzuto\", \"state\": \"active\", \"avatar_url\": \"(?P<url_1>https?:\\/\\/\\S+) \"web_url\": \"(?P<url_2>https?:\\/\\/\\S+) \"author_username\": \"alejandro\\.rizzuto\"\\}[\\s\\r\\n\\t]*$", "enabled": true, "regex_with_possible_values": "\\{\"project_id\": 1514, \"action_name\": \"(?P<action_1>created)\", \"target_id\": null, \"target_iid\": null, \"target_type\": null, \"author_id\": 392, \"target_title\": null, \"created_at\": \"2021-08-05T14:06:18\\.897Z\", \"author\": \\{\"id\": 392, \"name\": \"alejandro\\.rizzuto\", \"username\": \"alejandro\\.rizzuto\", \"state\": \"active\", \"avatar_url\": \"(?P<url_1>https?:\\/\\/\\S+) \"web_url\": \"(?P<url_2>https?:\\/\\/\\S+) \"author_username\": \"alejandro\\.rizzuto\"\\}[\\s\\r\\n\\t]*$"}, "event_count": 1, "sample_rate": 0.2}]}, "data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "sourcetype_builder": {"gitlabapi": {"metadata": {"event_count": 0, "data_input_name": "gitlabapi", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1628870648_17", "progress": 0.32142857142857145}}