[google_workspace_for_splunk]
base_index = <value>
* This is the base index for the searches of the app.

smtp_credentials = <value>
* This is a comma separated list of <uuid>;<name>[,<uuid>;<name>] that is used in the UI for SMTP Credential choosing, with matching values in passwords.

[ga_cmd_natural_language]
authentication_guid = <value>
* This is the Credential GUID to use with the natural language API.