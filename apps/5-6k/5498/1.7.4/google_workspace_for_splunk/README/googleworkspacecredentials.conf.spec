[<credential_stanza>]
*This is how the Google Workspaces Credential is configured

domain = <value>
* The Google Workspaces Domain for the service account

guid = <value>
* A unique guid for the credential

comment = <value>
* A Comment

impersonation_user = <value>
* The user to impersonate with access to the APIs.

proxy_guid = <value>
* The proxy to use with this credential.