[proxy]
proxy_enabled = <bool> Should the proxy enabled or not
proxy_type = <string> type of the proxy i.e. http, https, sock4 or sock5
proxy_url = <string> Proxy url
proxy_port = <int> Proxy port
proxy_username = <string> Username for the proxy server 
proxy_password = <password> Password for the proxy server user 

[logging]
loglevel = <string> Log level of the data collection logs

[powerflex_additional_parameters]
ssl_verification = <bool> Enable/Disable ssl verification for all the API endpoint requests
http_scheme = <string> This scheme will be used while calling the API endpoint