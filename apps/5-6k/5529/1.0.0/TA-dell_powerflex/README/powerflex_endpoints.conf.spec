[<stanza>]
input_prefix = <string> This will be used as prefix while creating input
instance_endpoint = <string> This will be used as endpoint URL for instance data
statistic_endpoint = <string> This will be used as endpoint URL for statistics data
index = <string> Index name that you want to assign to collected data
sourcetype = <string> Sourcetype name that you want to assign to collected data
input_type = <string> Modular input type
method = <string> Method name that you want to use for API
interval = <integer> Interval for input