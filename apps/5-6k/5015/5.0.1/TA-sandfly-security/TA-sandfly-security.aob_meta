{"basic_builder": {"appname": "TA-sandfly-security", "friendly_name": "Sandfly Security Add-on for Splunk", "version": "5.0.1", "author": "Sandfly Security", "description": "This is a technology add-on that ingests various types of data from a Sandfly Security server using the Sandfly Security REST API.", "theme": "#c3c4c9", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 51}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "sandfly:ssh:keys", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "sandfly_ssh_keys", "title": "Sandfly SSH Hunter", "description": "", "type": "customized", "parameters": [{"name": "sandfly_server_url", "label": "Sandfly Server URL", "help_string": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4).", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4", "type": "text", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "enable_ssl_verification", "label": "Enable SSL Verification", "help_string": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "sandfly_server_url", "title": "Sandfly Server URL", "description": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4).", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "enable_ssl_verification", "title": "Enable SSL Verification", "description": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nfrom datetime import datetime\nfrom datetime import timezone\nfrom datetime import timedelta\nimport collections\nimport re\nfrom solnlib import server_info\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ng_b_verify_ssl = None   # default to None until set by get_verify_ssl function\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # sandfly_server_url = definition.parameters.get('sandfly_server_url', None)\n    # global_account = definition.parameters.get('global_account', None)\n    pass\n\n\ndef get_verify_ssl(helper):\n    global g_b_verify_ssl\n\n    # if the global flag is already set, just return now\n    if g_b_verify_ssl is not None:\n        helper.log_debug(\"get_verify_ssl: global g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    # Force Verify SSL to True by default\n    g_b_verify_ssl = True\n\n    t_server_info = server_info.ServerInfo(helper.context_meta['session_key'])\n    # t_server_data = t_server_info.to_dict()\n    # helper.log_debug(\"get_verify_ssl: server_data\")\n    # helper.log_debug(json.dumps(t_server_data, default=str, indent=4))\n    b_is_cloud = t_server_info.is_cloud_instance()\n    helper.log_debug(\"get_verify_ssl: is_cloud_instance [{}]\".format(b_is_cloud))\n\n    if b_is_cloud is True:\n        helper.log_debug(\"get_verify_ssl: Splunk Cloud return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    b_verify_ssl = helper.get_arg('enable_ssl_verification')\n    if b_verify_ssl is not None:\n        g_b_verify_ssl = b_verify_ssl\n        helper.log_debug(\"get_verify_ssl: enable_ssl_verification flag [{}]\".format(b_verify_ssl))\n\n    helper.log_debug(\"get_verify_ssl: Splunk Enterprise return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n    return g_b_verify_ssl\n\n\ndef validate_secure_url(helper, url):\n    if get_verify_ssl(helper) is False:\n        helper.log_error(\"SANDFLY_WARNING(validate_secure_url): SSL certificate verification is disaled, NOT RECOMMENDED\")\n\n    # pattern = \"^https:\\/\\/[0-9A-z.]+.[0-9A-z.]+.[a-z]+$\"\n    pattern = \"^https:\\/\\/(.*)$\"\n\n    result = re.match(pattern, url)\n    if result is not None:\n        helper.log_debug(\"VALID SECURE URL: [{}]\".format(url))\n        return True\n\n    helper.log_error(\"SANDFLY_ERROR(validate_secure_url): insecure URL [{}]\".format(url))\n    return False\n\n\ndef get_zone_details( helper, ew, base_url, access_token, zone_id ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/zones/{}'.format( zone_id )\n    helper.log_debug('get_zone_details: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_zone_details): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n\n    return json_data\n\n\ndef get_host_details( helper, ew, base_url, access_token, host_id ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/hosts/{}'.format( host_id )\n    helper.log_debug('get_host_details: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_host_details): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n\n    return json_data\n\n\ndef get_user_details( helper, ew, base_url, access_token, user_id ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/users/{}'.format( user_id )\n    helper.log_debug('get_user_details: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_user_details): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n\n    return json_data\n\n\ndef get_key_details( helper, ew, base_url, access_token, key_id ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/key/{}'.format( key_id )\n    helper.log_debug('get_key_details: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_key_details): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n\n    return json_data\n\n\ndef get_ssh_zones( helper, ew, base_url, access_token, ssh_zone_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/zones'\n    helper.log_debug('get_ssh_zones: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_ssh_zones): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, ssh_zone_list\n\n    json_data = r.json()\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return None, ssh_zone_list\n\n    for d in hits_list:\n        zone_id = d['id']\n        zone_json = get_zone_details( helper, ew, base_url, access_token, zone_id )\n        ssh_zone_list.append( zone_json )\n\n    return ssh_zone_list\n\n\ndef get_ssh_host_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_host_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/hosts?size={}&page={}'.format( page_size, page_index )\n    helper.log_debug('get_ssh_host_summary: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_ssh_host_summary): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, ssh_keys_list\n\n    json_data = r.json()\n\n    more_results = json_data['more_results']\n\n    hits_list = json_data['data']['hosts']\n\n    if len(hits_list) == 0:\n        return None, ssh_host_list\n\n    for d in hits_list:\n        host_id = d['host_id']\n        host_json = get_host_details( helper, ew, base_url, access_token, host_id )\n        ssh_host_list.append( host_json )\n\n    return more_results, ssh_host_list\n\n\ndef get_ssh_user_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_user_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/users?size={}&page={}'.format( page_size, page_index )\n    helper.log_debug('get_ssh_user_summary: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_ssh_user_summary): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, ssh_keys_list\n\n    json_data = r.json()\n\n    more_results = json_data['more_results']\n\n    hits_list = json_data['data']['users']\n\n    if len(hits_list) == 0:\n        return None, ssh_user_list\n\n    for d in hits_list:\n        user_id = d['username']\n        user_json = get_user_details( helper, ew, base_url, access_token, user_id )\n        ssh_user_list.append( user_json )\n\n    return more_results, ssh_user_list\n\n\ndef get_ssh_keys_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_keys_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/sshhunter/summary?size={}&page={}'.format( page_size, page_index )\n    helper.log_debug('get_ssh_keys_summary: {}'.format(url_to_query))\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_ssh_keys_summary): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, ssh_keys_list\n\n    json_data = r.json()\n\n    more_results = json_data['more_results']\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return None, ssh_keys_list\n\n    for d in hits_list:\n        key_id = d['hash']['sha512']\n        if 'id' in d:\n            key_id = d['id']\n            helper.log_debug('get_ssh_keys_summary: using id as key_id {}'.format(key_id))\n        else:\n            helper.log_debug('get_ssh_keys_summary: using sha-512 hash as key_id {}'.format(key_id))\n        key_json = get_key_details( helper, ew, base_url, access_token, key_id )\n        ssh_keys_list.append( key_json )\n\n    return more_results, ssh_keys_list\n\n\ndef do_process_ssh_zone_list( helper, ew, ssh_zone_list ):\n    count = 0\n    t_now = datetime.now(timezone.utc)\n\n    if len(ssh_zone_list) > 0:\n        for d in ssh_zone_list:\n            t = {}\n            t['timestamp'] = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            t['event_type'] = 'ssh_zone_details'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            t['ssh_zone_details'] = d\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_ssh_zone_list: count [{}]'.format(count))\n\n    return count\n\n\ndef do_process_ssh_host_list( helper, ew, ssh_host_list ):\n    count = 0\n    t_now = datetime.now(timezone.utc)\n\n    if len(ssh_host_list) > 0:\n        for d in ssh_host_list:\n            t = {}\n            t['timestamp'] = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            t['event_type'] = 'ssh_host_details'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            t['ssh_host_details'] = d['data']\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_ssh_host_list: count [{}]'.format(count))\n\n    return count\n\n\ndef do_process_ssh_user_list( helper, ew, ssh_user_list ):\n    count = 0\n    t_now = datetime.now(timezone.utc)\n\n    if len(ssh_user_list) > 0:\n        for d in ssh_user_list:\n            t = {}\n            t['timestamp'] = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            t['event_type'] = 'ssh_user_details'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            t['ssh_user_details'] = d['data']\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_ssh_user_list: count [{}]'.format(count))\n\n    return count\n\n\ndef do_process_ssh_keys_list( helper, ew, ssh_keys_list ):\n    count = 0\n    t_now = datetime.now(timezone.utc)\n\n    if len(ssh_keys_list) > 0:\n        for d in ssh_keys_list:\n            t = {}\n            t['timestamp'] = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            t['event_type'] = 'ssh_key_details'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            #if 'friendly_name' in d:\n            #    t['ssh_key_friendly_name'] = d['friendly_name']\n            #if 'key_type' in d:\n            #    t['ssh_key_type'] = d['key_type']\n            #if 'hash' in d:\n            #    if 'sha512' in d['hash']:\n            #        t['ssh_key_sha512'] = d['hash']['sha512']\n            t['ssh_key_details'] = d\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_ssh_keys_list: count [{}]'.format(count))\n\n    return count\n\n\ndef validate_license( helper, ew, base_url, access_token ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/license'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(validate_license): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return False\n\n    json_data = r.json()\n    # helper.log_debug('validate_license: license info [{}]'.format(json.dumps(json_data, indent=4, default=str, sort_keys=False)))\n\n    t_customer = json_data['customer']\n    helper.log_info('validate_license: customer name [{}]'.format( t_customer['name'] ))\n\n    t_date = json_data['date']\n    t_expiry = datetime.strptime( t_date['expiry'], \"%Y-%m-%dT%H:%M:%SZ\" ).replace(tzinfo=timezone.utc)\n    helper.log_debug('validate_license: expiry date [{}]'.format( t_expiry ))\n    t_now = datetime.now(timezone.utc)\n    helper.log_debug('validate_license: todays date [{}]'.format( t_now ))\n    \n    if t_expiry < t_now:\n        helper.log_error('SANDFLY_ERROR(validate_license): expiry date [{}] EXPIRED'.format( t_date['expiry'] ))\n        return False\n\n    helper.log_info('validate_license: expiry date [{}] VALID'.format( t_date['expiry'] ))\n\n    t_limits = json_data['limits']\n    features_list = t_limits['features']\n\n    if len(features_list) == 0:\n        helper.log_error( 'SANDFLY_ERROR(validate_license): unable to find features in license' )\n        return False\n\n    for f in features_list:\n        if f == 'splunk_connector':\n            helper.log_info('validate_license: feature [{}] VALID'.format( f ))\n            return True\n\n    helper.log_info('validate_license: feature [splunk_connector] NOT FOUND')\n    helper.log_debug('validate_license: features_list [{}]'.format(json.dumps(features_list, indent=4, default=str, sort_keys=False)))\n\n    return False\n\n\ndef sandfly_login( helper, base_url, username, password ):\n    url_to_query = base_url + '/auth/login'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    payload = { \"username\": username, \"password\": password }\n    \n    helper.log_debug('sandfly_login URL [{}]'.format(url_to_query))\n    helper.log_debug('sandfly_login Headers [{}]'.format(headers))\n    helper.log_debug('sandfly_login Username [{}]'.format(username))\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_login): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n    refresh_token = json_data['refresh_token']\n\n    return access_token, refresh_token\n\n\ndef sandfly_refresh( helper, base_url, refresh_token ):\n    url_to_query = base_url + '/auth/login_refresh'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    headers['Authorization'] = 'Bearer ' + refresh_token\n    payload = { \"refresh_token\": refresh_token }\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_refresh): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n\n    return access_token\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg( 'global_account' )\n    base_url = helper.get_arg( 'sandfly_server_url' )\n    \n    my_app_name = helper.get_app_name()\n    my_stanza_name = helper.get_input_stanza_names()\n    my_input_type = helper.get_input_type()\n    helper.log_debug('collect_events [{}] STARTMEUP - [{}] - [{}]'.format(my_input_type, my_app_name, my_stanza_name))\n\n    if validate_secure_url(helper, base_url) is False:\n        helper.log_error(\"collect_events insecure url\")\n        return\n\n    # login and validate license\n    #\n\n    try:\n        access_token, refresh_token = sandfly_login( helper, base_url, global_account['username'], global_account['password'] )\n        if access_token is None:\n            helper.log_error(\"collect_events failed login\")\n            return\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n        return\n\n    b_valid_license = validate_license( helper, ew, base_url, access_token )\n    if b_valid_license is False:\n        helper.log_error(\"collect_events invalid license\")\n        return\n\n    stanza_checkpoint_timestamp = 'sandfly_ssh_keys_{}_timestamp'.format(my_stanza_name)\n\n    # ssh keys\n    #\n\n    page_size = 5\n    page_index = 1\n    more_results = False\n\n    ssh_keys_list = []\n\n    more_results, ssh_keys_list = get_ssh_keys_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_keys_list )\n\n    while more_results is True:\n        page_index += 1\n        more_results, ssh_keys_list = get_ssh_keys_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_keys_list )\n\n    if ssh_keys_list is not None:\n        do_process_ssh_keys_list( helper, ew, ssh_keys_list )\n\n    helper.log_debug('get_ssh_keys_summary success')\n\n    # ssh user\n    #\n\n    page_size = 5\n    page_index = 1\n    more_results = False\n\n    ssh_user_list = []\n\n    more_results, ssh_user_list = get_ssh_user_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_user_list )\n\n    while more_results is True:\n        page_index += 1\n        more_results, ssh_user_list = get_ssh_user_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_user_list )\n\n    if ssh_user_list is not None:\n        do_process_ssh_user_list( helper, ew, ssh_user_list )\n\n    helper.log_debug('get_ssh_user_summary success')\n\n    # ssh host\n    #\n\n    page_size = 5\n    page_index = 1\n    more_results = False\n\n    ssh_host_list = []\n\n    more_results, ssh_host_list = get_ssh_host_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_host_list )\n\n    while more_results is True:\n        page_index += 1\n        more_results, ssh_host_list = get_ssh_host_summary( helper, ew, base_url, access_token, page_size, page_index, ssh_host_list )\n\n    if ssh_host_list is not None:\n        do_process_ssh_host_list( helper, ew, ssh_host_list )\n\n    helper.log_debug('get_ssh_host_summary success')\n\n    # ssh zones\n    #\n\n    ssh_zone_list = []\n\n    ssh_zone_list = get_ssh_zones( helper, ew, base_url, access_token, ssh_zone_list )\n\n    if ssh_zone_list is not None:\n        do_process_ssh_zone_list( helper, ew, ssh_zone_list )\n\n    helper.log_debug('get_ssh_zones success')\n\n    # save checkpoint\n    #\n\n    t_now = datetime.now(timezone.utc)\n    t_now_timestamp = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n    helper.save_check_point( stanza_checkpoint_timestamp, t_now_timestamp )\n\n    helper.log_debug('collect_events [{}] success THE_END [{}] ===================='.format(my_input_type, my_stanza_name))\n\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url')\n    opt_global_account = helper.get_arg('global_account')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url', stanza_name)\n    opt_global_account = helper.get_arg('global_account', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "sandfly_server_url", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "value": "account0"}, {"name": "enable_ssl_verification", "value": true}], "uuid": "ec3bda55e2f14b1ba373736b1c03f790", "sample_count": 0}, {"index": "default", "sourcetype": "sandfly:hosts", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "sandfly_hosts", "title": "Hosts and Assets", "description": "", "type": "customized", "parameters": [{"name": "sandfly_server_url", "label": "Sandfly Server URL", "help_string": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4", "type": "text", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "enable_ssl_verification", "label": "Enable SSL Verification", "help_string": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "create_csv_lookup_files", "label": "Create CSV Lookup Files", "help_string": "Enable to automatically create sandfly_hosts.csv and sandfly_assets.csv in the TA lookups directory. May not work properly on Search Head cluster environments", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "sandfly_server_url", "title": "Sandfly Server URL", "description": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "enable_ssl_verification", "title": "Enable SSL Verification", "description": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "create_csv_lookup_files", "title": "Create CSV Lookup Files", "description": "Enable to automatically create sandfly_hosts.csv and sandfly_assets.csv in the TA lookups directory. May not work properly on Search Head cluster environments", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nfrom datetime import datetime\nfrom datetime import timezone\nfrom datetime import timedelta\nimport collections\nimport csv\nimport re\nfrom solnlib import server_info\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ng_b_verify_ssl = None   # default to None until set by get_verify_ssl function\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # sandfly_server_url = definition.parameters.get('sandfly_server_url', None)\n    # global_account = definition.parameters.get('global_account', None)\n    # create_csv_lookup_files = definition.parameters.get('create_csv_lookup_files', None)\n    pass\n\n\ndef get_verify_ssl(helper):\n    global g_b_verify_ssl\n\n    # if the global flag is already set, just return now\n    if g_b_verify_ssl is not None:\n        helper.log_debug(\"get_verify_ssl: global g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    # Force Verify SSL to True by default\n    g_b_verify_ssl = True\n\n    t_server_info = server_info.ServerInfo(helper.context_meta['session_key'])\n    # t_server_data = t_server_info.to_dict()\n    # helper.log_debug(\"get_verify_ssl: server_data\")\n    # helper.log_debug(json.dumps(t_server_data, default=str, indent=4))\n    b_is_cloud = t_server_info.is_cloud_instance()\n    helper.log_debug(\"get_verify_ssl: is_cloud_instance [{}]\".format(b_is_cloud))\n\n    if b_is_cloud is True:\n        helper.log_debug(\"get_verify_ssl: Splunk Cloud return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    b_verify_ssl = helper.get_arg('enable_ssl_verification')\n    if b_verify_ssl is not None:\n        g_b_verify_ssl = b_verify_ssl\n        helper.log_debug(\"get_verify_ssl: enable_ssl_verification flag [{}]\".format(b_verify_ssl))\n\n    helper.log_debug(\"get_verify_ssl: Splunk Enterprise return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n    return g_b_verify_ssl\n\n\ndef validate_secure_url(helper, url):\n    if get_verify_ssl(helper) is False:\n        helper.log_error(\"SANDFLY_WARNING(validate_secure_url): SSL certificate verification is disaled, NOT RECOMMENDED\")\n\n    # pattern = \"^https:\\/\\/[0-9A-z.]+.[0-9A-z.]+.[a-z]+$\"\n    pattern = \"^https:\\/\\/(.*)$\"\n\n    result = re.match(pattern, url)\n    if result is not None:\n        helper.log_debug(\"VALID SECURE URL: [{}]\".format(url))\n        return True\n\n    helper.log_error(\"SANDFLY_ERROR(validate_secure_url): insecure URL [{}]\".format(url))\n    return False\n\n\ndef create_lookup( helper, ew, items_list, lookup_name ):\n    my_path = os.path.abspath( os.path.dirname( __file__ ) )\n    lookup_path = os.path.abspath( os.path.join( my_path, \"..\", \"lookups\") )\n\n    if not os.path.exists( lookup_path ):\n        try:\n            os.mkdir( lookup_path )\n            helper.log_debug( 'Created Lookup Path: {}'.format( lookup_path ) )\n        except Exception as e:\n            helper.log_error( 'SANDFLY_ERROR(create_lookup): {}'.format( str( e ) ) )\n            return\n\n    lookup_file = lookup_path + '/' + lookup_name\n\n    csv_file = open( lookup_file, 'wt' )\n    csv_writer = csv.DictWriter( csv_file, fieldnames=items_list[0].keys(), extrasaction='ignore' )\n    csv_writer.writeheader()\n\n    for row in items_list:\n        csv_writer.writerow( row )\n\n    csv_file.close()\n\n    helper.log_debug( 'Created Lookup File: count [{}] {}'.format( len(items_list), lookup_file ) )\n\n    return\n\n\ndef get_devices( helper, ew, base_url, access_token, scroll_id, devices_list, b_summary_mode ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    if scroll_id is not None:\n        url_to_query = base_url + '/scroll'\n        payload = { \"scroll_id\": scroll_id }\n        r = helper.send_http_request(\n            url=url_to_query,\n            method='POST',\n            headers=headers,\n            payload=json.dumps( payload ),\n            use_proxy=use_proxy,\n            verify=verify_ssl\n            )\n    else:\n        url_to_query = base_url + '/hosts'\n        if b_summary_mode is True:\n            url_to_query = base_url + '/hosts?summary=true'\n        r = helper.send_http_request(\n            url=url_to_query,\n            method='GET',\n            headers=headers,\n            use_proxy=use_proxy,\n            verify=verify_ssl\n            )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_devices): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, devices_list\n\n    json_data = r.json()\n\n    scroll_id = json_data['scroll_id']\n    total_count = json_data['total']\n    \n    helper.log_info( 'Devices Total: [{}]'.format( total_count ) )\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return None, devices_list\n\n    for d in hits_list:\n        devices_list.append( d )\n\n    return scroll_id, devices_list\n\n\ndef convert_to_asset_lookup( helper, ew, item ):\n    asset = collections.OrderedDict()\n\n    asset['ip'] = item['last_seen_ip_addr']\n    asset['mac'] = ''\n    asset['nt_host'] = ''\n    asset['dns'] = ''\n    asset['owner'] = ''\n    asset['priority'] = 'unknown'\n    asset['lat'] = ''\n    asset['long'] = ''\n    asset['city'] = ''\n    asset['country'] = ''\n    asset['bunit'] = ''\n    asset['category'] = ''\n    if len(item['tags']) > 0:\n        for t in item['tags']:\n            if len(asset['category']) > 0:\n                asset['category'] += '|'\n            asset['category'] += t\n    asset['pci_domain'] = 'untrust'\n    asset['is_expected'] = ''\n    if item['active'] is True:\n        asset['is_expected'] = 'true'\n    asset['should_timesync'] = ''\n    asset['should_update'] = ''\n    asset['requires_av'] = ''\n    asset['cim_entity_zone'] = ''\n\n    return asset\n\n\ndef do_process_devices( helper, ew, devices_list, b_summary_mode ):\n    count = 0\n    asset_list = []\n    t_now = datetime.now(timezone.utc)\n\n    if len(devices_list) > 0:\n        for d in devices_list:\n            asset = convert_to_asset_lookup( helper, ew, d )\n            if asset is not None:\n                asset_list.append( asset )\n            t = {}\n            t['timestamp'] = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            if b_summary_mode is True:\n                t['event_type'] = 'host_summary'\n                t['sandfly_input'] = helper.get_input_stanza_names()\n                t['host_summary'] = d\n            else:\n                t['event_type'] = 'host_details'\n                t['sandfly_input'] = helper.get_input_stanza_names()\n                t['host_details'] = d\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_devices: count            [{}]'.format(count))\n\n    return count, asset_list\n\n\ndef validate_license( helper, ew, base_url, access_token ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/license'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(validate_license): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return False\n\n    json_data = r.json()\n    # helper.log_debug('validate_license: license info [{}]'.format(json.dumps(json_data, indent=4, default=str, sort_keys=False)))\n\n    t_customer = json_data['customer']\n    helper.log_info('validate_license: customer name [{}]'.format( t_customer['name'] ))\n\n    t_date = json_data['date']\n    t_expiry = datetime.strptime( t_date['expiry'], \"%Y-%m-%dT%H:%M:%SZ\" ).replace(tzinfo=timezone.utc)\n    helper.log_debug('validate_license: expiry date [{}]'.format( t_expiry ))\n    t_now = datetime.now(timezone.utc)\n    helper.log_debug('validate_license: todays date [{}]'.format( t_now ))\n    \n    if t_expiry < t_now:\n        helper.log_error('SANDFLY_ERROR(validate_license): expiry date [{}] EXPIRED'.format( t_date['expiry'] ))\n        return False\n\n    helper.log_info('validate_license: expiry date [{}] VALID'.format( t_date['expiry'] ))\n\n    t_limits = json_data['limits']\n    features_list = t_limits['features']\n\n    if len(features_list) == 0:\n        helper.log_error( 'SANDFLY_ERROR(validate_license): unable to find features in license' )\n        return False\n\n    for f in features_list:\n        if f == 'splunk_connector':\n            helper.log_info('validate_license: feature [{}] VALID'.format( f ))\n            return True\n\n    helper.log_info('validate_license: feature [splunk_connector] NOT FOUND')\n    helper.log_debug('validate_license: features_list [{}]'.format(json.dumps(features_list, indent=4, default=str, sort_keys=False)))\n\n    return False\n\n\ndef sandfly_login( helper, base_url, username, password ):\n    url_to_query = base_url + '/auth/login'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    payload = { \"username\": username, \"password\": password }\n    \n    helper.log_debug('sandfly_login URL [{}]'.format(url_to_query))\n    helper.log_debug('sandfly_login Headers [{}]'.format(headers))\n    helper.log_debug('sandfly_login Username [{}]'.format(username))\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_login): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n    refresh_token = json_data['refresh_token']\n\n    return access_token, refresh_token\n\n\ndef sandfly_refresh( helper, base_url, refresh_token ):\n    url_to_query = base_url + '/auth/login_refresh'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    headers['Authorization'] = 'Bearer ' + refresh_token\n    payload = { \"refresh_token\": refresh_token }\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_refresh): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n\n    return access_token\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg( 'global_account' )\n    base_url = helper.get_arg( 'sandfly_server_url' )\n    b_create_lookups = helper.get_arg( 'create_csv_lookup_files' )\n    \n    my_app_name = helper.get_app_name()\n    my_stanza_name = helper.get_input_stanza_names()\n    my_input_type = helper.get_input_type()\n    helper.log_debug('collect_events [{}] STARTMEUP - [{}] - [{}]'.format(my_input_type, my_app_name, my_stanza_name))\n\n    if validate_secure_url(helper, base_url) is False:\n        helper.log_error(\"collect_events insecure url\")\n        return\n\n    try:\n        access_token, refresh_token = sandfly_login( helper, base_url, global_account['username'], global_account['password'] )\n        if access_token is None:\n            helper.log_error(\"collect_events failed login\")\n            return\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n        return\n\n    b_valid_license = validate_license( helper, ew, base_url, access_token )\n    if b_valid_license is False:\n        helper.log_error(\"collect_events invalid license\")\n        return\n\n    scroll_id = None\n\n    devices_list = []\n\n    b_summary_mode = True\n    \n    scroll_id, devices_list = get_devices( helper, ew, base_url, access_token, scroll_id, devices_list, b_summary_mode )\n\n    while scroll_id is not None:\n        scroll_id, devices_list = get_devices( helper, ew, base_url, access_token, scroll_id, devices_list, b_summary_mode )\n\n    if devices_list is not None:\n        count, asset_list = do_process_devices( helper, ew, devices_list, b_summary_mode )\n        if b_create_lookups is True:\n            create_lookup( helper, ew, devices_list, 'sandfly_hosts.csv' )\n            create_lookup( helper, ew, asset_list, 'sandfly_assets.csv' )\n\n    helper.log_debug('get_devices success - summary mode [{}]'.format(b_summary_mode))\n    \n    scroll_id = None\n\n    devices_list = []\n\n    b_summary_mode = False\n    \n    scroll_id, devices_list = get_devices( helper, ew, base_url, access_token, scroll_id, devices_list, b_summary_mode )\n\n    while scroll_id is not None:\n        scroll_id, devices_list = get_devices( helper, ew, base_url, access_token, scroll_id, devices_list, b_summary_mode )\n\n    if devices_list is not None:\n        count, asset_list = do_process_devices( helper, ew, devices_list, b_summary_mode )\n        # do not create lookup files with full device objects\n\n    helper.log_debug('get_devices success - summary mode [{}]'.format(b_summary_mode))\n\n    stanza_checkpoint_timestamp = 'sandfly_devices_{}_timestamp'.format(my_stanza_name)\n\n    t_now = datetime.now(timezone.utc)\n    t_now_timestamp = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n    helper.save_check_point( stanza_checkpoint_timestamp, t_now_timestamp )\n\n    helper.log_debug('collect_events [{}] success THE_END [{}] ===================='.format(my_input_type, my_stanza_name))\n\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url')\n    opt_global_account = helper.get_arg('global_account')\n    opt_create_csv_lookup_files = helper.get_arg('create_csv_lookup_files')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url', stanza_name)\n    opt_global_account = helper.get_arg('global_account', stanza_name)\n    opt_create_csv_lookup_files = helper.get_arg('create_csv_lookup_files', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "sandfly_server_url", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "value": "account0"}, {"name": "enable_ssl_verification", "value": true}, {"name": "create_csv_lookup_files", "value": true}], "uuid": "e19acc11ce8247d5af67379215010c40", "sample_count": 0}, {"index": "default", "sourcetype": "sandfly:sandflies", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "sandfly_sandflies", "title": "Sandflies", "description": "", "type": "customized", "parameters": [{"name": "sandfly_server_url", "label": "Sandfly Server URL", "help_string": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4).", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4", "type": "text", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "enable_ssl_verification", "label": "Enable SSL Verification", "help_string": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "sandfly_server_url", "title": "Sandfly Server URL", "description": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4).", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "enable_ssl_verification", "title": "Enable SSL Verification", "description": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nfrom datetime import datetime\nfrom datetime import timezone\nfrom datetime import timedelta\nimport collections\nimport re\nfrom solnlib import server_info\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ng_b_verify_ssl = None   # default to None until set by get_verify_ssl function\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # sandfly_server_url = definition.parameters.get('sandfly_server_url', None)\n    # global_account = definition.parameters.get('global_account', None)\n    pass\n\n\ndef get_verify_ssl(helper):\n    global g_b_verify_ssl\n\n    # if the global flag is already set, just return now\n    if g_b_verify_ssl is not None:\n        helper.log_debug(\"get_verify_ssl: global g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    # Force Verify SSL to True by default\n    g_b_verify_ssl = True\n\n    t_server_info = server_info.ServerInfo(helper.context_meta['session_key'])\n    # t_server_data = t_server_info.to_dict()\n    # helper.log_debug(\"get_verify_ssl: server_data\")\n    # helper.log_debug(json.dumps(t_server_data, default=str, indent=4))\n    b_is_cloud = t_server_info.is_cloud_instance()\n    helper.log_debug(\"get_verify_ssl: is_cloud_instance [{}]\".format(b_is_cloud))\n\n    if b_is_cloud is True:\n        helper.log_debug(\"get_verify_ssl: Splunk Cloud return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    b_verify_ssl = helper.get_arg('enable_ssl_verification')\n    if b_verify_ssl is not None:\n        g_b_verify_ssl = b_verify_ssl\n        helper.log_debug(\"get_verify_ssl: enable_ssl_verification flag [{}]\".format(b_verify_ssl))\n\n    helper.log_debug(\"get_verify_ssl: Splunk Enterprise return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n    return g_b_verify_ssl\n\n\ndef validate_secure_url(helper, url):\n    if get_verify_ssl(helper) is False:\n        helper.log_error(\"SANDFLY_WARNING(validate_secure_url): SSL certificate verification is disaled, NOT RECOMMENDED\")\n\n    # pattern = \"^https:\\/\\/[0-9A-z.]+.[0-9A-z.]+.[a-z]+$\"\n    pattern = \"^https:\\/\\/(.*)$\"\n\n    result = re.match(pattern, url)\n    if result is not None:\n        helper.log_debug(\"VALID SECURE URL: [{}]\".format(url))\n        return True\n\n    helper.log_error(\"SANDFLY_ERROR(validate_secure_url): insecure URL [{}]\".format(url))\n    return False\n\n\ndef get_whitelist_rules( helper, ew, base_url, access_token, white_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/whitelistrules'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_whitelistrule): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, sandfly_list\n\n    json_data = r.json()\n\n    total_count = json_data['total']\n\n    helper.log_info( 'Whitelist Rules Total: [{}]'.format( total_count ) )\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return white_list\n\n    for d in hits_list:\n        white_list.append( d )\n\n    return white_list\n\n\ndef get_sandflies( helper, ew, base_url, access_token, scroll_id, sandfly_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    if scroll_id is not None:\n        url_to_query = base_url + '/scroll'\n        payload = { \"scroll_id\": scroll_id }\n        r = helper.send_http_request(\n            url=url_to_query,\n            method='POST',\n            headers=headers,\n            payload=json.dumps( payload ),\n            use_proxy=use_proxy,\n            verify=verify_ssl\n            )\n    else:\n        url_to_query = base_url + '/sandflies'\n        r = helper.send_http_request(\n            url=url_to_query,\n            method='GET',\n            headers=headers,\n            use_proxy=use_proxy,\n            verify=verify_ssl\n            )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_sandflies): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, sandfly_list\n\n    json_data = r.json()\n\n    scroll_id = json_data['scroll_id']\n    total_count = json_data['total']\n\n    helper.log_info( 'Sandflies Total: [{}]'.format( total_count ) )\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return None, sandfly_list\n\n    for d in hits_list:\n        sandfly_list.append( d )\n\n    return scroll_id, sandfly_list\n\n\ndef do_process_whitelist_rules( helper, ew, white_list ):\n    count = 0\n    t_now = datetime.now(timezone.utc)\n\n    if len(white_list) > 0:\n        for d in white_list:\n            t = {}\n            t['timestamp'] = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            t['event_type'] = 'sandfly_whitelist_rules'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            t['whitelist_rule'] = d\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=\"sandfly:whitelist\", data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_white_list: count            [{}]'.format(count))\n\n    return count\n\n\ndef do_process_sandflies( helper, ew, sandfly_list ):\n    count = 0\n    t_now = datetime.now(timezone.utc)\n\n    if len(sandfly_list) > 0:\n        for d in sandfly_list:\n            t = {}\n            t['timestamp'] = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            t['event_type'] = 'sandfly_sandflies'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            t['sandfly_info'] = d\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_sandflies: count            [{}]'.format(count))\n\n    return count\n\n\ndef validate_license( helper, ew, base_url, access_token ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/license'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(validate_license): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return False\n\n    json_data = r.json()\n    # helper.log_debug('validate_license: license info [{}]'.format(json.dumps(json_data, indent=4, default=str, sort_keys=False)))\n\n    t_customer = json_data['customer']\n    helper.log_info('validate_license: customer name [{}]'.format( t_customer['name'] ))\n\n    t_date = json_data['date']\n    t_expiry = datetime.strptime( t_date['expiry'], \"%Y-%m-%dT%H:%M:%SZ\" ).replace(tzinfo=timezone.utc)\n    helper.log_debug('validate_license: expiry date [{}]'.format( t_expiry ))\n    t_now = datetime.now(timezone.utc)\n    helper.log_debug('validate_license: todays date [{}]'.format( t_now ))\n\n    if t_expiry < t_now:\n        helper.log_error('SANDFLY_ERROR(validate_license): expiry date [{}] EXPIRED'.format( t_date['expiry'] ))\n        return False\n\n    helper.log_info('validate_license: expiry date [{}] VALID'.format( t_date['expiry'] ))\n\n    t_limits = json_data['limits']\n    features_list = t_limits['features']\n\n    if len(features_list) == 0:\n        helper.log_error( 'SANDFLY_ERROR(validate_license): unable to find features in license' )\n        return False\n\n    for f in features_list:\n        if f == 'splunk_connector':\n            helper.log_info('validate_license: feature [{}] VALID'.format( f ))\n            return True\n\n    helper.log_info('validate_license: feature [splunk_connector] NOT FOUND')\n    helper.log_debug('validate_license: features_list [{}]'.format(json.dumps(features_list, indent=4, default=str, sort_keys=False)))\n\n    return False\n\n\ndef sandfly_login( helper, base_url, username, password ):\n    url_to_query = base_url + '/auth/login'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    payload = { \"username\": username, \"password\": password }\n\n    helper.log_debug('sandfly_login URL [{}]'.format(url_to_query))\n    helper.log_debug('sandfly_login Headers [{}]'.format(headers))\n    helper.log_debug('sandfly_login Username [{}]'.format(username))\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_login): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n    refresh_token = json_data['refresh_token']\n\n    return access_token, refresh_token\n\n\ndef sandfly_refresh( helper, base_url, refresh_token ):\n    url_to_query = base_url + '/auth/login_refresh'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    headers['Authorization'] = 'Bearer ' + refresh_token\n    payload = { \"refresh_token\": refresh_token }\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_refresh): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n\n    return access_token\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg( 'global_account' )\n    base_url = helper.get_arg( 'sandfly_server_url' )\n\n    my_app_name = helper.get_app_name()\n    my_stanza_name = helper.get_input_stanza_names()\n    my_input_type = helper.get_input_type()\n    helper.log_debug('collect_events [{}] STARTMEUP - [{}] - [{}]'.format(my_input_type, my_app_name, my_stanza_name))\n\n    if validate_secure_url(helper, base_url) is False:\n        helper.log_error(\"collect_events insecure url\")\n        return\n\n    try:\n        access_token, refresh_token = sandfly_login( helper, base_url, global_account['username'], global_account['password'] )\n        if access_token is None:\n            helper.log_error(\"collect_events failed login\")\n            return\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n        return\n\n    b_valid_license = validate_license( helper, ew, base_url, access_token )\n    if b_valid_license is False:\n        helper.log_error(\"collect_events invalid license\")\n        return\n\n    stanza_checkpoint_timestamp = 'sandfly_sandflies_{}_timestamp'.format(my_stanza_name)\n\n    # sandflies\n    #\n\n    scroll_id = None\n\n    sandfly_list = []\n\n    scroll_id, sandfly_list = get_sandflies( helper, ew, base_url, access_token, scroll_id, sandfly_list )\n\n    while scroll_id is not None:\n        scroll_id, sandfly_list = get_sandflies( helper, ew, base_url, access_token, scroll_id, sandfly_list )\n\n    if sandfly_list is not None:\n        do_process_sandflies( helper, ew, sandfly_list )\n\n    helper.log_debug('get_sandflies success')\n\n    # whitelist rules\n    #\n\n    white_list = []\n\n    white_list = get_whitelist_rules( helper, ew, base_url, access_token, white_list )\n\n    if white_list is not None:\n        do_process_whitelist_rules( helper, ew, white_list )\n\n    helper.log_debug('get_whitelist_rules success')\n\n    t_now = datetime.now(timezone.utc)\n    t_now_timestamp = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n    helper.save_check_point( stanza_checkpoint_timestamp, t_now_timestamp )\n\n    helper.log_debug('collect_events [{}] success THE_END [{}] ===================='.format(my_input_type, my_stanza_name))\n\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url')\n    opt_global_account = helper.get_arg('global_account')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url', stanza_name)\n    opt_global_account = helper.get_arg('global_account', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "sandfly_server_url", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "value": "account0"}, {"name": "enable_ssl_verification", "value": true}], "uuid": "f552ebf06f6845faa4f053c597eb64e0", "sample_count": 0}, {"index": "default", "sourcetype": "sandfly:logs:audit", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "sandfly_audit_logs", "title": "Audit Logs", "description": "", "type": "customized", "parameters": [{"name": "sandfly_server_url", "label": "Sandfly Server URL", "help_string": "Enter the Sandfly Server URL including the API version (e.g., https://SERVER.sandflysecurity.com/v4)", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4", "type": "text", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "start_time", "label": "Start Time", "help_string": "The date (UTC in \"YYYY-MM-DDThh:mm:ssZ\" format) from when to start collecting data.  Default is last 24 hours if date is not specified.", "required": false, "format_type": "text", "default_value": "", "placeholder": "optional", "type": "text", "value": "2024-06-01T13:00:00Z"}, {"name": "enable_ssl_verification", "label": "Enable SSL Verification", "help_string": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "sandfly_server_url", "title": "Sandfly Server URL", "description": "Enter the Sandfly Server URL including the API version (e.g., https://SERVER.sandflysecurity.com/v4)", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "start_time", "title": "Start Time", "description": "The date (UTC in \"YYYY-MM-DDThh:mm:ssZ\" format) from when to start collecting data.  Default is last 24 hours if date is not specified.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "optional"}, {"type": "customized_var", "name": "enable_ssl_verification", "title": "Enable SSL Verification", "description": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nfrom datetime import datetime\nfrom datetime import timezone\nfrom datetime import timedelta\nimport collections\nimport csv\nimport re\nfrom solnlib import server_info\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ng_b_verify_ssl = None   # default to None until set by get_verify_ssl function\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # sandfly_server_url = definition.parameters.get('sandfly_server_url', None)\n    # global_account = definition.parameters.get('global_account', None)\n    # enable_ssl_verification = definition.parameters.get('enable_ssl_verification', None)\n    pass\n\n\ndef get_verify_ssl(helper):\n    global g_b_verify_ssl\n\n    # if the global flag is already set, just return now\n    if g_b_verify_ssl is not None:\n        helper.log_debug(\"get_verify_ssl: global g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    # Force Verify SSL to True by default\n    g_b_verify_ssl = True\n\n    t_server_info = server_info.ServerInfo(helper.context_meta['session_key'])\n    # t_server_data = t_server_info.to_dict()\n    # helper.log_debug(\"get_verify_ssl: server_data\")\n    # helper.log_debug(json.dumps(t_server_data, default=str, indent=4))\n    b_is_cloud = t_server_info.is_cloud_instance()\n    helper.log_debug(\"get_verify_ssl: is_cloud_instance [{}]\".format(b_is_cloud))\n\n    if b_is_cloud is True:\n        helper.log_debug(\"get_verify_ssl: Splunk Cloud return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    b_verify_ssl = helper.get_arg('enable_ssl_verification')\n    if b_verify_ssl is not None:\n        g_b_verify_ssl = b_verify_ssl\n        helper.log_debug(\"get_verify_ssl: enable_ssl_verification flag [{}]\".format(b_verify_ssl))\n\n    helper.log_debug(\"get_verify_ssl: Splunk Enterprise return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n    return g_b_verify_ssl\n\n\ndef validate_secure_url(helper, url):\n    if get_verify_ssl(helper) is False:\n        helper.log_error(\"SANDFLY_WARNING(validate_secure_url): SSL certificate verification is disaled, NOT RECOMMENDED\")\n\n    # pattern = \"^https:\\/\\/[0-9A-z.]+.[0-9A-z.]+.[a-z]+$\"\n    pattern = \"^https:\\/\\/(.*)$\"\n\n    result = re.match(pattern, url)\n    if result is not None:\n        helper.log_debug(\"VALID SECURE URL: [{}]\".format(url))\n        return True\n\n    helper.log_error(\"SANDFLY_ERROR(validate_secure_url): insecure URL [{}]\".format(url))\n    return False\n\n\ndef get_audit_logs( helper, ew, base_url, access_token, page_num, start_time_obj, audit_logs_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/audit?page=' + str(page_num)\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_audit_logs): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return False, None, audit_logs_list\n\n    json_data = r.json()\n\n    count = 0\n    last_timestamp_obj = None\n    more_results = json_data['more_results']\n    scroll_id = json_data['scroll_id']\n    total_count = json_data['total']\n\n    helper.log_info( 'Audit Page Number : [{}]'.format( page_num ) )\n    helper.log_info( 'More Results Flag : [{}]'.format( more_results ) )\n    helper.log_info( 'Scroll ID         : [{}]'.format( scroll_id ) )\n    helper.log_info( 'Audit Logs Total  : [{}]'.format( total_count ) )\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return False, None, audit_logs_list\n\n    for d in hits_list:\n        t_time_obj = datetime.strptime(d['timestamp'], \"%Y-%m-%dT%H:%M:%S.%fZ\").replace(tzinfo=timezone.utc)\n        if t_time_obj > start_time_obj:\n            if last_timestamp_obj is None:\n                last_timestamp_obj = t_time_obj\n                helper.log_debug('get_audit_logs: the first last timestamp [{}]'.format(last_timestamp_obj))\n            elif t_time_obj > last_timestamp_obj:\n                last_timestamp_obj = t_time_obj\n                helper.log_debug('get_audit_logs: update the last timestamp [{}]'.format(last_timestamp_obj))\n            audit_logs_list.append( d )\n            count += 1\n\n    helper.log_debug('get_audit_logs: count [{}]'.format(count))\n    helper.log_debug('get_audit_logs: last timestamp [{}]'.format(last_timestamp_obj))\n\n    if count < (total_count - 1):\n        helper.log_debug('get_audit_logs: count [{}] < total_count [{}] set more_results to False'.format(count, total_count-1))\n        more_results = False\n\n    return more_results, last_timestamp_obj, audit_logs_list\n\n\ndef do_process_audit_logs( helper, ew, audit_logs_list ):\n    count = 0\n\n    if len(audit_logs_list) > 0:\n        for d in audit_logs_list:\n            t = {}\n            t['timestamp'] = d['timestamp']\n            del d['timestamp']\n            t['event_type'] = 'sandfly_audit_log'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            t['audit_log'] = d\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_audit_logs: count [{}]'.format(count))\n\n    return count\n\n\ndef validate_license( helper, ew, base_url, access_token ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/license'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(validate_license): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return False\n\n    json_data = r.json()\n    # helper.log_debug('validate_license: license info [{}]'.format(json.dumps(json_data, indent=4, default=str, sort_keys=False)))\n\n    t_customer = json_data['customer']\n    helper.log_info('validate_license: customer name [{}]'.format( t_customer['name'] ))\n\n    t_date = json_data['date']\n    t_expiry = datetime.strptime( t_date['expiry'], \"%Y-%m-%dT%H:%M:%SZ\" ).replace(tzinfo=timezone.utc)\n    helper.log_debug('validate_license: expiry date [{}]'.format( t_expiry ))\n    t_now = datetime.now(timezone.utc)\n    helper.log_debug('validate_license: todays date [{}]'.format( t_now ))\n\n    if t_expiry < t_now:\n        helper.log_error('SANDFLY_ERROR(validate_license): expiry date [{}] EXPIRED'.format( t_date['expiry'] ))\n        return False\n\n    helper.log_info('validate_license: expiry date [{}] VALID'.format( t_date['expiry'] ))\n\n    t_limits = json_data['limits']\n    features_list = t_limits['features']\n\n    if len(features_list) == 0:\n        helper.log_error( 'SANDFLY_ERROR(validate_license): unable to find features in license' )\n        return False\n\n    for f in features_list:\n        if f == 'splunk_connector':\n            helper.log_info('validate_license: feature [{}] VALID'.format( f ))\n            return True\n\n    helper.log_info('validate_license: feature [splunk_connector] NOT FOUND')\n    helper.log_debug('validate_license: features_list [{}]'.format(json.dumps(features_list, indent=4, default=str, sort_keys=False)))\n\n    return False\n\n\ndef sandfly_login( helper, base_url, username, password ):\n    url_to_query = base_url + '/auth/login'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    payload = { \"username\": username, \"password\": password }\n\n    helper.log_debug('sandfly_login URL [{}]'.format(url_to_query))\n    helper.log_debug('sandfly_login Headers [{}]'.format(headers))\n    helper.log_debug('sandfly_login Username [{}]'.format(username))\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_login): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n    refresh_token = json_data['refresh_token']\n\n    return access_token, refresh_token\n\n\ndef sandfly_refresh( helper, base_url, refresh_token ):\n    url_to_query = base_url + '/auth/login_refresh'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    headers['Authorization'] = 'Bearer ' + refresh_token\n    payload = { \"refresh_token\": refresh_token }\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_refresh): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n\n    return access_token\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg( 'global_account' )\n    base_url = helper.get_arg( 'sandfly_server_url' )\n    user_start_time_str = helper.get_arg( 'start_time' )\n    if user_start_time_str is None:\n        user_start_time_str = ''\n#    b_test_mode = helper.get_arg('test_mode')\n#    if b_test_mode is None:\n#        b_test_mode = False\n\n    my_app_name = helper.get_app_name()\n    my_stanza_name = helper.get_input_stanza_names()\n    my_input_type = helper.get_input_type()\n    helper.log_debug('collect_events [{}] STARTMEUP - [{}] - [{}]'.format(my_input_type, my_app_name, my_stanza_name))\n\n    if validate_secure_url(helper, base_url) is False:\n        helper.log_error(\"collect_events insecure url\")\n        return\n\n    try:\n        access_token, refresh_token = sandfly_login( helper, base_url, global_account['username'], global_account['password'] )\n        if access_token is None:\n            helper.log_error(\"collect_events failed login\")\n            return\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n        return\n\n    b_valid_license = validate_license( helper, ew, base_url, access_token )\n    if b_valid_license is False:\n        helper.log_error(\"collect_events invalid license\")\n        return\n\n    user_start_time_obj = None\n    try:\n        if len(user_start_time_str) > 0:\n            user_start_time_obj = datetime.strptime(user_start_time_str, \"%Y-%m-%dT%H:%M:%SZ\").replace(tzinfo=timezone.utc)\n            helper.log_debug('user_start_time_obj: [{}]'.format(user_start_time_obj))\n    except Exception as e:\n        user_start_time_obj = None\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n\n    stanza_checkpoint_timestamp = 'sandfly_audit_logs_{}_timestamp'.format(my_stanza_name)\n    helper.log_debug('checkpoint key: [{}]'.format(stanza_checkpoint_timestamp))\n#    if b_test_mode is True:\n#        helper.delete_check_point( stanza_checkpoint_timestamp )\n#        helper.log_debug('test mode enabled - delete checkpoint key: [{}]'.format(stanza_checkpoint_timestamp))\n\n    start_time_obj = None\n    checkpoint_ts = helper.get_check_point( stanza_checkpoint_timestamp )\n    if checkpoint_ts is None:\n        if user_start_time_obj is None:\n            start_time_obj = datetime.now(timezone.utc) - timedelta(hours=24)\n            helper.log_debug('start_time default to 24 hours ago: [{}]'.format(start_time_obj))\n        else:\n            start_time_obj = user_start_time_obj\n            helper.log_debug('start_time defined by user: [{}]'.format(start_time_obj))\n    else:\n        start_time_obj = datetime.strptime(checkpoint_ts, \"%Y-%m-%dT%H:%M:%S.%fZ\").replace(tzinfo=timezone.utc)\n        helper.log_debug('start_time defined by checkpoint: [{}]'.format(start_time_obj))\n        if user_start_time_obj is not None:\n            if start_time_obj < user_start_time_obj:\n                start_time_obj = user_start_time_obj\n                helper.log_debug('checkpoint time older than user defined start_time: [{}]'.format(start_time_obj))\n\n    helper.log_info('start_time: [{}]'.format(start_time_obj))\n\n    page_num = 1\n    more_results = False\n    last_timestamp_obj = None\n    audit_logs_list = []\n    total_count = 0\n\n    more_results, last_timestamp_obj, audit_logs_list = get_audit_logs( helper, ew, base_url, access_token, page_num, start_time_obj, audit_logs_list )\n    helper.log_debug('page [{}] last timestamp [{}]'.format(page_num, last_timestamp_obj))\n    if audit_logs_list is not None:\n        total_count += do_process_audit_logs( helper, ew, audit_logs_list )\n        helper.log_debug('page [{}] total count [{}]'.format(page_num, total_count))\n        audit_logs_list.clear()\n\n    while more_results is True:\n        page_num += 1\n        more_results, t_last_timestamp_obj, audit_logs_list = get_audit_logs( helper, ew, base_url, access_token, page_num, start_time_obj, audit_logs_list )\n        if last_timestamp_obj is None:\n            last_timestamp_obj = t_last_timestamp_obj\n            helper.log_debug('last timestamp was None use page [{}] last timestamp [{}]'.format(page_num, last_timestamp_obj))\n        elif t_last_timestamp_obj > last_timestamp_obj:\n            last_timestamp_obj = t_last_timestamp_obj\n            helper.log_debug('update page [{}] last timestamp [{}]'.format(page_num, last_timestamp_obj))\n        else:\n            helper.log_debug('old last timestamp [{}]'.format(last_timestamp_obj))\n        if audit_logs_list is not None:\n            total_count += do_process_audit_logs( helper, ew, audit_logs_list )\n            helper.log_debug('page [{}] total count [{}]'.format(page_num, total_count))\n            audit_logs_list.clear()\n\n    helper.log_debug('last timestamp [{}]'.format(last_timestamp_obj))\n    helper.log_debug('total count    [{}]'.format(total_count))\n    helper.log_debug('get_audit_logs success')\n\n    if last_timestamp_obj is not None:\n        last_timestamp_str = last_timestamp_obj.strftime( \"%Y-%m-%dT%H:%M:%S.%fZ\" )\n        helper.log_debug('last timestamp str [{}]'.format(last_timestamp_str))\n        helper.save_check_point( stanza_checkpoint_timestamp, last_timestamp_str )\n\n    helper.log_debug('collect_events [{}] success THE_END [{}] ===================='.format(my_input_type, my_stanza_name))\n\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url')\n    opt_global_account = helper.get_arg('global_account')\n    opt_enable_ssl_verification = helper.get_arg('enable_ssl_verification')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url', stanza_name)\n    opt_global_account = helper.get_arg('global_account', stanza_name)\n    opt_enable_ssl_verification = helper.get_arg('enable_ssl_verification', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "sandfly_server_url", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "value": "account0"}, {"name": "start_time", "value": "2024-06-01T13:00:00Z"}, {"name": "enable_ssl_verification", "value": true}], "uuid": "55016eaa26944f22a538c8b9b2eb32a7", "sample_count": 0}, {"index": "default", "sourcetype": "sandfly:logs:error", "interval": "900", "use_external_validation": true, "streaming_mode_xml": true, "name": "sandfly_error_logs", "title": "Scanning Error Logs", "description": "", "type": "customized", "parameters": [{"name": "sandfly_server_url", "label": "Sandfly Server URL", "help_string": "Enter the Sandfly Server URL including the API version (e.g., https://SERVER.sandflysecurity.com/v4)", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4", "type": "text", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "start_time", "label": "Start Time", "help_string": "The date (UTC in \"YYYY-MM-DDThh:mm:ssZ\" format) from when to start collecting data.  Default is last 24 hours if date is not specified.", "required": false, "format_type": "text", "default_value": "", "placeholder": "optional", "type": "text", "value": "2024-07-15T00:00:00Z"}, {"name": "enable_ssl_verification", "label": "Enable SSL Verification", "help_string": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "sandfly_server_url", "title": "Sandfly Server URL", "description": "Enter the Sandfly Server URL including the API version (e.g., https://SERVER.sandflysecurity.com/v4)", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "start_time", "title": "Start Time", "description": "The date (UTC in \"YYYY-MM-DDThh:mm:ssZ\" format) from when to start collecting data.  Default is last 24 hours if date is not specified.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "optional"}, {"type": "customized_var", "name": "enable_ssl_verification", "title": "Enable SSL Verification", "description": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nfrom datetime import datetime\nfrom datetime import timezone\nfrom datetime import timedelta\nimport collections\nimport csv\nimport re\nfrom solnlib import server_info\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ng_b_verify_ssl = None   # default to None until set by get_verify_ssl function\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # sandfly_server_url = definition.parameters.get('sandfly_server_url', None)\n    # global_account = definition.parameters.get('global_account', None)\n    # start_time = definition.parameters.get('start_time', None)\n    # enable_ssl_verification = definition.parameters.get('enable_ssl_verification', None)\n    pass\n\n\ndef get_verify_ssl(helper):\n    global g_b_verify_ssl\n\n    # if the global flag is already set, just return now\n    if g_b_verify_ssl is not None:\n        helper.log_debug(\"get_verify_ssl: global g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    # Force Verify SSL to True by default\n    g_b_verify_ssl = True\n\n    t_server_info = server_info.ServerInfo(helper.context_meta['session_key'])\n    # t_server_data = t_server_info.to_dict()\n    # helper.log_debug(\"get_verify_ssl: server_data\")\n    # helper.log_debug(json.dumps(t_server_data, default=str, indent=4))\n    b_is_cloud = t_server_info.is_cloud_instance()\n    helper.log_debug(\"get_verify_ssl: is_cloud_instance [{}]\".format(b_is_cloud))\n\n    if b_is_cloud is True:\n        helper.log_debug(\"get_verify_ssl: Splunk Cloud return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    b_verify_ssl = helper.get_arg('enable_ssl_verification')\n    if b_verify_ssl is not None:\n        g_b_verify_ssl = b_verify_ssl\n        helper.log_debug(\"get_verify_ssl: enable_ssl_verification flag [{}]\".format(b_verify_ssl))\n\n    helper.log_debug(\"get_verify_ssl: Splunk Enterprise return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n    return g_b_verify_ssl\n\n\ndef validate_secure_url(helper, url):\n    if get_verify_ssl(helper) is False:\n        helper.log_error(\"SANDFLY_WARNING(validate_secure_url): SSL certificate verification is disaled, NOT RECOMMENDED\")\n\n    # pattern = \"^https:\\/\\/[0-9A-z.]+.[0-9A-z.]+.[a-z]+$\"\n    pattern = \"^https:\\/\\/(.*)$\"\n\n    result = re.match(pattern, url)\n    if result is not None:\n        helper.log_debug(\"VALID SECURE URL: [{}]\".format(url))\n        return True\n\n    helper.log_error(\"SANDFLY_ERROR(validate_secure_url): insecure URL [{}]\".format(url))\n    return False\n\n\ndef get_error_logs( helper, ew, base_url, access_token, b_detailed_logs, start_time_obj, error_logs_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/errors'\n    if b_detailed_logs is False:\n        url_to_query = url_to_query + '?summary=true'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_error_logs): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, error_logs_list\n\n    json_data = r.json()\n\n    count = 0\n    last_timestamp_obj = None\n    scroll_id = json_data['scroll_id']\n    total_count = json_data['total']\n\n    helper.log_info( 'Detailed Logs     : [{}]'.format( b_detailed_logs ) )\n    helper.log_info( 'Scroll ID         : [{}]'.format( scroll_id ) )\n    helper.log_info( 'Error Logs Total  : [{}]'.format( total_count ) )\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return None, error_logs_list\n\n    for d in hits_list:\n        t_timestamp_str = \"\"\n        if b_detailed_logs is True:\n            t_timestamp_str = d['header']['start_time']\n        else:\n            t_timestamp_str = d['start_time']\n        t_time_obj = datetime.strptime(t_timestamp_str, \"%Y-%m-%dT%H:%M:%SZ\").replace(tzinfo=timezone.utc)\n        if t_time_obj > start_time_obj:\n            if last_timestamp_obj is None:\n                last_timestamp_obj = t_time_obj\n                helper.log_debug('get_error_logs: the first last timestamp [{}]'.format(last_timestamp_obj))\n            elif t_time_obj > last_timestamp_obj:\n                last_timestamp_obj = t_time_obj\n                helper.log_debug('get_error_logs: update the last timestamp [{}]'.format(last_timestamp_obj))\n            error_logs_list.append( d )\n            count += 1\n\n    helper.log_debug('get_error_logs: count [{}]'.format(count))\n    helper.log_debug('get_error_logs: last timestamp [{}]'.format(last_timestamp_obj))\n\n    return last_timestamp_obj, error_logs_list\n\n\ndef do_process_error_logs( helper, ew, b_detailed_logs, error_logs_list ):\n    count = 0\n\n    if len(error_logs_list) > 0:\n        for d in error_logs_list:\n            t = {}\n            if b_detailed_logs is True:\n                t['timestamp'] = d['header']['start_time']\n                t['log_mode'] = 'detailed'\n            else:\n                t['timestamp'] = d['start_time']\n                t['log_mode'] = 'summary'\n            t['event_type'] = 'sandfly_error_log'\n            t['sandfly_input'] = helper.get_input_stanza_names()\n            t['error_log'] = d\n            data = json.dumps( t, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_error_logs: count [{}]'.format(count))\n\n    return count\n\n\ndef validate_license( helper, ew, base_url, access_token ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/license'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(validate_license): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return False\n\n    json_data = r.json()\n    # helper.log_debug('validate_license: license info [{}]'.format(json.dumps(json_data, indent=4, default=str, sort_keys=False)))\n\n    t_customer = json_data['customer']\n    helper.log_info('validate_license: customer name [{}]'.format( t_customer['name'] ))\n\n    t_date = json_data['date']\n    t_expiry = datetime.strptime( t_date['expiry'], \"%Y-%m-%dT%H:%M:%SZ\" ).replace(tzinfo=timezone.utc)\n    helper.log_debug('validate_license: expiry date [{}]'.format( t_expiry ))\n    t_now = datetime.now(timezone.utc)\n    helper.log_debug('validate_license: todays date [{}]'.format( t_now ))\n\n    if t_expiry < t_now:\n        helper.log_error('SANDFLY_ERROR(validate_license): expiry date [{}] EXPIRED'.format( t_date['expiry'] ))\n        return False\n\n    helper.log_info('validate_license: expiry date [{}] VALID'.format( t_date['expiry'] ))\n\n    t_limits = json_data['limits']\n    features_list = t_limits['features']\n\n    if len(features_list) == 0:\n        helper.log_error( 'SANDFLY_ERROR(validate_license): unable to find features in license' )\n        return False\n\n    for f in features_list:\n        if f == 'splunk_connector':\n            helper.log_info('validate_license: feature [{}] VALID'.format( f ))\n            return True\n\n    helper.log_info('validate_license: feature [splunk_connector] NOT FOUND')\n    helper.log_debug('validate_license: features_list [{}]'.format(json.dumps(features_list, indent=4, default=str, sort_keys=False)))\n\n    return False\n\n\ndef sandfly_login( helper, base_url, username, password ):\n    url_to_query = base_url + '/auth/login'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    payload = { \"username\": username, \"password\": password }\n\n    helper.log_debug('sandfly_login URL [{}]'.format(url_to_query))\n    helper.log_debug('sandfly_login Headers [{}]'.format(headers))\n    helper.log_debug('sandfly_login Username [{}]'.format(username))\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_login): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n    refresh_token = json_data['refresh_token']\n\n    return access_token, refresh_token\n\n\ndef sandfly_refresh( helper, base_url, refresh_token ):\n    url_to_query = base_url + '/auth/login_refresh'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    headers['Authorization'] = 'Bearer ' + refresh_token\n    payload = { \"refresh_token\": refresh_token }\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_refresh): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n\n    return access_token\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg( 'global_account' )\n    base_url = helper.get_arg( 'sandfly_server_url' )\n    user_start_time_str = helper.get_arg( 'start_time' )\n    if user_start_time_str is None:\n        user_start_time_str = ''\n#    b_detailed_logs = helper.get_arg('detailed_error_logs')\n#    if b_detailed_logs is None:\n#        b_detailed_logs = False\n#    b_test_mode = helper.get_arg('test_mode')\n#    if b_test_mode is None:\n#        b_test_mode = False\n\n    my_app_name = helper.get_app_name()\n    my_stanza_name = helper.get_input_stanza_names()\n    my_input_type = helper.get_input_type()\n    helper.log_debug('collect_events [{}] STARTMEUP - [{}] - [{}]'.format(my_input_type, my_app_name, my_stanza_name))\n\n    if validate_secure_url(helper, base_url) is False:\n        helper.log_error(\"collect_events insecure url\")\n        return\n\n    try:\n        access_token, refresh_token = sandfly_login( helper, base_url, global_account['username'], global_account['password'] )\n        if access_token is None:\n            helper.log_error(\"collect_events failed login\")\n            return\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n        return\n\n    b_valid_license = validate_license( helper, ew, base_url, access_token )\n    if b_valid_license is False:\n        helper.log_error(\"collect_events invalid license\")\n        return\n\n    user_start_time_obj = None\n    try:\n        if len(user_start_time_str) > 0:\n            user_start_time_obj = datetime.strptime(user_start_time_str, \"%Y-%m-%dT%H:%M:%SZ\").replace(tzinfo=timezone.utc)\n            helper.log_debug('user_start_time_obj: [{}]'.format(user_start_time_obj))\n    except Exception as e:\n        user_start_time_obj = None\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n\n    stanza_checkpoint_timestamp = 'sandfly_error_logs_{}_timestamp'.format(my_stanza_name)\n    helper.log_debug('checkpoint key: [{}]'.format(stanza_checkpoint_timestamp))\n#    if b_test_mode is True:\n#        helper.delete_check_point( stanza_checkpoint_timestamp )\n#        helper.log_debug('test mode enabled - delete checkpoint key: [{}]'.format(stanza_checkpoint_timestamp))\n\n    start_time_obj = None\n    checkpoint_ts = helper.get_check_point( stanza_checkpoint_timestamp )\n    if checkpoint_ts is None:\n        if user_start_time_obj is None:\n            start_time_obj = datetime.now(timezone.utc) - timedelta(hours=24)\n            helper.log_debug('start_time default to 24 hours ago: [{}]'.format(start_time_obj))\n        else:\n            start_time_obj = user_start_time_obj\n            helper.log_debug('start_time defined by user: [{}]'.format(start_time_obj))\n    else:\n        start_time_obj = datetime.strptime(checkpoint_ts, \"%Y-%m-%dT%H:%M:%SZ\").replace(tzinfo=timezone.utc)\n        helper.log_debug('start_time defined by checkpoint: [{}]'.format(start_time_obj))\n        if user_start_time_obj is not None:\n            if start_time_obj < user_start_time_obj:\n                start_time_obj = user_start_time_obj\n                helper.log_debug('checkpoint time older than user defined start_time: [{}]'.format(start_time_obj))\n\n    helper.log_info('start_time: [{}]'.format(start_time_obj))\n\n    last_timestamp_obj = None\n\n    # get the detailed error logs\n    #\n    error_logs_list = []\n    b_detailed_logs = True\n    last_timestamp_obj, error_logs_list = get_error_logs( helper, ew, base_url, access_token, b_detailed_logs, start_time_obj, error_logs_list )\n\n    if error_logs_list is not None:\n        do_process_error_logs( helper, ew, b_detailed_logs, error_logs_list )\n\n    # get the summary error logs\n    #\n    error_logs_list = []\n    b_detailed_logs = False\n\n    last_timestamp_obj, error_logs_list = get_error_logs( helper, ew, base_url, access_token, b_detailed_logs, start_time_obj, error_logs_list )\n\n    if error_logs_list is not None:\n        do_process_error_logs( helper, ew, b_detailed_logs, error_logs_list )\n\n    helper.log_debug('last timestamp [{}]'.format(last_timestamp_obj))\n    helper.log_debug('get_error_logs success')\n\n    if last_timestamp_obj is not None:\n        last_timestamp_str = last_timestamp_obj.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n        helper.log_debug('last timestamp str [{}]'.format(last_timestamp_str))\n        helper.save_check_point( stanza_checkpoint_timestamp, last_timestamp_str )\n\n    helper.log_debug('collect_events [{}] success THE_END [{}] ===================='.format(my_input_type, my_stanza_name))\n\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url')\n    opt_global_account = helper.get_arg('global_account')\n    opt_start_time = helper.get_arg('start_time')\n    opt_enable_ssl_verification = helper.get_arg('enable_ssl_verification')\n    opt_detailed_logs = helper.get_arg('detailed_logs')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url', stanza_name)\n    opt_global_account = helper.get_arg('global_account', stanza_name)\n    opt_start_time = helper.get_arg('start_time', stanza_name)\n    opt_enable_ssl_verification = helper.get_arg('enable_ssl_verification', stanza_name)\n    opt_detailed_logs = helper.get_arg('detailed_logs', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\", case insensitive)\n    helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    response = helper.send_http_request(url, method, parameters=None, payload=None,\n                                        headers=None, cookies=None, verify=True, cert=None,\n                                        timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n    # The following examples show usage of check pointing related helper functions.\n    # save checkpoint\n    helper.save_check_point(key, state)\n    # delete checkpoint\n    helper.delete_check_point(key)\n    # get checkpoint\n    state = helper.get_check_point(key)\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n\n    '''\n    # The following example writes a random number as an event for each input config. (Single Instance Mode)\n    # For advanced users, if you want to create single instance mod input, please use this code template.\n    # Also, you need to uncomment use_single_instance_mode() above.\n    import random\n    input_type = helper.get_input_type()\n    for stanza_name in helper.get_input_stanza_names():\n        data = str(random.randint(0,100))\n        event = helper.new_event(source=input_type, index=helper.get_output_index(stanza_name), sourcetype=helper.get_sourcetype(stanza_name), data=data)\n        ew.write_event(event)\n    '''\n", "customized_options": [{"name": "sandfly_server_url", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "value": "account0"}, {"name": "start_time", "value": "2024-07-15T00:00:00Z"}, {"name": "enable_ssl_verification", "value": true}], "uuid": "fb16733822fb43139efab8b2f0820e88", "sample_count": 0}, {"index": "default", "sourcetype": "sandfly:alarms", "interval": "600", "use_external_validation": true, "streaming_mode_xml": true, "name": "sandfly_alarms", "title": "Sandfly Alarms", "description": "", "type": "customized", "parameters": [{"name": "sandfly_server_url", "label": "Sandfly Server URL", "help_string": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4).", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4", "type": "text", "value": "https://blackbird.sandflysecurity.com/v4"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "sandfly_results", "label": "Sandfly Results", "help_string": "", "required": true, "possible_values": [{"label": "Alerts", "value": "alert"}, {"label": "Passed", "value": "pass"}, {"label": "Errors", "value": "error"}], "format_type": "multi_dropdownlist", "default_value": ["alert", "pass", "error"], "placeholder": "", "type": "multi_dropdownlist", "value": ["alert"]}, {"name": "sandfly_results_summary_data", "label": "Sandfly Results Summary Data", "help_string": "Enable to ingest summary data only, leave disabled to ingest full result data.", "required": false, "format_type": "checkbox", "default_value": false, "type": "checkbox", "value": true}, {"name": "duplicate_alerts", "label": "Duplicate Alerts", "help_string": "Enable to ingest duplicate Alerts. Duplicate Alerts are ingested when the Last Seen time for an existing Alert is updated.", "required": false, "format_type": "checkbox", "default_value": false, "type": "checkbox", "value": true}, {"name": "duplicate_alerts_summary_data", "label": "Duplicate Alerts Summary Data", "help_string": "Enable to ingest summary data only, leave disabled to ingest full result data.", "required": false, "format_type": "checkbox", "default_value": false, "type": "checkbox", "value": true}, {"name": "start_time", "label": "Start Time", "help_string": "The date (UTC in \"YYYY-MM-DDThh:mm:ssZ\" format) from when to start collecting data.  Default is last 24 hours if date is not specified.", "required": false, "format_type": "text", "default_value": "", "placeholder": "optional", "type": "text", "value": ""}, {"name": "enable_ssl_verification", "label": "Enable SSL Verification", "help_string": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "test_mode", "label": "Test Mode", "help_string": "Enable test mode to stop data ingestion after 999 events.  Not recommended for production environments.", "required": false, "format_type": "checkbox", "default_value": false, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "sandfly_server_url", "title": "Sandfly Server URL", "description": "Enter the Sandfly Server URL, including the API version (e.g., https://SERVER.sandflysecurity.com/v4).", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://SERVER.sandflysecurity.com/v4"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "sandfly_results", "title": "Sandfly Results", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"label": "Alerts", "value": "alert"}, {"label": "Passed", "value": "pass"}, {"label": "Errors", "value": "error"}], "format_type": "multi_dropdownlist", "default_value": ["alert", "pass", "error"], "placeholder": ""}, {"type": "customized_var", "name": "sandfly_results_summary_data", "title": "Sandfly Results Summary Data", "description": "Enable to ingest summary data only, leave disabled to ingest full result data.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": false}, {"type": "customized_var", "name": "duplicate_alerts", "title": "Duplicate Alerts", "description": "Enable to ingest duplicate Alerts. Duplicate Alerts are ingested when the Last Seen time for an existing Alert is updated.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": false}, {"type": "customized_var", "name": "duplicate_alerts_summary_data", "title": "Duplicate Alerts Summary Data", "description": "Enable to ingest summary data only, leave disabled to ingest full result data.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": false}, {"type": "customized_var", "name": "start_time", "title": "Start Time", "description": "The date (UTC in \"YYYY-MM-DDThh:mm:ssZ\" format) from when to start collecting data.  Default is last 24 hours if date is not specified.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "optional"}, {"type": "customized_var", "name": "enable_ssl_verification", "title": "Enable SSL Verification", "description": "Enable SSL certificate verification when connecting to the Sandfly Server URL. Leave unchecked when using self signed certificates (generally not recommended). Verification enforced on Splunk Cloud.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "test_mode", "title": "Test Mode", "description": "Enable test mode to stop data ingestion after 999 events.  Not recommended for production environments.", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": false}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nfrom datetime import datetime\nfrom datetime import timezone\nfrom datetime import timedelta\nimport collections\nimport csv\nimport re\nfrom solnlib import server_info\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ng_b_verify_ssl = None   # default to None until set by get_verify_ssl function\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # sandfly_server_url = definition.parameters.get('sandfly_server_url', None)\n    # global_account = definition.parameters.get('global_account', None)\n    # sandfly_results = definition.parameters.get('sandfly_results', None)\n    # start_time = definition.parameters.get('start_time', None)\n    pass\n\n\ndef get_verify_ssl(helper):\n    global g_b_verify_ssl\n\n    # if the global flag is already set, just return now\n    if g_b_verify_ssl is not None:\n        helper.log_debug(\"get_verify_ssl: global g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    # Force Verify SSL to True by default\n    g_b_verify_ssl = True\n\n    t_server_info = server_info.ServerInfo(helper.context_meta['session_key'])\n    # t_server_data = t_server_info.to_dict()\n    # helper.log_debug(\"get_verify_ssl: server_data\")\n    # helper.log_debug(json.dumps(t_server_data, default=str, indent=4))\n    b_is_cloud = t_server_info.is_cloud_instance()\n    helper.log_debug(\"get_verify_ssl: is_cloud_instance [{}]\".format(b_is_cloud))\n\n    if b_is_cloud is True:\n        helper.log_debug(\"get_verify_ssl: Splunk Cloud return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n        return g_b_verify_ssl\n\n    b_verify_ssl = helper.get_arg('enable_ssl_verification')\n    if b_verify_ssl is not None:\n        g_b_verify_ssl = b_verify_ssl\n        helper.log_debug(\"get_verify_ssl: enable_ssl_verification flag [{}]\".format(b_verify_ssl))\n\n    helper.log_debug(\"get_verify_ssl: Splunk Enterprise return g_b_verify_ssl [{}]\".format(g_b_verify_ssl))\n    return g_b_verify_ssl\n\n\ndef validate_secure_url(helper, url):\n    if get_verify_ssl(helper) is False:\n        helper.log_error(\"SANDFLY_WARNING(validate_secure_url): SSL certificate verification is disaled, NOT RECOMMENDED\")\n\n    # pattern = \"^https:\\/\\/[0-9A-z.]+.[0-9A-z.]+.[a-z]+$\"\n    pattern = \"^https:\\/\\/(.*)$\"\n\n    result = re.match(pattern, url)\n    if result is not None:\n        helper.log_debug(\"VALID SECURE URL: [{}]\".format(url))\n        return True\n\n    helper.log_error(\"SANDFLY_ERROR(validate_secure_url): insecure URL [{}]\".format(url))\n    return False\n\n\ndef create_lookup( helper, ew, sandfly_list ):\n    my_path = os.path.abspath( os.path.dirname( __file__ ) )\n    #data = my_path\n    #event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    #ew.write_event(event)\n\n    lookup_path = os.path.abspath( os.path.join( my_path, \"..\", \"lookups\") )\n    #data = lookup_path\n    #event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    #ew.write_event(event)\n\n    if not os.path.exists( lookup_path ):\n        try:\n            os.mkdir( lookup_path )\n            helper.log_debug( 'Created Lookup Path: {}'.format( lookup_path ) )\n        except Exception as e:\n            helper.log_error( 'SANDFLY_ERROR(create_lookup): {}'.format( str( e ) ) )\n            return\n\n    lookup_file = lookup_path + '/sandflies.csv'\n\n    #data = json.dumps( sandfly_list, indent=4, default=str, sort_keys=False )\n    #event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    #ew.write_event(event)\n\n    csv_file = open( lookup_file, 'wt' )\n    csv_writer = csv.DictWriter( csv_file, fieldnames=sandfly_list[0].keys() )\n    csv_writer.writeheader()\n\n    for row in sandfly_list:\n        csv_writer.writerow( row )\n\n    csv_file.close()\n\n    helper.log_debug( 'Created Lookup File: count [{}] {}'.format( len(sandfly_list), lookup_file ) )\n\n    return\n\n\ndef get_sandflies( helper, ew, base_url, access_token, scroll_id, sandfly_list ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    if scroll_id is not None:\n        url_to_query = base_url + '/scroll'\n        payload = { \"scroll_id\": scroll_id }\n        r = helper.send_http_request(\n            url=url_to_query,\n            method='POST',\n            headers=headers,\n            payload=json.dumps( payload ),\n            use_proxy=use_proxy,\n            verify=verify_ssl\n            )\n    else:\n        url_to_query = base_url + '/sandflies'\n        r = helper.send_http_request(\n            url=url_to_query,\n            method='GET',\n            headers=headers,\n            use_proxy=use_proxy,\n            verify=verify_ssl\n            )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_sandflies): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, sandfly_list\n\n    json_data = r.json()\n\n    if \"scroll_id\" in json_data:\n        scroll_id = json_data['scroll_id']\n    else:\n        scroll_id = None\n\n    total_count = json_data['total']\n\n    helper.log_info( 'Sandflies Total: [{}]'.format( total_count ) )\n\n    hits_list = json_data['data']\n\n    if len(hits_list) == 0:\n        return None, sandfly_list\n\n    for h in hits_list:\n        ## the_id = h['id'] # deprecated in 4.6.0\n        the_name = h['name']\n        the_type = h['type']\n        ##the_cpu = h['_source']['max_cpu_load']\n        ##the_disk = h['_source']['max_disk_load']\n        the_desc = h['description']\n        the_active = h['active']\n#        helper.log_debug('get_sandfles name [{}] desc [{}]'.format(the_name, the_desc))\n        d = collections.OrderedDict()\n        ## d['sandfly_id'] = the_id\n        d['sandfly_name'] = the_name\n        d['sandfly_title'] = the_name.replace( '_', ' ').upper()\n        d['sandfly_type'] = the_type\n        d['sandfly_active'] = the_active\n        d['sandfly_description'] = the_desc\n        sandfly_list.append( d )\n\n    return scroll_id, sandfly_list\n\n\ndef do_process_alarms( helper, ew, json_data, last_seen_time, b_summary, tag ):\n    count = 0\n    last_sequence_id = None\n    b_more_results = False\n    total = 0\n\n    hits_list = json_data['data']\n\n    if len(hits_list) > 0:\n        b_more_results = json_data['more_results']\n        total = json_data['total']\n\n        for h in hits_list:\n            last_sequence_id = h['sequence_id']\n            my_timestamp = h['last_seen']\n            if last_seen_time is None:\n                last_seen_time = my_timestamp\n            else:\n                dt1 = datetime.strptime(last_seen_time, \"%Y-%m-%dT%H:%M:%SZ\" )\n                dt2 = datetime.strptime(my_timestamp, \"%Y-%m-%dT%H:%M:%SZ\" )\n                if dt2 > dt1:\n                    last_seen_time = my_timestamp\n            if not 'timestamp' in h:\n                h['timestamp'] = my_timestamp\n            if not 'sandfly_input' in h:\n                h['sandfly_input'] = helper.get_input_stanza_names()\n            if not 'sandfly_tag' in h:\n                h['sandfly_tag'] = tag\n            if not 'sandfly_summary' in h:\n                h['sandfly_summary'] = b_summary\n            data = json.dumps( h, default=str, sort_keys=False )\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n            count += 1\n\n    helper.log_debug('do_process_alarms: sandfly_tag      [{}]'.format(tag))\n    helper.log_debug('do_process_alarms: summary_flag     [{}]'.format(b_summary))\n    helper.log_debug('do_process_alarms: more_results     [{}]'.format(b_more_results))\n    helper.log_debug('do_process_alarms: last_sequence_id [{}]'.format(last_sequence_id))\n    helper.log_debug('do_process_alarms: last_seen_time   [{}]'.format(last_seen_time))\n    helper.log_debug('do_process_alarms: total            [{}]'.format(total))\n    helper.log_debug('do_process_alarms: count            [{}]'.format(count))\n\n    return count, b_more_results, last_sequence_id, last_seen_time\n\n\ndef get_sandfly_alarms_by_last_seen( helper, ew, alarm_type, b_summary, base_url, access_token, max_sequence_id, min_sequence_id, last_seen_time ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    url_to_query = base_url + '/results'\n    payload = {\n        \"size\": 999,\n        \"summary\": b_summary,\n        \"filter\": {\n            \"items\": [\n                { \"columnField\": \"data.status\", \"operatorValue\": \"equals\", \"value\": alarm_type},\n                { \"columnField\": \"last_seen\", \"operatorValue\": \"after\", \"value\": last_seen_time},\n                { \"columnField\": \"sequence_id\", \"operatorValue\": \">\", \"value\": min_sequence_id},\n                { \"columnField\": \"sequence_id\", \"operatorValue\": \"<=\", \"value\": max_sequence_id}\n            ],\n            \"linkoperator\": \"and\"\n        },\n        \"sort\": [\n                { \"Field\": \"sequence_id\", \"sort\": \"asc\"}\n        ]\n    }\n    method = 'POST'\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    try:\n        r = helper.send_http_request(\n            url=url_to_query,\n            method=method,\n            headers=headers,\n            payload=json.dumps( payload ),\n            use_proxy=use_proxy,\n            timeout=30.0,\n            verify=verify_ssl\n            )\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(get_sandfly_alarms_by_last_seen): {}'.format( str( e ) ) )\n        return 0, None, None, None\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_sandfly_alarms_by_last_seen): alarm_type {} code {} reason {}'\n        helper.log_error( error_msg.format( alarm_type, r.status_code, r.reason ) )\n        return 0, None, None, None\n\n    json_data = r.json()\n\n    count, b_more_results, last_sequence_id, last_seen_time = do_process_alarms( helper, ew, json_data, last_seen_time, b_summary, \"last_seen\" )\n\n    helper.log_debug('get_sandfly_alarms_by_last_seen: [{}] RETURN count [{}] more_results [{}] last_sequence_id [{}] last_seen_time [{}]'.format(alarm_type, count, b_more_results, last_sequence_id, last_seen_time))\n\n    return count, b_more_results, last_sequence_id, last_seen_time\n\n\ndef get_sandfly_alarms_by_sequence_id( helper, ew, alarm_type, b_summary, base_url, access_token, last_sequence_id, last_seen_time ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    url_to_query = base_url + '/results'\n    payload = {\n        \"size\": 999,\n        \"summary\": b_summary,\n        \"filter\": {\n            \"items\": [\n                { \"columnField\": \"data.status\", \"operatorValue\": \"equals\", \"value\": alarm_type},\n                { \"columnField\": \"sequence_id\", \"operatorValue\": \">\", \"value\": last_sequence_id}\n            ],\n            \"linkoperator\": \"and\"\n        },\n        \"sort\": [\n                { \"Field\": \"sequence_id\", \"sort\": \"asc\"}\n        ]\n    }\n    method = 'POST'\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    try:\n        r = helper.send_http_request(\n            url=url_to_query,\n            method=method,\n            headers=headers,\n            payload=json.dumps( payload ),\n            use_proxy=use_proxy,\n            timeout=30.0,\n            verify=verify_ssl\n            )\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(get_sandfly_alarms_by_sequence_id): {}'.format( str( e ) ) )\n        return 0, None, None, None\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_sandfly_alarms_by_sequence_id): alarm_type {} code {} reason {}'\n        helper.log_error( error_msg.format( alarm_type, r.status_code, r.reason ) )\n        return 0, None, None, None\n\n    json_data = r.json()\n\n    count, b_more_results, last_sequence_id, last_seen_time = do_process_alarms( helper, ew, json_data, last_seen_time, b_summary, \"first_seen\" )\n\n    helper.log_debug('get_sandfly_alarms_by_sequence_id: [{}] RETURN count [{}] more_results [{}] last_sequence_id [{}] last_seen_time [{}]'.format(alarm_type, count, b_more_results, last_sequence_id, last_seen_time))\n\n    return count, b_more_results, last_sequence_id, last_seen_time\n\n\ndef get_sandfly_alarms_by_timestamp( helper, ew, alarm_type, b_summary, base_url, access_token, last_timestamp, last_seen_time ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    url_to_query = base_url + '/results'\n    payload = {\n        \"size\": 999,\n        \"summary\": b_summary,\n        \"time_since\": last_timestamp,\n        \"filter\": {\n            \"items\": [\n                { \"columnField\": \"data.status\", \"operatorValue\": \"equals\", \"value\": alarm_type}\n            ] \n        },\n        \"sort\": [\n                { \"Field\": \"sequence_id\", \"sort\": \"asc\"}\n        ]\n    }\n    method = 'POST'\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    try:\n        r = helper.send_http_request(\n            url=url_to_query,\n            method=method,\n            headers=headers,\n            payload=json.dumps( payload ),\n            use_proxy=use_proxy,\n            timeout=30.0,\n            verify=verify_ssl\n            )\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(get_sandfly_alarms_by_timestamp): {}'.format( str( e ) ) )\n        return 0, None, None, None\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(get_sandfly_alarms_by_timestamp): alarm_type {} code {} reason {}'\n        helper.log_error( error_msg.format( alarm_type, r.status_code, r.reason ) )\n        return 0, None, None, None\n\n    json_data = r.json()\n\n    count, b_more_results, last_sequence_id, last_seen_time = do_process_alarms( helper, ew, json_data, last_seen_time, b_summary, \"first_seen\" )\n\n    helper.log_debug('get_sandfly_alarms_by_timestamp: [{}] RETURN count [{}] more_results [{}] last_sequence_id [{}] last_seen_time [{}]'.format(alarm_type, count, b_more_results, last_sequence_id, last_seen_time))\n\n    return count, b_more_results, last_sequence_id, last_seen_time\n\n\ndef validate_checkpoint_timestamp( helper, ew, checkpoint_ts_key, start_time_str ):\n    if len(start_time_str) == 0:\n        helper.log_debug('validate_checkpoint_timestamp : start_time_str [{}], so just return False'.format(start_time_str))\n        return False\n\n    helper.log_debug('validate_checkpoint_timestamp [{}] - start_time_str [{}]'.format(checkpoint_ts_key, start_time_str))\n    checkpoint_ts = helper.get_check_point( checkpoint_ts_key )\n    if checkpoint_ts is None:\n        helper.log_debug('validate_checkpoint_timestamp : [{}] does not exist, so just return False'.format(checkpoint_ts_key))\n        return False\n\n    t_last = datetime.strptime( checkpoint_ts, \"%Y-%m-%dT%H:%M:%SZ\" )\n    t_test = datetime.strptime( start_time_str, \"%Y-%m-%dT%H:%M:%SZ\" )\n\n    helper.log_debug('validate_checkpoint_timestamp : last [{}]'.format(checkpoint_ts))\n    helper.log_debug('validate_checkpoint_timestamp : test [{}]'.format(start_time_str))\n\n    if t_last < t_test:\n        helper.log_error('SANDFLY_ERROR(validate_checkpoint_timestamp): last date [{}] older than test date [{}], return True'.format( checkpoint_ts, start_time_str ))\n        return True\n\n    helper.log_debug('validate_checkpoint_timestamp : last date [{}] is not older than test date [{}], return False'.format(checkpoint_ts, start_time_str))\n    return False\n\n\ndef validate_license( helper, ew, base_url, access_token ):\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n\n    if access_token is not None:\n        headers['Authorization'] = 'Bearer ' + access_token\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    url_to_query = base_url + '/license'\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='GET',\n        headers=headers,\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(validate_license): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return False\n\n    json_data = r.json()\n    # helper.log_debug('validate_license: license info [{}]'.format(json.dumps(json_data, indent=4, default=str, sort_keys=False)))\n\n    t_customer = json_data['customer']\n    helper.log_info('validate_license: customer name [{}]'.format( t_customer['name'] ))\n\n    t_date = json_data['date']\n    t_expiry = datetime.strptime( t_date['expiry'], \"%Y-%m-%dT%H:%M:%SZ\" ).replace(tzinfo=timezone.utc)\n    helper.log_debug('validate_license: expiry date [{}]'.format( t_expiry ))\n    t_now = datetime.now(timezone.utc)\n    helper.log_debug('validate_license: todays date [{}]'.format( t_now ))\n\n    if t_expiry < t_now:\n        helper.log_error('SANDFLY_ERROR(validate_license): expiry date [{}] EXPIRED'.format( t_date['expiry'] ))\n        return False\n\n    helper.log_info('validate_license: expiry date [{}] VALID'.format( t_date['expiry'] ))\n\n    t_limits = json_data['limits']\n    features_list = t_limits['features']\n\n    if len(features_list) == 0:\n        helper.log_error( 'SANDFLY_ERROR(validate_license): unable to find features in license' )\n        return False\n\n    for f in features_list:\n        if f == 'splunk_connector':\n            helper.log_info('validate_license: feature [{}] VALID'.format( f ))\n            return True\n\n    helper.log_info('validate_license: feature [splunk_connector] NOT FOUND')\n    helper.log_debug('validate_license: features_list [{}]'.format(json.dumps(features_list, indent=4, default=str, sort_keys=False)))\n\n    return False\n\n\ndef sandfly_login( helper, base_url, username, password ):\n    url_to_query = base_url + '/auth/login'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    payload = { \"username\": username, \"password\": password }\n\n    helper.log_debug('sandfly_login URL [{}]'.format(url_to_query))\n    helper.log_debug('sandfly_login Headers [{}]'.format(headers))\n    helper.log_debug('sandfly_login Username [{}]'.format(username))\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_login): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None, None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n    refresh_token = json_data['refresh_token']\n\n    return access_token, refresh_token\n\n\ndef sandfly_refresh( helper, base_url, refresh_token ):\n    url_to_query = base_url + '/auth/login_refresh'\n    headers = { \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" }\n    headers['Authorization'] = 'Bearer ' + refresh_token\n    payload = { \"refresh_token\": refresh_token }\n\n    proxy_settings = helper.get_proxy()\n    use_proxy = bool( proxy_settings )\n    verify_ssl = get_verify_ssl(helper)\n\n    r = helper.send_http_request(\n        url=url_to_query,\n        method='POST',\n        headers=headers,\n        payload=json.dumps( payload ),\n        use_proxy=use_proxy,\n        verify=verify_ssl\n        )\n\n    if r.status_code != 200:    # requests.codes.ok\n        error_msg = 'SANDFLY_ERROR(sandfly_refresh): {} {}'\n        helper.log_error( error_msg.format( r.status_code, r.reason ) )\n        return None\n\n    json_data = r.json()\n    access_token = json_data['access_token']\n\n    return access_token\n\n\ndef get_checkpoint_info( helper, my_stanza_name, alarm_type, start_time_str, reset_checkpoint_keys ):\n    checkpoint_timestamp = 'sandfly_alarms_timestamp_' + alarm_type\n    last_timestamp = None\n\n    checkpoint_old = 'sandfly_alarms_sequenceid_' + alarm_type\n    checkpoint_key = 'sandfly_alarms_sequenceid_' + my_stanza_name + '_' + alarm_type\n    last_seen_key = 'sandfly_alarms_lastseen_' + my_stanza_name + '_' + alarm_type\n\n    last_sequence_id = helper.get_check_point( checkpoint_old )\n    if last_sequence_id is not None:\n        helper.log_debug('OLD LAST SEQUENCE_ID : {}'.format(last_sequence_id))\n        helper.delete_check_point( checkpoint_old )\n        helper.save_check_point( checkpoint_key, last_sequence_id )\n\n    if reset_checkpoint_keys is True:\n        helper.delete_check_point( checkpoint_key )\n        helper.delete_check_point( last_seen_key )\n\n    last_sequence_id = helper.get_check_point( checkpoint_key )\n    helper.log_debug('GET LAST SEQUENCE_ID : {}'.format(last_sequence_id))\n\n    if last_sequence_id is None:\n        last_timestamp = helper.get_check_point( checkpoint_timestamp )\n        helper.log_debug('GET LAST TIMESTAMP   : {}'.format(last_timestamp))\n        if last_timestamp is not None:\n            helper.delete_check_point( checkpoint_timestamp )\n\n        if last_timestamp is None:\n            if len(start_time_str) == 0:\n                t_now = datetime.now(timezone.utc) - timedelta(hours=24)\n                last_timestamp = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n            else:\n                last_timestamp = start_time_str\n\n        helper.log_debug('NEW LAST_TIMESTAMP: {}'.format(last_timestamp))\n        helper.log_debug('NEW LAST_SEQUENCE : {}'.format(last_sequence_id))\n    else:\n        helper.delete_check_point( checkpoint_timestamp )\n\n    last_seen_time = helper.get_check_point( last_seen_key )\n    helper.log_debug('GET LAST SEEN TIME   : [{}]'.format(last_seen_time))\n\n    helper.log_info('get_checkpoint_info checkpoint_timestamp  : [{}] [{}]'.format(checkpoint_timestamp, last_timestamp))\n    helper.log_info('get_checkpoint_info checkpoint_sequenceid : [{}] [{}]'.format(checkpoint_key, last_sequence_id))\n    helper.log_info('get_checkpoint_info checkpoint_lastseen   : [{}] [{}]'.format(last_seen_key, last_seen_time))\n\n    return checkpoint_key, last_sequence_id, last_seen_key, last_seen_time, last_timestamp\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg( 'global_account' )\n    base_url = helper.get_arg( 'sandfly_server_url' )\n\n    start_time_str = helper.get_arg( 'start_time' )\n    if start_time_str is None:\n        start_time_str = \"\"\n\n    b_test_mode = helper.get_arg( 'test_mode' )\n    if b_test_mode is None:\n        b_test_mode = False\n\n    b_results_summary = helper.get_arg( 'sandfly_results_summary_data' )\n    if b_results_summary is None:\n        b_results_summary = False\n\n    b_duplicate_alerts = helper.get_arg( 'duplicate_alerts' )\n    if b_duplicate_alerts is None:\n        b_duplicate_alerts = False\n\n    b_duplicate_summary = helper.get_arg( 'duplicate_alerts_summary_data' )\n    if b_duplicate_summary is None:\n        b_duplicate_summary = False\n\n    try:\n        if len(start_time_str) > 0:\n            t_time_obj = datetime.strptime(start_time_str, \"%Y-%m-%dT%H:%M:%SZ\").replace(tzinfo=timezone.utc)\n    except Exception as e:\n        start_time_str = \"\"\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n\n    if b_test_mode is True:\n        if len(start_time_str) == 0:\n            t_now = datetime.now(timezone.utc) - timedelta(days=7)\n            start_time_str = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n\n    my_app_name = helper.get_app_name()\n    my_stanza_name = helper.get_input_stanza_names()\n    my_input_type = helper.get_input_type()\n    helper.log_debug('collect_events [{}] STARTMEUP - [{}] - [{}]'.format(my_input_type, my_app_name, my_stanza_name))\n\n    if validate_secure_url(helper, base_url) is False:\n        helper.log_error(\"collect_events insecure url\")\n        return\n\n    helper.log_debug('collect_events START TIME - [{}] - [{}]'.format(len(start_time_str), start_time_str))\n    helper.log_debug('collect_events RESULTS SUMMARY - [{}]'.format(b_results_summary))\n    helper.log_debug('collect_events DUPLICATE ALERTS - [{}] - summary [{}]'.format(b_duplicate_alerts, b_duplicate_summary))\n    helper.log_debug('collect_events TEST MODE - [{}]'.format(b_test_mode))\n\n    try:\n        access_token, refresh_token = sandfly_login( helper, base_url, global_account['username'], global_account['password'] )\n        if access_token is None:\n            helper.log_error(\"collect_events failed login\")\n            return\n    except Exception as e:\n        helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n        return\n\n    b_valid_license = validate_license( helper, ew, base_url, access_token )\n    if b_valid_license is False:\n        helper.log_error(\"collect_events invalid license\")\n        return\n\n    scroll_id = None\n\n    sandfly_list = []\n\n    scroll_id, sandfly_list = get_sandflies( helper, ew, base_url, access_token, scroll_id, sandfly_list )\n\n    while scroll_id is not None:\n        scroll_id, sandfly_list = get_sandflies( helper, ew, base_url, access_token, scroll_id, sandfly_list )\n\n    if sandfly_list is not None:\n        create_lookup( helper, ew, sandfly_list )\n\n    helper.log_debug('get_sandflies success')\n\n    stanza_checkpoint_timestamp = 'sandfly_alarms_{}_timestamp'.format(my_stanza_name)\n    reset_checkpoint_keys = validate_checkpoint_timestamp( helper, ew, stanza_checkpoint_timestamp, start_time_str )\n\n    sandfly_results = helper.get_arg('sandfly_results')\n    helper.log_debug('collect_events sandfly_results [{}]'.format(json.dumps(sandfly_results)))\n\n    helper.log_debug('collect_events start_time_str [{}]'.format(start_time_str))\n    helper.log_debug('collect_events reset_checkpt  [{}]'.format(reset_checkpoint_keys))\n\n    if b_test_mode is True:\n        reset_checkpoint_keys = True\n        helper.log_debug('collect_events reset_checkpt  [{}]'.format(reset_checkpoint_keys))\n\n    for alarm_type in sandfly_results:\n        helper.log_debug('collect_events alarm_type: [{}]'.format(alarm_type))\n        event_count = 0\n        refresh_max = 20\n        refresh_count = 0\n\n        checkpoint_key, last_sequence_id, last_seen_key, last_seen_time, last_timestamp = get_checkpoint_info( helper, my_stanza_name, alarm_type, start_time_str, reset_checkpoint_keys )\n\n        helper.log_info('collect_events checkpoint_timestamp  : [{}]'.format(last_timestamp))\n        helper.log_info('collect_events checkpoint_key        : [{}]'.format(checkpoint_key))\n        helper.log_info('collect_events checkpoint_sequenceid : [{}]'.format(last_sequence_id))\n        helper.log_info('collect_events last_seen_key         : [{}]'.format(last_seen_key))\n        helper.log_info('collect_events last_seen_time        : [{}]'.format(last_seen_time))\n\n        try:\n            access_token = sandfly_refresh( helper, base_url, refresh_token )\n            if access_token is None:\n                helper.log_error(\"collect_events failed refresh\")\n                return\n            refresh_count = 0\n        except Exception as e:\n            helper.log_error( 'SANDFLY_ERROR(collect_events): {}'.format( str( e ) ) )\n            return\n\n        b_more_results = True\n\n        if b_duplicate_alerts and b_test_mode is False and last_sequence_id is not None and last_seen_time is not None and alarm_type == \"alert\":\n            min_last_sequence_id = \"0\"\n            max_last_sequence_id = last_sequence_id\n            while b_more_results is True:\n                count, b_more_results, min_last_sequence_id, ignore_last_seen_time = get_sandfly_alarms_by_last_seen( helper, ew, alarm_type, b_duplicate_summary, base_url, access_token, max_last_sequence_id, min_last_sequence_id, last_seen_time )\n                helper.log_info('collect_events last_seen result count: [{}] [{}]'.format(alarm_type, count))\n\n        b_more_results = True\n\n        if last_sequence_id is None and last_timestamp is not None:\n            count, b_more_results, last_sequence_id, last_seen_time = get_sandfly_alarms_by_timestamp( helper, ew, alarm_type, b_results_summary, base_url, access_token, last_timestamp, last_seen_time )\n            if last_sequence_id is not None:\n                helper.save_check_point( checkpoint_key, last_sequence_id )\n                helper.log_info('collect_events update checkpoint sequence_id: [{}] [{}]'.format(checkpoint_key, last_sequence_id))\n            if last_seen_time is not None:\n                helper.save_check_point( last_seen_key, last_seen_time )\n                helper.log_info('collect_events update checkpoint last_seen  : [{}] [{}]'.format(last_seen_key, last_seen_time))\n            event_count += count\n\n        while b_more_results is True and b_test_mode is False:\n            count, b_more_results, last_sequence_id, last_seen_time = get_sandfly_alarms_by_sequence_id( helper, ew, alarm_type, b_results_summary, base_url, access_token, last_sequence_id, last_seen_time )\n            if last_sequence_id is not None:\n                helper.save_check_point( checkpoint_key, last_sequence_id )\n                helper.log_info('collect_events update checkpoint sequence_id: [{}] [{}]'.format(checkpoint_key, last_sequence_id))\n            if last_seen_time is not None:\n                helper.save_check_point( last_seen_key, last_seen_time )\n                helper.log_info('collect_events update checkpoint last_seen  : [{}] [{}]'.format(last_seen_key, last_seen_time))\n            event_count += count\n\n        helper.log_info('collect_events event_count: [{}] [{}]'.format(alarm_type, event_count))\n\n    t_now = datetime.now(timezone.utc)\n    t_now_timestamp = t_now.strftime( \"%Y-%m-%dT%H:%M:%SZ\" )\n    helper.save_check_point( stanza_checkpoint_timestamp, t_now_timestamp )\n    helper.log_info('collect_events update checkpoint last_timestamp : [{}] [{}]'.format(stanza_checkpoint_timestamp, t_now_timestamp))\n\n    helper.log_debug('collect_events [{}] success THE_END [{}] ===================='.format(my_input_type, my_stanza_name))\n\n    \"\"\"Implement your data collection logic here\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url')\n    opt_global_account = helper.get_arg('global_account')\n    opt_sandfly_results = helper.get_arg('sandfly_results')\n    opt_start_time = helper.get_arg('start_time')\n    # In single instance mode, to get arguments of a particular input, use\n    opt_sandfly_server_url = helper.get_arg('sandfly_server_url', stanza_name)\n    opt_global_account = helper.get_arg('global_account', stanza_name)\n    opt_sandfly_results = helper.get_arg('sandfly_results', stanza_name)\n    opt_start_time = helper.get_arg('start_time', stanza_name)\n\n    # get input type\n    helper.get_input_type()\n\n    # The following examples get input stanzas.\n    # get all detailed input stanzas\n    helper.get_input_stanza()\n    # get specific input stanza with stanza name\n    helper.get_input_stanza(stanza_name)\n    # get all stanza names\n    helper.get_input_stanza_names()\n\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    account = helper.get_user_credential_by_username(\"username\")\n    account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    # The following examples show usage of logging related helper functions.\n    # write to the log for this modular input using configured global log level or INFO as default\n    helper.log(\"log message\")\n    # write to the log using specified log level\n    helper.log_debug(\"log message\")\n    helper.log_info(\"log message\")\n    helper.log_warning(\"log message\")\n    helper.log_error(\"log message\")\n    helper.log_critical(\"log message\")\n    # set the log level for this modular input\n    # (log_level can be \"debug\", \"info\", \"warning\", \"error\" or \"critical\