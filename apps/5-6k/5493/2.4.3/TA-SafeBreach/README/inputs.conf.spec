[audit_input://<name>]
safebreach_account = Select your SafeBreach Account.
start_date_time = Enter the start date and time for the first audit log to fetch in ISO format: YYYY-MM-DDTHH:MM:SS.SSSZ (E.g. 2020-02-22T05:40:58.000Z).

[simulation_input://<name>]
safebreach_account = Select your SafeBreach Account.
start_date_time = Enter the start date and time for the first simulation to fetch in ISO format: YYYY-MM-DDTHH:MM:SS.SSSZ (E.g. 2020-02-22T05:40:58.000Z).
offset = Delay time (in minutes) to allow the security events to be populated in SafeBreach simulation results. Default is 20 miniutes.
extra_fields_to_parse = Extra fields to parse and add to the simulation event. Default is empty/none.

[insights_input://<name>]
safebreach_account = Select your SafeBreach Account.
start_date_time = Enter the start date and time for the first simulation to fetch in ISO format: YYYY-MM-DDTHH:MM:SS.SSSZ (E.g. 2020-02-22T05:40:58.000Z).