[slackbot_alert]
param.message = <string> Message. It's a required parameter. It's default value is Your *$name$* alert matched $job.resultCount$ events. First result: ```$result._raw$```.
param.channel = <string> Destination channel. It's a required parameter
param.username = <string> Bot username.
param.icon_emoji = <string> Emoji avatar. Supersedes icon_url.
param.icon_url = <string> URL for avatar.
param.token_name = <string> Slack token configuration name. It's a required parameter.

