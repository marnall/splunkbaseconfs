[vantage_alert://<name>]
api_key_name = API key name generated on Vantage.
api_key_token = API key token generated on Vantage
vantage_host = The Vantage endpoint without the ''http://' part
from_timestamp = Get the alerts from the timestamp passed here, the format is epoch milliseconds
organization_name = The name of the organization from where you want to get the alerts
group_by_incident = Allow group alerts by incident.

