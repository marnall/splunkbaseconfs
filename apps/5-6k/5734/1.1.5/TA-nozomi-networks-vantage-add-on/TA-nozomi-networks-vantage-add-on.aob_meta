n ''\n\n    def page(self):\n        return self.__page()\n\n    def reset_pagination(self):\n        return self.__clean_page()\n\n    def items(self):\n        token = self.__token()\n        organization_id = self.__organization_id_from(self.helper.get_arg('organization_name'))\n\n        # self.helper.log_info('items organization_id ' + organization_id + ' organization_name ' + self.helper.get_arg('organization_name'))\n\n        headers = {\n            'authorization': token,\n            'Vantage-Org': organization_id,\n            'content-type': 'application/json'\n        }\n\n        page = self.__page()\n\n        endpoint = \"https://\" + self.vantage_host + \"/api/v1/\" + self.item_name + \"?sort[first_activity_time]=asc&skip_total_count=true&filter[first_activity_time][gt]=\" + str(\n            self.__last_item_time()) + \"&page=\" + str(page) + \"&size=\" + str(self.PAGE_SIZE)\n\n        #self.helper.log_info('endpoint ' + endpoint)\n\n        response = requests.get(endpoint, headers=headers)\n\n        if response.status_code == 401:\n            self.__clean_last_token()\n            return {'data': []}\n\n        json_response = response.json()\n\n        if response.status_code >= 500 or response.status_code == 499:\n            self.__clean_page()\n            self.__save_last_item_time_raw(str(self.__before_last_time()))\n            return {'data': []}\n\n        if self.__is_ok(response) is not True:\n            self.helper.log_error(\n                \"ERROR REST API call /api/v1/\" + self.item_name + \" returned \" + str(response.status_code))\n            return {'data': []}\n\n        response_len = len(json_response[\"data\"])\n\n        if response_len == self.PAGE_SIZE:\n            self.__save_before_last_item_time(json_response[\"data\"])\n\n            RESET_AFTER_PAGINATION_COUNT = 100\n            if page == RESET_AFTER_PAGINATION_COUNT:\n                self.__clean_page()\n                self.__save_last_item_time(json_response[\"data\"])\n            else:\n                self.__increase_page()\n        else:\n            self.__clean_page()\n            if response_len >= 1:\n                self.__save_last_item_time(json_response[\"data\"])\n            else:\n                if self.__before_last_time() is not None:\n                    self.__save_last_item_time_raw(str(self.__before_last_time()))\n        return json_response\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    pass\n\n\ndef flat_and_filter_json_response_data(response_data):\n    flattened_data = []\n    for item in response_data:\n        flattened_item = {}\n        for key in item.keys():\n            if key != \"attributes\" and key != \"relationships\" and key != \"links\":\n                flattened_item[key] = item[key]\n        if \"attributes\" in item.keys():\n            item_attributes = item[\"attributes\"]\n            for key in item_attributes.keys():\n                flattened_item[key] = item_attributes[key]\n        flattened_data.append(flattened_item)\n    return flattened_data\n\n\ndef collect_events(helper, ew):\n   # helper.log_info(\"-----------------A NEW RUN START HERE------------------\")\n\n    vantage = Vantage('sessions', helper)\n\n    if vantage.is_configuration_changed():\n        # vantage.helper.log_info('clean token, page and last time')\n        vantage.clean_all()\n        vantage.save_current_configuration()\n\n    loglevel = helper.get_log_level()\n    helper.set_log_level(loglevel)\n\n    json_response = vantage.items()\n    response_data = json_response[\"data\"]\n    flattened_data = flat_and_filter_json_response_data(response_data)\n\n    # Create a splunk event\n    for item in flattened_data:\n        event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=json.dumps(item))\n        ew.write_event(event)\n    pass\n", "customized_options": [{"name": "api_key_name", "value": "AKe13681"}, {"name": "vantage_host", "value": "nozominetworkscom.customers.eu1.staging-slfkjne-vantage.nozominetworks.io"}, {"name": "from_timestamp", "value": "113"}, {"name": "organization_name", "value": "Splunk"}], "uuid": "49a5576efac04feabeffa7aa1f7a6dd0", "sample_count": 0}]}, "field_extraction_builder": {"nozomi:vantage_alert": {"is_parsed": true, "data_format": "json"}, "nozomi:vantage_asset": {"is_parsed": true, "data_format": "json"}, "nozomi:vantage_health_log": {"is_parsed": true, "data_format": "json"}, "nozomi:vantage_link": {"is_parsed": true, "data_format": "json"}, "nozomi:vantage_session": {"is_parsed": true, "data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}}}, "sourcetype_builder": {"nozomi:vantage_alert": {"metadata": {"event_count": 0, "data_input_name": "vantage_alert", "extractions_count": 0, "cims_count": 0}}, "nozomi:vantage_asset": {"metadata": {"event_count": 0, "data_input_name": "vantage_asset", "extractions_count": 0, "cims_count": 0}}, "nozomi:vantage_session": {"metadata": {"event_count": 0, "data_input_name": "vantage_session", "extractions_count": 0, "cims_count": 0}}, "nozomi:vantage_health_log": {"metadata": {"event_count": 0, "data_input_name": "vantage_health_log", "extractions_count": 0, "cims_count": 0}}, "nozomi:vantage_link": {"metadata": {"event_count": 0, "data_input_name": "vantage_link", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1686826029_82", "progress": 1.0}}