
[s3_sink]
python.version = python3
param.account_name = <string> Account Name. It's a required parameter.
param.aws_region = <string> AWS Region. It's a required parameter.
param.bucket = <string> Bucket. It's a required parameter.
param.prefix = <string> Prefix.
param.filename = <string> Filename. It's a required parameter.
param.compress_results = <list> Compress Results. It's a required parameter. It's default value is 1.
param.results_type = <list> Results type. It's a required parameter. It's default value is csv.

