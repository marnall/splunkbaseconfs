[]
access = read : [ * ], write : [ admin, power ]
export = system

[eventtypes]
export = system


[props]
export = system


[transforms]
export = system


[tags]
export = system

[collections]
access = read : [ * ], write : [ admin,cs_admin,cs_supervisor]

[views]
export = none

[savedsearches]
access = read : [ * ]
export = none

[workflow_actions/Cisco_Investigate_src]
access = read : [ * ], write : [ * ]
export = system


[workflow_actions/Cisco_Investigate_Translated_src]
access = read : [ * ], write : [ * ]
export = system


[workflow_actions/Cisco_Investigate_dest]
access = read : [ * ], write : [ * ]
export = system


[workflow_actions/Cisco_Investigate_domain]
access = read : [ * ], write : [ * ]
export = system


[workflow_actions/Cisco_Investigate_url]
access = read : [ * ], write : [ * ]
export = system

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[alert_actions]
export = system

[alerts]
export = system

[restmap]
export = system

[lookups]
export = system

