[<proxy_stanza>]
*This is how the Proxy is configured

proxy_url = <value>
* The Proxy URL

proxy_user = <value>
*The Proxy User for authenticated proxies.

use_ssl = <value>
* Optional. Set to true to use SSL (https)

verify_ssl = <value>
* Optional. Set to True to verify the SSL

proxy_name = <value>
* The proxy name for display purposes.

guid = <value>
* The distinct guid for proxy access