

[send_to_teams]
python.version = python3
param.webhook = <string> Webhook. It's a required parameter.
param.title = <string> Title. It's a required parameter.
param.summary = <string> Summary.
param.subtitle = <string> Subtitle.
param.image_url = <string> Image URL.
param.theme_colour = <string> Theme colour.  It's default value is #0072C6.
param.fields = <string> Fields.
param.fields_ordering = <list> Fields ordering.  It's default value is order_by_alphabet.
param.action_button_name = <string> Action button name.  It's default value is Open in Splunk.
param.action_button_url = <string> Action button URL.  It's default value is $results_link$.
param.additional_buttons = <string> Additional buttons.

