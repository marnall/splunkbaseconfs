[proofpoint_url_isolation://<name>]
api_key = Proofpoint Isolation API Key
chunk_size = Number of records processed per event 1 to 10000 (default: 10000)  Default: 10000
index = Default: default
interval = Time interval of input in seconds from 1 to 86400 (default: 600)  Default: 600
page_size = Number of records processed per request 1 to 10000 (default: 10000)  Default: 10000
request_timeout = Number of seconds before the web request timeout occurs (default: 60)  Default: 60

