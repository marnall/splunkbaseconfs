{"basic_builder": {"appname": "TA-mulesoft-cloudhub-add-on-for-splunk", "friendly_name": "Mulesoft Cloudhub Add-on for Splunk", "version": "1.1.9", "author": "iDelta", "description": "For ingesting data from the MuleSoft API's", "theme": "#000", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.3", "tab_build_no": "0", "build_no": 22}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "mulesoft:queue", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "mulesoftqueue", "title": "mulesoftQueue", "description": "", "type": "customized", "parameters": [{"required": true, "name": "org_id", "label": "org_id", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"required": true, "name": "env_id", "label": "env_id", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account3"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "org_id", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "env_id", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport requests\nimport utils.handleError as h_err\n\ndef validate_input(helper, definition):\n\tpass\n\ndef collect_events(helper, ew):\n\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    access_token = rauth.get_access_token(client_id, client_secret)\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    if(access_token):\n\n        regions_url=\"https://anypoint.mulesoft.com/mq/admin/api/v1/organizations/\"+org_id+\"/environments/\"+env_id+\"/regions\"\n        header = {\n            'Authorization': 'Bearer ' + access_token\n        }\n\n        #get list of regions\n        regions = requests.get(regions_url, headers=header)\n        #loop over list of regions, returning a list of region_ids\n        regions_json = regions.json()\n        \n        if regions.ok:\n    \n            region_ids=[]\n            for region in regions_json:\n                region_id=region['regionId']\n                region_ids.append(region_id)\n    \n    \n            for region_id in region_ids:\n                destinations_url=\"https://anypoint.mulesoft.com/mq/admin/api/v1/organizations/\"+org_id+\"/environments/\"+env_id+\"/regions/\"+region_id+\"/destinations\"\n    \n                # get list of queues in each region (destination)\n                destinations = requests.get(destinations_url, headers=header)\n    \n                #if there are queues in that region (destination), get queueId and add to queue_ids list\n                destinations_json = destinations.json()\n     \n                if destinations.ok:\n                    \n                    queue_ids = []\n                    for destination in destinations_json:\n                        queue_ids.append(destination['queueId'])\n    \n                    for queue_id in queue_ids:\n                        queue_url=\"https://anypoint.mulesoft.com/mq/admin/api/v1/organizations/\"+org_id+\"/environments/\"+env_id+\"/regions/\"+region_id+\"/destinations/queues/\"+queue_id\n                        \n                        queue = requests.get(queue_url, headers=header)\n                        \n                        if queue.ok:\n                            queues={\n            \t                \"orgId\":org_id,\n            \t                \"envId\":env_id,\n            \t                \"regionId\":region_id,\n            \t                \"data\":queue,\n                                }\n            \n                            event = helper.new_event(\n                                time=datetime.datetime.now(),\n                                data=json.dumps(queues),\n                                source=\"mulesoft:queuediscovery\",\n                                index=helper.get_output_index(),\n                                sourcetype=\"mulesoft:queuediscovery\")\n                            ew.write_event(event)\n                        \n                        else:\n                            h_err.handle_error=(helper,queue_url,queue,org_id,env_id)\n                \n                else:\n                    h_err.handle_error(helper,destinations_url,destinations,org_id,env_id)\n                    \n        else:\n            h_err.handle_error(helper,regions_url,regions,org_id,env_id)\n            \n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"name": "env_id", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"name": "global_account", "value": "account3"}], "uuid": "c5bc2759972e46f3a37c2961eb9ecd5f", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:queuediscovery", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "queuediscovery", "title": "queueDiscovery", "description": "", "type": "customized", "parameters": [{"required": true, "name": "org_id", "label": "org_id", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"required": true, "name": "env_id", "label": "env_id", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account3"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "org_id", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "env_id", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport requests\nimport utils.handleError as h_err\n\ndef validate_input(helper, definition):\n\tpass\n\ndef collect_events(helper, ew):\n\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    access_token = rauth.get_access_token(client_id, client_secret)\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n    \n    if(access_token):\n        #get list of regions\n        regions_url=\"https://anypoint.mulesoft.com/mq/admin/api/v1/organizations/\"+org_id+\"/environments/\"+env_id+\"/regions\"\n        header = {\n            'Authorization': 'Bearer ' + access_token\n        }\n        \n        regions = requests.get(regions_url, headers=header)\n        \n        if regions.ok:\n        \n            #loop over list of regions, returning a list of region_ids\n            regions_json = regions.json()\n            region_ids=[]\n            for region in regions_json:\n                region_ids.append(region['regionId'])\n                \n    \n     \n            #for each region, call to destinations endpoint and add data to destinations_json\n            for region_id in region_ids:\n                destinations_url=\"https://anypoint.mulesoft.com/mq/admin/api/v1/organizations/\"+org_id+\"/environments/\"+env_id+\"/regions/\"+region_id+\"/destinations\"\n                \n                # get list of queues in each region (destination)\n                destinations = requests.get(destinations_url, headers=header)\n                \n                if destinations.ok:\n                    destinations_json = destinations.json()\n        \n                    #If there is data in destinations_json, write it plus org_id env_id and region_id to a splunk event\n                    if destinations_json:\n                        \n                        for destination in destinations_json:\n                        \n                            queues={\n                                \"orgId\":org_id,\n                                \"envId\":env_id,\n                                \"regionId\":region_id,\n                                \"data\":destination,\n                                }\n                           \n                \n                            event = helper.new_event(\n                                time=datetime.datetime.now(),\n                                data=json.dumps(queues),\n                                source=\"mulesoft:queuediscovery\",\n                                index=helper.get_output_index(),\n                                sourcetype=\"mulesoft:queuediscovery\")\n                            ew.write_event(event)\n                else:\n                    h_err.handle_error(helper,destinations_url,destinations,org_id,env_id)\n        \n        else:\n            h_err.handle_error(helper,regions_url,regions,org_id,env_id)\n\n    \n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n  \n\n\n\n", "customized_options": [{"name": "org_id", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"name": "env_id", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"name": "global_account", "value": "account3"}], "uuid": "29787489a9e447a8ba5b3136f7796b06", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:versions", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "versions", "title": "versions", "description": "", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    \n    \n    url = \"https://anypoint.mulesoft.com/cloudhub/api/mule-versions\"\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    \n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n        }\n\n        r = requests.get(url, headers=header)\n\n        if r.ok:\n            response_json = r.json()\n    \n            event = helper.new_event(\n                time=datetime.datetime.now(),\n                data=json.dumps(response_json),\n                source=\"mulesoft:versions\",\n                index=helper.get_output_index(),\n                sourcetype=\"mulesoft:versions\")\n            ew.write_event(event)\n        else:\n            h_err.handle_error(helper,url,r,\"No_orgID\",\"No_envID\")\n\n        \n\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "global_account", "value": "account0"}], "uuid": "8cac70002ae74dcab0c511af0b445f10", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:organization", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "organization", "title": "organization", "description": "", "type": "customized", "parameters": [{"required": true, "name": "env_id", "label": "Env ID", "default_value": "", "placeholder": "Env ID", "help_string": "", "type": "text", "format_type": "text", "value": "92851106-0804-4698-8fad-8651fdbf8de8"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}], "data_inputs_options": [{"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    env_id = helper.get_arg(\"env_id\")\n    \n    \n    \n    url = \"https://anypoint.mulesoft.com/cloudhub/api/organization/\"\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    \n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n            'X-ANYPNT-ENV-ID': env_id\n        }\n\n        r = requests.get(url, headers=header)\n\n        if r.ok:\n  \n            response_json = r.json()\n    \n            event = helper.new_event(\n                data=json.dumps(response_json),\n                source=\"mulesoft:organization\",\n                index=helper.get_output_index(),\n                sourcetype=\"mulesoft:organization\")\n            ew.write_event(event)\n\n        else:\n            h_err.handle_error(helper,url,r,\"No_orgID\",env_id)\n            \n        \n\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "env_id", "value": "92851106-0804-4698-8fad-8651fdbf8de8"}, {"name": "global_account", "value": "account0"}], "uuid": "fe5046e70b0c4b4eb44329f031a8bb04", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:environments", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "environments", "title": "environments", "description": "", "type": "customized", "parameters": [{"required": false, "name": "org_id", "label": "Org ID", "default_value": "", "placeholder": "Org ID", "help_string": "", "type": "text", "format_type": "text", "value": "70bef61a-49b9-4082-9a0d-32af5f05358d"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Org ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    \n    \n    \n    \n    \n    url = \"https://anypoint.mulesoft.com/accounts/api/organizations/\"+org_id+\"/environments\"\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    \n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n        }\n\n        r = requests.get(url, headers=header)\n\n        if r.ok:\n \n            response_json = r.json()\n    \n    \n            if(response_json is not None):\n                for m_env in response_json['data']:\n    \n                    event = helper.new_event(\n                        data=json.dumps(m_env),\n                        source=\"mulesoft:environments\",\n                        index=helper.get_output_index(),\n                        sourcetype=\"mulesoft:environments\")\n                    ew.write_event(event)\n        else:\n            h_err.handle_error(helper,url,r,org_id,\"No_envID\")\n        \n\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "70bef61a-49b9-4082-9a0d-32af5f05358d"}, {"name": "global_account", "value": "account0"}], "uuid": "a82161328ef14a9598bf088a2edee9c0", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:mulesoftalerts", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "mulesoftalerts", "title": "mulesoftalerts", "description": "", "type": "customized", "parameters": [{"required": true, "name": "env_id", "label": "Env ID", "default_value": "", "placeholder": "Env ID", "help_string": "", "type": "text", "format_type": "text", "value": "357c6f6e-68b6-40e2-8d44-690f52c6135f"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    env_id = helper.get_arg(\"env_id\")\n    \n    url = \"https://anypoint.mulesoft.com/cloudhub/api/v2/alerts/\"\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    \n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n            'X-ANYPNT-ENV-ID': env_id\n        }\n\n        r = requests.get(url, headers=header)\n\n        if r.ok:\n            response_json = r.json()\n    \n            if response_json is not None:\n                for m_alert in response_json['data']:\n                    event = helper.new_event(\n                        data=json.dumps(m_alert),\n                        source=\"mulesoft:mulesoftalerts\",\n                        index=helper.get_output_index(),\n                        sourcetype=\"mulesoft:mulesoftalerts\")\n                    ew.write_event(event)\n        else:\n            h_err.handle_error(helper,url,r,\"No_orgID\",env_id)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "env_id", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "value": "account1"}], "uuid": "9954df67252e48a3a8e640ff1574b812", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:triggeredalerts", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "triggeredalerts", "title": "triggeredalerts", "description": "", "type": "customized", "parameters": [{"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Env ID", "type": "text", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "customized_options": [{"name": "env_id", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "value": "account1"}], "code": "import os\nimport sys\nimport time\nfrom datetime import datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport requests\nimport utils.handleError as h_err\n\n\ndef validate_input(helper, definition):\n    pass\n\n\ndef collect_events(helper, ew):\n\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    url = \"https://anypoint.mulesoft.com/cloudhub/api/v2/alerts/\"\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n            'X-ANYPNT-ENV-ID': env_id\n        }\n\n        r = requests.get(url, headers=header)\n\n        response_json = r.json()\n\n        if r.ok:\n\n            if response_json is not None and 'data' in response_json:\n    \n                for m_alert in response_json['data']:\n    \n                    sub_url = \"https://anypoint.mulesoft.com/cloudhub/api/v2/alerts/\"+m_alert['id']+\"/history\"\n    \n                    sub_r = requests.get(sub_url,headers=header)\n                    sub_response_json = sub_r.json()\n                    alerts = sub_response_json['data']\n                    sortedResponse = sorted(alerts, key=lambda x: x['triggeredAt'])\n                    helper.log_info(sortedResponse)\n    \n                    for t_alert in sortedResponse:\n    \n                        lastCheckpointTimestamp = helper.get_check_point('alerts_'+env_id+\"_\"+m_alert['id'])\n    \n                        if lastCheckpointTimestamp is None:\n                            lastCheckpointTimestamp = 0\n    \n                        triggeredAtTimestamp = int(t_alert['triggeredAt'])\n    \n                        if lastCheckpointTimestamp < triggeredAtTimestamp:\n    \n                            t_alert['environmentId'] = env_id\n                            t_alert['organizationId'] = org_id\n                            t_alert['alertId'] = m_alert['id']\n    \n                            event = helper.new_event(\n                                    data=json.dumps(t_alert),\n                                    source=\"mulesoft:triggeredalerts\",\n                                    index=helper.get_output_index(),\n                                    sourcetype=\"mulesoft:triggeredalerts\")\n                            ew.write_event(event)\n    \n                            # save checkpoint\n                            key = 'alerts_'+env_id+\"_\"+m_alert['id']\n                            state = t_alert['triggeredAt']\n                            helper.save_check_point(key, state)\n                            \n        else:\n            h_err.handle_error(helper,url,r,\"No_orgID\",env_id)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n\n\n\n", "uuid": "80ec10a45a204aa5b0a60df13c2ed0e1", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:mqstats:realtime", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "mqstats_realtime", "title": "mqstats:realtime", "description": "", "type": "customized", "parameters": [{"required": true, "name": "org_id", "label": "Org ID", "default_value": "", "placeholder": "organization ID", "help_string": "", "type": "text", "format_type": "text", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"required": true, "name": "env_id", "label": "Env ID", "default_value": "", "placeholder": "environment ID", "help_string": "", "type": "text", "format_type": "text", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"required": true, "name": "region", "label": "Region", "default_value": "", "placeholder": "Region ID", "help_string": "The Region ID i.e. 'eu-west-1'.", "type": "text", "format_type": "text", "value": "us-east-1"}, {"required": true, "name": "destination_id", "label": "Destination ID", "default_value": "", "placeholder": "The queue name", "help_string": "Multiple ID's can be entered, use comma as a delimiter.", "type": "text", "format_type": "text", "value": "splunktest,splunktest2"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account3"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "organization ID"}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "environment ID"}, {"type": "customized_var", "name": "region", "title": "Region", "description": "The Region ID i.e. 'eu-west-1'.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Region ID"}, {"type": "customized_var", "name": "destination_id", "title": "Destination ID", "description": "Multiple ID's can be entered, use comma as a delimiter.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "The queue name"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n\n    org_id = helper.get_arg(\"org_id\")\n\n    env_id = helper.get_arg(\"env_id\")\n\n    region = helper.get_arg(\"region\")\n\n    destinations = helper.get_arg(\"destination_id\")\n\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n\n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n\n        }\n\n        destinations = destinations.replace(\" \",\"\")\n\n        url = \"https://anypoint.mulesoft.com/mq/stats/api/v1/organizations/\"+org_id+\"/environments/\"+env_id+\"/regions/\"+region+\"/queues?destinationIds=\"+destinations\n\n\n        r = requests.get(url, headers=header)\n        \n        if r.ok:\n\n            response_json = r.json()\n    \n            json_check = json.dumps(response_json)\n    \n            if \"Destination not found\" in json_check:\n                helper.log_error(\"given destination not found\")\n            else:\n                for message_set in response_json:\n    \n                    message_set['org_id'] = org_id\n                    message_set['env_id'] = env_id\n                    message_set['region'] = region\n    \n                    event = helper.new_event(\n                        time=datetime.datetime.now(),\n                        data=json.dumps(message_set),\n                        source=\"mulesoft:mqstats:realtime\",\n                        index=helper.get_output_index(),\n                        sourcetype=\"mulesoft:mqstats:realtime\")\n                    ew.write_event(event)\n        \n        else:\n            h_err.handle_error(helper,url,r,org_id,env_id)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"name": "env_id", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"name": "region", "value": "us-east-1"}, {"name": "destination_id", "value": "splunktest,splunktest2"}, {"name": "global_account", "value": "account3"}], "uuid": "0e58e845c91c455889763389d6f06bf0", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:cpu", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "cpu", "title": "cpu", "description": "", "type": "customized", "parameters": [{"name": "org_id", "label": "Org ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "2df495b4-e16a-4a06-a49b-18d63b13e359"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"cpu\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id,endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "2df495b4-e16a-4a06-a49b-18d63b13e359"}, {"name": "env_id", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "value": "account1"}], "uuid": "51d77c5da23e44fb9e4b19c522c3b699", "sample_count": "4468"}, {"index": "default", "sourcetype": "mulesoft:stats:diskwritebytes", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "diskwritebytes", "title": "diskWriteBytes", "description": "", "type": "customized", "parameters": [{"required": true, "name": "org_id", "label": "Org ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"required": true, "name": "env_id", "label": "Env ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account2"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"diskWriteBytes\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id,endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"name": "env_id", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"name": "global_account", "value": "account2"}], "uuid": "1cb2365c5c0542cfbf5faba58bec3c0d", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:diskreadbytes", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "diskreadbytes", "title": "diskReadBytes", "description": "", "type": "customized", "parameters": [{"required": true, "name": "org_id", "label": "Org ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"required": true, "name": "env_id", "label": "Env ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account2"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"diskReadBytes\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id,endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"name": "env_id", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"name": "global_account", "value": "account2"}], "uuid": "91ff30d22dbe4ab8a2528337cb98667b", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:memorypercentageused", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "memorypercentageused", "title": "memoryPercentageUsed", "description": "", "type": "customized", "parameters": [{"name": "org_id", "label": "Org ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account2"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"memoryPercentageUsed\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id,endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"name": "env_id", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"name": "global_account", "value": "account2"}], "uuid": "62913ca5af1847b39e192d99d8877a40", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:memorytotalused", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "memorytotalused", "title": "memoryTotalUsed", "description": "", "type": "customized", "parameters": [{"required": true, "name": "org_id", "label": "Org ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"required": true, "name": "env_id", "label": "Env ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account2"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"memoryTotalUsed\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id,endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"name": "env_id", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"name": "global_account", "value": "account2"}], "uuid": "d682c04fb6a442b09e034b4312b987e1", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:networkin", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "networkin", "title": "networkIn", "description": "", "type": "customized", "parameters": [{"name": "org_id", "label": "Org ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "0299b81f-5a87-4746-8f09-9ca24c06d01f"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "bbdb9073-d42e-41b4-8ee4-71f037e24c49"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account4"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n\n \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    helper.log_debug(\"New Token is:  \" + access_token)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"networkIn\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id, endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "0299b81f-5a87-4746-8f09-9ca24c06d01f"}, {"name": "env_id", "value": "bbdb9073-d42e-41b4-8ee4-71f037e24c49"}, {"name": "global_account", "value": "account4"}], "uuid": "1941c9e927ff428199334f31c2cf2bd5", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:memorytotalmax", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "memorytotalmax", "title": "memoryTotalMax", "description": "", "type": "customized", "parameters": [{"name": "org_id", "label": "Org ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account2"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"memoryTotalMax\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id,endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "eb0f5503-9392-4793-ac0c-529ea3bebd57"}, {"name": "env_id", "value": "39bfbe01-f096-4132-8c6b-3f7e21f1f427"}, {"name": "global_account", "value": "account2"}], "uuid": "418ba5d335024152a529c979c631b1fa", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:networkout", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "networkout", "title": "networkOut", "description": "", "type": "customized", "parameters": [{"name": "org_id", "label": "Org ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "2df495b4-e16a-4a06-a49b-18d63b13e359"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"networkOut\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id, endpoint, access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "2df495b4-e16a-4a06-a49b-18d63b13e359"}, {"name": "env_id", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "value": "account1"}], "uuid": "f6e557bf57b240ffabe7762819b24e81", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:stats:mulesoftevents", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "mulesoftevents", "title": "mulesoftevents", "description": "", "type": "customized", "parameters": [{"required": true, "name": "org_id", "label": "Org ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "2df495b4-e16a-4a06-a49b-18d63b13e359"}, {"required": true, "name": "env_id", "label": "Env ID", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        \n        endpoint = \"events\"\n        \n        for app_name in app_names:\n            x =  rd.get_data(helper, app_name, env_id,endpoint,access_token, utils.get_items)\n        \n            wev.write_to_index(helper,app_name, org_id, env_id, endpoint,x,ew)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "2df495b4-e16a-4a06-a49b-18d63b13e359"}, {"name": "env_id", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "value": "account1"}], "uuid": "cd4f39bf6c844a1a912a498fe5dafea9", "sample_count": "2790"}, {"index": "default", "sourcetype": "mulesoft:deployments", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "deployments", "title": "deployments", "description": "", "type": "customized", "parameters": [{"name": "org_id", "label": "Org ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Org ID", "type": "text", "value": "8f41cf98-95b9-4957-9430-8627be6c9f4f"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Env ID", "type": "text", "value": "ccca50f17e6e454083f5b76f4cde3a08"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Org ID"}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    \n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n    \n    access_token = rauth.get_access_token(client_id, client_secret) \n    \n    \n    app_names = gan.get_application_name(access_token,env_id,helper)\n    \n    if(access_token):\n        for app in app_names:\n        \n            url = \"https://anypoint.mulesoft.com/cloudhub/api/v2/applications/\"+app+\"/deployments\"\n      \n            header = {\n                'Authorization': 'Bearer ' + access_token,\n                'X-ANYPNT-ENV-ID': env_id\n            }\n    \n            r = requests.get(url, headers=header)\n            \n            if r.ok:\n            \n                response_json = r.json()\n                \n                if response_json is not None:\n                    for m_dep in response_json['data']:\n        \n                        m_dep['domain'] = app\n        \n                        event = helper.new_event(\n                            time=datetime.datetime.now(),\n                            data=json.dumps(m_dep),\n                            source=\"mulesoft:deployments\",\n                            index=helper.get_output_index(),\n                            sourcetype=\"mulesoft:deployments\")\n                        ew.write_event(event)\n            else:\n                h_err.handle_error(helper,url,r,org_id,env_id)\n \n        \n\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "org_id", "value": "8f41cf98-95b9-4957-9430-8627be6c9f4f"}, {"name": "env_id", "value": "ccca50f17e6e454083f5b76f4cde3a08"}, {"name": "global_account", "value": "account1"}], "uuid": "2ab010a9a61946e2bfa5588039162d9c", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:applicationlogs", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "applicationlogs", "title": "applicationlogs", "description": "", "type": "customized", "parameters": [{"name": "domain", "label": "Domain", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Domain", "type": "text", "value": "covidtrackingdata"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Env ID", "type": "text", "value": "5049942d-47bd-4620-91eb-d916adaa6d1c"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account3"}], "data_inputs_options": [{"type": "customized_var", "name": "domain", "title": "Domain", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Domain"}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport requests\nimport utils.getInstanceIDs as gii\nimport utils.handleError as h_err\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n    #Read varialbes from inputs\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    domain = helper.get_arg(\"domain\")\n    env_id = helper.get_arg(\"env_id\")\n\n    #Obtain the access token\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    #If a valid access token has been obtained then proceed\n    if(access_token):\n    \n        deployment_url = \"https://anypoint.mulesoft.com/cloudhub/api/v2/applications/\"+domain+\"/deployments\"\n        \n        instanceIDs = gii.get_instance_ids(access_token,domain,env_id,helper)\n        previous_count = 0\n        current_count = len(instanceIDs)\n        \n        header = {\n            'Authorization': 'Bearer ' + access_token,\n            'X-ANYPNT-ENV-ID': env_id\n        }\n        \n        #Keep iterating so long as no new ids are discovered during the course of the API call\n        while previous_count!=current_count:\n            \n            previous_count = current_count\n            \n            #Loop over each id in the latest set of instanceIDs\n            for i_id in instanceIDs:\n                \n                \n                #helper.delete_check_point(\"applicationlogs_\"+env_id+\"_\"+i_id)\n                offset = helper.get_check_point(\"applicationlogs_\"+env_id+\"_\"+i_id)\n            \n                if offset is None:\n                    offset = 0\n                    \n                #Assume initially that not all possible messages are going to be returned by the call\n                need_additional_iterations = True\n                \n                while need_additional_iterations:\n                    \n                    url = \"https://anypoint.mulesoft.com/cloudhub/api/v2/applications/\"+domain+\"/instances/\"+i_id+\"/logs?limit=2000&tail=false&offset=\"+str(offset)    \n            \n                    #Make the GET request and jsonify the response\n                    r = requests.get(url,headers=header)\n                    response = r.json()\n                    \n                    if r.ok:\n         \n                        if 'data' in response:\n                            #Sort the response based on the timestamp key\n                            sortedResponse = sorted(response['data'], key=lambda x: x['timestamp'])\n                            \n                            #For each line in the sortedResponse\n                            for d_item in sortedResponse:\n                                    \n                                d_item['env_id']=env_id\n                                d_item['domain']=domain\n                                        \n                                event = helper.new_event(\n                                    time=datetime.datetime.now(),\n                                    data=json.dumps(d_item),\n                                    source=\"mulesoft:applicationlogs\",\n                                    index=helper.get_output_index(),\n                                    sourcetype=\"mulesoft:applicationlogs\")\n                                ew.write_event(event)\n                    \n                            #If there were fewer than 2000 results returned then assume there is nothing further to return in this API call\n                            if len(sortedResponse)<2000:\n                                need_additional_iterations = False\n                            \n                            else:\n                            #If the max number of messages was returned then need to fetch the next block of messages and process those\n                                offset+=2000\n                                \n                        else:\n                            need_additional_iterations = False\n                            \n                    else:\n                        h_err.handle_error(helper,url,r,\"No_orgID\" ,env_id)\n                        need_additional_iterations = False\n                \n                if len(sortedResponse)>0:\n                    key = \"applicationlogs_\"+env_id+\"_\"+i_id\n                    state = offset+len(sortedResponse)\n                    #state = sortedResponse[-1]['timestamp']\n                    helper.save_check_point(key, state)\n                      \n            #Once events have been written check to see if any further deployments have been added since the call was made\n            instanceIDs = gii.get_instance_ids(access_token,domain,env_id,helper)\n            current_count = len(instanceIDs)\n   \n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n            \n\n", "customized_options": [{"name": "domain", "value": "covidtrackingdata"}, {"name": "env_id", "value": "5049942d-47bd-4620-91eb-d916adaa6d1c"}, {"name": "global_account", "value": "account3"}], "uuid": "1cff851eccd24f20be06c75f682ad810", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:discovery", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "discovery", "title": "discovery", "description": "", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n\ndef validate_input(helper, definition):\n\tpass\n\ndef collect_events(helper, ew):\n\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n\n\n\n    url = \"https://anypoint.mulesoft.com/accounts/api/me/\"\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n    \n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n        }\n\n        r = requests.get(url, headers=header)\n        \n        if r.ok:\n\n            response_json = r.json()\n    \n            memberOrgs = []\n            for mo in response_json['user']['memberOfOrganizations']:\n    \n                url = \"https://anypoint.mulesoft.com/accounts/api/organizations/\"+mo['id']+\"/environments\"\n    \n                r_env = requests.get(url, headers=header)\n                \n                if r_env.ok:\n    \n                    response_env_json = r_env.json()\n        \n                    for environment in response_env_json['data']:\n        \n                        if mo['parentId']:\n                            org_env_data = {\n                                'orgID': mo['id'],\n                                'orgName': mo['name'],\n                                'envID': environment['id'],\n                                'envName': environment['name'],\n                                'parentOrgID': mo['parentId'],\n                                'parentOrgName': mo['parentName'],\n                                }\n        \n                        else:\n                            org_env_data = {\n                                'orgID': mo['id'],\n                                'orgName': mo['name'],\n                                'envID': environment['id'],\n                                'envName': environment['name'],\n                                }\n        \n                        event = helper.new_event(\n                            data=json.dumps(org_env_data),\n                            source=\"mulesoft:discovery\",\n                            index=helper.get_output_index(),\n                            sourcetype=\"mulesoft:discovery\")\n                        ew.write_event(event)\n                else:\n                    h_err.handle_error(helper,url,r,\"No_orgID\",\"No_envID\")\n\n        else:\n            h_err.handle_error(helper,url,r,\"No_orgID\",\"No_envID\")\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n        \n", "customized_options": [{"name": "global_account", "value": "account1"}], "uuid": "54cfc7f818104d3ab02023946ce42d2e", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:ping", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "ping", "title": "ping", "description": "", "type": "customized", "parameters": [{"name": "global_account", "label": "Global Account", "help_string": "", "required": false, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "has no effect - not required", "type": "global_account", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": false, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "has no effect - not required"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport re\n\n\ndef validate_input(helper, definition):\n\n    dummy = definition.parameters.get('dummy', None)\n    \n    pass\n\n\ndef collect_events(helper, ew):\n\n    url = 'https://anypoint.mulesoft.com/cloudhub/api/ping'\n    start = time.clock()\n    req = requests.get(url)\n    end = time.clock() - start\n    endMs = end*1000\n\n    capture_status = re.search('\\{\\\"status\\\"\\:([^}]*)', str(req.text))\n    status = str(capture_status.group(1))\n    json_obj = '{\"responseCode\":\"'+str(req.status_code)+'\", \"responseTimeMs\":\"'+str(endMs)+'\", \"status\":'+str(status)+'}'\n    json_dump = json.dumps(json_obj)\n    json_load = json.loads(json_dump)\n\n    event = helper.new_event(data=json_load,\n                                     time=None,\n                                     host=None,\n                                     index=helper.get_output_index(),\n                                     source=\"mulesoft:ping\",\n                                     sourcetype=\"mulesoft:ping\",\n                                     done=True,\n                                     unbroken=True)\n\n    ew.write_event(event)", "customized_options": [{"name": "global_account", "value": ""}], "uuid": "12f4e2e9cfc8420bab282733933daec0", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:mqstats:historic", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "mqstats_historic", "title": "mqstats_historic", "description": "", "type": "customized", "parameters": [{"name": "org_id", "label": "Org ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Org ID", "type": "text", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Env ID", "type": "text", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"name": "region", "label": "Region", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Region", "type": "text", "value": "us-east-1"}, {"name": "destination_id", "label": "Destination ID", "help_string": "Multiple ID's can be entered, use comma as a delimiter.", "required": true, "format_type": "text", "default_value": "", "placeholder": "Destination ID", "type": "text", "value": "splunktest,splunktest2"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account3"}], "data_inputs_options": [{"type": "customized_var", "name": "org_id", "title": "Org ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Org ID"}, {"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "region", "title": "Region", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Region"}, {"type": "customized_var", "name": "destination_id", "title": "Destination ID", "description": "Multiple ID's can be entered, use comma as a delimiter.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Destination ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n    #Read user input values as variables\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    org_id = helper.get_arg(\"org_id\")\n    env_id = helper.get_arg(\"env_id\")\n    region = helper.get_arg(\"region\")\n    destinations = helper.get_arg(\"destination_id\")\n\n    #Obtain the access token\n    access_token = rauth.get_access_token(client_id, client_secret)\n\n    if(access_token):\n\n        #Define the header\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n        }\n\n        #Remove any extraneous spaces from the destinations list\n        destinations = destinations.replace(\" \",\"\")\n        destinations = destinations.split(\",\")\n\n        #Loop over each destination\n        for destination in destinations:\n            \n            #Read the checkpoint for the current desintation\n            lastCheckpointTimestamp = helper.get_check_point(\"mqstats_historic_\"+str(org_id)+\"_\"+str(destination))\n            \n            \n            #If there is no checkpoint then set a start time of 1st of March 2021\n            if lastCheckpointTimestamp is None:\n                \n                '''\n                lastCheckpointTimestamp = \"2021-03-01T00:00:00.000Z\"\n                datetime_format = '%Y-%m-%dT%H:%M:%S.%fZ'\n                convertTimestamp = datetime.datetime.strptime(createdAtTimestamp, datetime_format)\n                lastCheckpointTimestamp = (convertTimestamp - datetime.datetime(1970, 1, 1)).total_seconds() - \n                '''\n                lastCheckpointTimestamp = datetime.datetime.now().timestamp() - 60\n            \n            \n            #datetime.datetime.fromtimestamp(s).strftime('%Y-%m-%d %H:%M:%S.%f')\n            \n            #2016-02-28T16:41:41.090Z\n            \n            #Defined the start and end times (and the period)\n            startDate_epoch = lastCheckpointTimestamp\n            endDate_epoch = datetime.datetime.now().timestamp()\n            #Convert these to a format that is usable by the API\n            \n            #Fri, 11 Jul 2015 08:49:37 GMT\n            \n            #startDate = datetime.datetime.fromtimestamp(startDate_epoch).strftime(\"%Y-%m-%dT%H:%M:%S.%fZ\")\n            \n            \n            \n            #endDate = datetime.datetime.fromtimestamp(endDate_epoch).strftime(\"%Y-%m-%dT%H:%M:%S.%fZ\")\n            \n            startDate = datetime.datetime.fromtimestamp(startDate_epoch).strftime(\"%a, %e %b %Y %H:%M:%S\")+\" BST\"\n            \n            endDate = datetime.datetime.fromtimestamp(endDate_epoch).strftime(\"%a, %e %b %Y %H:%M:%S\")+\" BST\"\n            \n            \n            period = 60\n\n            #startDate.replace(\"  \",\" \")\n\n            #startDate = startDate[:-4]+\"Z\"\n            #endDate = endDate[:-4]+\"Z\"\n\n            #Create the URL for the current destination\n            url = \"https://anypoint.mulesoft.com/mq/stats/api/v1/organizations/\"+org_id+\"/environments/\"+env_id+\"/regions/\"+region+\"/queues/\"+destination+\"?startDate=\"+startDate+\"&endDate=\"+endDate\n    \n            #Make the request\n            r = requests.get(url, headers=header)\n            \n            #If the request does not contain an error\n            if r.ok:\n    \n                #Get the json from the response object\n                response_json = r.json()\n                json_check = json.dumps(response_json)\n                \n                #If the destination doesn't exist then log an error message\n                if \"Destination not found\" in json_check:\n                    helper.log_error(\"given destination not found\")\n                else:\n                    \n                    #Read date \n\n                    message_set['org_id'] = org_id\n                    message_set['env_id'] = env_id\n                    message_set['region'] = region\n        \n                    event = helper.new_event(\n                        time=datetime.datetime.now(),\n                        data=json.dumps(message_set),\n                        source=\"mulesoft:mqstats:historic\",\n                        index=helper.get_output_index(),\n                        sourcetype=\"mulesoft:mqstats:historic\")\n                    ew.write_event(event)\n                    \n                    key = \"mqstats_historic_\"+str(org_id)+\"_\"+str(destination)\n                    state = endDate_epoch\n                    helper.save_check_point(key, state) \n            \n            else:\n                h_err.handle_error(helper,url,r,org_id,env_id)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n\n    \n\n", "customized_options": [{"name": "org_id", "value": "ad0e0029-ff88-44ab-928b-03dde2e09013"}, {"name": "env_id", "value": "f8a4ca9f-fa35-4daf-9028-96b15b638814"}, {"name": "region", "value": "us-east-1"}, {"name": "destination_id", "value": "splunktest,splunktest2"}, {"name": "global_account", "value": "account3"}], "uuid": "a796eed8c8a742e491bedbf551603446", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:notifications", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "notifications", "title": "notifications", "description": "", "type": "customized", "parameters": [{"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Env ID", "type": "text", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport requests\nimport utils.checkpoint as cp\nimport utils.handleError as h_err\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    env_id = helper.get_arg(\"env_id\")\n    \n\n    url = \"https://anypoint.mulesoft.com/cloudhub/api/notifications?limit=0\"\n    \n    #url = \"https://anypoint.mulesoft.com/cloudhub/api/applications/\"+domain+\"/notifications?limit=0\"\n\n    access_token = rauth.get_access_token(client_id, client_secret)\n\n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n            'X-ANYPNT-ENV-ID': env_id\n        }\n\n        r = requests.get(url, headers=header)\n\n        response_json = r.json()\n        \n        if r.ok:\n\n            if response_json is not None:\n    \n    \n                for m_not in response_json['data']:\n    \n                    \n                    createdAtTimestamp = m_not['createdAt']\n                    datetime_format = '%Y-%m-%dT%H:%M:%S.%fZ'\n                    convertTimestamp = datetime.datetime.strptime(createdAtTimestamp, datetime_format)\n                    epochTimestamp = (convertTimestamp - datetime.datetime(1970, 1, 1)).total_seconds()\n\n                    m_not['createdAt'] = epochTimestamp\n    \n                sortedResponse = sorted(response_json['data'], key=lambda x: x['createdAt'])\n                \n                #key = \"notifications_\"+str(env_id)\n                #helper.delete_check_point(key)\n                \n                lastCheckpointTimestamp = helper.get_check_point(\"notifications_\"+str(env_id))\n                \n                if lastCheckpointTimestamp is None:\n                    lastCheckpointTimestamp = 0\n    \n                for m_not in sortedResponse:\n    \n                    createdAtTimestamp = float(m_not['createdAt'])\n    \n                    if lastCheckpointTimestamp < createdAtTimestamp:\n    \n                        event = helper.new_event(\n                            data=json.dumps(m_not),\n                            source=\"mulesoft:notifications\",\n                            index=helper.get_output_index(),\n                            sourcetype=\"mulesoft:notifications\")\n                        ew.write_event(event)\n    \n                key = \"notifications_\"+str(env_id)\n                state = m_not['createdAt']\n                helper.save_check_point(key, state)        \n        \n        else:\n            h_err.handleError(helper,url,response,\"No_orgID\",env_id)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "env_id", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "value": "account1"}], "uuid": "d08457d62efc4b289d044dbb53b44b8c", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:mulesoftapplications", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "mulesoftapplications", "title": "mulesoftapplications", "description": "", "type": "customized", "parameters": [{"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Env ID", "type": "text", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account1"}], "data_inputs_options": [{"type": "customized_var", "name": "env_id", "title": "Env ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Env ID"}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils2 as utils\nimport utils.getAppName as gan\nimport utils.writeEvent as wev\nimport utils.retrieveData as rd\nimport utils.handleError as h_err\nimport requests\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n    global_account = helper.get_arg(\"global_account\")\n    client_id = global_account[\"username\"]\n    client_secret = global_account[\"password\"]\n    env_id = helper.get_arg(\"env_id\")\n\n\n\n    url = \"https://anypoint.mulesoft.com/cloudhub/api/v2/applications/\"\n\n    global_account = helper.get_arg(\"global_account\")\n    access_token = rauth.get_access_token(client_id, client_secret)\n\n    if(access_token):\n\n        header = {\n            'Authorization': 'Bearer ' + access_token,\n            'X-ANYPNT-ENV-ID': env_id\n        }\n\n        r = requests.get(url, headers=header)\n        \n        if r.ok:\n\n            response_json = r.json()\n    \n            if not response_json:\n                helper.log_info(\"No applications found in environment \" + env_id)\n            else:\n                for m_app in response_json:\n                    m_app['environmentId'] = env_id\n    \n                    event = helper.new_event(\n                        time=datetime.datetime.now(),\n                        data=json.dumps(m_app),\n                        source=\"mulesoft:mulesoftapplications\",\n                        index=helper.get_output_index(),\n                        sourcetype=\"mulesoft:mulesoftapplications\")\n                    ew.write_event(event)\n                    \n        else: \n            h_err.handle_error(helper,url,r,\"No_orgID\",env_id)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token.\")\n", "customized_options": [{"name": "env_id", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "global_account", "value": "account1"}], "uuid": "b276362e378842309f5cdf6d66f7693b", "sample_count": 0}, {"index": "default", "sourcetype": "mulesoft:notifications:perapplication", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "notifications_per_application", "title": "notifications_per_application", "description": "", "type": "customized", "parameters": [{"name": "env_id", "label": "Env ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Env ID", "type": "text", "value": "36717738-399a-4572-9cc2-c356c5ffc259"}, {"name": "domain", "label": "Domain", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "Domain", "type": "text", "value": "contactapi-79856"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type":