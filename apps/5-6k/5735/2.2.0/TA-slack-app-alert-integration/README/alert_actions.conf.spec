[slack_app_alert_integration]
param.channel = <string> Channel. It's a required parameter.
param.emoji = <string> Emoji.
param.bot_username = <string> Bot username.  It's default value is Splunk.
param.message = <string> Message. It's a required parameter.
param.auto_join_channel = <list> Auto-join channel.  It's default value is true.
