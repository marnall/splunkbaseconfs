import re
import json
from timestamp_utils import (
    get_epoch_ms,
    one_day_ms
)


def remove_https_from_host(host):
    return re.sub('^https?://', '', host)


def load_request_body(helper, request_body):
    if request_body:
        try:
            return json.loads(request_body)

        except:
            helper.log_error('Error converting body params to JSON, initializing body as an empty object: {}')

    return {}


def get_start_time_epoch_ms(start_date):
    now = get_epoch_ms()
    elapsed_ms = one_day_ms * int(start_date)
    return now - elapsed_ms


def is_historical_data_time_range(time_checkpoints, helper):
    """ Determines if the input is collecting historical data or not, used for Device Logs input. 
    If the input is collecting historical data, Device Details & Device CVEs requests are not triggered """

    time_diff = time_checkpoints['end_time'] - time_checkpoints['start_time']

    if time_diff > one_day_ms:
        helper.log_info('Collecting historical device data, device details & CVEs will NOT be collected.')
        return True

    helper.log_info('Non-historical device data time range, device details & CVEs will be collected.')
    return False









