{"alert_action_builder": {"modular_alerts": [{"description": "Removes a user from the Splunk SAML role mapping", "largeIcon": "", "smallIcon": "", "label": "Remove SAML User", "short_name": "remove_saml_user", "parameters": [{"format_type": "text", "required": true, "name": "username_field", "label": "Username field", "default_value": "", "help_string": "Field name in the results containing username to be removed from SAML role map", "type": "", "value": "splunk_server"}], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n   \n\n    # The following example gets the alert action parameters and prints them to the log\n    username_field = helper.get_param(\"username_field\")\n    helper.log_info(\"Removing user found in username_field={}\".format(username_field))\n\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    helper.log_info(\"server_uri={}\".format(helper.settings))\n \n    return 0\n", "uuid": "e826d304ac974195b71d14f862d3ad1c"}]}, "basic_builder": {"appname": "TA-saml-user-removal", "friendly_name": "SAML User Removal", "version": "1.0.0", "author": "luke.monahan@rivium.com.au", "description": "Contains a custom alert action to remove a SAML user role mapping from Splunk. Intended to be used as an automated action for when logs show a SAML user is removed from the directory.", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.0.0", "tab_build_no": "0", "build_no": 1}}