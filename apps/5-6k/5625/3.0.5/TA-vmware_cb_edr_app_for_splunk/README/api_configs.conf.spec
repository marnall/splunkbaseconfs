[<api_config_stanza>]
*This is how the api_config is configured
org_name = <value>
* Organization Name

cb_edr_env = <value>
* The CBC Environment (url, api required)

guid = <value>
* The GUID unique to this api_config

comment = <value>
* A descriptive comment

proxy_guid = <value>
* The guid of the proxy to use. Optional.