{"basic_builder": {"appname": "TA-mambu-audit-trail-collector", "friendly_name": "Mambu Audit Trail Collector", "version": "1.0.0", "author": "Leonardo Armesto", "description": "Mambu Audit Trail Collector enables a 360-degree view of all user activities that have been performed in the Mambu system. These activities are of two types: User Interface and API calls and offer a great way to understand what the users are doing and how they are using the Mambu application.", "theme": "#4fa484", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.0.0", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "audittrail", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "audittrail", "title": "Audit Trail", "description": "", "type": "customized", "parameters": [{"name": "mambu_audit_trail_endpoint", "label": "Mambu Audit Trail Endpoint URL", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "https://<YOUR_TENANT>.sandbox.mambu.com", "type": "text", "value": "https://naranja.mambu.com"}, {"name": "api_key", "label": "Api Key:", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "71BPRn8WYcbNiA1yPc6zDNCuTP5bTLD0"}, {"name": "event_source", "label": "Event Source:", "help_string": "The events that are supposed to be audited fall within the following categories: UI or API", "required": true, "possible_values": [{"value": "API", "label": "API"}, {"value": "UI", "label": "UI"}], "format_type": "multi_dropdownlist", "default_value": ["UI"], "placeholder": "", "type": "multi_dropdownlist", "value": ["API", "UI"]}, {"name": "resources", "label": "Resources:", "help_string": "Audited actions", "required": true, "possible_values": [{"value": "accounting", "label": "accounting"}, {"value": "accountingrates", "label": "accountingrates"}, {"value": "accounts", "label": "accounts"}, {"label": "activities", "value": "activities"}, {"label": "apiconsumers", "value": "apiconsumers"}, {"label": "apps", "value": "apps"}, {"label": "blockedips", "value": "blockedips"}, {"label": "branches", "value": "branches"}, {"label": "branding", "value": "branding"}, {"label": "cards", "value": "cards"}, {"label": "centres", "value": "centres"}, {"label": "clients", "value": "clients"}, {"label": "clienttypes", "value": "clienttypes"}, {"label": "comments", "value": "comments"}, {"label": "crons", "value": "crons"}, {"label": "currencies", "value": "currencies"}, {"label": "customfields", "value": "customfields"}, {"label": "customfieldsets", "value": "customfieldsets"}, {"label": "database", "value": "database"}, {"label": "documents", "value": "documents"}, {"label": "email", "value": "email"}, {"label": "federatedauthenticationsettings", "value": "federatedauthenticationsettings"}, {"label": "general", "value": "general"}, {"label": "glaccounts", "value": "glaccounts"}, {"label": "gljournalentries", "value": "gljournalentries"}, {"label": "groups", "value": "groups"}, {"label": "guarantees", "value": "guarantees"}, {"label": "indexratesources", "value": "indexratesources"}, {"label": "labels", "value": "labels"}, {"label": "linesofcredit", "value": "linesofcredit"}, {"label": "loanproducts", "value": "loanproducts"}, {"label": "loans", "value": "loans"}, {"label": "logins", "value": "logins"}, {"label": "notifications", "value": "notifications"}, {"label": "organization", "value": "organization"}, {"label": "portal", "value": "portal"}, {"label": "rates", "value": "rates"}, {"label": "reports", "value": "reports"}, {"label": "roles", "value": "roles"}, {"label": "savings", "value": "savings"}, {"label": "savingsproducts", "value": "savingsproducts"}, {"label": "search", "value": "search"}, {"label": "settings", "value": "settings"}, {"label": "sms", "value": "sms"}, {"label": "tasks", "value": "tasks"}, {"label": "tills", "value": "tills"}, {"label": "transactionchannels", "value": "transactionchannels"}, {"label": "transactions", "value": "transactions"}, {"label": "userroles", "value": "userroles"}, {"label": "users", "value": "users"}, {"label": "views", "value": "views"}, {"label": "webhooks", "value": "webhooks"}], "format_type": "multi_dropdownlist", "default_value": ["userroles", "users"], "placeholder": "", "type": "multi_dropdownlist", "value": ["userroles", "users"]}, {"name": "request_method", "label": "Request Method:", "help_string": "HTTP request method", "required": true, "possible_values": [{"value": "DELETE", "label": "DELETE"}, {"value": "GET", "label": "GET"}, {"value": "PATCH", "label": "PATCH"}, {"label": "POST", "value": "POST"}, {"label": "PUT", "value": "PUT"}], "format_type": "multi_dropdownlist", "default_value": ["POST", "GET"], "placeholder": "", "type": "multi_dropdownlist", "value": ["GET", "POST"]}, {"name": "occurred_at", "label": "Start Date (Ocurred at):", "help_string": "Optional: return events created after the given date", "required": false, "format_type": "text", "default_value": "", "placeholder": "YYYY-MM-DD", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "mambu_audit_trail_endpoint", "title": "Mambu Audit Trail Endpoint URL", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "https://<YOUR_TENANT>.sandbox.mambu.com"}, {"type": "customized_var", "name": "api_key", "title": "Api Key:", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "event_source", "title": "Event Source:", "description": "The events that are supposed to be audited fall within the following categories: UI or API", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "API", "label": "API"}, {"value": "UI", "label": "UI"}], "format_type": "multi_dropdownlist", "default_value": ["UI"], "placeholder": ""}, {"type": "customized_var", "name": "resources", "title": "Resources:", "description": "Audited actions", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "accounting", "label": "accounting"}, {"value": "accountingrates", "label": "accountingrates"}, {"value": "accounts", "label": "accounts"}, {"label": "activities", "value": "activities"}, {"label": "apiconsumers", "value": "apiconsumers"}, {"label": "apps", "value": "apps"}, {"label": "blockedips", "value": "blockedips"}, {"label": "branches", "value": "branches"}, {"label": "branding", "value": "branding"}, {"label": "cards", "value": "cards"}, {"label": "centres", "value": "centres"}, {"label": "clients", "value": "clients"}, {"label": "clienttypes", "value": "clienttypes"}, {"label": "comments", "value": "comments"}, {"label": "crons", "value": "crons"}, {"label": "currencies", "value": "currencies"}, {"label": "customfields", "value": "customfields"}, {"label": "customfieldsets", "value": "customfieldsets"}, {"label": "database", "value": "database"}, {"label": "documents", "value": "documents"}, {"label": "email", "value": "email"}, {"label": "federatedauthenticationsettings", "value": "federatedauthenticationsettings"}, {"label": "general", "value": "general"}, {"label": "glaccounts", "value": "glaccounts"}, {"label": "gljournalentries", "value": "gljournalentries"}, {"label": "groups", "value": "groups"}, {"label": "guarantees", "value": "guarantees"}, {"label": "indexratesources", "value": "indexratesources"}, {"label": "labels", "value": "labels"}, {"label": "linesofcredit", "value": "linesofcredit"}, {"label": "loanproducts", "value": "loanproducts"}, {"label": "loans", "value": "loans"}, {"label": "logins", "value": "logins"}, {"label": "notifications", "value": "notifications"}, {"label": "organization", "value": "organization"}, {"label": "portal", "value": "portal"}, {"label": "rates", "value": "rates"}, {"label": "reports", "value": "reports"}, {"label": "roles", "value": "roles"}, {"label": "savings", "value": "savings"}, {"label": "savingsproducts", "value": "savingsproducts"}, {"label": "search", "value": "search"}, {"label": "settings", "value": "settings"}, {"label": "sms", "value": "sms"}, {"label": "tasks", "value": "tasks"}, {"label": "tills", "value": "tills"}, {"label": "transactionchannels", "value": "transactionchannels"}, {"label": "transactions", "value": "transactions"}, {"label": "userroles", "value": "userroles"}, {"label": "users", "value": "users"}, {"label": "views", "value": "views"}, {"label": "webhooks", "value": "webhooks"}], "format_type": "multi_dropdownlist", "default_value": ["userroles", "users"], "placeholder": ""}, {"type": "customized_var", "name": "request_method", "title": "Request Method:", "description": "HTTP request method", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "DELETE", "label": "DELETE"}, {"value": "GET", "label": "GET"}, {"value": "PATCH", "label": "PATCH"}, {"label": "POST", "value": "POST"}, {"label": "PUT", "value": "PUT"}], "format_type": "multi_dropdownlist", "default_value": ["POST", "GET"], "placeholder": ""}, {"type": "customized_var", "name": "occurred_at", "title": "Start Date (Ocurred at):", "description": "Optional: return events created after the given date", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "YYYY-MM-DD"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\nimport os.path\nimport logging as Log\n\n# Validate if checkpoint log exists\ndef isCheckpoint(check_file, chkpntID):\n    file_exists = os.path.isfile(check_file) \n    if file_exists:\n        with open(check_file, 'r') as file:\n            chkpntID_list = file.read().splitlines()\n    else:\n        with open(check_file, 'w+') as file:\n            chkpntID_list = file.read().splitlines()\n\n    return (chkpntID in chkpntID_list)\n\n# Write checkpoint log\ndef write2Checkpoint(check_file, chkpntID):\n    with open(check_file,'a') as file:\n        file.writelines(chkpntID + '\\n')\n\n# Write to Splunk\ndef write2Splunk(helper, ew, data, sType):\n    data = json.dumps(data)\n    if sType == '':\n        event = helper.new_event(data, host=None, done=True, unbroken=True)\n    else:\n        event = helper.new_event(data, sourcetype=sType, host=None, done=True, unbroken=True)\n\n    try:\n        ew.write_event(event)\n    except Exception as e:\n        raise e\n\n# Filter/search parameters creation\ndef genParams(event_source, FROM,  request_method, resource, occurred_at):\n    lstParams = []\n    lstParams.append(('event_source[in]', event_source))\n    lstParams.append(('from', FROM))\n    lstParams.append(('size', '100'))\n    lstParams.append(('request_method[in]', request_method))\n    lstParams.append(('resource[in]', resource))\n\n    if occurred_at:\n        lstParams.append(('occurred_at[gte]', occurred_at))\n\n    params = []\n    for p in  lstParams:\n        params.append(p)\n\n    return tuple(params)\n\ndef validate_input(helper, definition):\n    mambu_audit_trail_endpoint = definition.parameters.get('mambu_audit_trail_endpoint', None)\n    api_key = definition.parameters.get('api_key', None)\n    event_source = definition.parameters.get('event_source', None)\n    resource = definition.parameters.get('resources', None)\n    request_method = definition.parameters.get('request_method', None)\n    occurred_at = definition.parameters.get('occurred_at', None)\n\ndef collect_events(helper, ew):\n    opt_mambu_audit_trail_endpoint = helper.get_arg('mambu_audit_trail_endpoint')\n    opt_api_key = helper.get_arg('api_key')\n    opt_event_source = helper.get_arg('event_source')\n    opt_resource = helper.get_arg('resources')\n    opt_request_method = helper.get_arg('request_method')\n    opt_occurred_at = helper.get_arg('occurred_at')\n\n    # Convert param lists to comma separated strings\n    opt_event_source = ','.join(opt_event_source)\n    opt_resource = ','.join(opt_resource)\n    opt_request_method = ','.join(opt_request_method)\n\n    headers = {\n        'apiKey': opt_api_key\n    }\n\n    # Audit Trail Endpoint V1\n    opt_mambu_audit_trail_endpoint = opt_mambu_audit_trail_endpoint + \"/api/v1/events\"\n    \n    # Path para el archivo de checkpoint utilizado (se crea un archivo por fecha YYYYMMDD)\n    dtFile = str(datetime.datetime.now().strftime(\"%Y%m%d\"))\n    check_file = os.path.join('/', os.path.dirname(os.path.abspath(__file__)), 'checkpoint', dtFile + '-mambu')\n\n    # We set to 0 the 'FROM' parameter (at first time)\n    FROM = 0\n\n    # Params generation\n    params = genParams(opt_event_source, FROM, opt_request_method, opt_resource, opt_occurred_at)\n    \n    # Session Init\n    client = requests.session()\n    \n    try:\n        # API Call\n        response = client.get(opt_mambu_audit_trail_endpoint, headers=headers, params=params, timeout=10)\n        \n        if response.status_code >= 200 and response.status_code <= 226:\n    \n            totalItemsCount = response.json()[\"totalItemsCount\"]\n            if totalItemsCount > 0:\n                # First Page\n                if len(response.json()[\"events\"]) > 0:\n                    for ev in response.json()[\"events\"]:\n        \n                        chkpntID = ev[\"occurred_at\"] + \"_\" + str(ev[\"response_code\"]) + \"_\" + ev[\"resource\"] + \"_\" + ev[\"event_source\"] + \"_\" + ev[\"client_ip\"] + \"_\" + ev[\"request_method\"] + \"_\" + ev[\"username\"]\n        \n                        # If checkpoint log does not exists \n                        if not isCheckpoint(check_file, chkpntID):\n                            # Write checkpoint log \n                            write2Checkpoint(check_file, chkpntID)\n                            \n                            # Write to Splunk \n                            write2Splunk(helper, ew, ev, '_json')\n        \n                # Maximum size per page is 100\n                size = 100\n        \n                # Recall every 100 events until Total is reached\n                while FROM <= totalItemsCount:\n        \n                    # 'FROM' parameter value will increase (by size -100-) until 'totalItemsCount' value is reached.\n                    FROM = FROM + size\n        \n                    # Params generation\n                    params = genParams(opt_event_source, FROM, opt_request_method, opt_resource, opt_occurred_at)\n                    \n                    # API Call\n                    response = client.get(opt_mambu_audit_trail_endpoint, headers=headers, params=params, timeout=10)\n        \n                    if len(response.json()[\"events\"]) > 0:\n                        for ev in response.json()[\"events\"]:\n                            chkpntID = ev[\"occurred_at\"] + \"_\" + str(ev[\"response_code\"]) + \"_\" + ev[\"resource\"] + \"_\" + ev[\"event_source\"] + \"_\" + ev[\"client_ip\"] + \"_\" + ev[\"request_method\"] + \"_\" + ev[\"username\"]\n        \n                            # If checkpoint log does not exists \n                            if not isCheckpoint(check_file, chkpntID):\n                                # Write checkpoint log\n                                write2Checkpoint(check_file, chkpntID)\n                                \n                                # Write to Splunk \n                                write2Splunk(helper, ew, ev, '_json')\n        else:\n            msg = json.dumps(response.json()[\"message\"])\n            status = str(response.status_code)\n           \n            Log.error(status + ' - Mambu Audit Trail connection Failure - ' + msg)\n            \n    except requests.exceptions.ConnectTimeout:\n        Log.error('Mambu Audit Trail ' + opt_mambu_audit_trail_endpoint + ', connection Timeout')", "customized_options": [{"name": "mambu_audit_trail_endpoint", "value": "https://naranja.mambu.com"}, {"name": "event_source", "value": ["API", "UI"]}, {"name": "resources", "value": ["userroles", "users"]}, {"name": "request_method", "value": ["GET", "POST"]}, {"name": "occurred_at", "value": ""}], "uuid": "9fa847c57c5340fc9e5ce1acdbfeaffc", "sample_count": 0}]}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}}}, "sourcetype_builder": {"audittrail": {"metadata": {"event_count": 0, "data_input_name": "audittrail", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1630416877_86", "progress": 0.39285714285714285}}