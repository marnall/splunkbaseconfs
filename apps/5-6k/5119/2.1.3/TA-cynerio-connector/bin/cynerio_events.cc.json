{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "__settings__.logging.loglevel",
        "host_ip",
        "global_account.username",
        "global_account.password",
        "marker"
    ],
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": [
                    {
                        "input": [
                            "{{marker}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_marker"
                    }
                ]
            },
            "request": {
                "url": "http://{{host_ip}}:5600/api/v1/external/alerts?marker={{marker}}",
                "method": "POST",
                "headers": {},
                "auth": {
                    "type": "basic_auth",
                    "options": {
                        "username": "{{global_account.username}}",
                        "password": "{{global_account.password}}"
                    }
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.items[*]"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.marker"
                        ],
                        "method": "json_path",
                        "output": "marker"
                    },
                    {
                        "input": [
                            "{{marker != ''}}",
                            "The value of token 'marker' extracted from response cannot be empty!"
                        ],
                        "method": "assert_true"
                    },
                    {
                        "input": [
                            "{{marker == _raw_marker}}"
                        ],
                        "method": "exit_if_true"
                    },
                    {
                        "input": [
                            "{{marker}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_marker"
                    },
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.items[*]"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "100",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.items[*]"
                        ],
                        "method": "json_empty"
                    }
                ]
            },
            "checkpoint": {
                "content": {
                    "marker": "{{_raw_marker}}"
                }
            }
        }
    ]
}