[zerofox_intel://<name>]
account = Credential account for the ZeroFox API.
email_domain = Filter by email domain. Only applies to Compromised Credentials and Botnet Credentials feeds.
index = (Default: default)
intel_source = Which CTI feed to collect (from intel_sources.yaml).
interval = Polling interval in seconds. (Default: 3600)

[zerofox_alerts://<name>]
account = Credential account for the ZeroFox API.
alert_filter = Import all alerts or only escalated. (Default: all)
index = (Default: default)
interval = Polling interval in seconds. (Default: 120)
