
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system


[datamodels/RiskIQ-GI]
access = read : [ * ], write : [ admin ]
export = system
owner = admin
