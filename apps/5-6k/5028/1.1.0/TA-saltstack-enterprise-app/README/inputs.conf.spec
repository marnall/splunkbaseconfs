[saltstack_enterprise_metrics://<name>]
global_account = Choose the account with configured SaltStack Enterprise User credentials in the Add-on Setup Parameters.
collect_metrics = Select to enable metrics collection from SaltStack Enterprise.
saltstack_enterprise_url = Override the SaltStack Enterprise URL configured in the Add-on Setup Parameters.
request_timeout = Override the Request Timeout configured in the Add-on Setup Parameters.
certificate_path = Override the Certificate Path configured in the Add-on Setup Parameters.
verify_ssl = Override the Verify SSL configured in the Add-on Setup Parameters.