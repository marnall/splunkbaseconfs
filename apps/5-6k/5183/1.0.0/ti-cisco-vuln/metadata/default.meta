[]
access = read : [ * ], write : [ admin ]
export = none

[props]
export = system

[transforms]
export = system

[macros]
export = system

[eventtypes]
export = system

[tags]
export = system

#
# Don't export fields.conf
# - Doing so could cause stanza clash in other apps
#
[fields]
export = none

#
# Don't export the Search Scripts
# - There's no need
#
[searchscripts]
access = read : [ admin ], write : [ admin ]
export = none