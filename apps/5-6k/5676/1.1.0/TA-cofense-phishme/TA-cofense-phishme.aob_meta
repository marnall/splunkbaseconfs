{"basic_builder": {"appname": "TA-cofense-phishme", "friendly_name": "CoFense PhishMe", "version": "1.0.0", "author": "DavidCottingham", "description": "This is an unofficial addon for CoFense PhishMe which enables the import of data from the PhishMe REST API", "theme": "#ec9960", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.0.0", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "PhishMeScenarioReports", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "phishmescenarioreports", "title": "PhishMeScenarioReports", "description": "Retrieves full scenario reports for scenarios that have run", "type": "customized", "parameters": [{"name": "scenarios_to_collect", "label": "Scenarios to Collect", "help_string": "", "required": true, "possible_values": [{"value": "/scenarios.json", "label": "Completed Scenarios"}, {"value": "/all_scenarios.json", "label": "All Scenarios"}, {"value": "/test_scenarios.json", "label": "Test Scenarios"}], "format_type": "dropdownlist", "default_value": "/scenarios.json", "placeholder": "", "type": "dropdownlist", "value": "/scenarios.json"}], "data_inputs_options": [{"type": "customized_var", "name": "scenarios_to_collect", "title": "Scenarios to Collect", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "/scenarios.json", "label": "Completed Scenarios"}, {"value": "/all_scenarios.json", "label": "All Scenarios"}, {"value": "/test_scenarios.json", "label": "Test Scenarios"}], "format_type": "dropdownlist", "default_value": "/scenarios.json", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport csv\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_phishme_login_domain = helper.get_global_setting('phishme_login_domain')\n    opt_phishme_api_token = helper.get_global_setting('phishme_api_token')\n    opt_scenarios_to_collect = helper.get_arg('scenarios_to_collect')\n    #opt_verify_remote_tls_certificate = helper.get_global_setting('verify_remote_tls_certificate')    \n    helper.get_input_stanza()\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    #loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    #account = helper.get_user_credential_by_username(\"username\")\n    #account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    #global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    #helper.set_log_level(log_level)\n\n    # The following examples send rest requests to some endpoint.\n    \n    response = helper.send_http_request(\"https://\" + opt_phishme_login_domain + opt_scenarios_to_collect, method=\"GET\", parameters=None, headers={'Authorization': 'Token token=' + opt_phishme_api_token}, cookies=None, verify=True, cert=None,timeout=600, use_proxy=True)\n\n    \n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n    r_json = response.json()\n\n    for identifier in r_json:\n        \n        touse = identifier['id']\n        scenario_type = identifier['scenario_type']\n        scenario_title = identifier['title']\n        helper.log_debug(touse)\n        jsonArray = []\n        \n        response = helper.send_http_request(\"https://\" + opt_phishme_login_domain +\"/scenario/\"+touse+\"/full_csv\", method=\"GET\", parameters=None, headers={'Authorization': 'Token token=' + opt_phishme_api_token}, cookies=None, verify=True, cert=None,timeout=600, use_proxy=True)\n        \n        decoded = response.content.decode('utf-8')\n        reader = csv.DictReader(decoded.splitlines(), delimiter=',')\n\n\n        \n        for row in reader:\n            jsonArray.append(row)\n        \n        rows = len(jsonArray)\n        helper.log_debug(\"Number of recipients are \" + str(rows))        \n        #seconds to sleep being slightly cautious\n        sleepingfor = (rows//900)\n        \n        for item in jsonArray:\n            item['scenario_type'] = scenario_type\n            item['scenario_title'] = scenario_title\n            item['scenario_id'] = touse\n        \n        jsondata = json.dumps(jsonArray)\n        \n\n        event = helper.new_event(source=\"Phish_Me_Scenario_Reports\", index=helper.get_output_index(), sourcetype=\"_json\", data=jsondata,unbroken=False,time=time.time())\n        ew.write_event(event)\n            \n        time.sleep(sleepingfor)\n        \n    \n    \n    \n    ", "customized_options": [{"name": "scenarios_to_collect", "value": "/scenarios.json"}], "uuid": "0d3ea740d3fb4630be317c50e3a60430", "sample_count": 0}, {"index": "default", "sourcetype": "PhishMeUsers", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "phishmeusers", "title": "PhishMeUsers", "description": "Return a list of information about each of the companies operators", "type": "customized", "parameters": [{"name": "endpoint", "label": "Endpoint", "help_string": "NOTE: This typically does not need to be changed", "required": true, "format_type": "text", "default_value": "/users", "placeholder": "/users", "type": "text", "value": "/users"}], "data_inputs_options": [{"type": "customized_var", "name": "endpoint", "title": "Endpoint", "description": "NOTE: This typically does not need to be changed", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "/users", "placeholder": "/users"}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport csv\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi instance mod input, args will be returned as a single value.\n    opt_phishme_login_domain = helper.get_global_setting('phishme_login_domain')\n    opt_phishme_api_token = helper.get_global_setting('phishme_api_token')\n    #opt_verify_remote_tls_certificate = helper.get_global_setting('verify_remote_tls_certificate')    \n    helper.get_input_stanza()\n    # The following examples get options from setup page configuration.\n    # get the loglevel from the setup page\n    #loglevel = helper.get_log_level()\n    # get proxy setting configuration\n    proxy_settings = helper.get_proxy()\n    # get account credentials as dictionary\n    #account = helper.get_user_credential_by_username(\"username\")\n    #account = helper.get_user_credential_by_id(\"account id\")\n    # get global variable configuration\n    #global_userdefined_global_var = helper.get_global_setting(\"userdefined_global_var\")\n\n    #helper.set_log_level(log_level)\n    jsonArray = []\n    # The following examples send rest requests to some endpoint.\n    \n    response = helper.send_http_request(\"https://\" + opt_phishme_login_domain +\"/users.csv\", method=\"GET\", parameters=None, headers={'Authorization': 'Token token=' + opt_phishme_api_token}, cookies=None, verify=True, cert=None,timeout=None, use_proxy=True)\n    decoded = response.content.decode('utf-8')\n    helper.log_debug(decoded)\n    reader = csv.DictReader(decoded.splitlines(), delimiter=',')\n    \n    for row in reader:\n        jsonArray.append(row)\n    \n    #Convert to JSON\n    jsondata = json.dumps(jsonArray)\n\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n\n    event = helper.new_event(source=\"Phish_Me_Users\", index=helper.get_output_index(), sourcetype=\"_json\", data=jsondata,unbroken=False,time=time.time())\n    ew.write_event(event)", "customized_options": [{"name": "endpoint", "value": "/users"}], "uuid": "d2442e5d951d4162a0e55a4a0164b532", "sample_count": 0}, {"index": "default", "sourcetype": "PhishMeScenarios", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "phishmescenarios", "title": "PhishMeScenarios", "description": "Retrieves JSON for each PhishMe completed scenarios", "type": "customized", "parameters": [{"name": "scenarios_to_collect", "label": "Scenarios to Collect", "help_string": "", "required": true, "possible_values": [{"value": "/scenarios.json", "label": "Completed Scenarios"}, {"value": "/all_scenarios.json", "label": "All Scenarios"}, {"value": "/test_scenarios.json", "label": "Test Scenarios"}], "format_type": "dropdownlist", "default_value": "/scenarios.json", "placeholder": "", "type": "dropdownlist", "value": "/all_scenarios.json"}], "data_inputs_options": [{"type": "customized_var", "name": "scenarios_to_collect", "title": "Scenarios to Collect", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "/scenarios.json", "label": "Completed Scenarios"}, {"value": "/all_scenarios.json", "label": "All Scenarios"}, {"value": "/test_scenarios.json", "label": "Test Scenarios"}], "format_type": "dropdownlist", "default_value": "/scenarios.json", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n\n\n    # The following examples get the arguments of this input.\n    # Note, for single instance mod input, args will be returned as a dict.\n    # For multi ins