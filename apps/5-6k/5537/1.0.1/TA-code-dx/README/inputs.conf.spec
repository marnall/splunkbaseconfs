[csv_report://<name>]
project_specifier = If nothing is specified, defaults to "all" (all projects)
detection_method = If nothing is specified, defaults to all detection methods
severity = If nothing is specified, defaults to all severities
include_resolved_findings = Check this box to include findings marked as "Ignored", "False Positive", "Mitigated", "Fixed", and "Gone"
filter_by_last_modified = Check this box to only retrieve findings that have been created/modified since the last run