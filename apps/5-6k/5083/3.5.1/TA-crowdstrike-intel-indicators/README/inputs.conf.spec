[crowdstrike_intel_indicators://<name>]
interval = <integer> Collection interval in seconds. Must be 300 or greater.
index = <string> Destination index for intel indicator events.
credentials = <string> API client credential configured in the add-on.
cloud = <string> CrowdStrike cloud environment (us_commercial, us_commercial2, eucloud, govcloud, govcloud2).
deleted = <boolean> Include indicators marked as deleted.
start_date = <string> Optional start date in YYYY-MM-DD format for initial collection.