{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "__settings__.logging.loglevel",
        "__settings__.proxy.proxy_enabled",
        "__settings__.proxy.proxy_url",
        "__settings__.proxy.proxy_port",
        "__settings__.proxy.proxy_type",
        "__settings__.proxy.proxy_username",
        "__settings__.proxy.proxy_rdns",
        "__settings__.proxy.proxy_password",
        "domain",
        "api_key",
        "last"
    ],
    "global_settings": {
        "proxy": {
            "enabled": "{{__settings__.proxy.proxy_enabled}}",
            "host": "{{__settings__.proxy.proxy_url}}",
            "port": "{{__settings__.proxy.proxy_port}}",
            "username": "{{__settings__.proxy.proxy_username}}",
            "password": "{{__settings__.proxy.proxy_password}}",
            "rdns": "{{__settings__.proxy.proxy_rdns}}",
            "type": "{{__settings__.proxy.proxy_type}}"
        },
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": [
                    {
                        "input": [
                            "{{last}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_last"
                    }
                ]
            },
            "request": {
                "url": "{{domain}}/api/v1/event/siem?last={{last}}",
                "method": "GET",
                "headers": {
                    "X-API-KEY": "{{api_key}}",
                    "Content-Type": "application/json"
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.results"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.last"
                        ],
                        "method": "json_path",
                        "output": "last"
                    },
                    {
                        "input": [
                            "{{last != ''}}",
                            "The value of token 'last' extracted from response cannot be empty!"
                        ],
                        "method": "assert_true"
                    },
                    {
                        "input": [
                            "{{last == _raw_last}}"
                        ],
                        "method": "exit_if_true"
                    },
                    {
                        "input": [
                            "{{last}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_last"
                    },
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.results"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "100",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.results"
                        ],
                        "method": "json_empty"
                    }
                ]
            },
            "checkpoint": {
                "content": {
                    "last": "{{_raw_last}}"
                }
            }
        }
    ]
}