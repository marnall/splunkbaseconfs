{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "bigpanda_alert", "short_name": "bigpanda_alert", "parameters": [{"format_type": "dropdownlist", "required": true, "name": "status", "label": "Status", "default_value": "Splunk", "help_string": "Whether to use the Splunk triggered alert severity or a specific BigPanda severity", "possible_values": {"Critical": "critical", "Warning": "Warning", "Use Splunk Severity": "Splunk"}, "type": "", "value": "Splunk"}, {"format_type": "text", "required": false, "name": "app_key_override", "label": "App Key Override", "default_value": "", "help_string": "Optional override to send this alert to a different BigPanda App Key than the globally configured App Key", "type": "", "value": ""}, {"format_type": "text", "required": false, "name": "primary_override", "label": "Primary Key Override", "default_value": "", "help_string": "Override the primary property for this alert. You can use Splunk variables, such as '$name$'.", "type": "", "value": ""}, {"format_type": "text", "required": false, "name": "secondary_override", "label": "Secondary Property Override", "default_value": "", "help_string": "Override the primary property for this alert. You can use Splunk variables, such as '$name$'.", "type": "", "value": ""}, {"format_type": "text", "required": false, "name": "description_override", "label": "Description Override", "default_value": "", "help_string": "Override the description for this alert. You can use Splunk variables", "type": "", "value": ""}], "code": "import json\nimport os\nimport re\n\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example sends rest requests to some endpoint\n    # response is a response object in python requests library\n    response = helper.send_http_request(\"http://www.splunk.com\", \"GET\", parameters=None,\n                                        payload=None, headers=None, cookies=None, verify=True, cert=None, timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n\n    # The following example gets and sets the log level\n    helper.set_log_level(helper.log_level)\n\n    # The following example gets the setup parameters and prints them to the log\n    app_key = helper.get_global_setting(\"app_key\")\n    helper.log_info(\"app_key={}\".format(app_key))\n    helper.log_info(\"token={}\".format(token))\n    api_url = helper.get_global_setting(\"api_url\")\n    helper.log_info(\"api_url={}\".format(api_url))\n\n    # The following example gets the alert action parameters and prints them to the log\n    status = helper.get_param(\"status\")\n    helper.log_info(\"status={}\".format(status))\n\n    app_key_override = helper.get_param(\"app_key_override\")\n    helper.log_info(\"app_key_override={}\".format(app_key_override))\n\n    primary_override = helper.get_param(\"primary_override\")\n    helper.log_info(\"primary_override={}\".format(primary_override))\n\n    secondary_override = helper.get_param(\"secondary_override\")\n    helper.log_info(\"secondary_override={}\".format(secondary_override))\n\n    description_override = helper.get_param(\"description_override\")\n    helper.log_info(\"description_override={}\".format(description_override))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action bigpanda_alert started.\")\n\n    # get events for this alert trigger\n    events = helper.get_events()\n\n    # get global settings\n    app_key_override = helper.get_param(\"app_key_override\")\n    app_key = app_key_override if app_key_override else helper.get_global_setting(\"app_key\")\n    api_url = helper.get_global_setting(\"api_url\")\n\n    # get token from environment variables if set to do so\n    token = os.environ.get('BIGPANDA_BEARER_TOKEN') if os.environ.get('BIGPANDA_USE_ENV_PASSWORDS') else helper.get_global_setting(\"token\")\n\n    # severity = helper.get_param(\"severity\")\n    # helper.log_info(\"severity: {}\".format(severity))\n\n    payload = helper.settings\n    payload[\"results\"] = list(events) # note this exhausts the generator\n\n    # remove any sensitive info before sending\n    payload.pop(\"session_key\")\n\n    helper.log_debug(\"payload: {}\".format(json.dumps(payload)))\n\n    # if we somehow have a non-secure (http) url here then coerce it into a secure (https) form\n    api_url = re.sub(r\"^http://(.*)$\", r\"https://\\1\", api_url, flags=re.IGNORECASE)\n\n    # ship it, send the alert to BigPanda\n    response = helper.send_http_request(api_url, \"POST\", parameters={\"app_key\": app_key},\n                                        payload=payload, headers={\"Authorization\": \"Bearer {}\".format(token)}, cookies=None, verify=True, cert=None, timeout=None, use_proxy=True)\n\n    helper.log_info(\"Alert action bigpanda_alert finished.\")\n\n    return 0\n", "uuid": "e0f1a431ca8e42baa0011ecf5596c6cc"}]}, "basic_builder": {"appname": "TA-bigpanda", "friendly_name": "BigPanda", "version": "2.2.1", "author": "BigPanda", "description": "The BigPanda App for Splunk allows you to trigger BigPanda incidents from Saved-Search Alerts by using the Custom Alert Actions capability in Splunk. This provides a dashboard to manage your Splunk alerts sending to BigPanda all of your Splunk alerts, making it easier than ever to correlate all of your alerts in BigPanda.", "theme": "#297ba5", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.4", "tab_build_no": "0", "build_no": 9}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}, "customized_settings": [{"format_type": "text", "required": true, "name": "app_key", "label": "App Key", "default_value": "", "help_string": "BigPanda app key for your integration", "internal_name": "", "type": "text", "value": "fcf0a1f3bcb75cd0010a8f37e2a0e8d7"}, {"format_type": "password", "required": true, "name": "token", "label": "API Token", "default_value": "", "help_string": "BigPanda authentication key for your integration", "internal_name": "", "type": "password", "value": ""}, {"format_type": "text", "required": false, "name": "api_url", "label": "Alerts Endpoint", "default_value": "https://inbound.bigpanda.io/splunk/alerts", "help_string": "BigPanda endpoints to send alerts to", "internal_name": "", "type": "text", "value": "https://inbound.bigpanda.io/splunk/alerts"}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1698438945_8"}}
