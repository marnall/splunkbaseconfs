{"basic_builder": {"appname": "TA-XShield", "friendly_name": "TA-XShield", "version": "1.0.6", "author": "ColorTokens", "description": "Technology Adaptor for XShield product.", "theme": "#3c6188", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.1.1", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "Assets", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "assets", "title": "Assets", "description": "Assets", "type": "customized", "parameters": [{"required": false, "name": "ttl", "label": "TTL", "default_value": "", "placeholder": "Optional", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "ttl", "title": "TTL", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Optional"}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\nimport requests, json\nfrom urllib3.exceptions import InsecureRequestWarning\nrequests.packages.urllib3.disable_warnings(category=InsecureRequestWarning)\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # tenant_name = definition.parameters.get('tenant_name', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n     # get global variable configuration\n    _url = helper.get_global_setting(\"spectrum_url\")\n    _token = helper.get_global_setting(\"api_token\")\n    _tenant = helper.get_global_setting(\"tenant_name\")\n\n    f = open(\"/opt/splunk/etc/xshield.conf\", \"w\")\n    f.write(_url    +'|')\n    f.write(_token  +'|')\n    f.write(_tenant)\n    f.close()\n    \n    # Name of the tenant Example: mycompany\n    TENANT_NAME=_tenant\n    \n    #Spectrum hostname. Example: mycompany.spectrum.colortokens.com\n    HOST_NAME=_url\n    \n    # API Client Token generated from API Manager\n    API_CLIENT_TOKEN=_token\n    \n    API_PATH='assets'\n    \n    page = 1\n    total_pages = 1\n    records_per_page=100\n    \n    headers = {\n      'x-api-token': f\"{API_CLIENT_TOKEN}\"\n    }\n    \n    while(page <= total_pages):\n        url = f\"{HOST_NAME}/public/api/v1/{TENANT_NAME}/{API_PATH}?limit={records_per_page}&page={page}\"\n        response = requests.request(\"GET\", url, headers=headers, verify=False)\n        responseJson = response.json()\n        total_pages = responseJson['pagination']['totalPages']\n        assets = responseJson['data']\n        for asset in assets:\n            event = helper.new_event(data=json.dumps(asset), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n            ew.write_event(event)\n        page = page + 1\n", "customized_options": [{"name": "ttl", "value": ""}], "uuid": "1d073d088cef48e79a90bbcacfc9ced7"}, {"index": "default", "sourcetype": "Audits", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "audits", "title": "Audits", "description": "Audits", "type": "customized", "parameters": [{"required": false, "name": "ttl", "label": "TTL", "default_value": "", "placeholder": "Optional", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "ttl", "title": "TTL", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Optional"}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nfrom time import time\nimport datetime\nfrom pathlib import Path\nimport requests, json\nfrom urllib3.exceptions import InsecureRequestWarning\nrequests.packages.urllib3.disable_warnings(category=InsecureRequestWarning)\n\nPRESET_FILE = \"/opt/splunk/etc/xshield_audits.conf\"\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # tenant_name = definition.parameters.get('tenant_name', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    _lte = int(time() * 1000)\n    _gte = _lte - int(30 * 24 * 60 * 60 * 1000)\n    \n     # get global variable configuration\n    _url = helper.get_global_setting(\"spectrum_url\")\n    _token = helper.get_global_setting(\"api_token\")\n    _tenant = helper.get_global_setting(\"tenant_name\")\n    \n    if Path(PRESET_FILE).is_file():\n        f = open (PRESET_FILE, \"r\")\n        data = json.loads(f.read())\n        _gte=data['lte']\n        f.close()\n        \n    \n    lte = str(_lte)\n    gte = str(_gte)\n\n    f = open(\"/opt/splunk/etc/xshield.conf\", \"w\")\n    f.write(_url    +'|')\n    f.write(_token  +'|')\n    f.write(_tenant)\n    f.close()\n    \n    # Name of the tenant Example: mycompany\n    TENANT_NAME=_tenant\n    \n    #Spectrum hostname. Example: mycompany.spectrum.colortokens.com\n    HOST_NAME=_url\n    \n    # API Client Token generated from API Manager\n    API_CLIENT_TOKEN=_token\n    \n    API_PATH='audit/events/splunk'\n    \n    page = 1\n    total_pages = 1\n    records_per_page=100\n    \n    headers = {\n      'x-api-token': f\"{API_CLIENT_TOKEN}\"\n    }\n    \n    done = 0\n    total = 1\n    while(page <= total_pages):\n        url = f\"{HOST_NAME}/public/api/v1/{TENANT_NAME}/{API_PATH}?from={gte}&to={lte}&limit={records_per_page}&page={page}\"\n        helper.log_debug(\">>>> URL = \" + url)\n        \n        response = requests.request(\"GET\", url, headers=headers, verify=False)\n        responseJson = response.json()\n        page_info = responseJson['pagination']\n        helper.log_debug(\"PAGINATION_INFO: \" + json.dumps(page_info))\n        total = page_info['totalElements']\n        total_pages = responseJson['pagination']['totalPages']\n        audits = responseJson['data']\n        for audit in audits:\n            if helper.get_check_point(audit['id']) is None:\n                event = helper.new_event(data=json.dumps(audit), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n                ew.write_event(event)\n                helper.save_check_point(audit['id'], 'Y')\n        page = page + 1\n        done = done + 100\n        helper.log_debug(\"DONE :: \" + str(done) + \", TOTAL = \" + str(total))\n        \n    if done >= total:\n        helper.log_debug(\">>>> STORING PRESESTS\")\n        f = open(PRESET_FILE, \"w\")\n        PRESETS = { \"gte\": _gte, \"lte\": _lte }\n        f.write(json.dumps(PRESETS))\n    else:\n        helper.log_debug(\">>>> OLD PRESESTS RETAINED\")\n\n", "customized_options": [{"name": "ttl", "value": ""}], "uuid": "5b0f7f17722944209ccb0ef0317e9414"}, {"index": "default", "sourcetype": "Flows", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "flows", "title": "Flows", "description": "Flows", "type": "customized", "parameters": [{"required": false, "name": "ttl", "label": "TTL", "default_value": "", "placeholder": "Optional", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "ttl", "title": "TTL", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Optional"}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nfrom time import time\nfrom datetime import datetime\nfrom requests.adapters import HTTPAdapter\nimport os.path\nfrom os import path\n\nimport requests, json\nfrom urllib3.util.retry import Retry\nfrom urllib3.exceptions import InsecureRequestWarning\nrequests.packages.urllib3.disable_warnings(category=InsecureRequestWarning)\n\nlimit = str(5000)\nPRESET_FILE = \"/opt/splunk/etc/xshield_flows.conf\"\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    pass\n\ndef collect_events(helper, ew):\n    _lte = int(time() * 1000)\n    lte = str(_lte - int(60 * 10 * 1000))\n    PRESETS=None\n    # get global variable configuration\n    base_url = helper.get_global_setting(\"spectrum_url\")\n    token = helper.get_global_setting(\"api_token\")\n    tenant = helper.get_global_setting(\"tenant_name\")\n\n    f = open(\"/opt/splunk/etc/xshield.conf\", \"w\")\n    f.write(base_url    +'|')\n    f.write(token  +'|')\n    f.write(tenant)\n    f.close()\n\n    gte = str(_lte - int(60 * 20 * 1000))\n    f = open(PRESET_FILE, \"w\")\n    PRESETS = { \"gte\": gte, \"lte\": lte }\n    f.write(json.dumps(PRESETS))\n    f.close()\n        \n    done = 0\n    total = 1\n    url = base_url + '/public/api/v1/' + tenant + '/analytics/flows?gte='+gte+'&lte='+lte+'&limit='+limit\n    helper.log_debug(\">>>> URL = \" + url)\n    s = requests.Session()\n    retries = Retry(total=10, backoff_factor=1, status_forcelist=[ 500, 502, 503, 504 ])\n    s.mount('https://', HTTPAdapter(max_retries=retries))\n    r = s.get(url = url, headers={'x-api-token': token}, verify=False)\n    \n    eventsArray = []\n    while done < total:\n        if \"pagination\" in r.json().keys():\n            page_info = r.json()['pagination']\n            helper.log_debug(\"PAGINATION_INFO: \" + json.dumps(page_info))\n            if \"updatedDate\" in page_info.keys():\n                updatedDate = str(page_info['updatedDate'])\n                skipUntil = page_info['skipUntil']\n                total = page_info['total']\n                itemCount = r.json()['itemCount']\n                if \"items\" in r.json().keys():\n                    for item in r.json()['items']:\n                        event = helper.new_event(data=json.dumps(item), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n                        ew.write_event(event)\n                    done = done + itemCount\n                    f = open(PRESET_FILE, \"w\")\n                    PRESETS['url'] = url\n                    PRESETS['total'] = total\n                    PRESETS['done'] = done\n                    f.write(json.dumps(PRESETS))\n                    f.close()\n                    helper.log_debug(\"DONE :: \" + str(done) + \", TOTAL = \" + str(total))\n                    url = base_url + '/public/api/v1/' + tenant + '/analytics/flows?gte='+gte+'&lte='+lte+'&limit='+limit+'&updatedDate='+updatedDate+'&skipUntil='+skipUntil\n                    helper.log_debug(\">>>> URL = \" + url)\n                    r = s.get(url = url, headers={'x-api-token': token}, verify=False)\n                else:\n                    helper.log_debug(\"EXITING-NO-ITEMS \" + json.dumps(r.json()))\n                    total = -1\n            else:\n                helper.log_debug(\"EXITING-NO-UPDATEDDATE \" + json.dumps(r.json()))\n                total = -1\n        else:\n            helper.log_debug(\"NO PAGINATION INFO IN RESPONSE\")\n            total = -1\n            if \"items\" in r.json().keys():\n                for item in r.json()['items']:\n                        event = helper.new_event(data=json.dumps(item), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n                        ew.write_event(event)\n\n\n", "customized_options": [{"name": "ttl", "value": ""}], "uuid": "1348731e31224703b88f0a6fd5b749db"}, {"index": "default", "sourcetype": "Notifications", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "notifications", "title": "Notifications", "description": "Notifications", "type": "customized", "parameters": [{"required": false, "name": "ttl", "label": "TTL", "default_value": "", "placeholder": "Optional", "help_string": "", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "ttl", "title": "TTL", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "Optional"}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport datetime\nfrom pathlib import Path\nfrom time import time\nimport requests, json\nfrom urllib3.exceptions import InsecureRequestWarning\nrequests.packages.urllib3.disable_warnings(category=InsecureRequestWarning)\n\nPRESET_FILE = \"/opt/splunk/etc/xshield_alerts.conf\"\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # tenant_name = definition.parameters.get('tenant_name', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    _lte = int(time() * 1000)\n    _gte = _lte - int(30 * 24 * 60 * 60 * 1000)\n    \n     # get global variable configuration\n    _url = helper.get_global_setting(\"spectrum_url\")\n    _token = helper.get_global_setting(\"api_token\")\n    _tenant = helper.get_global_setting(\"tenant_name\")\n\n    \n    if Path(PRESET_FILE).is_file():\n        f = open (PRESET_FILE, \"r\")\n        data = json.loads(f.read())\n        _gte=data['lte']\n        f.close()\n        \n    \n    lte = str(_lte)\n    gte = str(_gte)\n    \n    f = open(\"/opt/splunk/etc/xshield.conf\", \"w\")\n    f.write(_url    +'|')\n    f.write(_token  +'|')\n    f.write(_tenant)\n    f.close()\n    \n    # Name of the tenant Example: mycompany\n    TENANT_NAME=_tenant\n    \n    #Spectrum hostname. Example: mycompany.spectrum.colortokens.com\n    HOST_NAME=_url\n    \n    # API Client Token generated from API Manager\n    API_CLIENT_TOKEN=_token\n    \n    API_PATH='alerts/splunk'\n    \n    page = 1\n    total_pages = 1\n    records_per_page=100\n    \n    headers = {\n      'x-api-token': f\"{API_CLIENT_TOKEN}\"\n    }\n    \n    done = 0\n    total = 1\n    while(page <= total_pages):\n        url = f\"{HOST_NAME}/public/api/v1/{TENANT_NAME}/{API_PATH}?limit={records_per_page}&page={page}\"\n        helper.log_debug(\">>>> URL = \" + url)\n        response = requests.request(\"GET\", url, headers=headers, verify=False)\n        responseJson = response.json()\n        page_info = responseJson['pagination']\n        helper.log_debug(\"PAGINATION_INFO: \" + json.dumps(page_info))\n        total_pages = page_info['totalPages']\n        total = page_info['totalElements']\n        notifications = responseJson['data']\n        for notification in notifications:\n            if helper.get_check_point(notification['id']) is None:\n                event = helper.new_event(data=json.dumps(notification), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n                ew.write_event(event)\n                helper.save_check_point(notification['id'], 'Y')\n        page = page + 1\n        done = done + 100\n        helper.log_debug(\"DONE :: \" + str(done) + \", TOTAL = \" + str(total))\n    \n    if done >= total:\n        helper.log_debug(\">>>> STORING PRESESTS\")\n        f = open(PRESET_FILE, \"w\")\n        PRESETS = { \"gte\": _gte, \"lte\": _lte }\n        f.write(json.dumps(PRESETS))\n    else:\n        helper.log_debug(\">>>> OLD PRESESTS RETAINED\")\n\n", "customized_options": [{"name": "ttl", "value": ""}], "uuid": "0aabd7551fdc4c8f84c80455a9213eb6"}]}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": true, "name": "tenant_name", "label": "Tenant Name", "default_value": "", "placeholder": "", "help_string": "CTDemo", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "spectrum_url", "label": "Spectrum URL", "default_value": "", "placeholder": "", "help_string": "https://tenant.spectrum.colortokens.com", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "api_token", "label": "API Client Token", "placeholder": "", "default_value": "", "help_string": "API Client Token generated from API Manager", "type": "password", "format_type": "password", "value": ""}]}}, "sourcetype_builder": {"Assets": {"metadata": {"event_count": 0, "data_input_name": "assets", "extractions_count": 0, "cims_count": 0}}, "Audits": {"metadata": {"event_count": 0, "data_input_name": "audits", "extractions_count": 0, "cims_count": 0}}, "Flows": {"metadata": {"event_count": 0, "data_input_name": "flows", "extractions_count": 0, "cims_count": 0}}, "Notifications": {"metadata": {"event_count": 0, "data_input_name": "notifications", "extractions_count": 0, "cims_count": 0}}}}
