  <search>
    <query>| rest /services/configs/conf-umbrella | fields fmc_ip | rename fmc_ip as managementIp</query>
    <earliest>$time_tok.earliest$</earliest>
    <latest>$time_tok.latest$</latest>
    <done>
      <eval token="fmcLink">$managementIp$</eval>
      <eval token="tokTime">$job.earliestTime$</eval>
      <eval token="tokEarliestTime">strftime(strptime($job.earliestTime$,"%Y/%m/%dT%H:%M:%S.%3N %p"),"%B %dth %y %I:%M %p")</eval>
      <eval token="tokLatestTime">strftime(strptime($job.latestTime$,"%Y/%m/%dT%H:%M:%S.%3N %p"),"%B %dth %y %I:%M %p")</eval>
    </done>
    <finalized>
      <condition match=" 'job.resultCount' != 0">
        <set token="fmcLink">$result.managementIp$</set>
      </condition>
      <condition>
        <set token="fmcLink">No FMC found</set>
      </condition>
    </finalized>
  </search>
