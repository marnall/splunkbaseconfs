[hcs_obs://<name>]
global_account = Pre-Configured Huawei Cloud Account
bucket_name = Huawei Cloud OBS bucket name
dir_prefix = Target directory path in the bucket and will be assumed ending with '/'
deep_search = If recursively search objects in sub-directories
obj_pattern = The regex-pattern name of target objects in the bucket
timeout = The default timeout seconds for Http Request of OBSClient