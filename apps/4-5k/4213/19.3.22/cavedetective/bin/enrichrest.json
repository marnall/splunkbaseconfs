 "virustotal":{
   "prefix":"virustotal",
   "methods":["filereport","filebehaviour","urlreport","domainreport","ipreport"],
   "restend":{
     "filereport":{"endpoint":"/vtapi/v2/file/report","farget":"resource",
                   "fields":["md5","sha1","sha256","resource","permalink","positives","total","scans","scan_id","scan_date","response_code","verbose_msg"]},
     "filebehaviour":{"endpoint":"/vtapi/v2/file/behaviour","farget":"hash",
                      "fields":{"info":["started","duration","ended","version"],"network":["hosts","udp","tcp"],"response_code":null,"verbose_msg":null}},
     "urlreport":{"endpoint":"/vtapi/v2/url/report","farget":"resource",
                  "fields":["url","permalink","positives","total","scans","filescan_id","scan_id","scan_date","response_code","verbose_msg"]},
     "domainreport":{"endpoint":"/vtapi/v2/domain/report","farget":"domain",
                     "fields":["subdomains","domain_siblings","resolutions","detected_urls","detected_communicating_samples","undetected_downloaded_samples","detected_referrer_samples",
                               "undetected_referrer_samples","response_code","verbose_msg","positives"]},
     "ipreport":{"endpoint":"/vtapi/v2/ip-address/report","farget":"ip",
                 "fields":["asn","as_owner","country","resolutions","detected_urls","detected_communicating_samples","undetected_downloaded_samples","response_code","verbose_msg","positives"]}}}}
