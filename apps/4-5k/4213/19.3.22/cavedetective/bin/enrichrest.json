                      "technicalContactTelephone:whois_technicalContactTelephone","technicalContactTelephoneExt:whois_technicalContactTelephoneExt","timestamp:whois_timestamp","updated:whois_updated","whoisServers:whois_whoisServers","zoneContactCity:whois_zoneContactCity",
                      "zoneContactCountry:whois_zoneContactCountry","zoneContactEmail:whois_zoneContactEmail","zoneContactFax:whois_zoneContactFax","zoneContactFaxExt:whois_zoneContactFaxExt","zoneContactName:whois_zoneContactName","zoneContactOrganization:whois_zoneContactOrganization",
