@placement search-head

[report]

param.ip = <string>
* The ip passed from splunk to the script

param.base_url = <string>
* AbuseIPDB API report URL

param.key = <string>
* AbuseIPDB API key
* see https://www.abuseipdb.com/account/api

param.categories = <string>
* A comma-separated list of categories

param.comment = <string>
* A user-defined comment from the UI

