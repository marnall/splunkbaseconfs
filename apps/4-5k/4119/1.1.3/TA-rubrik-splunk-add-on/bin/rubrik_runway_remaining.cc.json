{
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "requests": [
        {
            "post_process": {
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "output": "__stdout__", 
                        "method": "splunk_xml"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}"
                        ], 
                        "method": "std_output"
                    }
                ], 
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "iteration_mode": {
                "iteration_count": "1", 
                "stop_conditions": []
            }, 
            "pre_process": {
                "pipeline": [], 
                "skip_conditions": []
            }, 
            "request": {
                "headers": {}, 
                "url": "https://{{rubrik_node}}/api/internal/stats/runway_remaining", 
                "auth": {
                    "options": {
                        "password": "{{global_account.password}}", 
                        "username": "{{global_account.username}}"
                    }, 
                    "type": "basic_auth"
                }, 
                "method": "GET"
            }
        }
    ], 
    "tokens": [
        "global_account.username", 
        "global_account.password", 
        "rubrik_node"
    ], 
    "global_settings": {
        "logging": {
            "level": "INFO"
        }
    }
}