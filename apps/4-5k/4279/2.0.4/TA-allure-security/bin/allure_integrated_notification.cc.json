{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "__settings__.logging.loglevel",
        "__settings__.additional_parameters.allure_server",
        "__settings__.additional_parameters.api_auth_token",
        "etimestamp"
    ],
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": [
                    {
                        "input": [
                            "{{etimestamp}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_etimestamp"
                    },
                    {
                        "input": [
                            "{{etimestamp}}",
                            "%s",
                            "%s"
                        ],
                        "method": "time_str2str",
                        "output": "etimestamp"
                    }
                ]
            },
            "request": {
                "url": "{{__settings__.additional_parameters.allure_server}}/api/v2/integratednotification/afterdatetime?datetime={{etimestamp}}",
                "method": "GET",
                "headers": {
                    "Authorization": "Bearer {{__settings__.additional_parameters.api_auth_token}}"
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.[*]"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.[*].firstActivity"
                        ],
                        "method": "json_path",
                        "output": "etimestamp"
                    },
                    {
                        "input": [
                            "{{etimestamp != ''}}",
                            "The value of token 'etimestamp' extracted from response cannot be empty!"
                        ],
                        "method": "assert_true"
                    },
                    {
                        "input": [
                            "{{etimestamp == _raw_etimestamp}}"
                        ],
                        "method": "exit_if_true"
                    },
                    {
                        "input": [
                            "{{etimestamp}}"
                        ],
                        "method": "set_var",
                        "output": "_raw_etimestamp"
                    },
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.[*]"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "100",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.[*]"
                        ],
                        "method": "json_empty"
                    }
                ]
            },
            "checkpoint": {
                "content": {
                    "etimestamp": "{{_raw_etimestamp}}"
                }
            }
        }
    ]
}