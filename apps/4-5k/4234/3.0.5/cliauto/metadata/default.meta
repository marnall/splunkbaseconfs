
# Application-level permissions

[]
access = read : [ admin, cliauto_user ], write : [ admin, cliauto_user ]

### EVENT TYPES

[eventtypes]
export = system

### PROPS

[props]
export = system

### TRANSFORMS

[transforms]
export = system

### LOOKUPS

[lookups]
export = system

### COLLECTIONS

[collections]
export = system

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

### VIEWS

[views/cli_auto]
#access = read : [ admin, cliauto_user ]
access = read : [ * ]
export = none
owner = nobody

