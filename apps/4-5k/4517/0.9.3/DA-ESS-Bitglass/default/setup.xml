<setup>
    <block title="Setup for Bitglass data extraction" endpoint="bitglassep/bitglassconf" entity="bitglass_config">
        <input field="customer">
            <label>Customer Name</label>
            <type>text</type>
         </input>
         <input field="url">
             <label>API URL</label>
             <type>text</type>
         </input>
         <input field="logtype">
             <label>Log Type</label>
             <type>text</type>
         </input>
         <input field="version">
             <label>API Version</label>
             <type>text</type>
         </input>
    </block>
    <block title="Password" endpoint="storage/passwords" entity="_new">
         <input field="name">
             <label>Username</label>
             <type>text</type>
         </input>
        <input field="password">
            <label>Password</label>
            <type>password</type>
        </input>
    </block>
 </setup>
