[sms_eagle_message]
param.message = <string> Message. It's a required parameter.
param.receiver_type = <list> Select Recipient Type. It's a required parameter. It's default value is receiver_phone_number.
param.phone_number = <string> Phone Number / Phonebook Group. It's a required parameter.
param.highpriority = <list> High Priority. It's a required parameter. It's default value is 0.
param.unicode = <list> Unicode. It's a required parameter. It's default value is 0.
param.flash = <list> Flash. It's a required parameter. It's default value is 0.
param.date = <string> Date.

[sms_eagle_call]
param.message = <string> Message.
param.phone_number = <string> Phone Number / Phonebook Group. It's a required parameter.
param.call_type = <list> Call Type. It's a required parameter. It's default value is ring.
param.voice_id = <string> Voice ID.
param.wave_id = <string> Wave File ID.
param.call_duration = <string> Duration. It's a required parameter. It's default value is 10.
param.highpriority = <list> High Priority. It's a required parameter. It's default value is 0.
param.call_date = <string> Date.
