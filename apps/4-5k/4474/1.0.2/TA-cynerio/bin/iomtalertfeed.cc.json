{
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "tokens": [
        "__settings__.logging.loglevel", 
        "__settings__.additional_parameters.password", 
        "__settings__.additional_parameters.hostname"
    ], 
    "requests": [
        {
            "iteration_mode": {
                "iteration_count": "1", 
                "stop_conditions": []
            }, 
            "post_process": {
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "output": "__stdout__", 
                        "method": "splunk_xml"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}"
                        ], 
                        "method": "std_output"
                    }
                ], 
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "request": {
                "headers": {
                    "Authorization": "{{__settings__.additional_parameters.password}}"
                }, 
                "url": "http://{{__settings__.additional_parameters.hostname}}/api/v1/data/alerts", 
                "method": "GET"
            }, 
            "pre_process": {
                "pipeline": [], 
                "skip_conditions": []
            }
        }
    ]
}