{"alert_action_builder": {"modular_alerts": [{"description": "Sends Alert (Updates SA) to ThreatDown Nebula", "largeIcon": "", "smallIcon": "", "label": "ThreatDown Cloud Remediation SA Alerts", "short_name": "mbcr_alert_sa", "active_response": {"technology": [{"product": "EPR", "version": ["2.0.4"], "vendor": "Malwarebytes"}], "supports_adhoc": true, "category": ["Endpoint Protection and Response"], "task": ["open", "close", "remediate"], "subject": ["endpoint", "traces"]}, "parameters": [{"format_type": "text", "required": true, "name": "hostname", "label": "Hostname", "default_value": "", "help_string": "", "type": "", "value": ""}, {"format_type": "text", "required": true, "name": "detection_id", "label": "Detection ID", "default_value": "", "help_string": "Suspicious Activity Detection ID", "type": "", "value": ""}, {"format_type": "dropdownlist", "required": true, "name": "action", "label": "Action", "default_value": "", "help_string": "Suspicious Activity Action", "possible_values": {"Open": "Open", "Close": "Close", "Remediate": "remediate"}, "type": "", "value": "Open"}], "code": "\n# encoding = utf-8\nfrom __future__ import print_function\nimport json\nimport base64\nimport traceback\nimport datetime\n\n\nAPI_LINK = \"https://api.threatdown.com\"\nTELEMETRY_LINK = \"https://api-msp-telemetry.threatdown.com/data\"\nAPP_VERSION = \"3.0.2\"\n\nSA_OPEN_CLOSE = [\"open\", \"close\"]\n\n# Get Path for OAuth token\ndef NEBULA_URL(path):\n\n    return \"{NEBULA_URL}{PATH}\".format(NEBULA_URL=API_LINK, PATH=path)\n\n\n# Get OAuth2 token\ndef get_nebula_client(client_id, client_secret, account_id, helper, user_proxy):\n\n    token_url=NEBULA_URL('/oauth2/token')\n    creds = \"{}:{}\".format(client_id,client_secret)\n    auth_val = base64.b64encode(creds.encode()).decode(\"ascii\")\n    headers = {\n        'Content-Type': 'application/x-www-form-urlencoded',\n        'Authorization': 'Basic {}'.format(auth_val)\n        }\n    payload='grant_type=client_credentials&scope=partner%20a{}'.format(account_id)\n    try:        \n        response = helper.send_http_request(url=token_url, method='POST', parameters=None, payload=payload, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=user_proxy)\n        return \"Bearer \"+response.json()['access_token']\n        \n    except Exception as e:\n        error_full_message = str(traceback.format_exc())\n        helper.log_error('Error message: '+ str(error_full_message))\n        return None\n\n\ndef search_for_enpoints_ids(auth_token, account_id, search_name, helper, use_proxy):\n    url = NEBULA_URL(f'/nebula/v1/endpoints')\n    body = {\"host_name\": search_name}\n    headers = {'Authorization': auth_token, 'accountid': account_id, \"Content-Type\": \"application/json\"}\n\n    # response = requests.request(\"POST\", url, data=json.dumps(body), headers=headers)\n    response = helper.send_http_request(url, method='POST', parameters=None, payload=body, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n\n    if response.status_code == 200:\n        resp = json.loads(response.text)\n        endpoints = resp['endpoints']\n        machine_ids = []\n        for el in endpoints:\n            machine_ids.append(el['machine']['id'])\n        return machine_ids\n\n\n\ndef perform_sa_remediate(auth_token, account_id, machine_id, sa_id, helper, use_proxy):\n    url = NEBULA_URL('/nebula/v1/endpoints/' + machine_id + '/sa/'+sa_id+'/remediate')\n    headers = {\"Authorization\": auth_token, \"accountid\": account_id}\n    response = helper.send_http_request(url, method='POST', parameters=None, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n\n    helper.log_info(str(response.status_code) + \" : \" + str(response.text))\n    if response.status_code == 201:\n        return response.text\n\n\n# action_type = \"open\" OR \"close\"\ndef perform_sa_open_close(auth_token, account_id, machine_id, action_type, sa_id, helper, use_proxy):\n    if action_type not in SA_OPEN_CLOSE:\n        return\n    url = NEBULA_URL('/nebula/v1/endpoints/' + machine_id + '/sa/'+sa_id+'/'+action_type)\n    headers = {\"Authorization\": auth_token, \"accountid\": account_id}\n    response = helper.send_http_request(url, method='PUT', parameters=None, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n\n    helper.log_info(str(response.status_code) + \" : \" + str(response.text))\n    if response.status_code == 201:\n        return response.text\n\n\ndef get_machine_ids_from_names(auth_token, account_id, hostnames, helper, use_proxy):\n    machine_ids  = []\n    for hostname in hostnames:\n        found_ids = search_for_enpoints_ids(auth_token,account_id, hostname, helper, use_proxy)\n        machine_ids.extend(found_ids)\n    return machine_ids\n\n\ndef get_quaranine_boolean_from_action(action_type):\n    return False if action_type == \"scan\" else True\n\n\ndef process_event(helper, *args, **kwargs):\n   \n   \n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example sends rest requests to some endpoint\n    # response is a response object in python requests library\n    response = helper.send_http_request(\"http://www.splunk.com\", \"GET\", parameters=None,\n                                        payload=None, headers=None, cookies=None, verify=True, cert=None, timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n\n    # The following example gets and sets the log level\n    helper.set_log_level(helper.log_level)\n\n    # The following example gets the setup parameters and prints them to the log\n    account_id = helper.get_global_setting(\"account_id\")\n    helper.log_info(\"account_id={}\".format(account_id))\n    client_id = helper.get_global_setting(\"client_id\")\n    helper.log_info(\"client_id={}\".format(client_id))\n    client_secret = helper.get_global_setting(\"client_secret\")\n    helper.log_info(\"client_secret={}\".format(client_secret))\n\n    # The following example gets the alert action parameters and prints them to the log\n    hostname = helper.get_param(\"hostname\")\n    helper.log_info(\"hostname={}\".format(hostname))\n\n    detection_id = helper.get_param(\"detection_id\")\n    helper.log_info(\"detection_id={}\".format(detection_id))\n\n    action = helper.get_param(\"action\")\n    helper.log_info(\"action={}\".format(action))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n\n    account_id = helper.get_global_setting(\"account_id\")\n    client_id = helper.get_global_setting(\"client_id\")\n    client_secret = helper.get_global_setting(\"client_secret\")\n\n    hostname_param = helper.get_param('hostname')\n\n    hostnames = hostname_param.split(\",\")\n    \n    use_proxy = False\n    if bool(helper.get_proxy()):\n        use_proxy = True\n    helper.log_info(\"Use proxy:\" + str(bool(helper.get_proxy())))\n\n\n    auth_token = get_nebula_client(client_id, client_secret, account_id, helper, use_proxy)\n    machine_ids = get_machine_ids_from_names(auth_token, account_id, hostnames, helper, use_proxy)\n\n\n    #ThreatDown Telemetry code\n    try:\n        telemetry_ts = datetime.datetime.now().strftime(\"%Y-%m-%dT%H:%M:%S.%f\")[:-3]+\"Z\"\n        msg_type = \"INTEGRATION INUSE\"\n\n        data = {\n            \"timestamp\": telemetry_ts,\n            \"integration_code\": \"TA-SPL\",\n            \"integration_name\": \"Splunk\",\n            \"integration_app\": \"ThreatDown Cloud Remediation\",\n            \"integration_app_version\": APP_VERSION,\n            \"nebula_account_id\": account_id,\n            \"ov_account_id\": \"\",\n            \"mbbr_license_key\": \"\",\n            \"api_client_id\": client_id,\n            \"custom_fields\": [],\n            \"msg_type\": msg_type,\n            \"token\": auth_token\n            }\n\n        body = json.dumps(data)\n        telemetry_response = helper.send_http_request(TELEMETRY_LINK, method='POST', parameters=None, payload=body, headers = None, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n        tel_resp_body = telemetry_response.json()\n        helper.log_debug(\"Telemetry response: \"  + str(tel_resp_body))\n\n    except:\n        helper.log_debug(\"Cannot send telemetry data \")\n        error_full_message = str(traceback.format_exc())\n        helper.log_debug('Error message: '+ str(error_full_message))\n\n\n    try:\n        if helper.get_param('action') is not None :\n            action_type_param = helper.get_param('action')\n            detection_id = helper.get_param('detection_id')\n            helper.log_info(\"MBCR: ALERT SA ACTION: Run [\" + str(action_type_param) + \"] for hostname [\"+ str(hostnames) +\"]\")\n            \n            command_executed = False\n            action_response = None\n            if action_type_param == \"remediate\":\n                action_response = perform_sa_remediate(auth_token,account_id, machine_ids[0], detection_id, helper, use_proxy )\n                command_executed = True\n\n            if action_type_param in SA_OPEN_CLOSE:\n                action_response = perform_sa_open_close(auth_token, account_id, machine_ids[0], action_type_param, detection_id, helper, use_proxy)\n                command_executed = True\n\n\n            if action_response is not None and command_executed:\n                ts = int(datetime.datetime.now().timestamp())\n                event_str =\"detection_id=\" + detection_id + \" machine_id=\" + machine_ids[0] + \" type=\" + \"sa_alert\" + \" command=\" + action_type_param +\" timestamp=\" + str(ts) + \" \"\n                helper.addevent(event_str, sourcetype=\"mwb:mbcr_alert\", cam_header=False)\n\n                write_event_success = helper.writeevents(host=None, source=\"test_mwb_source\", fext=\"mwb_test_fext\")\n                helper.log_info(\"new event:\" + event_str)\n                helper.log_info(\"Action event is created: \" + str(write_event_success))\n            else:\n                return 4\n    \n        helper.log_info(\"Action result (Nebula Response): \" + str(action_response))\n        helper.log_info(\"Alert action mbcr finished!\")\n        helper.log_info(\"==========================\")\n\n    except Exception as e:\n        error_full_message = str(traceback.format_exc())\n        helper.log_error('Can\\'t create Endpoint event! Message:'+ str(error_full_message))\n        return 5\n", "uuid": "5d440e4959e34dc88be8582052dc8208"}, {"description": "Sends Alert (Creates Job) to ThreatDown Nebula", "largeIcon": "", "smallIcon": "", "label": "ThreatDown Nebula Remediation Alerts", "short_name": "mbcr_alert", "active_response": {"technology": [{"vendor": "Malwarebytes", "product": "IR, EP, EPR", "version": ["2.0.4"]}], "supports_adhoc": true, "category": ["Endpoint Protection and Response"], "task": ["block", "scan", "isolate"], "subject": ["endpoint"]}, "parameters": [{"format_type": "text", "required": true, "name": "hostname", "label": "Hostname", "default_value": "", "help_string": "", "type": "", "value": ""}, {"format_type": "dropdownlist", "required": true, "name": "action", "label": "Action", "default_value": "", "help_string": "", "possible_values": {"Scan and Report": "scan", "Scan and Quarantine": "remove", "Isolate Endpoint": "isolate", "Isolate Desktop": "isolatedesktop", "Isolate Process": "isolateprocess", "Isolate Network": "isolatenetwork", "Deisolate Endpoint": "deisolate"}, "type": ""}], "code": "\n# encoding = utf-8\nfrom __future__ import print_function\nimport json\nimport base64\nimport traceback\nimport datetime\n\n\nAPI_LINK = \"https://api.malwarebytes.com\"\nTELEMETRY_LINK = \"https://api-msp-telemetry.malwarebytes.com/data\"\nAPP_VERSION = \"2.0.4\"\n\n\nSCAN_ACTIONS_LIST = [\"scan\", \"remove\"]\nISOLATION_ACTION_LIST = [\"isolate\", \"isolatedesktop\", \"isolateprocess\", \"isolatenetwork\"]\nCHECKPOINTS_NAME = \"mbcr_alerts\"\n\n\n# Get Path for OAuth token\ndef NEBULA_URL(path):\n\n    return \"{NEBULA_URL}{PATH}\".format(NEBULA_URL=API_LINK, PATH=path)\n\n\n# Get OAuth2 token\ndef get_nebula_client(client_id, client_secret, account_id, helper, user_proxy):\n\n    token_url=NEBULA_URL('/oauth2/token')\n    creds = \"{}:{}\".format(client_id,client_secret)\n    auth_val = base64.b64encode(creds.encode()).decode(\"ascii\")\n    headers = {\n        'Content-Type': 'application/x-www-form-urlencoded',\n        'Authorization': 'Basic {}'.format(auth_val)\n        }\n    payload='grant_type=client_credentials&scope=partner%20a{}'.format(account_id)\n    try:        \n        response = helper.send_http_request(url=token_url, method='POST', parameters=None, payload=payload, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=user_proxy)\n        return \"Bearer \"+response.json()['access_token']\n        \n    except Exception as e:\n        error_full_message = str(traceback.format_exc())\n        helper.log_error('Error message: '+ str(error_full_message))\n        return None\n\n\ndef search_for_enpoints_ids(auth_token, account_id, search_name, helper, use_proxy):\n    url = NEBULA_URL(f'/nebula/v1/endpoints')\n    body = {\"host_name\": search_name}\n    headers = {'Authorization': auth_token, 'accountid': account_id, \"Content-Type\": \"application/json\"}\n\n    # response = requests.request(\"POST\", url, data=json.dumps(body), headers=headers)\n    response = helper.send_http_request(url, method='POST', parameters=None, payload=body, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n\n    if response.status_code == 200:\n        resp = json.loads(response.text)\n        endpoints = resp['endpoints']\n        machine_ids = []\n        for el in endpoints:\n            machine_ids.append(el['machine']['id'])\n        return machine_ids\n\n\ndef scan_endpoints(auth_token, account_id, machine_ids, quarantine, helper, use_proxy):\n    url = NEBULA_URL('/nebula/v1/jobs')\n    helper.log_info(\"MACHINE IDS TO SCAN: \" + str(machine_ids))\n\n    body = {\"machine_ids\": machine_ids, \"command\": \"command.threat.scan\", \"data\": {\"scan_settings\":{\"type\":\"ThreatScan\", \"remove\": quarantine } } }\n    helper.log_info(\"BODY: \" + str(body))\n\n    headers = {\"Content-Type\": \"application/json\", \"Authorization\": auth_token, \"accountid\": account_id}\n    response = helper.send_http_request(url, method='POST', parameters=None, payload=body, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n    \n    helper.log_info(str(response.status_code) + \" : \" + str(response.text))\n    if response.status_code == 201:\n        return response.text\n\n\n\n\n# isolation_action params = [\"desktop\", \"network\", \"process\"]\ndef perform_isolation(auth_token, account_id, machine_ids, isolation_action, helper, use_proxy):\n    url = NEBULA_URL('/nebula/v1/jobs')\n    isolation_dict = get_isolation_dict(isolation_action)\n    body = {\"machine_ids\": machine_ids, \"command\": \"command.edr.isolation\", \"data\": isolation_dict}\n    headers = {\"Content-Type\": \"application/json\", \"Authorization\": auth_token, \"accountid\": account_id}\n    response = helper.send_http_request(url, method='POST', parameters=None, payload=body, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n\n    helper.log_info(str(response.status_code) + \" : \" + str(response.text))\n    if response.status_code == 201:\n        return response.text\n    \n\ndef perform_deisolation(auth_token, account_id, machine_ids, helper, use_proxy):\n    url = NEBULA_URL('/nebula/v1/jobs')\n    body = {\"machine_ids\": machine_ids, \"command\": \"command.edr.unlock\"}\n    headers = {\"Content-Type\": \"application/json\", \"Authorization\": auth_token, \"accountid\": account_id}\n    response = helper.send_http_request(url, method='POST', parameters=None, payload=body, headers = headers, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n\n    helper.log_info(str(response.status_code) + \" : \" + str(response.text))\n    if response.status_code == 201:\n        return response.text\n\n\n\ndef get_isolation_dict(action_type):\n    isolate_params = {\n        \"isolate\":        [\"desktop\", \"network\", \"process\"],\n        \"isolatedesktop\": [\"desktop\"],\n        \"isolateprocess\": [\"process\"],\n        \"isolatenetwork\": [\"network\"]\n    }\n    return dict.fromkeys(isolate_params[action_type], True)\n\n\ndef get_machine_ids_from_names(auth_token, account_id, hostnames, helper, use_proxy):\n    machine_ids  = []\n    for hostname in hostnames:\n        found_ids = search_for_enpoints_ids(auth_token,account_id, hostname, helper, use_proxy)\n        machine_ids.extend(found_ids)\n    return machine_ids\n\n\ndef get_quaranine_boolean_from_action(action_type):\n    return False if action_type == \"scan\" else True\n\n\n\ndef process_event(helper, *args, **kwargs):\n   \n   \n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example sends rest requests to some endpoint\n    # response is a response object in python requests library\n    response = helper.send_http_request(\"http://www.splunk.com\", \"GET\", parameters=None,\n                                        payload=None, headers=None, cookies=None, verify=True, cert=None, timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n\n    # The following example gets and sets the log level\n    helper.set_log_level(helper.log_level)\n\n    # The following example gets the setup parameters and prints them to the log\n    account_id = helper.get_global_setting(\"account_id\")\n    helper.log_info(\"account_id={}\".format(account_id))\n    client_id = helper.get_global_setting(\"client_id\")\n    helper.log_info(\"client_id={}\".format(client_id))\n    client_secret = helper.get_global_setting(\"client_secret\")\n    helper.log_info(\"client_secret={}\".format(client_secret))\n\n    # The following example gets the alert action parameters and prints them to the log\n    hostname = helper.get_param(\"hostname\")\n    helper.log_info(\"hostname={}\".format(hostname))\n\n    action = helper.get_param(\"action\")\n    helper.log_info(\"action={}\".format(action))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n\n    account_id = helper.get_global_setting(\"account_id\")\n    client_id = helper.get_global_setting(\"client_id\")\n    client_secret = helper.get_global_setting(\"client_secret\")\n\n    hostname_param = helper.get_param('hostname')\n\n    hostnames = hostname_param.split(\",\")\n    \n    use_proxy = False\n    if bool(helper.get_proxy()):\n        use_proxy = True\n    helper.log_info(\"Use proxy:\" + str(bool(helper.get_proxy())))\n\n\n    auth_token = get_nebula_client(client_id, client_secret, account_id, helper, use_proxy)\n    machine_ids = get_machine_ids_from_names(auth_token, account_id, hostnames, helper, use_proxy)\n\n\n\n    #Malwarebytes Telemetry code\n    try:\n        telemetry_ts = datetime.datetime.now().strftime(\"%Y-%m-%dT%H:%M:%S.%f\")[:-3]+\"Z\"\n        msg_type = \"INTEGRATION INUSE\"\n\n        data = {\n            \"timestamp\": telemetry_ts,\n            \"integration_code\": \"TA-SPL\",\n            \"integration_name\": \"Splunk\",\n            \"integration_app\": \"ThreatDown Cloud Remediation\",\n            \"integration_app_version\": APP_VERSION,\n            \"nebula_account_id\": account_id,\n            \"ov_account_id\": \"\",\n            \"mbbr_license_key\": \"\",\n            \"api_client_id\": client_id,\n            \"custom_fields\": [],\n            \"msg_type\": msg_type,\n            \"token\": auth_token\n            }\n\n        body = json.dumps(data)\n        telemetry_response = helper.send_http_request(TELEMETRY_LINK, method='POST', parameters=None, payload=body, headers = None, cookies=None, verify=True,cert=None, timeout=30, use_proxy=use_proxy)\n        tel_resp_body = telemetry_response.json()\n        helper.log_debug(\"Telemetry response: \"  + str(tel_resp_body))\n\n    except:\n        helper.log_debug(\"Cannot send telemetry data \")\n        error_full_message = str(traceback.format_exc())\n        helper.log_debug('Error message: '+ str(error_full_message))\n\n\n\n\n    respond_from_nubula = \"\"\n\n\n    if helper.get_param('action') is not None:\n        action_type_param = helper.get_param('action')\n        helper.log_info(\"ALERT ACTION: Run [\" + str(action_type_param) + \"] for hostname [\"+ str(hostnames) +\"]\")\n\n        command_executed = False\n        action_response = None\n        \n        if action_type_param in SCAN_ACTIONS_LIST:\n            action_response = scan_endpoints(auth_token, account_id, machine_ids, get_quaranine_boolean_from_action(action_type_param), helper, use_proxy)\n            respond_from_nubula = action_response\n            command_executed = True\n        \n        elif action_type_param in ISOLATION_ACTION_LIST:\n            action_response = perform_isolation(auth_token, account_id, machine_ids, action_type_param, helper, use_proxy)\n            respond_from_nubula = action_response\n            command_executed = True\n\n        elif action_type_param == \"deisolate\":\n            action_response = perform_deisolation(auth_token, account_id, machine_ids, helper, use_proxy)\n            respond_from_nubula = action_response\n            command_executed = True\n\n        try:\n            if command_executed and action_response is not None:\n                ts = str(datetime.datetime.now().strftime(\"%Y-%m-%dT%H:%M:%S.%f\")[:-3])+\"Z\"\n\n                for el in json.loads(action_response)[\"jobs\"]:\n                    helper.log_info(type(el))\n\n                    event_str = \"job_id=\" + str(el[\"job_id\"]) + \" machine_id=\" + str(el[\"machine_id\"]) +  \" type=\" + \"job_detections\"  +\" timestamp=\" + str(ts) + \" \"\n\n                    helper.addevent(event_str, sourcetype=\"mwb:mbcr_alert\", cam_header=False)\n\n                    write_event_success = helper.writeevents(host=None, source=\"test_mwb_source\", fext=\"mwb_test_fext\")\n                    helper.log_info(\"new event:\" + event_str)\n                    helper.log_info(\"Action event is created: \" + str(write_event_success))\n            else:\n                return 4\n            \n            helper.log_info(\"Action result (Nebula Response): \" + str(respond_from_nubula))\n            helper.log_info(\"Alert action mbcr finished!\")\n            helper.log_info(\"==========================\")\n\n        except Exception as e:\n            error_full_message = str(traceback.format_exc())\n            helper.log_error('Can\\'t create Endpoint event! Message:'+ str(error_full_message))\n            return 5\n", "uuid": "c61dadf47edb4648a98a0c1f5b408c85"}]}, "basic_builder": {"appname": "mbcr", "friendly_name": "ThreatDown Cloud Remediation", "version": "3.0.6", "author": "ThreatDown", "description": "ThreatDown Cloud Remediation App.", "theme": "#3c6188", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 9}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}, "customized_settings": [{"format_type": "text", "required": true, "name": "account_id", "label": "ThreatDown Nebula Account ID", "default_value": "", "help_string": "", "internal_name": "", "type": "text", "value": ""}, {"format_type": "text", "required": true, "name": "client_id", "label": "ThreatDown Nebula Client ID", "default_value": "", "help_string": "", "internal_name": "", "type": "text", "value": ""}, {"format_type": "password", "required": true, "name": "client_secret", "label": "ThreatDown Nebula Secret", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {}}