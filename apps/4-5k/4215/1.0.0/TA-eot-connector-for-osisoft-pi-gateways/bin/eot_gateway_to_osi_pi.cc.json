{
    "tokens": [
        "__settings__.logging.loglevel", 
        "account.username", 
        "account.password", 
        "hostname", 
        "port"
    ], 
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "requests": [
        {
            "post_process": {
                "pipeline": [
                    {
                        "output": "__stdout__", 
                        "input": [
                            "{{__response__.body}}", 
                            "$.$.[*]"
                        ], 
                        "method": "json_path"
                    }, 
                    {
                        "output": "__stdout__", 
                        "input": [
                            "{{__stdout__}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "method": "splunk_xml"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}"
                        ], 
                        "method": "std_output"
                    }
                ], 
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.$.[*]"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "iteration_mode": {
                "iteration_count": "1", 
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.$.[*]"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "pre_process": {
                "pipeline": [], 
                "skip_conditions": []
            }, 
            "request": {
                "headers": {}, 
                "url": "https://{{hostname}}:{{port}}/", 
                "method": "GET", 
                "auth": {
                    "type": "basic_auth", 
                    "options": {
                        "password": "{{account.password}}", 
                        "username": "{{account.username}}"
                    }
                }
            }
        }
    ]
}