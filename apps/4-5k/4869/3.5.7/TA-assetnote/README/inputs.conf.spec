[assetnote_assetgroups_download://<name>]
assetnote_account = Assetnote API key available from the Assetnote console
assetnote_instance = Assetnote Instance to use. The script connects to <assetnote-instance>.assetnotecloud.com to download Graphql data
backoff_time_per_page_retry = Back-Off Time per page retry
num_retries_per_page = Number of retries to perform per page in-case of failure
sleep_time_per_page = Number of seconds to sleep before getting the next page
limit_num_pages_returned = Limit the number of pages downloaded for purposes of testing

