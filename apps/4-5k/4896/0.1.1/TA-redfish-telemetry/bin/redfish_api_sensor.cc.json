{
    "meta": {
        "apiVersion": "1.0.0"
    },
    "tokens": [
        "global_account.username",
        "global_account.password"
    ],
    "global_settings": {
        "logging": {
            "level": "INFO"
        }
    },
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [],
                "pipeline": []
            },
            "request": {
                "url": "https://{{__settings__.additional_parameters.ip_address}}/redfish/v1/TelemetryService/MetricReports/Sensor",
                "method": "GET",
                "headers": {
                    "Accept": "application/json"
                },
                "auth": {
                    "type": "basic_auth",
                    "options": {
                        "username": "{{global_account.username}}",
                        "password": "{{global_account.password}}"
                    }
                }
            },
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$..MetricValues[*]"
                        ],
                        "method": "json_empty"
                    }
                ],
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$..MetricValues[*]"
                        ],
                        "method": "json_path",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}",
                            "",
                            "{{index}}",
                            "{{host}}",
                            "{{source}}",
                            "{{sourcetype}}"
                        ],
                        "method": "splunk_xml",
                        "output": "__stdout__"
                    },
                    {
                        "input": [
                            "{{__stdout__}}"
                        ],
                        "method": "std_output"
                    }
                ]
            },
            "iteration_mode": {
                "iteration_count": "1",
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}",
                            "$.$..MetricValues[*]"
                        ],
                        "method": "json_empty"
                    }
                ]
            }
        }
    ]
}