# Application-level permissions
[]
access = read : [ admin, sc_admin, vj_admin ], write : [ admin, sc_admin, vj_admin ]
owner = nobody

### PROPS
[props]
access = read : [ admin, sc_admin, vj_admin, vj_user ], write : [ admin, sc_admin, vj_admin ]
export = system
owner = nobody


### TRANSFORMS
[transforms]
access = read : [ admin, sc_admin, vj_admin, vj_user ], write : [ admin, sc_admin, vj_admin ]
export = system
