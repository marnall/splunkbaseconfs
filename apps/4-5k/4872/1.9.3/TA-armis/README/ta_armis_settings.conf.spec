[proxy]
proxy_enabled = <bool> Should the proxy enabled or not
proxy_type = <string> type of the proxy i.e. http, sock4 or sock5
proxy_url = <string> Proxy url
proxy_port = <integer> Proxy port
proxy_username = <string> Username for the proxy server
proxy_password = <string> Password for the proxy server user

[logging]
loglevel = 

[splunk_rest_host]
splunk_rest_host_url = The URL of the Splunk server
splunk_rest_port = The Management port of the Splunk server
splunk_username = The username of the Splunk server
splunk_password = The password of the Splunk server
splunk_verify_cert = Boolean to decide if SSL certificate validation should be done or not