# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

### EVENT TYPES

[eventtypes]
export = system

### PROPS

[props]
export = system

### TRANSFORMS

[transforms]
export = system

### LOOKUPS

[lookups]
export = system

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system


#We set this to allow less privileged users in Splunk to add entries to the KV Store
[transforms/SubmittedFeedback]
access = read : [ * ], write : [ * ]

#We set this to allow less privileged users in Splunk to add entries to the KV Store
[collections/SubmittedFeedback]
access = read : [ * ], write : [ * ]