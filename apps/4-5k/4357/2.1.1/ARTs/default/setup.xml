<setup>
    <block title="JIRA Settings" endpoint="jira_setup/jira_settings" entity="jira_settings">
        <input field="enabled_jira">
            <label>Enabled JIRA</label>
            <type>bool</type>
        </input>
        <input field="jira_server_url">
            <label>JIRA server url</label>
            <type>text</type>
        </input>
        <input field="jira_username">
            <label>JIRA user name</label>
            <type>text</type>
        </input>
        <input field="jira_password">
            <label>JIRA password</label>
            <type>password</type>
        </input>
    </block>
</setup>

