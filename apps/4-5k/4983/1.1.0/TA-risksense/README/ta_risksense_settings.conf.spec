[logging]
loglevel = <string> Defaults to INFO

[proxy]
proxy_enabled = <boolean | integer> True if proxy is enabled
proxy_password = <string> Password to connect to proxy
proxy_port = <number> Port at which proxy is running
proxy_type = <strinng> http | https | socks4 | socks5
proxy_url = <string> URL of the proxy instance
proxy_username = <string> Username of proxy
