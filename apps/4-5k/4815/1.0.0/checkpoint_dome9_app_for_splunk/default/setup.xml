<setup>
	<block title="Checkpoint Dome9 Configuration" endpoint="checkpointsetup" entity="API">
		<text>To run the action on your alerts select the checkbox and configure the required information or click on "Save" to skip.</text>
		<input field="show_settings">
			<label>Configure Dome9 API Key &amp; Token</label>
			<type>bool</type>
		</input>
		<input field="api_key">
			<label>API Key</label>
			<type>text</type>
		</input>
		<input field="secret_key">
			<label>Secret Key (Password)</label>
			<type>password</type>
		</input>
		<input field="is_proxy_enabled">
            <label>Enable Proxy</label>
            <type>bool</type>
        </input>
        <input field="proxy_scheme">
            <label>Proxy Scheme (Protocol)</label>
            <type>text</type>
        </input>
        <input field="proxy_ip">
            <label>IP/Hostname</label>
            <type>text</type>
        </input>
        <input field="proxy_port">
            <label>Port</label>
            <type>text</type>
        </input>
        <input field="proxy_is_auth_required">
            <label>Require Authentication for Proxy</label>
            <type>bool</type>
        </input>
        <input field="proxy_username">
            <label>Username</label>
            <type>text</type>
        </input>
        <input field="proxy_password">
            <label>Password</label>
            <type>password</type>
        </input>
	</block>
</setup>