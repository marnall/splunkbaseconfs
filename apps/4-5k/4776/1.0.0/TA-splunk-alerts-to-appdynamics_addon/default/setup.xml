<setup>
    <block title="Alert Action - Appdynamics Configuration" endpoint="splunk_ta_appdynamics/alert_configuration" entity="appdynamics_alert"> 
        <text>Provide the following details to copy alert file to shared directory.</text>
        <input field="appdynamics_url">
            <label>Appdynamics URL</label>
            <type>text</type>
        </input>
        <input field="access_token">
            <label>Access Token</label>
            <type>text</type>
        </input>
        <text>
            <![CDATA[ <script type="text/javascript">
                $(function(){
                    // Description text for each input
                    var appdynamics_url = $("#\\/splunk_ta_appdynamics\\/alert_configuration\\/appdynamics_alert\\/appdynamics_url_id");
                    var access_token = $("#\\/splunk_ta_appdynamics\\/alert_configuration\\/appdynamics_alert\\/access_token_id");

                    appdynamics_url.after('<p class="helpText" style="margin: 10px 0 0;">Example - https://demo.saas.appdynamics.com</p>');
                    access_token.after('<p class="helpText" style="margin: 10px 0 0;">Provide API access token to send events. Use the given link to create api token, <a href="https://docs.appdynamics.com/display/PRO45/API+Clients" target="_blank">Click Here</a></p>');
                });
            </script> ]]>
        </text>
    </block>
</setup>