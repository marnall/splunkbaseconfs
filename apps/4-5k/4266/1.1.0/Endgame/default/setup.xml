<setup>
    <block title="Configure Endgame App settings"  endpoint="endgame/endgameconf" entity="app_config">
        <input field="base_url">
            <label>Endgame API Base URL</label>
            <type>text</type>
        </input>
		<input field="native_base_url">
            <label>Endgame Base URL</label>
            <type>text</type>
        </input>
	</block>
	<block title="Enter your Endgame credentials" endpoint="storage/passwords" entity="_new">
        <input field="name">
            <label>Endgame Username</label>
            <type>text</type>
        </input>
        <input field="password">
            <label>Endgame Password</label>
            <type>password</type>
        </input>
        <input field="realm">
                <label>Realm</label>
                <type>text</type>
        </input>
    </block>
</setup>
