# Application-level permissions

[]
access = read : [ * ], write : [ admin,sc_admin]
export = system

[views]
access = read : [ * ], write : [ admin,sc_admin ]
export = none

[eventtypes]
access = read : [ * ], write : [ admin,sc_admin ]
export = system

[macros]
access = read : [ * ], write : [ admin,sc_admin ]
export = system

[tags]
access = read : [ * ], write : [ admin,sc_admin ]
export = system

[datamodels]
access = read : [ * ], write : [ admin,sc_admin ]
export = system

[models]
access = read : [ * ], write : [ admin,sc_admin ]
export = system
