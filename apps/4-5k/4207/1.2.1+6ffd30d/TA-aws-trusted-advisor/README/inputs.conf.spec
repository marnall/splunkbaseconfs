[aws_trusted_advisor://<name>]
aws_access_key = Optional when running on AWS  - Instance profile used if not specified
aws_secret_key = Optional when running on AWS  - Instance profile used if not specified
index = Default: default
interval = Time interval of input in seconds.
role_arn = Optional - Assume the following role to collect data (arn:aws:iam::1234567890123:role/myRoleName)
