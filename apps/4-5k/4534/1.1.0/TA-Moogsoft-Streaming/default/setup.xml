<setup>
    <block title="Configure Moogsoft Integration"  endpoint="moogsoft/moogconf" entity="moogsoft">
        <input field="url">
            <label>Moogsoft Integration URL</label>
            <type>text</type>
        </input>
        <input field="severity">
            <label>Default Alert Severity</label>
            <type>text</type>
        </input>
        <text>Alert Severity</text>
        <input field="moog_certificate">
            <label>Moogsoft Certificate Path</label>
            <type>text</type>
        </input>
        <text>Moogsoft Certificate required for SSL Communication (certificate format should be .pem)</text>
        <input field="max_batch_size">
            <label>Max Batch Size (KB)</label>
            <type>text</type>
        </input>
        <text>Batch size can not be less than 1000, there is no upper limit.</text>
    </block>
</setup>
