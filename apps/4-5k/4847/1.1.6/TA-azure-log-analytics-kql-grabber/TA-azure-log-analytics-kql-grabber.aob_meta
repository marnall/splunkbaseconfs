{"basic_builder": {"appname": "TA-azure-log-analytics-kql-grabber", "friendly_name": "Azure Log Analytics KQL Grabber", "version": "1.1.6", "author": "Leonardo Armesto", "description": "With Azure Log Analytics, you can gather log data from all of your resources.  Why not inject all this data into Splunk?", "theme": "#c4dff6", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.0.0", "tab_build_no": "0", "build_no": 10}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "kql", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "azure_log_analytics", "title": "Azure Log Analytics", "description": "", "type": "customized", "parameters": [{"name": "tenant_id", "label": "Tenant ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "7288177b-76ab-474e-8fd4-ea1afbe9ae68"}, {"name": "client_id", "label": "Client ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "7533e56c-0751-4b62-b9e8-58a979e59e9a"}, {"name": "client_secret", "label": "Client Secret", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "log_analytics_workspace_id", "label": "Log Analytics Workspace ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "86414567-5563-4a04-9d2f-6547c4551b10"}, {"name": "log_analytics_query", "label": "Log Analytics Query", "help_string": " Kusto query language to retrieve log data.", "required": true, "format_type": "text", "default_value": "", "placeholder": "AzureMetrics | where TimeGenerated > now(-10m)", "type": "text", "value": "SigninLogs | where TimeGenerated > ago(1h) | project tostring(TimeGenerated), UserDisplayName, Identity,UserPrincipalName,  AppDisplayName, AppId, ResourceDisplayName, IPAddress, Location, tostring(DeviceDetail.deviceId), UserAgent, ClientAppUsed"}, {"name": "output_format", "label": "Output Format", "help_string": "Data ingestion format", "required": true, "possible_values": [{"value": "csv", "label": "CSV"}, {"value": "json", "label": "JSON"}], "format_type": "radiogroup", "default_value": "csv", "type": "radiogroup", "value": "csv"}, {"name": "cust_source_type", "label": "Custom Source Type", "help_string": "Default is kql", "required": false, "format_type": "text", "default_value": "", "placeholder": "kql", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "tenant_id", "title": "Tenant ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "client_id", "title": "Client ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "client_secret", "title": "Client Secret", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "log_analytics_workspace_id", "title": "Log Analytics Workspace ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "log_analytics_query", "title": "Log Analytics Query", "description": " Kusto query language to retrieve log data.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "AzureMetrics | where TimeGenerated > now(-10m)"}, {"type": "customized_var", "name": "output_format", "title": "Output Format", "description": "Data ingestion format", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "csv", "label": "CSV"}, {"value": "json", "label": "JSON"}], "format_type": "radiogroup", "default_value": "csv"}, {"type": "customized_var", "name": "cust_source_type", "title": "Custom Source Type", "description": "Default is kql", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "kql"}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport datetime\nimport time\nimport requests, urllib3\nimport json\n\ndef get_token(url, resource, username, password):\n    payload = {\n        'grant_type': 'client_credentials',\n        'client_id': username,\n        'client_secret': password,\n        'Content-Type': 'x-www-form-urlencoded',\n        'resource': resource,\n        }\n    \n    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)\n    ApiReturn = requests.post(url, data=payload, verify=False)\n    ApiToken = json.loads(ApiReturn.content)[\"access_token\"]\n    \n    return {\n        'Authorization': 'Bearer ' + ApiToken, \n        'Content-Type': 'application/json'\n        }\n\ndef validate_input(helper, definition):\n    tenant_id = definition.parameters.get('tenant_id', None)\n    client_id = definition.parameters.get('client_id', None)\n    client_secret = definition.parameters.get('client_secret', None)\n    log_analytics_workspace_id = definition.parameters.get('log_analytics_workspace_id', None)\n    log_analytics_query = definition.parameters.get('log_analytics_query', None)\n    cust_source_type = definition.parameters.get('cust_source_type', None)\n    output_format = definition.parameters.get('output_format', None)\n\ndef collect_events(helper, ew):\n    opt_tenant_id = helper.get_arg('tenant_id')\n    opt_client_id = helper.get_arg('client_id')\n    opt_client_secret = helper.get_arg('client_secret')\n    opt_log_analytics_workspace_id = helper.get_arg('log_analytics_workspace_id')\n    opt_log_analytics_query = helper.get_arg('log_analytics_query')\n    opt_cust_source_type = helper.get_arg('cust_source_type')\n    opt_output_format = helper.get_arg('output_format')\n    \n    if opt_cust_source_type == '':\n        opt_cust_source_type = 'kql'\n    \n    try:\n        loginURL = \"https://login.microsoftonline.com/\" + opt_tenant_id + \"/oauth2/token\"\n        resource = \"https://api.loganalytics.io\"\n        url = \"https://api.loganalytics.io/v1/workspaces/\" + opt_log_analytics_workspace_id + \"/query\"\n        \n        Headers = get_token(loginURL, resource, opt_client_id, opt_client_secret)\n        params = {\n            \"query\": opt_log_analytics_query\n            }\n        \n        result = requests.get(url, params=params, headers=Headers, verify=False)\n        \n        if opt_output_format == 'csv':\n        \n            rows = len(result.json()[\"tables\"][0][\"rows\"])\n        \n            for row in range(0, rows):\n                data = json.dumps(result.json()[\"tables\"][0][\"rows\"][row]).strip(\"[]\").replace(\"'\",\"\")\n                \n                event = helper.new_event(data, host=None, source=None, sourcetype=opt_cust_source_type, done=True, unbroken=True)\n        \n                try:\n                    ew.write_event(event)\n                except Exception as e:\n                    raise e\n        \n        elif opt_output_format == 'json':\n            columns = result.json()[\"tables\"][0][\"columns\"]\n            column_length = len(result.json()[\"tables\"][0][\"columns\"])\n            \n            for row in result.json()[\"tables\"][0][\"rows\"]:\n                data = {}\n                \n                for i in range(0,column_length):\n                    data[columns[i]['name']] = row[i]\n                \n                data = json.dumps(data)\n\n                event = helper.new_event(data, host=None, source=None, sourcetype=opt_cust_source_type, done=True, unbroken=True)\n                try:\n                    ew.write_event(event)\n                except Exception as e:\n                    raise e        \n\n    except Exception as e:\n        raise e", "customized_options": [{"name": "tenant_id", "value": ""}, {"name": "client_id", "value": ""}, {"name": "log_analytics_workspace_id", "value": ""}, {"name": "log_analytics_query", "value": ""}, {"name": "output_format", "value": "json"}, {"name": "cust_source_type", "value": ""}], "uuid": "9db37af1ef1d4e2f858bc5c28752a647", "sample_count": 0}]}, "field_extraction_builder": {"kql": {"data_format": "tabular", "table_results": {"delim": ","}}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}}}, "sourcetype_builder": {"kql": {"metadata": {"event_count": 0, "data_input_name": "azure_log_analytics", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1642623432_68", "progress": 0.5}}