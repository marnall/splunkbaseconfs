<setup>
   <block title="openVulnQuery API Setup Page">
  </block>

  <block title="API credentials"
         endpoint="ovquery_setup/ovquery_settings" entity="ovquery_settings">

    <input field="client_id">
      <label>Client ID</label>
      <type>text</type>
    </input>

    <input field="client_secret">
      <label>Client Secret</label>
      <type>password</type>
    </input>
    <text><![CDATA[<a href="https://apiconsole.cisco.com">See documentation on how to acquire the API credentials</a>]]></text>

    <input field="ovquery_debug">
      <label>Enable Debug Logging</label>
      <type>bool</type>
    </input>

  </block>
</setup>

