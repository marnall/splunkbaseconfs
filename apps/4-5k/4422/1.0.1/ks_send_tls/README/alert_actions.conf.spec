[ks_send_tls]

param.shipper_host = <string>
* Shipper hostname or IP where to fire the alert

param.shipper_port = <integer>
* Shipper TCP port number where to fire the alert

param.shipper_certificate = <string>
* Shipper certificate used for the TLS connection

param.snow_alerting_domain = <string>
* Name of the company alerting domain in snow related to the splunk search server CI
