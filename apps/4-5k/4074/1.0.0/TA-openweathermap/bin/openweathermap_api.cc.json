{
    "requests": [
        {
            "request": {
                "method": "GET", 
                "url": "http://api.openweathermap.org/data/2.5/weather?q={{place}}&units={{units}}&appid={{api_key}}", 
                "headers": {}
            }, 
            "pre_process": {
                "skip_conditions": [], 
                "pipeline": []
            }, 
            "iteration_mode": {
                "stop_conditions": [], 
                "iteration_count": "1"
            }, 
            "post_process": {
                "skip_conditions": [
                    {
                        "method": "json_empty", 
                        "input": [
                            "{{__response__.body}}", 
                            "$"
                        ]
                    }
                ], 
                "pipeline": [
                    {
                        "method": "splunk_xml", 
                        "input": [
                            "{{__response__.body}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "output": "__stdout__"
                    }, 
                    {
                        "method": "std_output", 
                        "input": [
                            "{{__stdout__}}"
                        ]
                    }
                ]
            }
        }
    ], 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "tokens": [
        "__settings__.logging.loglevel", 
        "unit", 
        "place", 
        "api_key"
    ]
}