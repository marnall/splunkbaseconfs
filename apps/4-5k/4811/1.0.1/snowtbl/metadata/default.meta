
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]
export = none

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system
owner = nobody

[nav/default]
access = read : [ * ], write : [ admin, power ]
export = system
owner = nobody

[views/config]
access = read : [ admin ], write : [ admin ]
export = system
owner = nobody

[views/snow_table_alert_incident_count]
access = read : [ * ], write : [ admin, power ]
export = system
owner = nobody

[views/help]
access = read : [ * ], write : [ admin, power ]
export = system
owner = nobody

