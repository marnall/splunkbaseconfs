            <label>disabled [$name$] </label>
            <type>text</type>
        </input>
        <input field="interval">
            <label>Set the interval [$name$] </label>
            <type>text</type>
        </input>
        <input field="index">
            <label>Set the index [$name$] </label>
            <type>text</type>
        </input>
    </block>
</setup>