[azure_devops_main://<name>]
global_account = Account details need to be entered in the add-on's configuration settings in order for them to be selectable here
organization = The name of the Azure DevOps organization. N.B This MUST be populated if details of a custom endpoint have not been provided in the setup params
project = The name or ID (GUID) of the team project containing the team.
team = The name or ID (GUID) of the team.
work_item_types = Types of Work Items to Retrieve (Optional)
get_previous_work_items = Get Completed Work Items Associated With Previous Iterations. NOTE: This will increase licence use and should only be enabled with care!
get_team_info = Iteration and Capacity Info (Optional)