<setup>
  <block title="TCP Sender" endpoint="data/outputs/tcp/syslog" entity="syslog:diode-syslog-tcp">
    <text>TCP Sender configuration</text>
    <input field="disabled" old_style_disable="true">
      <label>Enabled</label>
      <type>bool</type>
    </input>
    <input field="server">
      <label>Destination (for example: 10.1.1.1:6003</label>
      <type>text</type>
    </input>
  </block>
  <block title="UDP sender" endpoint="data/outputs/udp" entity="syslog:diode-syslog-udp">
    <text>UDP sender configuration</text>
    <input field="disabled" old_style_disable="true">
      <label>Enabled</label>
      <type>bool</type>
    </input>
    <input field="server">
      <label>Destination (for example: 10.1.1.1:6003</label>
      <type>text</type>
    </input>
  </block>
</setup>
