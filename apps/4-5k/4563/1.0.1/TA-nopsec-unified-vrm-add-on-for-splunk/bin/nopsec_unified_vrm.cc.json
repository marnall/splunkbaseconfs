{
    "requests": [
        {
            "iteration_mode": {
                "iteration_count": "1", 
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.results"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "post_process": {
                "pipeline": [
                    {
                        "output": "__stdout__", 
                        "input": [
                            "{{__response__.body}}", 
                            "$.results"
                        ], 
                        "method": "json_path"
                    }, 
                    {
                        "output": "__stdout__", 
                        "input": [
                            "{{__stdout__}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "method": "splunk_xml"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}"
                        ], 
                        "method": "std_output"
                    }
                ], 
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.results"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "pre_process": {
                "pipeline": [], 
                "skip_conditions": []
            }, 
            "request": {
                "headers": {
                    "X-UVRM-API-KEY": "{{nopsec_unified_vrm_api_key}}"
                }, 
                "url": "https://api.nopsec.com/api/threat/export?filters=%7B%7D&query=&sortBy=riskScore-desc&limit=-1", 
                "method": "GET"
            }
        }
    ], 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "tokens": [
        "__settings__.logging.loglevel", 
        "nopsec_unified_vrm_api_key"
    ]
}