[observeit_api://<name>]
reports_api_url = API URL optionally including port. E.g. https://observeit.mycompany.com:443/v2/apis/report;realm=observeit/reports
client_id = Create app in API Console, e.g. https://observeit.mycompany.com/v2/apps/portal/home.html?#creds
client_secret = 
past_data_hours = WARNING: Updating this value on an active input will result in data duplication.
events_pagination = Amount of events to index per input invocation
reports_to_collect = 
ca_certificate_chain = Path to CA certificate chain file, relative to $SPLUNK_HOME. Default CA certificates will be used if no file name provided.