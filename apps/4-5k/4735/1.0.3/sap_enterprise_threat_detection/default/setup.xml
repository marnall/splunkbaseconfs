<setup>
    <block title="Splunk Alert Action for SAP® Enterprise Threat Detection">
        <text>Configuration for the deployed SAP® Enterprise Threat Detection server with Splunk alert handling capability.</text>
    </block>
    <block title="" endpoint="admin/alert_actions" entity="sap_etd">
        <input field="param.base_url">
            <label>Base URL</label>
            <type>text</type>
        </input>
        <input field="param.username">
          <label>Username</label>
          <type>text</type>
        </input>
    </block>
    <block title="" endpoint="storage/passwords" entity="sap_etd_user*" eai_strict="false">
        <input field="password">
          <label>Password</label>
          <type>password</type>
        </input>
    </block>
</setup>
