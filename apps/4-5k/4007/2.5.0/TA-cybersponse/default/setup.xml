<setup>
    <block title="CyberSponse Configuration" endpoint="cssetup/csconfig" entity="config">
        <input field="address">
            <label>CyberSponse Address (IP/Hostname)*</label>
            <type>text</type>
        </input>
        <input field="verify_ssl">
            <label>Verify CyberSponse SSL Cert?</label>
            <type>bool</type>
        </input>
        <input field="public_key">
            <label>Appliance Public Key*</label>
            <type>text</type>
        </input>
        <input field="private_key">
            <label>Appliance Private Key*</label>
            <type>text</type>
        </input>
        <input field="tag">
            <label>Playbook Tag to filter CyberSponse Playbooks listing</label>
            <type>text</type>
        </input>
        <input field="debug">
            <label>Enable debug logging?</label>
            <type>bool</type>
        </input>
    </block>
</setup>
