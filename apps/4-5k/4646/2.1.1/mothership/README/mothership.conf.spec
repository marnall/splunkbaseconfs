[settings]
poller_metrics_earliest_time = <Time in seconds>
* Environment search list handler runs a search for poller metrics
* This setting determines the earliest time of that search
* Default value is 90000 seconds (24 hours)
job_done_timeout = <Time in seconds>
* Timeout period for remote searches
job_status_interval = <Time in milliseconds>
* Interval between checks for job status
