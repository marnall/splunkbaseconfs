{
    "requests": [
        {
            "iteration_mode": {
                "iteration_count": "1", 
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.$.[*]"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "post_process": {
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.$.[*]"
                        ], 
                        "output": "__stdout__", 
                        "method": "json_path"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "output": "__stdout__", 
                        "method": "splunk_xml"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}"
                        ], 
                        "method": "std_output"
                    }
                ], 
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.$.[*]"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "pre_process": {
                "pipeline": [], 
                "skip_conditions": []
            }, 
            "request": {
                "headers": {}, 
                "method": "GET", 
                "url": "https://api.trello.com/1/boards/{{board_id}}/lists?fields={{fields}}&filter={{filter}}&key={{__settings__.additional_parameters.key}}&token={{__settings__.additional_parameters.token}}"
            }
        }
    ], 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "tokens": [
        "__settings__.logging.loglevel", 
        "__settings__.additional_parameters.key", 
        "__settings__.additional_parameters.token", 
        "board_id", 
        "fields", 
        "filter"
    ]
}