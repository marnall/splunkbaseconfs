{
    "tokens": [
        "__settings__.logging.loglevel", 
        "__settings__.additional_parameters.token", 
        "__settings__.additional_parameters.key", 
        "board_id", 
        "fields"
    ], 
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [], 
                "pipeline": []
            }, 
            "request": {
                "method": "GET", 
                "url": "https://api.trello.com/1/boards/{{board_id}}?fields={{fields}}&key={{__settings__.additional_parameters.key}}&token={{__settings__.additional_parameters.token}}", 
                "headers": {}
            }, 
            "post_process": {
                "skip_conditions": [
                    {
                        "method": "json_empty", 
                        "input": [
                            "{{__response__.body}}", 
                            "$"
                        ]
                    }
                ], 
                "pipeline": [
                    {
                        "method": "splunk_xml", 
                        "output": "__stdout__", 
                        "input": [
                            "{{__response__.body}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ]
                    }, 
                    {
                        "method": "std_output", 
                        "input": [
                            "{{__stdout__}}"
                        ]
                    }
                ]
            }, 
            "iteration_mode": {
                "stop_conditions": [], 
                "iteration_count": "1"
            }
        }
    ], 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "meta": {
        "apiVersion": "1.0.0"
    }
}