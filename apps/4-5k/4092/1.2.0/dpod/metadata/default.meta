# Application-level permissions
[]
access = read : [ * ], write : [ admin, sc_admin ]
export = none
owner = admin

# Views
[views]
access = read: [ * ], write : [ admin, sc_admin ]
export = none
owner = admin

# Tags
[tags]
export = none
owner = admin

# Props
[props]
export = none
owner = admin

# Macros
[macros]
export = none
owner = admin

# Transforms
[transforms]
export = none

# Reports
[savedsearches]
export = none
owner = admin

# Lookups
[lookups]
export = none
owner = admin

# Viewstates: even normal users should be able to create shared viewstates
[viewstates]
access = read : [ * ], write : [ * ]
export = none
