<setup>
    <block title="Credentials for BeeClear data extraction" endpoint="beeclearep/beeclearconf" entity="beeclear_config">
        <input field="host">
            <label>Hostname or IP address of Beeclear device</label>
            <type>text</type>
         </input>
         <input field="country">
             <label>Country: DE or NL</label>
             <type>text</type>
         </input>
    </block>
    <block title="Password" endpoint="storage/passwords" entity="_new">
         <input field="name">
             <label>Username</label>
             <type>text</type>
         </input>
        <input field="password">
            <label>Password</label>
            <type>password</type>
        </input>
    </block>
 </setup>
