[eview-mainframe]
EXTRACT-RMF Data = .+RMF DATA:.+?\s.+?\s+(?<CPU_UTIL>\d+)\s+(?<PAGING_RATE>\d+)\s+(?<SYS_COMMON_PAGES_IN>\d+)\s+(?<SWAP_OUTS>\d+)\s+(?<PAGES_SWAPPED_IN>\d+)\s+(?<PAGES_SWAPPED_OUT>\d+)\s+(?<PRIVATE_PAGES_IN>\d+)\s+(?<PRIVATE_PAGES_OUT>\d+)\s+(?<HIGH_UIC_COUNT>\d+)\s+(?<SYS_LPA_PAGES_IN>\d+)\s+(?<PAGES_TO_EXT>\d+)\s+(?<EXT_SLOTS_AVAIL>\d+)\s+(?<PAGES_MIG_AUX>\d+)\s+(?<AVAIL_FRAME_COUNT>\d+)\s+(?<DEV_ACTIVITY_RATE>\d+)\s+(?<DEV_RESP_TIME>\d+)\s+(?<DEV_IOSQ_TIME>\d+)\s+(?<FIXED_SQA_FRAMES>\d+)\s+(?<COMMON_FIXED_FRAMES>\d+)\s+(?<PRIVATE_FIXED_FRAMES>\d+)\s+(?<AS_IN_STORAGE>\d+)\s+(?<LPA_FRAMES>\d+)\s+(?<CSA_FRAMES>\d+)\s+(?<LPA_FIXED_FRAMES>\d+)\s+(?<CSA_FIXED_FRAMES>\d+)\s+(?<LSQA_FIXED_FRAMES>\d+)\s+(?<AS_LOG_OUT>\d+)
EXTRACT-mainframe-messages = \*ZOSMSG:(?<sysid>\S+)\s+(?<job_name>\S+)\s+(?<job_id>\S+)\s+(?<msg_id>\S+)\s+(?<event_text>.+)
EXTRACT-CICS Transactions = \*ZOSMSG:.+CICSA\s+TRANSACTION\s+(?<cics_transaction>\S+)\s+RESPONSE TIME OF\s+(?<cics_response_time>\S+).+THRESHOLD OF\s+(?<cics_threshold>\S+)
