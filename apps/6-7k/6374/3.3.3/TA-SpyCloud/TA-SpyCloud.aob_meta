{"basic_builder": {"appname": "TA-SpyCloud", "friendly_name": "TA-SpyCloud", "version": "3.2.3", "author": "SpyCloud", "description": "Provides inputs to bring data from the SpyCloud API into Splunk", "theme": "#131B2A", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.2.0", "tab_build_no": "0", "build_no": 5}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "spycloud:watchlist", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "spycloud_watchlist", "title": "SpyCloud Watchlist", "description": "Spycloud Watch List", "type": "customized", "parameters": [{"name": "notes", "label": "Notes", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "notes", "title": "Notes", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport json\nimport time\nimport datetime\nfrom collections import OrderedDict\n\nfrom requests import HTTPError\nimport api\nimport common\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # notes = definition.parameters.get('notes', None)\n    pass\n\ndef collect_events(helper, ew):\n    helper.log_debug(\"input_module_spycloud_watchlist.py start\")\n\n    common.check_api_key(helper, \"input_module_spycloud_watchlist.py\")\n\n    checkpoint_dir = os.path.join(\n        os.environ.get(\"SPLUNK_HOME\"), \"etc\", \"apps\", helper.get_app_name(), \"local\", \"data\"\n    )\n    checkpoint_path = os.path.join(checkpoint_dir, \"watchlist_v2.checkpoint\")\n    try:\n        with open(checkpoint_path, \"r\") as checkpoint_file:\n            checkpoint = json.load(checkpoint_file)\n    except IOError:\n        checkpoint = {\"last_run\": \"1970-01-01\", \"documents\": {}}\n\n    today = common.date_stamp()\n    helper.log_debug(\"today=\" + str(today))\n\n    try:\n        for result in api.watchlist(helper, checkpoint[\"last_run\"]):\n            document_id = result[\"document_id\"]\n            if document_id in checkpoint[\"documents\"].keys():\n                continue\n            # Add to checkpoint object\n            checkpoint[\"documents\"][document_id] = today\n            # Force timestamp to front of event\n            ordered_result = OrderedDict()\n            if \"spycloud_publish_date\" in result:\n                ordered_result[\"spycloud_publish_date\"] = result[\n                    \"spycloud_publish_date\"\n                ]\n                del result[\"spycloud_publish_date\"]\n            for key in result:\n                ordered_result[key] = result[key]\n            data=json.dumps(ordered_result)\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n\n    except HTTPError as http_exception:\n        if http_exception.response.status_code == 403:\n            message = (\n                \"Failed to authenticate to SpyCloud API. \"\n                \"Please make sure you have entered credentials on the app setup page.\"\n            )\n        else:\n            message = \"Received error from SpyCloud API. Error code: {}. {}\".format(http_exception.response.status_code, http_exception.response.text)  # pylint: disable=consider-using-f-string,line-too-long\n        common.make_error_message(helper, message, \"input_module_spycloud_watchlist.py\")\n        sys.exit(0)\n    except Exception as other_exception:  # pylint: disable=broad-except\n        message = \"SpyCloud encountered an error: {}\".format(str(other_exception))  # pylint: disable=consider-using-f-string\n        common.make_error_message(helper, message, \"input_module_spycloud_watchlist.py\")\n        sys.exit(0)\n\n    if not os.path.exists(checkpoint_dir):\n        os.makedirs(checkpoint_dir)\n        \n    checkpoint = common.checkpoint_cleanup(checkpoint)\n    with open(checkpoint_path, \"w\") as checkpoint_file:\n        json.dump(checkpoint, checkpoint_file)\n\n    #helper.log_debug(\"finish_checkpoint=\" + str(checkpoint))\n    helper.log_debug(\"input_module_spycloud_watchlist.py end\")\n", "customized_options": [{"name": "notes", "value": ""}], "uuid": "4e494211a5854ff4beacb2d54e083e1f", "sample_count": "1003"}, {"index": "default", "sourcetype": "spycloud:watchlist_identifiers", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "spycloud_watchlist_identifiers", "title": "SpyCloud Watchlist Identifiers", "description": "Spycloud Watchlist Identifies", "type": "customized", "parameters": [{"name": "notes", "label": "Notes", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "notes", "title": "Notes", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport json\nimport time\nfrom datetime import datetime\nfrom collections import OrderedDict\n\nfrom requests import HTTPError\nimport api\nimport common\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # notes = definition.parameters.get('notes', None)\n    pass\n\ndef collect_events(helper, ew):\n    helper.log_debug(\"input_module_spycloud_watchlist_identifiers.py start\")\n    \n    common.check_api_key(helper, \"input_module_spycloud_watchlist_identifiers.py\")\n        \n    try:\n        for result in api.identifiers(helper):\n            # Identifiers aren't time-indexed so add pull time as a field\n            ordered_result = OrderedDict()\n            ordered_result[\"export_time\"] = datetime.now().strftime(\n                \"%Y-%m-%dT%H:%M:%S.%f\"\n            )\n            for key in result:\n                ordered_result[key] = result[key]\n            data=json.dumps(ordered_result)\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n    except HTTPError as http_exception:\n        if http_exception.response.status_code == 403:\n            message = (\n                \"Failed to authenticate to SpyCloud API. \"\n                \"Please make sure you have entered credentials on the app setup page.\"\n            )\n        else:\n            message = \"Received error from SpyCloud API. Error code: {}. {}\".format(http_exception.response.status_code, http_exceptio.response.text)  # pylint: disable=consider-using-f-string,line-too-long\n        common.make_error_message(helper, message, \"input_module_spycloud_watchlist_identifiers.py\")\n        sys.exit(0)\n    except Exception as other_exception:  # pylint: disable=broad-except\n        message = \"SpyCloud encountered an error: {}\".format(str(other_exception))  # pylint: disable=consider-using-f-string\n        common.make_error_message(helper, message, \"input_module_spycloud_watchlist_identifiers.py\")\n        sys.exit(0)\n\n    #helper.log_debug(\"finish_checkpoint=\" + str(checkpoint))\n    helper.log_debug(\"input_module_spycloud_watchlist_identifiers.py end\")\n", "customized_options": [{"name": "notes", "value": ""}], "uuid": "97af5b262577434da5cc1ea730e33c30", "sample_count": "25"}, {"index": "default", "sourcetype": "spycloud:compass", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "spycloud_compass", "title": "SpyCloud Compass", "description": "Spycloud Compass - Requires Separate LIcense", "type": "customized", "parameters": [{"name": "notes", "label": "Notes", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "notes", "title": "Notes", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport json\nimport time\nimport datetime\n\nfrom collections import OrderedDict\n\nfrom requests import HTTPError\nimport api\nimport common\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # notes = definition.parameters.get('notes', None)\n    pass\n\ndef collect_events(helper, ew):\n    helper.log_debug(\"input_module_spycloud_compass.py start\")\n\n    common.check_api_key(helper, \"input_module_spycloud_compass.py\")\n\n    enable_compass = helper.get_global_setting('enable_compass')\n    helper.log_debug(\"enable_compass=\" + str(enable_compass))\n    if enable_compass is 1 or enable_compass is True or enable_compass is '1':\n        helper.log_debug(\"SpyCloud Compass is Enabled\")\n\n        checkpoint_dir = os.path.join(\n            os.environ.get(\"SPLUNK_HOME\"), \"etc\", \"apps\", helper.get_app_name(), \"local\", \"data\"\n        )\n        checkpoint_path = os.path.join(checkpoint_dir, \"compass_v2.checkpoint\")\n                \n        try:\n            with open(checkpoint_path, \"r\") as checkpoint_file:\n                checkpoint = json.load(checkpoint_file)\n        except IOError:\n            checkpoint = {\"last_run\": \"1970-01-01\", \"documents\": {}}\n\n        today = common.date_stamp()\n        helper.log_debug(\"today=\" + str(today))\n\n        try:\n            for result in api.compass(helper, checkpoint[\"last_run\"]):\n                document_id = result[\"document_id\"]\n                if document_id in checkpoint[\"documents\"].keys():\n                    continue\n                # Add to checkpoint object\n                checkpoint[\"documents\"][document_id] = today\n                # Force timestamp to front of event\n                ordered_result = OrderedDict()\n                if \"spycloud_publish_date\" in result:\n                    ordered_result[\"spycloud_publish_date\"] = result[\n                        \"spycloud_publish_date\"\n                    ]\n                    del result[\"spycloud_publish_date\"]\n                for key in result:\n                    ordered_result[key] = result[key]\n                data=json.dumps(ordered_result)\n                event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n                ew.write_event(event)\n\n        except HTTPError as http_exception:\n            if http_exception.response.status_code == 403:\n                message = (\n                    \"Failed to authenticate to SpyCloud API. \"\n                    \"Please make sure you have entered credentials on the app setup page.\"\n                )\n            else:\n                message = \"Received error from SpyCloud API. Error code: {}. {}\".format(http_exception.response.status_code, http_exception.response.text)  # pylint: disable=consider-using-f-string,line-too-long\n            common.make_error_message(helper, message, \"input_module_spycloud_compass.py\")\n            sys.exit(0)\n        except Exception as other_exception:  # pylint: disable=broad-except\n            message = \"SpyCloud encountered an error: {}\".format(str(other_exception))  # pylint: disable=consider-using-f-string\n            common.make_error_message(helper, message, \"input_module_spycloud_compass.py\")\n            sys.exit(0)\n\n        if not os.path.exists(checkpoint_dir):\n            os.makedirs(checkpoint_dir)\n\n        checkpoint = common.checkpoint_cleanup(checkpoint)\n        with open(checkpoint_path, \"w\") as checkpoint_file:\n            json.dump(checkpoint, checkpoint_file)\n\n    else:\n        helper.log_info(\"SpyCloud Compass is disabled. Enable Compass in the SpyCloud config to load Compass data\")\n    \n    #helper.log_debug(\"finish_checkpoint=\" + str(checkpoint))\n    helper.log_debug(\"input_module_spycloud_compass.py end\")\n", "customized_options": [{"name": "notes", "value": ""}], "uuid": "6e5961e9f24e4254a04ce0d6e5a23e3f", "sample_count": "12010"}, {"index": "default", "sourcetype": "spycloud:breach_catalog", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "spycloud_breach_catalog", "title": "SpyCloud Breach Catalog", "description": "Spycloud Breach Catalog", "type": "customized", "parameters": [{"name": "notes", "label": "Notes", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "notes", "title": "Notes", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport json\nimport time\nimport datetime\nfrom collections import OrderedDict\n\nfrom requests import HTTPError\nimport api\nimport common\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n\n    pass\n\ndef collect_events(helper, ew):\n    helper.log_debug(\"input_module_spycloud_breach_catalog.py start\")\n    \n    common.check_api_key(helper, \"input_module_spycloud_breach_catalog.py\")\n\n    checkpoint_dir = os.path.join(\n        os.environ.get(\"SPLUNK_HOME\"), \"etc\", \"apps\", helper.get_app_name(), \"local\", \"data\"\n    )\n    checkpoint_path = os.path.join(checkpoint_dir, \"breach_catalog_v2.checkpoint\")\n    try:\n        with open(checkpoint_path, \"r\") as checkpoint_file:\n            checkpoint = json.load(checkpoint_file)\n    except IOError:\n        checkpoint = {\"last_run\": \"1970-01-01\", \"documents\": {}}\n    \n    today = common.date_stamp()\n    helper.log_debug(\"today=\" + str(today))\n    \n    try:\n        for result in api.breach_catalog(helper, checkpoint[\"last_run\"]):\n            document_id = result[\"uuid\"]\n            if document_id in checkpoint[\"documents\"].keys():\n                helper.log_debug(\"input_module_spycloud_breach_catalog.py continue=\" + str(document_id))\n                continue\n            # Add to checkpoint object\n            helper.log_debug(\"input_module_spycloud_breach_catalog.py dont_continue=\" + str(document_id))\n            checkpoint[\"documents\"][document_id] = today\n            # Force timestamp to front of event\n            ordered_result = OrderedDict()\n            if \"breach_date\" in result:\n                ordered_result[\"breach_date\"] = result[\"breach_date\"]\n                del result[\"breach_date\"]\n            for key in result:\n                ordered_result[key] = result[key]\n            data=json.dumps(ordered_result)\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n\n    except HTTPError as http_exception:\n        if http_exception.response.status_code == 403:\n            message = (\n                \"Failed to authenticate to SpyCloud API. \"\n                \"Please make sure you have entered credentials on the app setup page.\"\n            )\n        else:\n            message = \"Received error from SpyCloud API. Error code: {}. {}\".format(http_exception.response.status_code, http_exception.response.text)  # pylint: disable=consider-using-f-string,line-too-long\n        common.make_error_message(helper, message, \"input_module_spycloud_breach_catalog.py\")\n        sys.exit(0)\n    except Exception as other_exception:  # pylint: disable=broad-except\n        message = \"SpyCloud encountered an error: {}\".format(str(other_exception))  # pylint: disable=consider-using-f-string\n        common.make_error_message(helper, message, \"input_module_spycloud_breach_catalog.py\")\n        sys.exit(0)\n\n    if not os.path.exists(checkpoint_dir):\n        os.makedirs(checkpoint_dir)\n    checkpoint = common.checkpoint_cleanup(checkpoint)\n    with open(checkpoint_path, \"w\") as checkpoint_file:\n        json.dump(checkpoint, checkpoint_file)\n        \n    #helper.log_debug(\"finish_checkpoint=\" + str(checkpoint))\n    helper.log_debug(\"input_module_spycloud_breach_catalog.py end\")        \n", "customized_options": [{"name": "notes", "value": ""}], "uuid": "a8732f2d28b34971b367a670d92ae13d", "sample_count": "48"}]}, "field_extraction_builder": {"spycloud:watchlist": {"data_format": "json"}, "spycloud:breach_catalog": {"data_format": "json"}, "spycloud:compass": {"data_format": "json"}, "spycloud:watchlist_identifiers": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": true, "name": "spycloud_key", "label": "SpyCloud API Key", "placeholder": "API Key", "default_value": "", "help_string": "Provide a SpyCloud API key. If this is the first time configuring this app, set the index before entering an API Key. NOTE: IF YOU UPGRADED OR ALREADY ENTERED AN API KEY, YOUR API KEY HAS BEEN SET.", "type": "password", "format_type": "password", "value": ""}, {"required": false, "name": "enable_compass", "label": "Enable Compass", "default_value": false, "help_string": "Check this box if you are licensed for SpyCloud Compass", "type": "checkbox", "format_type": "checkbox", "value": false}]}}, "sourcetype_builder": {"spycloud:watchlist": {"metadata": {"event_count": 0, "data_input_name": "spycloud_watchlist", "extractions_count": 0, "cims_count": 0}}, "spycloud:breach_catalog": {"metadata": {"event_count": 0, "data_input_name": "spycloud_breach_catalog", "extractions_count": 0, "cims_count": 0}}, "spycloud:watchlist_identifiers": {"metadata": {"event_count": 0, "data_input_name": "spycloud_watchlist_identifiers", "extractions_count": 0, "cims_count": 0}}, "spycloud:compass": {"metadata": {"event_count": 0, "data_input_name": "spycloud_compass", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1718814576_74"}}