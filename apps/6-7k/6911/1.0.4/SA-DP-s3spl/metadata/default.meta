[]
access = read : [ admin, sc_admin, s3spl_admin, s3spl_user ], write : [ admin, sc_admin ]
export = system

# Making sure the nav is not loaded into other apps
[nav]
export = none

[s3spl_query]
access = read : [ s3spl_user, admin, sc_admin ], write : [ s3spl_power, admin, sc_admin ]
export = system

[s3spl_bucket]
access = read : [ s3spl_user, admin, sc_admin ], write : [ s3spl_admin, admin, sc_admin ]
export = system

[views/configuration]
access = read : [ s3spl_user, admin, sc_admin ], write : [ ]
export = none

[views/workbench]
access = read : [ s3spl_user, admin, sc_admin ], write : [ ]
export = none

[command/s3spl_adhoc]
access = read : [ s3spl_adhoc, s3spl_admin, admin, sc_admin ], write : [ ]
export = system

[command/s3spl_query]
access = read : [ s3spl_query_run, s3spl_admin, admin, sc_admin ], write : [ ]
export = system
