{"basic_builder": {"appname": "TA-glowmarkt-add-on-for-splunk", "friendly_name": "Glowmarkt Add-on for Splunk", "version": "1.0.0", "author": "Stuart Robertson", "description": "Ingest UK Smart Meter data into Splunk", "theme": "#0092d2", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.3", "tab_build_no": "0", "build_no": 3}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "glowmarkt:electricity:current", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "electricity_consumption", "title": "Electricity Consumption", "description": "Current electricity usage", "type": "customized", "parameters": [{"name": "applicationid", "label": "applicationid", "help_string": "", "required": true, "format_type": "text", "default_value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d", "placeholder": "", "type": "text", "value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d"}, {"name": "resourceid", "label": "resourceid", "help_string": "See documentation for how to retrieve your resourceid", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "cf5a5ae1-7496-45f8-bb2f-e32bb19467ec"}, {"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}], "data_inputs_options": [{"type": "customized_var", "name": "applicationid", "title": "applicationid", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d", "placeholder": ""}, {"type": "customized_var", "name": "resourceid", "title": "resourceid", "description": "See documentation for how to retrieve your resourceid", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils as utils\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    global_account = helper.get_arg(\"global_account\")\n    username = global_account[\"username\"]\n    password = global_account[\"password\"]\n    applicationid = helper.get_arg(\"applicationid\")\n    resourceid = helper.get_arg(\"resourceid\")\n    \n    access_token = rauth.get_access_token(username, password, applicationid)\n    \n    if(access_token):\n        \n        helper.log_debug(\"Calling glowmarkt API\")\n        url = \"https://api.glowmarkt.com/api/v0-1/resource/%s/current\" % (resourceid)\n        electricity_reading = utils.get_items(helper, access_token, url, applicationid)\n        timeStamp = electricity_reading['data'][0][0]\n        \n        event = helper.new_event(\n            time=timeStamp,\n            data=json.dumps(electricity_reading),\n            source=helper.get_input_type(), \n            index=helper.get_output_index(),\n            sourcetype=helper.get_sourcetype())\n        ew.write_event(event)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token. Please check the username, password and applicationId\")", "customized_options": [{"name": "applicationid", "value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d"}, {"name": "resourceid", "value": "cf5a5ae1-7496-45f8-bb2f-e32bb19467ec"}, {"name": "global_account", "value": "account0"}], "uuid": "fc188030650b449ea15967d0a20f420c", "sample_count": 0}, {"index": "default", "sourcetype": "glowmarkt:virtualentity", "interval": "7200", "use_external_validation": true, "streaming_mode_xml": true, "name": "get_virtual_entities", "title": "Get Virtual Entities", "description": "Retrieves resource metadata", "type": "customized", "parameters": [{"required": true, "name": "applicationid", "label": "applicationid", "default_value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d"}, {"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "applicationid", "title": "applicationid", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d", "placeholder": ""}, {"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}], "code": "import os\nimport sys\nimport time\nimport datetime\nimport json\nimport utils.auth as rauth\nimport utils.utils as utils\n     \ndef validate_input(helper, definition):\n\tpass\n\t\ndef collect_events(helper, ew):\n    global_account = helper.get_arg(\"global_account\")\n    username = global_account[\"username\"]\n    password = global_account[\"password\"]\n    applicationid = helper.get_arg(\"applicationid\")\n    resourceid = helper.get_arg(\"resourceid\")\n    \n    access_token = rauth.get_access_token(username, password, applicationid)\n    \n    if(access_token):\n        \n        helper.log_debug(\"Calling glowmarkt API - get Virtual Entities\")\n        url = \"https://api.glowmarkt.com/api/v0-1/virtualentity/\"\n        virtual_entities_response = utils.get_items(helper, access_token, url, applicationid)\n        \n\n        for ve in virtual_entities_response:\n            helper.log_debug(\"Writing this VE: \" + str(ve))\n        \n            event = helper.new_event(\n                data=json.dumps(ve),\n                source=helper.get_input_type(), \n                index=helper.get_output_index(),\n                sourcetype=helper.get_sourcetype())\n            ew.write_event(event)\n\n    else:\n        raise RuntimeError(\"Unable to obtain access token. Please check the username, password and applicationId\")", "customized_options": [{"name": "applicationid", "value": "b0f1b774-a586-4f72-9edd-27ead8aa7a8d"}, {"name": "global_account", "value": "account0"}], "uuid": "5742d047573e4136a9baaca45ee5411c"}]}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "credential_settings": []}}, "sourcetype_builder": {"glowmarkt:electricity:current": {"metadata": {"event_count": 0, "data_input_name": "electricity_consumption", "extractions_count": 0, "cims_count": 0}}, "glowmarkt:virtualentity": {"metadata": {"event_count": 0, "data_input_name": "get_virtual_entities", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1690373625_2"}}