{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "LiveAgent", "short_name": "liveagent", "parameters": [{"format_type": "text", "required": true, "name": "email", "label": "Email", "default_value": "", "help_string": "Sender Email Adress", "type": "", "value": "liveagent2@datanalog.com"}, {"format_type": "text", "required": true, "name": "subject", "label": "Subject", "default_value": "Splunk Ticket", "help_string": "Subject of the ticket", "type": "", "value": "Splunk Ticket New"}, {"format_type": "text", "required": true, "name": "recipient_email", "label": "Recipient Email", "default_value": "", "help_string": "Recipient Email Address(Single email only)", "type": "", "value": "liveagent3@datanalog.com"}, {"format_type": "text", "required": true, "name": "message", "label": "Message", "default_value": "Ticket is created from splunk", "help_string": "Body/Message of the Ticket", "type": "", "value": "Ticket is created from splunk"}, {"format_type": "text", "required": true, "name": "department_id", "label": "Department ID", "default_value": "default", "help_string": "The department name on which the ticket needs to be tagged", "type": "", "value": "default"}], "code": "\n# encoding = utf-8\nimport requests\nimport json\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the setup parameters and prints them to the log\n    liveagent_url = helper.get_global_setting(\"liveagent_url\")\n    helper.log_info(\"liveagent_url={}\".format(liveagent_url))\n    api_key = helper.get_global_setting(\"api_key\")\n    helper.log_info(\"api_key={}\".format(api_key))\n\n    # The following example gets the alert action parameters and prints them to the log\n    email = helper.get_param(\"email\")\n    helper.log_info(\"email={}\".format(email))\n\n    subject = helper.get_param(\"subject\")\n    helper.log_info(\"subject={}\".format(subject))\n\n    recipient_email = helper.get_param(\"recipient_email\")\n    helper.log_info(\"recipient_email={}\".format(recipient_email))\n\n    message = helper.get_param(\"message\")\n    helper.log_info(\"message={}\".format(message))\n\n    department_id = helper.get_param(\"department_id\")\n    helper.log_info(\"department_id={}\".format(department_id))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action liveagent started.\")\n    api_key = helper.get_global_setting(\"api_key\")\n    liveagent_url = helper.get_global_setting(\"liveagent_url\")\n    email = helper.get_param(\"email\")\n    subject = helper.get_param(\"subject\")\n    recipient_email = helper.get_param(\"recipient_email\")\n    message = helper.get_param(\"message\")\n    department_id = helper.get_param(\"department_id\")\n    \n    payload = json.dumps({\n        \"useridentifier\": f\"{email}\",\n        \"subject\": f\"{subject}\",\n        \"departmentid\": f\"{department_id}\",\n        \"recipient\": f\"{recipient_email}\",\n        \"message\": f\"{message}\",\n        \"status\": \"N\"\n        })\n    \n    headers = {\n        'Content-Type': 'application/json',\n        'apikey': api_key\n        }\n    response = requests.request(\"POST\", liveagent_url, headers=headers, data=payload)\n    \n    data=response.json()\n    helper.log_info(data)\n\n    # TODO: Implement your alert action logic here\n    return 0\n", "uuid": "c066efabe4e94017b7ca1abeb45ffaa5"}]}, "basic_builder": {"appname": "TA-liveagent", "friendly_name": "LiveAgent", "version": "1.0.1", "author": "Lognalytics Technology", "description": "Alert Action to create tickets on LiveAgent", "theme": "#E98B1C", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 3}, "global_settings_builder": {"global_settings": {"customized_settings": [{"format_type": "text", "required": true, "name": "liveagent_url", "label": "LiveAgent URL", "default_value": "", "help_string": "https://your_domain.ladesk.com/api/v3/tickets", "internal_name": "", "type": "text", "value": "https://datanalog2.ladesk.com/api/v3/tickets"}, {"format_type": "password", "required": true, "name": "api_key", "label": "API Key", "default_value": "", "help_string": "API Key generated from LiveAgent", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1763540737_37"}}