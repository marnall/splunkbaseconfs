
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system

[transforms/jira_icc_collection_lookup]
access = read : [ * ], write : [ admin ]
export = none
owner = nobody

### LOOKUPS

[lookups]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

### VIEWS

[views/jira_icc]
access = read : [ * ]
export = none
owner = nobody

[views/help]
access = read : [ * ]
export = none
owner = nobody
