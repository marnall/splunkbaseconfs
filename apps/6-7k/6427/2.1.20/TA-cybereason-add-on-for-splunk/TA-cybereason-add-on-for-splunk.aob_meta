{"basic_builder": {"appname": "TA-cybereason-add-on-for-splunk", "friendly_name": "Cybereason Add-on for Splunk", "version": "2.1.20", "author": "Metron Labs", "description": "Cybereason Add-on for Splunk allows Cybereason admins and users to view and correlate their existing data within Splunk.", "theme": "#297ba5", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.1", "tab_build_no": "0", "build_no": 2}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "cybereason:malicious", "interval": "600", "use_external_validation": true, "streaming_mode_xml": true, "name": "malicious_data_input", "title": "Malicious Data Input", "description": "", "type": "customized", "parameters": [{"name": "base_url", "label": "Base URL", "help_string": "The base URL to Cybereason Server (without https://)", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "username", "label": "Username", "help_string": "The username for Cybereason Account", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "password", "label": "Password", "help_string": "The password for Cybereason Account\n", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "authentication_type", "label": "Authentication Type", "help_string": "The type of authentication to be used", "required": true, "possible_values": [{"value": "basic", "label": "Basic"}, {"value": "jwt_token", "label": "JWT Token"}], "format_type": "radiogroup", "default_value": "basic", "type": "radiogroup", "value": "basic"}, {"required": false, "name": "ssl_certificate_path", "label": "SSL Certificate Path", "default_value": "", "placeholder": "E.g.: /etc/certs/cacert.pem", "help_string": "Absolute Path to 3rd-Party Signed Non-Default Certificates to be used for SSL Verification at the time of data polling. If not provided, the default internal certificates will be used.", "type": "text", "format_type": "text", "value": ""}, {"name": "malops", "label": "MalOps", "help_string": "MalOps Endpoint, Enable this to fetch the MalOps", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "suspicious_objects", "label": "Suspicious Objects", "help_string": "Suspicious Objects Endpoint, Enable this to fetch the Suspicious Objects", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "malware", "label": "Malware", "help_string": "Malware Endpoint, Enable this to fetch the Malware", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "verify_ssl", "label": "Verify SSL", "help_string": "Enable this to verify SSL certification", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "base_url", "title": "Base URL", "description": "The base URL to Cybereason Server (without https://)", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "username", "title": "Username", "description": "The username for Cybereason Account", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "password", "title": "Password", "description": "The password for Cybereason Account\n", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "authentication_type", "title": "Authentication Type", "description": "The type of authentication to be used", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "basic", "label": "Basic"}, {"value": "jwt_token", "label": "JWT Token"}], "format_type": "radiogroup", "default_value": "basic"}, {"type": "customized_var", "name": "ssl_certificate_path", "title": "SSL Certificate Path", "description": "Absolute Path to 3rd-Party Signed Non-Default Certificates to be used for SSL Verification at the time of data polling. If not provided, the default internal certificates will be used.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "E.g.: /etc/certs/cacert.pem"}, {"type": "customized_var", "name": "malops", "title": "MalOps", "description": "MalOps Endpoint, Enable this to fetch the MalOps", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "suspicious_objects", "title": "Suspicious Objects", "description": "Suspicious Objects Endpoint, Enable this to fetch the Suspicious Objects", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "malware", "title": "Malware", "description": "Malware Endpoint, Enable this to fetch the Malware", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "verify_ssl", "title": "Verify SSL", "description": "Enable this to verify SSL certification", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}], "code": "# encoding = utf-8\nimport math\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nfrom cybereason_rest_client import CybereasonClient\nfrom splunk.appserver.mrsparkle.lib.util import make_splunkhome_path\n\n_APP_NAME = 'CybereasonAddOnForSplunk'\n\nlog_location = make_splunkhome_path(['var', 'log', 'splunk', _APP_NAME])\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # base_url = definition.parameters.get('base_url', None)\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # authentication_type = definition.parameters.get('authentication_type', None)\n    # malops = definition.parameters.get('malops', None)\n    # suspicious_objects = definition.parameters.get('suspicious_objects', None)\n    # malware = definition.parameters.get('malware', None)\n    pass\n\ndef get_last_polled_timestamp(base_url, username):\n    host = \"malicious-\"+base_url.split(\":\")[0]+\"-\"+username\n    file_dir = os.path.join(log_location, 'malicious_data_input',host) \n    filepath = os.path.join(file_dir, 'timestamp.txt')\n    earliest = 0\n    if not os.path.exists(file_dir):\n            os.makedirs(file_dir)\n    elif os.path.exists(filepath) and os.stat(filepath).st_size != 0:\n        file1 = open(filepath, \"r\")\n        earliest = int(file1.read())\n        file1.close()\n\n    return earliest\n\ndef set_last_polled_timestamp(base_url, username, timestamp):\n    host = \"malicious-\"+base_url.split(\":\")[0]+\"-\"+username\n    file_dir = os.path.join(log_location, 'malicious_data_input',host) \n    filepath = os.path.join(file_dir, 'timestamp.txt')\n    if not os.path.exists(file_dir):\n        os.makedirs(file_dir)\n    with open(filepath, \"w\") as file1:\n        file1.write(str(timestamp))\n\ndef collect_events(helper, ew):\n    try:\n        # The following examples get the arguments of this input.\n        # Note, for single instance mod input, args will be returned as a dict.\n        # For multi instance mod input, args will be returned as a single value.\n        opt_base_url = helper.get_arg('base_url')\n        opt_username = helper.get_arg('username')\n        opt_password = helper.get_arg('password')\n        opt_hist_days = helper.get_arg('hist_days')\n        opt_authentication_type = helper.get_arg('authentication_type')\n        opt_malops = helper.get_arg('malops')\n        opt_suspicious_objects = helper.get_arg('suspicious_objects')\n        opt_malware = helper.get_arg('malware')\n        opt_verify_ssl = helper.get_arg('verify_ssl')\n        opt_cybereason_account = dict()\n        opt_cybereason_account['password'] = opt_password\n        opt_cybereason_account['username'] = opt_username\n    \n        # get proxy setting configuration\n        proxy_settings = helper.get_proxy()\n    \n        earliest = get_last_polled_timestamp(opt_base_url, opt_username)\n        if earliest < 1:\n            earliest = int(\n                math.ceil(time.mktime((datetime.datetime.now() - datetime.timedelta(days=int(opt_hist_days))).timetuple())))\n        now = round(datetime.datetime.now().timestamp())\n        cyb_client = CybereasonClient(helper,ew, opt_base_url, opt_cybereason_account, opt_authentication_type, opt_verify_ssl, proxy_settings)\n        if opt_malops:\n            malops = cyb_client.get_time_bound_malops(ew, earliest=earliest, latest=int(now))\n            sourcetype = \"cybereason:api\"\n            data = json.dumps(malops)\n            event = helper.new_event(host=opt_base_url.split(\":\")[0], source=helper.get_arg('name'), index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n            ew.write_event(event)\n        if opt_suspicious_objects:\n            suspicious = cyb_client.get_time_bound_suspicious(requested_type=\"Process\",earliest=earliest, latest=int(now))\n            sourcetype = \"cybereason:api\"\n            data = json.dumps(suspicious)\n            event = helper.new_event(host=opt_base_url.split(\":\")[0], source=helper.get_arg('name'), index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n            ew.write_event(event)\n        if opt_malware:\n            malware = cyb_client.get_all_malware(starttime=earliest, limit=1000)\n            sourcetype = \"cybereason:api\"\n            data = json.dumps(malware)\n            event = helper.new_event(host=opt_base_url.split(\":\")[0], source=helper.get_arg('name'), index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n            ew.write_event(event)\n        set_last_polled_timestamp(opt_base_url,opt_username, now)\n    except Exception as e:\n        sourcetype = \"CybereasonAddonForSplunk:error\"\n        data = str(e)\n        event = helper.new_event(\n            host=opt_base_url.split(\":\")[0] if opt_base_url and len(opt_base_url) > 0 else \"host\",\n            source=helper.get_arg('name'), index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n        ew.write_event(event)\n   \n    \n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n", "customized_options": [{"name": "base_url", "value": ""}, {"name": "username", "value": ""}, {"name": "authentication_type", "value": "basic"}, {"name": "ssl_certificate_path", "value": ""}, {"name": "malops", "value": true}, {"name": "suspicious_objects", "value": true}, {"name": "malware", "value": true}, {"name": "verify_ssl", "value": true}], "uuid": "aeba4a7497474a43973fb20dbb6296e6", "sample_count": 0}, {"index": "default", "sourcetype": "cybereason:user_activity", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "user_activity_input", "title": "User Activity Input", "description": "", "type": "customized", "parameters": [{"name": "base_url", "label": "Base URL", "help_string": "The base URL to Cybereason Server (without https://)", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "username", "label": "Username", "help_string": "The username for Cybereason Account", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "password", "label": "Password", "help_string": "The password for Cybereason Account", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "authentication_type", "label": "Authentication Type", "help_string": "The type of authentication to be used", "required": true, "possible_values": [{"value": "basic", "label": "Basic"}, {"value": "jwt_token", "label": "JWT Token"}], "format_type": "radiogroup", "default_value": "basic", "type": "radiogroup", "value": "basic"}, {"required": false, "name": "ssl_certificate_path", "label": "SSL Certificate Path", "default_value": "", "placeholder": "E.g.: /etc/certs/cacert.pem", "help_string": "Absolute Path to 3rd-Party Signed Non-Default Certificates to be used for SSL Verification at the time of data polling. If not provided, the default internal certificates will be used.", "type": "text", "format_type": "text", "value": ""}, {"name": "users", "label": "Users", "help_string": "Users Endpoint, Enable this to fetch the Users", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "user_action_logs", "label": "User Action Logs", "help_string": "User Action Logs Endpoint, Enable this to fetch the User Action Logs", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "logon_sessions", "label": "Logon Sessions", "help_string": "Logon Sessions Endpoint, Enable this to fetch the Logon Sessions", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}, {"name": "verify_ssl", "label": "Verify SSL", "help_string": "Enable this to verify SSL certification", "required": false, "format_type": "checkbox", "default_value": true, "type": "checkbox", "value": true}], "data_inputs_options": [{"type": "customized_var", "name": "base_url", "title": "Base URL", "description": "The base URL to Cybereason Server (without https://)", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "username", "title": "Username", "description": "The username for Cybereason Account", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "password", "title": "Password", "description": "The password for Cybereason Account", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "authentication_type", "title": "Authentication Type", "description": "The type of authentication to be used", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "basic", "label": "Basic"}, {"value": "jwt_token", "label": "JWT Token"}], "format_type": "radiogroup", "default_value": "basic"}, {"type": "customized_var", "name": "ssl_certificate_path", "title": "SSL Certificate Path", "description": "Absolute Path to 3rd-Party Signed Non-Default Certificates to be used for SSL Verification at the time of data polling. If not provided, the default internal certificates will be used.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "E.g.: /etc/certs/cacert.pem"}, {"type": "customized_var", "name": "users", "title": "Users", "description": "Users Endpoint, Enable this to fetch the Users", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "user_action_logs", "title": "User Action Logs", "description": "User Action Logs Endpoint, Enable this to fetch the User Action Logs", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "logon_sessions", "title": "Logon Sessions", "description": "Logon Sessions Endpoint, Enable this to fetch the Logon Sessions", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}, {"type": "customized_var", "name": "verify_ssl", "title": "Verify SSL", "description": "Enable this to verify SSL certification", "required_on_edit": false, "required_on_create": false, "format_type": "checkbox", "default_value": true}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nfrom cybereason_rest_client import CybereasonClient\nfrom splunk.appserver.mrsparkle.lib.util import make_splunkhome_path\n\n_APP_NAME = 'CybereasonAddOnForSplunk'\n\nlog_location = make_splunkhome_path(['var', 'log', 'splunk', _APP_NAME])\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # base_url = definition.parameters.get('base_url', None)\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # authentication_type = definition.parameters.get('authentication_type', None)\n    # users = definition.parameters.get('users', None)\n    # user_action_logs = definition.parameters.get('user_action_logs', None)\n    # logon_sessions = definition.parameters.get('logon_sessions', None)\n    pass\n\ndef get_last_polled_timestamp(base_url, username):\n    host = \"user_activity-\"+base_url.split(\":\")[0]+\"-\"+username\n    file_dir = os.path.join(log_location, 'user_activity_data_input',host)\n    filepath = os.path.join(file_dir, 'timestamp.txt')\n    earliest = 0\n    if not os.path.exists(file_dir):\n            os.makedirs(file_dir)\n    elif os.path.exists(filepath) and os.stat(filepath).st_size != 0:\n        file1 = open(filepath, \"r\")\n        earliest = int(file1.read())\n        file1.close()\n\n    return earliest\n\ndef set_last_polled_timestamp(base_url, username, timestamp):\n    host = \"user_activity-\"+base_url.split(\":\")[0]+\"-\"+username\n    file_dir = os.path.join(log_location, 'user_activity_data_input',host)\n    filepath = os.path.join(file_dir, 'timestamp.txt')\n    if not os.path.exists(file_dir):\n        os.makedirs(file_dir)\n    with open(filepath, \"w\") as file1:\n        file1.write(str(timestamp))\n\ndef collect_events(helper, ew):\n    \n    try:\n        # The following examples get the arguments of this input.\n        # Note, for single instance mod input, args will be returned as a dict.\n        # For multi instance mod input, args will be returned as a single value.\n        opt_base_url = helper.get_arg('base_url')\n        opt_username = helper.get_arg('username')\n        opt_password = helper.get_arg('password')\n        opt_hist_days = helper.get_arg('hist_days')\n        opt_authentication_type = helper.get_arg('authentication_type')\n        opt_users = helper.get_arg('users')\n        opt_user_action_logs = helper.get_arg('user_action_logs')\n        opt_logon_sessions = helper.get_arg('logon_sessions')\n        opt_verify_ssl = helper.get_arg('verify_ssl')\n        opt_cybereason_account = dict()\n        opt_cybereason_account['password'] = opt_password\n        opt_cybereason_account['username'] = opt_username\n        # get proxy setting configuration\n        proxy_settings = helper.get_proxy()\n        earliest = get_last_polled_timestamp(opt_base_url, opt_username)\n        if earliest < 1:\n            earliest = round((datetime.datetime.now() - datetime.timedelta(days=int(opt_hist_days))).timestamp())\n        now = round(datetime.datetime.now().timestamp())\n        cyb_client = CybereasonClient(helper,ew, opt_base_url, opt_cybereason_account, opt_authentication_type, opt_verify_ssl, proxy_settings)\n        if opt_users:\n            users = cyb_client.get_all_users() \n            if users:\n                sourcetype = \"cybereason:api\"\n                data = json.dumps(users)\n                event = helper.new_event(host=opt_base_url.split(\":\")[0], source=helper.get_arg('name'), index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n                ew.write_event(event)\n        if opt_logon_sessions:\n            logon_sessions  = cyb_client.get_logon_sessions(start_time=int(earliest), end_time=int(now))\n            if logon_sessions:\n                sourcetype = \"cybereason:api\"\n                data = json.dumps(logon_sessions)\n                event = helper.new_event(host=opt_base_url.split(\":\")[0], source=helper.get_arg('name'), index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n                ew.write_event(event)\n        if opt_user_action_logs:\n            cyb_client.get_all_action_logs()\n        set_last_polled_timestamp(opt_base_url, opt_username, now)\n    except Exception as e:\n        sourcetype = \"CybereasonAddonForSplunk:error\"\n        data = str(e)\n        event = helper.new_event(source=helper.get_arg('name'), index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n        ew.write_event(event)\n    \n\n    '''\n    # The following example writes a random number as an event. (Multi Instance Mode)\n    # Use this code template by default.\n    import random\n    data = str(random.randint(0,100))\n    event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n    ew.write_event(event)\n    '''\n", "customized_options": [{"name": "base_url", "value": ""}, {"name": "username", "value": ""}, {"name": "authentication_type", "value": "basic"}, {"name": "ssl_certificate_path", "value": ""}, {"name": "users", "value": true}, {"name": "user_action_logs", "value": true}, {"name": "logon_sessions", "value": true}, {"name": "verify_ssl", "value": true}], "uuid": "d9d9f76b477d4646b9fff17ec22962a5", "sample_count": 0}]}, "field_extraction_builder": {"cybereason:malops": {"data_format": "json"}, "cybereason:malops:affectedMachines": {"data_format": "json"}, "cybereason:malops:affectedUsers": {"data_format": "json"}, "cybereason:malops:filesToRemediate": {"data_format": "json"}, "cybereason:malops:rootCauseElements": {"data_format": "json"}, "cybereason:malops:suspects": {"data_format": "json"}, "cybereason:malware": {"data_format": "json"}, "cybereason:suspicious": {"data_format": "json"}, "CybereasonAddonForSplunk:error": {"data_format": "tabular", "table_results": {"delim": " "}}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}}}, "sourcetype_builder": {"cybereason:malicious": {"metadata": {"event_count": 0, "data_input_name": "malicious_data_input", "extractions_count": 0, "cims_count": 0}}, "cybereason:user_activity": {"metadata": {"event_count": 0, "data_input_name": "user_activity_input", "extractions_count": 0, "cims_count": 0}}}, "validation": {}}
