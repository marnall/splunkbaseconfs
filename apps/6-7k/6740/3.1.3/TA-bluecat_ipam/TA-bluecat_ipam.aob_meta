{"basic_builder": {"appname": "TA-bluecat_ipam", "friendly_name": "Add-on for BlueCat Address Manager", "version": "3.1.3", "author": "caldwell@gwu.edu", "description": "Collect IPAM data from BlueCat", "theme": "#033C5A", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 20}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "bluecat:ipam", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "get_ipam_data", "title": "Get IPAM data", "description": "", "type": "customized", "parameters": [{"name": "object_type", "label": "Object type", "help_string": "", "required": true, "possible_values": [{"value": "IP4Block", "label": "IPv4 Blocks"}, {"value": "IP4Network", "label": "IPv4 Networks"}, {"value": "IP4Address", "label": "IPv4 Addresses"}, {"label": "IPv6 Blocks", "value": "IP6Block"}, {"label": "IPv6 Networks", "value": "IP6Network"}, {"label": "IPv6 Addresses", "value": "IP6Address"}, {"label": "Host records", "value": "HostRecord"}], "format_type": "dropdownlist", "default_value": "IP4Block", "placeholder": "", "type": "dropdownlist", "value": "IP4Address"}, {"name": "parent_type", "label": "Parent Type", "help_string": "Parent type must match object type IP version.", "required": false, "possible_values": [{"value": "IP4Block", "label": "IP4Block"}, {"value": "IP4Network", "label": "IP4Network"}, {"value": "IP6Block", "label": "IP6Block"}, {"label": "IP6Network", "value": "IP6Network"}, {"label": "None", "value": "none"}], "format_type": "dropdownlist", "default_value": "none", "placeholder": "", "type": "dropdownlist", "value": "IP4Block"}, {"name": "parent_id", "label": "Parent ID", "help_string": "You must already know the parent ID of an entity if you want to limit the scope of objects fetched.", "required": false, "format_type": "text", "default_value": "", "placeholder": "optional", "type": "text", "value": "1310791"}, {"name": "object_count", "label": "Object count", "help_string": "Maximum number of objects to try and retrieve", "required": true, "format_type": "text", "default_value": "1024", "placeholder": "", "type": "text", "value": "10"}, {"name": "keyword", "label": "Keyword search", "help_string": "", "required": true, "format_type": "text", "default_value": "*", "placeholder": "", "type": "text", "value": "*"}], "data_inputs_options": [{"type": "customized_var", "name": "object_type", "title": "Object type", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "IP4Block", "label": "IPv4 Blocks"}, {"value": "IP4Network", "label": "IPv4 Networks"}, {"value": "IP4Address", "label": "IPv4 Addresses"}, {"label": "IPv6 Blocks", "value": "IP6Block"}, {"label": "IPv6 Networks", "value": "IP6Network"}, {"label": "IPv6 Addresses", "value": "IP6Address"}, {"label": "Host records", "value": "HostRecord"}], "format_type": "dropdownlist", "default_value": "IP4Block", "placeholder": ""}, {"type": "customized_var", "name": "parent_type", "title": "Parent Type", "description": "Parent type must match object type IP version.", "required_on_edit": false, "required_on_create": false, "possible_values": [{"value": "IP4Block", "label": "IP4Block"}, {"value": "IP4Network", "label": "IP4Network"}, {"value": "IP6Block", "label": "IP6Block"}, {"label": "IP6Network", "value": "IP6Network"}, {"label": "None", "value": "none"}], "format_type": "dropdownlist", "default_value": "none", "placeholder": ""}, {"type": "customized_var", "name": "parent_id", "title": "Parent ID", "description": "You must already know the parent ID of an entity if you want to limit the scope of objects fetched.", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "optional"}, {"type": "customized_var", "name": "object_count", "title": "Object count", "description": "Maximum number of objects to try and retrieve", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "1024", "placeholder": ""}, {"type": "customized_var", "name": "keyword", "title": "Keyword search", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "*", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport re\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # object_type = definition.parameters.get('object_type', None)\n    # object_count = definition.parameters.get('object_count', None)\n    pass\n\n\ndef get_auth_token(endpoint, username, password):\n\n    url = endpoint + '/login'\n    \n    try:\n        response = requests.get(\n            url=url,\n            params={\n                \"username\": username,\n                \"password\": password,\n            }\n        )\n        content = response.text\n        c = re.search('^\\\"(?:\\S+\\s){2}(\\S+\\s\\S+)', content)\n        if c:\n            token = c.group(1)\n            return token\n    except requests.ConnectionError as e:\n        print(str(e))\n    except requests.exceptions.RequestException as e:\n        print('HTTP Request failed')\n        print(str(e))\n\n\ndef get_objects(auth_token, url, parameters):\n    \n    try:\n        response = requests.get(\n            url = url,\n            params = parameters,\n            headers={\n                \"Authorization\": auth_token,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        objects = json.loads(response.text)\n        return objects\n    except requests.ConnectionError as e:\n        print(str(e))\n    except requests.exceptions.RequestException as e:\n        print('HTTP Request failed')\n        print(str(e))\n        \ndef logout(endpoint):\n\n    url = endpoint + '/logout'\n    \n    try:\n        response = requests.get(\n            url = url,\n        )\n    except requests.ConnectionError as e:\n        print(str(e))\n    except requests.exceptions.RequestException as e:\n        print('HTTP Request failed')\n        print(str(e))\n\n\ndef collect_events(helper, ew):\n\n    username = helper.get_global_setting(\"username\")\n    password = helper.get_global_setting(\"password\")\n    endpoint = helper.get_global_setting(\"endpoint\")\n\n    endpoint = 'https://' + endpoint + '/Services/REST/v1'\n    \n\n    # get global variable configuration\n    object_type = helper.get_arg(\"object_type\")\n    object_count = helper.get_arg(\"object_count\")\n    if object_type == \"IP4Block\" or object_type == \"IP6Block\":\n        st = \"bluecat:ipam:block\"\n    elif object_type == \"IP4Network\" or object_type == \"IP6Network\":\n        st = \"bluecat:ipam:network\"\n    elif object_type == \"IP4Address\" or object_type == \"IP6Address\":\n        st = \"bluecat:ipam:address\"\n    elif object_type == \"HostRecord\":\n        st = \"bluecat:ipam:host\"\n    parent_type = helper.get_arg(\"parent_type\")\n    parent_id = helper.get_arg(\"parent_id\")\n    try:\n        parent_id = int(parent_id)\n    except ValueError:\n        parent_id = 0\n    except TypeError:\n        parent_id = 0\n    keyword = helper.get_arg(\"keyword\")\n    is_kw = re.search('^(\\w+)', keyword)\n        \n    auth_token = get_auth_token(endpoint, username, password)\n    \n    if (((object_type == \"IP4Address\" and parent_type == \"IP4Block\") or (object_type == \"IP6Address\" and parent_type == \"IP6Block\")) and parent_id > 0) or (is_kw and object_type ==\"IP4Address\"):\n        if is_kw:\n            url = endpoint + '/searchByObjectTypes'\n            parameters = {\n                \"keyword\": keyword,\n                \"types\": \"IP4Network\",\n                \"start\": \"0\",\n                \"count\": 16384,\n            }\n        else:\n            if parent_type == \"IP4Block\":\n                ot = \"IP4Network\"\n            elif parent_type == \"IP6Block\":\n                ot = \"IP6Network\"\n            url = endpoint + '/getEntities'\n            parameters = {\n                \"parentId\": parent_id,\n                \"type\": ot,\n                \"start\": \"0\",\n                \"count\": 16384,\n            } \n        networks = get_objects(auth_token, url, parameters)\n        for network in networks:\n            parent_id = network[\"id\"]\n            parent_id = int(parent_id)\n            url = endpoint + '/getEntities'\n            parameters = {\n                \"parentId\": parent_id,\n                \"type\": object_type,\n                \"start\": \"0\",\n                \"count\": object_count,\n            }\n            response = get_objects(auth_token, url, parameters)\n            for network_object in response:\n                data = json.dumps(network_object)\n                event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=st, data=data)\n                ew.write_event(event)\n   \n    elif  (parent_type == \"IP4Block\" or parent_type == \"IP6Block\") and parent_id > 0:\n        url = endpoint + '/getEntities'\n        parameters = {\n            \"parentId\": parent_id,\n            \"type\": object_type,\n            \"start\": \"0\",\n            \"count\": object_count,\n        }\n        response = get_objects(auth_token, url, parameters)\n        for network_object in response:\n            data = json.dumps(network_object)\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=st, data=data)\n            ew.write_event(event)\n\n    else:\n        url = endpoint + '/searchByObjectTypes'\n        parameters = {\n                \"keyword\": \"*\",\n                \"types\": object_type,\n                \"start\": \"0\",\n                \"count\": object_count,\n        }\n        response = get_objects(auth_token, url, parameters)\n        for network_object in response:\n            data = json.dumps(network_object)\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=st, data=data)\n            ew.write_event(event)\n            \n    logout(endpoint)        \n", "customized_options": [{"name": "object_type", "value": "IP4Address"}, {"name": "parent_type", "value": "IP4Block"}, {"name": "parent_id", "value": "1310791"}, {"name": "object_count", "value": "10"}, {"name": "keyword", "value": "*"}], "uuid": "e28e83d6e67e4c02a243a894ace22b49", "sample_count": 0}]}, "field_extraction_builder": {"bluecat:ipam:network": {"data_format": "json"}, "bluecat:ipam:block": {"data_format": "json"}, "bluecat:ipam:address": {"data_format": "json"}, "bluecat:ipam:host": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": true, "name": "username", "label": "Username", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "gwsplunk"}, {"required": true, "name": "password", "label": "Password", "placeholder": "", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}, {"required": true, "name": "endpoint", "label": "Server", "default_value": "", "placeholder": "myipam.example.com", "help_string": "", "type": "text", "format_type": "text", "value": "ipam3.gwu.edu"}]}}, "sourcetype_builder": {"bluecat:ipam": {"metadata": {"event_count": 0, "data_input_name": "get_ipam_data", "extractions_count": 0, "cims_count": 0}}, "bluecat:ipam:network": {"metadata": {"event_count": 0, "data_input_name": null, "extractions_count": 0, "cims_count": 0}}, "bluecat:ipam:block": {"metadata": {"event_count": 0, "data_input_name": null, "extractions_count": 0, "cims_count": 0}}, "bluecat:ipam:address": {"metadata": {"event_count": 0, "data_input_name": null, "extractions_count": 0, "cims_count": 0}}, "bluecat:ipam:host": {"metadata": {"event_count": 0, "data_input_name": null, "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1761911504_0"}}