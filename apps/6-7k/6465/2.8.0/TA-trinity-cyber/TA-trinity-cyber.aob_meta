  "data_input_builder": {
    "datainputs": [
      {
        "index": "default",
        "sourcetype": "trinitycyber:event",
        "interval": "300",
        "use_external_validation": true,
        "streaming_mode_xml": true,
        "name": "trinity_cyber",
        "title": "Trinity Cyber",
        "description": "Trinity Cyber API",
        "type": "customized",
        "parameters": [
          {
            "name": "api_key",
