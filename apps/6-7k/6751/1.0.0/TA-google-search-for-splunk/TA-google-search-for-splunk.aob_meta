{"basic_builder": {"appname": "TA-google-search-for-splunk", "friendly_name": "Google Search for Splunk", "version": "1.0.0", "author": "Lachlan Horsey", "description": "", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.1", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "google:search:result", "interval": "3600", "use_external_validation": true, "streaming_mode_xml": true, "name": "google_search_input", "title": "Google Search Input", "description": "", "type": "customized", "parameters": [{"name": "google_query", "label": "Google Query", "help_string": "Query to search", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "google_tld", "label": "Google TLD", "help_string": "Which countries version of Google to utilise. Most entries from https://en.wikipedia.org/wiki/Country_code_top-level_domain should be valid", "required": true, "format_type": "text", "default_value": "com", "placeholder": "", "type": "text", "value": "com"}, {"name": "google_language", "label": "Google Language", "help_string": "Search language to utilise. May provide different results. See lr query parameters as per https://sites.google.com/site/tomihasa/google-language-codes.", "required": true, "format_type": "text", "default_value": "en", "placeholder": "", "type": "text", "value": "en"}, {"name": "maximum_results", "label": "Maximum results", "help_string": "Maximum number of results to fetch.", "required": true, "format_type": "text", "default_value": "1000", "placeholder": "", "type": "text", "value": "20"}], "data_inputs_options": [{"type": "customized_var", "name": "google_query", "title": "Google Query", "description": "Query to search", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "google_tld", "title": "Google TLD", "description": "Which countries version of Google to utilise. Most entries from https://en.wikipedia.org/wiki/Country_code_top-level_domain should be valid", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "com", "placeholder": ""}, {"type": "customized_var", "name": "google_language", "title": "Google Language", "description": "Search language to utilise. May provide different results. See lr query parameters as per https://sites.google.com/site/tomihasa/google-language-codes.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "en", "placeholder": ""}, {"type": "customized_var", "name": "maximum_results", "title": "Maximum results", "description": "Maximum number of results to fetch.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "1000", "placeholder": ""}], "code": "# encoding = utf-8\r\n\r\nimport os\r\nimport sys\r\nimport time\r\nimport datetime\r\nimport ta_google_search_for_splunk_declare\r\nimport json\r\nimport csv\r\n\r\nfrom google_search import search\r\nfrom lookup_reader import get_dorks\r\n\r\n\"\"\"\r\n    IMPORTANT\r\n    Edit only the validate_input and collect_events functions.\r\n    Do not edit any other part in this file.\r\n    This file is generated only once when creating the modular input.\r\n\"\"\"\r\n\r\ndef validate_input(helper, definition):\r\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\r\n    # This example accesses the modular input variable\r\n    # lookup_file = definition.parameters.get('lookup_file', None)\r\n    # google_tld = definition.parameters.get('google_tld', None)\r\n    # google_language = definition.parameters.get('google_language', None)\r\n    # maximum_results = definition.parameters.get('maximum_results', None)\r\n    pass\r\n\r\n\r\ndef collect_events(helper, ew):\r\n    # The following examples get the arguments of this input.\r\n    # Note, for single instance mod input, args will be returned as a dict.\r\n    # For multi instance mod input, args will be returned as a single value.\r\n    google_query = helper.get_arg(\"google_query\", None)\r\n    google_tld = helper.get_arg(\"google_tld\", None)\r\n    google_language = helper.get_arg(\"google_language\", None)\r\n    maximum_results = helper.get_arg(\"maximum_results\", None)\r\n\r\n    #Set up logging\r\n    loglevel = helper.get_log_level()\r\n    helper.set_log_level(loglevel)\r\n\r\n    iter = search(helper,google_query, tld=google_tld, lang=google_language, stop=int(maximum_results))\r\n    if iter == None:\r\n        helper.log_error(f\"Failed to get events for input {helper.get_input_stanza_names()}.\")\r\n        pass\r\n    \r\n    for link in iter:\r\n        event = helper.new_event(\r\n            json.dumps({\r\n                \"url\": link,\r\n                \"rule_name\":helper.get_input_stanza_names()\r\n            }),\r\n            index=helper.get_output_index(),\r\n            source=helper.get_input_type(),\r\n            sourcetype=helper.get_sourcetype(),\r\n        )\r\n        ew.write_event(event)", "customized_options": [{"name": "google_query", "value": "cats"}, {"name": "google_tld", "value": "com"}, {"name": "google_language", "value": "en"}, {"name": "maximum_results", "value": "20"}], "uuid": "ca927004d6d647b0a63c6dc74fb70790", "sample_count": "183"}]}, "field_extraction_builder": {"google:search:result": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}}}, "sourcetype_builder": {"google:search:result": {"metadata": {"data_input_name": "google_search_input"}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1675138057_64", "progress": 0.7857142857142857}}