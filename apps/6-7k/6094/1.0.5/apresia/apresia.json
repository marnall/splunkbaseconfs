          "rule-id": {
            "description": "Rule Id",
            "data_type": "string",
            "order": 5,
            "required": true
          },
          "direction": {
            "description": "Direction of acl",
            "data_type": "string",
            "order": 6,
            "value_list": ["ingress", "egress"],
            "required": true
