      {
        "action": "block ip",
        "description": "Block an IP",
        "verbose": "This action requires parameters like 'src_ip', 'linecard-id' and etc to be specified",
        "type": "contain",
        "identifier": "block_ip",
        "undo": "unblock ip",
        "read_only": false,
        "parameters": {
          "src_ip": {
            "description": "Blocking source ip address",
            "data_type": "string",
            "default": "0.0.0.0",
            "order": 0,
            "contains": [ "ip" ],
            "required": true
          },
          "dst_ip": {
            "description": "Blocking destination ip address",
            "data_type": "string",
            "default": "0.0.0.0",
            "order": 1,
            "contains": [ "ip" ],
            "required": true
          },
          "linecard-id": {
            "description": "Linecard Id",
