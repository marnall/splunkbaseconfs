{"basic_builder": {"appname": "TA-XProtect", "friendly_name": "TA-Xprotect", "version": "1.0.6", "author": "ColorTokens", "description": "TA-Xprotect", "theme": "#fff", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "3.0.1", "tab_build_no": "2", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "xprotect_hosts", "interval": "600", "use_external_validation": true, "streaming_mode_xml": true, "name": "xprotect_hosts", "title": "xprotect Hosts", "description": "xprotect Hosts", "type": "customized", "parameters": [{"required": false, "name": "notes", "label": "Notes", "default_value": "", "placeholder": "", "help_string": "Optional Input", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "notes", "title": "Notes", "description": "Optional Input", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\nimport requests, json\nfrom urllib3.exceptions import InsecureRequestWarning\nrequests.packages.urllib3.disable_warnings(category=InsecureRequestWarning)\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    pass\n\ndef collect_events(helper, ew):\n    \n    # get global variable configuration\n    url = helper.get_global_setting(\"spectrum_url\")\n    token = helper.get_global_setting(\"api_token\")\n    tenant = helper.get_global_setting(\"tenant_name\")\n\n    f = open(\"/opt/splunk/var/log/splunk/xprotect.conf\", \"w\")\n    f.write(url    +'|')\n    f.write(token  +'|')\n    f.write(tenant)\n    f.close()\n\n    r = requests.get(url = url + '/public/api/v1/'+ tenant + '/resources', \n                headers={'x-api-token': token}, verify=False)\n\n    if \"items\" in r.json().keys():\n        event = helper.new_event(data=json.dumps(r.json()['items']), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n        ew.write_event(event)\n\n", "customized_options": [{"name": "notes", "value": ""}], "uuid": "8c7a1dc80d8846fe99b0b94b905837ab"}, {"index": "default", "sourcetype": "xprotect_events", "interval": "600", "use_external_validation": true, "streaming_mode_xml": true, "name": "xprotect_events", "title": "Events", "description": "Events", "type": "customized", "parameters": [{"name": "notes", "label": "Notes", "help_string": "Optional Input", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "notes", "title": "Notes", "description": "Optional Input", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nfrom time import time\nfrom datetime import datetime\nfrom requests.adapters import HTTPAdapter\nimport os.path\nfrom os import path\n\nimport requests, json\nfrom urllib3.util.retry import Retry\nfrom urllib3.exceptions import InsecureRequestWarning\nrequests.packages.urllib3.disable_warnings(category=InsecureRequestWarning)\n\nlimit = str(5000)\nPRESET_FILE = \"/opt/splunk/var/log/splunk/xprotect_events.conf\"\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    pass\n\ndef collect_events(helper, ew):\n    _lte = int(time() * 1000)\n    lte = str(_lte)\n    INITIAL_RUN=False\n    PRESETS=None\n    # get global variable configuration\n    base_url = helper.get_global_setting(\"spectrum_url\")\n    token = helper.get_global_setting(\"api_token\")\n    tenant = helper.get_global_setting(\"tenant_name\")\n\n    f = open(\"/opt/splunk/var/log/splunk/xprotect.conf\", \"w\")\n    f.write(base_url    +'|')\n    f.write(token  +'|')\n    f.write(tenant)\n    f.close()\n\n    if os.path.exists(PRESET_FILE):\n        with open(PRESET_FILE) as f:\n            PRESETS = json.load(f)\n        if int(PRESETS['lte']) + 1 > _lte:\n            lte = str(_lte)\n            gte = str(int(lte) - int(60 * 10 * 1000))\n        else:\n            gte = str(int(PRESETS['lte']) + 1)\n            lte = str(int(gte) + int(60 * 10 * 1000))\n    else:\n        INITIAL_RUN=True\n        gte = str(int(lte) - int(60 * 10 * 1000))\n\n    f = open(PRESET_FILE, \"w\")\n    PRESETS = { \"gte\": gte, \"lte\": lte }\n    f.write(json.dumps(PRESETS))\n    f.close()\n        \n    done = 0\n    total = 1\n    url = base_url + '/public/api/v1/' + tenant + '/analytics/events?gte='+gte+'&lte='+lte+'&limit='+limit\n    helper.log_debug(\">>>> URL = \" + url)\n    s = requests.Session()\n    retries = Retry(total=5, backoff_factor=0.1, status_forcelist=[ 500, 502, 503, 504 ])\n    s.mount('https://', HTTPAdapter(max_retries=retries))\n    r = s.get(url = url, headers={'x-api-token': token}, verify=False)\n    \n    eventsArray = []\n    while done < total:\n        if \"pagination\" in r.json().keys():\n            page_info = r.json()['pagination']\n            helper.log_debug(json.dumps(page_info))\n            if \"updatedDate\" in page_info.keys():\n                updatedDate = str(page_info['updatedDate'])\n                skipUntil = page_info['skipUntil']\n                total = page_info['total']\n                itemCount = r.json()['itemCount']\n                if \"items\" in r.json().keys():\n                    event = helper.new_event(data=json.dumps(r.json()['items']), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n                    ew.write_event(event)\n                    done = done + itemCount\n                    f = open(PRESET_FILE, \"w\")\n                    PRESETS['url'] = url\n                    PRESETS['total'] = total\n                    PRESETS['done'] = done\n                    f.write(json.dumps(PRESETS))\n                    f.close()\n                    helper.log_debug(\"DONE :: \" + str(done) + \", TOTAL = \" + str(itemCount))\n                    url = base_url + '/public/api/v1/' + tenant + '/analytics/events?gte='+gte+'&lte='+lte+'&limit='+limit+'&updatedDate='+updatedDate+'&skipUntil='+skipUntil\n                    helper.log_debug(\">>>> URL = \" + url)\n                    r = s.get(url = url, headers={'x-api-token': token}, verify=False)\n                else:\n                    helper.log_debug(json.dumps(r.json()))\n                    total = -1\n            else:\n                helper.log_debug(json.dumps(r.json()))\n                total = -1\n        else:\n            helper.log_debug(\"NO PAGINATION INFO IN RESPONSE\")\n            total = -1\n            if \"items\" in r.json().keys():\n                event = helper.new_event(data=json.dumps(r.json()['items']), source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype())\n                ew.write_event(event)\n", "customized_options": [{"name": "notes", "value": ""}], "uuid": "8da177fc0699498a8fb0787c82bb8894", "sample_count": "1"}]}, "field_extraction_builder": {"xprotect_hosts": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": true, "name": "spectrum_url", "label": "Spectrum URL", "default_value": "", "placeholder": "", "help_string": "Eg. https://tenant.spectrum.colortokens.com", "type": "text", "format_type": "text", "value": "https://siemdemo-stage1.spectrum.colortokensecurecloud.com"}, {"required": true, "name": "tenant_name", "label": "Tenant Name", "default_value": "", "placeholder": "", "help_string": "Eg. ctdemo", "type": "text", "format_type": "text", "value": "siemdemo"}, {"required": true, "name": "api_token", "label": "API Token", "placeholder": "", "default_value": "", "help_string": "API Token generated from API Manager", "type": "password", "format_type": "password", "value": ""}]}}, "sourcetype_builder": {"xprotect_events": {"metadata": {"event_count": 0, "data_input_name": "xprotect_events", "extractions_count": 0, "cims_count": 0}}, "xprotect_hosts": {"metadata": {"event_count": 0, "data_input_name": "xprotect_hosts", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1666166098_85", "progress": 0.7857142857142857}}