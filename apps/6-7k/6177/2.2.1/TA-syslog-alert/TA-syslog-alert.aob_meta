{"alert_action_builder": {"modular_alerts": [{"description": "Send message over syslog", "largeIcon": "", "smallIcon": "", "label": "Syslog message", "short_name": "syslog_message", "parameters": [{"format_type": "text", "required": true, "name": "message_field", "label": "Message Field", "default_value": "message", "help_string": "", "type": "", "value": "_raw"}, {"format_type": "text", "required": true, "name": "host", "label": "Destination host", "default_value": "", "help_string": "Destination hostname or IP address", "type": "", "value": "172.32.21.10"}, {"format_type": "text", "required": true, "name": "port", "label": "Destination port", "default_value": "", "help_string": "Destination port number", "type": "", "value": "6000"}, {"format_type": "dropdownlist", "required": true, "name": "proto", "label": "Protocol", "default_value": "udp", "help_string": "", "possible_values": {"TCP": "tcp", "UDP": "udp"}, "type": "", "value": "udp"}, {"format_type": "dropdownlist", "required": true, "name": "facility", "label": "Facility", "default_value": "16", "help_string": "", "possible_values": {"Kernel messages (kern)": "0", "User-level messages (user)": "1", "Mail system (mail)": "2", "System daemons (daemon)": "3", "Security/authentication messages (auth)": "4", "Messages generated internally by syslogd (syslog)": "5", "Line printer subsystem (lpr)": "6", "Network news subsystem (news)": "7", "UUCP subsystem (uucp)": "8", "Clock daemon (cron)": "9", "Security/authentication (authpriv)": "10", "FTP daemon (ftp)": "11", "NTP subsystem (ntp)": "12", "Log audit (security)": "13", "Log alert (console)": "14", "Scheduling daemon (solaris-cron)": "15", "Local facility - 0 (local0)": "16", "Local facility - 1 (local1)": "17", "Local facility - 2 (local2)": "18", "Local facility - 3 (local3)": "19", "Local facility - 4 (local4)": "20", "Local facility - 5 (local5)": "21", "Local facility - 6 (local6)": "22", "Local facility - 7 (local7)": "23"}, "type": "", "value": "16"}, {"format_type": "dropdownlist", "required": true, "name": "severity", "label": "Severity", "default_value": "6", "help_string": "", "possible_values": {"Emergency": "0", "Alert": "1", "Critical": "2", "Error": "3", "Warning": "4", "Notice": "5", "Informational": "6", "Debug": "7"}, "type": "", "value": "6"}, {"format_type": "dropdownlist", "required": true, "name": "syslog_format", "label": "Syslog format", "default_value": "classic", "help_string": "\"Classic\" format messages are prefixed with short hostname and app name", "possible_values": {"Classic": "classic", "Plain message": "plain"}, "type": "", "value": "classic"}, {"format_type": "text", "required": false, "name": "timestamp_format", "label": "Timestamp format", "default_value": "%b %e %H:%M:%S", "help_string": "Timestamp format in strftime() syntax", "type": "", "value": "%b %e %H:%M:%S"}], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets and sets the log level\n    helper.set_log_level(helper.log_level)\n\n    # The following example gets the alert action parameters and prints them to the log\n    message_field = helper.get_param(\"message_field\")\n    helper.log_info(\"message_field={}\".format(message_field))\n\n    host = helper.get_param(\"host\")\n    helper.log_info(\"host={}\".format(host))\n\n    port = helper.get_param(\"port\")\n    helper.log_info(\"port={}\".format(port))\n\n    proto = helper.get_param(\"proto\")\n    helper.log_info(\"proto={}\".format(proto))\n\n    facility = helper.get_param(\"facility\")\n    helper.log_info(\"facility={}\".format(facility))\n\n    severity = helper.get_param(\"severity\")\n    helper.log_info(\"severity={}\".format(severity))\n\n    syslog_format = helper.get_param(\"syslog_format\")\n    helper.log_info(\"syslog_format={}\".format(syslog_format))\n\n    timestamp_format = helper.get_param(\"timestamp_format\")\n    helper.log_info(\"timestamp_format={}\".format(timestamp_format))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action syslog_message started.\")\n\n    import logging\n    import logging.handlers\n    import socket\n\n    message_field = helper.get_param(\"message_field\")\n    host = helper.get_param(\"host\")\n    port = helper.get_param(\"port\")\n    proto = helper.get_param(\"proto\")\n    helper.log_info(\"proto={}\".format(proto))\n    facility = int(helper.get_param(\"facility\"))\n    severity = int(helper.get_param(\"severity\"))\n    syslog_format = helper.get_param(\"syslog_format\")\n    timestamp_format = helper.get_param(\"timestamp_format\")\n    class ContextFilter(logging.Filter):\n        hostname = socket.gethostname().split('.', 1)[0]\n        def filter(self, record):\n            record.hostname = ContextFilter.hostname\n            return True\n            \n    logger = logging.getLogger('syslog')\n    logger.setLevel(1)\n    \n    if proto == \"tcp\":\n        handler = logging.handlers.SysLogHandler(address=(host,int(port)), socktype=socket.SOCK_STREAM, facility=facility)\n        # Trailing character for emmitted messages\n        trailer=\"\\n\"\n    else:\n        handler = logging.handlers.SysLogHandler(address=(host,int(port)), socktype=socket.SOCK_DGRAM, facility=facility)\n        # Trailing character for emmitted messages\n        trailer=\"\"\n\n    # Modern syslog server implementations consider trailing \\0 to be a part of the payload and \n    # not message message terminator\n    handler.append_nul = False\n\n    logger.addHandler(handler)\n    \n    if syslog_format == \"plain\":\n        formatter = logging.Formatter('%(message)s')\n    elif syslog_format == \"classic\":\n        handler.addFilter(ContextFilter())\n        formatter = logging.Formatter('%(asctime)s %(hostname)s splunk: %(message)s',datefmt=timestamp_format)\n    \n    handler.setFormatter(formatter)\n    \n    priority = handler.encodePriority(facility,severity)\n    \n    events = helper.get_events()\n    for event in events:\n        message=event[message_field] + trailer\n        helper.log_info(type(message))\n        helper.log_debug(\"event={}\".format(message))\n        logger.log(severity,message)\n\n\n    return 0\n    \n", "uuid": "045348aaf3114bc2b70cfa6129c911c0"}]}, "basic_builder": {"appname": "TA-syslog-alert", "friendly_name": "Syslog Alert", "version": "2.2.1", "author": "Igor Sher", "description": "Alert action for sending messages over syslog", "theme": "#297ba5", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.4", "tab_build_no": "0", "build_no": 8}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1709590212_58", "progress": 1.0}}