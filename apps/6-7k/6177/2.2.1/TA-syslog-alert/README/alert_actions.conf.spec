
[syslog_message]
python.version = python3
param.message_field = <string> Message Field. It's a required parameter. It's default value is message.
param.host = <string> Destination host. It's a required parameter.
param.port = <string> Destination port. It's a required parameter.
param.proto = <list> Protocol. It's a required parameter. It's default value is udp.
param.facility = <list> Facility. It's a required parameter. It's default value is 16.
param.severity = <list> Severity. It's a required parameter. It's default value is 6.
param.syslog_format = <list> Syslog format. It's a required parameter. It's default value is classic.
param.timestamp_format = <string> Timestamp format.  It's default value is %b %e %H:%M:%S.

