: 0, "cims_count": 0}}, "mutiny:nodes:default": {"metadata": {"event_count": 0, "data_input_name": "get_nodes_default", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1677173972_29", "progress": 0.75}}