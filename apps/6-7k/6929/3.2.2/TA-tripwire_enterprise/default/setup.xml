<setup>
  <block title="Tripwire Data Directory"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="data_location">
        <label>This is the directory the FIM and SCM folders will be stored in</label>
        <type>text</type>
      </input>
  </block>
  <!--block title="sourcetypes" endpoint="data/inputs/monitor" entity="*" mode="iter">
      <input field="disabled">
        <label>$name$</label>
        <type>bool</type>
      </input>
  </block-->
  <block title="Splunk Parent Directory (e.g. C:\Program Files)"
         endpoint="te_data/te_endpoint" enabled="in-windows" entity="te_parameters">
      <input field="windows_splunk_dir">
        <label>This directory should contain the Splunk installation</label>
        <type>text</type>
      </input>
  </block>
  <block title="Tripwire Listening Port"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="listening_port">
        <label>Enter the port that Splunk should listen for data</label>
        <type>text</type>
      </input>
  </block>
  <block title="Tripwire Enterprise Console"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="workflow_host">
        <label>Enter the IP address for the Tripwire Enterprise console ($workflow_host$)</label>
        <type>text</type>
      </input>
      <input field="te_sslverify">
          <label>Verify SSL certificate of TE console</label>
          <type>bool</type>
      </input>
      <input field="te_ssl_cert_path">
          <label>Path to trusted CA certificate</label>
          <type>text</type>
      </input>
  </block>
  <block title="Frequency of SCM Data Retrieval"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="scm_int">
        <label>Currently set at $scm_int_saved$ $scm_unit$(s). Enter new frequency:</label>
        <type>text</type>
      </input>
      <input field="scm_hour">
        <label>Hour(s)</label>
        <type>bool</type>
      </input>
      <input field="scm_day">
        <label>Day(s)</label>
        <type>bool</type>
      </input>
  </block>
  <block title="Frequency of FIM Data Retrieval"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="fim_int">
        <label>Currently set at $fim_int_saved$ $fim_unit$(s). Enter new frequency:</label>
        <type>text</type>
      </input>
      <input field="fim_hour">
        <label>Hour(s)</label>
        <type>bool</type>
      </input>
      <input field="fim_day">
        <label>Day(s)</label>
        <type>bool</type>
      </input>
      <input field="fim_timeout">
        <label>Timeout (in minutes) of FIM data retrieval. Currently set at $fim_timeout$ minute(s).</label>
        <type>text</type>
      </input>
  </block>
    <block title="Frequency of ECR Data Retrieval"
           endpoint="te_data/te_endpoint" entity="te_parameters">
        <input field="ecr_int">
            <label>Currently set at $ecr_int_saved$ $ecr_unit$(s). Enter new frequency:</label>
            <type>text</type>
        </input>
        <input field="ecr_hour">
            <label>Hour(s)</label>
            <type>bool</type>
        </input>
        <input field="ecr_day">
            <label>Day(s)</label>
            <type>bool</type>
        </input>
    </block>
  <block title="Number of Historical Days to Populate"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="hist_days">
        <label>Enter the number of days of data to collect from the Tripwire Enterprise console for the initial data pull. Currently set at $hist_days$ days.</label>
        <type>text</type>
      </input>
  </block>
  <block title="showContentDiff Data"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="showContentDiff">
        <label>Index data for showContentDiff</label>
        <type>bool</type>
      </input>
  </block>
    <block title="Compare Previous Versions"
           endpoint="te_data/te_endpoint" entity="te_parameters">
        <input field="compare_prev_version">
            <label>Diff previous versions rather than baseline.</label>
            <type>bool</type>
        </input>
    </block>
  <block title="Distributed Environment"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="use_forwarder_bool">
        <label>Monitor data on forwarders</label>
        <type>bool</type>
      </input>
  </block>
  <block title="REST API - FIM"
                   endpoint="te_data/te_endpoint" entity="te_parameters">
    <input field="fim_use_rest">
        <label>(Experimental) Use the REST API for FIM data instead of running SOAP reports.</label>
        <type>bool</type>
    </input>
    <input field="fim_rest_threads">
        <label>Number of worker threads to use for gathering FIM data from the REST API.</label>
        <type>text</type>
    </input>
cc</block>
  <block title="REST API - SCM"
                   endpoint="te_data/te_endpoint" entity="te_parameters">
    <input field="scm_use_rest">
        <label>(Experimental) Use the REST API for SCM data instead of running SOAP reports.</label>
        <type>bool</type>
    </input>
    <input field="scm_rest_threads">
        <label>Number of worker threads to use for gathering SCM data from the REST API.</label>
        <type>text</type>
    </input>
    <input field="scm_policy_names">
        <label>CSV list of policy names to pull data for.  Default is all policies.</label>
        <type>text</type>
    </input>
    <input field="scm_daily_reindex">
        <label>Pull and reindex all SCM results on the first run of each day.</label>
        <type>bool</type>
    </input>
    <input field="scm_exclude_waivered">
        <label>Exclude waivered test results from being gathered.</label>
        <type>bool</type>
    </input>
    <input field="scm_detailed_attributes">
        <label>Include more detailed Node Attribute data.</label>
        <type>bool</type>
    </input>
    <input field="scm_reindex_policy_names">
        <label>CSV list of policy names to pull and reindex results for on the first run of each day. Default is all policies.</label>
        <type>text</type>
    </input>
</block>
    <block title="ECR"
           endpoint="te_data/te_endpoint" entity="te_parameters">
        <input field="ecr_rpt_names">
            <label>CSV list of Element Content Reports to run.  Default is no reports.</label>
            <type>text</type>
        </input>
        <input field="ecr_parse_sql">
            <label>Parse SQL Query Rules separately.</label>
            <type>bool</type>
        </input>
    </block>
  <block title="Logging"
         endpoint="te_data/te_endpoint" entity="te_parameters">
      <input field="tripwire_debug_logging">
          <label>Enable debug logging.</label>
          <type>bool</type>
      </input>
      <input field="tripwire_rest_logging">
          <label>Enable REST API logging.</label>
          <type>bool</type>
      </input>
  </block>
  <block title="Tripwire Enterprise Credentials" endpoint="te_data/te_endpoint" entity="te_parameters">
    <input endpoint="te_data/te_endpoint" entity="te_parameters" field="te_username">
      <label>Username</label>
      <type>text</type>
    </input>
    <input field="te_pass">
      <label>Password</label>
      <type>password</type>
    </input>
  </block>
  <!--<block title="Splunk Credentials" endpoint="te_data/te_endpoint" entity="te_parameters">
    <input endpoint="te_data/te_endpoint" entity="te_parameters" field="spl_username">
      <label>Username</label>
      <type>text</type>
    </input>
    <input field="spl_pass">
      <label>Password</label>
      <type>password</type>
    </input>
  </block>-->
</setup>
