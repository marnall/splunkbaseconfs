
[supportbee_alert_action]
python.version = python3
param.subject = <string> Subject. It's a required parameter. It's default value is Splunk Ticket.
param.requester_name = <string> Requester Name.  It's default value is splunk.
param.requester_email = <string> Requester Email. It's a required parameter.
param.message = <string> Message.  It's default value is Ticket created from splunk.

