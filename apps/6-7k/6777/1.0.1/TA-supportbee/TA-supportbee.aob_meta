{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "Supportbee Alert Action", "short_name": "supportbee_alert_action", "parameters": [{"format_type": "text", "required": true, "name": "subject", "label": "Subject", "default_value": "Splunk Ticket", "help_string": "", "type": "", "value": "Splunk Ticket"}, {"format_type": "text", "required": false, "name": "requester_name", "label": "Requester Name", "default_value": "splunk", "help_string": "", "type": "", "value": "splunk"}, {"format_type": "text", "required": true, "name": "requester_email", "label": "Requester Email", "default_value": "", "help_string": "", "type": "", "value": "test@test.com"}, {"format_type": "text", "required": false, "name": "message", "label": "Message", "default_value": "Ticket created from splunk", "help_string": "", "type": "", "value": "Ticket created from splunk"}], "code": "import requests\nimport json\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the setup parameters and prints them to the log\n    supportbee_url = helper.get_global_setting(\"supportbee_url\")\n    helper.log_info(\"supportbee_url={}\".format(supportbee_url))\n    api_key = helper.get_global_setting(\"api_key\")\n    helper.log_info(\"api_key={}\".format(api_key))\n\n    # The following example gets the alert action parameters and prints them to the log\n    subject = helper.get_param(\"subject\")\n    helper.log_info(\"subject={}\".format(subject))\n\n    requester_name = helper.get_param(\"requester_name\")\n    helper.log_info(\"requester_name={}\".format(requester_name))\n\n    requester_email = helper.get_param(\"requester_email\")\n    helper.log_info(\"requester_email={}\".format(requester_email))\n\n    message = helper.get_param(\"message\")\n    helper.log_info(\"message={}\".format(message))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action supportbee_alert_action started.\")\n    api_key = helper.get_global_setting(\"api_key\")\n    supportbee_url = helper.get_global_setting(\"supportbee_url\")\n    subject = helper.get_param(\"subject\")\n    requester_email = helper.get_param(\"requester_email\")\n    requester_name = helper.get_param(\"requester_name\")\n    message = helper.get_param(\"message\")\n    api_url = \"https://\" + supportbee_url + \"/tickets.json\"\n    payload = json.dumps({\n    \"ticket\": {\n        \"subject\": f\"{subject}\",\n        \"requester_name\": f\"{requester_name}\",\n        \"requester_email\": f\"{requester_email}\",\n        \"content_attributes\": {\n        \"body\": f\"{message}\",\n        \"body_html\": f\"{message}\"\n        }\n    }\n    })\n    headers = {\n    'auth_token': api_key,\n    'Content-Type': 'application/json'\n    }\n    response = requests.request(\"POST\", api_url, headers=headers, data=payload)\n    \n    data=response.json()\n    helper.log_info(data)\n    print(data)\n    # TODO: Implement your alert action logic here\n    return 0\n", "uuid": "9014b673677c48d8942307d8b95e8bbd"}]}, "basic_builder": {"appname": "TA-supportbee", "friendly_name": "Supportbee", "version": "1.0.1", "author": "Lognalytics Technology", "description": "Alert Action to create tickets on Supportbee", "theme": "#F2C059", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 3}, "global_settings_builder": {"global_settings": {"customized_settings": [{"format_type": "text", "required": true, "name": "supportbee_url", "label": "Supportbee URL", "default_value": "", "help_string": "yourdomain.supportbee.com", "internal_name": "", "type": "text", "value": "datanalog1.supportbee.com"}, {"format_type": "password", "required": true, "name": "api_key", "label": "API Key", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1763541807_24"}}