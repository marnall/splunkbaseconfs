[sendToBHOM]

param.base_url = <string>
#sets the target for the BHOM Instance

param.access_key = <string>
#Access Key for REST api to BHOM

param.secret_key = <string>
#Secret Key for REST api to BHOM

param.tenant_id = <string
#Tenant ID for REST api to BHOM

param.message = <string>
#sets a user defined message to send

param.severity = <string>
#sets the severity of the event (ie. CRITICAL )

param.hostname = <string>
#host value from Splunk

param.object = <string>
