[sma1000_api_poller://<name>]
python.version = <value>
* Which Python version to use.

address = <value>
* DNS name or IP address of SMA1000 device to poll.

username = <value>
* SMA1000 username for API request authentication. User must have an administrator role with System monitoring > View privileges.

validate_ssl = <value>
* Validate SSL certificate presented by SMA1000 device.

port = <value>
* TCP port used for management traffic to SMA1000 devices.

credential_uuid = <value>
* UUID of password credential in Splunk StoragePasswords service.
