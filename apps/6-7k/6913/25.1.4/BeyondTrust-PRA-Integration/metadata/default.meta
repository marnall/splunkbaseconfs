# Application-level permissions

[]
access = read : [ * ], write : [ admin, power, sc_admin ]

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system

[views]
access = read : [ * ], write : [ admin ]
export = none

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[props/source%3A%3A...beyondtrust-pra-integration%2A.log%2A]
owner = admin

[props/source%3A%3A...beyondtrust_pra_integration%2A.log%2A]
owner = admin

[props/beyondtrust%3Apra%3Acef]
owner = admin