{"basic_builder": {"appname": "TA-verkada-add-on", "friendly_name": "Verkada Add-on", "version": "1.2.11", "author": "verkada", "description": "verkada add-on for verkada insights and verkada notifications", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.2.0", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "splunk:verkada:insights:json", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "verkada_insights", "title": "verkada_insights", "description": "", "type": "customized", "parameters": [{"required": true, "name": "organization_id", "label": "Organization ID", "default_value": "", "placeholder": "Organization ID", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "api_key", "label": "API Key", "placeholder": "API Key", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "organization_id", "title": "Organization ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Organization ID"}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": "API Key"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nimport requests\nfrom datetime import datetime, timedelta\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # organization_id = definition.parameters.get('organization_id', None)\n    # api_key = definition.parameters.get('api_key', None)\n    pass\n\ndef collect_events(helper, ew):\n    \"\"\"Implement your data collection logic here\"\"\"\n    \n    # get args from input setting\n    org_id = helper.get_arg('organization_id')\n    api_key = helper.get_arg('api_key')\n    interval = int(helper.get_arg('interval'))\n    check_point_key = \"{}_insights\".format(org_id)\n    last_indexed_time = helper.get_check_point(check_point_key)\n\n\n    # get last indexed time\n    if last_indexed_time:\n        start_time = last_indexed_time\n    else:\n        start_time = int((datetime.now() - timedelta(seconds=interval*2)).timestamp())\n    end_time = int((datetime.now() - timedelta(seconds=interval)).timestamp())\n    helper.log_info(f\"Start running object count jobs: {org_id}/{start_time}:{end_time}\")\n    \n    # start calling verkada vpublicapi\n    cameras = get_cameras(helper, api_key)\n    if cameras == None:\n        helper.log_error(f\"error getting cameraids from vpublicapi for org:{org_id}\")\n        helper.save_check_point(check_point_key, end_time)\n        return\n    \n    for camera in cameras:\n        helper.log_info(f\"Running Object Counts Job for camera {camera['camera_id']}\")\n        object_counts = get_object_counts(helper, api_key, camera[\"camera_id\"], start_time, end_time)\n        if object_counts == None:\n            helper.log_error(f'error getting object_counts from vpublicapi for camera:{camera[\"camera_id\"]} under org:{org_id}')\n            continue \n        \n        for object_count in object_counts:\n            object_count['camera_id'] = camera['camera_id']\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(),\n                                     sourcetype=helper.get_sourcetype(), data=json.dumps(object_count))\n            ew.write_event(event)\n    helper.save_check_point(check_point_key, end_time)\n\ndef get_cameras(helper, api_key: str) -> dict:\n    \"\"\"\n    Gets all cameras for an organization\n    Args:\n        org_id: Organization ID\n        api_key: API Key of the organization\n    Returns:\n        Dictionary that contains every camera. Mapped with camera ID\n    \"\"\"\n    proxies = get_proxy(helper, \"requests\")\n    url = \"https://api.verkada.com/cameras/v1/devices\"\n    paradict = {\n        'headers':{\"x-api-key\": api_key},\n        'params': {\n            'page_size': 200,\n        },\n        'proxies':proxies\n    }\n    resp = retry(url, paradict)\n    if resp == None:\n        helper.log_error(\"error calling get cameras\")\n        return None\n    cameras = resp.json()[\"cameras\"]\n    next_page_token = resp.json()[\"next_page_token\"]\n    while next_page_token:\n        paradict = {\n            'headers':{\"x-api-key\": api_key},\n            'params': {\n                'page_size': 200,\n                'page_token': next_page_token,\n            },\n            'proxies':proxies\n        }\n        resp = retry(url, paradict)\n        if resp == None:\n            helper.log_error(\"error calling get cameras\")\n            return None\n\n        cameras.extend(resp.json()[\"cameras\"])\n        next_page_token = resp.json()[\"next_page_token\"]\n            \n    return cameras\n\n\ndef get_object_counts(helper,\n                      api_key: str,\n                      camera_id: str,\n                      start_time: int,\n                      end_time: int) -> list:\n    \"\"\"\n    Gets all notifications for the past minute and returns them as a list\n    Args:\n        org_id: Organization ID\n        api_key: API Key of the organization\n        camera_id: Id of the camera\n        start_time: Start of time range\n        end_time: End of time range\n\n    Returns:\n        List of dictionaries where each entry is a object_count\n    \"\"\"\n    proxies = get_proxy(helper, \"requests\")\n    url = \"https://api.verkada.com/cameras/v1/analytics/object_counts\"\n    paradict = {\n        'headers':{\"x-api-key\": api_key},\n        'params':{\n            \"camera_id\": camera_id,\n            \"start_time\": start_time,\n            \"end_time\": end_time,\n            \"page_size\": 200,\n        },\n        'proxies':proxies,\n    }\n    resp = retry(url, paradict)\n    if resp == None:\n        helper.log_error(f\"error calling get object counts: {url}/{camera_id}/{start_time}:{end_time}\")\n        return None\n    \n    object_counts: list = resp.json()[\"object_counts\"]\n    next_page_token = resp.json()[\"next_page_token\"]\n    while next_page_token:\n        paradict = {\n            'headers':{\"x-api-key\": api_key},\n            'params':{\n                \"camera_id\": camera_id,\n                \"start_time\": start_time,\n                \"end_time\": end_time,\n                \"page_size\": 200,\n                \"page_token\": next_page_token,\n            },\n            'proxies':proxies,\n        }\n        resp = retry(url, paradict)\n        if resp == None:\n            helper.log_error(f\"error calling get object counts: {url}/{camera_id}/{start_time}:{end_time}\")\n            return None\n        object_counts.extend(resp.json()[\"object_counts\"])\n        next_page_token = resp.json()[\"next_page_token\"]\n    return object_counts\n\ndef retry(url, paradict):\n    NUM_RETRIES = 3\n    for _ in range(NUM_RETRIES):\n        try:\n            response = requests.get(url, **paradict)\n            if response.status_code in [200, 404]:\n                if response.status_code == 200:\n                    break\n        except requests.exceptions.ConnectionError:\n            pass\n        \n    ## Do something with successful response\n    if response is not None and response.status_code == 200:\n        return response\n    return None\n\ndef get_proxy(helper, proxy_type=\"requests\"):\n    proxies = None\n    helper.log_debug(\"_Splunk_ Getting proxy server.\")\n    proxy = helper.get_proxy()\n\n    if proxy:\n        helper.log_debug(\"_Splunk_ Proxy is enabled: %s:%s\" % (proxy[\"proxy_url\"], proxy[\"proxy_port\"]))\n        if proxy_type.lower() == \"requests\":\n            proxy_url = \"%s:%s\" % (proxy[\"proxy_url\"], proxy[\"proxy_port\"])\n            proxies = {\n                \"http\": proxy_url,\n                \"https\": proxy_url\n            }\n        elif proxy_type.lower() == \"event hub\":\n            proxies = {\n                'proxy_hostname': proxy[\"proxy_url\"],\n                'proxy_port': int(proxy[\"proxy_port\"]),\n                'username': proxy[\"proxy_username\"],\n                'password': proxy[\"proxy_password\"]\n            }\n\n    return proxies", "customized_options": [{"name": "organization_id", "value": "8fba9c3c-46c6-4bf7-9d5f-eabd95ee335d"}], "uuid": "138abe44ab4b4533bc8bd3823dd8f7ca"}, {"index": "default", "sourcetype": "splunk:verkada:notifications:json", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "verkada_notifications", "title": "verkada_notifications", "description": "", "type": "customized", "parameters": [{"required": true, "name": "organization_id", "label": "Organization ID", "default_value": "", "placeholder": "Organization ID", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "api_key", "label": "API Key", "placeholder": "API Key", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}, {"required": true, "name": "event_types", "label": "Event Types", "default_value": [], "help_string": "", "placeholder": "Event Types", "possible_values": [{"value": "access_control", "label": "Access Control"}, {"value": "camera", "label": "Camera"}], "type": "multi_dropdownlist", "format_type": "multi_dropdownlist", "value": []}], "data_inputs_options": [{"type": "customized_var", "name": "organization_id", "title": "Organization ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Organization ID"}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": "API Key"}, {"type": "customized_var", "name": "event_types", "title": "Event Types", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "access_control", "label": "Access Control"}, {"value": "camera", "label": "Camera"}], "format_type": "multi_dropdownlist", "default_value": [], "placeholder": "Event Types"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nimport requests\nfrom datetime import datetime, timedelta\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # organization_id = definition.parameters.get('organization_id', None)\n    # api_key = definition.parameters.get('api_key', None)\n    pass\n\ndef collect_events(helper, ew):\n    \"\"\"Implement your data collection logic here\"\"\"\n    \n    # get args from input setting\n    org_id = helper.get_arg('organization_id')\n    api_key = helper.get_arg('api_key')\n    interval = int(helper.get_arg('interval'))\n    event_types = helper.get_arg('event_types')\n    if len(event_types) > 2:\n        helper.log_warning(f\"event_types is a string, not a list: {event_types}\")\n        event_types = [event_types]\n    check_point_key = \"{}_notifications\".format(org_id)\n    last_indexed_time = helper.get_check_point(check_point_key)\n\n    # get last indexed time\n    if last_indexed_time:\n        start_time = last_indexed_time\n    else:\n        start_time = int((datetime.now() - timedelta(seconds=interval*2)).timestamp())\n    end_time = int((datetime.now() - timedelta(seconds=interval)).timestamp())\n    helper.log_info(f\"Start running notification jobs: {org_id}/{start_time}:{end_time}\")\n    \n    # start calling verkada vpublicapi\n    all_notifications = list()\n    for event_type in event_types:\n        notifications = get_notifications(helper, event_type, api_key, start_time, end_time)\n        if notifications == None:\n            helper.log_error(f\"error getting {event_type} notifications from vpublicapi for org:{org_id}\")\n            continue\n        all_notifications.extend(notifications)\n    \n    for notification in all_notifications:\n        event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(),\n                                 sourcetype=helper.get_sourcetype(), data=json.dumps(notification))\n        ew.write_event(event)\n    helper.save_check_point(check_point_key, end_time)\n\n\ndef get_notifications(\n    helper, event_type: str, api_key: str, start_time: int, end_time: int\n) -> list:\n    \"\"\"\n    Gets all notifications for the past minute and returns them as a list\n    Args:\n        org_id: Organization ID\n        api_key: API Key of the organization\n        notification_types: Types of notifications to look for\n\n    Returns:\n        List of dictionaries where each entry is a notification\n    \"\"\"\n    proxies = get_proxy(helper, \"requests\")\n    urls = {\n        \"camera\": \"https://api.verkada.com/cameras/v1/alerts?include_image_url=false\",\n        \"access_control\": \"https://api.verkada.com/events/v1/access\",\n    }\n    url = urls.get(event_type)\n    if not url:\n        helper.log_error(f\"error getting notications: no url for event type {event_type}\")\n        return None\n    paradict = {\n        'headers':{\"x-api-key\": api_key},\n        'params':{\n            \"start_time\": start_time,\n            \"end_time\": end_time,\n            \"page_size\": 200,\n        },\n        'proxies':proxies,\n    }\n\n    resp = retry(url, paradict)\n    if resp == None:\n        helper.log_error(f\"error calling get notifications: {url}/{start_time}:{end_time}\")\n        return None\n    result_keys = {\n        \"camera\": \"notifications\",\n        \"access_control\": \"events\",\n    }\n    notifications: list = resp.json()[result_keys.get(event_type)]\n    next_page_token = resp.json()[\"next_page_token\"]\n    while next_page_token:\n        paradict = {\n            'headers':{\"x-api-key\": api_key},\n            'params':{\n                \"start_time\": start_time,\n                \"end_time\": end_time,\n                \"page_size\": 200,\n                \"page_token\": next_page_token,\n            },\n            'proxies':proxies,\n        }\n        resp = retry(url, paradict)\n        if resp == None:\n            helper.log_error(f\"error calling get notifications: {url}/{start_time}:{end_time}\")\n            return None\n        \n        notifications.extend(resp.json()[result_keys.get(event_type)])\n        next_page_token = resp.json()[\"next_page_token\"]\n\n    return notifications\n\n\ndef retry(url, paradict):\n    NUM_RETRIES = 3\n    for _ in range(NUM_RETRIES):\n        try:\n            response = requests.get(url, **paradict)\n            if response.status_code in [200, 404]:\n                if response.status_code == 200:\n                    break\n        except requests.exceptions.ConnectionError:\n            pass\n        \n    ## Do something with successful response\n    if response is not None and response.status_code == 200:\n        return response\n    return None\n\ndef get_proxy(helper, proxy_type=\"requests\"):\n    proxies = None\n    helper.log_debug(\"_Splunk_ Getting proxy server.\")\n    proxy = helper.get_proxy()\n\n    if proxy:\n        helper.log_debug(\"_Splunk_ Proxy is enabled: %s:%s\" % (proxy[\"proxy_url\"], proxy[\"proxy_port\"]))\n        if proxy_type.lower() == \"requests\":\n            proxy_url = \"%s:%s\" % (proxy[\"proxy_url\"], proxy[\"proxy_port\"])\n            proxies = {\n                \"http\": proxy_url,\n                \"https\": proxy_url\n            }\n        elif proxy_type.lower() == \"event hub\":\n            proxies = {\n                'proxy_hostname': proxy[\"proxy_url\"],\n                'proxy_port': int(proxy[\"proxy_port\"]),\n                'username': proxy[\"proxy_username\"],\n                'password': proxy[\"proxy_password\"]\n            }\n\n    return proxies", "customized_options": [{"name": "organization_id", "value": "665f45d1-856f-48c3-aa56-cef2f17f2903"}, {"name": "event_types", "value": ["access_control", "camera"]}], "uuid": "150e04f9121648f5abc5fc0220217284"}, {"index": "default", "sourcetype": "splunk:verkada:auditLogs:json", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "verkada_audit_logs", "title": "verkada_audit_logs", "description": "", "type": "customized", "parameters": [{"required": true, "name": "organization_id", "label": "Organization ID", "default_value": "", "placeholder": "Organization ID", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "api_key", "label": "API Key", "placeholder": "API Key", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "organization_id", "title": "Organization ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "Organization ID"}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": "API Key"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nimport requests\nfrom datetime import datetime, timedelta\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # organization_id = definition.parameters.get('organization_id', None)\n    # api_key = definition.parameters.get('api_key', None)\n    pass\n\ndef collect_events(helper, ew):\n    \"\"\"Implement your data collection logic here\"\"\"\n    \n    # get args from input setting\n    org_id = helper.get_arg('organization_id')\n    api_key = helper.get_arg('api_key')\n    interval = int(helper.get_arg('interval'))\n    check_point_key = \"{}_audit_logs\".format(org_id)\n    last_indexed_time = helper.get_check_point(check_point_key)\n\n    # get last indexed time\n    if last_indexed_time:\n        start_time = last_indexed_time\n    else:\n        start_time = int((datetime.now() - timedelta(seconds=interval*2)).timestamp())\n    end_time = int((datetime.now() - timedelta(seconds=interval)).timestamp())\n    helper.log_info(f\"Start running notification jobs: {org_id}/{start_time}:{end_time}\")\n    \n    # start calling verkada vpublicapi\n    audit_logs = get_audit_logs(helper, api_key, start_time, end_time)\n    if audit_logs == None:\n        helper.log_error(f\"error getting audit_logs from vpublicapi for org:{org_id}\")\n    for audit_log in audit_logs:\n        event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(),\n                                 sourcetype=helper.get_sourcetype(), data=json.dumps(audit_log))\n        ew.write_event(event)\n    helper.save_check_point(check_point_key, end_time)\n\n\ndef get_audit_logs(\n    helper, api_key: str, start_time: int, end_time: int\n) -> list:\n    \"\"\"\n    Gets all audit_logs for the past minute and returns them as a list\n    Args:\n        org_id: Organization ID\n        api_key: API Key of the organization\n        notification_types: Types of audit_logs to look for\n\n    Returns:\n        List of dictionaries where each entry is a notification\n    \"\"\"\n    proxies = get_proxy(helper, \"requests\")\n    url = \"https://api.verkada.com/core/v1/audit_log\"\n    paradict = {\n        'headers':{\"x-api-key\": api_key},\n        'params':{\n            \"start_time\": start_time,\n            \"end_time\": end_time,\n            \"page_size\": 200,\n        },\n        'proxies':proxies,\n    }\n\n    resp = retry(url, paradict)\n    if resp == None:\n        helper.log_error(f\"error calling get audit_logs: {url}/{start_time}:{end_time}\")\n        return None\n    audit_logs: list = resp.json()[\"audit_logs\"]\n    next_page_token = resp.json()[\"next_page_token\"]\n    while next_page_token:\n        paradict = {\n            'headers':{\"x-api-key\": api_key},\n            'params':{\n                \"start_time\": start_time,\n                \"end_time\": end_time,\n                \"page_size\": 200,\n                \"page_token\": next_page_token,\n            },\n            'proxies':proxies,\n        }\n        resp = retry(url, paradict)\n        if resp == None:\n            helper.log_error(f\"error calling get audit_logs: {url}/{start_time}:{end_time}\")\n            return None\n        \n        audit_logs.extend(resp.json()[\"audit_logs\"])\n        next_page_token = resp.json()[\"next_page_token\"]\n\n    return audit_logs\n\n\ndef retry(url, paradict):\n    NUM_RETRIES = 3\n    for _ in range(NUM_RETRIES):\n        try:\n            response = requests.get(url, **paradict)\n            if response.status_code in [200, 404]:\n                if response.status_code == 200:\n                    break\n        except requests.exceptions.ConnectionError:\n            pass\n        \n    ## Do something with successful response\n    if response is not None and response.status_code == 200:\n        return response\n    return None\n\ndef get_proxy(helper, proxy_type=\"requests\"):\n    proxies = None\n    helper.log_debug(\"_Splunk_ Getting proxy server.\")\n    proxy = helper.get_proxy()\n\n    if proxy:\n        helper.log_debug(\"_Splunk_ Proxy is enabled: %s:%s\" % (proxy[\"proxy_url\"], proxy[\"proxy_port\"]))\n        if proxy_type.lower() == \"requests\":\n            proxy_url = \"%s:%s\" % (proxy[\"proxy_url\"], proxy[\"proxy_port\"])\n            proxies = {\n                \"http\": proxy_url,\n                \"https\": proxy_url\n            }\n        elif proxy_type.lower() == \"event hub\":\n            proxies = {\n                'proxy_hostname': proxy[\"proxy_url\"],\n                'proxy_port': int(proxy[\"proxy_port\"]),\n                'username': proxy[\"proxy_username\"],\n                'password': proxy[\"proxy_password\"]\n            }\n\n    return proxies", "customized_options": [{"name": "organization_id", "value": "665f45d1-856f-48c3-aa56-cef2f17f2903"}], "uuid": "e5549f63e8f6418f9e39d3d215f027f3"}]}, "global_settings_builder": {"global_settings": {"log_settings": {}}}, "sourcetype_builder": {"splunk:verkada:insights:json": {"metadata": {"event_count": 0, "data_input_name": "verkada_insights", "extractions_count": 0, "cims_count": 0}}, "splunk:verkada:notifications:json": {"metadata": {"event_count": 0, "data_input_name": "verkada_notifications", "extractions_count": 0, "cims_count": 0}}, "splunk:verkada:auditLogs:json": {"metadata": {"event_count": 0, "data_input_name": "verkada_audit_logs", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1715989535_34", "progress": 1.0}}