{"basic_builder": {"appname": "TA-mondaycom-add-on-for-splunk", "friendly_name": "monday.com add-on for Splunk", "version": "2.6.1", "author": "monday.com", "description": "The monday.com add-on for Splunk let's you connect your monday.com audit-logs to your corporate's Splunk", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.0", "tab_build_no": "0", "build_no": 8}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "monday-audit-log", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "monday_com_audit_log", "title": "monday.com audit log", "description": "", "type": "customized", "parameters": [{"name": "api_token", "label": "API token", "help_string": "You can find it under monday.com -> Admin -> Connections -> Personal API Token", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "monday_com_domain", "label": "(UNUSED) monday.com domain", "help_string": "NO LONGER USED. HERE FOR BACKWARDS COMPATIBILITY ONLY. LEAVE BLANK. ", "required": false, "format_type": "text", "default_value": "", "placeholder": "my-domain", "type": "text", "value": "test"}, {"name": "audit_log_api_token", "label": "(UNUSED) Audit log token", "help_string": "NO LONGER USED. HERE FOR BACKWARDS COMPATIBILITY ONLY. LEAVE BLANK. ", "required": false, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "api_token", "title": "API token", "description": "You can find it under monday.com -> Admin -> Connections -> Personal API Token", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "monday_com_domain", "title": "(UNUSED) monday.com domain", "description": "NO LONGER USED. HERE FOR BACKWARDS COMPATIBILITY ONLY. LEAVE BLANK. ", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "my-domain"}, {"type": "customized_var", "name": "audit_log_api_token", "title": "(UNUSED) Audit log token", "description": "NO LONGER USED. HERE FOR BACKWARDS COMPATIBILITY ONLY. LEAVE BLANK. ", "required_on_edit": false, "required_on_create": false, "format_type": "password", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nfrom datetime import date\nimport os\nimport sys\nimport time\nimport json\nimport requests\nimport date as date_service\nfrom store import KVStore, AppStore\nfrom monday_api_client import MondayApiClient\nimport constants\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    monday_domain = definition.parameters.get('monday_com_domain', None)\n    MondayApiClient.check_slug_exists(monday_domain, helper)\n\n\n# helper https://docs.splunk.com/Documentation/AddonBuilder/4.1.0/UserGuide/PythonHelperFunctions#:~:text=The%20Add%2Don%20Builder%20provides,input%20arguments%20using%20helper%20functions.\n# ew - Event Writter\ndef collect_events(helper, ew):\n    opt_monday_domain = helper.get_arg('monday_com_domain')\n    opt_audit_log_api_token = helper.get_arg('audit_log_api_token')\n    opt_api_token = helper.get_arg('api_token')\n\n\n    state = AppStore(KVStore(helper))\n    api_client = MondayApiClient(helper, opt_monday_domain, opt_audit_log_api_token, opt_api_token)\n\n    streamToSplunk({'helper': helper, 'ew': ew},\n                   {'monday_api_client': api_client, 'state': state, 'page': constants.FIRST_PAGE})\n\n    state.success()\n\n\ndef streamToSplunk(splunk_payload, request_data):\n    helper = splunk_payload['helper']\n    monday_api_client, state, page = request_data.values()\n\n    try:\n        data = monday_api_client.fetch_audit_logs(\n            {'start_date': state.get_start_date(), 'end_date': state.get_end_date(), 'page': page})\n        logs, next_page = data.values()\n\n    except (json.decoder.JSONDecodeError, requests.exceptions.HTTPError):\n        helper.log_error(constants.RESPONSE_ERROR_MESSAGE)\n        exit()\n\n    sendEvent(splunk_payload, state, logs)\n\n    if (next_page is not None):\n        streamToSplunk(splunk_payload, {**request_data, 'page': next_page})\n\n\ndef sendEvent(splunk_payload, state, logs):\n    helper, ew = splunk_payload.values()\n    for log in logs:\n        timestamp = log[\"timestamp\"]\n        # In case we failed in our last fetch, we skip the logs we already sent to Splunk\n        if (timestamp >= state.get_current_position()):\n            continue\n\n        event = helper.new_event(json.dumps(\n            log), index=helper.get_output_index(), source=helper.get_input_type(), sourcetype=helper.get_sourcetype())\n        # Creates a new event. This function is used to index data in Splunk\n        ew.write_event(event)\n\n        state.set_current_position(timestamp)\n", "customized_options": [{"name": "monday_com_domain", "value": ""}], "uuid": "bc77dc7b70fe4d0e99331cdf31575988", "sample_count": "63"}]}, "field_extraction_builder": {"monday-audit-log": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}}}, "sourcetype_builder": {"monday-audit-log": {"metadata": {"data_input_name": "monday_com_audit_log"}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1749218531_76"}}