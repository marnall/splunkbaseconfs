[crowdstrike_scheduled_search_json://<name>]
cloud = Select the appropriate cloud environment for the Falcon Instance
collection_option = Configure to collect historic or most recent search events
credentials = This is an OAuth2 based API credential with a Scheduled Reports 'Read' scope
index = (Default: default)
interval = Time interval of input in seconds - must be greater than or equal to 300 (5 Minutes)
search_name = Enter the full name of the scheduled search from the Falcon UI
