[teamviewer:log]

EXTRACT-teamviewer_log = (?<date>\d{4}\/\d{2}\/\d{2})\s+(?<time>\d{2}:\d{2}:\d{2}\.\d{3})\s+(?<number1>\d+)\s+(?<number2>\d+)\s+(?<code>\S+)\s+(?<message>.*)$

FIELDALIAS-code = code as code_log

LINE_BREAKER = ([\r\n]+)
NO_BINARY_CHECK = true
category = Application
description = Application Teamviewer logs
disabled = false
pulldown_type = true

EVAL-vendor = "Icewarp"
EVAL-product = "Email"
