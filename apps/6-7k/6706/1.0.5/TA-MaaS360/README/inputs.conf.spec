[device://<name>]
app_compliance = Filter devices based on their app compliance status (Default: ALL)
device_status = Filter devices based on their status (Default: ALL)
index = (Default: default)
interval = Time interval of input in seconds. (Default: 86400)
maas360_account = Global account to use for MaaS360 input
managed_status = Filter devices based on their MaaS360 managed status (Default: ALL)
platform = Filter devices based on their platform (Default: ALL)
plc_compliance = Filter devices based on their policy compliance status (Default: ALL)
pswd_compliance = Filter devices based on their password compliance status (Default: ALL)
rule_compliance = Filter devices based on their rule compliance status (Default: ALL)

[compliance_events://<name>]
index = (Default: default)
interval = Time interval of input in seconds. (Default: 1800)
maas360_account = Global account to use for MaaS360 input
