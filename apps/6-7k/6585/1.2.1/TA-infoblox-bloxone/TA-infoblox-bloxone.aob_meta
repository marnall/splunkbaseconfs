ponse.encoding is None:\n        response.encoding = 'utf-8'\n\n    for line in response.iter_lines(decode_unicode=True):\n        if line:\n            line = line.replace('\"host\":\"','\"hostname\":\"')\n            try:\n                r_json=json.loads(line)\n            except:\n                raise Exception(\"Unable to load into a json format\")\n\n            data = json.dumps(r_json)\n            #data = data.replace('\"host\":\"','\"hostname\":\"')\n            #data = data.replace(\"\\\"{\",\"{\")\n            #data = data.replace(\"}\\\"\",\"}\")\n            #data = data.replace(\"\\\\\\\"\",\"\\\"\")\n                \n            helper.log_info(data)\n\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=data)\n            ew.write_event(event)\n\n    helper.log_info(\"Infoblox TIDE download completed\")", "customized_options": [{"name": "first_run_get_past_iocs", "value": false}], "uuid": "7cd871e615cc4484a801610b6b3733b4", "sample_count": 0}]}, "field_extraction_builder": {"ib:tide:domains": {"data_format": "json"}, "ib:tide:ips": {"data_format": "json"}, "ib:tide:urls": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": true, "name": "apikey", "label": "BloxOne API Key", "placeholder": "", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}]}}, "sourcetype_builder": {"ib:tide:urls": {"metadata": {"event_count": 0, "data_input_name": "infoblox_bloxone_threat_intelligence_urls", "extractions_count": 0, "cims_count": 0}}, "ib:tide:domains": {"metadata": {"event_count": 0, "data_input_name": "infoblox_bloxone_threat_intelligence_domains", "extractions_count": 0, "cims_count": 0}}, "ib:tide:ips": {"metadata": {"event_count": 0, "data_input_name": "infoblox_bloxone_threat_in