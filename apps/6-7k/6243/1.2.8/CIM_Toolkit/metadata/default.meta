# Global Application-level permissions
[]
access = read : [ * ], write : [ sc_admin, admin, power ]
#export = system

# Specific KO permissions
[eventtypes]
export = system
[lookups]
export = system
[macros]
export = system
[props]
export = system
[savedsearches]
export = system
[tags]
export = system
[transforms]
export = system
[workflow_actions]
export = system
### VIEWSTATES: even normal users should be able to create shared viewstates
[viewstates]
access = read : [ * ], write : [ * ]
export = system
