{"alert_action_builder": {"modular_alerts": [{"description": "This action will send an Alert Event to the specified Cyware Orchestrate instance.", "largeIcon": "", "smallIcon": "", "label": "Push Alert Event to Cyware Orchestrate", "short_name": "push_alert_event_to_cyware_orchestrate", "active_response": {"technology": [{"vendor": "Cyware Labs", "product": "Cyware Orchestrate API", "version": ["1"]}], "supports_adhoc": true, "category": ["Information Gathering"], "task": ["create"], "subject": ["process"], "drilldown_uri": ""}, "parameters": [{"format_type": "text", "required": true, "name": "event_title", "label": "Event Title", "default_value": "Splunk Event Data", "help_string": "", "type": "", "value": "Splunk Event Data"}, {"format_type": "text", "required": true, "name": "event_type", "label": "Event Type", "default_value": "splunk-event", "help_string": "", "type": "", "value": "splunk-event"}], "code": "import hmac\nimport hashlib\nimport time\nimport base64\nimport requests\n\ndef generate_signature(expires, access_id, secret_key):\n    to_sign = '{}\\n{}'.format(access_id, expires)\n    signature = base64.b64encode(\n        hmac.new(\n            secret_key.encode('utf-8'),\n            to_sign.encode('utf-8'),\n            hashlib.sha1\n        ).digest()\n    ).decode(\"utf-8\")\n    return signature\n\ndef process_event(helper, *args, **kwargs):\n    try:\n        helper.log_info(\"INFO: Initiated sending events to Cyware products\")\n        # Setting variables\n        app_identifier = \"splunk-app\"\n        action_identifier = helper.configuration.get(\"event_type\")\n        cyware_orchestrate_url = helper.get_global_setting(\"cyware_url\")\n\n        # Verify that Orchestrate URL starts with HTTPS\n        # This is also done when entering values initially\n        if not cyware_orchestrate_url.startswith(\"https://\"):\n            helper.log_error(\"ERROR: Orchestrate URL is not HTTPS\")\n            return 0\n\n        cyware_orchestrate_access_key = helper.get_global_setting(\"cyware_access_key\")\n        cyware_orchestrate_secret_key = helper.get_global_setting(\"cyware_secret_key\")\n\n        helper.log_debug(\"Alert action csol_push_alerts started.\")\n        alert_data = {}\n        alert_data[\"sid\"] = helper.sid\n        alert_data[\"search_name\"] = helper.search_name\n        try:\n            alert_data[\"events\"] = []\n            alert_data[\"event_config\"] = helper.configuration\n            for event in helper.get_events():\n                alert_data[\"events\"].append(event)\n        except Exception as e:\n            helper.log_error(\"ERROR: Events not found: {}\".format(str(e)))\n            return 0\n            \n        data = {\n            \"title\": helper.configuration.get(\"event_title\"),\n            \"app_identifier\": app_identifier,\n            \"action_identifier\": action_identifier,\n            \"data\": alert_data,\n        }\n        # Formulating request data\n        expires = int(time.time() + 300)\n        sec_params = {}\n        sec_params[\"AccessID\"] = cyware_orchestrate_access_key\n        sec_params[\"Expires\"] = expires\n        try:\n            sec_params[\"Signature\"] = generate_signature(expires, cyware_orchestrate_access_key, cyware_orchestrate_secret_key)\n        except Exception as e:\n            helper.log_error(\"Fatal Error: Caught an exception while generating Authentication Signature: {}\".format(e))\n            return 0\n        else:\n            helper.log_debug(\"Authentication Signature Generated Successfully\")\n        endpoint = \"{0}/v1/events/\".format(cyware_orchestrate_url.rstrip('/'))\n        try:\n            response = helper.send_http_request(endpoint, \"POST\", parameters=sec_params, payload=data)\n            status_code = response.status_code\n\n            if status_code < 300:\n                helper.log_info(\"Created Source Event Successfully\")\n                return 1\n            else:\n                helper.log_error(\"Unable to create source event! Status Code: {0}\".format(status_code))\n                \n        except requests.exceptions.RequestException as e:\n            helper.log_error(\"Fatal Error: Encountered Error while pushing data to Cyware Orchestrate. \\nException Encountered: {}\".format(e))\n        \n    except Exception as e:\n        helper.log_error(\"ERROR: App error {}\".format(str(e)))\n        return 0\n    \n    return 1\n", "uuid": "011cde6746d24c5b8e2991f1588582c4"}]}, "basic_builder": {"appname": "TA-cyware-orchestrate", "friendly_name": "Cyware Orchestrate (CO)", "version": "1.1.9", "author": "Cyware Labs", "description": "The purpose of the Cyware Orchestrate app is to enable integration of the Cyware Orchestrate (CO) platform with Splunk Enterprise or Splunk Cloud.", "theme": "#A9A9A9", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 10}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}, "customized_settings": [{"format_type": "text", "required": true, "name": "cyware_url", "label": "Base URL", "default_value": "", "help_string": "Base URL of the OpenAPI of the Cyware Orchestrate Platform. (Only Secure, HTTPS Based, connections are allowed)\ne.g. https://<domain>:<port>/soarapi/openapi/", "internal_name": "", "type": "text", "value": ""}, {"format_type": "text", "required": true, "name": "cyware_access_key", "label": "Access ID", "default_value": "", "help_string": "Access ID used to integrate with Cyware Orchestrate Platform via OpenAPI", "internal_name": "", "type": "text", "value": ""}, {"format_type": "password", "required": true, "name": "cyware_secret_key", "label": "Secret Key", "default_value": "", "help_string": "Secret Key used to integrate with Cyware Orchestrate Platform via OpenAPI", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1762938071_38"}}