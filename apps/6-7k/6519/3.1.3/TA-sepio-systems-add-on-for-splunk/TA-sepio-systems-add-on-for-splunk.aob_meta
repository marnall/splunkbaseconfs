{"basic_builder": {"appname": "TA-sepio-systems-add-on-for-splunk", "friendly_name": "Sepio Systems Add-on For Splunk", "version": "3.1.3", "author": "Sepio", "description": "Splunk input for retrieving Sepio Platform audit trails and system events", "theme": "#297ba5", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.4.1", "tab_build_no": "0", "build_no": 24}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "sepio:system:events", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "sepio_events_input", "title": "Sepio Events Input", "description": "Query the prime/webui/Events/GetEventsIntegration endpoint", "type": "customized", "parameters": [{"name": "sepio_platform", "label": "Sepio Platform", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "log_type", "label": "Log Type", "help_string": "", "required": true, "possible_values": [{"value": "AuditsIntegration", "label": "Audit Trails"}, {"value": "EventsIntegration", "label": "Event Logs"}], "format_type": "dropdownlist", "default_value": "", "placeholder": "", "type": "dropdownlist", "value": "AuditsIntegration"}, {"name": "min_severity", "label": "Min Severity", "help_string": "", "required": true, "possible_values": [{"value": "Emergency", "label": "Emergency"}, {"value": "Alert", "label": "Alert"}, {"value": "Critical", "label": "Critical"}, {"label": "Error", "value": "Error"}, {"label": "Warning", "value": "Warning"}, {"label": "Notice", "value": "Notice"}, {"label": "Informational", "value": "Informational"}, {"label": "Debug", "value": "Debug"}], "format_type": "dropdownlist", "default_value": "Warning", "placeholder": "", "type": "dropdownlist", "value": "Informational"}], "data_inputs_options": [{"type": "customized_var", "name": "sepio_platform", "title": "Sepio Platform", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "log_type", "title": "Log Type", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "AuditsIntegration", "label": "Audit Trails"}, {"value": "EventsIntegration", "label": "Event Logs"}], "format_type": "dropdownlist", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "min_severity", "title": "Min Severity", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "Emergency", "label": "Emergency"}, {"value": "Alert", "label": "Alert"}, {"value": "Critical", "label": "Critical"}, {"label": "Error", "value": "Error"}, {"label": "Warning", "value": "Warning"}, {"label": "Notice", "value": "Notice"}, {"label": "Informational", "value": "Informational"}, {"label": "Debug", "value": "Debug"}], "format_type": "dropdownlist", "default_value": "Warning", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport random\n\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # category = definition.parameters.get('category', None)\n    # from = definition.parameters.get('from', None)\n    pass\n\ndef collect_events(helper, ew):\n    \n    opt_log_type = helper.get_arg('log_type')\n    account_name = helper.get_arg('sepio_platform')\n    \n    global_host_url = account_name['username']\n    opt_token = account_name['password']\n    \n    if not global_host_url.startswith(\"https\"):\n        raise Exception(\"The  Sepio Platform Url must use https protocol, e.g https://example.com\")\n    \n    if global_host_url.endswith('/'):\n        global_host_url = global_host_url[:-1]\n    \n    #query the GetEventsIntegration api\n    r_json = query_get_data(helper,global_host_url,opt_token,opt_log_type)\n    \n    ingest_Integrations(helper,ew,r_json,global_host_url,opt_log_type)\n    \n\ndef query_get_data(helper,host_url,opt_token,opt_log_type):\n    \n    payload = None\n    \n    opt_min_severity = helper.get_arg('min_severity')\n    \n    url = \"{}/prime/webui/Events/Get{}\".format(host_url,opt_log_type)\n    \n    header = {\n        'Content-Type': 'application/json',\n        'Authorization':'Bearer {}'.format(opt_token)\n        }\n    \n    if opt_log_type == \"EventsIntegration\":\n        \n        eventid = helper.get_check_point('eventID-{}'.format(helper.get_input_stanza_names()))\n        \n        if eventid == None:\n            \n            FromDate = helper.get_check_point('FromDate-{}'.format(helper.get_input_stanza_names()))\n            \n            if FromDate == None:\n                FromDate = str((datetime.datetime.now()  - datetime.timedelta(days=1)).strftime(\"%Y-%m-%d %H:%M:%S\"))\n                helper.save_check_point('FromDate-{}'.format(helper.get_input_stanza_names()),str(FromDate))\n                next_eventid = None\n            else:\n                next_eventid = None\n        else:\n            FromDate = None\n            next_eventid = eventid\n        \n        \n        params={\n            'MinimumSeverity': opt_min_severity,\n            'PageSize': 10000,\n            'FromDate': FromDate,\n            'FromEventId': next_eventid\n            }\n            \n    elif opt_log_type == \"AuditsIntegration\":\n\n        audit_id = helper.get_check_point('auditTrailID-{}'.format(helper.get_input_stanza_names()))\n        \n        if audit_id == None:\n            \n            FromDate = helper.get_check_point('FromDate-{}'.format(helper.get_input_stanza_names()))\n            \n            if FromDate == None:\n                FromDate = str((datetime.datetime.now()  - datetime.timedelta(days=1)).strftime(\"%Y-%m-%d %H:%M:%S\"))\n                helper.save_check_point('FromDate-{}'.format(helper.get_input_stanza_names()),str(FromDate))\n                next_AuditTrailId = None\n            else:\n                next_AuditTrailId = None\n        else:\n            FromDate = None\n            next_AuditTrailId = audit_id\n            \n        params={\n            'MinimumSeverity': opt_min_severity,\n            'PageSize': 10000,\n            'FromDate': FromDate,\n            'FromAuditTrailId': next_AuditTrailId\n            }\n    else:\n        params={}\n    \n    #api call to /prime/webui/Events/GetEventsIntegration endpoint\n    response = api_call(helper,url,'GET',params,header,payload)\n    \n    # get response status code\n    r_status = response.status_code\n    \n    if r_status != 200:\n        helper.log_info(\"{}: api query responded with {}\".format(opt_log_type,r_status))\n        response.raise_for_status()\n        \n    response_json = response.json()\n    \n    data = response_json['data']\n    \n    return data\n\n\ndef api_call(helper,url,method,params,header,payload):\n    \n    proxy_setup = helper.get_proxy()\n    proxy_setting = proxy_setup is not None\n    \n    isVerify = helper.get_global_setting('is_verify')  # Checkbox setting for SSL verification\n    cert_path = str(helper.get_global_setting('cert_path'))  # Path to custom certificate \n    \n    response = helper.send_http_request(\n        url, \n        method, \n        parameters=params, \n        payload=payload,\n        headers=header, \n        cookies=None, \n        verify=cert_path if isVerify else False,\n        timeout=(10.0, 30.0), \n        use_proxy=proxy_setting\n    )\n    return response\n    \n\ndef ingest_Integrations(helper,ew,r_json,global_host_url,opt_log_type):\n    \n    if len(r_json)>0:\n        \n        results = []\n        \n        if opt_log_type == \"EventsIntegration\":\n            eventid = ''\n            \n            for event in reversed(r_json):\n                \n                key = '{}-{}'.format(r_json[r_json.index(event)][\"eventID\"],helper.get_input_stanza_names())\n                \n                state = helper.get_check_point(key)\n                \n                if state is None:\n                    results.append(event)\n                    helper.save_check_point(key,\"indexed\")\n                    eventid = r_json[r_json.index(event)][\"eventID\"] + 1\n                \n                \"\"\"\n                delete this after testing\n                \"\"\"    \n                #helper.delete_check_point(key)\n            if eventid != '':\n                helper.save_check_point('eventID-{}'.format(helper.get_input_stanza_names()),str(eventid))\n                \"\"\"\n                delete this after testing\n                \"\"\"\n                #helper.delete_check_point('eventID-{}'.format(helper.get_input_stanza_names()))\n        \n        elif opt_log_type == \"AuditsIntegration\":\n            \n            audittrailid = ''\n            \n            for event in reversed(r_json):\n                \n                key = '{}-{}'.format(r_json[r_json.index(event)][\"auditTrailID\"],helper.get_input_stanza_names())\n                \n                state = helper.get_check_point(key)\n                \n                if state is None:\n                    results.append(event)\n                    helper.save_check_point(key,\"indexed\")\n                    audittrailid = r_json[r_json.index(event)][\"auditTrailID\"] + 1\n                    \n                \"\"\"\n                delete this after testing\n                \"\"\"\n                #helper.delete_check_point(key)\n            \n            if audittrailid != '':\n                helper.save_check_point('auditTrailID-{}'.format(helper.get_input_stanza_names()),str(audittrailid))\n                \"\"\"\n                delete this after testing\n                \"\"\"\n                #helper.delete_check_point('auditTrailID-{}'.format(helper.get_input_stanza_names()))\n        \n        if len(results) == 0:\n            helper.log_info(\"No new events\")\n            \n        else:\n            data =json.dumps(results)\n            \n            extract_host = (global_host_url.rsplit('://'))[1].rsplit('.')[0]\n            s_type = \"sepio:system:events\"\n            \n            if opt_log_type == \"AuditsIntegration\":\n                s_type = \"sepio:audit\"\n            \n            #define new events\n            events = helper.new_event(data, time=None, host=extract_host, index=None, source=helper.get_input_type(), sourcetype=s_type, done=True, unbroken=True)\n            \n            #index/ingest data\n            ew.write_event(events)\n            helper.log_info(\"{} new events has been indexed\".format(len(results)))\n    else:\n        helper.log_info(\"No new events found\")\n", "customized_options": [{"name": "sepio_platform", "value": "account0"}, {"name": "log_type", "value": "AuditsIntegration"}, {"name": "min_severity", "value": "Informational"}], "uuid": "92b41ca59bb04f37bec35006d592d5e6", "sample_count": "42450"}]}, "field_extraction_builder": {"sepio:network:events": {"data_format": "json"}, "sepio:general:events": {"data_format": "json"}, "sepio:host:events": {"data_format": "json"}, "sepio:system:events": {"data_format": "json"}, "sepio:General:events": {"data_format": "json"}, "sepio:Host:events": {"data_format": "json"}, "sepio:Network:events": {"data_format": "json"}, "sepio:System:events": {"data_format": "json"}, "sepio:audit": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}, "credential_settings": [], "customized_settings": [{"required": false, "name": "is_verify", "label": "Verify", "default_value": true, "help_string": "", "type": "checkbox", "format_type": "checkbox", "value": true}, {"required": false, "name": "cert_path", "label": "Cert Path", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}]}}, "sourcetype_builder": {"sepio:system:events": {"metadata": {"data_input_name": "sepio_events_input"}}, "sepio:audit": {"metadata": {"event_count": 0, "data_input_name": null, "extractions_count": 0, "cims_count": 0}}}, "validation": {}}