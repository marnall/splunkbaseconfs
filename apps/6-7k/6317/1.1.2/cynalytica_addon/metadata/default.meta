
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

[views]
access = read : [ * ], write : [ admin ]
export = none

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system
