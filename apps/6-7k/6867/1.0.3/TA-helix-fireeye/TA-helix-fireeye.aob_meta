{"basic_builder": {"appname": "TA-helix-fireeye", "friendly_name": "Helix Fireeye", "version": "1.0.3", "author": "Trifork.Security", "description": "App to pull down data from Helix Fireeye, supports multiple regions", "theme": "#708794", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.0", "tab_build_no": "0", "build_no": 6}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "fireeye:helix:alerts", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "fireeye_helix_alerts_ts", "title": "fireeye:helix:alerts", "description": "", "type": "customized", "parameters": [{"name": "instance_id", "label": "Instance ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "region", "label": "Region", "help_string": "", "required": true, "possible_values": [{"value": "apps", "label": "US"}, {"value": "helix.eu", "label": "EU"}, {"label": "APAC", "value": "helix.ap"}], "format_type": "dropdownlist", "default_value": "apps", "placeholder": "", "type": "dropdownlist", "value": "apps"}, {"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "api_limit", "label": "API Limit", "help_string": "", "required": true, "format_type": "text", "default_value": "0", "placeholder": "", "type": "text", "value": "10"}, {"name": "api_timeout", "label": "API Timeout", "help_string": "", "required": true, "format_type": "text", "default_value": "5", "placeholder": "", "type": "text", "value": "5"}], "data_inputs_options": [{"type": "customized_var", "name": "instance_id", "title": "Instance ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "region", "title": "Region", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "apps", "label": "US"}, {"value": "helix.eu", "label": "EU"}, {"label": "APAC", "value": "helix.ap"}], "format_type": "dropdownlist", "default_value": "apps", "placeholder": ""}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_limit", "title": "API Limit", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "0", "placeholder": ""}, {"type": "customized_var", "name": "api_timeout", "title": "API Timeout", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "5", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json \n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # instance_id = definition.parameters.get('instance_id', None)\n    # region = definition.parameters.get('region', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # api_limit = definition.parameters.get('api_limit', None)\n    # api_timeout = definition.parameters.get('api_timeout', None)\n    pass\n\ndef collect_events(helper, ew):\n    # Retrieve runtime variables\n    opt_region = helper.get_arg('region')\n    opt_instanceid = helper.get_arg('instance_id') \n    opt_apikey = helper.get_arg('api_key') \n    opt_limit = helper.get_arg('api_limit')\n    opt_timeout = float(helper.get_arg('api_timeout'))\n\n    # Create checkpoint key\n    opt_checkpoint = \"alerts_\" + opt_region + \"_\" + opt_instanceid\n    #Create last status entry for storage as checkpoint\n    current_status = time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime())\n    \n    #Check for last query execution data in kvstore & generate if not present\n    try:\n        last_status = helper.get_check_point(opt_checkpoint) or time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())\n        helper.log_debug(\"[\" + opt_instanceid + \"] Helix Alerts - Last successful checkpoint time: \" + str(last_status))\n    except Exception as e:\n        helper.log_error(\"[\" + opt_instanceid + \"] Helix Alerts - Unable to retrieve last execution checkpoint!\")\n        raise e\n\n    # use simple rest call to load the events\n    header = {}\n    data = {}\n    parameter = {}\n    parameter['limit'] = opt_limit\n    parameter['sort'] = \"-createDate\"\n    parameter['withCount'] = \"1\"\n    parameter['includes'] = \"revisions._updatedBy\"\n    parameter['query'] = str('{\"updateDate\":{\"$gte\":\"' + last_status + '\"}}')\n    url = \"https://\" + opt_region + \".fireeye.com/helix/id/\" + opt_instanceid + \"/api/v1/alerts\"\n    method = 'GET'\n    header['x-fireeye-api-key'] = opt_apikey\n    helper.log_info(url)\n    try:\n        # Leverage helper function to send http request\n        response = helper.send_http_request(url, method, parameters=parameter, payload=None, headers=header, cookies=None, verify=True, cert=None, timeout=opt_timeout, use_proxy=True)\n        helper.log_info(response.content)\n        # Return API response code\n        r_status = response.status_code\n        # Return API request status_code\n        if r_status is not 200:\n            helper.log_error(\"[\" + opt_instanceid + \"] Alerts API unsuccessful status_code=\" + str(r_status))\n            response.raise_for_status()\n        # Return API request as JSON\n        obj = response.json()\n\n        if obj is None:\n            helper.log_info(\"[\" + opt_instanceid + \"] No new alerts retrieved from Helix.\")\n\n        # Iterate over alerts in array & index\n        i=0\n        for alert in obj.get(\"alerts\"):\n            singleAlert = (obj.get(\"alerts\")[i])\n            singleAlert['helix_instance'] = opt_instanceid\n            singleAlert['helix_region'] = opt_region\n            \n            # Rename underscore fields so Splunk will index values\n            singleAlert['updatedBy'] = singleAlert['_updatedBy']\n            singleAlert['createdBy'] = singleAlert['_createdBy']\n            singleAlert['assignedTo'] = singleAlert['_assignedTo']\n            # Remove underscore fieldnames and values\n            del singleAlert['_updatedBy']\n            del singleAlert['_createdBy']\n            del singleAlert['_assignedTo']\n\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=json.dumps(singleAlert))\n            \n            try:\n                ew.write_event(event)\n                helper.log_debug(\"[\" + opt_instanceid + \"] Added alert:\" + str(singleAlert['id']))\n            except Exception as error:\n                helper.log_error(\"[\" + opt_instanceid + \"] Unable to add alert:\" + str(singleAlert['id']))\n            i = i + 1\n\n        #Update last completed execution time\n        helper.save_check_point(opt_checkpoint, current_status)\n        helper.log_info(\"[\" + opt_instanceid + \"] Alerts collection complete. Records added: \" + str(i))\n        helper.log_debug(\"[\" + opt_instanceid + \"] Helix Alerts - Storing checkpoint time: \" + current_status)\n\n    except Exception as error:\n        helper.log_error(\"[\" + opt_instanceid + \"] Helix Alerts - An unknown error occurred!\")\n        raise error\n", "customized_options": [{"name": "instance_id", "value": ""}, {"name": "region", "value": "apps"}, {"name": "api_limit", "value": "10"}, {"name": "api_timeout", "value": "5"}], "uuid": "db32f519c9d34f919e61e1c010bf604b", "sample_count": 0}, {"index": "default", "sourcetype": "fireeye:helix:incidents", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "fireeye_helix_incidents_ts", "title": "fireeye:helix:incidents", "description": "", "type": "customized", "parameters": [{"name": "instance_id", "label": "Instance ID", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "region", "label": "Region", "help_string": "", "required": true, "possible_values": [{"value": "apps", "label": "US"}, {"value": "helix.eu", "label": "EU"}, {"label": "APAC", "value": "helix.ap"}], "format_type": "dropdownlist", "default_value": "", "placeholder": "", "type": "dropdownlist", "value": ""}, {"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": ""}, {"name": "api_limit", "label": "API Limit", "help_string": "", "required": true, "format_type": "text", "default_value": "0", "placeholder": "", "type": "text", "value": "0"}, {"name": "api_timeout", "label": "API Timeout", "help_string": "", "required": true, "format_type": "text", "default_value": "5", "placeholder": "", "type": "text", "value": "5"}], "data_inputs_options": [{"type": "customized_var", "name": "instance_id", "title": "Instance ID", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "region", "title": "Region", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "apps", "label": "US"}, {"value": "helix.eu", "label": "EU"}, {"label": "APAC", "value": "helix.ap"}], "format_type": "dropdownlist", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_limit", "title": "API Limit", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "0", "placeholder": ""}, {"type": "customized_var", "name": "api_timeout", "title": "API Timeout", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "5", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # api_env = definition.parameters.get('api_env', None)\n    # api_key = definition.parameters.get('api_key', None)\n    # api_limit = definition.parameters.get('api_limit', None)\n    # api_timeout = definition.parameters.get('api_timeout', None)\n    pass\n\ndef collect_events(helper, ew):\n\n    opt_region = helper.get_arg('region')\n    opt_instanceid = helper.get_arg('instance_id')\n    opt_apikey = helper.get_arg('api_key')\n    opt_limit = helper.get_arg('api_limit')\n    opt_timeout = float(helper.get_arg('api_timeout'))\n    \n    # Create checkpoint key\n    opt_checkpoint = \"alerts_\" + opt_region + \"_\" + opt_instanceid\n    #Create last status entry for storage as checkpoint\n    current_status = time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime())\n    \n    #Check for last query execution data in kvstore & generate if not present\n    try:\n        last_status = helper.get_check_point(opt_checkpoint) or time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())\n        helper.log_debug(\"[\" + opt_instanceid + \"] Helix Alerts - Last successful checkpoint time: \" + str(last_status))\n    except Exception as e:\n        helper.log_error(\"[\" + opt_instanceid + \"] Helix Alerts - Unable to retrieve last execution checkpoint!\")\n        raise e\n\n\n    # use simple rest call to load the events\n    header = {}\n    data = {}\n    parameter = {}\n    parameter['limit'] = opt_limit\n    parameter['sort'] = \"-createDate\"\n    parameter['withCount'] = \"1\"\n    parameter['includes'] = \"revisions._updatedBy\"\n    parameter['query'] = str('{\"updateDate\":{\"$gte\":\"' + last_status + '\"}}')\n    url = \"https://\" + opt_region + \".fireeye.com/helix/id/\" + opt_instanceid + \"/api/v1/alerts\"\n    method = 'GET'\n    header['x-fireeye-api-key'] = opt_apikey\n    \n    \n    \n    try:\n        # Leverage helper function to send http request\n        response = helper.send_http_request(url, method, parameters=parameter, payload=None, headers=header, cookies=None, verify=True, cert=None, timeout=opt_timeout, use_proxy=True)\n\n        # Return API response code\n        r_status = response.status_code\n        # Return API request status_code\n        if r_status is not 200:\n            helper.log_error(\"[\" + opt_instanceid + \"] Alerts API unsuccessful status_code=\" + str(r_status))\n            response.raise_for_status()\n        # Return API request as JSON\n        obj = response.json()\n\n        if obj is None:\n            helper.log_info(\"[\" + opt_instanceid + \"] No new alerts retrieved from Helix.\")\n\n        # Iterate over alerts in array & index\n        i=0\n        for alert in obj.get(\"alerts\"):\n            singleAlert = (obj.get(\"alerts\")[i])\n            singleAlert['helix_instance'] = opt_instanceid\n            singleAlert['helix_region'] = opt_region\n            \n            # Rename underscore fields so Splunk will index values\n            singleAlert['updatedBy'] = singleAlert['_updatedBy']\n            singleAlert['createdBy'] = singleAlert['_createdBy']\n            singleAlert['assignedTo'] = singleAlert['_assignedTo']\n            # Remove underscore fieldnames and values\n            del singleAlert['_updatedBy']\n            del singleAlert['_createdBy']\n            del singleAlert['_assignedTo']\n\n            event = helper.new_event(source=helper.get_input_type(), index=helper.get_output_index(), sourcetype=helper.get_sourcetype(), data=json.dumps(singleAlert))\n            \n            try:\n                ew.write_event(event)\n                helper.log_debug(\"[\" + opt_instanceid + \"] Added alert:\" + str(singleAlert['id']))\n            except Exception as error:\n                helper.log_error(\"[\" + opt_instanceid + \"] Unable to add alert:\" + str(singleAlert['id']))\n            i = i + 1\n\n        #Update last completed execution time\n        helper.save_check_point(opt_checkpoint, current_status)\n        helper.log_info(\"[\" + opt_instanceid + \"] Alerts collection complete. Records added: \" + str(i))\n        helper.log_debug(\"[\" + opt_instanceid + \"] Helix Alerts - Storing checkpoint time: \" + current_status)\n\n    except Exception as error:\n        helper.log_error(\"[\" + opt_instanceid + \"] Helix Alerts - An unknown error occurred!\")\n        raise error    \n    \n    \n    ", "customized_options": [{"name": "instance_id", "value": ""}, {"name": "region", "value": ""}, {"name": "api_limit", "value": "0"}, {"name": "api_timeout", "value": "5"}], "uuid": "dd6033392fb0