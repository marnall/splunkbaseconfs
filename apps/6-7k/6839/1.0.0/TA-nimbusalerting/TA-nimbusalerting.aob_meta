{"alert_action_builder": {"modular_alerts": [{"description": "Python script calling nimalarm", "smallIcon": "", "largeIcon": "", "label": "Nimbus alert in Splunk", "short_name": "nimbus_alert_in_splunk", "parameters": [{"format_type": "text", "required": true, "name": "kb_label", "label": "KB label", "default_value": "", "help_string": "Knowledge base ID", "type": "", "value": "KB12345"}, {"format_type": "radio", "required": false, "name": "alarm_name", "label": "Alarm Name", "default_value": "", "help_string": "", "possible_values": {"Threshold exceeded": "threshold", "Error": "error", "Drop in traffic": "drop"}, "type": "", "value": "error"}, {"format_type": "text", "required": false, "name": "bank", "label": "Bank/ Customer", "default_value": "", "help_string": "You can use $var$ fields from search results.", "type": "", "value": "bank"}, {"format_type": "text", "required": false, "name": "nimbus_severity", "label": "Nimbus Severity (integer)", "default_value": "", "help_string": "0 = clear, 1 = minor (also ~clear), 5 = severe (alarm)", "type": "", "value": "3"}, {"format_type": "text", "required": false, "name": "additional_text", "label": "Additional Text", "default_value": "", "help_string": "Appended to previous fields: \"KB12345 Error - Bank_Name - 49 trx code 1 (17% of total).\"", "type": "", "value": "bank"}, {"format_type": "text", "required": true, "name": "subsystem_id", "label": "Subsystem ID", "default_value": "", "help_string": "System logging to Splunk: E.g. app1, app2, wtc.", "type": "", "value": "bank"}], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the alert action parameters and prints them to the log\n    kb_label = helper.get_param(\"kb_label\")\n    helper.log_info(\"kb_label={}\".format(kb_label))\n\n    alarm_name = helper.get_param(\"alarm_name\")\n    helper.log_info(\"alarm_name={}\".format(alarm_name))\n\n    bank = helper.get_param(\"bank\")\n    helper.log_info(\"bank={}\".format(bank))\n\n    nimbus_severity = helper.get_param(\"nimbus_severity\")\n    helper.log_info(\"nimbus_severity={}\".format(nimbus_severity))\n\n    additional_text = helper.get_param(\"additional_text\")\n    helper.log_info(\"additional_text={}\".format(additional_text))\n\n    subsystem_id = helper.get_param(\"subsystem_id\")\n    helper.log_info(\"subsystem_id={}\".format(subsystem_id))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    # Custom code for alert logic\n    import subprocess\n    import os\n    import sys\n\n    kb_label = helper.get_param(\"kb_label\")\n    alert_choice = helper.get_param(\"alarm_name\")\n    if \"threshold\" in alert_choice:\n        alarm_name = kb_label + \" Threshold exceeded\"\n    else:\n        if \"drop\" in alert_choice:\n            alarm_name = kb_label + \" Drop in traffic\"\n        else:\n            alarm_name = kb_label + \" Error\"\n    helper.log_info(\"alarm={}\".format(alarm_name))\n\n    bank = str(\" - \" + helper.get_param(\"bank\"))\n    helper.log_info(\"bank={}\".format(bank))\n\n    custom_text = str(\" - \" + helper.get_param(\"additional_text\"))\n    helper.log_info(\"text={}\".format(custom_text))\n\n    nimbus_severity = helper.get_param(\"nimbus_severity\")\n    helper.log_info(\"severity={}\".format(nimbus_severity))\n\n    subsystem_id = str(helper.get_param(\"subsystem_id\"))\n    helper.log_info(\"log_source={}\".format(subsystem_id))\n\n    nimbus_string = str(' -l ' + nimbus_severity + ' -s \"' + subsystem_id + '\" -S \"ITO Splunk\" \"' + alarm_name + bank + custom_text) + '\"'\n    helper.log_info(\"output={}\".format(nimbus_string))\n\n    # For error testing:\n    #f= open(\"/tmp/nimb_py_test.txt\",\"w+\")\n    #f.write(\"{0} {1} {2} {3} {4}: {5} {6}\\n\".format(alarm_name, bank, custom_text, nimbus_severity, subsystem_id, nimbus_string, sys.path[0]))\n    # Shell script converts severity to integer\n    subprocess.call(['/opt/splunk/etc/apps/TA-nimbusalerting/bin/scripts/nimbus.sh', alarm_name, bank, custom_text, nimbus_severity, subsystem_id])\n    return 0\n", "uuid": "eaf75ce036ea4e4b900e8fe5e8843b49"}]}, "basic_builder": {"appname": "TA-nimbusalerting", "friendly_name": "nimbusalerting", "version": "1.0.0", "author": "Yash Chawla", "description": "", "theme": "#3c6188", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "3.0.1", "tab_build_no": "2", "build_no": 1}, "validation": {}}