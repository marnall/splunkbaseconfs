{"basic_builder": {"appname": "TA-splunk-add-on-for-sepio-systems", "friendly_name": "Splunk Add-on for Sepio Systems", "version": "1.2.1", "author": "", "description": "With this Add-On, Sepio customers can receive Syslog events from HAC-1.\n\nSepio Systems has developed the Hardware Access Control (HAC-1) solution to provide a panacea to the gap in device visibility. The HAC-1 solution uses Layer 1 information to calculate a digital fingerprint of all IT, OT and IoT assets, meaning every device gets identified as what it truly is. Additionally, the comprehensive policy enforcement mechanism of the HAC-1 solution, combined with its Rogue Device Mitigation capability, means that any unapproved or rogue hardware is blocked instantly, preventing any hardware-based attacks from occurring. With the HAC-1 solution in place, not only is the hardware level covered but, in doing so, current cybersecurity investments, such as NAC, EPS, IDS, or IoT Network Security, get put to better use and Zero Trust Hardware Access is achieved.", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.0.0", "tab_build_no": "0", "build_no": 2}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "sepio:hac-1:events", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "SepioEvents", "title": "SepioEventsDisplay", "description": "Splunk input for retriving Sepio HAC-1 events", "type": "customized", "parameters": [{"name": "min_severity", "label": "Min severity", "help_string": "", "required": true, "possible_values": [{"value": "Emergency", "label": "Emergency"}, {"value": "Alert", "label": "Alert"}, {"value": "Critical", "label": "Critical"}, {"label": "Error", "value": "Error"}, {"label": "Warning", "value": "Warning"}, {"label": "Notice", "value": "Notice"}, {"label": "Informational", "value": "Informational"}, {"label": "Debug", "value": "Debug"}], "format_type": "dropdownlist", "default_value": "W