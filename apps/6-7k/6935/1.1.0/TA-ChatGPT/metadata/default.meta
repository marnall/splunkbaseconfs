[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system


[views/readme]
owner = nobody
access = read : [ * ], write : [ admin, sc_admin ]

# Warning; this command should not be exported.
# Access should be heavily restricted.
# Anyone allowed to use this command will be able to (accidentally or otherwise) perform batch deletions on the KVstore

[commands/cleantimekv]
export = none
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]

# The following elements need to be exported for the virustotal command to work outside the VirusTotal TA

[commands/virustotal]
export = system
access = read : [ admin, sc_admin, power ], write : [ admin, sc_admin ]

[ChatGPTKEY]
export = system
access = read : [ admin, sc_admin, power ], write : [ admin, sc_admin ]

[searchbnf/virustotal-command]
export = system
access = read : [ * ], write : [ admin, sc_admin ]

[searchbnf/virustotal-options]
export = system
access = read : [ * ], write : [ admin, sc_admin ]