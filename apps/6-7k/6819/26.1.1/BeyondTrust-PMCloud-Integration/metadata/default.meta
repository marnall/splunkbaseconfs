# Application-level permissions

[]
access = read : [ * ], write : [ admin, power, sc_admin ]

### EVENT TYPES

[eventtypes]
export = system

### PROPS

[props]
export = system

### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system

[views]
access = read : [ * ], write : [ admin ]
export = none

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[props/beyondtrust%3Apmcloud%3Aecs]
owner = admin

[props/beyondtrust%3Apmcloud%3Aaudit]
owner = admin

[props/source%3A%3A...beyondtrust_pmcloud_integration%2A.log%2A]
owner = admin

[props/source%3A%3A...beyondtrust-pmcloud-integration%2A.log%2A]
owner = admin




