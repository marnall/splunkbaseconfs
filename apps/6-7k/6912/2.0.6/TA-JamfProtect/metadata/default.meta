
# Application-level permissions

[]
access = read : [ * ], write : [ admin, sc_admin, power ]

### EVENT TYPES

[eventtypes]
export = system

[tags]
export = system

### PROPS

[props]
export = system

### MACROS

[macros]
export = system

### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system

### WORKFLOW_ACTIONS

[workflow_actions]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system