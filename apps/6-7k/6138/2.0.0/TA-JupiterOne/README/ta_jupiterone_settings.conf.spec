[proxy]
proxy_enabled = Should the proxy enabled or not
proxy_type = type of the proxy i.e. http, https, sock4 or sock5
proxy_url = Proxy url
proxy_port = Proxy port
proxy_username = Username for the proxy server
proxy_password = Password for the proxy server user

[logging]
loglevel = Log level of the data collection logs

[threads]
no_of_threads = Specify the no. of threads to collect alert related entities