{"basic_builder": {"appname": "TA-banyan-events", "friendly_name": "Banyan Events", "version": "0.0.7", "author": "Carlos Martinez", "description": "Banyan\u2019s integration provides the system log events, shown in the System Log in the console. \n\nFor more info:\nhttps://docs.banyansecurity.io/docs/manage-admins/admin-system-log/", "theme": "#ffffff", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.3", "tab_build_no": "0", "build_no": 10}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "banyaneventstest", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "name": "banyan_events", "title": "Banyan Events", "description": "Collect from Banyan console", "type": "rest", "parameters": [{"name": "banyan_url", "label": "Banyan URL", "help_string": "", "required": true, "format_type": "text", "default_value": "https://net.banyanops.com", "placeholder": "https://net.banyanops.com", "type": "text", "value": "https://net.banyanops.com"}, {"name": "api_key", "label": "API Key", "help_string": "Banyan API Key", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "ikRhBZcSfmvUXnqS1GknHZnJEUvs-tD2BWQcqWr7b7w"}], "data_inputs_options": [{"name": "_rest_api_url", "rest_header": false, "description": "url", "value": "${banyan_url}/api/v1/events?limit=1000&after=${last_created_at}&order=DESC"}, {"name": "_rest_api_method", "rest_header": false, "description": "method", "value": "GET"}, {"name": "Authorization", "value": "Bearer ${api_key}", "rest_header": true, "description": "Authorization"}, {"type": "event_json_path_key", "name": "_event_json_path_key", "value": "$.data[*]"}, {"type": "ckpt_enable", "name": "_ckpt_enable", "value": true}, {"type": "ckpt_var_name", "name": "_ckpt_var_name", "value": "last_created_at"}, {"type": "ckpt_json_path_key", "name": "_ckpt_json_path_key", "value": "$.data[0].created_at"}, {"type": "ckpt_initial_value", "name": "_ckpt_initial_value", "value": "0"}, {"type": "ckpt_source_time_format", "name": "_ckpt_source_time_format", "value": ""}, {"type": "ckpt_target_time_format", "name": "_ckpt_target_time_format", "value": ""}, {"type": "customized_var", "name": "banyan_url", "title": "Banyan URL", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "https://net.banyanops.com", "placeholder": "https://net.banyanops.com"}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "Banyan API Key", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "use_basic_auth": false, "customized_options": [{"name": "banyan_url", "value": "https://net.banyanops.com"}, {"name": "api_key", "value": "ikRhBZcSfmvUXnqS1GknHZnJEUvs-tD2BWQcqWr7b7w"}], "uuid": "57609bb2a2dc425b9fe5821ce33e221f", "sample_count": "1600"}]}, "field_extraction_builder": {"banyaneventstest": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}}}, "sourcetype_builder": {"banyaneventstest": {"metadata": {"event_count": 0, "data_input_name": "banyan_events", "extractions_count": 0, "cims_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1691468216_41"}}