ular input variable\n    # hostname_ip_address = definition.parameters.get('hostname_ip_address', None)\n    # port = definition.parameters.get('port', None)\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # component_type = definition.parameters.get('component_type', None)\n    pass\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    # opt_username = helper.get_arg('username')\n    # opt_password = helper.get_arg('password')\n    opt_component_type = helper.get_arg('component_type')\n    # --------------------------------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    # --------------------------------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/orchestration/showcomponents\"\n    method = \"POST\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    header1 = {\n        \"managerurl\":managerurl,\n        \"user\":username,\n        \"pwd\":password_base64\n        }\n    body1 = {\n        \"componenttype\":opt_component_type\n        }\n    # --------------------------------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, method, parameters=None, payload=body1,\n                                            headers=header1, cookies=None, verify=False, cert=None,\n                                            timeout=None, use_proxy=False)\n        r_status = response.status_code\n        if (r_status != 200):\n            response.raise_for_status()\n        else:\n            r_json = response.json()\n            output = json.dumps(r_json)\n            event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=output)\n            ew.write_event(event)\n    except Exception as e:\n        message1 = \"Exception= \" + \"\\\"\" + str(e) + \"\\\"\"\n        helper.log_debug(message1)\n", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "component_type", "value": "Oracle Database"}], "uuid": "f99d3835cd9f474791517ec58d00fba9", "sample_count": 0}, {"index": "default", "sourcetype": "api:analytics:getAlerts", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "getalerts", "title": "getAlerts", "description": "By default, using the eG REST API, administrators can retrieve the count of current alarms raised in the eG manager as well as the detailed current alarms raised in the eG manager.", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "eG manager FQDN / IP, xxx.xxx.xxx.xxx", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "", "type": "text", "value": "7077"}, {"name": "type", "label": "Type", "help_string": "<zone/segment/service/componentType>", "required": true, "format_type": "text", "default_value": "componentType", "placeholder": "", "type": "text", "value": "componentType"}, {"name": "name_", "label": "Name_", "help_string": "<comma-separated list of zone/segment/service/componentType>", "required": true, "format_type": "text", "default_value": "Oracle Database", "placeholder": "", "type": "text", "value": "Oracle Database"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "eG manager FQDN / IP, xxx.xxx.xxx.xxx", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}, {"type": "customized_var", "name": "type", "title": "Type", "description": "<zone/segment/service/componentType>", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "componentType", "placeholder": ""}, {"type": "customized_var", "name": "name_", "title": "Name_", "description": "<comma-separated list of zone/segment/service/componentType>", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "Oracle Database", "placeholder": ""}], "code": "# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\n\ndef validate_input(helper, definition):\n    pass\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    opt_type = helper.get_arg('type')\n    opt_name_ = helper.get_arg('name_')\n    # --------------------------------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    # --------------------------------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getAlerts\"\n    method = \"POST\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    header1 = {\n        \"managerurl\":managerurl,\n        \"user\":username,\n        \"pwd\":password_base64\n        }\n    body1 = {\n        \"type\":opt_type,\n        \"name\":opt_name_\n        }\n    # --------------------------------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, method, parameters=None, payload=body1,\n                                            headers=header1, cookies=None, verify=False, cert=None,\n                                            timeout=None, use_proxy=False)\n        r_status = response.status_code\n        if r_status != 200:\n            response.raise_for_status()\n        else:\n            r_json = response.json()\n            data = r_json['data']\n            for item in data:\n                item_str = json.dumps(item)\n                event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=item_str)\n                ew.write_event(event)\n    except Exception as e:\n        message1 = \"Exception= \" + \"\\\"\" + str(e) + \"\\\"\"\n        helper.log_debug(message1)\n    ", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "type", "value": "componentType"}, {"name": "name_", "value": "Oracle Database"}], "uuid": "93bf2bbbc24c4118bd2a8e5d7b36276c", "sample_count": 0}, {"index": "default", "sourcetype": "eg:input:1", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "input_1", "title": "Input_1", "description": "Get Test Name for Component Type (API)\nIterate through Test Name\nRetrieve Test Data", "type": "customized", "parameters": [{"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "", "type": "text", "value": "7077"}, {"name": "username", "label": "Username", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "splunk"}, {"name": "password", "label": "Password", "help_string": "Base64 encoded password", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "U3AxOG5rIzAw"}, {"name": "component_type", "label": "Component Type", "help_string": "Technology monitored by eG, e.g. Oracle Database", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Oracle Database"}, {"name": "component_name_and_test_port", "label": "Component Name and Test Port", "help_string": "Hostname of the server monitored by eG and its corresponding test port separated comma, e.g. <hostname1>:<testPort1>, <hostname2>:<testPort2>", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "CCSDBMYP01:1522,CCSDBMYP01:1522,CCSDBSGP01:1522,CCSDBSGP01:1522,CCSDBTHP01:1522,CCSDBTHP01:1522,F1PRODDB:1521,F1PRODDB:1521,GFMSDBPROD01:1521,MXiTHDB1:1523,MYBTRADEUPRDDB01:1521,MYUCBP1VEWDBS01:1522,MYUCBPFALCDBS01:1521,MYUCBPNEOSDBS01:1521,myucbpneosdbs02:1521,MYUCBPPAYNDBS01:1522,MYUCBPPAYNDBS02:1522,MYUCBPRCRSDBS01:1521,MYUCBPRTBSDBS01:1526,MYUCBPRTBSDBS03:1521,MYUCBPRWSADBS01:1526,MYUCBPRWSADBS01:1528,MYUCBRFALCDBS01:1521,MYUCBRRTBSDBS01:1526,MYUCBRRTBSDBS01:1526,MYUWBPMURXDBS01:1523,MYUWBPMURXDBS02:1523,RTBINTDBTH01:1521,RTBINTDBTH01:1522,sgdseuprddb01:1522,sgdseuprddb01:1522"}, {"name": "category", "label": "Category", "help_string": "", "required": false, "format_type": "text", "default_value": "Enabled", "placeholder": "Enabled/Disabled/All", "type": "text", "value": "Enabled"}, {"name": "test_type", "label": "Test Type", "help_string": "", "required": false, "format_type": "text", "default_value": "Performance", "placeholder": "Performance/Configuration", "type": "text", "value": "Performance"}, {"name": "checkpoint_initial_value", "label": "Checkpoint Initial Value", "help_string": "checkpoint for metric / test data, %Y-%m-%d %H:%M:%S", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "2022-12-08 15:30:00"}], "data_inputs_options": [{"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}, {"type": "customized_var", "name": "username", "title": "Username", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "password", "title": "Password", "description": "Base64 encoded password", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "component_type", "title": "Component Type", "description": "Technology monitored by eG, e.g. Oracle Database", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "component_name_and_test_port", "title": "Component Name and Test Port", "description": "Hostname of the server monitored by eG and its corresponding test port separated comma, e.g. <hostname1>:<testPort1>, <hostname2>:<testPort2>", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "category", "title": "Category", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Enabled", "placeholder": "Enabled/Disabled/All"}, {"type": "customized_var", "name": "test_type", "title": "Test Type", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Performance", "placeholder": "Performance/Configuration"}, {"type": "customized_var", "name": "checkpoint_initial_value", "title": "Checkpoint Initial Value", "description": "checkpoint for metric / test data, %Y-%m-%d %H:%M:%S", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # text = definition.parameters.get('text', None)\n    pass\n\ndef collect_events(helper, ew):\n\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_component_type = helper.get_arg('component_type')\n    opt_component_name_and_test_port = helper.get_arg('component_name_and_test_port')\n    opt_category = helper.get_arg('category')\n    opt_test_type = helper.get_arg('test_type')\n    opt_checkpoint_initial_value = helper.get_arg('checkpoint_initial_value')\n    \n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    stanza_name = helper.get_input_stanza_names()\n    input_type = helper.get_input_type()\n\n    # Get a list of tests for specified component type\n    url1 = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/orchestration/showtests\"\n    method1 = \"POST\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    header1 = {\n        \"managerurl\":managerurl,\n        \"user\":opt_username,\n        \"pwd\":opt_password\n        }\n    body1 = {\n        \"componenttype\":opt_component_type,\n        \"category\":opt_category,\n        \"testtype\":opt_test_type\n        }\n    url2 = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getTestData\"\n    # ---------------------------------------------------------------------------------\n    # FIRST API CALL for All TEST NAME \n    response1 = helper.send_http_request(url1, method1, parameters=None, payload=body1,\n                                        headers=header1, cookies=None, verify=False, cert=None,\n                                        timeout=None, use_proxy=False)\n\n    r_json1 = response1.json()\n    if \"enabledTests\" in r_json1.keys():\n        enabledTests = r_json1['enabledTests']\n    if \"disabledTests\" in r_json1.keys():\n        disabledTests = r_json1['disabledTests']\n    \n    r_status1 = response1.status_code\n    if r_status1 != 200:\n        response1.raise_for_status()\n    \n    # ---------------------------------------------------------------------------------\n    \n    cName_list = opt_component_name_and_test_port.split(\",\")\n    # remove duplicates\n    cName_list = list( dict.fromkeys(cName_list) )\n    cName_port_list = [None] * len(cName_list)\n    for i in range(0,len(cName_list),1):\n        # event = helper.new_event(source=source1, index=index1, sourcetype=sourcetype1, data=str(cName_list[i]))\n        # ew.write_event(event)\n        cName_port_list[i] = cName_list[i].split(\":\")\n    \n    # ---------------------------------------------------------------------------------\n    # CHECKPOINTING\n    key = \"startDate\"\n    endDate = datetime.datetime.now()\n    endDate_str = endDate.strftime(\"%Y-%m-%d %H:%M:%S\")\n    # # Retrieve datetime checkpoint\n    state = helper.get_check_point(key)\n    if state is None:\n        state = opt_checkpoint_initial_value\n    # # Update the checkpoint\n    helper.save_check_point(key,endDate_str)\n    # helper.delete_check_point(key)\n    \n    # ---------------------------------------------------------------------------------\n\n    # try:\n    for test in enabledTests:\n        for cName_port in cName_port_list:\n            try:\n                body2 = {\n                        \"test\":test,\n                        \"host\":cName_port[0],\n                        \"port\":cName_port[1],\n                        \"lastmeasure\":\"false\",\n                        \"startDate\":state,\n                        \"endDate\":endDate_str\n                        }\n                response = helper.send_http_request(url2, method1, parameters=None, payload=body2,\n                                                    headers=header1, cookies=None, verify=False, cert=None,\n                                                    timeout=None, use_proxy=False)\n                r_json = response.json()\n                if len(r_json) > 1:\n                    fields = r_json[0]\n                    fields_list = fields.split()\n    \n                    data_raw = r_json[1:]\n\n                    \n                    for row in data_raw:\n                        if row != None:\n                            try:\n                                match = re.search(r\"^(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2}\\s\\d{2}:\\d{2}:\\d{2})\\s+(.+)\",row)\n                                # event = helper.new_event(source=source1, index=index1, sourcetype=sourcetype1, data=match.group(7))\n                                # ew.write_event(event)\n                                output = \"\"\n                                test_data = match.group(7).split()\n                                for i in range(0,6,1):\n                                    output += fields_list[i] + \"=\" + match.group(i+1) + \",\" \n                                for i in range(6,len(fields_list),1):\n                                    if (i == len(fields_list)-1):\n                                        output += fields_list[i] + \"=\" + test_data[i-6] + \",test=\\\"\" + test + \"\\\"\"\n                                    else:\n                                        output += fields_list[i] + \"=\" + test_data[i-6] + \",\"\n                                event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=output)\n                                ew.write_event(event)\n                            except Exception as e:\n                                message1 = \"Exception=\" + \"\\\"\" + str(e) + \"\\\"\" + \",inputName=\" + \"\\\"\" + stanza_name + \"\\\"\" + \",inputType=\" + \"\\\"\" + input_type + \"\\\"\" + \",test=\" + str(test) + \",componentName=\" + \"\\\"\" + str(cName_port) + \"\\\"\" + \",length of json=\" + str(len(r_json)) + \",json=\" + json.dumps(r_json) + \",fields=\" + str(fields) + \",allData=\" + str(data_raw) + \",dataInThePipeline=\" + str(row)\n                                helper.log_info(message1)\n                                message2 = \"ExceptionInfo=\" + str(sys.exc_info())\n                                helper.log_info(message2)\n                                message3 = \"Traceback=\" + str(traceback.format_exc())\n                                helper.log_info(message3)\n                                pass\n                        else:\n                            pass\n                    \n                else:\n                    fields = None\n                    pass\n        \n            except Exception as e:\n                message1 = \"Exception=\" + \"\\\"\" + str(e) + \"\\\"\" + \",inputName=\" + \"\\\"\" + stanza_name + \"\\\"\" + \",inputType=\" + \"\\\"\" + input_type + \"\\\"\" + \",test=\" + str(test) + \",componentName=\" + \"\\\"\" + str(cName_port) + \"\\\"\" + \",HTTPResponse=\" + \"\\\"\" + str(r_json) + \"\\\"\" \n                helper.log_info(message1)\n                message2 = \"ExceptionInfo=\" + str(sys.exc_info())\n                helper.log_info(message2)\n                message3 = \"Traceback=\" + str(traceback.format_exc())\n                helper.log_info(message3)\n                pass\n                # event = helper.new_event(source=source1, index=index1, sourcetype=sourcetype1, data=json.dumps(response.json()))\n                # ew.write_event(event)\n    # except Exception as e:\n    #     message1 = \"Exception=\" + \"\\\"\" + str(e) + \"\\\"\" + \",inputName=\" + \"\\\"\" + stanza_name + \"\\\"\" + \",inputType=\" + \"\\\"\" + input_type + \"\\\"\"\n    #     helper.log_info(message1)\n    #     message2 = \"ExceptionInfo=\" + str(sys.exc_info())\n    #     helper.log_info(message2)\n    #     message3 = \"Traceback=\" + str(traceback.format_exc())\n    #     helper.log_info(message3)\n        # event = helper.new_event(source=source1, index=index1, sourcetype=sourcetype1, data=message1)\n        # ew.write_event(event)\n        # event = helper.new_event(source=source1, index=index1, sourcetype=sourcetype1, data=message2)\n        # ew.write_event(event)\n        pass\n\n", "customized_options": [{"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "username", "value": "splunk"}, {"name": "password", "value": "U3AxOG5rIzAw"}, {"name": "component_type", "value": "Oracle Database"}, {"name": "component_name_and_test_port", "value": "CCSDBMYP01:1522,CCSDBMYP01:1522,CCSDBSGP01:1522,CCSDBSGP01:1522,CCSDBTHP01:1522,CCSDBTHP01:1522,F1PRODDB:1521,F1PRODDB:1521,GFMSDBPROD01:1521,MXiTHDB1:1523,MYBTRADEUPRDDB01:1521,MYUCBP1VEWDBS01:1522,MYUCBPFALCDBS01:1521,MYUCBPNEOSDBS01:1521,myucbpneosdbs02:1521,MYUCBPPAYNDBS01:1522,MYUCBPPAYNDBS02:1522,MYUCBPRCRSDBS01:1521,MYUCBPRTBSDBS01:1526,MYUCBPRTBSDBS03:1521,MYUCBPRWSADBS01:1526,MYUCBPRWSADBS01:1528,MYUCBRFALCDBS01:1521,MYUCBRRTBSDBS01:1526,MYUCBRRTBSDBS01:1526,MYUWBPMURXDBS01:1523,MYUWBPMURXDBS02:1523,RTBINTDBTH01:1521,RTBINTDBTH01:1522,sgdseuprddb01:1522,sgdseuprddb01:1522"}, {"name": "category", "value": "Enabled"}, {"name": "test_type", "value": "Performance"}, {"name": "checkpoint_initial_value", "value": "2022-12-08 15:30:00"}], "uuid": "754a4441dcd146d285694573feb0dfc2", "sample_count": 0}, {"index": "default", "sourcetype": "eg:input:3", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "input_3", "title": "Input_3", "description": "", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "7077", "type": "text", "value": "7077"}, {"name": "component_type", "label": "Component Type", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Oracle Database"}, {"name": "component_name_and_test_port", "label": "Component Name and Test Port", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "GFMSDBPROD01:1521"}, {"name": "category", "label": "Category", "help_string": "", "required": false, "format_type": "text", "default_value": "Enabled", "placeholder": "", "type": "text", "value": "Enabled"}, {"name": "test_type", "label": "Test Type", "help_string": "", "required": false, "format_type": "text", "default_value": "Performance", "placeholder": "", "type": "text", "value": "Performance"}, {"name": "checkpoint_initial_value", "label": "Checkpoint Initial Value", "help_string": "", "required": true, "format_type": "text", "default_value": "2022-12-20 10:30:00", "placeholder": "", "type": "text", "value": "2023-02-24 09:00:00"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": "7077"}, {"type": "customized_var", "name": "component_type", "title": "Component Type", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "component_name_and_test_port", "title": "Component Name and Test Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "category", "title": "Category", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Enabled", "placeholder": ""}, {"type": "customized_var", "name": "test_type", "title": "Test Type", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Performance", "placeholder": ""}, {"type": "customized_var", "name": "checkpoint_initial_value", "title": "Checkpoint Initial Value", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "2022-12-20 10:30:00", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # text = definition.parameters.get('text', None)\n    pass\n\ndef parseHostnamePort(nameList_string):\n    \"\"\" Function to parse the string of hostname and port to list \n    Parameters\n    ----------\n    nameList_string : str\n        A string of hostname and port separated by comma. \"<hostname1>:<port1>,<hostname2>:<port2>,...\"\n    Returns\n    -------\n    cName_port_list : list\n        A list of list where hostname and port are stored.\n        [\n            [hostname1, port1],\n            [hostname2, port2], ...\n        ]\n    \"\"\"\n    assert nameList_string is not None, 'Hostname and Port is not provided.'\n    cName_list = nameList_string.split(\",\")\n    cName_list = list(dict.fromkeys(cName_list))  # remove duplicate name\n    cName_port_list = [None] * len(cName_list)\n    for i in range(0, len(cName_list), 1):\n        cName_port_list[i] = cName_list[i].split(\":\")\n    return cName_port_list\n\n\ndef httpReq(helper, URL, Method, Body, Header):\n    \"\"\" Function for HTTP Request\n    Parameters\n    ----------\n    helper : Splunk Add-on Builder helper function\n    URL : str\n    Method : str\n    Body : dict\n    Header : dict\n    Returns\n    -------\n    HTTP Response Object\n    \"\"\"\n    return helper.send_http_request(URL, Method, parameters=None, payload=Body, headers=Header, cookies=None, verify=False, cert=None, timeout=None, use_proxy=False)\n\n\ndef checkpoint(helper, initialValue):\n    \"\"\" Function for creating Checkpoint using the start and end datetime %Y-%m-%d %H:%M:%S\n    Parameters\n    ----------\n    helper : Splunk Add-on Builder helper function\n    initialValue : str\n        The initial value for the checkpoint on the first run with empty checkpoint. Uses format \"%Y-%m-%d %H:%M:%S\"\n    Returns\n    -------\n    state : str\n        The start time or the previous checkpoint stored.\n    endDate_str : str\n        The end time or the new checkpoint updated. \n    \"\"\"\n    # CHECKPOINTING\n    key = \"startDate\"\n    endDate = datetime.datetime.now()\n    endDate_str = endDate.strftime(\"%Y-%m-%d %H:%M:%S\")\n    # # Retrieve datetime checkpoint\n    state = helper.get_check_point(key)\n    if state is None:\n        state = initialValue\n    # # Update the checkpoint\n    helper.save_check_point(key, endDate_str)\n    # helper.delete_check_point(key)\n    return state, endDate_str\n\n\ndef isHeader(data):\n    \"\"\" Function to check the first 4 characters of the data and determine the type of data (header or metrics)\n    Parameters\n    ----------\n    data : str\n        The data obtained from the REST API. Analyse for header or metrics data.\n    Returns\n    -------\n    bool\n        True - data is a header, False - data is metrics data. \n    \"\"\"\n    pattern = \"^(TRGT_HOST)\"\n    return bool(re.match(pattern, data))\n\n\ndef isData(hostname, data):\n    \"\"\" Function to verify the data for valid format with hostname.\n    Parameters\n    ----------\n    hostname : str\n        The component name / hostname for the eG test.\n    data : str\n        The data from the test. \n    Returns\n    -------\n    bool\n        True - data is a valid format, False - data is not valid.\n    \"\"\"\n    pattern = \"^(\" + hostname + \")\"\n    return bool(re.match(pattern, data))\n\n\ndef parseHeaDat(data):\n    \"\"\" Function to parse the data and return the header and metrics data. \n    Parameters\n    ----------\n    data : str\n        The data obtained from the REST API.\n    Returns\n    -------\n    hea : list\n        The header of the data which is the attribute name or field name. \n    dat : list\n        The body of the data which holds the corresponding value for the header.  \n    \"\"\"\n    assert data is not None, \"There is no data to parse. \"\n    hea = dat = []\n    if isHeader(data):\n        hea = data.split()\n    else:\n        match = re.search(\n            r\"^(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2}\\s\\d{2}:\\d{2}:\\d{2})\\s+(.+)\", data)\n        dat = []\n        for i in range(1, 7, 1):\n            dat.append(match.group(i))\n        temp = match.group(7).split()\n        dat = dat + temp\n    return hea, dat\n\n\ndef splkData_format(fields, values):\n    \"\"\" Function to format the data into string with the fields and values pair separated by comma. \"<field1>=<value1>,<field2>=<value2>,....\"\n    Parameters\n    ----------\n    fields : list\n        The attribute names / field names.\n    values : list\n        The value of the attribute / field.\n    Returns\n    -------\n    splkData : str\n        string data in format of \"<field1>=<value1>,<field2>=<value2>,....\"\n    \"\"\"\n    assert len(fields) == len(values), \"Fields and Values mismatched.\"\n    splkData = \"\"\n\n    for i in range(0, len(fields) - 1, 1):\n        splkData += fields[i] + \"=\\\"\" + values[i] + \"\\\",\"\n\n    splkData += fields[len(fields) - 1] + \\\n        \"=\\\"\" + values[len(fields) - 1] + \"\\\"\"\n\n    return splkData\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    # opt_username = helper.get_arg('username')\n    # opt_password = helper.get_arg('password')\n    opt_component_type = helper.get_arg('component_type')\n    opt_component_name_and_test_port = helper.get_arg('component_name_and_test_port')\n    opt_category = helper.get_arg('category')\n    opt_test_type = helper.get_arg('test_type')\n    opt_checkpoint_initial_value = helper.get_arg('checkpoint_initial_value')\n    # ---------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    stanza_name = helper.get_input_stanza_names()\n    input_type = helper.get_input_type()\n    # ---------------------------------------------------------------------------------\n    method1 = \"POST\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    header1 = {\n        \"managerurl\": managerurl,\n        \"user\": username,\n        \"pwd\": password_base64\n    }\n    # ---------------------------------------------------------------------------------\n    # showtests endpoint\n    url1 = \"https://\" + opt_hostname_ip_address + \":\" + \\\n        opt_port + \"/api/eg/orchestration/showtests\"\n    body1 = {\n        \"componenttype\": opt_component_type,\n        \"category\": opt_category,\n        \"testtype\": opt_test_type\n    }\n    # ---------------------------------------------------------------------------------\n    # getTestData endpoint\n    url2 = \"https://\" + opt_hostname_ip_address + \\\n        \":\" + opt_port + \"/api/eg/analytics/getTestData\"\n    # ---------------------------------------------------------------------------------\n    # Query for All the Test Names\n    try:\n        response1 = httpReq(helper, url1, method1, body1, header1)\n        r_status1 = response1.status_code\n        if r_status1 == 200:\n            r_json1 = response1.json()\n            if \"enabledTests\" in r_json1.keys():\n                enabledTests = r_json1['enabledTests']\n            if \"disabledTests\" in r_json1.keys():\n                disabledTests = r_json1['disabledTests']\n        else:\n            response1.raise_for_status()\n    except Exception as e:\n        message1 = \"Exception: \" + str(e)\n        helper.log_debug(message1)\n    # ---------------------------------------------------------------------------------\n    # Parse the Hostname and Port provided into List\n    cName_port_list = parseHostnamePort(opt_component_name_and_test_port)\n    # ---------------------------------------------------------------------------------\n    # Checkpoint to avoid querying duplicate data\n    state, endDate_str = checkpoint(helper, opt_checkpoint_initial_value)\n    # ---------------------------------------------------------------------------------\n    if len(enabledTests) > 0:\n        for test in enabledTests:\n            for cName_port in cName_port_list:\n                try:\n                    body2 = {\n                        \"test\": test,\n                        \"host\": cName_port[0],\n                        \"port\": cName_port[1],\n                        \"lastmeasure\": \"false\",\n                        \"startDate\": state,\n                        \"endDate\": endDate_str\n                    }\n    # ---------------------------------------------------------------------------------\n                    # HTTP Request to retrieve the test data\n                    response2 = httpReq(helper, url2, method1, body2, header1)\n                    r_status2 = response2.status_code\n                    # Skip if bad response\n                    if r_status2 != 200:\n                        response2.raise_for_status()\n                        continue\n                    # Extract the json data\n                    r_json2 = response2.json()\n                    # event = helper.new_event(\n                    #             source=source1, index=index1, sourcetype=sourcetype1, data=json.dumps(r_json2, indent=4))\n                    # ew.write_event(event)\n                    # Skip if no data\n                    if len(r_json2) < 2:\n                        continue\n                    # Parse the json data to header and data in list\n                    curFields = []\n                    curValues = []\n                    for row in r_json2:\n                        fields, values = parseHeaDat(row)\n                        if len(fields) > 1:\n                            curFields = fields\n                        if len(values) > 1:\n                            curValues = values\n                        # Format the extracted header and data to fields and values\n                        # event1 = helper.new_event(\n                        #         source=source1, index=index1, sourcetype=sourcetype1, data=json.dumps(curFields, indent=4))\n                        # ew.write_event(event1)\n                        # event2 = helper.new_event(\n                        #         source=source1, index=index1, sourcetype=sourcetype1, data=json.dumps(curValues, indent=4))\n                        # ew.write_event(event2)\n                        if len(curFields) == len(curValues):\n                            output2Splk = splkData_format(curFields, curValues)\n                            output2Splk += \",test=\\\"\" + test + \"\\\"\"\n                            # Write the event to Splunk\n                            event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=output2Splk)\n                            ew.write_event(event)\n                        else:\n                            continue\n    # ---------------------------------------------------------------------------------\n                except Exception as e:\n                    message1 = \"Exception=\" + str(e)\n                    message2 = \"ExceptionInfo=\" + str(sys.exc_info())\n                    message3 = \"Traceback=\" + str(traceback.format_exc())\n                    helper.log_debug(message1)\n                    helper.log_debug(message2)\n                    helper.log_debug(message3)\n\n    else:\n        message = \"There is no test enabled for \" + stanza_name\n        helper.log_debug(message)\n\n", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "component_type", "value": "Oracle Database"}, {"name": "component_name_and_test_port", "value": "GFMSDBPROD01:1521"}, {"name": "category", "value": "Enabled"}, {"name": "test_type", "value": "Performance"}, {"name": "checkpoint_initial_value", "value": "2023-02-24 09:00:00"}], "uuid": "af6feaa8d1714e3a872fb0c23197a24d", "sample_count": 0}, {"index": "default", "sourcetype": "eg:orchestration:showtests", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "showtests", "title": "showtests", "description": "Administrators can use this API to obtain all the performance/configuration tests pertaining to a chosen Component Type.", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "eG manager FQDN / IP, xxx.xxx.xxx.xxx", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "", "type": "text", "value": "7077"}, {"name": "component_type", "label": "Component Type", "help_string": "", "required": true, "format_type": "text", "default_value": "Oracle Database", "placeholder": "", "type": "text", "value": "Oracle Database"}, {"name": "category", "label": "Category", "help_string": "", "required": false, "format_type": "text", "default_value": "Enabled", "placeholder": "Enabled/Disabled/All", "type": "text", "value": "Enabled"}, {"name": "test_type", "label": "Test Type", "help_string": "", "required": false, "format_type": "text", "default_value": "Performance", "placeholder": "Performance/Configuration", "type": "text", "value": "Performance"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "eG manager FQDN / IP, xxx.xxx.xxx.xxx", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}, {"type": "customized_var", "name": "component_type", "title": "Component Type", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "Oracle Database", "placeholder": ""}, {"type": "customized_var", "name": "category", "title": "Category", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Enabled", "placeholder": "Enabled/Disabled/All"}, {"type": "customized_var", "name": "test_type", "title": "Test Type", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "Performance", "placeholder": "Performance/Configuration"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # hostname_ip_address = definition.parameters.get('hostname_ip_address', None)\n    # port = definition.parameters.get('port', None)\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # component_type = definition.parameters.get('component_type', None)\n    # category = definition.parameters.get('category', None)\n    # test_type = definition.parameters.get('test_type', None)\n    pass\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    # opt_username = helper.get_arg('username')\n    # opt_password = helper.get_arg('password')\n    opt_component_type = helper.get_arg('component_type')\n    opt_category = helper.get_arg('category')\n    opt_test_type = helper.get_arg('test_type')\n    # --------------------------------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    # --------------------------------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/orchestration/showtests\"\n    method = \"POST\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    header1 = {\n        \"managerurl\":managerurl,\n        \"user\":username,\n        \"pwd\":password_base64\n        }\n    body1 = {\n        \"componenttype\":opt_component_type,\n        \"category\":opt_category,\n        \"testtype\":opt_test_type\n        }\n    # --------------------------------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, method, parameters=None, payload=body1,\n                                            headers=header1, cookies=None, verify=False, cert=None,\n                                            timeout=None, use_proxy=False)\n        r_status = response.status_code\n        if r_status != 200:\n            response.raise_for_status()\n        else:\n            r_json = response.json()\n            output = json.dumps(r_json)\n            event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=output)\n            ew.write_event(event)\n    except Exception as e:\n        message1 = \"Exception= \" + \"\\\"\" + str(e) + \"\\\"\"\n        helper.log_debug(message1)\n", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "component_type", "value": "Oracle Database"}, {"name": "category", "value": "Enabled"}, {"name": "test_type", "value": "Performance"}], "uuid": "c5a392f6239640e1a295fd2f3a1daf6b", "sample_count": 0}, {"index": "default", "sourcetype": "eg:input:2", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "input_2", "title": "Input 2", "description": "User defined component name, test port, and test name. Iterate through the items (component name and test name) and query for test data.", "type": "customized", "parameters": [{"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "eG manager", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "eG manager REST API port", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "", "type": "text", "value": "7077"}, {"name": "username", "label": "Username", "help_string": "eG manager username", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "splunk"}, {"name": "password", "label": "Password", "help_string": "Base64 encoded password", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "U3AxOG5rIzAw"}, {"name": "component_name_list", "label": "Component Name List", "help_string": "Host / Component Name with its Test Port, Comma separated, e.g. host1:port1, host3:port3, host4:port4", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "CCSDBMYP01:1522,CCSDBMYP01:1522,CCSDBSGP01:1522,CCSDBSGP01:1522,CCSDBTHP01:1522,CCSDBTHP01:1522,F1PRODDB:1521,F1PRODDB:1521,GFMSDBPROD01:1521,MXiTHDB1:1523,MYBTRADEUPRDDB01:1521,MYUCBP1VEWDBS01:1522,MYUCBPFALCDBS01:1521,MYUCBPNEOSDBS01:1521,myucbpneosdbs02:1521,MYUCBPPAYNDBS01:1522,MYUCBPPAYNDBS02:1522,MYUCBPRCRSDBS01:1521,MYUCBPRTBSDBS01:1526,MYUCBPRTBSDBS03:1521,MYUCBPRWSADBS01:1526,MYUCBPRWSADBS01:1528,MYUCBRFALCDBS01:1521,MYUCBRRTBSDBS01:1526,MYUCBRRTBSDBS01:1526,MYUWBPMURXDBS01:1523,MYUWBPMURXDBS02:1523,RTBINTDBTH01:1521,RTBINTDBTH01:1522,sgdseuprddb01:1522,sgdseuprddb01:1522"}, {"name": "test_name_list", "label": "Test Name List", "help_string": "Comma separated, e.g. Memory Usage, System Details ", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Oracle Database Growth,Oracle Tablespaces,Oracle Temporary Tablespaces,System Details,Memory Usage"}, {"name": "checkpoint_initial_value", "label": "Checkpoint Initial Value", "help_string": "%Y-%m-%d %H:%M:%S", "required": true, "format_type": "text", "default_value": "2022-12-07 00:00:00", "placeholder": "", "type": "text", "value": "2022-12-07 00:00:00"}], "data_inputs_options": [{"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "eG manager", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "eG manager REST API port", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}, {"type": "customized_var", "name": "username", "title": "Username", "description": "eG manager username", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "password", "title": "Password", "description": "Base64 encoded password", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "component_name_list", "title": "Component Name List", "description": "Host / Component Name with its Test Port, Comma separated, e.g. host1:port1, host3:port3, host4:port4", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "test_name_list", "title": "Test Name List", "description": "Comma separated, e.g. Memory Usage, System Details ", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "checkpoint_initial_value", "title": "Checkpoint Initial Value", "description": "%Y-%m-%d %H:%M:%S", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "2022-12-07 00:00:00", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # hostname_ip_address = definition.parameters.get('hostname_ip_address', None)\n    # port = definition.parameters.get('port', None)\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # component_name_list = definition.parameters.get('component_name_list', None)\n    # test_name_list = definition.parameters.get('test_name_list', None)\n    # checkpoint_initial_value = definition.parameters.get('checkpoint_initial_value', None)\n    pass\n\ndef collect_events(helper, ew):\n\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    opt_username = helper.get_arg('username')\n    opt_password = helper.get_arg('password')\n    opt_component_name_list = helper.get_arg('component_name_list')\n    opt_test_name_list = helper.get_arg('test_name_list')\n    opt_checkpoint_initial_value = helper.get_arg('checkpoint_initial_value')\n\n    stanza_name = helper.get_input_stanza_names()\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    \n    url1 = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getTestData\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    method1 = \"POST\"\n    header1 = {\n        \"managerurl\":managerurl,\n        \"user\":opt_username,\n        \"pwd\":opt_password\n        }\n    \n    cName_list = opt_component_name_list.split(\",\")\n    # remove duplicates\n    cName_list = list( dict.fromkeys(cName_list) )\n    cName_port_list = [None] * len(cName_list)\n    for i in range(0,len(cName_list),1):\n        cName_port_list[i] = cName_list[i].split(\":\")\n        \n    tName_list = opt_test_name_list.split(\",\")\n    \n    key = \"startDate\"\n    endDate = datetime.datetime.now()\n    endDate_str = endDate.strftime(\"%Y-%m-%d %H:%M:%S\")\n    # # Retrieve datetime checkpoint\n    state = helper.get_check_point(key)\n    if state is None:\n        state = opt_checkpoint_initial_value\n    # # Update the checkpoint\n    helper.save_check_point(key,endDate_str)\n    # helper.delete_check_point(key)\n    \n    try:\n        for test in tName_list:\n            for cName_port in cName_port_list:\n                body1 = {\n                        \"test\":test,\n                        \"host\":cName_port[0],\n                        \"port\":cName_port[1],\n                        \"lastmeasure\":\"false\",\n                        \"startDate\":state,\n                        \"endDate\":endDate_str\n                        }\n                response = helper.send_http_request(url1, method1, parameters=None, payload=body1,\n                                                    headers=header1, cookies=None, verify=False, cert=None,\n                                                    timeout=None, use_proxy=True)\n                r_json = response.json()\n                fields = r_json[0]\n                fields_list = fields.split()\n                data_raw = r_json[1:]\n                for row in data_raw:\n                    match = re.search(r\"^(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2}\\s\\d{2}:\\d{2}:\\d{2})\\s+(.+)\",row)\n\n                    output = \"\"\n                    test_data = match.group(7).split()\n                    for i in range(0,6,1):\n                        output += fields_list[i] + \"=\" + match.group(i+1) + \",\" \n                    for i in range(6,len(fields_list),1):\n                        if (i == len(fields_list)-1):\n                            output += fields_list[i] + \"=\" + test_data[i-6] + \",test=\\\"\" + test + \"\\\"\"\n                        else:\n                            output += fields_list[i] + \"=\" + test_data[i-6] + \",\"\n                    event = helper.new_event(source=source1, index=index1, sourcetype=sourcetype1, data=output)\n                    ew.write_event(event)\n\n    except Exception as e:\n        message = \"Exception=\" + str(e)\n        helper.log_info(message)\n        ", "customized_options": [{"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "username", "value": "splunk"}, {"name": "password", "value": "U3AxOG5rIzAw"}, {"name": "component_name_list", "value": "CCSDBMYP01:1522,CCSDBMYP01:1522,CCSDBSGP01:1522,CCSDBSGP01:1522,CCSDBTHP01:1522,CCSDBTHP01:1522,F1PRODDB:1521,F1PRODDB:1521,GFMSDBPROD01:1521,MXiTHDB1:1523,MYBTRADEUPRDDB01:1521,MYUCBP1VEWDBS01:1522,MYUCBPFALCDBS01:1521,MYUCBPNEOSDBS01:1521,myucbpneosdbs02:1521,MYUCBPPAYNDBS01:1522,MYUCBPPAYNDBS02:1522,MYUCBPRCRSDBS01:1521,MYUCBPRTBSDBS01:1526,MYUCBPRTBSDBS03:1521,MYUCBPRWSADBS01:1526,MYUCBPRWSADBS01:1528,MYUCBRFALCDBS01:1521,MYUCBRRTBSDBS01:1526,MYUCBRRTBSDBS01:1526,MYUWBPMURXDBS01:1523,MYUWBPMURXDBS02:1523,RTBINTDBTH01:1521,RTBINTDBTH01:1522,sgdseuprddb01:1522,sgdseuprddb01:1522"}, {"name": "test_name_list", "value": "Oracle Database Growth,Oracle Tablespaces,Oracle Temporary Tablespaces,System Details,Memory Usage"}, {"name": "checkpoint_initial_value", "value": "2022-12-07 00:00:00"}], "uuid": "898be8d7f6a940ffafff532ee4b05979", "sample_count": 0}, {"index": "default", "sourcetype": "eg:analytics:getTestData", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "gettestdata", "title": "getTestData", "description": "Using the eG REST API, administrators can retrieve the measurement data collected upon execution of tests across all relevant component types.", "type": "customized", "parameters": [{"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "eG manager FQDN / IP, xxx.xxx.xxx.xxx", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "7077", "type": "text", "value": "7077"}, {"name": "test_name", "label": "Test Name", "help_string": "e.g. Memory Usage, System Details etc.", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "TCP Port Status"}, {"name": "component_name", "label": "Component Name", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}, {"name": "checkpoint_initial_value", "label": "Checkpoint Initial Value", "help_string": "%Y-%m-%d %H:%M:%S", "required": true, "format_type": "text", "default_value": "2020-01-01 00:00:00", "placeholder": "", "type": "text", "value": "2023-02-27 10:00:00"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "eG manager FQDN / IP, xxx.xxx.xxx.xxx", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": "7077"}, {"type": "customized_var", "name": "test_name", "title": "Test Name", "description": "e.g. Memory Usage, System Details etc.", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "component_name", "title": "Component Name", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "checkpoint_initial_value", "title": "Checkpoint Initial Value", "description": "%Y-%m-%d %H:%M:%S", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "2020-01-01 00:00:00", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # hostname_ip_address = definition.parameters.get('hostname_ip_address', None)\n    # port = definition.parameters.get('port', None)\n    # username = definition.parameters.get('username', None)\n    # password = definition.parameters.get('password', None)\n    # component_test_name = definition.parameters.get('component_test_name', None)\n    # component_host_name = definition.parameters.get('component_host_name', None)\n    # component_test_port = definition.parameters.get('component_test_port', None)\n    # checkpoint_initial_value = definition.parameters.get('checkpoint_initial_value', None)\n    pass\n\ndef checkpoint(helper, initialValue):\n    \"\"\" Function for creating Checkpoint using the start and end datetime %Y-%m-%d %H:%M:%S\n    Parameters\n    ----------\n    helper : Splunk Add-on Builder helper function\n    initialValue : str\n        The initial value for the checkpoint on the first run with empty checkpoint. Uses format \"%Y-%m-%d %H:%M:%S\"\n    Returns\n    -------\n    state : str\n        The start time or the previous checkpoint stored.\n    endDate_str : str\n        The end time or the new checkpoint updated. \n    \"\"\"\n    # CHECKPOINTING\n    key = \"startDate\"\n    endDate = datetime.datetime.now()\n    endDate_str = endDate.strftime(\"%Y-%m-%d %H:%M:%S\")\n    # # Retrieve datetime checkpoint\n    state = helper.get_check_point(key)\n    if state is None:\n        state = initialValue\n    # # Update the checkpoint\n    helper.save_check_point(key, endDate_str)\n    # helper.delete_check_point(key)\n    return state, endDate_str\n    \n\ndef isHeader(data):\n    \"\"\" Function to check the first 4 characters of the data and determine the type of data (header or metrics)\n    Parameters\n    ----------\n    data : str\n        The data obtained from the REST API. Analyse for header or metrics data.\n    Returns\n    -------\n    bool\n        True - data is a header, False - data is metrics data. \n    \"\"\"\n    pattern = \"^(TRGT_HOST)\"\n    return bool(re.match(pattern, data))\n\n    \ndef parseHeaDat(data):\n    \"\"\" Function to parse the data and return the header and metrics data. \n    Parameters\n    ----------\n    data : str\n        The data obtained from the REST API.\n    Returns\n    -------\n    hea : list\n        The header of the data which is the attribute name or field name. \n    dat : list\n        The body of the data which holds the corresponding value for the header.  \n    \"\"\"\n    assert data is not None, \"There is no data to parse. \"\n    hea = dat = []\n    if isHeader(data):\n        hea = data.split()\n    else:\n        match = re.search(\n            r\"^(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(.+?)\\s+(\\d{4}-\\d{2}-\\d{2}\\s\\d{2}:\\d{2}:\\d{2})\\s+(.+)\", data)\n        dat = []\n        for i in range(1, 7, 1):\n            dat.append(match.group(i))\n        temp = match.group(7).split()\n        dat = dat + temp\n    return hea, dat\n\n\ndef splkData_format(fields, values):\n    \"\"\" Function to format the data into string with the fields and values pair separated by comma. \"<field1>=<value1>,<field2>=<value2>,....\"\n    Parameters\n    ----------\n    fields : list\n        The attribute names / field names.\n    values : list\n        The value of the attribute / field.\n    Returns\n    -------\n    splkData : str\n        string data in format of \"<field1>=<value1>,<field2>=<value2>,....\"\n    \"\"\"\n    assert len(fields) == len(values), \"Fields and Values mismatched.\"\n    splkData = \"\"\n\n    for i in range(0, len(fields) - 1, 1):\n        splkData += fields[i] + \"=\\\"\" + values[i] + \"\\\",\"\n\n    splkData += fields[len(fields) - 1] + \\\n        \"=\\\"\" + values[len(fields) - 1] + \"\\\"\"\n\n    return splkData\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    # opt_username = helper.get_arg('username')\n    # opt_password = helper.get_arg('password')\n    opt_test_name = helper.get_arg('test_name')\n    opt_component_name = helper.get_arg('component_name')\n    # opt_component_test_port = helper.get_arg('component_test_port')\n    opt_checkpoint_initial_value = helper.get_arg('checkpoint_initial_value')\n    # --------------------------------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    # --------------------------------------------------------------------------------------------------------\n    # Checkpoint to avoid querying duplicate data\n    state, endDate_str = checkpoint(helper, opt_checkpoint_initial_value)\n    # ---------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getTestData\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    method = \"POST\"\n    header1 = {\n        \"managerurl\":managerurl,\n        \"user\":username,\n        \"pwd\":password_base64\n        }\n    body1 = {\n        \"test\":opt_test_name,\n        \"orderby\":\"desc\",\n        \"componentName\":opt_component_name,\n        \"showData\":\"test\",\n        \"lastmeasure\":\"false\",\n        \"startDate\":state,\n        \"endDate\":endDate_str\n        }\n    # ---------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, method, parameters=None, payload=body1,\n                                            headers=header1, cookies=None, verify=False, cert=None,\n                                            timeout=None, use_proxy=False)\n    \n        r_status = response.status_code\n        if r_status != 200:\n            response.raise_for_status()\n        else:\n            r_json = response.json()\n            curFields = []\n            curValues = []\n            for row in r_json:\n                fields, values = parseHeaDat(row)\n                if len(fields) > 1:\n                    curFields = fields\n                if len(values) > 1:\n                    curValues = values\n                if len(curFields) == len(curValues):\n                    output2Splk = splkData_format(curFields, curValues)\n                    output2Splk += \",test=\\\"\" + opt_test_name + \"\\\"\"\n                    event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=output2Splk)\n                    ew.write_event(event)\n                else:\n                    continue\n    except Exception as e:\n        message1 = \"Exception= \" + \"\\\"\" + str(e) + \"\\\"\"\n        helper.log_debug(message1)\n        ", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "test_name", "value": "SQL Database Status"}, {"name": "component_name", "value": ""}, {"name": "checkpoint_initial_value", "value": "2023-02-27 10:00:00"}], "uuid": "527c8f8d12804dffbb7c978b4bd9d98e", "sample_count": 0}, {"index": "default", "sourcetype": "eg:analytics:getLiveMeasure", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "getlivemeasure", "title": "getLiveMeasure", "description": "", "type": "customized", "parameters": [{"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "", "type": "text", "value": "7077"}, {"name": "server_type", "label": "Server Type", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Microsoft SQL"}, {"name": "server_name", "label": "Server Name", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "MYWCBP1PLADBS01:50000"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}, {"type": "customized_var", "name": "server_type", "title": "Server Type", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "server_name", "title": "Server Name", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "# encoding = utf-8\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\n\ndef validate_input(helper, definition):\n    pass\n\ndef formatEvent(metrics,tests,metricName,*dimension):    \n    event = \"time=\\\"\" + datetime.datetime.now().strftime('%d/%m/%y %H:%M:%S') + \"\\\" \" + \"test=\\\"\" + list(tests.keys())[0] + \"\\\" \"\n    if(len(dimension)>0):\n        event = event + \\\n        \"testInfo=\\\"\" + dimension[0] + \"\\\" \" + \\\n        \"testState=\\\"\" + dimension[1] + \"\\\" \"    \n    \n    event = event + \\\n    \"metric_name=\\\"\" + metricName + \"\\\" \" + \\\n    \"State=\\\"\" + metrics[0]['State'] + \"\\\" \" + \\\n    \"Value=\\\"\" + metrics[0]['Value'] + \"\\\" \" + \\\n    \"Unit=\\\"\" + metrics[0]['Unit'] + \"\\\"\"\n    return event\n    \ndef getDataLeaf(helper,ew,host,source,sourcetype,index,metrics,tests,metricName,*dimension):\n    for value in metrics:\n        data = formatEvent(metrics,tests,metricName,*dimension)\n        event = helper.new_event(host=host, source=source, index=index, sourcetype=sourcetype, data=data)\n        ew.write_event(event)\n\ndef parseData(helper,ew,host,source,sourcetype,index,data):  \n    for tests in data[0][list(data[0])[0]]:\n        if (type(tests) == dict):\n            #helper.log_debug(tests)\n            for test in tests.items():\n                for field, metrics in test[1].items():\n                    if (type(metrics) == list):\n                        if all(key in metrics[0] for key in (\"State\", \"Value\", \"Unit\")):                        getDataLeaf(helper,ew,host,source,sourcetype,index,metrics,tests,field)\n                        else:\n                            for name, metric in metrics[0].items():\n                                if all(key in metric[0] for key in (\"State\", \"Value\", \"Unit\")):\n                                    getDataLeaf(helper,ew,host,source,sourcetype,index,metric, tests, name, field, metrics[0]['State'])\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(\n        bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    opt_server_type = helper.get_arg('server_type')\n    opt_server_name = helper.get_arg('server_name')\n    # --------------------------------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    # ---------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getLiveMeasure\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    method = \"POST\"\n    header1 = {\n        \"managerurl\": managerurl,\n        \"user\": username,\n        \"pwd\": password_base64\n    }\n    body1 = {\n        \"servertype\": opt_server_type,\n        \"servername\": opt_server_name\n    }\n    # ---------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, method, parameters=None, payload=body1, headers=header1, cookies=None, verify=False, cert=None, timeout=None, use_proxy=False)\n        r_status = response.status_code\n        if r_status != 200:\n            response.raise_for_status()\n        else:\n            r_json = response.json()\n            parseData(helper,ew,opt_hostname_ip_address,source1,sourcetype1,index1,r_json)\n            #event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=json.dumps(r_json, indent=4))\n            #ew.write_event(event)\n    except Exception as e:\n        message1 = \"Exception=\" + \"\\\"\" + str(e) + \"\\\"\"\n        helper.log_debug(message1)", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "server_type", "value": "Microsoft SQL"}, {"name": "server_name", "value": "MYWCBP1PLADBS01:50000"}], "uuid": "6884661c4cf144639ed86c7184ab82c1", "sample_count": 0}, {"index": "default", "sourcetype": "eg:miscservice:getComponentMapping", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "getcomponentmapping", "title": "getComponentMapping", "description": "The eG REST API can be used to retrieve all the components managed in the eG Manager along with their respective Component Types.", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": ""}, {"required": true, "name": "hostname_ip_address", "label": "Hostname / IP Address", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "port", "label": "Port", "default_value": "7077", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "7077"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}], "code": "# encoding = utf-8\r\nimport os\r\nimport sys\r\nimport time\r\nimport datetime\r\nimport json\r\nimport re\r\nimport traceback\r\nimport base64\r\n\r\n\r\ndef validate_input(helper, definition):\r\n    pass\r\n\r\n\r\ndef collect_events(helper, ew):\r\n    global_account = helper.get_arg('global_account')\r\n    username = global_account['username']\r\n    password = global_account['password']\r\n    password_base64 = base64.b64encode(\r\n        bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\r\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\r\n    opt_port = helper.get_arg('port')\r\n    # --------------------------------------------------------------------------------------------------------\r\n    source1 = helper.get_input_stanza_names()\r\n    index1 = helper.get_output_index()\r\n    sourcetype1 = helper.get_sourcetype()\r\n    # ---------------------------------------------------------------------------------\r\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getComponentMapping\"\r\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\r\n    method = \"POST\"\r\n    header1 = {\r\n        \"managerurl\": managerurl,\r\n        \"user\": username,\r\n        \"pwd\": password_base64\r\n    }\r\n    body1 = {}\r\n    # ---------------------------------------------------------------------------------\r\n    try:\r\n        response = helper.send_http_request(url, method, parameters=None, payload=body1, headers=header1, cookies=None, verify=False, cert=None, timeout=None, use_proxy=False)\r\n        r_status = response.status_code\r\n        if r_status != 200:\r\n            response.raise_for_status()\r\n        else:\r\n            r_json = response.json()\r\n            event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=json.dumps(r_json, indent=4))\r\n            ew.write_event(event)\r\n    except Exception as e:\r\n        message1 = \"Exception=\" + \"\\\"\" + str(e) + \"\\\"\"\r\n        helper.log_debug(message1)", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}], "uuid": "87105c82ae6c4976b7622f6d33828b03"}, {"index": "default", "sourcetype": "eg:getAllLiveData", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "getalllivedata", "title": "getAllLiveData", "description": "Call getZoneMapping resource for list of servers and zone. \nRecursively run all the servers and zone and call getLiveMeasure for all the latest measurement.", "type": "customized", "parameters": [{"name": "global_account", "label": "Global Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "7077", "placeholder": "7077", "type": "text", "value": "7077"}, {"name": "zone", "label": "Zone", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Oracle Database"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": "7077"}, {"type": "customized_var", "name": "zone", "title": "Zone", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "# encoding = utf-8\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\n\ndef validate_input(helper, definition):\n    pass\n\ndef formatEvent(hostname,zone,metrics,tests,metricName,*dimension):    \n    event = \"time=\\\"\" + tests[list(tests.keys())[0]]['Last Measurement Time'] + \"\\\" \" + \\\n    \"componentName=\\\"\" + hostname + \"\\\" \" + \\\n    \"componentType=\\\"\" + zone + \"\\\" \" + \\\n    \"test=\\\"\" + list(tests.keys())[0] + \"\\\" \"\n    \n    if(len(dimension)>0):\n        event = event + \\\n        \"testInfo=\\\"\" + dimension[0] + \"\\\" \" + \\\n        \"testState=\\\"\" + dimension[1] + \"\\\" \"    \n    \n    event = event + \\\n    \"metric_name=\\\"\" + metricName + \"\\\" \" + \\\n    \"State=\\\"\" + metrics[0]['State'] + \"\\\" \" + \\\n    \"Value=\\\"\" + metrics[0]['Value'] + \"\\\" \" + \\\n    \"Unit=\\\"\" + metrics[0]['Unit'] + \"\\\"\"\n    return event\n    \ndef getDataLeaf(helper,ew,host,source,sourcetype,index,hostname,zone,metrics,tests,metricName,*dimension):\n    for value in metrics:\n        data = formatEvent(hostname,zone,metrics,tests,metricName,*dimension)\n        event = helper.new_event(host=host, source=source, index=index, sourcetype=sourcetype, data=data)\n        ew.write_event(event)\n\ndef parseData(helper,ew,host,source,sourcetype,index,hostname,zone,data):  \n    for tests in data[0][list(data[0])[0]]:\n        if (type(tests) == dict):\n            #helper.log_debug(tests)\n            for test in tests.items():\n                for field, metrics in test[1].items():\n                    if (type(metrics) == list):\n                        if all(key in metrics[0] for key in (\"State\", \"Value\", \"Unit\")):                        getDataLeaf(helper,ew,host,source,sourcetype,index,hostname,zone,metrics,tests,field)\n                        else:\n                            for name, metric in metrics[0].items():\n                                if all(key in metric[0] for key in (\"State\", \"Value\", \"Unit\")):\n                                    getDataLeaf(helper,ew,host,source,sourcetype,index,hostname,zone,metric, tests, name, field, metrics[0]['State'])\n\ndef zoneLookup(zone):\n    #Lookup zone from host list to get zone in live measure\n    lookup={\n        \"Microsoft SQL\":\"MSSQL\",\n        \"Microsoft SQL Cluster\":\"MSSQL\",\n        \"Maria Database\":\"MariaDB\",\n        \"Oracle Database\":\"Oracle\",\n        \"Oracle Cluster\":\"Oracle\",\n        \"Linux\":\"Linux\",\n        \"Microsoft Windows\":\"Microsoft Windows\",\n        \"MySQL\":\"MySQL\",\n        \"Solaris\":\"Solaris\",\n        \"DB2 UDB\":\"DB2\"\n    }\n    return lookup[zone]\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(\n        bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    opt_zone = helper.get_arg('zone')\n    # --------------------------------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    # --------------------------------------------------------------------------------------------------------\n    url1 = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getZoneMapping\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    method = \"POST\"\n    header1 = {\n        \"managerurl\": managerurl,\n        \"user\": username,\n        \"pwd\": password_base64\n    }\n    body1 = {}\n    url2 = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getLiveMeasure\"\n    header2 = {\n        \"managerurl\": managerurl,\n        \"user\": username,\n        \"pwd\": password_base64\n    }\n    # body2 = {\n    #     \"servertype\": component_type,\n    #     \"servername\": component_name\n    # }\n    # --------------------------------------------------------------------------------------------------------\n    try:\n        response1 = helper.send_http_request(url1, method, parameters=None, payload=body1, headers=header1, cookies=None, verify=False, cert=None, timeout=None, use_proxy=False)\n        r_status1 = response1.status_code\n        if r_status1 != 200:\n            response1.raise_for_status()\n        else:\n            zones = response1.json()\n            for zone in zones:\n                if (zone['zone']==zoneLookup(opt_zone)):\n                    zone_name = opt_zone\n                    servers = zone['Server']\n                    for server in servers:\n                        body2 = {\n                            \"servertype\": zone_name,\n                            \"servername\": server\n                        }\n                        try:\n                            response2 = helper.send_http_request(url2, method, parameters=None, payload=body2, headers=header1, cookies=None, verify=False, cert=None, timeout=600, use_proxy=False)\n                            r_status2 = response2.status_code\n                            if r_status2 != 200:\n                                response2.raise_for_status()\n                            else:\n                                LiveMeasure = response2.json()\n                                parseData(helper,ew,opt_hostname_ip_address,source1,sourcetype1,index1,server,zone_name,LiveMeasure)\n                        except Exception as e:\n                            message1 = \"Exception=\" + \"\\\"\" + str(e) + \"\\\"\"\n                            helper.log_debug(message1)\n\n    except Exception as e:\n        message1 = \"Exception=\" + \"\\\"\" + str(e) + \"\\\"\"\n        helper.log_debug(message1)", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "zone", "value": "Oracle Database"}], "uuid": "c511d605aa8f4ca78c23fca3b48bd9ab", "sample_count": 0}, {"index": "default", "sourcetype": "eg:analytics:getZoneMapping", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "getzonemapping", "title": "getZoneMapping", "description": "To retrieve the details of the zones and the elements associated with the zone (services, segments, servers etc).", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}, {"required": true, "name": "hostname_ip_address", "label": "Hostname / IP Address", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "10.111.33.10"}, {"required": true, "name": "port", "label": "Port", "default_value": "7077", "placeholder": "7077", "help_string": "", "type": "text", "format_type": "text", "value": "7077"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": "7077"}], "code": "# encoding = utf-8\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\n\ndef validate_input(helper, definition):\n    pass\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(\n        bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    # --------------------------------------------------------------------------------------------------------\n    source = helper.get_input_stanza_names()\n    index = helper.get_output_index()\n    sourcetype = helper.get_sourcetype()\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    method = \"POST\"\n    header = {\n        \"managerurl\": managerurl,\n        \"user\": username,\n        \"pwd\": password_base64\n    }\n    timeout_60s = 60\n    timeout_120s = 120\n    timeout_240s = 240\n    # ---------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getZoneMapping\"\n    body1 = {}\n    # ---------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, \n                                            method, \n                                            parameters=None, \n                                            payload=body1, \n                                            headers=header, \n                                            cookies=None, \n                                            verify=False, \n                                            cert=None, \n                                            timeout=timeout_60s, \n                                            use_proxy=False)\n        r_status = response.status_code\n        if r_status != 200:\n            response.raise_for_status()\n        else:\n            r_json = response.json()\n            for i in r_json:\n                zone_name = i['zone']\n                servers = i['Server']\n                for server in servers:\n                    output = \"zone='{}',server='{}'\".format(zone_name, server)\n                    event = helper.new_event(host=opt_hostname_ip_address, \n                                            source=source, \n                                            index=index, \n                                            sourcetype=sourcetype, \n                                            data=output)\n                    ew.write_event(event)\n    except Exception as e:\n        message1 = \"Get Zone Mapping Failed, Exception={}\".format(str(e))\n        helper.log_debug(message1)", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}], "uuid": "1949071269804075b7db0377ce1ac4f2", "sample_count": 0}, {"index": "default", "sourcetype": "eg:analytics:getZoneDetails", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "getzonedetails", "title": "getZoneDetails", "description": "To retrieve the details of elements such as sub-zones, services, segments and components associated with a zone added on eG Enterprise.", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}, {"required": true, "name": "hostname_ip_address", "label": "Hostname / IP Address", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "10.111.33.10"}, {"required": true, "name": "port", "label": "Port", "default_value": "7077", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "7077"}, {"required": true, "name": "zone", "label": "Zone", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "Oracle"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}, {"type": "customized_var", "name": "zone", "title": "Zone", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "# encoding = utf-8\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\n\ndef validate_input(helper, definition):\n    pass\n\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(\n        bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    opt_zone = helper.get_arg('zone')\n    # --------------------------------------------------------------------------------------------------------\n    source = helper.get_input_stanza_names()\n    index = helper.get_output_index()\n    sourcetype = helper.get_sourcetype()\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    method = \"POST\"\n    header = {\n        \"managerurl\": managerurl,\n        \"user\": username,\n        \"pwd\": password_base64\n    }\n    timeout_60s = 60\n    timeout_120s = 120\n    timeout_240s = 240\n    # ---------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/analytics/getZoneDetails\"\n    body1 = {\n        \"zone\": opt_zone\n    }\n    # ---------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, \n                                            method, \n                                            parameters=None, \n                                            payload=body1, \n                                            headers=header, \n                                            cookies=None, \n                                            verify=False, \n                                            cert=None, \n                                            timeout=timeout_60s, \n                                            use_proxy=False)\n        r_status = response.status_code\n        if r_status != 200:\n            response.raise_for_status()\n        else:\n            r_json = response.json()\n            components_list = r_json['Components']['Details']\n            for item in components_list:\n                item['zone'] = opt_zone\n                event = helper.new_event(host=opt_hostname_ip_address, \n                                        source=source, \n                                        index=index, \n                                        sourcetype=sourcetype, \n                                        data=json.dumps(item))\n                ew.write_event(event)\n    except Exception as e:\n        message1 = \"Get Zone Details Failed, Exception={}\".format(str(e))\n        helper.log_debug(message1)", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "zone", "value": "Oracle"}], "uuid": "7b441815b8464e1487164262b7723bdd", "sample_count": 0}, {"index": "default", "sourcetype": "eg:getAllLiveData:2", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "getalllivedata_v2", "title": "getAllLiveData_v2", "description": "", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": ""}, {"required": true, "name": "hostname_ip_address", "label": "Hostname / IP Address", "default_value": "", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "port", "label": "Port", "default_value": "7077", "placeholder": "", "help_string": "", "type": "text", "format_type": "text", "value": "7077"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "7077", "placeholder": ""}], "code": "# encoding = utf-8\r\nimport os\r\nimport sys\r\nimport time\r\nimport datetime\r\nimport json\r\nimport re\r\nimport traceback\r\nimport base64\r\n\r\n\r\ndef validate_input(helper, definition):\r\n    pass\r\n\r\n\r\ndef formatEvent(componentName, componentType, metrics, tests, metricName, *dimension):\r\n    event = \"time=\\\"\" + tests[list(tests.keys())[0]]['Last Measurement Time'] + \"\\\" \" + \\\r\n        \"componentName=\\\"\" + componentName + \"\\\" \" + \\\r\n        \"componentType=\\\"\" + componentType + \"\\\" \" + \\\r\n        \"test=\\\"\" + list(tests.keys())[0] + \"\\\" \"\r\n\r\n    if (len(dimension) > 0):\r\n        event = event + \\\r\n            \"testInfo=\\\"\" + dimension[0] + \"\\\" \" + \\\r\n            \"testState=\\\"\" + dimension[1] + \"\\\" \"\r\n\r\n    event = event + \\\r\n        \"metric_name=\\\"\" + metricName + \"\\\" \" + \\\r\n        \"State=\\\"\" + metrics[0]['State'] + \"\\\" \" + \\\r\n        \"Value=\\\"\" + metrics[0]['Value'] + \"\\\" \" + \\\r\n        \"Unit=\\\"\" + metrics[0]['Unit'] + \"\\\"\"\r\n    return event\r\n\r\n\r\ndef getDataLeaf(helper, ew, host, source, sourcetype, index, componentName, componentType, metrics, tests, metricName, *dimension):\r\n    for value in metrics:\r\n        data = formatEvent(componentName, componentType, metrics,\r\n                           tests, metricName, *dimension)\r\n        event = helper.new_event(\r\n            host=host, source=source, index=index, sourcetype=sourcetype, data=data)\r\n        ew.write_event(event)\r\n\r\n\r\ndef parseData(helper, ew, host, source, sourcetype, index, componentName, componentType, data):\r\n    for tests in data[0][list(data[0])[0]]:\r\n        if (type(tests) == dict):\r\n            # helper.log_debug(tests)\r\n            for test in tests.items():\r\n                for field, metrics in test[1].items():\r\n                    if (type(metrics) == list):\r\n                        if all(key in metrics[0] for key in (\"State\", \"Value\", \"Unit\")):\r\n                            getDataLeaf(helper, ew, host, source, sourcetype,\r\n                                        index, componentName, componentType, metrics, tests, field)\r\n                        else:\r\n                            for name, metric in metrics[0].items():\r\n                                if all(key in metric[0] for key in (\"State\", \"Value\", \"Unit\")):\r\n                                    getDataLeaf(helper, ew, host, source, sourcetype, index, componentName,\r\n                                                componentType, metric, tests, name, field, metrics[0]['State'])\r\n\r\n\r\ndef collect_events(helper, ew):\r\n    global_account = helper.get_arg('global_account')\r\n    username = global_account['username']\r\n    password = global_account['password']\r\n    password_base64 = base64.b64encode(\r\n        bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\r\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\r\n    opt_port = helper.get_arg('port')\r\n    # opt_zone = helper.get_arg('zone')\r\n    # --------------------------------------------------------------------------------------------------------\r\n    source = helper.get_input_stanza_names()\r\n    index = helper.get_output_index()\r\n    sourcetype = helper.get_sourcetype()\r\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\r\n    method = \"POST\"\r\n    header = {\r\n        \"managerurl\": managerurl,\r\n        \"user\": username,\r\n        \"pwd\": password_base64\r\n    }\r\n    timeout_60s = 60\r\n    timeout_120s = 120\r\n    timeout_240s = 240\r\n    timeout_300s = 300\r\n    # --------------------------------------------------------------------------------------------------------\r\n    # Get all the zones and servers list\r\n    # zones_servers_list = []\r\n    zones_list = []\r\n    # servers_list = []\r\n    url1 = \"https://\" + opt_hostname_ip_address + \":\" + \\\r\n        opt_port + \"/api/eg/analytics/getZoneMapping\"\r\n    body1 = {}\r\n    try:\r\n        response1 = helper.send_http_request(url1,\r\n                                             method,\r\n                                             parameters=None,\r\n                                             payload=body1,\r\n                                             headers=header,\r\n                                             cookies=None,\r\n                                             verify=False,\r\n                                             cert=None,\r\n                                             timeout=timeout_60s,\r\n                                             use_proxy=False)\r\n        r_status1 = response1.status_code\r\n        if r_status1 != 200:\r\n            response1.raise_for_status()\r\n        else:\r\n            r_json1 = response1.json()\r\n            for i in r_json1:\r\n                zone_name = i['zone']\r\n                zones_list.append(zone_name)\r\n                # servers = i['Server']\r\n                # for server in servers:\r\n                # servers_list.append(server)\r\n                # server_zone_item = {\r\n                #     \"server\": server,\r\n                #     \"zone\": zone_name\r\n                # }\r\n                # zones_servers_list.append(server_zone_item)\r\n    except Exception as e:\r\n        message1 = \"Get all the zones failed, Exception= {}\".format(str(e))\r\n        helper.log_debug(message1)\r\n    # --------------------------------------------------------------------------------------------------------\r\n    # Get the corresponding inventory information for component type and component name\r\n    url2 = \"https://\" + opt_hostname_ip_address + \":\" + \\\r\n        opt_port + \"/api/eg/analytics/getZoneDetails\"\r\n    components_list = []\r\n    for zone in zones_list:\r\n        body2 = {\r\n            \"zone\": zone\r\n        }\r\n        try:\r\n            response2 = helper.send_http_request(url2,\r\n                                                 method,\r\n                                                 parameters=None,\r\n                                                 payload=body2,\r\n                                                 headers=header,\r\n                                                 cookies=None,\r\n                                                 verify=False,\r\n                                                 cert=None,\r\n                                                 timeout=timeout_60s,\r\n                                                 use_proxy=False)\r\n            r_status2 = response2.status_code\r\n            if r_status2 != 200:\r\n                response2.raise_for_status()\r\n            else:\r\n                r_json2 = response2.json()\r\n                for item in r_json2['Components']['Details']:\r\n                    components_list.append(item)\r\n                # components_list.append(r_json2['Components']['Details'])\r\n        except Exception as e:\r\n            message2 = \"Get Zone Details Failed for {}, Exception={}\".format(\r\n                zone, str(e))\r\n            helper.log_debug(message2)\r\n    helper.log_debug(components_list)\r\n    # --------------------------------------------------------------------------------------------------------\r\n    url3 = \"https://\" + opt_hostname_ip_address + \":\" + \\\r\n        opt_port + \"/api/eg/analytics/getLiveMeasure\"\r\n    for component in components_list:\r\n        body3 = {\r\n            \"servertype\": component['type'],\r\n            \"servername\": component['name']\r\n        }\r\n        try:\r\n            response3 = helper.send_http_request(url3,\r\n                                                 method,\r\n                                                 parameters=None,\r\n                                                 payload=body3,\r\n                                                 headers=header,\r\n                                                 cookies=None,\r\n                                                 verify=False,\r\n                                                 cert=None,\r\n                                                 timeout=timeout_300s,\r\n                                                 use_proxy=False)\r\n            r_status3 = response3.status_code\r\n            if r_status3 != 200:\r\n                response3.raise_for_status()\r\n            else:\r\n                LiveMeasure = response3.json()\r\n                parseData(helper,\r\n                   