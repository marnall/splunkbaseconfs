{"basic_builder": {"appname": "TA-eg-add-on-for-splunk", "friendly_name": "eG Add-on for Splunk", "version": "1.7.1", "author": "Justin & Elton", "description": "Add-on for Splunk to integrate eG Innovations monitoring solution through REST API query.", "theme": "#f29305", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.1", "tab_build_no": "0", "build_no": 14}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "eg:orchestration:showtestsdetails", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "showtestsdetails", "title": "showtestsdetails", "description": "Use this API to display the details of a test pertaining to a chosen Component Type.", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [], "type": "global_account", "format_type": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "label": "Hostname / IP Address", "help_string": "eG manager IP: xxx.xxx.xxx.xxx", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "10.111.33.10"}, {"name": "port", "label": "Port", "help_string": "", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "7077"}, {"name": "component_type", "label": "Component Type", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Oracle Database"}, {"name": "component_name", "label": "Component Name", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "F1PRODDB:1521:CIMB"}, {"name": "test_type", "label": "Test Type", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Performance"}, {"name": "test_name", "label": "Test Name", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "Oracle Long Running Queries"}], "data_inputs_options": [{"type": "customized_var", "name": "global_account", "title": "Global Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "hostname_ip_address", "title": "Hostname / IP Address", "description": "eG manager IP: xxx.xxx.xxx.xxx", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "port", "title": "Port", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "component_type", "title": "Component Type", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "component_name", "title": "Component Name", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "test_type", "title": "Test Type", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "test_name", "title": "Test Name", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport json\nimport re\nimport traceback\nimport base64\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # hostname_ip_address = definition.parameters.get('hostname_ip_address', None)\n    # port = definition.parameters.get('port', None)\n    # component_type = definition.parameters.get('component_type', None)\n    # component_name = definition.parameters.get('component_name', None)\n    # test_type = definition.parameters.get('test_type', None)\n    # test_name = definition.parameters.get('test_name', None)\n    pass\n\ndef collect_events(helper, ew):\n    global_account = helper.get_arg('global_account')\n    username = global_account['username']\n    password = global_account['password']\n    password_base64 = base64.b64encode(bytes(f\"{password}\", \"utf-8\")).decode(\"ascii\")\n    opt_hostname_ip_address = helper.get_arg('hostname_ip_address')\n    opt_port = helper.get_arg('port')\n    # opt_username = helper.get_arg('username')\n    # opt_password = helper.get_arg('password')\n    opt_component_type = helper.get_arg('component_type')\n    opt_component_name = helper.get_arg('component_name')\n    opt_test_type = helper.get_arg('test_type')\n    opt_test_name = helper.get_arg('test_name')\n    # --------------------------------------------------------------------------------------------------------\n    source1 = helper.get_input_stanza_names()\n    index1 = helper.get_output_index()\n    sourcetype1 = helper.get_sourcetype()\n    # --------------------------------------------------------------------------------------------------------\n    url = \"https://\" + opt_hostname_ip_address + \":\" + opt_port + \"/api/eg/orchestration/showtestsdetails\"\n    method = \"POST\"\n    managerurl = \"https://\" + opt_hostname_ip_address + \":\" + opt_port\n    header1 = {\n        \"managerurl\":managerurl,\n        \"user\":username,\n        \"pwd\":password_base64\n        }\n    body1 = {\n        \"componenttype\":opt_component_type,\n        \"componentname\":opt_component_name,\n        \"testtype\":opt_test_type,\n        \"testname\":opt_test_name\n        }\n    # --------------------------------------------------------------------------------------------------------\n    try:\n        response = helper.send_http_request(url, method, parameters=None, payload=body1,\n                                            headers=header1, cookies=None, verify=False, cert=None,\n                                            timeout=None, use_proxy=False)\n        r_status = response.status_code\n        if (r_status != 200):\n            response.raise_for_status()\n        else: \n            r_json = response.json()\n            output = json.dumps(r_json)\n            event = helper.new_event(host=opt_hostname_ip_address, source=source1, index=index1, sourcetype=sourcetype1, data=output)\n            ew.write_event(event)\n    except Exception as e:\n        message1 = \"Exception= \" + \"\\\"\" + str(e) + \"\\\"\"\n        helper.log_debug(message1)\n", "customized_options": [{"name": "global_account", "value": "account0"}, {"name": "hostname_ip_address", "value": "10.111.33.10"}, {"name": "port", "value": "7077"}, {"name": "component_type", "value": "Oracle Database"}, {"name": "component_name", "value": "F1PRODDB:1521:CIMB"}, {"name": "test_type", "value": "Performance"}, {"name": "test_name", "value": "Oracle Long Running Queries"}], "uuid": "be911da7238b43f7b7a713a5c11b5d4c", "sample_count": 0}, {"index": "default", "sourcetype": "eg:orchestration:showcomponents", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "showcomponents", "title": "showcomponents", "description": "Administrators can use this API to display the components available in the target environment.", "type": "customized", "parameters": [{"required": true, "name": "global_account", "label": "Global Account", "default_value": "", "placeholder": "", "help_string": "", "possible_values": [],