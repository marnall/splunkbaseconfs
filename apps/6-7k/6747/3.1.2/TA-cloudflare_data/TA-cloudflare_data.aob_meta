{"basic_builder": {"appname": "TA-cloudflare_data", "friendly_name": "Add-on for CloudFlare API", "version": "3.1.2", "author": "caldwell@gwuedu", "description": "Import zone and WAF settings and WAF events into Splunk using the Cloudflare API.", "theme": "#033C5A", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 9}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "cloudflare:firewall:rules", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "firewall_rules", "title": "Firewall rules", "description": "Firewall rules for all zones", "type": "customized", "parameters": [{"required": true, "name": "action", "label": "Action", "default_value": "all", "placeholder": "", "help_string": "", "possible_values": [{"value": "all", "label": "all"}, {"value": "allow", "label": "allow"}, {"value": "block", "label": "block"}], "type": "dropdownlist", "format_type": "dropdownlist", "value": "all"}], "data_inputs_options": [{"type": "customized_var", "name": "action", "title": "Action", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "all", "label": "all"}, {"value": "allow", "label": "allow"}, {"value": "block", "label": "block"}], "format_type": "dropdownlist", "default_value": "all", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input,\nuncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza\n    configurations\n    \"\"\"\n    # This example accesses the modular input variable\n    # checkbox = definition.parameters.get('checkbox', None)\n    pass\n\n\ndef get_zones(auth_email, auth_key):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/',\n            params={\n                \"match\": 'all',\n            },\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        zones = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return zones\n\n\ndef get_rules(zone_id, auth_email, auth_key, parameters):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/' +\n            zone_id + '/firewall/rules',\n            params=parameters,\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        rules = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return rules\n\n\ndef collect_events(helper, ew):\n\n    # get global variable configuration\n    auth_key = helper.get_global_setting('x_auth_key')\n    auth_email = helper.get_global_setting('x_auth_email')\n    action = helper.get_arg('action')\n\n\n    if action == \"all\":\n        parameters = {\n            \"per_page\": 100,\n        }\n    else:\n        parameters = {\n            \"per_page\": 100,\n            \"action\": action\n        }\n\n    response = get_zones(auth_email, auth_key)\n    zones = json.loads(response)\n    for zone in zones[\"result\"]:\n        zone_id = zone[\"id\"]\n        zone_name = zone[\"name\"]\n        response = get_rules(zone_id, auth_email, auth_key, parameters)\n        rules = json.loads(response)\n        for rule in rules[\"result\"]:\n            rule = json.dumps(rule)\n            event = helper.new_event(source=zone_name,\n                                     index=helper.get_output_index(),\n                                     sourcetype=helper.get_sourcetype(),\n                                     data=rule)\n            ew.write_event(event)\n", "customized_options": [{"name": "action", "value": "all"}], "uuid": "4619c96bf2d44860aff26ff65293faa4", "sample_count": 0}, {"index": "default", "sourcetype": "cloudflare:zone:settings", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "zone_settings", "title": "Zone settings", "description": "Settings for all zones", "type": "customized", "parameters": [{"required": true, "name": "ids", "label": "Setting ID", "default_value": "all", "placeholder": "", "help_string": "", "possible_values": [{"value": "all", "label": "all"}], "type": "dropdownlist", "format_type": "dropdownlist", "value": "all"}], "data_inputs_options": [{"type": "customized_var", "name": "ids", "title": "Setting ID", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "all", "label": "all"}], "format_type": "dropdownlist", "default_value": "all", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input,\nuncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza\n    configurations\n    \"\"\"\n    # This example accesses the modular input variable\n    # checkbox = definition.parameters.get('checkbox', None)\n    pass\n\n\ndef get_zones(auth_email, auth_key):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/',\n            params={\n                \"match\": 'all',\n            },\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        zones = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return zones\n\n\ndef get_settings(zone_id, auth_email, auth_key, parameters):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/' +\n            zone_id + '/settings',\n            params=parameters,\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        settings = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return settings\n\n\ndef collect_events(helper, ew):\n\n    # get global variable configuration\n    auth_key = helper.get_global_setting('x_auth_key')\n    auth_email = helper.get_global_setting('x_auth_email')\n    ids = helper.get_arg('ids')\n\n    if ids == \"all\":\n        parameters = {\n            \"per_page\": 100,\n        }\n\n    response = get_zones(auth_email, auth_key)\n    zones = json.loads(response)\n    for zone in zones[\"result\"]:\n        zone_id = zone[\"id\"]\n        zone_name = zone[\"name\"]\n        response = get_settings(zone_id, auth_email, auth_key, parameters)\n        settings = json.loads(response)\n        for setting in settings[\"result\"]:\n            setting = json.dumps(setting)\n            event = helper.new_event(source=zone_name,\n                                     index=helper.get_output_index(),\n                                     sourcetype=helper.get_sourcetype(),\n                                     data=setting)\n            ew.write_event(event)\n", "customized_options": [{"name": "ids", "value": "all"}], "uuid": "5be6a2e667244b3d8c7b7d5ff9d5af0d", "sample_count": 0}, {"index": "default", "sourcetype": "cloudflare:waf:events", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "waf_logs_received", "title": "WAF logs received", "description": "WAF events for all zones", "type": "customized", "parameters": [{"name": "timestamps", "label": "Timestamps", "help_string": "", "required": true, "possible_values": [{"value": "unix", "label": "unix"}, {"value": "unixnano", "label": "unixnano"}, {"value": "rfc3339", "label": "rfc3339"}], "format_type": "dropdownlist", "default_value": "unix", "placeholder": "", "type": "dropdownlist", "value": "unix"}, {"name": "earliest_event", "label": "Event lookback", "help_string": "Minutes to look back for earliest event", "required": true, "format_type": "text", "default_value": "10", "placeholder": "", "type": "text", "value": "10"}, {"name": "event_count", "label": "Event count", "help_string": "", "required": false, "format_type": "text", "default_value": "", "placeholder": "optional", "type": "text", "value": "6700"}], "data_inputs_options": [{"type": "customized_var", "name": "timestamps", "title": "Timestamps", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "unix", "label": "unix"}, {"value": "unixnano", "label": "unixnano"}, {"value": "rfc3339", "label": "rfc3339"}], "format_type": "dropdownlist", "default_value": "unix", "placeholder": ""}, {"type": "customized_var", "name": "earliest_event", "title": "Event lookback", "description": "Minutes to look back for earliest event", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "10", "placeholder": ""}, {"type": "customized_var", "name": "event_count", "title": "Event count", "description": "", "required_on_edit": false, "required_on_create": false, "format_type": "text", "default_value": "", "placeholder": "optional"}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input,\nuncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza\n    configurations\n    \"\"\"\n    # This example accesses the modular input variable\n    # checkbox = definition.parameters.get('checkbox', None)\n    pass\n\n\ndef get_zones(auth_email, auth_key):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/',\n            params={\n                \"match\": 'all',\n            },\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        zones = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return zones\n\n\ndef get_waf_events(zone_id, auth_email, auth_key, parameters):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/' +\n                zone_id + '/logs/received',\n            params=parameters,\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        events = response.text\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return events\n\n\ndef collect_events(helper, ew):\n\n    # get global variable configuration\n    auth_key = helper.get_global_setting('x_auth_key')\n    auth_email = helper.get_global_setting('x_auth_email')\n    earliest = helper.get_arg('earliest_event')\n    c = helper.get_arg('event_count')\n\n    try:\n        c = int(c)\n    except:\n        c = 0\n    timestamps = helper.get_arg('timestamps')\n\n    start_time = datetime.datetime.now() - datetime.timedelta(minutes=int(earliest))\n    end_time = datetime.datetime.now() - datetime.timedelta(minutes=5)\n    waf_fields = \"CacheCacheStatus,CacheResponseBytes,CacheResponseStatus,ClientASN,ClientCountry,ClientDeviceType,ClientIP,ClientIPClass,ClientRequestBytes,ClientRequestHost,ClientRequestMethod,ClientRequestProtocol,ClientRequestReferer,ClientRequestURI,ClientRequestUserAgent,ClientSSLCipher,ClientSSLProtocol,ClientSrcPort,EdgeColoID,EdgeEndTimestamp,EdgePathingOp,EdgePathingSrc,EdgePathingStatus,EdgeResponseBytes,EdgeResponseCompressionRatio,EdgeResponseStatus,EdgeStartTimestamp,OriginIP,OriginResponseBytes,OriginResponseHTTPExpires,OriginResponseHTTPLastModified,OriginResponseStatus,OriginResponseTime,RayID,WAFAction,WAFFlags,WAFMatchedVar,WAFProfile,WAFRuleID,WAFRuleMessage\"\n\n    if c >= 1:\n        parameters = {\n            \"timestamps\": timestamps,\n            \"fields\": str(waf_fields),\n            \"start\": start_time.strftime(\"%s\"),\n            \"end\": end_time.strftime(\"%s\"),\n            \"count\": c\n        }\n    else:\n         parameters = {\n            \"timestamps\": timestamps,\n            \"fields\": str(waf_fields),\n            \"start\": start_time.strftime(\"%s\"),\n            \"end\": end_time.strftime(\"%s\"),\n        }\n\n    response = get_zones(auth_email, auth_key)\n    zones = json.loads(response)\n    for zone in zones[\"result\"]:\n        zone_id = zone[\"id\"]\n        zone_name = zone[\"name\"]\n        events = get_waf_events(zone_id, auth_email, auth_key, parameters)\n        events = events.split('\\n')\n        for waf_event in events:\n            event = helper.new_event(source=zone_name,\n                                     index=helper.get_output_index(),\n                                     sourcetype=helper.get_sourcetype(),\n                                     data=waf_event)\n            ew.write_event(event)\n", "customized_options": [{"name": "timestamps", "value": "unix"}, {"name": "earliest_event", "value": "10"}, {"name": "event_count", "value": "6700"}], "uuid": "0c2955d210184562940fb995056cb365", "sample_count": 0}, {"index": "default", "sourcetype": "cloudflare:firewall:rules:ip", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "ip_access_rules", "title": "IP access rules", "description": "IP access rules for all zones", "type": "customized", "parameters": [{"required": true, "name": "mode", "label": "Mode", "default_value": "all", "placeholder": "", "help_string": "", "possible_values": [{"value": "all", "label": "all"}, {"value": "block", "label": "block"}, {"value": "challenge", "label": "challenge"}, {"label": "whitelist", "value": "whitelist"}, {"label": "js_challenge", "value": "js_challenge"}, {"label": "managed_challenge", "value": "managed_challenge"}], "type": "dropdownlist", "format_type": "dropdownlist", "value": "all"}], "data_inputs_options": [{"type": "customized_var", "name": "mode", "title": "Mode", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "all", "label": "all"}, {"value": "block", "label": "block"}, {"value": "challenge", "label": "challenge"}, {"label": "whitelist", "value": "whitelist"}, {"label": "js_challenge", "value": "js_challenge"}, {"label": "managed_challenge", "value": "managed_challenge"}], "format_type": "dropdownlist", "default_value": "all", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input,\nuncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza\n    configurations\n    \"\"\"\n    # This example accesses the modular input variable\n    # checkbox = definition.parameters.get('checkbox', None)\n    pass\n\n\ndef get_zones(auth_email, auth_key):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/',\n            params={\n                \"match\": 'all',\n            },\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        zones = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return zones\n\n\ndef get_rules(zone_id, auth_email, auth_key, parameters):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/' +\n            zone_id + '/firewall/access_rules/rules',\n            params=parameters,\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        rules = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return rules\n\n\ndef collect_events(helper, ew):\n\n    # get global variable configuration\n    auth_key = helper.get_global_setting('x_auth_key')\n    auth_email = helper.get_global_setting('x_auth_email')\n    mode = helper.get_arg('mode')\n\n    if mode == \"all\":\n        parameters = {\n            \"per_page\": 100\n        }\n    else:\n        parameters = {\n            \"per_page\": 100,\n            \"mode\": mode,\n            \"match\": \"any\"\n        }\n\n    response = get_zones(auth_email, auth_key)\n    zones = json.loads(response)\n    for zone in zones[\"result\"]:\n        zone_id = zone[\"id\"]\n        zone_name = zone[\"name\"]\n        response = get_rules(zone_id, auth_email, auth_key, parameters)\n        rules = json.loads(response)\n        for rule in rules[\"result\"]:\n            rule = json.dumps(rule)\n            event = helper.new_event(source=zone_name,\n                                     index=helper.get_output_index(),\n                                     sourcetype=helper.get_sourcetype(),\n                                     data=rule)\n            ew.write_event(event)\n", "customized_options": [{"name": "mode", "value": "all"}], "uuid": "8b2e55f491c3428d87166e50f2b97d1a", "sample_count": 0}, {"index": "default", "sourcetype": "cloudflare:zone:rules:page", "interval": "86400", "use_external_validation": true, "streaming_mode_xml": true, "name": "page_rules", "title": "Page rules", "description": "Page rules for all zones", "type": "customized", "parameters": [{"required": true, "name": "status", "label": "Status", "default_value": "all", "placeholder": "", "help_string": "", "possible_values": [{"value": "all", "label": "all"}, {"value": "active", "label": "active"}, {"value": "disabled", "label": "disabled"}], "type": "dropdownlist", "format_type": "dropdownlist", "value": "all"}], "data_inputs_options": [{"type": "customized_var", "name": "status", "title": "Status", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "all", "label": "all"}, {"value": "active", "label": "active"}, {"value": "disabled", "label": "disabled"}], "format_type": "dropdownlist", "default_value": "all", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nimport requests\nimport json\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input,\nuncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza\n    configurations\n    \"\"\"\n    # This example accesses the modular input variable\n    # checkbox = definition.parameters.get('checkbox', None)\n    pass\n\n\ndef get_zones(auth_email, auth_key):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/',\n            params={\n                \"match\": 'all',\n            },\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        zones = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return zones\n\n\ndef get_rules(zone_id, auth_email, auth_key, parameters):\n\n    try:\n        response = requests.get(\n            url='https://api.cloudflare.com/client/v4/zones/' +\n            zone_id + '/pagerules',\n            params=parameters,\n            headers={\n                \"X-Auth-Email\": auth_email,\n                \"X-Auth-Key\": auth_key,\n                \"Content-Type\": \"application/json\",\n            },\n        )\n        rules = response.content\n    except requests.exceptions.RequestException:\n        print('HTTP Request failed')\n    return rules\n\n\ndef collect_events(helper, ew):\n\n    # get global variable configuration\n    auth_key = helper.get_global_setting('x_auth_key')\n    auth_email = helper.get_global_setting('x_auth_email')\n    status = helper.get_arg('status')\n\n    if status == \"all\":\n        parameters = {\n            \"per_page\": 100,\n        }\n    else:\n        parameters = {\n            \"per_page\": 100,\n            \"status\": status\n        }\n\n    response = get_zones(auth_email, auth_key)\n    zones = json.loads(response)\n    for zone in zones[\"result\"]:\n        zone_id = zone[\"id\"]\n        zone_name = zone[\"name\"]\n        response = get_rules(zone_id, auth_email, auth_key, parameters)\n        rules = json.loads(response)\n        for rule in rules[\"result\"]:\n            rule = json.dumps(rule)\n            event = helper.new_event(source=zone_name,\n                                     index=helper.get_output_index(),\n                                     sourcetype=helper.get_sourcetype(),\n                                     data=rule)\n            ew.write_event(event)\n", "customized_options": [{"name": "status", "value": "all"}], "uuid": "4de0124a6ddc416b8a0e4981a0a3322b", "sample_count": 0}]}, "field_extraction_builder": {"cloudflare:af:events": {"data_format": "json"}, "cloudflare:firewall:rules": {"is_parsed": true, "data_format": "json"}, "cloudflare:firewall:rules:ip": {"is_parsed": true, "data_format": "json"}, "cloudflare:waf:events": {"is_parsed": true, "data_format": "json"}, "cloudflare:zone:rules:page": {"is_parsed": true, "data_format": "json"}, "cloudflare:zone:settings": {"is_parsed": true, "data_format": "json"}}, "global_settings_builder": {"global_settings": {"log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"required": true, "name": "x_auth_email", "label": "X-Auth 