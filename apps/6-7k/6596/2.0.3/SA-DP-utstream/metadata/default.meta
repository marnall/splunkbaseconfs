[collections/backup_utstream_discovery_inventory]
access = read: [ admin, sc_admin, utstream_admin ], write : [ admin, sc_admin, utstream_admin ]

[savedsearches/Backup%20Gen%20-%20backup_utstream_discovery_inventory]
