[commands/criblqueue]
access = read: [ admin, sc_admin, utstream_writer ], write : [ admin, sc_admin, utstream_writer ]
export = system

[commands/criblsearch]
access = read: [ admin, sc_admin, utstream_reader ], write : [ admin, sc_admin, utstream_reader ]
