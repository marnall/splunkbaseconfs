# App wide setting

[]
access = read: [ * ], write : [ utstream_admin, admin, sc_admin ]
export = system

# Settings for dashboards

[views/account_setup]
access = read: [ utstream_admin, admin, sc_admin ], write : [ utstream_admin, admin, sc_admin ]
export = none

[views/instance_setup]
access = read: [ utstream_admin, admin, sc_admin ], write : [ utstream_admin, admin, sc_admin ]
export = none

[views/monitoring]
access = read: [ admin, sc_admin, utstream_admin ], write : [ admin, sc_admin, utstream_admin ]
export = none

[views/command_usage]
access = read: [ admin, sc_admin, utstream_admin ], write : [ admin, sc_admin, utstream_admin ]

[views/access_violations]
access = read: [ admin, sc_admin, utstream_admin ], write : [ admin, sc_admin, utstream_admin ]

[views/general_setup]
access = read : [ admin, sc_admin, utstream_admin ], write : [ admin, sc_admin, utstream_admin ]

[views/utstream_setup]
access = read : [ admin, sc_admin, utstream_admin ], write : [ admin, sc_admin, utstream_admin ]

# Settings for kv stores

[collections/utstream_discovery_jobs]
