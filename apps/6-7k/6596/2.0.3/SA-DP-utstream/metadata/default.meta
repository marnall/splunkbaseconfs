[collections/utstream_discovery_inventory]
access = read: [ utstream_reader ], write : [ admin, sc_admin, utstream_writer ]

[collections/utstream_discovery_results]
access = read: [ utstream_reader ], write : [ admin, sc_admin, utstream_writer ]

[collections/utstream_replay_jobs]
access = read: [ utstream_reader ], write : [ admin, sc_admin, utstream_writer ]

[collections/utstream_replay_inventory]
access = read: [ utstream_reader ], write : [ admin, sc_admin, utstream_writer ]

