{"alert_action_builder": {"modular_alerts": [{"description": "Create a task in Clickup", "largeIcon": "", "smallIcon": "", "label": "Create task in ClickUp", "short_name": "create_ticket_in_clickup", "parameters": [{"format_type": "text", "required": true, "name": "clickup_list_id", "label": "Clickup list ID", "default_value": "", "help_string": "To find a list, go to your clickup list and take the second integer value (such as 10000000) from the url\nhttps://app.clickup.com/123123123/v/l/li/10000000", "type": "", "value": ""}, {"format_type": "text", "required": true, "name": "clickup_task_name", "label": "Clickup task name", "default_value": "", "help_string": "", "type": "", "value": ""}, {"format_type": "text", "required": false, "name": "clickup_task_description", "label": "Clickup task description", "default_value": "", "help_string": "To reference values in the alert search result use this format: $result.client_ip$", "type": "", "value": ""}], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n\n    helper.log_info(\"Alert action create_ticket_in_clickup started.\")\n\n    # Code based off https://clickup.com/api/clickupreference/operation/CreateTask/\n    \n    import requests\n\n    clickup_personal_api_token = helper.get_global_setting(\"clickup_api_key\")\n\n    clickup_list_id = helper.get_param(\"clickup_list_id\")\n    helper.log_info(\"clickup_list_id={}\".format(clickup_list_id))\n\n    clickup_task_name = helper.get_param(\"clickup_task_name\")\n    helper.log_info(\"clickup_task_name={}\".format(clickup_task_name))\n\n    clickup_task_description = helper.get_param(\"clickup_task_description\")\n    helper.log_info(\"clickup_task_description={}\".format(clickup_task_description))\n\n\n    list_id = clickup_list_id\n    url = \"https://api.clickup.com/api/v2/list/\" + list_id + \"/task\"\n\n    query = {\n      \"custom_task_ids\": \"true\"\n    }\n    \n    payload = {\n      \"name\": clickup_task_name,\n      # description only in plaintext\n#      \"description\": clickup_task_description\n        # description in markdown format    \n      \"markdown_content\": clickup_task_description \n    }\n    \n    headers = {\n      \"Content-Type\": \"application/json\",\n      \"Authorization\": clickup_personal_api_token\n    }\n    \n    response = requests.post(url, json=payload, headers=headers, params=query)\n    \n    data = response.json()\n\n    helper.log_info(\"clickup_task_name={}\".format(data))\n    print(data)\n    \n\n    return 0\n", "uuid": "bbcf132c796b46938410d622a59c5dda"}]}, "basic_builder": {"appname": "alert_clickup", "friendly_name": "ClickUp alert for creating tasks", "version": "1.0.6", "author": "Maciej Duda", "description": "Create simple tasks with title and description in ClickUp via API.", "theme": "#7B68EE", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.1.3", "tab_build_no": "0", "build_no": 9}, "global_settings_builder": {"global_settings": {"customized_settings": [{"format_type": "password", "required": true, "name": "clickup_api_key", "label": "Clickup API key", "default_value": "", "help_string": "How to get API key https://clickup.com/api/developer-portal/authentication", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1688472721_16"}}