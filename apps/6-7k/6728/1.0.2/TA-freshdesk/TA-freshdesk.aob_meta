{"alert_action_builder": {"modular_alerts": [{"description": "", "label": "freshdesk", "short_name": "freshdesk", "largeIcon": "", "smallIcon": "", "parameters": [{"format_type": "text", "required": true, "name": "freshdesk_url", "label": "Freshdesk URL", "default_value": "", "help_string": "domain.freshdesk.com", "type": "", "value": ""}, {"format_type": "text", "required": true, "name": "alert_description", "label": "Alert Description", "default_value": "", "help_string": "Type here", "type": "", "value": ""}, {"format_type": "text", "required": true, "name": "subject", "label": "Subject", "default_value": "", "help_string": "Type here", "type": "", "value": ""}, {"format_type": "text", "required": true, "name": "email", "label": "Email", "default_value": "", "help_string": "Use single email id only", "type": "", "value": ""}, {"format_type": "dropdownlist", "required": true, "name": "alert_priority", "label": "Alert Priority", "default_value": "low", "help_string": "", "possible_values": {"Low": "low", "Medium": "medium", "High": "high", "Urgent": "urgent"}, "type": "", "value": "urgent"}], "code": "\n# encoding = utf-8\nimport requests\nimport json\nimport base64\nfrom datetime import datetime\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the setup parameters and prints them to the log\n    api_key = helper.get_global_setting(\"api_key\")\n    helper.log_info(\"api_key={}\".format(api_key))\n\n    # The following example gets the alert action parameters and prints them to the log\n    freshdesk_url = helper.get_param(\"freshdesk_url\")\n    helper.log_info(\"freshdesk_url={}\".format(freshdesk_url))\n\n    alert_description = helper.get_param(\"alert_description\")\n    helper.log_info(\"alert_description={}\".format(alert_description))\n\n    subject = helper.get_param(\"subject\")\n    helper.log_info(\"subject={}\".format(subject))\n\n    email = helper.get_param(\"email\")\n    helper.log_info(\"email={}\".format(email))\n\n    alert_priority = helper.get_param(\"alert_priority\")\n    helper.log_info(\"alert_priority={}\".format(alert_priority))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    #helper.log_info(\"Alert action freshdesk started.\")\n    now = datetime.now()\n    current_time = now.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n    freshdesk_url = helper.get_param(\"freshdesk_url\")\n    api_url = \"https://\" + freshdesk_url + \"/api/v2/tickets\" # url for rest api\n    \n    api_key = helper.get_global_setting(\"api_key\") # getting input\n    b = base64.b64encode(bytes(api_key, 'utf-8')) # encoding to base64\n    encoded_api = b.decode('utf-8') # encoded api\n\n    alert_description = helper.get_param(\"alert_description\")\n    alert_description = alert_description +\" (Created at: \"+ current_time +\")\"\n    subject = helper.get_param(\"subject\")\n    email = helper.get_param(\"email\")\n    alert_priority = helper.get_param(\"alert_priority\")\n    \n    # replacing alert_priority string values to numericals\n    if alert_priority == \"low\":\n        alert_p = 1\n    elif alert_priority == \"medium\":\n        alert_p = 2\n    elif alert_priority == \"high\":\n        alert_p = 3\n    elif alert_priority == \"urgent\":\n        alert_p = 4\n\n\n    # header starts here\n    headers = {\n        'Content-Type': 'application/json',\n        'Authorization': f\"Basic {encoded_api}\"\n        }\n\n    # payload starts here\n    payload = json.dumps({\n        \"description\": f\"{alert_description}\",\n        \"subject\": f\"{subject}\",\n        \"email\": f\"{email}\",\n        \"priority\": alert_p,\n        \"status\": 2\n        })\n    \n    response = requests.request(\"POST\", api_url, headers=headers, data=payload)\n    data=response.json()\n    helper.log_info(data)\n\n    # TODO: Implement your alert action logic here\n    return 0\n", "uuid": "103fd914acc74537a9c56e8bf48f3df0"}]}, "basic_builder": {"appname": "TA-freshdesk", "friendly_name": "Freshdesk", "version": "1.0.2", "author": "Lognalytics Technology", "description": "Alert Action to create tickets on Freshdesk", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 4}, "global_settings_builder": {"global_settings": {"customized_settings": [{"format_type": "password", "required": true, "name": "api_key", "label": "API KEY", "default_value": "", "help_string": "abcdefghij1234567890", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1763539316_5"}}