Contains commands for working with structured data like YAML, TOML and wrapps jq up into a splunk command


[jq-command]
syntax      = jq input=<string> filter=<string>
shortdesc   = Processes json in a field with the jq filter syntax provided
description = Processes json in a field with the jq filter syntax provided. \i\\
              "input"    - Name of the field used by this command. \i\\
              "filter"   - jq filter to apply to the field. \i\\
              "output"   - The name of the field where it get output in, default is the field `json`. \i\\

comment1 = pretty print json in the field json.
example1 = | jq field="json" filter="."

[yaml-command]
syntax      = yaml (input=<string>)? (output=<string>)?
shortdesc   = Converts yaml to json
description = Processes yaml in a field and converts it to json. \i\\
              "input"    - Name of the field used by this command, default is `_raw`. \i\\
              "output"   - The name of the field where it get output in, default is the field `json`. \i\\

comment1 = convert yaml to json.
example1 = | yaml 


[toml-command]
syntax      = toml (input=<string>)? (output=<string>)?
shortdesc   = Converts toml to json
description = Processes toml in a field and converts it to json. \i\\
              "input"    - Name of the field used by this command, default is `_raw`. \i\\
              "output"   - The name of the field where it get output in, default is the field `json`. \i\\

comment1 = convert toml to json.
example1 = | toml 