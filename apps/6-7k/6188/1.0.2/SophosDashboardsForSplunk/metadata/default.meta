
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]
export = none


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system


# Restricting the READ/WRITE access of macros to App namespace only

[macros]
export = none
