{"basic_builder": {"appname": "TA-radiflow-addon-for-splunk", "friendly_name": "Radiflow Addon For Splunk", "version": "1.0.3", "author": "", "description": "", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.2", "tab_build_no": "0", "build_no": 1}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "Radiflow:Assets", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "assets_input", "title": "Assets Input", "description": "", "type": "customized", "parameters": [{"name": "radiflow_account", "label": "Radiflow Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": ""}, {"required": true, "name": "site_id", "label": "Site Id", "default_value": "", "placeholder": "", "help_string": "Please provide the Site Id ", "type": "text", "format_type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "radiflow_account", "title": "Radiflow Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "site_id", "title": "Site Id", "description": "Please provide the Site Id ", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport json\nimport datetime\nimport requests\nfrom radiflow_rest_client import get_all_assets,get_detailed_device_info\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # radiflow_account = definition.parameters.get('radiflow_account', None)\n    pass\n\ndef collect_events(helper, ew):\n    try:\n        all_assets = get_all_assets(helper)\n        if all_assets==None:\n            pass\n        else:\n            for asset in all_assets:\n                asset_id = asset['id']\n                get_detailed_device_info(asset_id,helper,ew)\n            helper.log_info(f\"Found {len(all_assets)} Assets!\")\n    except Exception as e:\n        sourcetype = \"RadiFlowAddonForSplunk:error\"\n        data = str(e)\n        input_type = helper.get_input_type()\n        event = helper.new_event(source=input_type, index=helper.get_output_index(), sourcetype=sourcetype, data=data)\n        ew.write_event(event)\n        \n    ", "customized_options": [{"name": "radiflow_account", "value": ""}, {"name": "site_id", "value": ""}], "uuid": "427475144237442f89cb77ae102df8fd", "sample_count": "462"}, {"index": "default", "sourcetype": "Radiflow:Alerts", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "alerts_input", "title": "Alerts Input", "description": "", "type": "customized", "parameters": [{"name": "radiflow_account", "label": "Radiflow Account", "help_string": "", "required": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": "", "type": "global_account", "value": ""}, {"required": true, "name": "historical_polling_days", "label": "Historical Polling Days", "default_value": "10", "placeholder": "", "help_string": "Please Provide Historical Polling Days", "type": "text", "format_type": "text", "value": "10"}, {"name": "site_id", "label": "site_id", "help_string": "Please provide the Site Id ", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": ""}], "data_inputs_options": [{"type": "customized_var", "name": "radiflow_account", "title": "Radiflow Account", "description": "", "required_on_edit": false, "required_on_create": true, "possible_values": [], "format_type": "global_account", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "historical_polling_days", "title": "Historical Polling Days", "description": "Please Provide Historical Polling Days", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "10", "placeholder": ""}, {"type": "customized_var", "name": "site_id", "title": "site_id", "description": "Please provide the Site Id ", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\nfrom radiflow_rest_client import get_all_alerts, set_last_polled_timestamp\nimport json\nimport logging\nfrom splunk.appserver.mrsparkle.lib.util import make_splunkhome_path\n\n\n# _APP_NAME = 'RadiFlowAddOnForSplunk'\n\n# log_location = make_splunkhome_path(['var', 'log', 'splunk', _APP_NAME])\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    # This example accesses the modular input variable\n    # radiflow_account = definition.parameters.get('radiflow_account', None)\n    pass\n\ndef collect_events(helper, ew):\n    source = helper.get_arg('name')\n    opt_radiflow_account = helper.get_arg('radiflow_account')\n    site_id = helper.get_arg(\"site_id\")\n    all_opened_alerts = get_all_alerts(helper)\n    now = datetime.utcnow()\n    sourcetype = \"Radiflow:Alerts\"\n    total_alerts = 0\n    for alert in all_opened_alerts:\n        alert.update({\"site_id\":site_id})\n        alert_new = json.dumps(alert)\n        event = helper.new_event(source=source, index=helper.get_output_index(), sourcetype=sourcetype, data=alert_new)\n        ew.write_event(event)\n        total_alerts += 1\n    logging.info(f'Wrote the event {total_alerts}')\n    # if total_alerts > 0:\n    #     set_last_polled_timestamp(log_location, source, datetime.isoformat(now))\n", "customized_options": [{"name": "radiflow_account", "value": ""}, {"name": "historical_polling_days", "value": "10"}, {"name": "site_id", "value": ""}], "uuid": "b37438c22d8a4802aa9ef18be8834515", "sample_count": "9014"}]}, "field_extraction_builder": {"Radiflow:Assets": {"is_parsed": true, "data_format": "json"}, "Radiflow:Alerts": {"is_parsed": true, "data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {"log_level": "DEBUG"}, "credential_settings": []}}, "sourcetype_builder": {"Radiflow:Assets": {"metadata": {"event_count": 0, "data_input_name": "assets_input", "extractions_count": 0, "cims_count": 0}}, "Radiflow:Alerts": {"metadata": {"event_count": 0, "data_input_name": "alerts_input", "extractions_count": 0, "cims_count": 0}}}, "validation": {}}