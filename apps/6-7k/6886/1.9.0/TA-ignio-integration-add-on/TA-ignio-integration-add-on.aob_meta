{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "ignio integration", "short_name": "ignio_integration", "parameters": [{"format_type": "dropdownlist", "required": true, "name": "alert_severity", "label": "Alert Severity", "default_value": "Critical", "help_string": "", "possible_values": {"Warning": "Warning", "Minor": "Minor", "Major": "Major", "Critical": "Critical"}, "type": "", "value": "Critical"}], "code": "# encoding = utf-8\r\nimport json\r\nimport os\r\nimport requests\r\nimport configparser\r\nimport logging\r\nfrom urllib.parse import urlparse\r\nimport uuid\r\n\r\nlogger = logging.getLogger()\r\n\r\ndef setup_logger(logLevel):\r\n    logger = logging.getLogger()\r\n    LOGGING_FILE_NAME = \"ignio_alert_integration.log\"\r\n    SPLUNK_HOME = os.environ['SPLUNK_HOME']\r\n    BASE_LOG_PATH = os.path.join('var', 'log', 'splunk')\r\n    directory = os.path.join(SPLUNK_HOME, BASE_LOG_PATH)\r\n\r\n    if not os.path.exists(directory):\r\n        os.makedirs(directory)\r\n\r\n    LOGGING_FORMAT = \"%(asctime)s %(levelname)-s\\t%(module)s:%(lineno)d - %(message)s\"\r\n    handler = logging.handlers.RotatingFileHandler(os.path.join(SPLUNK_HOME, BASE_LOG_PATH, LOGGING_FILE_NAME), mode='a', maxBytes=10024000, backupCount=100)\r\n    formatter = logging.Formatter(LOGGING_FORMAT)\r\n    handler.setFormatter(formatter)\r\n    logger.addHandler(handler)\r\n    loggerLevel = get_log_level(logLevel)\r\n    logger.setLevel(loggerLevel)\r\n    logger.debug('Logger initialized')\r\n    return logger\r\n\r\ndef process_event(helper, *args, **kwargs):\r\n    try:\r\n        logLevel = helper.get_log_level()\r\n        logger = setup_logger(logLevel)\r\n        logger.info(\"Alert action started.\")\r\n        SPLUNK_HOME = os.environ['SPLUNK_HOME']\r\n        configfile = os.path.join(SPLUNK_HOME, 'etc', 'apps', 'TA-ignio-integration-add-on', 'default', 'ignio.conf')\r\n        config = configparser.RawConfigParser()\r\n        config.read(configfile)\r\n\r\n        jsonMap = config.get('JSONMAP', 'jsonMap')\r\n\r\n        ignio_Url = helper.get_global_setting(\"ignio_url\")\r\n        apigee_Url = helper.get_global_setting(\"apigee_url\")\r\n        if ignio_Url and ignio_Url.startswith(\"https\") is False:\r\n            logger.error(\"Splunk Cloud requires https\")\r\n            return 0\r\n        if apigee_Url and apigee_Url.startswith(\"https\") is False:\r\n            logger.error(\"Splunk Cloud requires https\")\r\n            return 0\r\n\r\n        auth_Token = helper.get_global_setting(\"auth_token\")\r\n        apigee_id = helper.get_global_setting(\"apigee_id\")\r\n        apigee_secret = helper.get_global_setting(\"apigee_secret\")\r\n        severity = helper.get_param(\"alert_severity\")\r\n\r\n        resdata = json.loads(jsonMap)\r\n\r\n        events = helper.get_events()\r\n        count = 0\r\n        eventDict = {\"externalRecords\":[]}\r\n\r\n        for event in events:\r\n            count += 1\r\n            eventExternalID = \"e_splunk_\" + str(count) + \"_\" + str(uuid.uuid4().hex)\r\n\r\n            event[\"server_host\"] = helper.settings.get(\"server_host\")\r\n            event[\"alert_title\"] = helper.settings.get(\"search_name\")\r\n            event[\"alert_description\"] = helper.settings.get(\"configuration\").get(\"alert_description\")\r\n            event[\"severity\"] = severity\r\n\r\n            externalEvent = {\"externalId\":str(eventExternalID),\"properties\":event}\r\n            eventDict[\"externalRecords\"].append(externalEvent)\r\n\r\n            logger.debug(\"event: \" + str(event))\r\n\r\n        resdata.update(eventDict)\r\n\r\n        logger.info(\"Total count of events received: \" + str(count))\r\n\r\n        # Proxy Configuration if present\r\n        proxyConfig = None\r\n        proxyUri = get_proxyInfo(helper)\r\n\r\n        if proxyUri is not None:\r\n            proxy_http = proxyUri\r\n            proxy_https = proxyUri\r\n            logger.debug(\"Using proxy as {0}\".format(proxyUri))\r\n            proxyConfig = {'https' : proxy_http, 'http': proxy_https}\r\n            logger.debug(proxyConfig)\r\n        \r\n        apigeeToken = None\r\n        if apigee_id and apigee_secret and apigee_Url:\r\n            apigeeToken = get_apigee_token(helper, apigee_Url, apigee_id, apigee_secret, proxyConfig)\r\n        post_message(helper, ignio_Url, auth_Token, apigeeToken, resdata, proxyConfig)\r\n\r\n    except Exception as exc:\r\n        logger.error(str(exc))\r\n\r\n    return 0\r\n\r\ndef get_proxyInfo(helper):\r\n    proxyUri = None\r\n    proxyInfo = helper.get_proxy()\r\n    logger.debug(proxyInfo)\r\n\r\n    if proxyInfo and proxyInfo.get('proxy_url') and proxyInfo.get('proxy_type'):\r\n        proxyUri = proxyInfo['proxy_url']\r\n        if proxyInfo.get('proxy_port'):\r\n            proxyUri = '{0}:{1}'.format(proxyUri, proxyInfo.get('proxy_port'))\r\n            if proxyInfo.get('proxy_username') and proxyInfo.get('proxy_password'):\r\n                proxyUri = '{0}://{1}:{2}@{3}/'.format(proxyInfo['proxy_type'], proxyInfo['proxy_username'], proxyInfo['proxy_password'], proxyUri)\r\n            else:\r\n                proxyUri = '{0}://{1}'.format(proxyInfo['proxy_type'], proxyUri)\r\n\r\n    logger.debug(\"Using proxy as {0}\".format(proxyUri))\r\n\r\n    return proxyUri\r\n\r\ndef get_apigee_token(helper, apigee_Url, apigee_id, apigee_secret, proxyConfig):\r\n    \r\n    logger.debug(\"Getting the access token from apigee\")\r\n    \r\n    url = apigee_Url\r\n    \r\n    try:\r\n        payload = {'grant_type': 'client_credentials'}\r\n        headers = {'Content-Type': 'x-www-form-urlencoded'}\r\n        \r\n        if proxyConfig is None:\r\n            response = requests.post(url, data=payload, auth=(apigee_id, apigee_secret), headers=headers, timeout=60, verify=True)\r\n        else:\r\n            response = requests.post(url, data=payload, auth=(apigee_id, apigee_secret), proxies=proxyConfig, headers=headers, timeout=60, verify=True)\r\n            \r\n        logger.info(\"Request response status: \" +  str(response.status_code))\r\n        responseJson = response.json()\r\n        \r\n        return responseJson['access_token']\r\n        \r\n    except Exception as exception:\r\n        exceptionMsg = str(exception)\r\n        logger.error(\"Exception occured : \" + exceptionMsg)\r\n        raise Exception(\"An error has occurred while executing HTTP POST request to ignio with error message: \" + exceptionMsg)    \r\n\r\ndef post_message(helper, ignio_Url, auth_Token, apigeeToken, data, proxyConfig):\r\n    \r\n    payloadJS = json.dumps(data)\r\n    logger.debug(\"Sending the following event data to ignio: \\n\" + payloadJS)\r\n\r\n    #url = ignio_Url + \"/integration/work/\"\r\n    url = ignio_Url\r\n    \r\n    try:\r\n        if apigeeToken is None:\r\n            headers = {'User-Agent': 'Splunk', 'Content-Type': 'application/json', 'ApplicationAuthorization' : auth_Token}\r\n        else:\r\n            headers = {'User-Agent': 'Splunk', 'Content-Type': 'application/json', 'ApplicationAuthorization' : auth_Token, 'Authorization': 'Bearer ' + str(apigeeToken)}\r\n            \r\n        if proxyConfig is None:\r\n            response = requests.post(url, data=payloadJS, headers=headers, timeout=60, verify=True)\r\n        else:\r\n            response = requests.post(url, proxies=proxyConfig, data=payloadJS, headers=headers, timeout=60, verify=True)\r\n            \r\n        logger.info(\"POST request response status: \" + str(response.status_code))\r\n        logger.info(\"Response received from ignio: \" + str(response.text))\r\n\r\n    except Exception as exception:\r\n        exceptionMsg = str(exception)\r\n        logger.error(\"Exception occured : \" + exceptionMsg)\r\n        raise Exception(\"An error has occurred while executing HTTP POST request to ignio with error message: \" + exceptionMsg)\r\n\r\ndef get_log_level(logLevel):\r\n    switcher={\r\n        \"DEBUG\":logging.DEBUG,\r\n        \"INFO\":logging.INFO,\r\n        \"WARNING\":logging.WARNING,\r\n        \"ERROR\":logging.ERROR,\r\n        \"CRITICAL\":logging.CRITICAL\r\n    }\r\n    return switcher.get(logLevel, logging.INFO)", "uuid": "1be1b1bf7c674424b84490de5dc41999"}]}, "basic_builder": {"appname": "TA-ignio-integration-add-on", "friendly_name": "ignio integration add on", "version": "1.6.0", "author": "", "description": "", "theme": "#38b8bf", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.3.0", "tab_build_no": "0", "build_no": 1}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http"}, "log_settings": {}, "customized_settings": [{"format_type": "text", "required": true, "name": "ignio_url", "label": "ignio URL", "default_value": "", "help_string": "", "internal_name": "", "type": "text", "value": ""}, {"format_type": "password", "required": true, "name": "auth_token", "label": "Auth Token", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}, {"format_type": "text", "required": false, "name": "apigee_url", "label": "apigee URL", "default_value": "", "help_string": "", "internal_name": "", "type": "text", "value": ""}, {"format_type": "text", "required": false, "name": "apigee_id", "label": "Apigee ID", "default_value": "", "help_string": "", "internal_name": "", "type": "text", "value": ""}, {"format_type": "password", "required": false, "name": "apigee_secret", "label": "Apigee Secret", "default_value": "", "help_string": "", "internal_name": "", "type": "password", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1759504920_39", "progress": 0.75}}