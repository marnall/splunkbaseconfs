
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power, sc_admin ]
export = none

[alert_actions]
export = system

[alerts]
export = system

[collections]
export = system

[commands]
export = system

[eventtypes]
export = system

[lookups]
export = system

[props]
export = system

[transforms]
export = system

[views]
export = system

[visualizations]
export = system

### VIEWSTATES: even normal users should be able to create shared viewstates
[viewstates]
access = read : [ * ], write : [ * ]
export = system
