{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "Send alert to LaMetric", "short_name": "send_alert_to_lametric", "parameters": [{"format_type": "text", "required": true, "name": "alert_message", "label": "Alert message", "default_value": "", "help_string": "", "type": "", "value": ""}, {"format_type": "text", "required": true, "name": "alert_icon", "label": "Alert icon", "default_value": "9047", "help_string": "Icon number sucha as 9047. List of icons is at https://developer.lametric.com/icons", "type": "", "value": "9047"}, {"format_type": "dropdownlist", "required": true, "name": "notification_sound", "label": "Notification sound", "default_value": "cat", "help_string": "", "possible_values": {"cat": "cat", "notification": "notification", "notification2": "notification2", "notification3": "notification3", "notification4": "notification4", "positive1": "positive1", "positive5": "positive5", "negative1": "negative1"}, "type": "", "value": "positive5"}], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the setup parameters and prints them to the log\n    lametric_api_key = helper.get_global_setting(\"lametric_api_key\")\n    helper.log_info(\"lametric_api_key={}\".format(lametric_api_key))\n    lametric_ip_address = helper.get_global_setting(\"lametric_ip_address\")\n    helper.log_info(\"lametric_ip_address={}\".format(lametric_ip_address))\n\n    # The following example gets the alert action parameters and prints them to the log\n    alert_message = helper.get_param(\"alert_message\")\n    helper.log_info(\"alert_message={}\".format(alert_message))\n\n    alert_icon = helper.get_param(\"alert_icon\")\n    helper.log_info(\"alert_icon={}\".format(alert_icon))\n\n    notification_sound = helper.get_param(\"notification_sound\")\n    helper.log_info(\"notification_sound={}\".format(notification_sound))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action send_alert_to_lametric started.\")\n    \n    import requests\n    from urllib3.exceptions import InsecureRequestWarning\n    import base64\n    from requests.auth import HTTPBasicAuth\n\n    alert_message = helper.get_param(\"alert_message\")\n    alert_icon = helper.get_param(\"alert_icon\")\n    notification_sound = helper.get_param(\"notification_sound\")\n\n    lametric_api_key = helper.get_global_setting(\"lametric_api_key\")\n    lametric_ip_address = helper.get_global_setting(\"lametric_ip_address\")\n\n    # user \"dev\" is hardcoded by LaMetric\n    # see: https://lametric-documentation.readthedocs.io/en/latest/reference-docs/device-authorization.html\n    basic = HTTPBasicAuth('dev', lametric_api_key)\n\n    url = \"https://\"+lametric_ip_address+\":4343/api/v2/device/notifications\"\n    \n    payload = {\n      \"priority\": \"warning\",\n      \"model\": {\n          \"cycles\": 1,\n          \"frames\": [\n          {\n              \"icon\": alert_icon,\n              \"text\": alert_message\n          } ],\n          \"sound\": {\n              \"category\": \"notifications\",\n              \"id\": notification_sound\n          }\n      }\n  }\n    headers = {\n        \"Content-Type\": \"application/json\"\n    }\n    \n    # lametric supports https, however the certificate is self-signed\n    # this code disables alerts about verify=False\n    requests.packages.urllib3.disable_warnings(category=InsecureRequestWarning)\n    response = requests.request(\"POST\", url, json=payload, headers=headers, auth=basic, verify=False)\n    \n    print(response.text)\n    return 0\n", "uuid": "b1954bbbb3ec49eabb65a19f2e7c12d4"}]}, "basic_builder": {"appname": "TA-lametric-alert-for-lan", "friendly_name": "LaMetric alert for LAN", "version": "1.0.1", "author": "Maciej Duda", "description": "Sends API call directly to the LaMetric device to trigger instant notification. Works only on the same local network as the LaMetric device.", "theme": "#000000", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.1.3", "tab_build_no": "0", "build_no": 2}, "global_settings_builder": {"global_settings": {"customized_settings": [{"format_type": "password", "required": true, "name": "lametric_api_key", "label": "Lametric API key", "default_value": "", "help_string": "https://lametric-documentation.readthedocs.io/en/latest/guides/first-steps/first-local-notification.html#find-api-key", "internal_name": "", "type": "password", "value": ""}, {"format_type": "text", "required": true, "name": "lametric_ip_address", "label": "LaMetric IP address", "default_value": "", "help_string": "https://lametric-documentation.readthedocs.io/en/latest/guides/first-steps/first-local-notification.html#discover-ip-address", "internal_name": "", "type": "text", "value": ""}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1688061825_8", "progress": 1.0}}