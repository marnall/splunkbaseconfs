{"basic_builder": {"appname": "TA-kemp-add-on-for-splunk", "friendly_name": "Kemp Add-on for Splunk", "version": "1.1.1", "author": "stuart@idelta.co.uk", "description": "Make API calls to Kemp Load balancer to extract meta-data and stats", "theme": "#5DE601", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.4", "tab_build_no": "0", "build_no": 6}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "kemp:generic", "interval": "300", "use_external_validation": true, "streaming_mode_xml": true, "name": "generic_cmd", "title": "Generic cmd", "description": "Provide the API cmd to run", "type": "rest", "parameters": [{"required": true, "name": "kemp_server", "label": "Kemp Server", "default_value": "", "placeholder": "", "help_string": "Kemp hostname or IP address", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "cmd", "label": "cmd", "default_value": "", "placeholder": "", "help_string": "The API command to run", "type": "text", "format_type": "text", "value": ""}, {"required": true, "name": "api_key", "label": "API Key", "placeholder": "", "default_value": "", "help_string": "", "type": "password", "format_type": "password", "value": ""}], "data_inputs_options": [{"name": "_rest_api_url", "rest_header": false, "description": "url", "value": "https://${kemp_server}/accessv2"}, {"name": "_rest_api_method", "rest_header": false, "description": "method", "value": "POST"}, {"name": "apikey", "value": "${api_key}", "rest_header": false, "description": "apikey"}, {"name": "cmd", "value": "${cmd}", "rest_header": false, "description": "cmd"}, {"type": "event_json_path_key", "name": "_event_json_path_key", "value": ""}, {"type": "ckpt_enable", "name": "_ckpt_enable", "value": false}, {"type": "ckpt_var_name", "name": "_ckpt_var_name", "value": ""}, {"type": "ckpt_json_path_key", "name": "_ckpt_json_path_key", "value": ""}, {"type": "ckpt_initial_value", "name": "_ckpt_initial_value", "value": ""}, {"type": "ckpt_source_time_format", "name": "_ckpt_source_time_format", "value": ""}, {"type": "ckpt_target_time_format", "name": "_ckpt_target_time_format", "value": ""}, {"type": "customized_var", "name": "kemp_server", "title": "Kemp Server", "description": "Kemp hostname or IP address", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "cmd", "title": "cmd", "description": "The API command to run", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_key", "title": "API Key", "description": "", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}], "use_basic_auth": false, "customized_options": [{"name": "kemp_server", "value": "192.168.178.44"}, {"name": "cmd", "value": "listvs"}], "uuid": "ad0029fdcb764cbfa9365fc110e0c7db"}, {"index": "default", "sourcetype": "kemp:vstotals", "interval": "30", "use_external_validation": true, "streaming_mode_xml": true, "name": "get_vs_totals", "title": "Get VS Totals", "description": "Gets summary VS stats", "type": "rest", "parameters": [{"name": "kemp_server", "label": "Kemp Server", "help_string": "Kemp Server hostname or IP Address", "required": true, "format_type": "text", "default_value": "", "placeholder": "", "type": "text", "value": "192.168.178.44"}, {"name": "api_key", "label": "API Key", "help_string": "", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "Posl0qEvBFPoMinwti320MI5YOcMSe0PKuVfehdpOpIz"}], "data_inputs_options": [{"name": "_rest_api_url", "rest_header": false, "description": "url", "value": "https://${kemp_server}/accessv2"}, {"name": "_rest_api_method", "rest_header": false, "description": "method", "value": "POST"}, {"name": "apikey", "value": "${api_key}", "res