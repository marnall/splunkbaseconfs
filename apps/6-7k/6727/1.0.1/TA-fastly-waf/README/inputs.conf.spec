[fastly_corp_events://<name>]
time_delta = This is the interval of time for the input to pull data from the API. This Should be set to the same value as the input Interval

[fastly_site_events://<name>]
site_api_name = This is the API Name for the site it should NOT include a full URL.
time_delta = This is the period of time to pull from the Fastly API. It should be set to the exact same setting at the Input Interval

[fastly_requests://<name>]
site_api_name = This is the API Name of the site. It should NOT be a URL
time_delta = This is the period of time to pull from the Fastly API. It should be set to the exact same setting at the Input Interval