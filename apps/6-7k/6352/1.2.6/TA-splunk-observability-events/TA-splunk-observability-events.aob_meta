{"alert_action_builder": {"modular_alerts": [{"description": "Send Enterprise Security data to Splunk Observability", "appname": "TA-splunk-observability-events", "friendly_name": "Splunk Observability Events", "name": "splunk-observability-events", "version": "1.2.5", "author": "Jeremy Hicks", "visible": true, "largeIcon": "", "smallIcon": "", "label": "Enterprise Security to Splunk Observability", "short_name": "enterprise_security_to_splunk_observability", "active_response": {"technology": [{"vendor": "Splunk", "product": "Observability", "version": ["0.0.1"]}], "supports_adhoc": true, "category": ["Information Conveyance"], "task": ["update"], "subject": ["splunk.event"]}, "parameters": [{"format_type": "text", "required": true, "name": "realm", "label": "realm", "default_value": "", "help_string": "", "type": "", "value": "us0"}, {"format_type": "text", "required": true, "name": "info_field", "label": "Info field (title)", "default_value": "", "help_string": "", "type": "", "value": "beep"}, {"format_type": "text", "required": false, "name": "included_fields", "label": "Included fields", "default_value": "", "help_string": "", "type": "", "value": "source, index"}], "code": "\n# encoding = utf-8\nimport requests\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the setup parameters and prints them to the log\n    observability_api_token = helper.get_global_setting(\"observability_api_token\")\n    helper.log_info(\"observability_api_token={}\".format(observability_api_token))\n\n    # The following example gets the alert action parameters and prints them to the log\n    realm = helper.get_param(\"realm\")\n    helper.log_info(\"realm={}\".format(realm))\n\n    info_field = helper.get_param(\"info_field\")\n    helper.log_info(\"info_field={}\".format(info_field))\n\n    included_fields = helper.get_param(\"included_fields\")\n    helper.log_info(\"included_fields={}\".format(included_fields))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n    \n    ## Get settings\n    observability_api_token = helper.get_global_setting(\"observability_api_token\")\n    realm = helper.get_param(\"realm\")\n    headers = {\"X-SF-Token\" : observability_api_token, \"Content-Type\": \"application/json\"}\n    \n    # Get parameters\n    info_field = helper.get_param(\"info_field\")\n    info_string = \"\"\n    fields = \"\"\n    included_fields = helper.get_param(\"included_fields\")\n    ## We strip spaces and make a list here from included_fields\n    if included_fields:\n        included_fields = list(included_fields.replace(\" \", \"\").split(\",\"))\n    \n    # Go down the logic train\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n        if event[\"source\"]:\n            source = event[\"source\"]\n        else:\n            source = \"NaN\"\n        if helper.settings[\"search_name\"]:\n            search_name = helper.settings[\"search_name\"]\n        else:\n            search_name = \"NaN\"\n        if helper.settings[\"server_uri\"]:\n            server_uri = helper.settings[\"server_uri\"]\n        else:\n            server_uri = \"NaN\"\n        if helper.settings[\"results_link\"]:\n            results_link = helper.settings[\"results_link\"]\n        else:\n            results_link = \"NaN\"\n        ### Build our fields and info string. This is ugly.\n        if included_fields and isinstance(included_fields, list):\n            for i in included_fields:\n                fields += '\\\"' + str(i)+ '\\\":' '\\\"' + event[str(i)] + '\\\", '\n        if info_field:\n            info_string = '\\\"' + \"info\" + '\\\":' '\\\"' + info_field + '\\\", '\n    \n        url = 'https://ingest.'+ realm + '.signalfx.com/v2/event'\n        myobj = '[{\\\"category\\\": \\\"USER_DEFINED\\\",\\\"eventType\\\": \\\"' + search_name + '\\\" ,\\\"dimensions\\\": {' + str(info_string) + str(fields) + '\\\"results_link\\\": \\\"' + results_link + '\\\", \\\"splunk_server_uri\\\": \\\"' + server_uri + '\\\"}}]'\n    \n        x = requests.post(url, headers=headers, data=myobj)\n        response_status_code = str(x.status_code)\n        helper.log_warn(\"Request JSON was:  \" + str(myobj) + \"Response was:  \" + response_status_code)\n            \n    return 0\n", "uuid": "bf85b2507a9b4ba7b3ca97b1877d3ffe"}]}, "basic_builder": {"appname": "TA-splunk-observability-events", "friendly_name": "Splunk Observability Events", "version": "1.2.6", "author": "Jeremy Hicks", "description": "Send Splunk data to Splunk Observability", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.5.0", "tab_build_no": "0", "build_no": 2}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1758637368_17", "progress": 1.0}}