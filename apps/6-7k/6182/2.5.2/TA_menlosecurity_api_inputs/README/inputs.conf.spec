[menlo_log_api://<name>]
api_token = Menlo API token
api_version = 
log_type = The type of Menlo Security Isolation Platform logs to fetch
remove_na_fields = Remove all fields with the value of "NA" from the events.
max_page_size = The maximum number of events to retrieve per API call
api_batch_span = The maximum timespan used per API call
settling_time = The number of seconds to allow for log events to be available via the API call
api_query = Query to be passed-on via a query parameter in the API call
backfill_start_days = The number of days to backfill data on the first run of the input