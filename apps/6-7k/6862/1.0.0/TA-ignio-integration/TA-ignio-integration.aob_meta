{"alert_action_builder": {"modular_alerts": [{"description": "", "largeIcon": "", "smallIcon": "", "label": "Ignio Alert Integration", "short_name": "ignio_alert_integration", "parameters": [{"format_type": "text", "required": true, "name": "severity", "label": "Severity", "default_value": "", "help_string": "", "type": "", "value": "critical"}, {"format_type": "text", "required": true, "name": "ignio_url", "label": "Ignio URL", "default_value": "", "help_string": "", "type": "", "value": "https://digitatecto3-uat.onignio.com/integration/work/"}, {"format_type": "text", "required": true, "name": "auth_key", "label": "Auth Token", "default_value": "", "help_string": "", "type": "", "value": "Y2lwaGVye280SmxrS3NzUmNnOGg4d1F0RjhrTVZGZDFRU25Ya3hiN3o4M29ZY3JPN3FDek1rOWZQbzdSbjBabHdzN3lyZE1wK3RsRFo4L2hTay92V2t5Qzg2cFVJQ0lkcTg9fQ=="}], "code": "\n# encoding = utf-8\nimport json\nimport sys, os\nimport requests\nimport requests.auth\nimport configparser\nimport logging\nimport socket\nimport ssl\nfrom urllib.parse import urlparse\nimport uuid\n\nlogger = logging.getLogger()\n\ndef setup_logger(logLevel):\n    logger = logging.getLogger()\n    LOGGING_STANZA_NAME = 'python'\n    LOGGING_FILE_NAME = \"ignio_alert_integration.log\"\n    SPLUNK_HOME = os.environ['SPLUNK_HOME']\n    BASE_LOG_PATH = os.path.join('var', 'log', 'splunk')\n    directory = os.path.join(SPLUNK_HOME, BASE_LOG_PATH)\n\n    if not os.path.exists(directory):\n        os.makedirs(directory)\n\n    LOGGING_FORMAT = \"%(asctime)s %(levelname)-s\\t%(module)s:%(lineno)d - %(message)s\"\n    LOGGING_FILE = os.path.join(SPLUNK_HOME, BASE_LOG_PATH, LOGGING_FILE_NAME)\n    handler = logging.handlers.RotatingFileHandler(os.path.join(SPLUNK_HOME, BASE_LOG_PATH, LOGGING_FILE_NAME), mode='a', maxBytes=10024000, backupCount=100)\n    formatter = logging.Formatter(LOGGING_FORMAT)\n    handler.setFormatter(formatter)\n    logger.addHandler(handler)\n    loggerLevel = get_log_level(logLevel)\n    logger.setLevel(loggerLevel)\n    logger.debug('Logger initialized')\n    return logger\n\ndef process_event(helper, *args, **kwargs):\n    try:\n        logLevel = helper.get_log_level()\n        logger = setup_logger(logLevel)\n        logger.info(\"Alert action started.\")\n        SPLUNK_HOME = os.environ['SPLUNK_HOME']\n        configfile = os.path.join(SPLUNK_HOME, 'etc', 'apps', 'TA-ignio-integration', 'default', 'ignio.conf')\n        config = configparser.RawConfigParser()\n        config.read(configfile)\n\n        jsonMap = config.get('JSONMAP', 'jsonMap')\n\n        ignio_Url = helper.get_param(\"ignio_url\")\n        auth_Token = helper.get_param(\"auth_key\")\n        severity = helper.get_param(\"severity\")\n        param_use_socket = helper.get_global_setting(\"use_socket\")\n\n        resdata = json.loads(jsonMap)\n\n        sid = helper.settings.get(\"sid\")\n        events = helper.get_events()\n        count = 0\n        eventDict = {\"externalRecords\":[]}\n\n        \n\n        for event in events:\n            count += 1\n            eventExternalID = \"e_splunk_\" + str(count) + \"_\" + str(uuid.uuid4().hex)\n            externalEvent = {\"externalId\":str(eventExternalID),\"severity\":severity,\"properties\":event}\n            eventDict[\"externalRecords\"].append(externalEvent)\n        resdata.update(eventDict)\n\n        logger.info(\"Total count of events received: \" + str(count))\n\n        # Proxy Configuration if present\n        proxyConfig = None\n        proxyUri = get_proxyInfo(helper)\n\n        if proxyUri is not None:\n            proxy_http = proxyUri\n            proxy_https = proxyUri\n            logger.debug(\"Using proxy as {0}\".format(proxyUri))\n            proxyConfig = {'https' : proxy_http, 'http': proxy_https}\n            logger.debug(proxyConfig)\n\n        \n\n        if param_use_socket is True:\n            # print(\"post_message_scoket\")\n            post_message_using_socket(helper, ignio_Url, auth_Token, resdata, proxyUri)\n\n        else:\n            # print(\"post_message\")\n            post_message(helper, ignio_Url, auth_Token, resdata, proxyConfig)\n\n    except Exception as exc:\n        logger.error(str(exc))\n\n    return 0\n\n\t\n\ndef get_proxyInfo(helper):\n    proxyUri = None\n    proxyInfo = helper.get_proxy()\n    logger.debug(proxyInfo)\n\n    if proxyInfo and proxyInfo.get('proxy_url') and proxyInfo.get('proxy_type'):\n        proxyUri = proxyInfo['proxy_url']\n        if proxyInfo.get('proxy_port'):\n            proxyUri = '{0}:{1}'.format(proxyUri, proxyInfo.get('proxy_port'))\n            if proxyInfo.get('proxy_username') and proxyInfo.get('proxy_password'):\n                proxyUri = '{0}://{1}:{2}@{3}/'.format(proxyInfo['proxy_type'], proxyInfo['proxy_username'], proxyInfo['proxy_password'], proxyUri)\n            else:\n                proxyUri = '{0}://{1}'.format(proxyInfo['proxy_type'], proxyUri)\n\n    logger.debug(\"Using proxy as {0}\".format(proxyUri))\n\n    return proxyUri\n\n\n\ndef post_message(helper, ignio_Url, auth_Token, data, proxyConfig):\n    SPLUNK_HOME = os.environ['SPLUNK_HOME']\n    certFile = os.path.join(SPLUNK_HOME, 'etc', 'apps', 'TA-ignio-integration', 'default', 'IgnioCert.crt')\n    \n    payloadJS = json.dumps(data)\n    logger.debug(\"Sending the following event data to ignio: \\n\" + payloadJS)\n\n    url = ignio_Url\n    authToken = auth_Token\n\n    try:  \n        headers = {'Content-Type': 'application/json', 'ApplicationAuthorization' : authToken }  \n\n        if proxyConfig is None:\n            response = requests.post(url, data=payloadJS, headers=headers, timeout=60, verify=certFile)\n            # response = helper.send_http_request(url=url, method=\"POST\", payload=payloadJS, headers=headers, verify=False, timeout=60, use_proxy=False)\n        else:\n            response = requests.post(url, proxies=proxyConfig, data=payloadJS, headers=headers, timeout=60, verify=certFile)\n            # response = helper.send_http_request(url=url, method=\"POST\", payload=payloadJS, headers=headers, verify=False, timeout=60, use_proxy=True)\n\n        logger.info(\"POST request response status: \" + str(response.status_code))\n        logger.info(\"Response received from ignio: \" + str(response.text))\n\n    except Exception as exception:\n        exceptionMsg = str(exception)\n        logger.error(\"Exception occured : \" + exceptionMsg)\n        raise Exception(\"An error has occurred while executing HTTP POST request to ignio with error message: \" + exceptionMsg)\n\n        \n\ndef post_message_using_socket(helper, ignio_Url, auth_Token, data, proxyUri):\n    resjs = json.dumps(data)\n    resjs = str(resjs)\n    logger.debug(resjs)\n\n    oUrl = urlparse(ignio_Url)\n    hostName = oUrl.netloc + \":443\"\n\n    if proxyUri is not None:\n        pUrl = urlparse(proxyUri)\n        proxy = str(pUrl.netloc).split(\":\")[0]\n        proxyPort = pUrl.port\n\n        postRequest = \"POST /integration/work/ HTTP/1.1\\r\\n\"\n        postRequest += \"Host: \"+ hostName +\"\\r\\n\"\n        postRequest += \"Proxy-Connection: Keep-Alive\\r\\n\"\n        postRequest += \"Connection: close\\r\\n\"\n        postRequest += \"Content-Length: \" + str(len(resjs)) + \"\\r\\n\"\n        postRequest += \"Content-Type: application/json\\r\\n\"\n        postRequest += \"ApplicationAuthorization: \"+ auth_Token + \"\\r\\n\\r\\n\"\n        postRequest += resjs\n\n        requestConnect  = \"CONNECT \" + hostName + \" HTTP/1.1\\r\\n\"\n        requestConnect  += \"Host: \" + hostName + \"\\r\\n\"\n        requestConnect  += \"Proxy-Connection: Keep-Alive\\r\\n\\r\\n\"\n\n        try:\n\n            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n            s.connect((proxy, 80))\n            s.send(requestConnect)\n            logger.debug(str(s.recv(10000)).strip())\n            context = ssl.SSLContext(ssl.PROTOCOL_TLSv1_2)\n            ssocket = context.wrap_socket(s, server_hostname=hostName)\n            ssocket.send(postRequest.encode())\n            logger.debug(ssocket.recv(10000))\n            ssocket.close()\n            s.close()\n            logger.info(\"POST request completed. Socket closed.\")\n\n        except Exception as ex:\n            logger.error(str(ex))\n    else:\n        logger.info(\"Proxy is not enabled. SOCKET communication requires Proxy setting enabled.\")\n        logger.info(\"POST terminated as Proxy is not enabled.\")\n\ndef get_log_level(logLevel):\n    switcher={\n        \"DEBUG\":logging.DEBUG,\n        \"INFO\":logging.INFO,\n        \"WARNING\":logging.WARNING,\n        \"ERROR\":logging.ERROR,\n        \"CRITICAL\":logging.CRITICAL\n    }\n    return switcher.get(logLevel, logging.INFO)\n", "uuid": "3c176f5dd00042dda50ed2269d8e0a37"}]}, "basic_builder": {"appname": "TA-ignio-integration", "friendly_name": "ignio-Integration", "version": "1.0.0", "author": "Digitate", "description": "", "theme": "#38b8bf", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.2", "tab_build_no": "0", "build_no": 1}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_type": "http", "proxy_enabled": 1, "proxy_url": "10.150.5.6", "proxy_port": "8080"}, "log_settings": {"log_level": "INFO"}, "customized_settings": [{"format_type": "checkbox", "required": false, "name": "use_socket", "label": "Socket Based Connection", "default_value": 0, "help_string": "", "internal_name": "", "type": "checkbox", "value": 0}]}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1681772919_30", "progress": 1.0}}