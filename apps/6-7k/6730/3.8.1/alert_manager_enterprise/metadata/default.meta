#
# following exports are absolutely necessary for the app to function
# without them, users will not be able to create e.g. alerts, saved searches, etc. nor access the used search commands
#
[alerts]
access = read : [ admin, sc_admin, ame.admin, ame.power, ame.user ], write : [ admin, sc_admin, ame.admin, ame.power, ame.user ]
export = system

