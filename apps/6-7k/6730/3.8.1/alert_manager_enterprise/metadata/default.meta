#
# app access permissions
#
[]
access = read : [ admin, sc_admin, ame.admin, ame.power, ame.user ], write : [ admin, sc_admin, ame.admin ]
owner = nobody
export = none

#
# views, start & administrative dashboards
#
[views]
access = read : [ admin, sc_admin, ame.admin, ame.power, ame.user ], write : [ admin, sc_admin, ame.admin ]

[views/configuration]
access = read : [ admin, sc_admin, ame.admin ], write : [ admin, sc_admin, ame.admin ]

[views/health]
access = read : [ admin, sc_admin, ame.admin ], write : [ admin, sc_admin, ame.admin ]

[views/ame_health_overview]
access = read : [ admin, sc_admin, ame.admin ], write : [ admin, sc_admin, ame.admin ]

[views/setup]
access = read : [ admin, sc_admin, ame.admin ], write : [ admin, sc_admin, ame.admin ]

