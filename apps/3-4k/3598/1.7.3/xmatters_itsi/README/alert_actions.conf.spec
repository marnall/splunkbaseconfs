[xmatters_itsi]

param.endpoint_url = <url>
* The Inbound Integration URL from the xMatters Communication Plan

param.username = <string>
* The username of the REST User within xMatters

param.recipients = <password>
* The groups and people you want to receive notifications (separated by semicolons).

param.priority = <string>
* The Priority to assign to the xMatters Event. Valid values are HIGH, MEDIUM and LOW.