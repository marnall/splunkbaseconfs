### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system


### WORKFLOW ACTIONS

[workflow_actions]
access = read : [ * ], write: [ admin ]
export = system

[macros]
access = read : [ * ], write : [ * ]
export = system

[alert_actions/logger]
export = system

[alerts]
export = system

[savedsearches]
access = read : [ * ], write : [ admin ]
export = system

[views/setup]
access = read : [ admin ], write : [ admin ]
