export = system

[tldextract_command]
export = system

[searchbnf/tldextract-command]
export = system



### TRANSFORMS

[transforms]
access = read : [ * ], write : [ * ]
export = system


### LOOKUPS

[lookups]
access = read : [ * ], write : [ * ]
export = system

[lookups/dtools_watchlist]
access = read : [ * ], write : [ * ]
