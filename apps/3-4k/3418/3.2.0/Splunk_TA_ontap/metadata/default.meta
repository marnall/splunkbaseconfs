
## shared Application-level permissions
[]
access = read : [ * ], write : [ admin ]
export = system

[savedsearches]
owner = admin

[governance]
access = read : [ * ], write : [ * ]

## Postprocess
[postprocess]
access = read : [ * ], write : [ * ]


## Exclude export of custom alert actions
[alert_actions/email]
export = none


[views/ta_ontap_credential_config]
access = read : [ admin, splunk_ontap_admin ], write : [ admin, splunk_ontap_admin ]

[views/ta_ontap_collection_config]
access = read : [ admin, splunk_ontap_admin ], write : [ admin, splunk_ontap_admin ]

