<setup>
   <block title="Cb API Query Setup Page">
  </block>

  <block title="Cb Protection Credentials"
         endpoint="cbquerysetup/token" entity="default">

    <input field="protection_url">
      <label>Cb Protection Host URL</label>
      <type>text</type>
    </input>

    <input field="protection_token">
      <label>Generated API Token</label>
      <type>text</type>
    </input>
    <text><![CDATA[<a href="http://developer.carbonblack.com/reference/enterprise-protection/authentication/">See the documentation on the Developer Network website on how to acquire the API token for Cb Protection</a>]]></text>

    <input field="protection_ssl_verify">
      <label>Enable SSL Verification</label>
      <type>bool</type>
    </input>

  </block>
  <block title="Cb Response Credentials"
         endpoint="cbquerysetup/token" entity="default">

    <input field="response_url">
      <label>Cb Response Host URL</label>
      <type>text</type>
    </input>

    <input field="response_token">
      <label>Generated API Token</label>
      <type>text</type>
    </input>
    <text><![CDATA[<a href="http://developer.carbonblack.com/reference/enterprise-response/authentication/">See the documentation on the Developer Network website on how to acquire the API token for Cb Response</a>]]></text>

    <input field="response_ssl_verify">
      <label>Enable SSL Verification</label>
      <type>bool</type>
    </input>

  </block>
  <block title="Cb Defense Credentials"
         endpoint="cbquerysetup/token" entity="default">

    <input field="defense_url">
      <label>Cb Defense Host URL</label>
      <type>text</type>
    </input>

    <input field="defense_token">
      <label>Generated API Token</label>
      <type>text</type>
    </input>
    <text><![CDATA[<a href="https://developer.carbonblack.com/reference/cb-defense/authentication/">See the documentation on the Developer Network website on how to acquire the API token for Cb Defense</a>]]></text>

    <input field="defense_ssl_verify">
      <label>Enable SSL Verification</label>
      <type>bool</type>
    </input>

  </block>
</setup>
