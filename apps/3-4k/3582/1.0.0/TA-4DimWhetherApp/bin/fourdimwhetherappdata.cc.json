{
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "tokens": [
        "__settings__.logging.loglevel", 
        "north", 
        "south", 
        "west", 
        "east"
    ], 
    "requests": [
        {
            "iteration_mode": {
                "iteration_count": "1", 
                "stop_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.weatherObservations"
                        ], 
                        "method": "json_empty"
                    }
                ]
            }, 
            "request": {
                "headers": {}, 
                "method": "GET", 
                "url": "http://api.geonames.org/weatherJSON?north={{north}}&south={{south}}&east={{east}}&west={{west}}&username=dharnendra"
            }, 
            "post_process": {
                "skip_conditions": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.weatherObservations"
                        ], 
                        "method": "json_empty"
                    }
                ], 
                "pipeline": [
                    {
                        "input": [
                            "{{__response__.body}}", 
                            "$.weatherObservations"
                        ], 
                        "method": "json_path", 
                        "output": "__stdout__"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "method": "splunk_xml", 
                        "output": "__stdout__"
                    }, 
                    {
                        "input": [
                            "{{__stdout__}}"
                        ], 
                        "method": "std_output"
                    }
                ]
            }, 
            "pre_process": {
                "skip_conditions": [], 
                "pipeline": []
            }
        }
    ]
}