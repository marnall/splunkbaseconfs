[trustar://<name>]

* trustar_url
trustar_url = <value>

* api_key
api_key = <value>

* api_secret
api_secret = <value>

* Date (UTC in "YYYY-MM-DD hh:mm:ss" format) since which you want to fetch reports and indicators from TruSTAR during first polling.
start_time_to_fetch_reports = <value>

* Certificate file path
cert_path = <value>

* HTTPS proxy server address
https_proxy = <value>

* HTTPS proxy server port
https_proxy_port = <value>

* HTTPS proxy server username
https_proxy_username = <value>

* HTTPS proxy server password
https_proxy_password = <value>

* Enable Data Collection
enable_data_collection = <value>

* Enclave ID
enclave_id = <value>

* A list of tags to filter by indicators list, only indicators containing all of these tags will be returned.
tags = <value>