<setup>
    <block title="Configure SOC Prime SSL Framework App">
    </block>
	<block title="Please verify that the your server matches all the requirements:" endpoint="socprime/sslframework_configure/" entity="main">
		<text>1. Python version 2.6.6 or higher, except versions 3.x.x.</text>
		<text>2. Libraries for Python: requests, argparse.</text>
		<text>3. Network access to api.ssllabs.com port 443.</text>
	</block>
    <block title="Script setup" endpoint="socprime/sslframework_configure/" entity="main">
        <input field="domainslist">
            <label>Domains list* for scan (comma separated, for example: socprime.com, my.socprime.com)</label>
            <type>text</type>
        </input>
    </block>
   
     <block title="Notification setup" endpoint="saved/searches/" entity="Certificate Expired|Certificate Revoked|Overall Rating Changed|Soon to Expire Certificates" mode="bulk">
        <input field="action.email.to">
            <label>E-mail address for alerts and notifications (comma separated)</label>
            <type>text</type>
        </input>

    </block>   
<block title="Configure proxy settings" endpoint="socprime/sslframework_configure/" entity="main">
    <input field="proxy_used">
      <label>Enable proxy (optional)</label>
      <type>bool</type>
    </input>

    <input field="proxy_host">
              <label>Proxy host</label>
              <type>text</type>
    </input>
    <input field="proxy_port">
              <label>Proxy port</label>
              <type>text</type>
    </input>

    <input field="proxy_auth_used">
      <label>Enable proxy authentication (optional)</label>
      <type>bool</type>
    </input>

</block>

<block title="Proxy authentication" endpoint="socprime/sslframework_configure/" entity="main">
       <input field="proxy_user">
       <label>Username</label>
       <type>text</type>
       </input>

       <input field="proxy_password">
       <label>Password</label>
       <type>password</type>
       </input>
<text>Fields marked with an asterisk (*) are required.</text>
</block>

     
</setup>
