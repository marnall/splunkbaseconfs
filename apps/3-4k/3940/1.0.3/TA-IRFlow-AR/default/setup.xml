<setup>
  <block title="IR-Flow Action Configuration">
    <text>Configure the IR-Flow alert action to be able to create Alerts within IR-Flow</text>
  </block>
  <block title="IR-Flow Server (IP/Hostname)" endpoint="admin/alert_actions" entity="irflow_action">
    <input field="param.address">
      <label>Server</label>
      <type>text</type>
    </input>
  </block>
  <block title="IR-Flow API Credentials" endpoint="admin/alert_actions" entity="irflow_action">
    <input field="param.api_user">
      <label>API User:</label>
      <type>text</type>
    </input>
    <input field="param.api_key">
      <label>API Key:</label>
      <type>text</type>
    </input>
  </block>
</setup>
