<setup>
	<block title="Specify ServiceNow Server" endpoint="sn_sec_ops_setup/myinstance"
		entity="sn_instance">
		<input field="url">
			<label>URL</label>
			<type>text</type>
		</input>
		<input field="username">
			<label>Username</label>
			<type>text</type>
		</input>
		<input field="password">
			<label>Password</label>
			<type>password</type>
		</input>
	</block>
    <block title="Optional Proxy Setup" endpoint="sn_sec_ops_setup/myinstance" entity="sn_instance">
        <input field="proxy_url">
            <label>Proxy URL</label>
            <type>text</type>
        </input>
        <input field="proxy_port">
            <label>Port</label>
            <type>integer</type>
        </input>
        <input field="proxy_username">
            <label>Username</label>
            <type>text</type>
        </input>
        <input field="proxy_password">
            <label>Password</label>
            <type>password</type>
        </input>
    </block></setup>