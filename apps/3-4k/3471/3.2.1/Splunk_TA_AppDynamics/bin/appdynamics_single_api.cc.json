{
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "tokens": [
        "__settings__.logging.loglevel", 
        "__settings__.proxy.proxy_enabled", 
        "__settings__.proxy.proxy_url", 
        "__settings__.proxy.proxy_port", 
        "__settings__.proxy.proxy_type", 
        "__settings__.proxy.proxy_username", 
        "__settings__.proxy.proxy_rdns", 
        "__settings__.proxy.proxy_password", 
        "__settings__.additional_parameters.timeout", 
        "host_port", 
        "auth_token", 
        "duration", 
        "app_name", 
        "url_path", 
        "params"
    ], 
    "requests": [
        {
            "pre_process": {
                "skip_conditions": [], 
                "pipeline": []
            }, 
            "request": {
                "url": "{{host_port}}/controller/rest/applications/{{app_name}}{{url_path}}?output=json&time-range-type=BEFORE_NOW&duration-in-mins={{duration}}&{{params}}", 
                "method": "GET", 
                "headers": {
                    "Authorization": "Basic {{auth_token}}"
                }
            }, 
            "iteration_mode": {
                "stop_conditions": [], 
                "iteration_count": "1"
            }, 
            "post_process": {
                "skip_conditions": [
                    {
                        "method": "json_empty", 
                        "input": [
                            "{{__response__.body}}", 
                            "$"
                        ]
                    }
                ], 
                "pipeline": [
                    {
                        "method": "splunk_xml", 
                        "output": "__stdout__", 
                        "input": [
                            "{{__response__.body}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ]
                    }, 
                    {
                        "method": "std_output", 
                        "input": [
                            "{{__stdout__}}"
                        ]
                    }
                ]
            }
        }
    ], 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }, 
        "proxy": {
            "username": "{{__settings__.proxy.proxy_username}}", 
            "port": "{{__settings__.proxy.proxy_port}}", 
            "password": "{{__settings__.proxy.proxy_password}}", 
            "host": "{{__settings__.proxy.proxy_url}}", 
            "rdns": "{{__settings__.proxy.proxy_rdns}}", 
            "enabled": "{{__settings__.proxy.proxy_enabled}}", 
            "type": "{{__settings__.proxy.proxy_type}}"
        }
    }
}