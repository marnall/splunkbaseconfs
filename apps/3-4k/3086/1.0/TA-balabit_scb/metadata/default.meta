[]
access = read : [ * ], write : [ admin ]
export = none

[eventtypes]
access = read : [ * ], write : [ admin ]
export = system
owner = admin

[lookups]
access = read : [ * ], write : [ admin ]
export = system
owner = admin

[props]
access = read : [ * ], write : [ admin ]
export = system
owner = admin

[tags]
access = read : [ * ], write : [ admin ]
export = system
owner = admin

[transforms]
access = read : [ * ], write : [ admin ]
export = system
owner = admin
