{"alert_action_builder": {"modular_alerts": [{"description": "Google Chat Alert", "largeIcon": "", "smallIcon": "", "label": "Hangsout Chat Alert", "short_name": "hangsout_chat_alert", "active_response": {"technology": [{"vendor": "Google", "product": "Hangouts Chat", "version": ["1"]}], "supports_adhoc": false, "category": ["Information Conveyance"], "task": ["update"], "subject": ["endpoint"]}, "parameters": [{"format_type": "text", "required": true, "name": "webhook_url", "label": "Webhook URL", "default_value": "", "help_string": "", "type": "", "value": "https://chat.googleapis.com/v1/spaces/AAAAjY-lS8g/messages?key=AIzaSyDdI0hCZtE6vySjMm-WEfRq3CPzqKqqsHI&token=94Qq3c-uIZ0SlH6ZI5JcfPyTmiTC-bGRSaQFjj914GA%3D"}, {"format_type": "text", "required": true, "name": "message_text", "label": "Message Text", "default_value": "", "help_string": "", "type": "", "value": "test new version"}], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example gets the alert action parameters and prints them to the log\n    webhook_url = helper.get_param(\"webhook_url\")\n    helper.log_info(\"webhook_url={}\".format(webhook_url))\n\n    message_text = helper.get_param(\"message_text\")\n    helper.log_info(\"message_text={}\".format(message_text))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action hangsout_chat_alert started.\")\n    \n    chat_webhook_url = helper.get_param('webhook_url')\n    message_text = helper.get_param('message_text')\n    result = chat_webhook_url.startswith('https://')\n    if not result:\n        helper.log_info(\"webhook must be https\")\n        return(1)\n    helper.log_info(\"HTTPS confirmed.\")\n    chat_message = {\n        'text': message_text\n    }\n    \n    \n    chat_response = helper.send_http_request(chat_webhook_url, 'POST', payload=chat_message)\n    \n    if chat_response.status_code >= 400:\n        helper.log_error('Hangsout Chat request failed: {}'.format(chat_response.text))\n        return chat_response.status_code\n    \n\n    # TODO: Implement your alert action logic here\n    return 0\n", "uuid": "7be6c71e59284d22aae21613a93f25f0"}]}, "basic_builder": {"appname": "TA-hangsout-chat-webhook", "friendly_name": "Webhook Alerts for Google Chat", "version": "1.8.5", "author": "Allan Edwards", "description": "This app allows you to easily configure adaptive response alert actions in Splunk ES that trigger webhook alerts for Google  Chat channels. You configure the webhook in the channel and then use that URL in Splunk when configuring the alert.", "theme": "#65A637", "large_icon": "", "small_icon": "", "visible": false, "tab_version": "4.5.1", "tab_build_no": "0", "build_no": 11}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_started", "validation_id": "v_1777042571_36"}}