<setup>
  <block title="Production IR-Flow API Configuration" endpoint="admin/irflowconfig" entity="config">
    <text>
      For production use, specify these settings.
    </text>
    <input field="api_user">
      <label>Production API User</label>
      <type>text</type>
    </input>
    <input field="api_key">
      <label>Production API Key</label>
      <type>password</type>
    </input>
    <input field="address">
      <label>Production IR-Flow Address (IP/Hostname)</label>
      <type>text</type>
    </input>
    <input field="verify_ssl">
      <label>Verify IR-Flow SSL Cert?</label>
      <type>bool</type>
    </input>
    <input field="arf">
      <label>Send Alerts via Adaptive Response?</label>
      <type>bool</type>
    </input>
    <input field="suppress">
      <label>Suppress Missing Field Warnings?</label>
      <type>bool</type>
    </input>
  </block>
  <block title="Staging IR-Flow API Configuration" endpoint="admin/irflowconfig" entity="config">
    <text>
      If you have a Staging or Test environment, enter those details here.
    </text>
    <input field="stage_api_user">
      <label>Staging API User</label>
      <type>text</type>
    </input>
    <input field="stage_api_key">
      <label>Staging API Key</label>
      <type>password</type>
    </input>
    <input field="stage_address">
      <label>Staging IR-Flow Address (IP/Hostname)</label>
      <type>text</type>
    </input>
    <input field="stage_verify_ssl">
      <label>Staging Verify IR-Flow SSL Cert?</label>
      <type>bool</type>
    </input>
    <input field="stage_arf">
      <label>Send Alerts via Adaptive Response?</label>
      <type>bool</type>
    </input>
    <input field="stage_suppress">
      <label>Suppress Missing Field Warnings?</label>
      <type>bool</type>
    </input>
  </block>
    <block title="Logging Options" endpoint="admin/irflowconfig" entity="config">
      <text>
        Check these boxes if you would like more verbose logging.
      </text>
    <input field="debug">
      <label>Enable debug logging (Splunk app)?</label>
      <type>bool</type>
    </input>
    <input field="verbose">
      <label>Verbose logging (IR-Flow client)</label>
      <type>bool</type>
    </input>
  </block>
  <block title="Adaptive Response Index" endpoint="admin/irflowconfig" entity="config">
    <input field="index">
      <label>Index Name</label>
      <type>text</type>
    </input>
  </block>
</setup>
