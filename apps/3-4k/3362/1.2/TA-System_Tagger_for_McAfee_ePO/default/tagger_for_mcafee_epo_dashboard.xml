<form>
  <label>Tagger for McAfee ePO Dashboard</label>
  <description>Allows search and lists all tags and systems in ePO</description>
  <fieldset submitButton="false">
    <input type="time" token="field1">
      <label></label>
      <default>
        <earliest>-4h@m</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>All ePO Tags</title>
      <table>
        <search>
          <query>index="epo_tagger" sourcetype="mcafee:epo:tag" | stats latest(tagId) as tagId latest(tagNotes) as tagNotes by tagName | sort tagName</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">100</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">cell</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
    <panel>
      <title>Tag Search</title>
      <input type="text" token="tag_name" searchWhenChanged="true">
        <label>Tag Name</label>
        <initialValue>Server</initialValue>
      </input>
      <table>
        <search>
          <query>index="epo_tagger" sourcetype="mcafee:epo:tag" tagName="*$tag_name$*" | stats latest(tagId) as tagId latest(tagNotes) as tagNotes by tagName | sort tagName</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>All ePO Systems</title>
      <table>
        <search>
          <query>index="epo_tagger"  sourcetype="mcafee:epo:systems" |stats latest(Tags) as Tags latest(Communication) as Communication latest(Platform) as Platform latest(Type) as Type by Name | sort Name</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">100</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">cell</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
    <panel>
      <title>System Search</title>
      <input type="text" token="name" searchWhenChanged="true">
        <label>System Name</label>
      </input>
      <table>
        <search>
          <query>index="epo_tagger"  sourcetype="mcafee:epo:systems" Name="*$name$*" |stats latest(Tags) as Tags latest(Communication) as Communication latest(Platform) as Platform latest(Type) as Type by Name | sort Name</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
</form>