<setup>
    <block title="ATA IR Portal Alert Action">
        <text>Configure ATA Portal Alert Action</text>
    </block>

    <block title="Server" endpoint="admin/alert_actions" entity="ataportal">
        <input field="param.base_url">
            <label>URL to send Security Event</label>
            <type>text</type>
        </input>
        <input field="param.auth_token">
            <label>Authorization Token from ATA</label>
            <type>text</type>
        </input>
        <input field="param.psa_id">
            <label>Your Customer ID, provided by ATA</label>
            <type>text</type>
        </input>
    </block>
</setup>