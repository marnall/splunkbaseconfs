
# Application-level permissions

[]
access = read : [ * ], write : [ admin ]
export = none



### EVENT TYPES

[eventtypes]
export = system
access = read : [ * ], write : [ power ]

### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system

[transforms/protocol_lookup]
export = none
owner = admin

### LOOKUPS

[lookups]
export = system

[lookups/protocol_lookup.csv]
access = read : [ * ], write : [ admin, power ]
export = none
owner = admin



### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[views/l7_application_overview]
owner = admin

[views/http_application_view]
owner = admin

[views/dns_application_view]
owner = admin

[views/network_monitor]
owner = admin

[views/application_tunnel_view]
owner = admin

[views/traffic_by_host]
owner = admin

[views/traffic_by_eng]
owner = admin

[views/overview_apm]
access = read : [ * ], write : [ admin ]
export = none
owner = admin


