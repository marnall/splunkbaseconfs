<setup>
  <block title="Enable web proxy" endpoint="urlexpander/urlexpander_configure" entity="settings">
    <text>
              &lt;i&gt;Setup up web proxy&lt;/i&gt;
    </text>

    <input field="http_proxy">
      <label>HTTP Proxy</label>
      <type>text</type>
    </input>

    <input field="https_proxy">
      <label>HTTPS Proxy</label>
      <type>text</type>
    </input>
  </block>
  <block title="User Agent String" endpoint="urlexpander/urlexpander_configure" entity="settings">
    <text>
      Specify a useragent string to make requests with (not required).
    </text>

    <input field="useragent">
      <label>Useragent</label>
      <type>text</type>
    </input>
  </block>
</setup>
