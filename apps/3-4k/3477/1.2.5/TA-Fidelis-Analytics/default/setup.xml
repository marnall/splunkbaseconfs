<setup>
<block title="Fidelis Setup Page" endpoint="fidelis/fideliscustomendpoint" entity="setupentity">
  	
   <input field="RESTSERVER" placeholder="https://example.com">
      <label>CommandPost URL</label>
      <type>text</type>
	</input>
	<input field="ALLOW_SSL">
        <label>Allow Self Signed Certificate</label>
        <type>bool</type>
	</input>
	<input field="SSL_CERT_LOC">
        <label>Location to Public Key</label>
        <type>text</type>
	</input>
    <input field="USERNAME">
      <label>User Name</label>
      <type>text</type>
	</input>
	<input field="PASSWORD">
	  <label>Password</label>
	  <type>password</type>
	</input>
	<input field="INPUT_CONFIG">
        <label>Enable Input Configuration</label>
        <type>bool</type>
	</input>
	 <input field="ECPORT" >
      <label>TCP Port to listen for Fidelis Alert traffic</label>
      <type>text</type>
    </input>	

    <input field="INDEX" >
      <label>Index</label>
      <type>text</type>
    </input> 
  </block>

</setup>
