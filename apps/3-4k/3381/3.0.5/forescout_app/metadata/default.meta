[]
access = read : [ * ], write : [ admin, power ]
export = system

[tags]
export = system

[props]
export = system

[transforms]
export = system

[lookups]
export = system

[viewstates]
access = read : [ * ], write : [ * ]
export = system


### Cancel
[savedsearches/counteract_cancel_webhook]
access = read : [ * ], write : [ admin, power ]
export = system
owner = admin

[savedsearches/trigger_cancel_action]
access = read : [ * ], write : [ admin, power ]
export = none
owner = nobody

