[zfox://<name>]
* ZeroFOX Configuration
interval = 60

zf_api_token = <value>
* ZeroFOX API key

zf_api_proxy_username = <value>
* ZeroFOX API proxy username

zf_api_proxy_password = <value>
* ZeroFOX API proxy password

zf_api_proxy_host = <value>
* ZeroFOX API proxy host

zf_api_proxy_port = <value>
* ZeroFOX API proxy port

expand_metadata = [1|0]
* Enable Alert metadata expansion

[zfox_global://<name>]
* ZeroFOX Global Threat Config
interval = 60

tg_api_key = <value>
* ThreatGraph API key

tg_api_proxy_username = <value>
* ZeroFOX API proxy username

tg_api_proxy_password = <value>
* ZeroFOX API proxy password

tg_api_proxy_host = <value>
* ZeroFOX API proxy host

tg_api_proxy_port = <value>
* ZeroFOX API proxy port
