
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system

### MACROS

[macros]
export = system

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system


[collections/cloudlock]
access = read : [ cloudlock_read ], write : [ cloudlock_write ]
