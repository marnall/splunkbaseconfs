

[triage_endpoint]
python.version = python3
param.endpoint = <string> Endpoint. It's a required parameter.
param.scan_options = <string> Data types. It's a required parameter. It's default value is pr,nw,nc,st,sc,ru,co,lo,ns,wb,fs.
param.malware_options = <list> Malware options. It's a required parameter. It's default value is 1.
param.incident_name = <string> Incident name. It's a required parameter. It's default value is Default.
param._cam = <json> Active response parameters.

