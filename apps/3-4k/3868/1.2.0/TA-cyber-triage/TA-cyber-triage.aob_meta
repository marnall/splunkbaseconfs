{"alert_action_builder": {"modular_alerts": [{"code": "#\n# Cyber Triage Add-on for Splunk\n#\n# Copyright 2018 Basis Technology Corp.\n# Contact: support <at> cybertriage <dot> com\n#\n# Licensed under the Apache License, Version 2.0 (the 'License');\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#     http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an 'AS IS' BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n#\n\n# encoding = utf-8\nimport requests.exceptions\nimport os\nimport json\n\ndef process_event(helper, *args, **kwargs):\n\n    helper.set_log_level(helper.get_log_level())\n    helper.log_info('Alert action triage_system started.')\n    SCAN_OPTIONS = ['pr', 'nw', 'nc', 'st', 'sc', 'ru', 'co', 'lo', 'ns', 'wb', 'fs']\n\n    # Configuration settings\n    server = helper.get_global_setting('server')\n    rest_port = helper.get_global_setting('rest_port')\n    api_key = helper.get_global_setting('api_key')\n    win_user = helper.get_global_setting('username')\n    win_pass = helper.get_global_setting('password')\n    event_index = helper.get_global_setting('index')\n    verify_server_cert = helper.get_global_setting('verify_server_cert')\n    base_url = 'https://{0}:{1}/api'.format(server, rest_port)\n    api_headers = {'restApiKey': api_key}\n    is_proxy_set = helper.get_proxy()\n    helper.log_debug('server:{}({}), port:{}({}), user:{}({}), verify_cert:{}({}), proxy:{}({})'.format(server, type(server), rest_port, type(rest_port), win_user, type(win_user), verify_server_cert, type(verify_server_cert), is_proxy_set, type(is_proxy_set)))\n\n    # Action parameters\n    endpoint = helper.get_param('endpoint')\n    scan_options = helper.get_param('scan_options').replace(' ','')\n    malware_options = int(helper.get_param('malware_options'))\n    incident_name = helper.get_param('incident_name')\n    helper.log_debug('scan_options:{}({}), malware_options:{}({}))'.format(scan_options, type(scan_options), malware_options, type(malware_options)))\n\n    # Set rc to success by default. Any exceptions thrown will result in rc = 1\n    rc = 0\n    json_err_msg = ''\n    ex = None\n    event_json = {'actionStatus' : 'Failure', 'message' : json_err_msg, 'endpoint' : endpoint}\n\n    # Validate scan options\n    invalid_options = [opt for opt in scan_options.split(',') if opt not in SCAN_OPTIONS]\n    if invalid_options:\n        helper.log_error('The following are not valid scan options: {0}'.format(','.join(invalid_options)))\n        event_json['message'] = 'The following are not valid scan options: {0}'.format(','.join(invalid_options))\n        writeEvent(helper, event_index, event_json)\n        return 1\n\n    # Convert necessary options to bool values\n    # Checkboxes/drop downs return 1/Yes if selected and 0 if unselected/No\n    # helper.get_proxy() returns {} if not configured\n    try:\n        verify_server_cert = bool(int(verify_server_cert))\n        is_proxy_set = bool(is_proxy_set)\n        is_hash_upload_on = True if malware_options > 0 else False\n        is_file_upload_on = True if malware_options == 2 else False\n        helper.log_debug('verify_cert:{}({}), proxy:{}({}), hash_upload:{}({}), file_upload:{}({})'.format(verify_server_cert, type(verify_server_cert), is_proxy_set, type(is_proxy_set), is_hash_upload_on, type(is_hash_upload_on), is_file_upload_on, type(is_file_upload_on)))\n\n    except ValueError as val_e:\n        helper.log_error('{}: {}'.format(type(val_e).__name__, val_e.args))\n\n    # Make data dict for rest call\n    api_data = {'incidentName' : incident_name}\n    api_data.update({'hostName': endpoint})\n    api_data.update({'userId': win_user})\n    api_data.update({'password': win_pass})\n    api_data.update({'scanOptions': scan_options})\n    api_data.update({'malwareScanRequested': is_hash_upload_on})\n    api_data.update({'sendContent': is_file_upload_on})\n    api_data.update({'sendIpAddress': False})\n\n    # If user wants to verify the server cert we expect a cybertriage.pem file to be located in\n    # %SPLUNK_HOME%\\etc\\auth. If the file does not exist we log an error. It will be caught as an SSLError\n    # when doing the http request. If SPLUNK_HOME is not found we let splunk catch the error, this should never happen.\n    if verify_server_cert:\n        pem_path = '{}\\\\etc\\\\auth\\\\cybertriage.pem'.format(os.environ['SPLUNK_HOME'])\n        verify_server_cert = pem_path\n        if not os.path.isfile(pem_path):\n            helper.log_error('Certificate not found: {}'.format(pem_path))\n\n    # Attempt to make the rest API call and get data from response\n    try:\n        # Default ReadTimeout set by send_http_requests seems to be 5s even when specifying timeout=None. As a result,\n        # we need to set a reasonable timeout b/c when an invalid username/password is provided a response can take some\n        # time before coming back. 15/20s failed occasionally so setting timeout to 40s to be safe.\n        response = helper.send_http_request((base_url + '/livesessions'), 'POST', headers=api_headers, payload=api_data, verify=verify_server_cert, cert=None, use_proxy=is_proxy_set, parameters=None, cookies=None, timeout=40)\n\n        # Raises ValueError exception if response cannot be converted to json\n        resp_json = response.json()\n\n        # Raises HTTPError exception if we get a non successful http status code (4xx/5xx)\n        response.raise_for_status()\n\n    except ValueError as e:\n        json_err_msg = 'No valid json found in the HTTP response'\n        helper.log_error('Text from http response: {0}. Status code: {1}'.format(response.text, response.status_code))\n        rc = 1\n        ex = e\n\n    except requests.exceptions.SSLError as e:\n        json_err_msg = 'Unable to verify the Cyber Triage server certificate'\n        rc = 1\n        ex = e\n    except requests.exceptions.ConnectionError as e:\n        json_err_msg = 'Error while connecting to the Cyber Triage server ({})'.format(server)\n        rc = 1\n        ex = e\n\n    except requests.exceptions.HTTPError as e:\n        # Format error message based on error response in json\n        json_err_msg = 'No Error Message found'\n        if 'Error' in resp_json:\n            json_err_msg = resp_json['Error']\n\n        elif 'message' in resp_json:\n            json_err_msg = resp_json['message']\n\n        helper.log_error('{0} Error from Cyber Triage server. Error Message: {1}'.format(response.status_code, json_err_msg))\n        rc = 1\n        ex = e\n\n    except requests.exceptions.RequestException as e:\n        json_err_msg = 'An unexpected error has occurred'\n        rc = 1\n        ex = e\n\n    # Build the response json that we will write out as an event.\n    # The event tells the action status (success/failure) and a message that provides\n    # more detail on why the action failed. If it succeeded the message contains the sessionID.\n    if rc == 1:\n        helper.log_error('Failure response msg: {}'.format(json_err_msg))\n        if ex is not None:\n            helper.log_error('{}: {}'.format(type(ex).__name__, ex))\n        event_json['message'] = json_err_msg\n\n    else:\n        helper.log_info('Successful response msg: {}'.format(resp_json))\n        event_json['actionStatus'] = 'Success'\n        event_json['message'] = resp_json['SessionId']\n\n    writeEvent(helper, event_index, event_json)\n    return rc\n\ndef writeEvent(helper, event_index, event_json):\n    # I have not found a way to verify if the event_index (proivded by the user) exists. If it does not exist\n    # helper.writeevents() still succeeds, however, the events/index do not appear to be created.\n    helper.addevent(json.dumps(event_json, indent=4, sort_keys=True), sourcetype='cybertriage:alert:response')\n    helper.writeevents(index=event_index, host=event_json['endpoint'], source='cybertriage')", "largeIcon": "", "short_name": "triage_endpoint", "label": "triage endpoint", "smallIcon": "", "parameters": [{"help_string": "IP or hostname of a Windows endpoint", "type": "", "name": "endpoint", "required": true, "format_type": "text", "default_value": "", "value": "10.2.7.51", "label": "Endpoint"}, {"help_string": "pr (process), nw (network), nc (network cache), st (startup programs), sc (scheduled tasks), ru (program run), co (system config), lo (user logins), ns (network shares), wb (web), fs (full file scan)", "type": "", "name": "scan_options", "required": true, "format_type": "text", "default_value": "pr,nw,nc,st,sc,ru,co,lo,ns,wb,fs", "value": "pr,nw,nc,st,sc", "label": "Data types"}, {"help_string": "Malware options for the session. File hashes and content for unknown files are uploaded to ReversingLabs for analysis.", "possible_values": {"md5 lookup": "1", "disable": "0", "md5 lookup + upload unknown files": "2"}, "type": "", "name": "malware_options", "required": true, "format_type": "dropdownlist", "default_value": "1", "value": "1", "label": "Malware options"}, {"help_string": "Incident that the collection will below to within Cyber Triage", "type": "", "name": "incident_name", "required": true, "format_type": "text", "default_value": "Default", "value": "Test", "label": "Incident name"}], "active_response": {"technology": [{"product": "Cyber Triage", "version": ["2.6.0"], "vendor": "Basis Technology"}], "sourcetype": "cybertriage:alert:response", "supports_adhoc": true, "subject": ["endpoint.workstation", "endpoint.server", "endpoint.laptop"], "task": ["scan"], "category": ["Information Gathering"]}, "description": "Initiates a Cyber Triage collection on a remote endpoint", "uuid": "52d31b3948784b578e0be2a9a4853acf"}]}, "basic_builder": {"appname": "TA-cyber-triage", "friendly_name": "Cyber Triage", "version": "1.2.0", "author": "Basis Technology", "description": "An add-on that allows for the ingest of Cyber Triage json reports and implements a custom alert action which initiates a Cyber Triage collection.", "theme": "#708794", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.0", "tab_build_no": "0", "build_no": 18}, "field_extraction_builder": {"cybertriage": {"is_parsed": true, "data_format": "json"}, "cybertriage:alert:response": {"data_format": "json"}}, "global_settings_builder": {"global_settings": {"proxy_settings": {"proxy_port": "8888", "proxy_type": "http", "proxy_url": "hpa-win7-mtg1", "proxy_enabled": 0}, "log_settings": {"log_level": "DEBUG"}, "customized_settings": [{"help_string": "IP or hostname of a Cyber Triage server", "format_type": "text", "type": "text", "label": "Server", "required": true, "internal_name": "", "name": "server", "default_value": "", "value": "ct-server"}, {"help_string": "Port # of the Cyber Triage REST service", "format_type": "text", "type": "text", "label": "Rest Port", "required": true, "internal_name": "", "name": "rest_port", "default_value": "9443", "value": "9443"}, {"help_string": "Cyber Triage server API key.", "format_type": "password", "type": "password", "label": "API key", "required": true, "internal_name": "", "name": "api_key", "default_value": "", "value": ""}, {"help_string": "The username of an administrative windows account in the form of domain\\user", "format_type": "text", "type": "text", "label": "Username", "required": true, "internal_name": "", "name": "username", "default_value": "", "value": "qa"}, {"help_string": "The password of an administrative windows account", "format_type": "password", "type": "password", "label": "Password", "required": true, "internal_name": "", "name": "password", "default_value": "", "value": ""}, {"help_string": "The index in which events generated by the app will be stored under", "format_type": "text", "type": "text", "label": "Index", "required": true, "internal_name": "", "name": "index", "default_value": "main", "value": "main"}, {"help_string": "Verify the Cyber Triage server cert. Only enabled if you have imported a custom cert into Cyber Triage.", "format_type": "checkbox", "type": "checkbox", "label": "Verify server cert", "required": false, "internal_name": "", "name": "verify_server_cert", "default_value": 0, "value": 0}]}}, "sourcetype_builder": {"cybertriage": {"metadata": {"cims_count": 0, "event_count": 0, "data_input_name": null, "extractions_count": 0}}, "cybertriage:alert:response": {"metadata": {"cims_count": 0, "event_count": 0, "data_input_name": null, "extractions_count": 0}}}, "validation": {"validators": ["best_practice_validation", "data_model_mapping_validation", "field_extract_validation", "app_cert_validation"], "status": "job_finished", "validation_id": "v_1651967748_15", "progress": 1.0}}