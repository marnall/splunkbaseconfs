
# Application-level permissions

[]
access = read : [ itm6_user ], write : [ itm6_admin ]
export = system

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### LOOKUPS

[lookups]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[tems]
access = read : [ itm6_admin, itm6_user, admin ], write : [ itm6_admin, admin ]

[app]
access = read : [ itm6_admin, itm6_user, admin ], write : [ itm6_admin, admin ]