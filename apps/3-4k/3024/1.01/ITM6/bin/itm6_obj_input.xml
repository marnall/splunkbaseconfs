<scheme>
	<title>ITM6 Object Query</title>
	<description>Get data from ITM6.</description>
	<use_external_validation>true</use_external_validation>
	<streaming_mode>xml</streaming_mode>

	<endpoint>
		<args>
			<arg name="tems">
				<title>TEMS</title>
				<description>The nom of the TEMS connection to use for this query.</description>
			</arg>
			<arg name="target">
				<title>Target</title>
				<description>MSL or Node to query.</description>
			</arg>
			<arg name="object">
				<title>Object</title>
				<description>The ITM6 object to query.</description>
			</arg>
			<arg name="history">
				<title>History</title>
				<description>Retrive historical data.</description>
				<required_on_create>false</required_on_create>
				<required_on_edit>false</required_on_edit>
			</arg>
			<arg name="attributes">
				<title>Attributes</title>
				<description>A CSV list of attributes to return.</description>
				<required_on_create>false</required_on_create>
				<required_on_edit>false</required_on_edit>
			</arg>
			<arg name="afilter">
				<title>Afilter</title>
				<description>List of values in format:
attribute1;operator1;value1:attribute2;operator2;value2:...
				</description>
				<required_on_create>false</required_on_create>
				<required_on_edit>false</required_on_edit>
			</arg>
		</args>
	</endpoint>
</scheme>
