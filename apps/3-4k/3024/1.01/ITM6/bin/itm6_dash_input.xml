<scheme>
	<title>ITM6 Dash Query</title>
	<description>Get data from ITM6.</description>
	<use_external_validation>true</use_external_validation>
	<streaming_mode>xml</streaming_mode>

	<endpoint>
		<args>
			<arg name="tems">
				<title>TEMS</title>
				<description>The name of the TEMS connection to use for this query.</description>
			</arg>
			<arg name="datasource">
				<title>Datasourse</title>
				<description>The DDP Data Source</description>
			</arg>
			<arg name="sourcetoken">
				<title>System</title>
				<description>MSL or Node to query.</description>
			</arg>
			<arg name="dataset">
				<title>Dataset</title>
				<description>The DDP Data Set</description>
			</arg>
			<arg name="properties">
				<title>Properties</title>
				<description>The short name of the properties you wish to return, defaults to all</description>
				<required_on_create>false</required_on_create>
				<required_on_edit>false</required_on_edit>
			</arg>
			<arg name="condition">
				<title>Condition</title>
				<description>Set a condition for the query</description>
				<required_on_create>false</required_on_create>
				<required_on_edit>false</required_on_edit>
			</arg>
			<arg name="fieldformat">
				<title>Field Format</title>
				<description>Display properties labels or their long name</description>
				<required_on_create>false</required_on_create>
				<required_on_edit>false</required_on_edit>
			</arg>
		</args>
	</endpoint>
</scheme>
