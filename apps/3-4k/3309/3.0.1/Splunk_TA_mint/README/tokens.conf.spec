[<name>]
* This determines parameters of Splunk MINT Data Collector.
* Parameters include cloud endpoint and authentication required to pull data.
* A default entity called 'cds' will be created for you upon first time run.

cds_url = <URL>
* Splunk MINT Data Collector URL endpoint returned by the authentication server.
* This will be set upon first time run.

token = <string>
* Splunk MINT Data Collector authentication token returned by the authentication server
* This will be set upon first time run.
