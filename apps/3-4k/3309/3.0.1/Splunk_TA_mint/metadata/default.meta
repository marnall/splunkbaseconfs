# Application-level permissions
[]
access = read : [ * ], write : [ mint_admin, admin ]

### EVENT TYPES

[eventtypes]
export = system

### LOOKUPS

[lookups]
export = system

### PROPS

[props]
export = system

[props/default]
export = none

### TAGS

[tags]
export = system

### TRANSFORMS

[transforms]
export = system

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]

### Splunk MINT Data Collector parameters
[inputs/mi_cds://default]
access = read : [ mint_user, mint_admin, admin ], write : [ mint_admin, admin ]
export = none

[savedsearches]
export = system
