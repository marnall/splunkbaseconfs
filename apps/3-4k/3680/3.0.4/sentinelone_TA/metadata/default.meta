# Application-level permissions
[]
access = read : [ * ], write : [ admin ]
export = system

[inputs]
access = read : [ * ], write : [ admin ]
export = system

[lookups]
access = read : [ * ], write : [ admin ]
export = system

[tags]
access = read : [ * ], write : [ admin ]
export = system

[props]
access = read : [ * ], write : [ admin ]
export = system

[transforms]
access = read : [ * ], write : [ admin ]
export = system

[collections]
access = read : [ * ], write : [ admin ]
export = system

# Event Types

[eventtypes]
access = read : [ * ], write : [ admin ]
export = system

# Views

[views]
access = read : [ * ], write : [ admin ]
export = none

[views/setup]
access = read : [ admin ], write : [ admin ]
export = none

# Saved Searches

[savedsearches]
access = read : [ * ], write : [ admin, power ]
owner = admin
export = system
