[logging]
loglevel = <value>
* Log level that should be used. Defaults to INFO. Accepts INFO, DEBUG, WARN, ERROR

[app_settings]
indexes = <value>
* Comma separated list of indexes to query

sourcetype_core = <value>
* Comma separated list of tech. "Corelight" or "Zeek" are the only two acceptable values.

local_network_blocks = <value>
* Comma separated list of local network blocks.

[additional_parameters]
is_app_configured = <value>
* Is the app configured