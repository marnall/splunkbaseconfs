<setup>
<block title="Akamai EAA Credentials" endpoint="storage/passwords" entity="_new">
  <input field="name">
    <label>Api Key</label>
    <type>text</type>
  </input>

  <input field="password">
    <label>Secret</label>
    <type>text</type>
  </input>

 <!-- Remove the realm input field if your app is not using realm -->
  <input field="realm">
     <label>Realm</label>
     <type>text</type>
  </input>

</block>
</setup>