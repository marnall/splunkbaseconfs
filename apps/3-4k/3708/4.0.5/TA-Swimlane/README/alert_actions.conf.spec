
[push_alerts_to_swimlane]
python.version = python3
param._cam = <json> Active response parameters.
param.swimlane_hosts = <string> Swimlane Hosts. Possible values are prod, staging and dev.
param.swimlane_app_name = <string> Swimlane App Name. It's a required parameter.
param.push_method = <list> Push Method. It's a required parameter. It's default value is add.
param.update_key_field = <string> Update Key Field.
param.use_automapping = <list> Automapping. It's a required parameter. It's default value is 1.
param.custom_field_mappings = <string> Custom Field Mappings.
param.extra_fields = <string> Extra fields in JSON format.
param.number_of_events_to_send = <string> Number of Events to Send. It's a required parameter. It's default value is All.

