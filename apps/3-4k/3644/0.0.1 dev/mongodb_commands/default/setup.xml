<setup>
  <block title="Configure MongoDB Commands">
  </block>

  <block title="MongoDB host"
         endpoint="mongodb/mongodb_conf" entity="mongodb">

      <input field="host">
        <label>Enter hostname or ip address of MongoDB instance</label>
        <type>text</type>
      </input>

  </block>

  <block title="MongoDB port"
         endpoint="mongodb/mongodb_conf" entity="mongodb">

    <input field="port" endpoint="mongodb/mongodb_conf" entity="mongodb">
      <label>Enter MongoDB port</label>
      <type>text</type>
    </input>

  </block>

</setup>