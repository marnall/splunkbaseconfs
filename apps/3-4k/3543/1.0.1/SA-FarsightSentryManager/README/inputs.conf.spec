[sra://default]
* Sample SRA input

channels = <channels>
* SRA Channel(s). Comma delimited.

watches = <watches>
* Watches. Comma delimited.

timeout = <timeout>
* Socket timeout in seconds

sample_rate = <sample_rate>
* Channel sampling rate (percent)

rate_limit = <rate_limit>
* Maximum packets per second

report_interval = <report_interval>
* Seconds between emission of server accounting messages (packet statistics)

