<setup>
  <block title="AXAMD Setup" endpoint="configs/conf-axamd"
    entity="axamd">
    <input field="server">
      <label>Server Hostname: (e.g. axamd-eft.sra-remote.net)</label>
      <type>text</type>
    </input>
    <input field="logging_uri">
      <label>Splunk Logging Target: (default: localhost:8089 )</label>
      <type>text</type>
    </input>
    <input field="proxy">
      <label>Proxy</label>
      <type>text</type>
    </input>
    <input field="api_key">
      <label>API Key</label>
      <type>text</type>
    </input>
  </block>
</setup>
