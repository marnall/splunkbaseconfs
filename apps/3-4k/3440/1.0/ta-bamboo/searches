sourcetype="Bamboo Input" plan.type="chain"
| rename projectName as project_key, plan.shortKey as plan_key, number as build_number, plan.key as project_plan
| eval totalTestCount=successfulTestCount + failedTestCount
| sort project_plan -build_number
| where totalTestCount = 0
| dedup project_plan 

threshold field = testlessResult
entity = project_plan