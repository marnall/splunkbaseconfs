# Incman connection configuraiton
[config]
host = <string>
* Incman host to connect to
* (required)

apiuser = <string>
* Incman api username
* (required)

apipassword = <string>
* Incman api user password
* (required)

user = <string>
* Incman user username
* (required)

password = <string>
* Incman user password
* (required)

ssl = <bool>
* Use ssl connection
* (required)

number_cef_field = <integer>
* Number of cef fields to add to incident
* (required)
