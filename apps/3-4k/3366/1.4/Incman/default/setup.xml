<setup>
    <block title="Incman Server Connection Configuration" endpoint="incman/incmanendpoint" entity="inc_config">
      <input field="host">
	<label>Hostname for Incman server</label>
	<type>text</type>
      </input>
      
      <input field="apiuser">
        <label>Api Username</label>
        <type>text</type>
      </input>
      <input field="apipassword">
        <label>Api Password</label>
        <type>password</type>
      </input>
	
      <input field="user">
	<label>Username</label>
	<type>text</type>
      </input>
      <input field="password">
	<label>Password</label>
	<type>password</type>
      </input>
      <input field="number_cef_field">
        <label>Max number cef fields</label>
        <type>text</type>
      </input>

    </block>
</setup>
