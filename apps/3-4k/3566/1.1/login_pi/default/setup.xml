<setup>
  <block title="Login PI Splunk intergration configuration">
    <text>This setup will configure the Splunk intergration with Login PI</text>
  </block>

  <block title="Login PI host configuration" endpoint="login_pi/pi_configuration" entity="setup">

      <input field="host">
        <label>Please provide the hostname of the Login PI server. Example [loginpi.login.lab:8080]</label>
        <type>text</type>
      </input>

  </block>

  <block title="Data capture interval" endpoint="login_pi/pi_configuration" entity="setup">

    <input field="interval">
      <label>Please provide an interval for the datacapture (default=5)</label>
      <type>text</type>
    </input>

  </block>
  
    <block title="Credentials">

    <input field="username" endpoint="login_pi/pi_configuration" entity="setup">
      <label>Please provide the username</label>
      <type>text</type>
    </input>

    <input field="password" endpoint="login_pi/pi_configuration" entity="setup">
      <label>Please provide the password</label>
      <type>password</type>
    </input>
  </block>


</setup>