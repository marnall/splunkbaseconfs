token.1.replacementType = file
token.1.replacement = $SPLUNK_HOME/etc/apps/Splunk_TA_New_Relic/samples/entity_name.sample

token.2.token = (##acount_id##)
token.2.replacementType = file
token.2.replacement = $SPLUNK_HOME/etc/apps/Splunk_TA_New_Relic/samples/id.sample

[nr_transactions.sample]
interval = 300
earliest = -60m
latest = now
sourcetype = newrelic:transactions
outputMode = modinput

## replace timestamps "last_reported_at": "2017-03-16T21:14:52+00:00"
token.0.token = last_reported_at":\s+"([^\+]+)
