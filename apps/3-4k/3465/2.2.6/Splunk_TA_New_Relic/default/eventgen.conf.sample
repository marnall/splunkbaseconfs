[nr_app.sample]
interval = 300
earliest = -60m
latest = now
sourcetype = newrelic:applications
outputMode = modinput

## replace timestamps "last_reported_at": "2017-03-16T21:14:52+00:00"
token.0.token = last_reported_at":\s+"([^\+]+)
token.0.replacementType = timestamp
token.0.replacement = %Y-%m-%d %H:%M:%S

## replace entity name
token.1.token = (##entity_name##)
token.1.replacementType = file
token.1.replacement = $SPLUNK_HOME/etc/apps/Splunk_TA_New_Relic/samples/entity_name.sample

