[nr_alerts_events.sample]
interval = 300
earliest = -60m
latest = now
sourcetype = newrelic:alerts:events
outputMode = modinput

## replace timestamps "timestamp": 1489261115005
token.0.token = timestamp":\s+([^,]+)
token.0.replacementType = timestamp
token.0.replacement = %s

## replace email
token.1.token = (##email##)
token.1.replacementType = file
token.1.replacement = $SPLUNK_HOME/etc/apps/Splunk_TA_New_Relic/samples/email_add.sample

[nr_alerts_violations.sample]
interval = 300
earliest = -60m
latest = now
sourcetype = newrelic:alerts:violations
outputMode = modinput


## replace timestamps "opened_at": 1485700620000
token.0.token = opened_at":\s+([^,]+)
token.0.replacementType = timestamp
token.0.replacement = %s

## replace entity name
token.1.token = (##entity_name##)
token.1.replacementType = file
token.1.replacement = $SPLUNK_HOME/etc/apps/Splunk_TA_New_Relic/samples/entity_name.sample
