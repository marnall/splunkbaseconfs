{"alert_action_builder": {"modular_alerts": [{"description": "Send Alerts to New Relic Insights", "largeIcon": "", "smallIcon": "", "label": "Send to New Relic", "short_name": "alerts_to_newrelic", "parameters": [{"format_type": "text", "required": false, "name": "account", "label": "New Relic Account Number", "default_value": "", "help_string": "", "type": "", "value": "631431"}, {"format_type": "text", "required": true, "name": "apikey", "label": "New Relic Insights Insert Key", "default_value": "", "help_string": "", "type": "", "value": "NRII-fmsXzlh_CPodik6J44A7Vuu6P7z1C-bN"}, {"format_type": "text", "required": true, "name": "eventtype", "label": "Event Type", "default_value": "SplunkAlert", "help_string": "", "type": "", "value": "SplunkAlert"}], "code": "\n# encoding = utf-8\n\ndef process_event(helper, *args, **kwargs):\n    \"\"\"\n    # IMPORTANT\n    # Do not remove the anchor macro:start and macro:end lines.\n    # These lines are used to generate sample code. If they are\n    # removed, the sample code will not be updated when configurations\n    # are updated.\n\n    [sample_code_macro:start]\n\n    # The following example sends rest requests to some endpoint\n    # response is a response object in python requests library\n    response = helper.send_http_request(\"http://www.splunk.com\", \"GET\", parameters=None,\n                                        payload=None, headers=None, cookies=None, verify=True, cert=None, timeout=None, use_proxy=True)\n    # get the response headers\n    r_headers = response.headers\n    # get the response body as text\n    r_text = response.text\n    # get response body as json. If the body text is not a json string, raise a ValueError\n    r_json = response.json()\n    # get response cookies\n    r_cookies = response.cookies\n    # get redirect history\n    historical_responses = response.history\n    # get response status code\n    r_status = response.status_code\n    # check the response status, if the status is not sucessful, raise requests.HTTPError\n    response.raise_for_status()\n\n\n    # The following example gets and sets the log level\n    helper.set_log_level(helper.log_level)\n\n    # The following example gets the alert action parameters and prints them to the log\n    account = helper.get_param(\"account\")\n    helper.log_info(\"account={}\".format(account))\n\n    apikey = helper.get_param(\"apikey\")\n    helper.log_info(\"apikey={}\".format(apikey))\n\n    eventtype = helper.get_param(\"eventtype\")\n    helper.log_info(\"eventtype={}\".format(eventtype))\n\n\n    # The following example adds two sample events (\"hello\", \"world\")\n    # and writes them to Splunk\n    # NOTE: Call helper.writeevents() only once after all events\n    # have been added\n    helper.addevent(\"hello\", sourcetype=\"sample_sourcetype\")\n    helper.addevent(\"world\", sourcetype=\"sample_sourcetype\")\n    helper.writeevents(index=\"summary\", host=\"localhost\", source=\"localhost\")\n\n    # The following example gets the events that trigger the alert\n    events = helper.get_events()\n    for event in events:\n        helper.log_info(\"event={}\".format(event))\n\n    # helper.settings is a dict that includes environment configuration\n    # Example usage: helper.settings[\"server_uri\"]\n    helper.log_info(\"server_uri={}\".format(helper.settings[\"server_uri\"]))\n    [sample_code_macro:end]\n    \"\"\"\n\n    helper.log_info(\"Alert action alerts_to_newrelic started.\")\n\n     # TODO: Implement your alert action logic here\n    import json\n    helper.set_log_level(helper.log_level)\n\n    acctId = helper.get_param(\"account\")\n    insertKey = helper.get_param(\"apikey\")\n    eventType = helper.get_param(\"eventtype\")\n\n    insightsURL = 'https://insights-collector.newrelic.com/v1/accounts/' + acctId + '/events'\n    \n    \n    # If the value is a number represented as a String, change it to a Number for Insights.\n    # if the key is in the 'dontChange' list, then leave those as Strings\n    dontChangeList = ['HTTPCode', 'httpcode']\n    \n    def parseFields(event):\n        event_out = {}\n        for key in event:\n            if key in dontChangeList:\n                event_out[key] = event[key]\n            else:\n                try:\n                    result_float = float(event[key])\n                    event_out[key] = result_float\n                except ValueError:\n                    event_out[key] = event[key]\n        return event_out\n\n\n    events = helper.get_events()\n\n    results_out = []\n    for event in events:\n        event['eventType'] = eventType\n        results_out.append(parseFields(event))\n\n    helper.log_info(\"Alert sent to New Relic Insights:  AlertText={}\".format(results_out))\n\n    payload = json.dumps(results_out)\n    headers = {  'X-Insert-Key': '{}'.format(insertKey), 'Content-Type': 'application/json'  }\n    response = helper.send_http_request(insightsURL, \"POST\", parameters=None, payload=payload, headers=headers, cookies=None, verify=True, cert=None, timeout=None, use_proxy=True)\n    \n    #helper.log_info(\"result={}\".format(response.text))  \n    response.raise_for_status()\n    \n    return response.status_code\n", "uuid": "909d306ddbbe47789c57fb03754938f5"}]}, "basic_builder": {"appname": "Splunk_TA_New_Relic", "friendly_name": "Splunk Add-on for New Relic", "version": "2.2.6", "author": "Splunk", "description": "Splunk add-on for New Relic", "theme": "#38b8bf", "large_icon": "", "small_icon": "", "visible": true, "tab_version": "4.1.0", "tab_build_no": "0", "build_no": 12}, "data_input_builder": {"datainputs": [{"index": "default", "sourcetype": "newrelic:multiple_inputs", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "parameters": [{"name": "api_key", "default_value": "", "format_type": "password", "help_string": "Enter new relic account's api key here ", "required": true, "value": "0d27291dc862905e8e3e8e0f570f0d10b98686e27ffe21d", "label": "API Key", "type": "password", "placeholder": ""}, {"name": "api_url", "default_value": [], "possible_values": [{"value": "applications.json", "label": "Applications"}, {"value": "key_transactions.json", "label": "Key Transactions"}, {"value": "mobile_applications.json", "label": "Mobile Applications"}, {"value": "servers.json", "label": "Servers"}, {"value": "alerts_events.json", "label": "Alerts Events"}, {"value": "alerts_violations.json", "label": "Alerts Violations"}], "format_type": "multi_dropdownlist", "help_string": "Select one or more Api URLs to collect data from New Relic", "required": true, "value": ["applications.json"], "label": "API URL", "type": "multi_dropdownlist", "placeholder": ""}, {"name": "account", "default_value": "", "format_type": "text", "help_string": "Enter your New Relic account number. You can locate it here: https://rpm.newrelic.com/accounts/<######>/applications", "required": true, "value": "781649", "label": "Account ID ", "type": "text", "placeholder": ""}], "description": "Configure this input to collect data from one or more components associated with your New Relic account", "customized_options": [{"name": "api_url", "value": ["applications.json"]}, {"name": "account", "value": "781649"}], "name": "new_relic_account_input", "type": "customized", "title": "New Relic Account Input", "uuid": "d8cda3100b0e4e89af4510810d98ee07", "sample_count": 0, "is_loaded": true, "data_inputs_options": [{"type": "customized_var", "name": "api_key", "title": "API Key", "description": "Enter new relic account's api key here ", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "customized_var", "name": "api_url", "title": "API URL", "description": "Select one or more Api URLs to collect data from New Relic", "required_on_edit": false, "required_on_create": true, "possible_values": [{"value": "applications.json", "label": "Applications"}, {"value": "key_transactions.json", "label": "Key Transactions"}, {"value": "mobile_applications.json", "label": "Mobile Applications"}, {"value": "servers.json", "label": "Servers"}, {"value": "alerts_events.json", "label": "Alerts Events"}, {"value": "alerts_violations.json", "label": "Alerts Violations"}], "format_type": "multi_dropdownlist", "default_value": [], "placeholder": ""}, {"type": "customized_var", "name": "account", "title": "Account ID ", "description": "Enter your New Relic account number. You can locate it here: https://rpm.newrelic.com/accounts/<######>/applications", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": ""}], "code": "\n# encoding = utf-8\n\nimport os\nimport sys\nimport time\nimport datetime\n\n'''\n    IMPORTANT\n    Edit only the validate_input and collect_events functions.\n    Do not edit any other part in this file.\n    This file is generated only once when creating the modular input.\n'''\n'''\n# For advanced users, if you want to create single instance mod input, uncomment this method.\ndef use_single_instance_mode():\n    return True\n'''\n\ndef validate_input(helper, definition):\n    \"\"\"Implement your own validation logic to validate the input stanza configurations\"\"\"\n    pass\n\ndef collect_events(helper, ew):\n    \"\"\"Implement your data collection logic here\n\n    # To create a splunk event\n    helper.new_event(data, time=None, host=None, index=None, source=None, sourcetype=None, done=True, unbroken=True)\n    \"\"\"\n\n    import json, re\n    import jsonpath_rw\n    api_base_url = \"https://api.newrelic.com/v2/\"\n    opt_api_key = helper.get_arg('api_key')\n    headers = {'X-Api-Key': '{}'.format(opt_api_key)}\n    parameters = \"\"\n    api_url = helper.get_arg('api_url')\n    opt_account = helper.get_arg('account')\n    account_dict = {'account_id': '{}'.format(opt_account)}\n    urls = api_url\n\n    if opt_account:\n        input_source = helper.get_input_stanza_names() + \":\" + opt_account\n    else:\n        input_source = helper.get_input_stanza_names()\n\n    for i in range(len(urls)):\n        url = api_base_url + urls[i]\n        if urls[i] == \"alerts_events.json\":\n            break_point = \"recent_events\"\n            source_type = \"newrelic:alerts:events\"\n        elif urls[i] == \"alerts_violations.json\":\n            break_point = \"violations\"\n            source_type = \"newrelic:alerts:violations\"\n        elif urls[i] == \"browser_applications.json\":\n            break_point = \"browser_applications\"\n            source_type = \"newrelic:applications:browser\"\n        elif urls[i] == \"mobile_applications.json\":\n            break_point = \"applications\"\n            source_type = \"newrelic:applications:mobile\"\n        elif urls[i] == \"servers.json\":\n            break_point = \"servers\"\n            source_type = \"newrelic:servers\"\n        elif urls[i] == \"key_transactions.json\":\n            break_point = \"key_transactions\"\n            source_type = \"newrelic:transactions\"\n        else:\n            break_point = \"applications\"\n            source_type = \"newrelic:applications\"\n        \n        \n        j=0\n        while j==0:\n            response = helper.send_http_request(url, \"GET\", headers=headers,  parameters=parameters, payload=None, cookies=None, verify=True, cert=None, timeout=None, use_proxy=True)\n\n            r_json = response.json()\n            r_headers = str(response.headers)\n            r_status = response.status_code\n\n            try:\n                response.raise_for_status()\n                \n            except:\n                helper.log_error (response.text)\n                \n            if r_status == 200:\n                helper.log_info (\"Continue data collection process \")\n            #capture next link for pagination\n            m = re.search(\".*Link.*(http[^>]+).+\\srel=\\\"next\\\".*\", r_headers)\n            \n            try:\n                for one_dict in r_json.get(break_point):\n                    one_dict.update(account_dict)\n                    data = json.dumps(one_dict)\n                    event = helper.new_event(source=input_source, index=helper.get_output_index(), sourcetype=source_type, data=data)\n                    ew.write_event(event)\n            except:\n                helper.log_info(\"Caught noneType\")\n            if r_status == 200:\n                helper.log_info(\"checking if more pages exist to collect data from\")\n            \n            \n            if m:\n                url=m.group(1)\n                helper.log_info(\"Collecting data from next page i.e, url={}\".format(url)) \n                i=i+1\n            else:\n                if r_status == 200:\n                    helper.log_warning (\"No more data exist for sourcetype={}, end of data collection\".format(source_type))\n                break\n            \n\n    \n    \n    \n  \n\n\n  "}, {"index": "default", "sourcetype": "newrelic:insights", "interval": "60", "use_external_validation": true, "streaming_mode_xml": true, "parameters": [{"name": "account_number", "label": "New Relic Account Number", "help_string": "This is the number in your New Relic url.  e.g.: https://rpm.newrelic.com/accounts/<######>/applications", "required": true, "format_type": "text", "default_value": "", "placeholder": "#####", "type": "text", "value": "781649"}, {"name": "insights_api_key", "label": "Insights API Key", "help_string": "You can create or locate your API Key here:  https://insights.newrelic.com/accounts/XXXXXX/manage/api_keys", "required": true, "format_type": "password", "default_value": "", "placeholder": "", "type": "password", "value": "j5QaPs0W46XXR3DCAUCjitxb8lVhd2QI"}, {"name": "nrql_query", "label": "NRQL Query", "help_string": "Enter the NRQL Query to execute", "required": true, "format_type": "text", "default_value": "SELECT average(duration) FROM PageView SINCE 5 Minutes ago", "placeholder": "", "type": "text", "value": "SELECT average(duration) FROM PageView SINCE 5 Minutes ago"}], "use_basic_auth": false, "description": "Collect data by executing a query in New Relic Insights via Insights API", "customized_options": [{"name": "account_number", "value": "781649"}, {"name": "nrql_query", "value": "SELECT average(duration) FROM PageView SINCE 5 Minutes ago"}], "data_inputs_options": [{"name": "_rest_api_url", "rest_header": false, "description": "url", "value": "https://insights-api.newrelic.com/v1/accounts/${account_number}/query?nrql=${nrql_query}"}, {"name": "_rest_api_method", "rest_header": false, "description": "method", "value": "GET"}, {"name": "X-Query-Key", "value": "${insights_api_key}", "rest_header": true, "description": "X-Query-Key"}, {"type": "event_json_path_key", "name": "_event_json_path_key", "value": ""}, {"type": "ckpt_enable", "name": "_ckpt_enable", "value": false}, {"type": "ckpt_var_name", "name": "_ckpt_var_name", "value": ""}, {"type": "ckpt_json_path_key", "name": "_ckpt_json_path_key", "value": ""}, {"type": "ckpt_initial_value", "name": "_ckpt_initial_value", "value": ""}, {"type": "ckpt_source_time_format", "name": "_ckpt_source_time_format", "value": ""}, {"type": "ckpt_target_time_format", "name": "_ckpt_target_time_format", "value": ""}, {"type": "customized_var", "name": "account_number", "title": "New Relic Account Number", "description": "This is the number in your New Relic url.  e.g.: https://rpm.newrelic.com/accounts/<######>/applications", "required_on_edit": false, "required_on_create": true, "format_type": "text", "default_value": "", "placeholder": "#####"}, {"type": "customized_var", "name": "insights_api_key", "title": "Insights API Key", "description": "You can create or locate your API Key here:  https://insights.newrelic.com/accounts/XXXXXX/manage/api_keys", "required_on_edit": false, "required_on_create": true, "format_type": "password", "default_value": "", "placeholder": ""}, {"type": "cus