# Spark Room alert action params

action.room.param.agent = <string>
* list of agents associated with the alert.

action.room.param.subject = <string>
* Title of the room.

action.room.param.desc = <string>
* Description of the alert.
* This will be sent as first message in the room.

action.room.param.viewLink = <string>
* Get link of the triggered alert

action.room.param.searchLink = <string>
* Get link of search result

action.room.param.alertName = <string>
* Get Saved Search name
