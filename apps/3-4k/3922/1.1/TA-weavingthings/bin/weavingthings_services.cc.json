{
    "requests": [
        {
            "request": {
                "method": "POST", 
                "headers": {
                    "Content-Type": "application/json"
                }, 
                "url": "https://platform.weavingthings.com:4443/services", 
                "body": {
                    "appname": "{{__settings__.additional_parameters.appname}}", 
                    "appkey": "{{__settings__.additional_parameters.api_key}}"
                }
            }, 
            "pre_process": {
                "skip_conditions": [], 
                "pipeline": []
            }, 
            "iteration_mode": {
                "stop_conditions": [
                    {
                        "method": "json_empty", 
                        "input": [
                            "{{__response__.body}}", 
                            "$.data.services"
                        ]
                    }
                ], 
                "iteration_count": "1"
            }, 
            "post_process": {
                "skip_conditions": [
                    {
                        "method": "json_empty", 
                        "input": [
                            "{{__response__.body}}", 
                            "$.data.services"
                        ]
                    }
                ], 
                "pipeline": [
                    {
                        "method": "json_path", 
                        "input": [
                            "{{__response__.body}}", 
                            "$.data.services"
                        ], 
                        "output": "__stdout__"
                    }, 
                    {
                        "method": "splunk_xml", 
                        "input": [
                            "{{__stdout__}}", 
                            "", 
                            "{{index}}", 
                            "{{host}}", 
                            "{{source}}", 
                            "{{sourcetype}}"
                        ], 
                        "output": "__stdout__"
                    }, 
                    {
                        "method": "std_output", 
                        "input": [
                            "{{__stdout__}}"
                        ]
                    }
                ]
            }
        }
    ], 
    "meta": {
        "apiVersion": "1.0.0"
    }, 
    "global_settings": {
        "logging": {
            "level": "{{__settings__.logging.loglevel}}"
        }
    }, 
    "tokens": [
        "__settings__.logging.loglevel", 
        "__settings__.additional_parameters.appname", 
        "__settings__.additional_parameters.api_key"
    ]
}