<setup>
  <block title="InsightIDR"
         endpoint="idr/idr_configuration" entity="setupentity">
    <text>Enter the hostname or IP address of each of your InsightIDR collectors (e.g. collector.mynetwork.com).</text>
<!--
   <input field="app_enabled">
   <label>Enable InsightIDR functionality</label>
<type>bool</type>
</input>
    -->

    <input field="hostnames">
      <label>InsightIDR collectors</label>
      <type>text</type>
    </input>

 <text>
      <![CDATA[ <script type="text/javascript">
        $(document).ready(function(){
            var submit_btn = $(".splButton-primary");
            submit_btn.text("Save and Submit");
            console.log("Submitted.");
        });

        $(function() {
          var valid_host = function(host){
            return host != "";
          }

          var input_focused = function(event){
            add_host_input(event);
          }

          var update_hosts = function(){
            //Get the text from all collector boxes
            var inputs = $("input[id^='collector_']");
            var collectors = [];
            for(var i = 0; i < inputs.length; i++) {
              collectors.push(inputs[i].value);
            }

            hosts_element[0].value = collectors.filter(valid_host).join(',');
          };

          //Split the hosts field into a number of inputs
          var hosts_element = $("#\\/idr\\/idr_configuration\\/setupentity\\/hostnames_id");
          var hosts = hosts_element[0].value;
          hosts = hosts.split(',');
          var parent_div = hosts_element.parent();
          hosts_element.hide();

          hosts.push('');
          for(var i = 0; i < hosts.length; i++)
          {
              jQuery('<input/>', {
                  id: 'collector_' + i,
                  value: hosts[i]
              }).appendTo(parent_div);
              jQuery('<br/>').appendTo(parent_div);
          }

          //Append a new input box when the last one is clicked
          var add_host_input = function(event){
            var id = event.target.id;
            if(!id.startsWith('collector')){
              return;
            }

            collector_id = parseInt(id.split('_').pop());
            if(collector_id < (hosts.length-1)){
              return;
            }

            var collector_id = 'collector_' + hosts.length;
            jQuery('<input/>', {
                id: collector_id,
                value: ''
            }).appendTo(parent_div);
            jQuery('<br/>').appendTo(parent_div);

            hosts.push('');
            $("#"+collector_id).on('input paste', update_hosts);
            $("#"+collector_id).on('focus', input_focused);
          };  

          //Hook up all inputs to events
          $("input[id^='collector_']").on('input paste', update_hosts);
          $("input[id^='collector_']").on('focus', input_focused);
        });
      </script> ]]>
    </text>

  </block>
</setup>
