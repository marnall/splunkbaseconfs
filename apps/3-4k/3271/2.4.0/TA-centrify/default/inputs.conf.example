# This file  contains entries for various standard file locations for monitoring syslog depending on OS platform. You may need to check actual file location where Centrify Audit TRAIL logs getting collected and may need to add that location in new stanza if not present in this file.By default all the monitoring stanzas are disabled. To enable any monitoring stanza, change the disabled property of stanza from “disabled = 1” to “diabled = 0”.

# windows
[WinEventLog://Application]
whitelist = SourceName="Centrify AuditTrail V2"
disabled = 1

# Solaris & AIX
[monitor:///var/adm/messages]
sourcetype = syslog
disabled = 1

# Red Hat, CentOS, Citrix XenServer, oracle Enterprise Linux, Scientific Linux, Fedora, SUSE, openSUSE
[monitor:///var/log/messages]
sourcetype = syslog
disabled = 1

# Ubuntu, Debian, Linux Mint
[monitor:///var/log/syslog]
sourcetype = syslog
disabled = 1

#HPUX
[monitor:///var/adm/syslog/syslog.log]
sourcetype = syslog
disabled = 1

#Mac/Darwin
[monitor:///var/log/system.log]
sourcetype = syslog
disabled = 1
