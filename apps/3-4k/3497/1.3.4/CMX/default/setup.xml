<setup>

  <block title="CMX Setup page" endpoint="cmx/cmximagemapendpoint" entity="imagemapentity">
  	<text><![CDATA[
    <script>
    function addStar( labelname )
    {
    	var newlabel=document.getElementById('/cmx/cmximagemapendpoint/imagemapentity/'+labelname +'_id').parentElement.parentElement.firstElementChild.innerHTML;

    	newlabel = newlabel +"<font color=\"red\" face=\"verdana\">*</font>";

		document.getElementById('/cmx/cmximagemapendpoint/imagemapentity/'+labelname +'_id').parentElement.parentElement.firstElementChild.innerHTML=newlabel;
    }

	$(document).ready(function(e)
	{
		$(window).keydown(function(event){
		if(event.keyCode == 13) 
		{
				
			if(validateIP("RESTSERVER") && validateIndex("INDEX"))
			{
					return true;
			}
			else
			{
					event.preventDefault();
					return false;
			}
		}	
		});		
		var app = Splunk.util.getCurrentApp();
		var css = "/static/app/" + app + "/setup.css";
		addStylesheet(css);

		var label=document.getElementById('/cmx/cmximagemapendpoint/imagemapentity/RESTSERVER_id').parentElement.parentElement.firstElementChild.innerHTML;
		if (!label.includes("*"))
		{ 
			label = label +"<font color=\"red\" face=\"verdana\">*</font>";

			addStar("RESTSERVER");

			addStar("USERNAME");

			addStar("PASSWORD");
			

			label=document.getElementById('/cmx/cmximagemapendpoint/imagemapentity/INDEX_id').parentElement.parentElement.firstElementChild.innerHTML

			label = label +"<br><font color=\"#a5acb7\" face=\"verdana\">To use index other than main, please specify it here.</font><br><font color=\"#a5acb7\" face=\"verdana\"><i><sup>**</sup>Make sure you specify same index which you configured on TA-CMX setup.</i></font>";

			document.getElementById('/cmx/cmximagemapendpoint/imagemapentity/INDEX_id').parentElement.parentElement.firstElementChild.innerHTML=label;
		}

		$(".splButton-primary").on("click",function(e) { 
		    $('.custom-error').remove();
			
			if(validateIP("RESTSERVER") && validateIndex("INDEX"))
			{
				console.log('HERE');
				return true;
			}
			else 
			{
				e.preventDefault();
			}
		});
		
	});
	function addStylesheet( filename )
	{
		if( document.createStyleSheet )
		{
			document.createStyleSheet(filename);
		}
		else
		{
			var link = $("<link>");
			link.attr({type: 'text/css',rel: 'stylesheet', href: filename});
			$("head").append( link );
		}
	}

	function validateTextBox(name) 
	{
		var errMsg = "";
		var _errid = name+'_err';
		var errid = '#'+_errid;
		var fieldval = "";
		var fieldLabel = "";
		
		var fieldvalRegex = "";
		
		if(name==="USERNAME"){
			fieldvalRegex = /^[a-z0-9!@&-]+$/;
		}
		else if (name==="PASSWORD"){
			fieldvalRegex = /^[a-z0-9!@&-]{8}[a-z0-9!@&-]*$/;
		}
		
		fieldval = $.trim($('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id').val());

		label = $('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id')[0].parentElement.parentElement.firstElementChild.innerHTML;
			
       	if(fieldval.length<=0)
		{
	   		console.log(fieldval);
	    	errMsg="Please enter " +label.replace("*","")+" in the textbox";
			var div = $(''+errid+'');
			if (div.length ==0 )
	    	{
				$('#item-\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/'+name+' > div').append("<div id='"+_errid+"' class='custom-error' style='display:inline'> "+errMsg+ "</div>");
			}
			else if (div.length >0)
	    	{
	    		div[0].innerHTML = errMsg;
				div[0].style = 'display:inline';
	    	}
			return false;
		}
		else if(!fieldval.match(fieldvalRegex))
		{
			errMsg="Please enter valid " +label.replace("*","");
			var div = $(''+errid+'');
			if (div.length ==0 )
			{
				$('#item-\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/'+name+' > div').append("<div id='"+_errid+"' class='custom-error' style='display:inline'> "+errMsg+ "</div>");
			}
			else if (div.length >0)
			{
				div[0].innerHTML = errMsg;
				div[0].style = 'display:inline';
			}
			return false;
		}
		else
		{
			$(errid).hide();
			return true;
		}
	}

	function validateNumber(name) 
	{
		console.log('In Validate Number')
		var patt = /^([0-9]{1,4}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$/i;
		var errMsg = "";
		var _errid = name+'_err';
		var errid = '#'+_errid;
		var fieldval = "";
		fieldval = $.trim($('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id').val());

		label = $('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id')[0].parentElement.parentElement.firstElementChild.innerHTML;

       	if(fieldval.length<=0 && name !='RESTPORT')
		{
			console.log(fieldval);
			errMsg="Please enter " +label.replace("*","")+" in the textbox";
			var div = $(''+errid+'');
			if (div.length ==0 )
	    	{
				$('#item-\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/'+name+' > div').append("<div id='"+_errid+"' class='custom-error' style='display:inline'> "+errMsg+ "</div>");
			}
			else if (div.length >0)
	    	{
	    		div[0].innerHTML = errMsg;
				div[0].style = 'display:inline';
	    	}
			return false;
		}
		else if (!patt.test(fieldval) && fieldval.length >0)
		{
			
			errMsg="Please enter valid " +label.replace("*","");
			var div = $(''+errid+'');
	    	if (div.length ==0 )
	    	{
				$('#item-\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/'+name+' > div').append("<div id='"+_errid+"' class='custom-error' style='display:inline'> "+errMsg+ "</div>");
			}
			else if (div.length >0)
	    	{
	    		div[0].innerHTML = errMsg;
				div[0].style = 'display:inline';
	    	}

			return false;
		}
		else
		{
			$(errid).hide();
			return true;
		}
	}

	function validateIP(name) 
	{
		
		var errMsg = "";
		var _errid = name+'_err';
		var errid = '#'+_errid;
		var fieldval = "";
		var fieldLabel = "";
		var ipRegex = /^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$/;
		fieldval = $.trim($('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id').val());

		var hostRegex = "^(([a-zA-Z0-9]|[a-zA-Z0-9][a-zA-Z0-9\-]*[a-zA-Z0-9])\.)*([A-Za-z0-9]|[A-Za-z0-9][A-Za-z0-9\-]*[A-Za-z0-9])$";

		label = $('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id')[0].parentElement.parentElement.firstElementChild.innerHTML;
		
		
		if(fieldval.length>0)
		{
        	if(fieldval.match(ipRegex) || fieldval.match(hostRegex))
			{
		    	console.log("Ip is correct")
		    	$(errid).hide();
		    	if(validateTextBox("USERNAME") && validateTextBox("PASSWORD") && validateNumber("RESTPORT"))
		    		{
		    			return true;
		    		}
		    	else
				{
					return false;
				}

			}
			else
			{
				console.log(fieldval);
		    	errMsg="Please enter valid Host Name or IP Address of CMX.";
		    	var div = $(''+errid+'');
	    		if (div.length ==0 )
	    		{
					$('#item-\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/'+name+' > div').append("<div id='"+_errid+"' class='custom-error' style='display:inline'> "+errMsg+ "</div>");
				}
				else if (div.length >0)
	    		{
	    			div[0].innerHTML = errMsg;
					div[0].style = 'display:inline';
	    		}
				return false;
			}
		}
		else
		{
			
			return true;
		}
		
	}
	
	function validateIndex(name) 
	{
		var errMsg = "";
		var _errid = name+'_err';
		var errid = '#'+_errid;
		var fieldLabel = "";
		var indexRegex = /^[a-z0-9][a-z0-9_-]*$/;
		var fieldval = $.trim($('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id').val());
		fieldLabel = $('#\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/' + name + '_id')[0].parentElement.parentElement.firstElementChild.innerHTML;
		
		
		if(fieldval.length>0)
		{
        	if(fieldval.match(indexRegex))
			{
		    	$(errid).hide();
		    	return true;
			}
			else
			{
		    	errMsg="Please enter valid Index";
		    	var div = $(''+errid+'');
	    		if (div.length ==0 )
	    		{
					$('#item-\\/cmx\\/cmximagemapendpoint\\/imagemapentity\\/'+name+' > div').append("<div id='"+_errid+"' class='custom-error' style='display:inline'> "+errMsg+ "</div>");
				}
				else if (div.length >0)
	    		{
	    			div[0].innerHTML = errMsg;
					div[0].style = 'display:inline';
	    		}
				return false;
			}
		}
		else
		{
			return true;
		}
	}
    </script>
  ]]></text>
  
      
     <input field="RESTSERVER">
        <label>CMX Host Name/IP Address</label>
        <type>text</type>
    </input>
    <input field="RESTPORT">
        <label>Port Number for CMX</label>
        <type>text</type>
    </input>
    <input field="USERNAME">
        <label>User Name of CMX</label>
        <type>text</type>
    </input>
    <input field="PASSWORD">
        <label>Password of CMX</label>
        <type>password</type>
    </input>
    <input field="INDEX" >
      <label>Index</label>
      <type>text</type>
    </input>
    <input field="ALLSSC" >
      <label>Allow Self Signed Certificate</label>
      <type>bool</type>
    </input>
  </block>

</setup>
