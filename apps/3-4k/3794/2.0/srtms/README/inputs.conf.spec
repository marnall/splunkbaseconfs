[srtms://<name>]

srtms_sam = <value>
* Enable Software Asset Management.

srtms_svm = <value>
* Enable Software Vulnerability Management.

srtms_api = <value>
* This is sRTMS Url.

srtms_license = <value>
* This is the sRTMS License key.

srtms_login = <value>
* This is the sRTMS Login.

srtms_pwd = <value>
* This is the sRTMS Password.

splunk_api = <value>
* This is the Splunk API Url. When provided, Splunk indexes will be used as a datasource for fatstacks sRTMS.

splunk_login = <value>
* This is the Splunk Login.

splunk_pwd = <value>
* This is the Splunk Password.

splunk_device_search = <value>
* This is the Splunk Device Search query.

splunk_package_search = <value>
* This is the Splunk Package Search query.

srtms_api_size = <value>
* This is sRTMS API size page.