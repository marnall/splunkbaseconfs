stepClickEvent3 = mousedown
stepClickEvent4 = mousedown
stepElement2 = .fieldset.splunk-view.editable
stepElement3 = .dashboard-row.dashboard-row1.splunk-view
stepElement4 = .dashboard-row.dashboard-row2.splunk-view
stepPosition2 = bottom
stepPosition3 = bottom
stepPosition4 = top
stepText1 = <b>Welcome to Data Lab!</b><BR><BR>Data Lab is a place to explore different security data sources for <fon
t color="yellow">use-case development / demo / training</font>. Initially we are introducing the data explorer for you
 to explorer different data-sets. <BR>Far more features with Security search use-cases wil be extended from this app.
stepText2 = This is <font color="yellow">Data Source Explorer</font>.<BR><BR> Select either <font color="yellow">Vendo
r</font>, <font color="yellow">Technology</font> or <font color="yellow">Soucetype</font>. <BR> Make sure to de-select
 "<font color="yellow">* - ALL</font>", this will affect next select options.
stepText3 = Your selection is verfified here, showing quick stattistics on your selection.<BR> There are now 45 Vendor
s and 257 data sourcetypes indexed here.
stepText4 = Here selected source types are listed for you to dive in. <BR> Click on a single data source to view raw d
ata.  Once a sourcetype is seleted and loaded in an expanded events list, further click on magnifying glass to jump in
to a free search in Splunk <font color="yellow">Search</font>window.
tourPage = datalab_01
type = interactive
urlData = ?form.VENDOR=*&form.TECH=*&form.SOURCETYPE=*&earliest=0&latest=


