<setup>
  <block title="Demo Mode"
         endpoint="tm1_data/tm1_endpoint" entity="tm1_parameters">
      <input field="eventgen_bool">
        <label>Select -only- if you want to enable demo mode.  TM1 events will be generated and sent to the index tm1_eventgen</label>
        <type>bool</type>
      </input>
  </block>
  <block title="TM1 Index Name"
         endpoint="tm1_data/tm1_endpoint" entity="tm1_parameters">
      <input field="tm1_index_name">
        <label>Enter the name of the index for TM1 data to be sent to (default, tm1).  If demo mode is enabled, this should be set to tm1_eventgen</label>
        <type>text</type>
      </input>
  </block>
  <block title="Distributed Environment"
         endpoint="tm1_data/tm1_endpoint" entity="tm1_parameters">
      <input field="use_forwarder_bool">
        <label>Select if you are using forwarders to collect TM1 data.</label>
        <type>bool</type>
      </input>
  </block>
  <block title="TM1 Top Level Install Directory"
         endpoint="tm1_data/tm1_endpoint" entity="tm1_parameters">
      <input field="data_location">
        <label>This is the top level directory that the TM1 instance(s) are installed into.  Example: C:\Program Files\IBM </label>
        <type>text</type>
      </input>
  </block>
  <block title="Splunk Home Directory (e.g. C:\Program Files)"
         endpoint="tm1_data/tm1_endpoint" enabled="in-windows" entity="tm1_parameters">
      <input field="windows_splunk_dir">
        <label>This directory should contain the Splunk installation</label>
        <type>text</type>
      </input>
  </block>
</setup>
