[languardian://default]
*This is how the LANGuardian App For Splunk is configured

hostname = <value>
*This is the hostname for the NetFort appliance

report_ids = <value>
*Report IDs to be indexed. Separate each ID with a comma.

report_credential_realm = <value>
*Required. The realm of a credential to use.

report_user = <value>
*Required. Used to search for the correct credential.

http_type = <value>
*Specify HTTP or HTTPS for connection to host.

proxy_name = <value>
*Optional. The stanza name of the Proxy Configuration to use.