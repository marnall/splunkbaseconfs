<setup>
    <block title="Splunk For CAWS Configuration Settings">
        <text>Use of the CAWS API with Splunk requires Automation privileges.</text>
    </block>
    <block title="Please provide your CAWS API credentials." endpoint="caws/config" entity="settings">
        <input field="username">
            <label>CAWS API Username:</label>
            <type>text</type>
        </input>
        <input field="password">
            <label>CAWS API Password:</label>
            <type>password</type>
        </input>            
    </block>
    <block title="Splunk For CAWS Configuration Settings" endpoint="caws/config" entity="settings">
        <text>These settings are defaults and normally do not need to be changed.</text>
        <input field="interval">
            <label>Request Interval (seconds):</label>
            <type>text</type>
        </input>
        <input field="baseurl">
            <label>CAWS API Host URL (https://data.nsslabs.com):</label>
            <type>text</type>
        </input>
        <input field="proxy">
            <label>Proxy Server:</label>
            <type>text</type>
        </input>
    </block>
</setup>