<form>
  <label>Predict</label>
  <fieldset submitButton="true" autoRun="true">
    <input type="dropdown" token="field1">
      <label>Currencies</label>
      <choice value="avg(TWD) as avg_TWD | predict avg_TWD">TWD</choice>
      <choice value="avg(JPY) as avg_JPY | predict avg_JPY">JPY</choice>
      <choice value="avg(AUD) as avg_AUD | predict avg_AUD">AUD</choice>
      <choice value="avg(EUR) as avg_EUR | predict avg_EUR">EUR</choice>
      <choice value="avg(GBP) as avg_GBP | predict avg_GBP">GBP</choice>
      <choice value="avg(CAD) as avg_CAD | predict avg_CAD">CAD</choice>
      <choice value="avg(CNY) as avg_CNY | predict avg_CNY">CNY</choice>
      <default>avg(TWD) as avg_TWD | predict avg_TWD</default>
    </input>
    <input type="dropdown" token="field2">
      <label>History</label>
      <choice value="1d">1d</choice>
      <choice value="5d">5d</choice>
      <choice value="1w">1w</choice>
      <choice value="1mon">1mon</choice>
      <choice value="1h">1h</choice>
      <choice value="12h">12h</choice>
      <default>1d</default>
    </input>
  </fieldset>
  <row>
    <panel>
      <chart>
        <title>Predict future currency value</title>
        <search>
          <query>sourcetype="usd" | timechart span=$field2$ $field1$</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.axisY2.enabled">undefined</option>
      </chart>
    </panel>
  </row>
</form>