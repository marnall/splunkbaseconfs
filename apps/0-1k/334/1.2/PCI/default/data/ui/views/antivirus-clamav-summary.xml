<dashboard>
  <label>Clam AV</label>

  <row>
    <html><center><h1>Clam AV</h1></center></html>
  </row>

 <row>
  <single>
   <searchName>ClamAV-Update_Date</searchName>
   <title>Last Update</title>
   <option name="field">Updated</option>
  </single>
  <single>
   <searchName>ClamAV-Updated_24hours</searchName>
   <option name="classField">range</option>
   <title>AV Updates in 24h</title>
   <option name="field">count</option>
   <option name="afterLabel">updates in 24h</option>
  </single>
  <single>
   <searchName>ClamAV-signatures</searchName>
   <title>AV Signature Pack</title>
   <option name="field">Signatures</option>
   <earliestTime>-24h</earliestTime>
   <option name="afterLabel">signatures</option>
  </single>
 </row>
 <row>
   <chart>
     <title>ClamAV Daemon by Host</title>
     <searchTemplate>clamav Update process started | top host limit=0</searchTemplate>
     <option name="charting.chart">pie</option>
     <earliestTime>-7d</earliestTime>
   </chart>
   <chart>
     <title>ClamAV Process by Host</title>
     <searchTemplate>source="/var/log/clamav/clamav.log" SelfCheck | timechart count by host</searchTemplate>
     <option name="charting.chart">line</option>
     <earliestTime>-30d</earliestTime>
     <option name="charting.chart.stackMode">default</option>
     <option name="charting.legend.placement">left</option>
     <option name="charting.chart.nullValueMode">gaps</option>
     <option name="charting.secondaryAxisTitle.text">Clam Process</option>
    </chart>
 </row>
 <row>
   <table>
     <title>ClamAV Daemon</title>
     <searchTemplate>source=/var/log/clamav/freshclam.log clamav Update process started | rename _time AS Updated | table host Updated</searchTemplate>
     <earliestTime>-24h</earliestTime>
    </table> 
 </row>
</dashboard>
