<form class="formsearch">
  <label>Linux System Patching</label>

  <fieldset>
    <input type="dropdown" token="host" searchWhenChanged="true">
      <label>Selected Host(s):</label>
      <default>ALL HOSTS (*)</default>
      <populatingSearch fieldForValue="host" fieldForLabel="host">ubuntu | top host |fields host</populatingSearch>
      <choice value="*">ALL HOSTS (*)</choice>
    </input>
  </fieldset>

  <row>
    <html><left><h1>System Updates</h1></left></html>
    <html><left>The Requirement States: Ensure that all system components and software have the latest vendor-supplied security patches installed. Install critical security patches within one month of release. </left></html>
    
  </row>

 <row>
	<chart>
     		<title>Hosts Updated</title>
     		<searchTemplate>source="/var/log/apt/history.log" host=$host$ Upgrade | chart count by host </searchTemplate>
     		<option name="charting.chart">pie</option>
     		<earliestTime>-30d</earliestTime>
   	</chart>
	<table>
		<title>Updates Applied</title>
		<searchTemplate>source="/var/log/apt/history.log" host=$host$ Upgrade</searchTemplate>
		<earliestTime>-30d</earliestTime>
	</table>

</row>

</form>

