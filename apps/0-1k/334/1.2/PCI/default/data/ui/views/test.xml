<?xml version="1.0"?>
<view template="dashboard.html" stylesheet="application.css">
    <label>Summary</label>
    <module name="AccountBar" layoutPanel="appHeader"/>
    <module name="AppBar" layoutPanel="navigationHeader"/>
    <module name="Message" layoutPanel="messaging">
        <param name="filter">*</param>
        <param name="clearOnJobDispatch">False</param>
        <param name="maxSize">1</param>
    </module>
    <module name="TitleBar" layoutPanel="viewHeader">
        <param name="actionsMenuFilter">dashboard</param>
    </module>
    
    <!--
        Global index summary counts
    -->
    <module name="HiddenSearch" group="Global summary" layoutPanel="panel_row1_col1" autoRun="true">
        <param name="search">| metadata type=hosts </param>
        <param name="maxCount">100000</param>
        <module name="HiddenPostProcess">
            <param name="search">| stats sum(totalCount)</param>
            <module name="SingleValue">
                <param name="beforeLabel">Events indexed</param>
                <param name="format">number</param>
            </module>
        </module>
        <module name="HiddenPostProcess" layoutPanel="panel_row1_col2" autoRun="true">
            <param name="search">| stats min(firstTime) as min | convert ctime(min)</param>
            <module name="SingleValue">
                <param name="beforeLabel">Earliest event</param>
                <param name="format">unixtime</param>
            </module>
        </module>
        <module name="HiddenPostProcess" layoutPanel="panel_row1_col3" autoRun="true">
            <param name="search">| stats max(lastTime) as max | convert ctime(max)</param>
            <module name="SingleValue">
                <param name="beforeLabel">Latest event</param>
                <param name="format">unixtime</param>
            </module>
        </module>
    </module>

    <module name="IFrameInclude">
      <param name="src">192.168.244.131/sfeed.html</param>
      <param name="height">42</param>
    </module>

</view>
