<dashboard>
 <label>Firewall Summary</label>

  <row>
    <html><center><h1>Firewall Summary</h1></center></html>
    <html><left>This page provides an overview summary of the firewalls status for dropped traffic over the past 7 days.</left></html>
  </row>

 <row>
  <single>
   <searchName>Firewall-Denied_Packet_Count_RangeMap</searchName>
   <title>Drops in last 7d</title>
   <earliestTime>-7d</earliestTime>
   <option name="classField">range</option>
  </single>
  <single>
   <searchName>Firewall-Denied_Traffic_Country</searchName>
   <title>Biggest Offending Country</title>
   <earliestTime>-7d</earliestTime>
  </single>
  <single>
   <searchName>Firewall-Denied_Ports_Top</searchName>
   <title>Most Attempted Port</title>
   <earliestTime>-7d</earliestTime>
  </single>
 </row>
  
 <row>
  <chart>
   <searchName>Firewall-Average_Denied_Traffic_Average_Chart</searchName>
   <title>Average Number of Dropped Packets</title>
   <earliestTime>-7d</earliestTime>
   <option name="charting.chart">area</option>
   <option name="height">280px</option>
   <option name="charting.chart.stackMode">default</option>
   <option name="charting.legend.placement">left</option>
   <option name="charting.chart.nullValueMode">gaps</option>
   <option name="charting.secondaryAxisTitle.text">Num of Dropped Packets</option>
  </chart>
 </row>

  

</dashboard>


