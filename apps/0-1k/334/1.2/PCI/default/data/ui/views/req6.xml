<form class="formsearch">
  <label>Requirement 6</label>

  <fieldset>
    <input type="dropdown" token="host" searchWhenChanged="true">
      <label>Selected Host(s):</label>
      <default>ALL HOSTS (*)</default>
      <populatingSearch fieldForValue="host" fieldForLabel="host">| metadata type=hosts</populatingSearch>
      <choice value="*">ALL HOSTS (*)</choice>
    </input>
  </fieldset>

  <row>
    <html><center><h1>System Updates</h1></center></html>
    <html><left>The Requirement States: . </left></html>
  </row>

  <row>
   <html><left><h2>6.x: Updates</h2></left></html>
  </row>

  <row>
    <chart>
     <title>System Updated in last 24 Hours</title>
     <searchTemplate>source="/var/log/apt/history.log" Upgrade | chart count by host </searchTemplate>
     <option name="charting.chart">pie</option>
     <earliestTime>-24h</earliestTime>
   </chart>

  </row>

</form>

