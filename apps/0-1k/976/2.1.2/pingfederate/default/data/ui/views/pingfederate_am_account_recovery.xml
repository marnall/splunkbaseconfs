<form version="1.1">

    <label>Account Recovery</label>

    <fieldset>
        <!-- Define a simple dropdown form driven by a search -->
        <input type="dropdown" token ="subject">
            <label></label>
            <default>Any</default>
            <choice value="*">Any</choice>
            <search>
                <query>
                    eventtype="am.recovery.*" | chart count over subject
                </query>
                <earliest>-24mon</earliest>
            </search>
            <fieldForLabel>subject</fieldForLabel>
            <fieldForValue>subject</fieldForValue>
        </input>
        <input type="time"></input>
    </fieldset>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.*.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.*.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.recovery.*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <row>
        <chart>
            <title>Event Type Percentage</title>
            <search>
                <query>
                    eventtype="am.recovery.*" subject="$subject$" | top eventtype | fields - percent
                </query>
            </search>
            <option name="charting.chart">pie</option>
            <option name="height">400</option>
        </chart>
    </row>

    <!-- Password Reset -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">Password Reset</h1>
        </html>
    </row>

    <row>
        <table>
            <title>Password Reset Location By IP</title>
            <search>
                <query>
                    eventtype="am.recovery.reset*" subject="$subject$" | iplocation ip | table ip, City, Country
                </query>
            </search>
        </table>
        <map>
            <title>Location Map</title>
            <search>
                <query>
                    eventtype="am.recovery.reset*" subject="$subject$" | iplocation ip | geostats latfield=lat longfield=lon count
                </query>
            </search>
        </map>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.reset*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.reset*.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.reset*.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Reset Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.recovery.reset*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <!-- Account Unlock -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">Account Unlock</h1>
        </html>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.unlock.*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.unlock.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Unlocks</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.unlock.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Unlock Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.recovery.unlock.*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <!-- Username Recovery -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">Username Recovery</h1>
        </html>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.recover.*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.recover.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Recoveries</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.recovery.recover.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Recovery Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.recovery.recover.*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

</form>