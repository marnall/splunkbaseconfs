<form version="1.1">

    <label>Access</label>

    <fieldset>
        <!-- Define a simple dropdown form driven by a search -->
        <input type="dropdown" token ="connection">
            <label></label>
            <default>Any</default>
            <choice value="*">Any</choice>
            <search>
                <query>
                    eventtype="sp.access.*" | chart count over connectionid
                </query>
                <earliest>-24mon</earliest>
            </search>
            <fieldForLabel>connectionid</fieldForLabel>
            <fieldForValue>connectionid</fieldForValue>
        </input>

        <input type="time"></input>
    </fieldset>

    <row>
        <html>
            <span style="font-family:arial;font-size:14px;font-style:normal;font-weight:bold;color:3399FF;">
                Connection ID chosen does not affect the Authentication Requests section.</span>
        </html>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="sp.access.*" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="sp.access.*.success" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="sp.access.*.failure" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="sp.access.*" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <row>
        <table>
            <title>Top Identity Providers</title>
            <search>
                <query>
                    eventtype="sp.access.*" connectionid="$connection$" | top connectionid
                </query>
            </search>
        </table>
        <chart>
            <title>SSO Success Vs Failure</title>
            <search>
                <query>
                    eventtype="sp.access.sso.*" | top eventtype | fields - percent
                </query>
            </search>
            <option name="charting.chart">pie</option>
            <option name="height">400</option>
        </chart>
    </row>

    <!-- SSO -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">SSO</h1>
        </html>
    </row>

    <row>
        <table>
            <title>User SSO Location By IP</title>
            <search>
                <query>
                    eventtype="sp.access.sso.*" connectionid="$connection$" | iplocation ip | table ip, City, Country
                </query>
            </search>
        </table>
        <map>
            <title>Location Map</title>
            <search>
                <query>
                    eventtype="sp.access.sso.*" connectionid="$connection$" | iplocation ip | geostats latfield=lat longfield=lon count
                </query>
            </search>
        </map>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="sp.access.sso.*" connectionid="$connection$" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="sp.access.sso.success" connectionid="$connection$" | stats count
                </query>
            </search>
            <title># Of Successful SSO</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="sp.access.sso.failure" connectionid="$connection$" | stats count
                </query>
            </search>
            <title># Of SSO Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <table>
            <title>Top Connections</title>
            <search>
                <query>
                    eventtype="sp.access.sso.*" connectionid="$connection$" | top connectionid
                </query>
            </search>
        </table>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="sp.access.sso.*" connectionid="$connection$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

