<form version="1.1">

    <label>Account Registration</label>

    <fieldset>
        <!-- Define a simple dropdown form driven by a search -->
        <input type="dropdown" token ="subject">
            <label></label>
            <default>Any</default>
            <choice value="*">Any</choice>
            <search>
                <query>
                    eventtype="am.account.*" | chart count over subject
                </query>
                <earliest>-24mon</earliest>
            </search>
            <fieldForLabel>subject</fieldForLabel>
            <fieldForValue>subject</fieldForValue>
        </input>

        <input type="time"></input>
    </fieldset>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.account.*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.account.*.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.account.*.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.account.*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <row>
        <chart>
            <title>Event Type Percentage</title>
            <search>
                <query>
                    eventtype="am.account.*" subject="$subject$" | top eventtype | fields - percent
                </query>
            </search>
            <option name="charting.chart">pie</option>
            <option name="height">400</option>
        </chart>
    </row>

    <!-- Account Registration -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">Account Registration</h1>
        </html>
    </row>

    <row>
        <table>
            <title>Account Registration Location By IP</title>
            <search>
                <query>
                    eventtype="am.account.account*" subject="$subject$" | iplocation ip | table ip, City, Country
                </query>
            </search>
        </table>
        <map>
            <title>Location Map</title>
            <search>
                <query>
                    eventtype="am.account.account*" subject="$subject$" | iplocation ip | geostats latfield=lat longfield=lon count
                </query>
            </search>
        </map>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.account.account*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.account.account*.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.account.account*.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.account.account*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <!-- Email Verification -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">Email Verification</h1>
        </html>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.account.verif*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.account.verif*.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.account.verif*.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.account.verif*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

</form>