<form version="1.1">

    <label>Outbound Provisioning</label>

    <fieldset>
        <!-- Define a simple dropdown form driven by a search -->
        <input type="dropdown" token ="channel">
            <label></label>
            <default>Any</default>
            <choice value="*">Any</choice>
            <search>
                <query>
                    eventtype="idp.provision.*" | chart count over channel_id
                </query>
                <earliest>-24mon</earliest>
            </search>
            <fieldForLabel>channel_id</fieldForLabel>
            <fieldForValue>channel_id</fieldForValue>
        </input>

        <input type="time"></input>
    </fieldset>

    <row>
        <single>
            <search>
                <query>
                    channel_id="$channel$" eventtype="idp.provision.*" | stats dc(channel_id) as count
                </query>
            </search>
            <title># Of Channels</title>
            <option name="underLabel">Channels</option>
        </single>
        <single>
            <search>
                <query>
                    channel_id="$channel$" eventtype="idp.provision.*.success" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    channel_id="$channel$" eventtype="idp.provision.*.failure" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    channel_id="$channel$" eventtype="idp.provision.*" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <row>
        <table>
            <title>Top Channels</title>
            <search>
                <query>
                    channel_id="$channel$" eventtype="idp.provision.*" | top channel_id
                </query>
            </search>
        </table>
        <chart>
            <title>Event Type Percentage</title>
            <search>
                <query>
                    channel_id="$channel$" eventtype="idp.provision.*" | top eventtype | fields - percent
                </query>
            </search>
            <option name="charting.chart">pie</option>
            <option name="height">400</option>
        </chart>
    </row>

</form>