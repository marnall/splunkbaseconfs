            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="idp.access.sso.success" connectionid="$connection$" | stats count
                </query>
            </search>
            <title># Of Successful SSO</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
