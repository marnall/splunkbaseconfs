                    eventtype="idp.access.sso.failure" connectionid="$connection$" | stats count
                </query>
            </search>
            <title># Of SSO Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <table>
            <title>Top Connections</title>
            <search>
                <query>
                    eventtype="idp.access.sso.*" connectionid="$connection$" | top connectionid
