<form version="1.1">

    <label>Profile Updates</label>

    <fieldset>
        <!-- Define a simple dropdown form driven by a search -->
        <input type="dropdown" token ="subject">
            <label></label>
            <default>Any</default>
            <choice value="*">Any</choice>
            <search>
                <query>
                    eventtype="am.profile.*" | chart count over subject
                </query>
                <earliest>-24mon</earliest>
            </search>
            <fieldForLabel>subject</fieldForLabel>
            <fieldForValue>subject</fieldForValue>
        </input>

        <input type="time"></input>
    </fieldset>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.profile.*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.profile.*.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.profile.*.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.profile.*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <row>
        <chart>
            <title>Event Type Percentage</title>
            <search>
                <query>
                    eventtype="am.profile.*" subject="$subject$" | top eventtype | fields - percent
                </query>
            </search>
            <option name="charting.chart">pie</option>
            <option name="height">400</option>
        </chart>
    </row>

    <!-- Profile Updates -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">Profile Updates</h1>
        </html>
    </row>

    <row>
        <table>
            <title>Profile Update Location By IP</title>
            <search>
                <query>
                    eventtype="am.profile.change.*" subject="$subject$" | iplocation ip | table ip, City, Country
                </query>
            </search>
        </table>
        <map>
            <title>Location Map</title>
            <search>
                <query>
                    eventtype="am.profile.change.*" subject="$subject$" | iplocation ip | geostats latfield=lat longfield=lon count
                </query>
            </search>
        </map>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.profile.change.*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.profile.change.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Changes</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.profile.change.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.profile.change.*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <!-- Identity Connections -->
    <row>
        <html>
            <h1 style="font-family:arial;font-size:300%;">Identity Connections</h1>
        </html>
    </row>

    <row>
        <single>
            <search>
                <query>
                    eventtype="am.profile.identity*" subject="$subject$" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.profile.identity*.success" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="am.profile.identity*.failure" subject="$subject$" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    eventtype="am.profile.identity*" subject="$subject$" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

</form>
