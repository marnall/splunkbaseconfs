<form version="1.1">

    <label>Token Validation</label>

    <fieldset>
        <!-- Define a simple dropdown form driven by a search -->
        <input type="dropdown" token ="connection">
            <label></label>
            <default>Any</default>
            <choice value="*">Any</choice>
            <search>
                <query>
                    eventtype="oauth.validation.*" | chart count over connectionid
                </query>
                <earliest>-24mon</earliest>
            </search>
            <fieldForLabel>connectionid</fieldForLabel>
            <fieldForValue>connectionid</fieldForValue>
        </input>

        <input type="time"></input>
    </fieldset>

    <row>
        <single>
            <search>
                <query>
                    connectionid="$connection$" eventtype="oauth.validation.*" subject!="" | stats dc(subject) as count
                </query>
            </search>
            <title># Of Users</title>
            <option name="underLabel">Users</option>
        </single>
        <single>
            <search>
                <query>
                    connectionid="$connection$" eventtype="oauth.validation.*.success" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    connectionid="$connection$" eventtype="oauth.validation.*.failure" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    connectionid="$connection$"  eventtype="oauth.validation.*" | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <row>
        <table>
            <title>Top Clients</title>
            <search>
                <query>
                    connectionid="$connection$" eventtype="oauth.validation.*" | top connectionid
                </query>
            </search>
        </table>
        <chart>
            <title>Event Type Percentage</title>
            <search>
                <query>
                    connectionid="$connection$" eventtype="oauth.validation.*" | top eventtype | fields - percent
                </query>
            </search>
            <option name="charting.chart">pie</option>
            <option name="height">400</option>
        </chart>
    </row>

</form>