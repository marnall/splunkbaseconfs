<form version="1.1">

    <label>Dynamic Client Registration</label>

    <fieldset>
        <!-- Define a simple dropdown form driven by a search -->
        <input type="dropdown" token ="connection">
            <label></label>
            <default>Any</default>
            <choice value="*">Any</choice>
            <search>
                <query>
                    eventtype="oauth.registration.*" | chart count over connectionid
                </query>
                <earliest>-24mon</earliest>
            </search>
            <fieldForLabel>connectionid</fieldForLabel>
            <fieldForValue>connectionid</fieldForValue>
        </input>

        <input type="time"></input>
    </fieldset>

    <row>
        <single>
            <search>
                <query>
                    connectionid="$connection$" eventtype="oauth.registration.*.success" | stats count
                </query>
            </search>
            <title># Of Successful Transactions</title>
            <option name="underLabel">Transactions</option>
        </single>
        <single>
            <search>
                <query>
                    eventtype="oauth.registration.*.failure" | stats count
                </query>
            </search>
            <title># Of Failures</title>
            <option name="underLabel">Failures</option>
        </single>
    </row>

    <row>
        <chart>
            <title>Traffic By Event Type</title>
            <search>
                <query>
                    (connectionid="$connection$" eventtype="oauth.registration.*.success") 
                    OR (eventtype="oauth.registration.*.failure") | timechart count by eventtype
                </query>
            </search>
            <option name="charting.chart">column</option>
            <option name="height">400</option>
            <option name="charting.legend.labelStyle.overflowMode">ellipsisNone</option>
        </chart>
    </row>

    <row>
        <chart>
            <title>Event Type Percentage</title>
            <search>
                <query>
                    (connectionid="$connection$" eventtype="oauth.registration.*.success") 
                    OR (eventtype="oauth.registration.*.failure") | top eventtype | fields - percent
                </query>
            </search>
            <option name="charting.chart">pie</option>
            <option name="height">400</option>
        </chart>
    </row>

    <row>
        <table>
            <title>Client Registration Location From IP</title>
            <search>
                <query>
                    (connectionid="$connection$" eventtype="oauth.registration.*.success") 
                    OR (eventtype="oauth.registration.*.failure") | iplocation ip | table ip, City, Country
                </query>
            </search>
        </table>
        <map>
            <title>Location Map</title>
            <search>
                <query>
                    (connectionid="$connection$" eventtype="oauth.registration.*.success") 
                    OR (eventtype="oauth.registration.*.failure") | iplocation ip | geostats latfield=lat longfield=lon count
                </query>
            </search>
        </map>
    </row>

</form>