<?xml version='1.0' encoding='utf-8'?>
<form>
  <label>Users Summary</label>
  <fieldset autoRun="true">      
      <input type="time">
        <default>Last 24 hours</default>
    </input>
  </fieldset>
<row>
      <chart>
          <title>Top 10 Users by Hits >> User Profile</title>
          <searchTemplate>
             index=websense_summary search_name="user_domain" | stats count by user | sort - count | head 10
          </searchTemplate>
          <option name="charting.chart">bar</option>
      <option name="charting.chart.nullValueMode">gaps</option>
      <option name="charting.chart.stackMode">default</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      <option name="count">50</option>
      <option name="displayRowNumbers">true</option>
          <drilldown>
           <link>
               /app/Websense/User_search?form.username=$click.value$
           </link>    
       </drilldown>
    </chart>
  				<chart>
          <title>Top 10 Users by Bandwidth >> User profile</title>
          <searchTemplate>
             index=websense_summary search_name="bandwidth_by_user" | eval MB_in=Bytes_in/1024/1024 | eval MB_out=Bytes_out/1024/1024 | eval TotalMB=MB_in+MB_out | chart sum(TotalMB) by user | sort - sum(TotalMB) | head 10
          </searchTemplate>
          <option name="charting.chart">bar</option>
      <option name="charting.chart.nullValueMode">gaps</option>
      <option name="charting.chart.stackMode">default</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      <option name="count">50</option>
      <option name="displayRowNumbers">true</option>
       <drilldown>
           <link>
               /app/Websense/User_search?form.username=$click.value$
           </link>    
       </drilldown>             
    </chart>
       </row>
 <row>
   <chart>
          <title>Top 10 Policy by Bandwidth</title>
          <searchTemplate>
             index=websense_summary search_name="Bandwidth_by_action" | eval MB_in=Bytes_in/1024/1024 | eval MB_out=Bytes_out/1024/1024 | eval TotalMB=MB_in+MB_out | stats sum(TotalMB) by policy | sort - sum(TotalMB) | head 10
          </searchTemplate>
      <option name="charting.chart">bar</option>
      <option name="charting.chart.nullValueMode">gaps</option>
      <option name="charting.chart.stackMode">default</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      <option name="count">50</option>
      <option name="displayRowNumbers">true</option>
    </chart>
          
   <chart>
   <title>User agent</title>
          <searchTemplate>
             index=websense_summary search_name="user_proxy" | stats sum(count) by http_user_agent
           </searchTemplate>
   <option name="charting.chart">pie</option>
   </chart> 
       </row>
  <row>
   <chart>
          <title>HTTP response 400 and 500 errors</title>
          <searchTemplate>
             index=websense_summary search_name="user_proxy" http_response="4*" OR http_response="5*"| stats count by httpstatus_description | sort -count
          </searchTemplate>
          <option name="charting.chart">bar</option>
      <option name="charting.chart.nullValueMode">gaps</option>
      <option name="charting.chart.stackMode">default</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      <option name="count">50</option>
      <option name="displayRowNumbers">true</option>
    </chart>
  </row>
       
</form>