<?xml version='1.0' encoding='utf-8'?>
<form>
  <label>RT-Debug-Destination Host</label>
  <searchTemplate>
    index=websense dst_host="$dsthost$" | stats count by user,disposition_description,policy,proxystatus_description
  </searchTemplate>
  <earliestTime>rt-5m</earliestTime>
  <latestTime>rt</latestTime>
  <fieldset>
      <input type="text" token="dsthost">
        <label>Destination Host</label>
        <default>*</default>
        <suffix>*</suffix>
        <prefix>*</prefix>
      </input>
  </fieldset>
  <row>
    <table>
      <title>RT debug by Destination Host for the last 5 minutes</title>
      <option name="count">50</option>
      <option name="showPager">true</option>
    </table>
  </row>
</form>