<?xml version='1.0' encoding='utf-8'?>
<form>
  <label>Security Summary</label>
  <fieldset autoRun="true">      
      <input type="time">
        <default>Last 24 hours</default>
    </input>
  </fieldset>
<row>
      <chart>
          <title>Security events by destination >> Aceinsight</title>
          <searchTemplate>
             index=websense_summary search_name="security_by_category" | timechart sum(count) by dst_host
          </searchTemplate>
          <option name="charting.chart">area</option>
      <option name="charting.chart.nullValueMode">zero</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
          <drilldown>
           <link>
               http://aceinsight.websense.com/Results.aspx?url=$click.name2$
           </link>    
       </drilldown> 
    </chart>
  				<chart>
          <title>Security events by source ip(Top 10)</title>
          <searchTemplate>
             index=websense_summary search_name="security_by_category" | timechart sum(count) by src_host
          </searchTemplate>
          <option name="charting.chart">area</option>
      <option name="charting.chart.nullValueMode">zero</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      </chart>

       </row>
 <row>
   <chart>
          <title>Security events by user(Top 10)</title>
          <searchTemplate>
             index=websense_summary search_name="security_by_category" | timechart sum(count) by user 
          </searchTemplate>
          <option name="charting.chart">area</option>
      <option name="charting.chart.nullValueMode">zero</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      </chart> 
    
   <chart>
          <title>Security events by child category</title>
          <searchTemplate>
             index=websense_summary search_name="security_by_category" | stats sum(count) by category_child_name
          </searchTemplate>
          <option name="charting.chart">bar</option>
      <option name="charting.chart.nullValueMode">gaps</option>
      <option name="charting.chart.stackMode">default</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      <option name="count">50</option>
      <option name="displayRowNumbers">true</option>
    </chart>
  </row>
  <row>
    <table>
      <title>Security events summary</title>
      <searchTemplate>
      index=websense_summary search_name="security_by_category" | stats sum(count) by user, category_child_name, dst_host,disposition_description | sort -sum(count)
      </searchTemplate>  
    </table>  
  </row>  
       
</form>