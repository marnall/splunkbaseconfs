<?xml version='1.0' encoding='utf-8'?>
<form>
  <label>Bandwidth Summary</label>
       
  <fieldset autoRun="true">      
      <input type="time">
        <default>Last 24 hours</default>
    </input>
  </fieldset>
    <row>
      <chart>
          <title>Bandwidth usage over time</title>
          <searchTemplate>
             index=websense_summary search_name="bandwidth_by_user" | eval MB_in=Bytes_in/1024/1024 | eval MB_out=Bytes_out/1024/1024 |timechart sum(MB_in),sum(MB_out)
          </searchTemplate>
          <option name="charting.chart">area</option>
      <option name="charting.chart.nullValueMode">zero</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      </chart>
  				<chart>
          <title>Bandwidth usage by category (Top 10) >> Category by child</title>
          <searchTemplate>
             index=websense_summary search_name="bandwidth_by_user" | eval MB_in=Bytes_in/1024/1024 | eval MB_out=Bytes_out/1024/1024 |eval Total_MB=MB_in+MB_out |timechart sum(Total_MB) AS Total_MB by category_name | sort -Total_MB 
          </searchTemplate>
          <option name="charting.chart">area</option>
      <option name="charting.chart.nullValueMode">zero</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
     <drilldown>
           <link>
               /app/Websense/Category_by_child?form.category=$click.name2$
           </link>    
       </drilldown> 
    </chart>

       </row>
 <row>
   <chart>
          <title>Bandwidth usage by DST Host (Top 10) >> URL Domain</title>
          <searchTemplate>
             index=websense_summary search_name="bandwidth_by_user" | eval MB_in=Bytes_in/1024/1024 | eval MB_out=Bytes_out/1024/1024 |eval Total_MB=MB_in+MB_out |timechart sum(Total_MB) AS Total_MB by dst_host| sort -Total_MB 
          </searchTemplate>
          <option name="charting.chart">area</option>
      <option name="charting.chart.nullValueMode">zero</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
       <drilldown>
           <link>
               /app/Websense/URL_Domain?form.dstdomain=$click.name2$
           </link>    
       </drilldown>    
      </chart> 
   <chart>
   <title>User agent</title>
          <searchTemplate>
             index=websense_summary search_name="user_proxy" | stats sum(count) by http_user_agent
           </searchTemplate>
   <option name="charting.chart">pie</option>
   </chart> 
       </row>
  <row>
   <chart>
          <title>Action</title>
          <searchTemplate>
             index=websense_summary search_name="action_by_user" | stats sum(count) AS Attempts by disposition_description | sort -Attempts
          </searchTemplate>
          <option name="charting.chart">bar</option>
      <option name="charting.chart.nullValueMode">gaps</option>
      <option name="charting.chart.stackMode">default</option>
      <option name="charting.layout.splitSeries">false</option>
      <option name="charting.legend.placement">right</option>
      <option name="charting.secondaryAxis.maximumNumber">""</option>
      <option name="charting.secondaryAxis.minimumNumber">""</option>
      <option name="charting.secondaryAxis.scale">""</option>
      <option name="count">50</option>
      <option name="displayRowNumbers">true</option>
    </chart>
  </row>
       
</form>