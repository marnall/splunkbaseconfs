<?xml version='1.0' encoding='utf-8'?>
<form>
  <label>RT-Debug-Source Host</label>
  <searchTemplate>
    index=websense src_host="$srchost$" | stats count by user,dst_host,disposition_description,policy,proxystatus_description
  </searchTemplate>
  <earliestTime>rt-5m</earliestTime>
  <latestTime>rt</latestTime>
  <fieldset>
      <input type="text" token="srchost">
        <label>Source IP</label>
        <default>*</default>
        <suffix>*</suffix>
        <prefix>*</prefix>
      </input>
  </fieldset>
  <row>
    <table>
      <title>RT debug by Source Host for the last 5 minutes</title>
      <option name="count">50</option>
      <option name="showPager">true</option>
    </table>
  </row>
</form>