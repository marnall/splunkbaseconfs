
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[app/ui]
owner = nobody
version = 4.2

[nav/default]
owner = nobody
version = 4.2

[workflow_actions/get_article]
access = read : [ * ], write : [ admin ]
owner = nobody
export = none
version = 4.2


