<view template="dashboard.html" stylesheet="threat_dashboard.css" >

 <label>ModSecurity Threat Overview</label>
 <module name="AccountBar" layoutPanel="navigationHeader"/>
 <module name="AppBar" layoutPanel="navigationHeader"/>

 <module name="Message" layoutPanel="messaging">
  <param name="filter">*</param>
  <param name="clearOnJobDispatch">False</param>
  <param name="maxSize">1</param>
 </module>

 <module name="TitleBar" layoutPanel="navigationHeader">
  <param name="showActionsMenu">False</param>
 </module>

 
<module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
  <param name="searchWhenChanged">True</param>
  <param name="selected">Last 60 minutes</param>
  
  
  <module name="GenericHeader" layoutPanel="panel_row2_col1_grp1">
     <param name="label">Total events</param>
  </module>
  <module name="HiddenSearch" layoutPanel="panel_row2_col1_grp1">
  <param name="search">`modsec_index` `modsec_src` | stats count | rangemap field=count grey=0-0 green=1-5 orange=6-100 purple=101-200 default=red</param>
  <module name="SingleValue">
     <param name="field">count</param>
     <param name="afterLabel">Events</param>
     <param name="classField">range</param>
     <param name="linkFields">afterlabel,result</param>
     <param name="linkView">search</param>
     <param name="linkSearch">`modsec_index` `modsec_src` | stats count</param>
  </module>
  </module>  
  

  <module name="GenericHeader" layoutPanel="panel_row2_col1_grp2">
     <param name="label">Number of outbound events</param>
  </module>
  <module name="HiddenSearch" layoutPanel="panel_row2_col1_grp2">
  <param name="search">sourcetype="modsec_audit" outbound | stats count | rangemap field=count grey=0-0 green=1-2 orange=3-15 purple=16-100 default=red</param>
  <module name="SingleValue">
     <param name="field">count</param>
     <param name="afterLabel">Events</param>
     <param name="classField">range</param>
     <param name="linkFields">afterlabel,result</param>
     <param name="linkView">search</param>
     <param name="linkSearch">`modsec_index` `modsec_src` outbound</param>
  </module> 
  </module>
  
  
  <module name="GenericHeader" layoutPanel="panel_row2_col1_grp3">
     <param name="label">ModSec event from Open proxies</param>
  </module>
  <module name="HiddenSearch" layoutPanel="panel_row2_col1_grp3">
  <param name="search">`modsec_index` `modsec_src` status="BAD" | stats count | rangemap field=count grey=0-0 green=1-2 orange=3-15 purple=16-100 default=red</param>
  <module name="SingleValue">
     <param name="field">count</param>
     <param name="afterLabel">Events</param>
     <param name="classField">range</param>
     <param name="linkFields">afterlabel,result</param>
     <param name="linkView">search</param>
     <param name="linkSearch">`modsec_index` `modsec_src` status="BAD"</param>
    </module>
  </module>


  <module name="HiddenSearch" autoRun="True" layoutPanel="panel_row3_col1" group="Denied by IP">
   <param name="search">`modsec_index` `modsec_src` | stats count by clientip | head 10</param>
   <module name="EnablePreview">
    <param name="enable">true</param>
    <param name="display">false</param>
    <module name="HiddenChartFormatter">
     <param name="chart">pie</param>
     <module name="JSChart">
      <param name="height">300px</param>
      <module name="ViewRedirector">
       <param name="viewTarget">search</param>
       <param name="popup">true</param>
      </module>
     </module>          
    </module>
   </module>
  </module>


  <module name="HiddenSearch" autoRun="True" layoutPanel="panel_row3_col2" group="Blocked IP by host">
   <param name="search">`modsec_index` `modsec_src` | stats dc(clientip) as count by host | sort - host</param>
   <module name="EnablePreview">
    <param name="enable">true</param>
    <param name="display">false</param>
    <module name="HiddenChartFormatter">
     <param name="chart.stackMode">stacked</param>
     <param name="primaryAxisTitle.text">Time</param>
     <param name="secondaryAxisTitle.text"># of client ip</param>
     <module name="JSChart">
      <param name="height">300px</param>
      <module name="ViewRedirector">
       <param name="viewTarget">search</param>
       <param name="popup">true</param>
      </module>
     </module>          
    </module>
   </module>
  </module>

  
  <module name="HiddenSearch" autoRun="True" layoutPanel="panel_row3_col3" group="Denied by eventtype">
   <param name="search">`modsec_index` `modsec_src` | stats count by msg | head 10</param>
   <module name="EnablePreview">
    <param name="enable">true</param>
    <param name="display">false</param>
    <module name="HiddenChartFormatter">
     <param name="chart">pie</param>
     <module name="JSChart">
      <param name="height">300px</param>
      <module name="ViewRedirector">
       <param name="viewTarget">search</param>
       <param name="popup">true</param>
      </module>
     </module>          
    </module>
   </module>
  </module>
  
    

<module name="GenericHeader" layoutPanel="panel_row4_col1">
 <param name="label">Geographical map</param>
</module>
    
<module name="HiddenSearch" layoutPanel="panel_row4_col1" autoRun="true">
 <param name="search">`modsec_index` `modsec_src` | localop | geoip clientip</param>

  <module name="GoogleMaps">
   <param name="autoPostProcess">on</param>
   <param name="scrollwheel">on</param>
   <param name="doubleClickZoom">off</param>
   <param name="drilldown">true</param>
   <param name="drilldown_field">clientip</param>
   <param name="height">550px</param>
   <param name="mapStyles">splunk</param>
   <param name="mapType">splunk</param>
   <param name="mapTypeControl">off</param>
		<module name="HiddenSearch">
			<param name="search">`modsec_index` `modsec_src` $clientips$</param>
			<module name="ConvertToIntention">
				<param name="settingToConvert">maps.drilldown</param>
				<param name="intention">
					<param name="name">stringreplace</param>
					<param name="arg">
						<param name="clientips">
							<param name="value">$target$</param>
						</param>
					</param>
				</param>
				<module name="ViewRedirector">
					<param name="viewTarget">flashtimeline</param>
					<param name="popup">true</param>
				</module>
			</module>
		</module>
    </module>
</module>

    
    
    
    
</module>
</view>