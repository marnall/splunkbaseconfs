<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html" stylesheet="event_dashboard.css" isSticky="False">
<label>ModSecurity Event Search</label>
<module name="AccountBar" layoutPanel="appHeader" />
<module name="AppBar" layoutPanel="appHeader" />
<module name="SideviewUtils" layoutPanel="appHeader" />

<module name="Message" layoutPanel="messaging">
<param name="filter">*</param>
<param name="maxSize">2</param>
<param name="clearOnJobDispatch">False</param>
</module>

<module name="TimeRangePicker" layoutPanel="panel_row2_col1">
<param name="searchWhenChanged">True</param>
<param name="selected">Yesterday</param>

<module name="Search" layoutPanel="panel_row2_col1" autoRun="True">
<param name="search">`modsec_index` `modsec_src` | stats count by host, msg</param>

<module name="TextField" layoutPanel="panel_row2_col1">
<param name="name">clientip</param>
<param name="default">*</param>
<param name="label">IP:</param>
<param name="width">100px</param>

<module name="Pulldown">
<param name="name">host</param>
<param name="label">Host:</param>
<param name="template">host="$value$"</param>
<param name="float">left</param>
<param name="postProcess">dedup $name$ | sort $name$</param>
<param name="searchFieldsToDisplay">
<list>
<param name="label">host</param>
<param name="value">host</param>
</list>
</param>

<module name="Pulldown">
<param name="name">msg</param>
<param name="label">Eventtype</param>
<param name="template">msg="$value$"</param>
<param name="postProcess">search $group$ | dedup $name$ | sort $name$</param>
<param name="searchFieldsToDisplay">
<list>
<param name="label">msg</param>
<param name="value">msg</param>
</list>
</param>

<module name="SubmitButton" layoutPanel="panel_row2_col1">
<param name="allowSoftSubmit">True</param>
<param name="label">Search</param>

<module name="Search">
<param name="search">`modsec_index` `modsec_src` clientip="$clientip$" $host$ $msg$  | geoip clientip | stats c(clientip) as count values(msg) as Eventtype values(host) as Host values(clientip_city) as City by clientip | sort - count</param>

<module name="Pulldown">
<param name="name">results.count</param>
<param name="label">results per page</param>
<param name="float">right</param>
<param name="staticFieldsToDisplay">
<list><param name="value">10</param></list>
<list><param name="value">20</param><param name="selected">True</param></list>
<list><param name="value">50</param></list>
<list><param name="value">100</param></list>
</param>

<module name="JobProgressIndicator"></module>

<module name="Pager">
<param name="entityName">results</param>
<module name="SimpleResultsTable">
<param name="displayRowNumbers">True</param>
<param name="entityName">results</param>
</module>
</module>

</module>
</module>
</module>
</module>
</module>
</module>  
</module>  
</module>  
</view>