<form refresh="900">
  <label>NetWitness Forensic Fingerprint Overview</label>
  <fieldset submitButton="false">
    <input type="time" token="field1">
      <label></label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <table>
        <title>Top 10 File Types</title>
        <search>
          <query>index=summary search=netwitness_filetype_traffic_top_filetype | top filetype showperc=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 Suspicious Origin Country</title>
        <search>
          <query>index=summary search=netwitness_filetype_traffic_top_host_filename_country | top dest_country showperc=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 Executables</title>
        <search>
          <query>index=summary search=netwitness_filetype_traffic_top_host_filename_country "x86 pe" OR "windows executable" | top dest_host file_name dest_country showperc=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 Java Files</title>
        <search>
          <query>index=summary search=netwitness_filetype_traffic_top_host_filename_country "filetype=java_jar" OR "filetype=java" OR "filetype=jar" | top dest_host file_name dest_country showperc=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 PDF Files</title>
        <search>
          <query>index=summary search=netwitness_filetype_traffic_top_host_filename_country "filetype=pdf"  | top dest_host file_name dest_country showperc=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>File Types over time</title>
        <search>
          <query>index=summary search=netwitness_filetype_traffic_filetype_over_time | timechart usenull=f span=15m count by filetype</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Sessions</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
</form>