<form refresh="900">
  <label>NetWitness All Traffic</label>
  <fieldset submitButton="false">
    <input type="time" token="field1">
      <label></label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <chart>
        <title>Service over time (Last day)</title>
        <search>
          <query>index=summary search=netwitness_all_traffic_sessions_by_service | timechart span=15m count by service_alias usenull=f useother=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Sessions</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 Services (Last day)</title>
        <search>
          <query>index=summary search="netwitness_all_traffic_top_destination_service" | top service_alias</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 Source IPs (Last day)</title>
        <search>
          <query>index="summary" search="netwitness_all_traffic_top_srcip_service" | top src_ip</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 Destination Organisations (Last day)</title>
        <search>
          <query>index=summary search="netwitness_all_traffic_top_destination_service" | top dest_org</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 Destination Countries (Last day)</title>
        <search>
          <query>index=summary search="netwitness_all_traffic_top_destination_service" | top dest_country</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
</form>