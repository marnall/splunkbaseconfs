<form refresh="900">
  <label>NetWitness OTHER Traffic</label>
  <fieldset submitButton="false">
    <input type="time" token="field1">
      <label></label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <table>
        <title>Top 10 OTHER Destination Ports</title>
        <search>
          <query>index=summary search=netwitness_other_traffic_top_port_proto_domain_org_country | top dest_port proto</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 OTHER Destination Domains</title>
        <search>
          <query>index=summary search=netwitness_other_traffic_top_port_proto_domain_org_country | top dest_domain</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 OTHER (Top Port) Destinations</title>
        <search>
          <query>index=summary search=netwitness_other_traffic_top_port_proto_domain_org_country [search index=summary search=netwitness_other_traffic_top_port_proto_domain_org_country | top limit=1 dest_port | fields + dest_port] | top dest_country dest_org showperc=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 OTHER Destinations (Ports 80 &amp; 443)</title>
        <search>
          <query>index=summary search=netwitness_other_traffic_top_port_proto_domain_org_country (dest_port=80 OR dest_port=443)| top dest_domain dest_org showperc=f</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>OTHER Destination Organisations over time</title>
        <search>
          <query>index=summary search=netwitness_other_traffic_dest_org_over_time | timechart span=15m usenull=false count by dest_org</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Sessions</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>OTHER (External only) Destination Organisations over time</title>
        <search>
          <query>index=summary search=netwitness_other_traffic_dest_org_over_time NOT "dest_org=RFC1918" NOT "dest_org=\"255.255.255.255\"" NOT "dest_org=\"224.0.*\"" | timechart span=15m usenull=false count by dest_org</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Sessions</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
</form>