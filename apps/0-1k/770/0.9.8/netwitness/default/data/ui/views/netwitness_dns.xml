<form refresh="900">
  <label>NetWitness DNS Traffic</label>
  <fieldset submitButton="false">
    <input type="time" token="field1">
      <label></label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <chart>
        <title>Top 10 DNS Queries over time (Last day)</title>
        <search>
          <query>index=summary search=netwitness_dns_traffic_dest_host_over_time | timechart span=15m usenull=f useother=f count by dest_host</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Queries</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Top 10 DNS Servers over time (Last day)</title>
        <search>
          <query>index=summary search=netwitness_dns_traffic_dest_ip_over_time | timechart span=15m usenull=f useother=f count by dest_ip</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Queries</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Top 10 DNS Clients over time (Last day)</title>
        <search>
          <query>index=summary search=netwitness_dns_traffic_src_ip_over_time | timechart span=15m usenull=f useother=f count by src_ip</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Queries</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 Queries with most distinct IPs (Last day)</title>
        <search>
          <query>sourcetype="netwitness" service=53 |rex field=_raw max_match=15 "alias\.ip=(?&lt;alias_ip&gt;\S+)" | chart sparkline dc(alias_ip) as distinct_ips by dest_host| sort - distinct_ips | head 10</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
</form>