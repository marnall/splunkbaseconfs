<form refresh="900">
  <label>NetWitness SMTP Traffic</label>
  <fieldset submitButton="false">
    <input type="time" token="field1">
      <label></label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <table>
        <title>Top 10 SMTP Sender addresses</title>
        <search>
          <query>index=summary search=netwitness_smtp_traffic_top_sender | top sender</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 Recipient addresses</title>
        <search>
          <query>index=summary search=netwitness_smtp_traffic_top_recipient | top recipient</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 SMTP E-mail addresses</title>
        <search>
          <query>index=summary search=netwitness_smtp_traffic_top_email | top email</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Top 10 SMTP Subjects</title>
        <search>
          <query>index=summary search=netwitness_smtp_traffic_top_subject | top subject</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Top 10 SMTP Attachment names</title>
        <search>
          <query>index=summary search=netwitness_smtp_traffic_top_attachment | top attachment</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
    <panel>
      <table>
        <title>Rarest 10 SMTP Subjects</title>
        <search>
          <query>index=summary search=netwitness_smtp_traffic_top_subject | rare subject</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>SMTP Destination Organisations over time</title>
        <search>
          <query>index=summary search=netwitness_smtp_traffic_dest_org_over_time | timechart span=15m usenull=false count by dest_org</query>
          <earliest>$field1.earliest$</earliest>
          <latest>$field1.latest$</latest>
        </search>
        <earliest>-1d@h</earliest>
        <latest>now</latest>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Sessions</option>
        <option name="charting.chart">line</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
</form>