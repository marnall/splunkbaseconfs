<view template="dashboard.html" stylesheet="dashboard2.css">
  <label>BlueCoat Traffic Overview</label>
    <module name="AccountBar" layoutPanel="appHeader"/>
    <module name="AppBar" layoutPanel="navigationHeader"/>
    <module name="Message" layoutPanel="messaging">
        <param name="filter">*</param>
        <param name="clearOnJobDispatch">False</param>
        <param name="maxSize">1</param>
    </module>
    <module name="TitleBar" layoutPanel="viewHeader">
        <param name="actionsMenuFilter">dashboard</param>
    </module>
   
    
    <!--
        Global index summary counts
    -->



   <module name="GenericHeader" layoutPanel="panel_row1_col1">
      <param name="label">BlueCoat Traffic Overview</param>
    </module>
	    <module name="StaticContentSample" layoutPanel="panel_row1_col1">
      <param name="text">This dashboard provides visibility into traffic activity in your BlueCoat ProxySG and CacheFlow deployment. You can adjust the time range of this report by selecting your desired time using the picker below. 
&lt;br&gt;
The information in the report provides a count of request and the bandwidth utilization stats over time for selected time range, as well as a break down of those requets by client, host and category.
</param>
    </module>
  
   <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
      <param name="selected">Last 7 days</param>
      <param name="searchWhenChanged">True</param>
	

	



 
 	<module name="HiddenSavedSearch" layoutPanel="panel_row1_col1" autoRun="True">
  
  <param name="savedSearch">BlueCoat - DataCube</param>
  <module name="ViewRedirectorLink">
          <param name="viewTarget">flashtimeline</param>
          <param name="label">View Full Report</param>
        </module>
      </module>

 
  <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1" autoRun="True">

  <param name="savedSearch">BlueCoat - DataCube</param>
<module name="JobProgressIndicator"></module>



 <module name="HiddenPostProcess" layoutPanel="panel_row2_col1">
      <param name="search">stats sum(count)  as Requests by category  | head 10</param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Top Category</param>
        <param name="chart">pie</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
        <module name="ViewRedirectorLink">
          <param name="viewTarget">cf_bw_category</param>
          <param name="label">Catgeory Report</param>
        </module>

    </module>

<module name="HiddenPostProcess" layoutPanel="panel_row2_col2">
      <param name="search">stats sum(count) as Requests by dest_host  | head 10</param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Top Destination</param>
        <param name="chart">pie</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
        <module name="ViewRedirectorLink">
          <param name="viewTarget">cf_bw_host</param>
          <param name="label">Site Report</param>
        </module>

    </module>

<module name="HiddenPostProcess" layoutPanel="panel_row2_col3">
      <param name="search">stats sum(count) as Requests by src_ip | head 10</param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Top Client IP</param>
        <param name="chart">pie</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
        <module name="ViewRedirectorLink">
          <param name="viewTarget">cf_bw_client</param>
          <param name="label">Client Report</param>
        </module>

    </module>


 <module name="HiddenPostProcess" layoutPanel="panel_row3_col1">


      <param name="search">timechart sum(count) as Requests</param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Requests Over Time</param>
        <param name="chart">area</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
    </module>


 <module name="HiddenPostProcess" layoutPanel="panel_row4_col1">


      <param name="search">timechart sum(client_bytes) as "Client Bytes" sum(server_bytes) as "Server Bytes"  sum(savings_bytes) as "Bandwidth Savings" </param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Bandwidth Utilization Over Time</param>
        <param name="chart">area</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
    </module>






	<module name="HiddenPostProcess" group="Detailed Report Info " layoutPanel="panel_row5_col1"  autoRun="True">
            <param name="search"> |  stats sum(count) as Requests sum(client_bytes) as "ClientBytes" sum(server_bytes) as "Server Bytes"  avg(savings_perc) as "Bandwidth Savings %"  by category | sort -Requests</param>
		<module name="SimpleResultsTable">
          <param name="drilldown">row</param>
          <param name="entityName">results</param>
          <param name="displayRowNumbers">False</param>
        </module>
	</module>




	</module>
    </module>





  
 </view>
