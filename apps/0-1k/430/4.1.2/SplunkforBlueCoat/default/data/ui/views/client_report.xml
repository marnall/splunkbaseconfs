          	<searchPostProcess>stats sum(count) as count by dest_host</searchPostProcess>
      	</table>
	  
    	<chart>
			<title>Top Category</title>
        	<searchPostProcess>stats sum(count) as count by category | head 10</searchPostProcess>
        	<option name="charting.chart">pie</option>
          <option name="charting.legend.placement">bottom</option>
        	<option name="height">300px</option>
      	</chart>
    	<chart>
			<title>Top client</title>
