      <param name="label">Bandwidth Savings by Site</param>
    </module>
	    <module name="StaticContentSample" layoutPanel="panel_row1_col1">
      <param name="text">This dashboard provides visibility into bandwidth usage and savings by destination address across your BlueCoat ProxySG and CacheFlow deployment. You can adjust the time range of this report by selecting your desired time using the picker below. 
&lt;br&gt;
The information in the report provides a breakdown of bandwidth utilization by category, server as well as bandwidth savings
</param>
    </module>
  
   <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
