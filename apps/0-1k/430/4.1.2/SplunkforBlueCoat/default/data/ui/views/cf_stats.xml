<view template="dashboard.html">
  <label>CacheFlow Stats</label>
  <module name="AccountBar" layoutPanel="navigationHeader"/>
  <module name="AppBar" layoutPanel="navigationHeader"/>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="navigationHeader">
    <param name="showActionsMenu">True</param>
  </module>

  <!-- this one HiddenSearch will 'contain' several whole panels of UI -->
  <!-- If you dont want to have an inline search and you'd rather have a  -->
  <!-- saved search here, (possibly scheduled), just replace this module with 'HiddenSavedSearch' -->
  <!-- and give it a 'savedSearch' param, give it the name of your savedSearch. -->
  <!-- see the other dashboard example views if this makes no sense -->
   <module name="TimeRangePicker" layoutPanel="panel_row1_col1" >
      <param name="selected">Last 24 hours</param>
      <param name="searchWhenChanged">True</param>


	<module name="HiddenSavedSearch" layoutPanel="panel_row1_col1" autoRun="True">
  
  <param name="savedSearch">BlueCoat - DataCube</param>
  <module name="ViewRedirectorLink">
          <param name="viewTarget">flashtimeline</param>
          <param name="label">View Full Report</param>
        </module>
      </module>

 
  <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1" autoRun="True">

  <param name="savedSearch">BlueCoat - DataCube</param>
<module name="JobProgressIndicator"></module>




  <module name="HiddenPostProcess" layoutPanel="panel_row2_col1" group="Requests" autoRun="True">
            <param name="search">| stats count</param>
            <module name="SingleValue">
                <param name="format">count</param>
            </module>
        </module>

  <module name="HiddenPostProcess" layoutPanel="panel_row2_col2" group="Bandwidth" autoRun="True">
            <param name="search">| stats sum(server_bytes)</param>
            <module name="SingleValue">

                <param name="afterLabel">server bytes</param>
                <param name="format">count</param>
            </module>
        </module>

  <module name="HiddenPostProcess" layoutPanel="panel_row2_col2"  group="Bandwidth" autoRun="True">
            <param name="search">| stats sum(client_bytes) as count</param>
            <module name="SingleValue">
                <param name="afterLabel">client bytes</param>
                <param name="format">count</param>
            </module>
        </module>

  <module name="HiddenPostProcess" layoutPanel="panel_row2_col3" group="Bandwidth Savings" autoRun="True">
            <param name="search">| stats avg(savings_perc)</param>
            <module name="SingleValue">

                <param name="afterLabel">%</param>
                <param name="format">count</param>
            </module>
        </module>

 <module name="HiddenPostProcess" layoutPanel="panel_row3_col1">


      <param name="search">timechart sum(client_bytes) as "Client Bytes" sum(server_bytes) as "Server Bytes"  sum(savings_bytes) as "Bandwidth Savings" </param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Bandwidth Over Time</param>
        <param name="chart">area</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
    </module>




 <module name="HiddenPostProcess" layoutPanel="panel_row4_col1">

<param name="search">stats avg(savings_perc)  as "Bandwidth Savings" by _time</param> 
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Bandwidth Savings Over Time</param>
        <param name="chart">area</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
    </module>






 <module name="HiddenPostProcess" layoutPanel="panel_row5_col1">
      <param name="search">stats sum(server_bytes)  as server_bytes by _time</param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Server Bandwidth Over Time</param>
        <param name="chart">area</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
    </module>

 <module name="HiddenPostProcess" layoutPanel="panel_row6_col1">
      <param name="search">stats sum(client_bytes)  as client_bytes by _time</param>
      <module name="HiddenChartFormatter">
  <param name="chartTitle">Client Bandwidth	Over Time</param>
        <param name="chart">area</param>
        <param name="legend.placement">bottom</param>
        <module name="FlashChart">
          <param name="width">100%</param>
         <module name="ConvertToDrilldownSearch">
         <module name="ViewRedirector">
           <param name="viewTarget">flashtimeline</param>
         </module>
		</module>
        </module>
      </module>
    </module>

    </module>

</module>

 </view>
