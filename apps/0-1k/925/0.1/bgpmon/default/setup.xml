<setup>
  <block title="Credentials" endpoint="admin/passwords" entity="_new">
    <text>                                                        
	 &lt;i&gt;Use your account or &lt;/i&gt;demo@bgpmon.net / demo&lt;i&gt;.&lt;/i&gt;
    </text>  
    <input field="name">
    <label>BgpMon.net username:</label>
      <type>text</type>
    </input>
    <input field="password">
      <label>Password:</label>
      <type>password</type>
    </input>
  </block>
  
  <block title="Scheduling"
         endpoint="admin/script"
	 entity=".%252Fbin%252Fwrapper.py">
    <text>
      &lt;i&gt;Value should be set to at least 10 minutes (600).&lt;/i&gt;
    </text>
    <input field="interval">
      <label>Specify the interval for [$name$] (sec):</label>
      <type>text</type>
    </input>
	
  </block>
  
</setup>
