<form>
  <label>Event Code Searchs</label>
  
  <!-- define master search template; leave time unbounded so that the time input can be used -->
<searchTemplate>`EventCode($series$)` `UserGroup($otherSeries$)`</searchTemplate>

  <fieldset>
      <input type="text" token="series">
        <label>Event Code(s) (Ex: 605,705...,n) MAX=20</label>
	<seed>*</seed>
        <prefix>*</prefix>
      </input>

      <input type="text" token="otherSeries">
        <label>User Group(s) (Ex: HR,SAS...,n) MAX=20</label>
        <seed>*</seed>
        <prefix>*</prefix>
      </input>
      
      <!-- add default TimePicker -->
      <input type="time" />
      
  </fieldset>
  
  <row>
    
      <!-- show results as a table -->
      <event>
        <option name="showPager">true</option>
        <option name="count">20</option>
      </event>
      
  </row>
  
</form>
