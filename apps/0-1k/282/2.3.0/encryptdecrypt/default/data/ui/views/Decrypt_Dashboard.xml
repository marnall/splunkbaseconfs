<form script="set_input_type.js" version="1.1">
  <label>Decrypt (DES)</label>
  <search id="baseQuery">
    <query>
      $filter_field$ |decrypt "$regex_field$" "$key_field$"
    </query>
  </search>
  <fieldset>      
      <input type="text" token="filter_field">
          <label>Enter filter (e.g. sourcetype=credit)</label>
      </input>
      <input type="text" token="regex_field">
          <label>Enter Regular Expression to find field</label>
      </input>
      <input type="text" token="key_field" id="decrypt_key">
          <label>Enter Key to decrypt</label>
      </input>

      <input type="time" />
  </fieldset>
 <row>
      <table>
          <title>Decrypted Results</title>
	  <search base="baseQuery">
	    <query>|table decryptedField  _raw
	    </query>
	  </search>
	  <option name="count">20</option>
	  <option name="showPager">true</option>
	  <option name="drilldown">none</option>
      </table>
 </row>

</form>

