<form version="1.1" theme="light" script="js/info_tooltip.js" stylesheet="css/info_tooltip.css">
  <label>Allowed Binds</label>
  <init>
    <set token="show_server_count"> </set>
  </init>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <default>
        <earliest>-7d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Number Of Allowed Binds By Time</title>
      <chart>
        <search>
          <query>`windowsindex` `windowssourcetype` EventCode=5159 | timechart count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="refresh.display">progressbar</option>
        <option name="charting.seriesColors">[0xa2cc3e, 0x1e93c6, 0xf2b827, 0xd6563c, 0x6a5c9e, 0x31a35f, 0xed8440, 0x3863a0, 0xcc5068, 0x73427f, 0x11a88b, 0xea9600, 0x0e776d, 0xffb380, 0xaa3977, 0x91af27, 0x4453aa, 0x99712b, 0x553577, 0x97bc71, 0xd35c2d, 0x314d5b, 0x99962b, 0x844539, 0x00b290, 0xe2c188, 0xa34a41, 0x44416d, 0xe29847, 0x8c8910, 0x0b416d, 0x774772, 0x3d9988, 0xbdbd5e, 0x5f7396, 0x844539]</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Top 10 Servers With Allowed Binds</title>
      <chart>
        <search>
          <query>`windowsindex` `windowssourcetype` EventCode=5159 | top 10 host | rename host AS "Server"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="refresh.display">progressbar</option>
        <option name="charting.seriesColors">[0xa2cc3e, 0x1e93c6, 0xf2b827, 0xd6563c, 0x6a5c9e, 0x31a35f, 0xed8440, 0x3863a0, 0xcc5068, 0x73427f, 0x11a88b, 0xea9600, 0x0e776d, 0xffb380, 0xaa3977, 0x91af27, 0x4453aa, 0x99712b, 0x553577, 0x97bc71, 0xd35c2d, 0x314d5b, 0x99962b, 0x844539, 0x00b290, 0xe2c188, 0xa34a41, 0x44416d, 0xe29847, 0x8c8910, 0x0b416d, 0x774772, 0x3d9988, 0xbdbd5e, 0x5f7396, 0x844539]</option>
      </chart>
    </panel>
    <panel>
      <title>Top 10 Allowed Ports</title>
      <chart>
        <search>
          <query>`windowsindex` `windowssourcetype` EventCode=5159 | top 10 Source_Port | rename Source_Port AS "Source port"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="refresh.display">progressbar</option>
        <option name="charting.seriesColors">[0xa2cc3e, 0x1e93c6, 0xf2b827, 0xd6563c, 0x6a5c9e, 0x31a35f, 0xed8440, 0x3863a0, 0xcc5068, 0x73427f, 0x11a88b, 0xea9600, 0x0e776d, 0xffb380, 0xaa3977, 0x91af27, 0x4453aa, 0x99712b, 0x553577, 0x97bc71, 0xd35c2d, 0x314d5b, 0x99962b, 0x844539, 0x00b290, 0xe2c188, 0xa34a41, 0x44416d, 0xe29847, 0x8c8910, 0x0b416d, 0x774772, 0x3d9988, 0xbdbd5e, 0x5f7396, 0x844539]</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
        <title>Windows Firewall Allowed Binds (detailed)</title>
        <input type="text" token="Server">
            <label>Server:</label>
            <default>*</default>
            <initialValue>*</initialValue>
        </input>
        <input type="text" token="Application_Name">
            <label>Application Name:</label>
            <default>*</default>
            <initialValue>*</initialValue>
        </input>
      <table>
        <search>
          <query>`windowsindex` `windowssourcetype` EventCode=5159 host=$Server$ Application_Name=$Application_Name$ | table _time host Application_Name Source_Address Source_Port | rename _time AS Time host AS Serverr Application_Name AS Application Source_Address AS "Source IP" Source_Port AS "Source Port" | convert timeformat="%H:%M:%S %d.%m.%Y." ctime(Time)</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="rowNumbers">true</option>
        <option name="refresh.display">preview</option>
      </table>
    </panel>
  </row>
</form>