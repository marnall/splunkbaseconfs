<form version="1.1" theme="light" script="js/info_tooltip.js" stylesheet="css/info_tooltip.css">
  <label>Process Tracking</label>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <default>
        <earliest>-7d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Process Activity</title>
      <chart>
        <search>
          <query>`windowsindex` `windowssourcetype` EventCode="592" OR EventCode="4688" NOT (User="SYSTEM" OR TargetUserName="SYSTEM") NOT (User="NETWORK SERVICE" OR TargetUserName="NETWORK SERVICE") | timechart bins=100 count by host</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="refresh.display">progressbar</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.seriesColors">[0xa2cc3e, 0x1e93c6, 0xf2b827, 0xd6563c, 0x6a5c9e, 0x31a35f, 0xed8440, 0x3863a0, 0xcc5068, 0x73427f, 0x11a88b, 0xea9600, 0x0e776d, 0xffb380, 0xaa3977, 0x91af27, 0x4453aa, 0x99712b, 0x553577, 0x97bc71, 0xd35c2d, 0x314d5b, 0x99962b, 0x844539, 0x00b290, 0xe2c188, 0xa34a41, 0x44416d, 0xe29847, 0x8c8910, 0x0b416d, 0x774772, 0x3d9988, 0xbdbd5e, 0x5f7396, 0x844539]</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Detailed Process Activity</title>
      <input type="text" token="Host">
            <label>Host:</label>
            <default>*</default>
            <initialValue>*</initialValue>
        </input>
        <input type="text" token="Useracc">
            <label>User Account:</label>
            <default>*</default>
            <initialValue>*</initialValue>
        </input>
        <input type="text" token="FileName">
            <label>File Name:</label>
            <default>*</default>
            <initialValue>*</initialValue>
        </input>
      <table>
        <search>
          <query>`windowsindex` `windowssourcetype` EventCode="592" OR EventCode=4688 NOT (User="SYSTEM" OR TargetUserName="SYSTEM") NOT (User="NETWORK SERVICE" OR TargetUserName="NETWORK SERVICE") | eval FileName=coalesce(Image_File_Name,Image_File_Name,New_Process_Name,NewProcessName) | eval finaluser=coalesce(User_Name,User_Name,Account_Name,TargetUserName) | search host="$Host$" finaluser="$Useracc$" FileName="$FileName$" | fillnull value="-" Domain | table _time host finaluser Domain FileName | rename _time AS Time host AS Server finaluser AS Username | convert timeformat="%H:%M:%S %d.%m.%Y." ctime(Time)</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="rowNumbers">true</option>
        <option name="refresh.display">preview</option>
      </table>
    </panel>
  </row>
</form>