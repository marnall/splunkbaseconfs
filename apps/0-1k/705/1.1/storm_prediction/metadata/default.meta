
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[default]

[app/launcher]
owner = admin
version = 4.2.2

[app/ui]
owner = admin
version = 4.2.2

[inputs/monitor/$SPLUNK_HOME/etc/apps/storm_prediction/logs/hail.csv]
owner = admin
version = 4.2.2

[inputs/monitor/$SPLUNK_HOME/etc/apps/storm_prediction/logs/torn.csv]
owner = admin
version = 4.2.2

[inputs/monitor/$SPLUNK_HOME/etc/apps/storm_prediction/logs/wind.csv]
owner = admin
version = 4.2.2

[savedsearches/graph]
access = read : [ * ]
owner = admin
version = 4.2.2
export = none

[savedsearches/hail_analysis]
access = read : [ * ]
owner = admin
version = 4.2.2
export = none

[savedsearches/searchyear]
access = read : [ * ], write : [ admin, power ]
owner = admin
version = 4.2.2

[views/hail_analysis]
owner = admin
version = 4.2.2

[views/torn_analysis]
owner = admin
version = 4.2.2

[views/wind_analysis]
owner = admin
version = 4.2.2

