<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html">
  <label>Tune eventtypes - step 2</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
<!-- 
  <module name="AppBar" layoutPanel="navigationHeader"/>
-->
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">2</param>
  </module>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">splunk.search.job</param>
    <param name="clearOnJobDispatch">True</param>
    <param name="maxSize">1</param>
  </module>
  <module name="FeedbackLinks" layoutPanel="viewHeader">
    <param name="section">tune</param>
    <param name="subSection">eventtypes</param>
  </module>
  <module name="BreadCrumb" layoutPanel="viewHeader">
    <param name="options">
      <list>
        <param name="view">home</param>
        <param name="label">Home</param>
      </list>
      <list>
        <param name="view">tune_eventtypes_1</param>
        <param name="label">Tune Eventtypes</param>
      </list>
      <list>
        <param name="label">Select a search</param>
      </list>
    </param>
  </module>


  <module name="HiddenSearch" layoutPanel="splSearchControls-inline">
      
    
    <module name="Message" layoutPanel="viewHeader">
      <param name="filter">splunk.search.job</param>
      <param name="clearOnJobDispatch">True</param>
      <param name="maxSize">2</param>


      <!-- to get sid/q/s permalink resurrection working properly sometimes you have to have 
      the XML tree come down to a somewhat redundant single dispatching child, like the JobProgressIndicator below, 
      in order to get hte modules below that point working correctly. 
      EG:   if you have TitleBar be the module at the fork point, instead of JobProgressIndicator below, 
      then the TitleBar never gets the saved search name applied..
      -->

      <module name="JobProgressIndicator" layoutPanel="panel_row1_col1">

        <module name="EnablePreview">
          <param name="enable">True</param>
          <param name="display">False</param>
        </module>

        <module name="SimpleResultsHeader">
          <param name="entityName">results</param>
          <param name="headerFormat">Select one of the $count$ suggested eventtypes</param>
        </module>

        <module name="Paginator">
          <param name="entityName">results</param>
          <param name="count">5</param>
          
          
          <module name="SimpleResultsTable">
            <param name="entityName">results</param>
            <param name="drilldown">row</param>
            <param name="fields">search</param>
            
            <module name="NullModule" layoutPanel="panel_row2_col1">
              <module name="GenericHeader">
                <param name="label">Preview</param>
              </module>
              <module name="SearchBar">
                <module name="ServerSideInclude">
                  <param name="src">text/generic_action_buttons.html</param>
                </module>
                <!-- i use a maxCount param to limit the search to only 1000 events. -->
                <module name="HiddenSearch">
                  <param name="maxCount">1000</param>


                 
                  <module name="LinkSwitcher">
                    <param name="mode">independent</param>
                    <param name="label"> </param>
                    
                    <module name="SimpleResultsHeader" group="events">
                      <param name="entityName">events</param>
                      <param name="headerFormat">showing matching events</param>
                      <module name="Count">
                        <param name="default">5</param>
                        <param name="options">
                          <list>
                            <param name="text">5</param>
                            <param name="value">5</param>
                          </list>
                          <list>
                            <param name="text">10</param>
                            <param name="value">10</param>
                          </list>
                          <list>
                            <param name="text">20</param>
                            <param name="value">20</param>
                          </list>
                        </param>


                        <module name="Paginator">
                          <param name="count">10</param>
                          <param name="entityName">events</param>
                          <module name="EventsViewer">
                          </module>
                        </module>
                      </module>
                    </module>

                    <module name="SimpleResultsHeader" group="sourcetypes">
                      <param name="entityName">results</param>
                      <param name="headerFormat">distribution of matching events by sourcetype</param>
                      <module name="HiddenIntention">
                        <param name="intention">
                          <param name="name">plot</param>
                          <param name="arg">
                            <param name="mode">timechart</param>
                            <param name="fields">
                              <list>
                                <list>count</list>
                                <list>__events</list>
                              </list>
                            </param>
                            <param name="splitby">sourcetype</param>
                          </param>
                        </param>
                        <module name="HiddenChartFormatter">
                          <module name="EnablePreview">
                            <param name="enable">True</param>
                            <param name="display">False</param>
                          </module>
                          <module name="FlashChart">
                          </module>
                        </module>
                      </module>
                    </module>

                    <module name="SimpleResultsHeader" group="eventtypes">
                      <param name="entityName">results</param>
                      <param name="headerFormat">distribution of matching events by eventtype</param>
                      <module name="HiddenIntention">
                        <param name="intention">
                          <param name="name">plot</param>
                          <param name="arg">
                            <param name="mode">timechart</param>
                            <param name="fields">
                              <list>
                                <list>count</list>
                                <list>__events</list>
                              </list>
                            </param>
                            <param name="splitby">eventtype</param>
                          </param>
                        </param>
                        <module name="HiddenChartFormatter">
                          <module name="EnablePreview">
                            <param name="enable">True</param>
                            <param name="display">False</param>
                          </module>
                          <module name="FlashChart">
                          </module>
                        </module>
                      </module>
                    </module>
                  </module>
                    
                </module>
              </module>
            </module>
             
            

            
          </module>
          <module name="Paginator">
            <param name="entityName">results</param>
          </module>
        </module>
      </module>
    </module>
  </module>


</view>




