<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html">
  <label>Discover fields - step 2</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
<!-- 
  <module name="AppBar" layoutPanel="navigationHeader"/>
-->
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">2</param>
  </module>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">splunk.search.job</param>
    <param name="clearOnJobDispatch">True</param>
    <param name="maxSize">2</param>
  </module>
  <module name="FeedbackLinks" layoutPanel="viewHeader">
    <param name="section">discover</param>
    <param name="subSection">fields</param>
  </module>
  <module name="BreadCrumb" layoutPanel="viewHeader">
    <param name="options">
      <list>
        <param name="view">home</param>
        <param name="label">Home</param>
      </list>
      <list>
        <param name="view">discover_fields_1</param>
        <param name="label">Discover Fields</param>
      </list>
      <list>
        <param name="label">Select a Regex</param>
      </list>
    </param>
  </module>
  
  <!-- see application.js -->
  <module name="NullModule" layoutPanel="panel_row1_col1">
    <module name="SimpleResultsHeader">
      <param name="entityName">results</param>
      <param name="headerFormat">Select one of the $count$ suggested regexes for the sourcetype "$sourcetype$"</param>
    </module>
    <module name="Paginator">
      <param name="entityName">results</param>
        
      <module name="SimpleResultsTable">
        <param name="entityName">results</param>
        <param name="count">10</param>
        <param name="fields">regex redundancy_percent coverage_percent</param>
        <param name="displayRowNumbers">False</param>
        <param name="drilldown">row</param>
        
        <!-- BEGIN RIGHT PANEL -->
        <module name="NullModule" layoutPanel="panel_row1_col2">
          <module name="SimpleResultsHeader">
            <param name="entityName">results</param>
            <param name="headerFormat">Text matched by the selected regex is shown highlighted. </param>
          </module>

          <module name="StaticContentSample" layoutPanel="panel_row1_col2">
            <param name="text">"Create" to make a new extracted field from this regex. "Ignore" ones that look useless. You can also edit the regex manually below.</param>
          </module>
          
          <module name="SearchBar" layoutPanel="panel_row1_col2">
            <param name="useOwnSubmitButton">False</param>
            <module name="ServerSideInclude">
              <param name="src">text/generic_action_buttons.html</param>
            </module>
            <module name="JobProgressIndicator"></module>
              <module name="Message">
                <param name="filter">splunk.search.customRegexClass</param>
                <param name="clearOnJobDispatch">True</param>
                <param name="maxSize">2</param>
              </module>
            <module name="HiddenSoftWrap">
              <param name="enable">True</param>
              <module name="Paginator">
                <param name="entityName">events</param>
                <module name="EventsViewer">
                  <param name="segmentation">raw</param>
                </module>
                <module name="Paginator">
                  <param name="entityName">events</param>
                </module>
              </module>
            </module>
          </module>
        </module>
        <!-- END RIGHT PANEL -->


      </module>
      <module name="Paginator">
        <param name="entityName">results</param>
      </module>
    </module>
  </module>


  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text"><![CDATA[
<p>
  <b>redundancy percent</b> -- this refers to how often this field duplicates or occurs within a field that already exists.
</p>
<p>
  <b>coverage percent</b> -- this refers to how many events within this sourcetype contain a value for this extraction.
</p>
<p>
  Note that this tool deliberately ignores fields that you are already extracting successfully.  If it doesn't recommend very many fields, or if they dont seem useful, you may have just done a good job already of extracting everything. 
</p>

  ]]></param>
  </module>


</view>




