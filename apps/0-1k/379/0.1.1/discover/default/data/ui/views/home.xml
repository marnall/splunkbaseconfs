<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html">
  <label>Home</label>
  <module name="AccountBar" layoutPanel="appHeader" />
  <module name="FeedbackLinks" layoutPanel="viewHeader">
    <param name="section">discover</param>
  </module>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="maxSize">2</param>
    <param name="clearOnJobDispatch">False</param>
  </module>
  

  <module name="BreadCrumb" layoutPanel="viewHeader">
    <param name="options">
      <list>
        <param name="label">Home</param>
      </list>
    </param>
  </module>


  <!-- 
  <module name="PrerequisiteChecker" layoutPanel="panel_row1_col1">
    <param name="search">| inputlookup discover_fields_status | search sourcetype="$sourcetype$"</param>
    <param name="passMessage">Good to go.</param>
    <param name="failMessage">You have not run 'Discover fields' for this sourcetype.</param>
  </module>
  -->

  <module name="GenericHeader" layoutPanel="panel_row1_col1">
    <param name="label">Welcome</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text"><![CDATA[

The functionality contained in this app is not final and much of it is experimental.  The main purpose of this app today is to gather your feedback.   Note the feedback links at the top right. Please please use them.<br>
<br>
<b>NOTE: Any field extractions, reports and eventtypes you create here will only exist within this app.  If you want them to be available in other apps you will have to go to Manager and either move them to another app or share them across all apps.</b>


  ]]></param>
  </module>

  
  <module name="GenericHeader" layoutPanel="panel_row2_col1">
    <param name="label">Discover</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row2_col1">
    <param name="text"><![CDATA[
These analyze the data you have indexed and suggest new search-time knowledge objects that will improve your experience in Splunk. Click below to try some out and learn more.
  ]]></param>
  </module>

  <module name="HiddenSearch" layoutPanel="panel_row2_col1" autoRun="True">
    <param name="search">foo NOT foo | append [ | inputlookup nav_discover | search view="discover_*" view!="discover_fields_alternate_1" | sort order | fields view, name, description, lastRun | rename lastRun as _time | customreltime | rename reltime as lastRun | eval lastRun=if(lastRun="41 years ago","never",lastRun) | eval eventtype="section_navigation" ]</param>

    <module name="EventsViewer">
      <param name="entityName">events</param>
      <param name="fields">view, name, description, lastRun</param>
    </module>

  </module>


  <module name="GenericHeader" layoutPanel="panel_row3_col1">
    <param name="label">Tune</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row3_col1">
    <param name="text"><![CDATA[

These would analyze configurations as well as how you've been using Splunk.  Then can they suggest better ways to use or organize the search-time knowledge objects you already have.  Click below to read more.
  ]]></param>
  </module>

  <module name="HiddenSearch" layoutPanel="panel_row3_col1" autoRun="True">
    <param name="search">foo NOT foo | append [| inputlookup nav_discover | search view="tune_other"  | sort order | fields view, name, description, lastRun | rename lastRun as _time | customreltime | rename reltime as lastRun | eval lastRun=if(lastRun="41 years ago","never",lastRun) | eval eventtype="section_navigation" ]</param>

    <module name="EventsViewer">
      <param name="entityName">events</param>
      <param name="fields">view, name, description, lastRun</param>
    </module>

  </module>
  

  <module name="GenericHeader" layoutPanel="panel_row4_col1">
    <param name="label">Validate</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row4_col1">
    <param name="text"><![CDATA[

Find common problems in your server or specific apps by analyzing your data, usage, and configuration.

  ]]></param>
  </module>

  <module name="GenericHeader" layoutPanel="panel_row4_col1_grp1">
    <param name="label">Validate Server</param>
  </module>

  <module name="SubmitButton" layoutPanel="panel_row4_col1_grp1">
    <param name="label">Validate Server</param>
    <module name="ViewRedirector">
      <param name="viewTarget">validate_system</param>
    </module>
  </module>

  <module name="GenericHeader" layoutPanel="panel_row4_col1_grp2">
    <param name="label">Validate Specific App </param>
  </module>

  <module name="EntitySelectLister" layoutPanel="panel_row4_col1_grp2">
    <param name="entityPath">apps/local</param>
    <param name="label">App</param>
    <param name="settingToCreate">app</param>
    <param name="count">250</param>
    <param name="selected">Any</param>
    <param name="entityFieldsToDisplay">
      <list>
        <param name="multiLabel">%(label)s</param>
        <param name="multiLabelAlt">%(name)s %(label)s</param>
        <!-- Because of the unfortunate way in which EntitySelectLister implements setSelected(), 
        (it sets the selection according to the text label rather than the value)
        we have to actually pass the label of the app instead of the app name. 
        Note: the app label is not guaranteed to be unique so this will problematic someday. 
        -->
        <param name="value">label</param>
      </list>
    </param>
    <param name="staticFieldsToDisplay">
      <list>
        <param name="label">Any</param>
        <param name="value">none</param>
      </list>
    </param>
    <module name="SubmitButton">
      <module name="ViewRedirector">
        <param name="viewTarget">validate_app</param>

        <!--  
        see comment above about EntitySelectLister, to find out why we pass 
        the <option> label here instead of the actual value.
        -->
        <param name="uriParam.app">$app$</param>
      </module>
    </module>
  </module>
</view>
