<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html">
  <label>Discover fields - alternate - step 2</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
<!-- 
  <module name="AppBar" layoutPanel="navigationHeader"/>
-->
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">2</param>
  </module>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">splunk.search.job</param>
    <param name="clearOnJobDispatch">True</param>
    <param name="maxSize">1</param>
  </module>
  <module name="FeedbackLinks" layoutPanel="viewHeader">
    <param name="section">discover</param>
    <param name="subSection">fields</param>
  </module>
  <module name="BreadCrumb" layoutPanel="viewHeader">
    <param name="options">
      <list>
        <param name="view">home</param>
        <param name="label">Home</param>
      </list>
      <list>
        <param name="view">discover_fields_alternate_1</param>
        <param name="label">Discover Fields (alternate)</param>
      </list>
      <list>
        <param name="label">Select a Discovered Field</param>
      </list>
    </param>
  </module>

  <module name="Message" layoutPanel="viewHeader">
    <param name="filter">splunk.search.job</param>
    <param name="clearOnJobDispatch">True</param>
    <param name="maxSize">2</param>
  </module>

  <module name="StaticContentSample" layoutPanel="mainSearchControls">
    <param name="text"><![CDATA[
On this page you are presented with a number of suggestions for new fields to create. <br>
Select a field to be taken to the <a href="../../ifx">interactive field extractor</a> with those field 
values prepopulated.<br>
<b>NOTE: this is an earlier prototype of discover fields. Check out the <a href="discover_fields_1">official version</a></b>
    ]]></param>
  </module>

  <module name="NullModule" layoutPanel="mainSearchControls">
 
    <module name="HiddenSearch" autoRun="True">
      <param name="search">index=$index$ sourcetype=$sourcetype$ | head 1000 | discover fields | search redundancy_percent &lt; 100 | sort + redundancy_percent - coverage_percent | fields - _time | fields top_extractions regex redundancy_percent coverage_percent type numeric snippet *</param>
    
      
      

      <module name="JobProgressIndicator" layoutPanel="panel_row1_col1">


        <module name="SimpleResultsHeader">
          <param name="entityName">results</param>
          <param name="headerFormat">Select one of the $count$ suggested regexes.  You will be taken to the Interactive Field Extractor</param>
        </module>

        <module name="Paginator">
          <param name="entityName">results</param>
          <param name="count">10</param>
          
          
          <module name="SimpleResultsTable">
            <param name="entityName">results</param>
            <param name="drilldown">row</param>
            
          
            
            <!-- 
            We put a NullModule here.  
            It doesnt DO anything, but it will get wired up with all the events 
            and data by the module framework. 
            Then by setting up some things onHierarchyLoaded and implementing its 
            onContextChange method from our custom JS, we can make this thing do our bidding. 
            -->

            <module name="NullModule">
            </module>
          </module>
          <module name="Paginator">
            <param name="entityName">results</param>
          </module>
        </module>
      </module>
    </module>
  </module>


</view>




