<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html">
  <label>Discover event types - step 2</label>
  <module name="AccountBar" layoutPanel="appHeader"/>

  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">2</param>
  </module>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">splunk.search.job</param>
    <param name="clearOnJobDispatch">True</param>
    <param name="maxSize">1</param>
  </module>

  <module name="FeedbackLinks" layoutPanel="viewHeader">
    <param name="section">discover</param>
    <param name="subSection">eventtypes</param>
  </module>

  <module name="BreadCrumb" layoutPanel="viewHeader">
    <param name="options">
      <list>
        <param name="view">home</param>
        <param name="label">Home</param>
      </list>
      <list>
        <param name="view">discover_eventtypes_1</param>
        <param name="label">Discover Eventtypes</param>
      </list>
      <list>
        <param name="label">Select a search</param>
      </list>
    </param>
  </module>


  


  <module name="NullModule" layoutPanel="viewHeader"> 

    <module name="PrerequisiteChecker" layoutPanel="viewHeader">
      <param name="search">| inputlookup discover_fields_status | search sourcetype="$sourcetype$"</param>
      <param name="passMessage"> </param>
      <param name="failMessage"><![CDATA[
<b style="color:#f00">WARNING: You haven't run 'Discover Fields' for this sourcetype yet.<br>
<a href="discover_fields_1">Run the Discover Fields tool.</a></b>
            ]]></param>
    </module>
    <module name="Message" layoutPanel="viewHeader">
      <param name="filter">splunk.search.job</param>
      <param name="clearOnJobDispatch">True</param>
      <param name="maxSize">2</param>

      <module name="HiddenPostProcess">
        <param name="search">search depth=0</param>

        <module name="JobProgressIndicator" layoutPanel="panel_row1_col1">
          <module name="SimpleResultsHeader">
            <param name="entityName">events</param>
            <param name="headerFormat">Select one of the discovered event types below</param>
          </module>

          <module name="Paginator">
            <param name="entityName">results</param>
            <param name="count">10</param>
            
            <module name="SimpleResultsTable">

              <!-- 
              TODO its lame that you have to do this.
              If you are displaying 'results', and you have some 'fields' set
              when would the 'fields' ever mean non-transformed fields.
              -->
              <param name="allowTransformedFieldSelect">True</param>

              <param name="fields">search coverage</param>
              <param name="entityName">results</param>
              <param name="drilldown">row</param>
              
              <module name="NullModule">
                <module name="Paginator">
                  <param name="entityName">results</param>
                  <param name="count">10</param>
                  
                  <module name="SimpleResultsHeader">
                    <param name="entityName">events</param>
                    <param name="headerFormat">These more specific searches may also be interesting:</param>
                  </module>

                  <module name="SimpleResultsTable">
                    <param name="fields">search coverage</param>
                    <param name="allowTransformedFieldSelect">True</param>
                    <param name="entityName">results</param>
                    <param name="drilldown">row</param>
                    
                    <module name="NullModule">
                      <module name="SimpleResultsHeader">
                        <param name="entityName">events</param>
                        <param name="headerFormat">even more...</param>
                      </module>
                      <module name="Paginator">
                        <param name="entityName">results</param>
                        <param name="count">10</param>

                        <module name="SimpleResultsTable">
                          <param name="fields">search coverage</param>
                          <param name="allowTransformedFieldSelect">True</param>
                          <param name="entityName">results</param>
                          <param name="drilldown">row</param>
                          <module name="NullModule"></module>
                        </module>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
               
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
  <module name="SearchBar" layoutPanel="panel_row1_col2">
    <module name="ServerSideInclude">
      <param name="src">text/generic_action_buttons.html</param>
    </module>

    <module name="HiddenSearch">
      <module name="JobProgressIndicator">
      </module>
      <module name="SimpleResultsHeader">
        <param name="entityName">events</param>
        <param name="headerFormat">Showing events that match this discovered eventtype</param>
      </module>
      <module name="Paginator">
        <param name="entityName">events</param>
        <module name="HiddenSoftWrap">
          <module name="EventsViewer">
            <param name="fields">*</param>
            
            <param name="segmentation">raw</param>
          </module>
        </module>
      </module>
    </module>
  </module>
  
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text"><![CDATA[
<p>
  <b>coverage</b> -- this refers to how many events within this sourcetype contain a value for this extraction.
</p>
<p>
  Note that this tool deliberately ignores eventtypes that you have already created.  If it doesn't recommend very many eventtypes, or if they dont seem useful, you may have just done a good job already of creating them all. 
</p>

  ]]></param>
  </module>
</view>




