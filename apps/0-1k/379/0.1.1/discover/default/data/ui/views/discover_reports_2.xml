<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html">
  <label>Discover reports - step 2</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
<!-- 
  <module name="AppBar" layoutPanel="navigationHeader"/>
-->
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">2</param>
  </module>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">splunk.search.job</param>
    <param name="clearOnJobDispatch">True</param>
    <param name="maxSize">1</param>
  </module>
  <module name="FeedbackLinks" layoutPanel="viewHeader">
    <param name="section">discover</param>
    <param name="subSection">reports</param>
  </module>
  <module name="BreadCrumb" layoutPanel="viewHeader">
    <param name="options">
      <list>
        <param name="view">home</param>
        <param name="label">Home</param>
      </list>
      <list>
        <param name="view">discover_reports_1</param>
        <param name="label">Discover reports</param>
      </list>
      <list>
        <param name="label">Select a field</param>
      </list>
    </param>
  </module>

  <module name="NullModule" layoutPanel="mainSearchControls">
      
    <module name="PrerequisiteChecker">
      <param name="search">| inputlookup discover_fields_status | search sourcetype="$sourcetype$"</param>
      <param name="passMessage"> </param>
      <param name="failMessage"><![CDATA[
<b style="color:#f00">WARNING: You haven't run 'Discover Fields' for this sourcetype yet.<br>
<a href="discover_fields_1">Run the Discover Fields tool.</a></b>
            ]]></param>
    </module>

    <module name="Message" layoutPanel="viewHeader">
      <param name="filter">splunk.search.job</param>
      <param name="clearOnJobDispatch">True</param>
      <param name="maxSize">2</param>

      


      <module name="NullModule" layoutPanel="panel_row1_col1">

        <module name="JobProgressIndicator"></module>

        <module name="SimpleResultsHeader">
          <param name="entityName">results</param>
          <param name="headerFormat">Select one of the $count$ fields from the sourcetype "$sourcetype$"</param>
        </module>
          
            
        <module name="Paginator">
          <param name="entityName">results</param>
          <param name="count">10</param>

          <module name="SimpleResultsTable">
            <param name="entityName">results</param>
            <param name="drilldown">row</param>
            <param name="fields">field dc</param>

            <module name="StaticSelect" layoutPanel="panel_row1_col2">
              <param name="settingToCreate">includeOtherFields</param>
              <param name="label">Include other fields in suggestions?</param>
              <param name="searchWhenChanged">True</param>
              <param name="staticFieldsToDisplay">
                <list>
                  <param name="label">Yes</param>
                  <param name="value">yes</param>
                </list>
                <list>
                  <param name="label">No</param>
                  <param name="value">no</param>
                </list>
              </param>

              <module name="NullModule">

                <module name="JobProgressIndicator"></module>

                <module name="SimpleResultsHeader">
                  <param name="entityName">results</param>
                  <param name="headerFormat">Select one of the $count$ suggested reports about the "$click.value$" field</param>
                </module>
                  
                <module name="Paginator">
                  <param name="entityName">results</param>
                  <param name="count">10</param>

                  <module name="SimpleResultsTable">
                    <param name="entityName">results</param>
                    <param name="drilldown">row</param>
                    <param name="drilldownPrefix">click2</param>


                    <module name="NullModule" layoutPanel="panel_row2_col1">
                      

                      <module name="SimpleResultsHeader">
                        <param name="entityName">results</param>
                        <param name="headerFormat">description: $description$</param>
                      </module>

                      <module name="SimpleResultsHeader">
                        <param name="entityName">results</param>
                        <param name="headerFormat">search language: $search$</param>
                      </module>

                      <module name="EnablePreview">
                        <param name="display">False</param>
                        <param name="enable">True</param>
                      </module>

                      <module name="FlashChart">
                        <param name="enableResize">False</param>
                        <module name="ConvertToDrilldownSearch">
                          <module name="ViewRedirector">
                            <param name="viewTarget">flashtimeline</param>
                            <param name="popup">True</param>
                          </module>
                        </module>
                      </module>

                      <module name="SubmitButton">
                        <param name="label">View in Report Builder</param>
                        <module name="ViewRedirector">
                          <param name="viewTarget">report_builder_format_report</param>
                          <param name="popup">True</param>
                        </module>
                      </module>

                      <module name="SubmitButton">
                        <param name="label">View in Advanced Charting</param>
                        <module name="ViewRedirector">
                          <param name="viewTarget">charting</param>
                          <param name="popup">True</param>
                        </module>
                      </module>

                    </module>
                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>


</view>




