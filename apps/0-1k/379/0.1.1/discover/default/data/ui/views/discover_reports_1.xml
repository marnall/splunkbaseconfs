<view autoCancelInterval="90" isVisible="true" onunloadCancelJobs="true" template="dashboard.html">
  <label>Discover reports - step 1</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
<!-- 
  <module name="AppBar" layoutPanel="navigationHeader"/>
-->
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">2</param>
  </module>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">splunk.search.job</param>
    <param name="clearOnJobDispatch">True</param>
    <param name="maxSize">1</param>
  </module>
  <module name="FeedbackLinks" layoutPanel="viewHeader">
    <param name="section">discover</param>
    <param name="subSection">reports</param>
  </module>
  <module name="BreadCrumb" layoutPanel="viewHeader">
    <param name="options">
      <list>
        <param name="view">home</param>
        <param name="label">Home</param>
      </list>
      <list>
        <param name="label">Discover Reports</param>
      </list>
      <list>
        <param name="label">Select a Sourcetype</param>
      </list>
    </param>
  </module>

  

  
  <module name="SearchSelectLister" layoutPanel="viewHeader" autoRun="True">
    <param name="searchWhenChanged">True</param>
    <param name="selected">Any</param>
    <param name="settingToCreate">index</param>
    <param name="label">Index</param>
    <param name="search">| eventcount summarize=false index=* | search count>0 | search index!=*summary* | stats sum(count) as count values(server) as server by index | sort - count</param>
    <param name="searchFieldsToDisplay">
      <list>
        <param name="label">index</param>
        <param name="value">index</param>
      </list>
    </param>
    <param name="staticFieldsToDisplay">
      <list>
        <param name="label">Any</param>
        <param name="value">*</param>
      </list>
    </param>

    <module name="HiddenSearch">
      <param name="search">| metadata type=sourcetypes index="$index$" | search sourcetype!=*-too_small* | sort - totalCount | fields sourcetype totalCount | lookup discover_reports_status sourcetype | convert ctime(lastRun) timeformat="%a %D %H:%M" | rename lastRun as "last time this tool was run" totalCount as "events"</param>
    
      <module name="SubmitButton">
        <param name="allowSoftSubmit">True</param>


        
        <module name="Message" layoutPanel="viewHeader">
          <param name="filter">splunk.search.job</param>
          <param name="clearOnJobDispatch">True</param>
          <param name="maxSize">2</param>
          

          <!-- to get sid/q/s permalink resurrection working properly sometimes you have to have 
          the XML tree come down to a somewhat redundant single dispatching child, like the JobProgressIndicator below, 
          in order to get the modules below that point working correctly. 
          EG:   if you have TitleBar be the module at the fork point, instead of JobProgressIndicator below, 
          then the TitleBar never gets the saved search name applied..
          -->

          <module name="JobProgressIndicator" layoutPanel="panel_row1_col1">

            <module name="EnablePreview">
              <param name="enable">True</param>
              <param name="display">False</param>
            </module>

            <module name="SimpleResultsHeader">
              <param name="entityName">results</param>
              <param name="headerFormat">Select a sourcetype to analyze.  ($count$ total)</param>
            </module>

            <module name="Paginator">
              <param name="entityName">results</param>
              <param name="count">50</param>
              
              
              <module name="SimpleResultsTable">
                <param name="entityName">results</param>
                <param name="drilldown">row</param>
                
                <module name="ViewRedirector">
                  <param name="viewTarget">discover_reports_2</param>
                  <param name="uriParam.sourcetype">$click.value$</param>
                  <param name="uriParam.index">$index$</param>
                </module>

              </module>
              <module name="Paginator">
                <param name="entityName">results</param>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>


</view>




