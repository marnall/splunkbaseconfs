<?xml version="1.0"?>
<view template="dashboard.html">

    <label>Application Crashes</label>
    <module name="AccountBar" layoutPanel="appHeader"/>
    <module name="WindowsMonitoringCommon" layoutPanel="appHeader" />
    <module name="WindowsMonitoringAppBar" layoutPanel="navigationHeader"/>
    <module name="Message" layoutPanel="messaging">
        <param name="filter">*</param>
        <param name="clearOnJobDispatch">False</param>
        <param name="maxSize">2</param>
    </module>
    <module name="TitleBar" layoutPanel="viewHeader">
        <param name="actionsMenuFilter">dashboard</param>
    </module>
    <module name="WindowsMonitoringSearch" layoutPanel="mainSearchControls" autoRun="true">
        <param name="search">| inputlookup windows_event_system.csv | table Host</param>

        <module name="WindowsMonitoringDropdown">
            <param name="varName">Host</param>
            <param name="label">Select Host</param>
            <param name="style">float:left;</param>
            <param name="displayField">Host</param>
            <param name="valueField">Host</param>
            <param name="staticItem">All,*</param>
            <param name="topLabel">True</param>
            <param name="useWildcards">True</param>

            <module name="TimeRangePicker">
                <!--<param name="label"></param>-->
                <param name="searchWhenChanged">True</param>
                <param name="selected">Last 24 hours</param>

                <!-- Total Crashes by Host -->
                <module name="WindowsMonitoringContent" layoutPanel="panel_row1_col1">
                    <param name="style"></param>
                    <param name="content">
                        <![CDATA[
                            <h1>Total Crashes by Host</h1>
                        ]]>
                    </param>
                </module>
                <module name="WindowsMonitoringSearch" layoutPanel="panel_row1_col1">
                    <param name="search">eventtype="windows_events" EventCode="1001" Event_Name="*" host="$Host$" | eval application=P1 | stats sparkline as Trend, count by host | sort -count </param>
                    
                    <module name="ViewstateAdapter">
                        <param name="suppressionList">
                            <item>count</item>
                        </param>
                        <module name="HiddenFieldPicker">
                            <param name="strictMode">True</param>
                            <module name="JobProgressIndicator"/>
                            <module name="Paginator">
                                <param name="count">10</param>
                                <param name="entityName">results</param>
                                <module name="EnablePreview">
                                    <param name="enable">True</param>
                                    <param name="display">False</param>
                                    <module name="SimpleResultsTable">
                                        <param name="count">10</param>
                                        <param name="entityName">results</param>
                                        <param name="allowTransformedFieldSelect">False</param>
                                        <param name="drilldown">row</param>
                                        <module name="Gimp"/>
                                        <module name="WindowsMonitoringSearch">
                                            <param name="search">
                                                <![CDATA[
                                                    eventtype="windows_events" host="$click.value$" EventCode="1001" Event_Name="*"
                                                ]]>
                                            </param>
                                            <module name="ViewRedirector">
                                                <param name="viewTarget">flashtimeline</param>
                                            </module>
                                        </module>
                                    </module>
                                    <module name="ViewRedirectorLink">
                                        <param name="viewTarget">flashtimeline</param>
                                    </module>
                                </module>
                            </module>
                        </module>
                    </module>
                </module>
                <!-- End Total Crashes by Host -->




                <!-- Total Crashes by Application -->
                <module name="WindowsMonitoringContent" layoutPanel="panel_row1_col2">
                    <param name="style"></param>
                    <param name="content">
                        <![CDATA[
                            <h1>Total Crashes by Application</h1>
                        ]]>
                    </param>
                </module>
                <module name="WindowsMonitoringSearch" layoutPanel="panel_row1_col2">
                    <param name="search">eventtype="windows_events" EventCode="1001" Event_Name="*" host="$Host$" 
                        | eval application=P1." (version: ".P2.")" 
                        | stats sparkline as Trend, count by application
                        | sort -count
                    </param>
                    
                    <module name="ViewstateAdapter">
                        <param name="suppressionList">
                            <item>count</item>
                        </param>
                        <module name="HiddenFieldPicker">
                            <param name="strictMode">True</param>
                            <module name="JobProgressIndicator"/>
                            <module name="Paginator">
                                <param name="count">10</param>
                                <param name="entityName">results</param>
                                <module name="EnablePreview">
                                    <param name="enable">True</param>
                                    <param name="display">False</param>
                                    <module name="SimpleResultsTable">
                                        <param name="count">10</param>
                                        <param name="entityName">results</param>
                                        <param name="allowTransformedFieldSelect">False</param>
                                        <param name="drilldown">row</param>
                                        <module name="Gimp"/>
                                        <module name="WindowsMonitoringSearch">
                                            <param name="search">
                                                <![CDATA[
                                                    eventtype="windows_events" host="$Host$" EventCode="1001" Event_Name="*"
                                                    | eval application=P1." (version: ".P2.")" 
                                                    | search application="$click.value$"
                                                ]]>
                                            </param>
                                            <module name="ViewRedirector">
                                                <param name="viewTarget">flashtimeline</param>
                                            </module>
                                        </module>
                                    </module>
                                    <module name="ViewRedirectorLink">
                                        <param name="viewTarget">flashtimeline</param>
                                    </module>
                                </module>
                            </module>
                        </module>
                    </module>
                </module>
                <!-- End Total Crashes by Application -->




                <!-- Crashes Over Time by Host -->
                <module name="WindowsMonitoringContent" layoutPanel="panel_row2_col1">
                    <param name="style"></param>
                    <param name="content">
                        <![CDATA[
                            <h1>Crashes Over Time by Host</h1>
                        ]]>
                    </param>
                </module>
                <module name="WindowsMonitoringSearch" layoutPanel="panel_row2_col1">
                    <param name="search">eventtype="windows_events" EventCode="1001" Event_Name="*" host="$Host$"
| timechart count by host</param>
                    
                    <module name="ViewstateAdapter">
                        <param name="suppressionList">
                            <item>charting.legend.placement</item>
                            <item>charting.chart</item>
                        </param>

                        <module name="HiddenFieldPicker">
                            <param name="strictMode">True</param>
                            <module name="JobProgressIndicator"/>
                            
                            <module name="HiddenChartFormatter">
                                <param name="charting.legend.placement">left</param>
                                <param name="charting.chart">line</param>
                                <module name="JSChart">
                                    <param name="width">100%</param>
                                    <module name="Gimp"/>
                                    <module name="WindowsMonitoringSearch">
                                        <param name="search">eventtype="windows_events" EventCode="1001" Event_Name="*" host="$click.name2$"</param>
                                        <module name="ViewRedirector">
                                            <param name="viewTarget">flashtimeline</param>
                                        </module>
                                    </module>
                                </module>
                            </module>
                            <module name="ViewRedirectorLink">
                                <param name="viewTarget">flashtimeline</param>
                            </module>
                        </module>
                    </module>
                </module>
                <!-- End Crashes Over Time by Host -->





                
                <!-- Crashes Over Time by Application -->
                <module name="WindowsMonitoringContent" layoutPanel="panel_row2_col2">
                    <param name="style"></param>
                    <param name="content">
                        <![CDATA[
                            <h1>Crashes Over Time by Application</h1>
                        ]]>
                    </param>
                </module>
                <module name="WindowsMonitoringSearch" layoutPanel="panel_row2_col2">
                    <param name="search">eventtype="windows_events" EventCode="1001" Event_Name="*" host="$Host$"
| eval application=P1." (version: ".P2.")"              
| timechart count by application</param>
                    
                    <module name="ViewstateAdapter">
                        <param name="suppressionList">
                            <item>charting.legend.placement</item>
                            <item>charting.chart</item>
                        </param>

                        <module name="HiddenFieldPicker">
                            <param name="strictMode">True</param>
                            <module name="JobProgressIndicator"/>
                            
                            <module name="HiddenChartFormatter">
                                <param name="charting.legend.placement">left</param>
                                <param name="charting.chart">line</param>
                                <module name="JSChart">
                                    <param name="width">100%</param>
                                    <module name="Gimp"/>
                                    <module name="WindowsMonitoringSearch">
                                        <param name="search">eventtype="windows_events" EventCode="1001" Event_Name="*" host="$Host$" | eval application=P1." (version: ".P2.")" | search application="$click.name2$"</param>
                                        <module name="ViewRedirector">
                                            <param name="viewTarget">flashtimeline</param>
                                        </module>
                                    </module>
                                </module>
                            </module>
                            <module name="ViewRedirectorLink">
                                <param name="viewTarget">flashtimeline</param>
                            </module>
                        </module>
                    </module>
                </module>
                <!-- End Crashes Over Time by Application -->



                <!-- Crash Details by Host -->
                <module name="WindowsMonitoringContent" layoutPanel="panel_row3_col1">
                    <param name="style"></param>
                    <param name="content">
                        <![CDATA[
                            <h1>Crash Details by Host</h1>
                        ]]>
                    </param>
                </module>
                <module name="WindowsMonitoringSearch" layoutPanel="panel_row3_col1">
                    <param name="search">eventtype="windows_events" EventCode="1001" Event_Name="*" host="$Host$"
| eval application=P1." (version: ".P2.")"
| stats latest(_time) as ltime, count by host, application
| convert ctime(ltime)
| eval comb=application." (Total App Events = ".count." )(Last Crash Time = ".ltime." )"              
| stats values(comb) AS Applications, sum(count) AS Total_Events by host
| sort -Total_Events                   </param>
                    
                    <module name="ViewstateAdapter">
                        <param name="suppressionList">
                            <item>count</item>
                        </param>
                        <module name="HiddenFieldPicker">
                            <param name="strictMode">True</param>
                            <module name="JobProgressIndicator"/>
                            <module name="Paginator">
                                <param name="count">10</param>
                                <param name="entityName">results</param>
                                <module name="EnablePreview">
                                    <param name="enable">True</param>
                                    <param name="display">False</param>
                                    <module name="SimpleResultsTable">
                                        <param name="count">10</param>
                                        <param name="entityName">results</param>
                                        <param name="allowTransformedFieldSelect">False</param>
                                        <param name="drilldown">row</param>
                                        <module name="Gimp"/>
                                        <module name="WindowsMonitoringSearch">
                                            <param name="search">
                                                <![CDATA[
                                                    eventtype="windows_events" EventCode="1001" Event_Name="*" host="$click.value$"
                                                ]]>
                                            </param>
                                            <module name="ViewRedirector">
                                                <param name="viewTarget">flashtimeline</param>
                                            </module>
                                        </module>
                                    </module>
                                    <module name="ViewRedirectorLink">
                                        <param name="viewTarget">flashtimeline</param>
                                    </module>
                                </module>
                            </module>
                        </module>
                    </module>
                </module>
                <!-- End Crash Details by Host -->




            </module>
        </module>
    </module>
    
    <module name="WindowsMonitoringContent" layoutPanel="panel_row4_col1"> 
        <param name="style"></param>
        <param name="content">
            <![CDATA[
                 <div class="winmonitoring-morereports">
                    <h1>More Reports</h1>
                    <ul>
                        <li><a href="/app/windows/%40go?s=Application%20crash%20count%20in%20the%20last%2024%20hours">Application crash count in the last 24 hours</a></li>
                        <li><a href="/app/windows/%40go?s=Application%20crash%20count%20in%20the%20last%207%20days">Application crash count in the last 7 days</a></li>
                        <li><a href="/app/windows/%40go?s=Application%20crash%20count%20in%20the%20last%2030%20days">Application crash count in the last 30 days</a></li>
                        <li><a href="/app/windows/%40go?s=List%20of%20shutdowns%20for%20last%2030%20days">List of shutdowns for last 30 days</a></li>
                        <li><a href="/app/windows/%40go?s=List%20of%20unexpected%20service%20terminations%20for%20the%20last%2030%20days">List of unexpected service terminations for the last 30 days</a></li>
                        <li><a href="/app/windows/%40go?s=List%20of%20failed%20service%20starts%20for%20the%20last%2030%20days">List of failed service starts for the last 30 days</a></li>
                    </ul>
                </div>
        ]]>
        </param>
    </module>

</view>
