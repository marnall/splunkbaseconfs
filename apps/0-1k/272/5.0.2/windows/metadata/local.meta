[tags]
export = system

[props]
export = system

[transforms]
export = system

[lookups]
export = system

### EVENT TYPES

[eventtypes]
access = read : [ * ], write : [ admin ]
export = system

### SAVED SEARCHES

[savedsearches]
access = read : [ * ], write : [ admin ]

### COMMANDS

[commands/trans]
access = read : [ * ], write : [admin]

### SEARCH SCRIPTS

[searchscripts]
access = read : [ * ], write : [ admin ]
export = system

### VIEWS

[views/setup]
access = read : [ admin ], write : [ admin ]
export = none

### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system
