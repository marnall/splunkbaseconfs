<view isVisible="false" stylesheet="custom.css">
  <label>Extensions</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="URLLoader" layoutPanel="viewHeader">
    <param name="keepURLUpdated">True</param>

    <pattern name="display_saved_report_name" />

    <module name="HTML" layoutPanel="viewHeader">
      <param name="html"><![CDATA[
      <h1 class="doNotPrint">Extensions</h1>
      ]]></param>
    </module>

    <module name="CustomBehavior">
      <param name="customBehavior">tour_extensionsPage</param>
    </module>

    <module name="Search" layoutPanel="mainSearchControls">
      <param name="search">| inputlookup groups | search NOT group="PLACEHOLDER GROUP" | fillnull subgroup value="EXPLICIT_NULL" | stats count by group subgroup | sort 0 group</param>

      <module name="TimePicker">
        <param name="default">Last 60 minutes</param>

        <module name="CheckboxPulldown">
          <param name="name">group</param>
          <param name="label">group</param>
          <param name="valueField">$name$</param>
          <param name="selectAllOptimization">omit</param>
          <param name="postProcess">stats count by group | eval lower=lower(group) | sort + lower</param>
          <param name="template">(callingPartyGroup="$value$" OR originalCalledPartyGroup="$value$" OR finalCalledPartyGroup="$value$")</param>
          <param name="nullTemplate">(NOT callingPartyGroup=* NOT originalCalledPartyGroup=* NOT finalCalledPartyGroup=* )</param>
          <param name="staticOptions">
            <list>
              <param name="value"></param>
              <param name="label">no group</param>
              <param name="selected">True</param>
            </list>
          </param>

          <module name="ArrayValueSetter">
            <param name="name">genericGroupTerms</param>
            <param name="array">$group.rawValue$</param>
            <param name="template">group="$value$"</param>
            <param name="nullTemplate">NOT group=*</param>
            <param name="separator">+OR+</param>
            <param name="outerTemplate">( $value$ )</param>

            <module name="CheckboxPulldown">
              <param name="name">subgroup</param>
              <param name="label">subgroup</param>
              <param name="valueField">$name$</param>
              <param name="selectAllOptimization">omit</param>
              <param name="postProcess">search subgroup!="" subgroup!="EXPLICIT_NULL" $genericGroupTerms$ | stats count by subgroup  | eval lower=lower(subgroup) | sort + lower</param>
              <param name="template">(callingPartySubgroup="$value$" OR originalCalledPartySubgroup="$value$" OR finalCalledPartySubgroup="$value$")</param>
              <param name="nullTemplate">(NOT callingPartySubgroup=* NOT originalCalledPartySubgroup=* NOT finalCalledPartySubgroup=* )</param>
              <param name="staticOptions">
                <list>
                  <param name="value"></param>
                  <param name="label">no subgroup</param>
                  <param name="selected">True</param>
                </list>
              </param>

              <module name="ArrayValueSetter">
                <param name="name">genericSubgroupTerms</param>
                <param name="array">$subgroup.rawValue$</param>
                <param name="template">subgroup="$value$"</param>
                <param name="nullTemplate">NOT subgroup=*</param>
                <param name="separator">+OR+</param>
                <param name="outerTemplate">( $value$ )</param>

                <module name="TextField">
                  <param name="name">name</param>
                  <param name="label">name</param>
                  <param name="template">(callingPartyName="$value$" OR originalCalledPartyName="$value$" OR finalCalledPartyName="$value$")</param>
                  <param name="width">150px</param>

                  <module name="TextField">
                    <param name="name">number</param>
                    <param name="label">number</param>
                    <param name="width">150px</param>

                    <module name="TextField">
                      <param name="name">huntPilotDN</param>
                      <param name="label">hunt pilot</param>
                      <param name="width">150px</param>
                      <param name="template">$name$="$value$"</param>

                      <module name="TextField">
                        <param name="name">searchterms</param>
                        <param name="label">search filters</param>
                        <param name="width">334px</param>

                        <pattern name="cluster_controls">

                          <module name="Search">
                            <param name="search">| inputlookup cidr | stats count by site_name | sort + site_name</param>

                            <module name="CheckboxPulldown">
                              <param name="name">sites</param>
                              <param name="label">sites</param>
                              <param name="valueField">site_name</param>
                              <param name="selectAllOptimization">omit</param>
                              <param name="template">(origSite="$value$" OR destSite="$value$")</param>
                              <param name="nullTemplate">(NOT origSite=* OR NOT destSite=*)</param>
                              <param name="outerTemplate">( $value$ )</param>
                              <param name="staticOptions">
                                <list>
                                  <param name="value"/>
                                  <param name="label">no site extracted</param>
                                  <param name="selected">True</param>
                                </list>
                              </param>

                              <module name="CheckboxPulldown">
                                <param name="name">modifiers</param>
                                <param name="label">options</param>
                                <param name="selectedByDefault">False</param>
                                <param name="sticky">True</param>
                                <param name="staticOptions">
                                  <list>
                                    <param name="value">numbersWithZeroCalls</param>
                                    <param name="label">include numbers with zero calls</param>
                                  </list>
                                  <list>
                                    <param name="value">callsWithZeroDuration</param>
                                    <param name="label">count calls with zero duration</param>
                                  </list>
                                </param>

                                <module name="Button">
                                  <param name="allowSoftSubmit">True</param>

                                  <module name="CustomBehavior">
                                    <param name="customBehavior">createPhoneNumberSearchTerms</param>

                                    <module name="CustomBehavior">
                                      <param name="customBehavior">getKeysForModifiers</param>

                                      <module name="ValueSetter">
                                        <param name="name">genericNameTerm</param>
                                        <param name="requiredKeys">name.rawValue</param>
                                        <param name="value">name="$name.rawValue$"</param>

                                        <module name="ArrayValueSetter">
                                          <param name="name">genericSiteTerms</param>
                                          <param name="array">$sites.rawValue$</param>
                                          <param name="template">site="$value$"</param>
                                          <param name="nullTemplate">site="unknown"</param>
                                          <param name="separator">+OR+</param>

                                          <module name="Search">
                                            <param name="search"><![CDATA[
| rest /servicesNS/-/cisco_cdr/admin/eventtypes splunk_server=local
| search title="leg_type_*" disabled=0
| eval leg_type=replace(title,"leg_type_", "")
| stats values(leg_type) as leg_types

                                            ]]></param>

                                            <!--
                                              We get this via RVS instead of with a subsearch.
                                              The reason is so that we can have the $leg_types$
                                              token to later ALSO do a fillnull.
                                              If we don't do that fillnull,  then if no matching
                                              huntPilots have ANY calls that match that particular
                                              leg type, then there is never a <leg_type>_call_id
                                              for it, and then the field doesn't exist at all in the
                                              output and the column becomes undisplayable.
                                              Conversely with the fillnull there's a 0
                                            -->
                                            <module name="ResultsValueSetter">
                                              <param name="fields">leg_types</param>


                                              <module name="Search" layoutPanel="resultsHeaderPanel">
                                                <param name="search"><![CDATA[
| makeresults count=1
| eval field=split("number,name,group,loginUserID,partition,calls,site,failed,pct_failed,outside_parties,transferred_away,incoming,outgoing,internal,total_duration,incoming_duration,outgoing_duration,internal_duration,total_duration_min,incoming_duration_min,outgoing_duration_min,internal_duration_min,business_hours,off_hours,business_hours_duration,off_hours_duration,audio,video,audio_duration,video_duration,$leg_types$",",")
| mvexpand field
                                                ]]></param>







                                                <module name="Fields">
                                                  <param name="fields">number,name,group,calls,site,failed,pct_failed,outside_parties,transferred_away,incoming,outgoing,internal,total_duration,incoming_duration,outgoing_duration,internal_duration</param>
                                                  <param name="float">right</param>

                                                  <module name="Search" layoutPanel="resultsHeaderPanel">
                                                    <param name="search"><![CDATA[
`custom_index` sourcetype=cucm_cdr cause_description!="Unallocated (unassigned) number" $clusterGroup$ $clusterId$ $group$ $subgroup$ $name$ $internalPartyNumberTerms$ $huntPilotSubsearch$ $excludeCallsWithZeroDuration$
| `customizable_sites_extractions` | `get_sites` | search * $sites$
| `get_custom_type_fields`
| fillnull duration value="0"
| eval {type}_duration=duration
| eval {type}_call_id=call_id
| eval {bh_type}_duration=duration
| eval {bh_type}_call_id=call_id
| eval {callMediaType}_duration=duration
| eval {callMediaType}_call_id=call_id
| eval failure_type=if(call_failed==1,"failed","completed")
| eval {failure_type}_call_id=call_id
| eval {leg_type}_call_id=call_id
| eval transfer_call_id=if(cause_description=="Call split",call_id,null())
| `get_external_party_numbers`
| `calculate_all_internal_parties`
$includeNumbersWithZeroCalls$
| eval number=mvfilter(isnotnull(number) AND number!="")
| stats dc(call_id) as calls dc(*_call_id) as * values(loginUserID) as loginUserID values(huntPilotDN) as huntPilotDN sum(incoming_duration) as incoming_duration sum(outgoing_duration) as outgoing_duration sum(internal_duration) as internal_duration sum(duration) as total_duration dc(external_party_number) as outside_parties dc(transfer_call_id) as transferred_away sum(off_hours_duration) as off_hours_duration sum(business_hours_duration) as business_hours_duration dc(business_hours_call_id) as business_hours dc(off_hours_call_id) as off_hours dc(failed_call_id) as failed sum(audio_duration) as audio_duration sum(video_duration) as video_duration dc(audio_call_id) as audio dc(video_call_id) as video values(partyName) as name values(site) as site dc(site) as site_count values(partition) as partition by number
| fillnull site partition loginUserID value="(none)"
| eval site=if(site_count>4,"(" + site_count + " sites)", site)
| fields - site_count
| lookup groups number as number output name group subgroup
| fillnull calls incoming outgoing internal failed $leg_types$
| eval pct_failed = if(failed==0,"0",round((100 * failed / calls), 2) )
| search * $genericNumberTerms$ $genericGroupTerms$ $genericSubgroupTerms$ $genericNameTerm$ $genericSiteTerms$ $huntPilotDN$ $searchterms$
| eval pct_failed = pct_failed . "%"
| `get_durations_for_internal_parties`
| `replace_zeros_with_nulls`



                                                    ]]></param>


                                                    <pattern name="save_create_buttons" />

                                                    <module name="SearchControls" layoutPanel="resultsHeaderPanel">
                                                      <param name="sections">jobControls info export print</param>
                                                      <param name="float">right</param>
                                                    </module>

                                                    <module name="HTML" layoutPanel="resultsHeaderPanel">
                                                      <param name="html"><![CDATA[

                                                      <h2>$qualifier$ $results.count$ extensions found $search.timeRange.label$ </h2>

                                                      ]]></param>
                                                      <param name="customBehavior">qualifyNumberOfResults</param>
                                                    </module>

                                                    <module name="Pulldown" layoutPanel="resultsAreaLeft">
                                                      <param name="name">results.count</param>
                                                      <param name="label">results per page</param>
                                                      <param name="float">right</param>
                                                      <param name="staticOptions">
                                                        <list><param name="value">10</param></list>
                                                        <list><param name="value">20</param><param name="selected">True</param></list>
                                                        <list><param name="value">50</param></list>
                                                        <list><param name="value">100</param></list>
                                                        <list><param name="value">200</param></list>
                                                      </param>

                                                      <module name="ProgressIndicator" layoutPanel="resultsAreaLeft"></module>

                                                      <module name="PostProcess">
                                                        <param name="search">fields $results.fields$</param>

                                                        <module name="Pager">

                                                          <module name="Table">

                                                            <module name="Layer">
                                                              <param name="cssClass">menu</param>

                                                              <module name="Link">
                                                                <param name="cssClass">menuItem</param>
                                                                <param name="label">investigate calls to/from this extension</param>

                                                                <module name="Redirector">
                                                                  <param name="url">calls</param>
                                                                  <param name="mergeDrilldownKeys">False</param>
                                                                  <param name="arg.number">$row.fields.number$</param>
                                                                  <param name="arg.clusterId">$clusterId.rawValue$</param>
                                                                  <param name="arg.clusterGroup">$clusterGroup.rawValue$</param>
                                                                  <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                                  <param name="arg.latest">$search.timeRange.latest$</param>
                                                                  <param name="arg.searchterms">$excludeCallsWithZeroDuration$ $sites$ </param>
                                                                </module>
                                                              </module>

                                                              <module name="Link">
                                                                <param name="cssClass">menuItem</param>
                                                                <param name="label">view extension details</param>

                                                                <module name="Redirector">
                                                                  <param name="url">extension_detail</param>
                                                                  <param name="mergeDrilldownKeys">False</param>

                                                                  <param name="arg.number">$row.fields.number$</param>
                                                                  <param name="arg.huntPilotDN">$huntPilotDN.rawValue$</param>
                                                                  <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                                  <param name="arg.latest">$search.timeRange.latest$</param>

                                                                  <param name="arg.bc_earliest">$search.timeRange.earliest$</param>
                                                                  <param name="arg.bc_latest">$search.timeRange.latest$</param>
                                                                  <param name="arg.bc_group">$group.rawValue$</param>
                                                                  <param name="arg.bc_subgroup">$subgroup.rawValue$</param>
                                                                  <param name="arg.bc_name">$name.rawValue$</param>
                                                                  <param name="arg.bc_number">$number.rawValue$</param>
                                                                  <param name="arg.bc_huntPilotDN">$huntPilotDN.rawValue$</param>
                                                                  <param name="arg.bc_searchterms">$searchterms.rawValue$</param>
                                                                  <param name="arg.bc_sites">$sites.rawValue$</param>
                                                                  <param name="arg.bc_clusterId">$clusterId.rawValue$</param>
                                                                  <param name="arg.bc_clusterGroup">$clusterGroup.rawValue$</param>


                                                                </module>
                                                              </module>
                                                            </module>
                                                          </module>

                                                          <pattern name="see_raw_search_syntax" />

                                                        </module>
                                                      </module>
                                                    </module>
                                                  </module>
                                                </module>
                                              </module>
                                            </module>
                                          </module>
                                        </module>
                                      </module>
                                    </module>
                                  </module>
                                </module>
                              </module>
                            </module>
                          </module>
                        </pattern>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</view>