<view isVisible="false" template="dashboard.html" stylesheet="update_lookup.css,custom.css">
  <label>Update License</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="HTML" layoutPanel="viewHeader">
    <param name="html"><![CDATA[
    <h1><a href="home">Home</a> &gt; Admin &gt; Update License</h1>
    ]]></param>
  </module>

  <module name="URLLoader" layoutPanel="mainSearchControls">
    <param name="keepURLUpdated">False</param>

    <module name="HTML" layoutPanel="panel_row1_col1">
      <param name="html"><![CDATA[
        <p>
          If you have received a new trial license or production license from Sideview (and your Splunk account is more or less that of an admin) then you can enter your license here.
        </p>
      ]]></param>
    </module>

    <module name="TextField" layoutPanel="panel_row1_col1">
      <param name="name">license</param>
      <param name="label">license</param>
      <param name="cssClass">licenseString</param>
      <param name="width">80%</param>

      <module name="Button">
        <param name="allowSoftSubmit">True</param>
        <param name="allowAutoSubmit">False</param>
        <param name="label">Update License</param>

        <module name="ShowHide">
          <param name="hide">.licenseMessage</param>
        </module>

        <module name="REST">
          <param name="name">updateLicenseRest</param>
          <param name="uri">/splunkd/__raw/cisco_cdr_license</param>
          <param name="arg.license">$license$</param>

          <module name="ShowHide">
            <param name="hide">#currentLicenseTable</param>
          </module>

          <module name="Switcher">
            <param name="selectedGroup">$updateLicenseRest.state$</param>

            <module name="NullModule" group="success">
              <module name="HTML">
                <param name="html"><![CDATA[
                  <div class="licenseMessage">
                    Your license was successfully updated.
                  </div>
                ]]></param>
              </module>
              <module name="Gate">
                <param name="to">loadCurrentLicenseInfo</param>
              </module>

            </module>

            <module name="NullModule" group="failure">
              <module name="HTML">
                <param name="html"><![CDATA[
                  <div class="licenseMessage">
                    ERROR: We were not able to update your license.
                    <br>
                    <br>
                    $updateLicenseRest.errorMessage$
                  </div>
                ]]></param>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>

  <module name="NullModule" layoutPanel="panel_row2_col1">
    <module name="Gate">
      <param name="id">loadCurrentLicenseInfo</param>

      <pattern name="display_license" />
    </module>
  </module>
</view>
