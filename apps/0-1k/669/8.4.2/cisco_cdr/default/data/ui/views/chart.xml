<view isVisible="false" css="custom.css,calls.css" customJS="lib/custom_behaviors/chart.js">
  <label>Chart</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="URLLoader" layoutPanel="viewHeader">
    <param name="keepURLUpdated">True</param>

    <module name="HTML">
      <param name="html"><![CDATA[
      <h1 class="doNotPrint">Chart</h1>
      ]]></param>
    </module>

    <pattern name="call_filter_controls">

      <module name="TextField">
        <param name="name">advancedSearchLanguage</param>
        <param name="label">advanced</param>
        <param name="template">| $value$ </param>
        <param name="width">399px</param>

        <module name="TextField">
          <param name="name">searchterms</param>
          <param name="label">search filters</param>
          <param name="width">600px</param>

          <module name="Button">
            <param name="allowSoftSubmit">True</param>

            <module name="CustomBehavior">
              <param name="customBehavior">createPhoneNumberSearchTerms</param>

              <module name="Search">
                <param name="search">
`get_field_list("$data_type$", "$advancedSearchLanguage$")`
                </param>
                <param name="preview">False</param>

                <module name="HTML">
                  <param name="html"><![CDATA[
                    <br clear="both" />
                  ]]></param>
                </module>

                <module name="CustomBehavior">
                  <param name="requiresDispatch">True</param>
                  <param name="customBehavior">customLogicWhenZeroResultsAreFound</param>

                  <module name="Pulldown" layoutPanel="mainSearchControls">
                    <param name="name">stat</param>
                    <param name="label">chart the</param>
                    <param name="clear">left</param>
                    <param name="staticOptions">
                      <list>
                        <param name="label">distinct count of</param>
                        <param name="value">dc</param>
                      </list>
                      <list>
                        <param name="label">average</param>
                        <param name="value">avg</param>
                      </list>
                      <list>
                        <param name="label">max</param>
                        <param name="value">max</param>
                      </list>
                      <list>
                        <param name="label">min</param>
                        <param name="value">min</param>
                      </list>
                      <list>
                        <param name="label">sum</param>
                        <param name="value">sum</param>
                      </list>
                      <list>
                        <param name="label">95th percentile</param>
                        <param name="value">perc95</param>
                      </list>
                      <list>
                        <param name="label">5th percentile</param>
                        <param name="value">perc5</param>
                      </list>
                    </param>

                    <module name="Pulldown">
                      <param name="name">yField</param>
                      <param name="valueField">field</param>
                      <param name="customBehavior">yFieldPulldown</param>
                      <param name="postProcess">`y_axis_fields`</param>
                      <param name="staticOptions">
                        <list>
                          <param name="value">call_id</param>
                          <param name="label">calls</param>
                        </list>
                        <list>
                          <param name="value">duration</param>
                          <param name="label">duration</param>
                        </list>
                        <list>
                          <param name="value"></param>
                          <param name="label">--------------</param>
                        </list>
                      </param>

                      <module name="Pulldown">
                        <param name="name">xField</param>
                        <param name="postProcess">search field!="dateTime*" | eval label="over " + field</param>
                        <param name="valueField">field</param>
                        <param name="labelField">label</param>
                        <param name="customBehavior">xFieldPulldown</param>
                        <param name="staticOptions">
                          <list>
                            <param name="label">(over nothing)</param>
                            <param name="value"></param>
                          </list>
                          <list>
                            <param name="label">over time</param>
                            <param name="value">_time</param>
                            <param name="selected">true</param>
                          </list>
                        </param>

                        <module name="Pulldown">
                          <param name="name">xFieldBins</param>
                          <param name="label"># of bins</param>
                          <param name="customBehavior">xFieldBinsPulldown</param>
                          <param name="staticOptions">
                            <list><param name="value"></param><param name="label">none</param></list>
                            <list><param name="value">5</param></list>
                            <list><param name="value">10</param></list>
                            <list><param name="value">15</param></list>
                            <list><param name="value">20</param></list>
                            <list><param name="value">30</param></list>
                            <list><param name="value">50</param></list>
                            <list><param name="value">100</param></list>
                            <list><param name="value">250</param></list>
                            <list><param name="value">500</param></list>
                            <list><param name="value">800</param></list>
                          </param>

                          <module name="Pulldown">
                            <param name="name">zField</param>
                            <param name="label">split by</param>
                            <param name="valueField">field</param>
                            <param name="customBehavior">zFieldPulldown</param>
                            <param name="staticOptions">
                              <list>
                                <param name="label">(none)</param>
                                <param name="value"></param>
                              </list>
                            </param>

                            <module name="Pulldown">
                              <param name="name">zFieldBins</param>
                              <param name="label"># of bins</param>
                              <param name="customBehavior">zFieldBinsPulldown</param>
                              <param name="staticOptions">
                                <list><param name="value"></param><param name="label">none</param></list>
                                <list><param name="value">5</param></list>
                                <list><param name="value">10</param></list>
                                <list><param name="value">15</param></list>
                                <list><param name="value">20</param></list>
                                <list><param name="value">30</param></list>
                                <list><param name="value">50</param></list>
                                <list><param name="value">75</param></list>
                                <list><param name="value">100</param></list>
                              </param>

                              <module name="Search">
                                <param name="search">
| stats count
| fields - count
| eval field1="$stat$($yField$) (descending)"
| eval field2="$stat$($yField$) (ascending)"
| eval field3="$xField$  (ascending)"
| eval field4="$xField$  (descending)"
| transpose
| rename "row 1" as sortByLabel
| eval sortByValue=replace(replace(sortByLabel,"\(ascending\)",""),"\(descending\)","desc")
                                </param>

                                <module name="Pulldown">
                                  <param name="name">sortBy</param>
                                  <param name="label">sort by</param>
                                  <param name="template"> | sort 0 $value$</param>
                                  <param name="valueField">sortByValue</param>
                                  <param name="labelField">sortByLabel</param>
                                  <param name="staticOptions"></param>
                                  <param name="customBehavior">sortByPulldown</param>

                                  <module name="Button">
                                    <param name="allowSoftSubmit">True</param>

                                    <module name="CustomBehavior">
                                      <param name="customBehavior">buildMainReportingTokens</param>

                                      <module name="Report">
                                        <param name="name">report</param>
                                        <param name="stat">$stat$</param>
                                        <param name="xField">$xField$</param>
                                        <param name="yField">$yField$</param>
                                        <param name="zField">$zField$</param>
                                        <param name="xFieldBins">$xFieldBins$</param>
                                        <param name="zFieldBins">$zFieldBins$</param>
                                        <param name="customBehavior">concurrencyPatch</param>

                                        <module name="Search">
                                          <param name="search">$baseEventsSearch$$requiredExtractions$$advancedSearchLanguage$$statsCommand$$postStatsSearch$$postStatsTransform$| $report$ $sortBy$ $disableSearchOptimization$</param>

                                          <module name="ValueSetter" layoutPanel="resultsAreaLeft">
                                            <param name="name">zFieldLabel</param>
                                            <param name="value">by $zField$</param>
                                            <param name="requiredKeys">zField</param>

                                            <module name="Link">
                                              <param name="label">&#187; see calls</param>
                                              <param name="float">right</param>

                                              <module name="Redirector">
                                                <param name="url">calls</param>
                                                <param name="generalSearchTermField">searchterms</param>
                                                <param name="arg.data_type">$data_type.rawValue$</param>
                                                <param name="arg.type">$type.rawValue$</param>
                                                <param name="arg.number">$number.rawValue$</param>
                                                <param name="arg.numberType">$numberType.rawValue$</param>
                                                <param name="arg.searchterms">$searchterms.rawValue$</param>
                                                <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                <param name="arg.latest">$search.timeRange.latest$</param>

                                              </module>
                                            </module>

                                            <pattern name="see_raw_search_syntax" />

                                            <module name="HTML">
                                              <param name="html"><![CDATA[
                                                <h3>$stat.label$ $yField.label$ $xField.label$ $zFieldLabel$ $search.timeRange.label$ ($results.count$ rows returned.  $results.scanCount$ events scanned.)</h3>
                                              ]]></param>
                                            </module>
                                          </module>

                                          <module name="ProgressIndicator" layoutPanel="resultsAreaLeft"></module>

                                          <module name="Tabs" layoutPanel="graphArea">
                                            <param name="name">selectedTab</param>
                                            <param name="staticTabs">
                                              <list>
                                                <param name="value">Chart</param>
                                              </list>
                                              <list>
                                                <param name="value">Table</param>
                                              </list>
                                            </param>

                                            <!-- looks a little crazy.  you might think - why have these all up here, under
                                            the Tabs module but UPSTREAM from the Switcher, and then have to show/hide them
                                            all with a customBehavior.
                                            Why not just put them under the Switcher in the "chart" section?
                                            Well because the save/create stuff has to live above the Switcher.
                                            yet the save/create stuff needs to preserve chart settings.
                                            -->
                                            <module name="Pulldown" layoutPanel="resultsAreaLeft">
                                              <param name="name">charting.chart</param>
                                              <param name="label">Chart type</param>
                                              <param name="clear">left</param>
                                              <param name="staticOptions">
                                                <list>
                                                  <param name="value">column</param>
                                                </list>
                                                <list>
                                                  <param name="value">line</param>
                                                </list>
                                                <list>
                                                  <param name="value">area</param>
                                                </list>
                                                <list>
                                                  <param name="value">bar</param>
                                                </list>
                                              </param>
                                              <param name="customBehavior">chartTypePulldown</param>

                                              <module name="Pulldown">
                                                <param name="name">charting.chart.stackMode</param>
                                                <param name="label">Stack mode</param>
                                                <param name="staticOptions">
                                                  <list>
                                                    <param name="value">stacked</param>
                                                    <param name="label">stacked</param>
                                                  </list>
                                                  <list>
                                                    <param name="value">default</param>
                                                    <param name="label">not stacked</param>
                                                  </list>
                                                </param>
                                                <param name="customBehavior">stackModePulldown</param>

                                                <module name="Pulldown">
                                                  <param name="name">charting.chart.nullValueMode</param>
                                                  <param name="label">Null Values</param>
                                                  <param name="staticOptions">
                                                    <list>
                                                      <param name="value">zero</param>
                                                      <param name="label">Treat as zero</param>
                                                    </list>
                                                    <list>
                                                      <param name="value">gaps</param>
                                                      <param name="label">Omit</param>
                                                    </list>
                                                    <list>
                                                      <param name="value">connect</param>
                                                      <param name="label">Connect</param>
                                                    </list>
                                                  </param>
                                                  <param name="customBehavior">nullValueModePulldown</param>

                                                  <module name="Pulldown">
                                                    <param name="name">charting.chart.showMarkers</param>
                                                    <param name="label">Display markers</param>
                                                    <param name="staticOptions">
                                                      <list>
                                                        <param name="value">true</param>
                                                        <param name="label">Yes</param>
                                                      </list>
                                                      <list>
                                                        <param name="value">false</param>
                                                        <param name="label">No</param>
                                                      </list>
                                                    </param>
                                                    <param name="customBehavior">showMarkersPulldown</param>

                                                    <module name="NullModule" layoutPanel="graphArea">

                                                      <pattern name="save_create_buttons" />

                                                    </module>
                                                    <module name="SearchControls" layoutPanel="graphArea">
                                                      <param name="sections">jobControls info export print</param>
                                                      <param name="float">right</param>
                                                    </module>

                                                    <module name="ValueSetter">
                                                      <param name="arg.quality.fieldOrder">poor fair acceptable good</param>

                                                      <module name="Switcher">
                                                        <param name="selectedGroup">$selectedTab$</param>

                                                        <module name="Chart" group="Chart">
                                                          <param name="height">400px</param>

                                                          <module name="Layer">
                                                            <param name="cssClass">menu</param>

                                                            <module name="Link">
                                                              <param name="cssClass">menuItem</param>
                                                              <param name="label">chart these calls over time</param>

                                                              <module name="Redirector">
                                                                <param name="url">calls</param>
                                                                <param name="generalSearchTermField">searchterms</param>

                                                                <param name="arg.data_type">$data_type.rawValue$</param>
                                                                <param name="arg.mode">chart</param>
                                                                <param name="arg.type">$type.rawValue$</param>
                                                                <param name="arg.number">$number.rawValue$</param>
                                                                <param name="arg.numberType">$numberType.rawValue$</param>
                                                                <param name="arg.searchterms">$searchterms.rawValue$</param>
                                                                <param name="arg.advancedSearchLanguage">$advancedSearchLanguage.rawValue$</param>

                                                                <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                                <param name="arg.latest">$search.timeRange.latest$</param>
                                                              </module>
                                                            </module>

                                                            <module name="Link">
                                                              <param name="cssClass">menuItem</param>
                                                              <param name="label">investigate these calls</param>

                                                              <module name="Redirector">
                                                                <param name="url">calls</param>
                                                                <param name="generalSearchTermField">searchterms</param>

                                                                <param name="arg.data_type">$data_type.rawValue$</param>
                                                                <param name="arg.type">$type.rawValue$</param>
                                                                <param name="arg.number">$number.rawValue$</param>
                                                                <param name="arg.numberType">$numberType.rawValue$</param>
                                                                <param name="arg.searchterms">$searchterms.rawValue$</param>
                                                                <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                                <param name="arg.latest">$search.timeRange.latest$</param>

                                                              </module>
                                                            </module>
                                                          </module>
                                                        </module>

                                                        <module name="Pulldown" group="Table" layoutPanel="resultsAreaLeft">
                                                          <param name="name">results.count</param>
                                                          <param name="label">results per page</param>
                                                          <param name="float">right</param>
                                                          <param name="clear">right</param>
                                                          <param name="staticOptions">
                                                            <list><param name="value">10</param></list>
                                                            <list><param name="value">20</param></list>
                                                            <list><param name="value">50</param></list>
                                                            <list><param name="value">100</param></list>
                                                          </param>

                                                          <module name="Pager">

                                                            <module name="Table">
                                                              <param name="drilldown">cell</param>
                                                              <param name="customBehavior">callsTable</param>


                                                              <module name="Layer">
                                                                <param name="cssClass">menu</param>

                                                                <module name="Link">
                                                                  <param name="cssClass">menuItem</param>
                                                                  <param name="label">chart these calls over time</param>

                                                                  <module name="Redirector">
                                                                    <param name="url">calls</param>
                                                                    <param name="generalSearchTermField">searchterms</param>

                                                                    <param name="arg.data_type">$data_type.rawValue$</param>
                                                                    <param name="arg.mode">chart</param>
                                                                    <param name="arg.type">$type.rawValue$</param>
                                                                    <param name="arg.number">$number.rawValue$</param>
                                                                    <param name="arg.numberType">$numberType.rawValue$</param>
                                                                    <param name="arg.searchterms">$searchterms.rawValue$</param>
                                                                    <param name="arg.advancedSearchLanguage">$advancedSearchLanguage.rawValue$</param>

                                                                    <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                                    <param name="arg.latest">$search.timeRange.latest$</param>
                                                                  </module>
                                                                </module>

                                                                <module name="Link">
                                                                  <param name="cssClass">menuItem</param>
                                                                  <param name="label">investigate these calls</param>

                                                                  <module name="Redirector">
                                                                    <param name="url">calls</param>
                                                                    <param name="generalSearchTermField">searchterms</param>

                                                                    <param name="arg.data_type">$data_type.rawValue$</param>
                                                                    <param name="arg.type">$type.rawValue$</param>
                                                                    <param name="arg.number">$number.rawValue$</param>
                                                                    <param name="arg.numberType">$numberType.rawValue$</param>
                                                                    <param name="arg.searchterms">$searchterms.rawValue$</param>
                                                                    <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                                    <param name="arg.latest">$search.timeRange.latest$</param>

                                                                  </module>
                                                                </module>
                                                              </module>
                                                            </module>



                                                          </module>
                                                        </module>
                                                      </module>
                                                    </module>
                                                  </module>
                                                </module>
                                              </module>

                                            </module>
                                          </module>
                                        </module>
                                      </module>
                                    </module>
                                  </module>
                                </module>
                              </module>
                            </module>
                          </module>
                        </module>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
              <module name="HTML" layoutPanel="resultsAreaLeft">
                <param name="html"><![CDATA[
                  <p class="emptyResults zeroResultsFoundNoFilters">
                    No calls were found $search.timeRange.label$.
                  </p>
                  <p class="emptyResults zeroResultsFoundWithFilters">
                    No calls were found $search.timeRange.label$ that match the filtering criteria above.
                  </p>
                ]]></param>
              </module>
            </module>
          </module>
        </module>
      </module>
    </pattern>
  </module>
</view>