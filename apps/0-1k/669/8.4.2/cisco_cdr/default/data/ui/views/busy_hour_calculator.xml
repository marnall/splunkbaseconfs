<view isVisible="false" template="dashboard.html" stylesheet="custom.css">
  <label>Busy hour calculator</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="HTML" layoutPanel="viewHeader">
    <param name="html"><![CDATA[
      <h1><a href="home">Home</a> &gt; Busy Hour Calculator</h1>
      ]]>
    </param>
  </module>

  <module name="URLLoader" layoutPanel="mainSearchControls">
    <param name="keepURLUpdated">True</param>

    <module name="TimePicker">
      <param name="default">Last 24 hours</param>

      <module name="CheckboxPulldown">
        <param name="name">type</param>
        <param name="label">call types</param>
        <param name="template">type="$value$"</param>
        <param name="selectAllOptimization">omit</param>
        <param name="staticOptions">
          <list>
            <param name="value">incoming</param>
            <param name="selected">True</param>
          </list>
          <list>
            <param name="value">outgoing</param>
            <param name="selected">True</param>
          </list>
          <list>
            <param name="value">internal</param>
          </list>
          <list>
            <param name="value">tandem</param>
          </list>
        </param>

        <module name="CustomBehavior">
          <param name="customBehavior">createRequiredExtractions</param>

          <module name="Search">
            <param name="search"><![CDATA[
| `get_gateways_from_tstats(dest)`
| append [
  | `get_gateways_from_tstats(orig)`]
| stats count by gateway
| sort 0 + gateway
              ]]></param>

            <module name="CheckboxPulldown">
              <param name="name">gateway</param>
              <param name="label">gateway</param>
              <param name="template">orig_gateway="$value$" OR dest_gateway="$value$"</param>
              <param name="outerTemplate">($value$)</param>
              <param name="valueField">$name$</param>
              <param name="labelField">label</param>
              <param name="selectAllOptimization">omit</param>
              <param name="customBehavior">hideAndReturnNullIfInternalPresent</param>

              <module name="Tabs">
                <param name="name">selectedTab</param>
                <param name="staticTabs">
                  <list>
                    <param name="value">Overall</param>
                  </list>
                  <list>
                    <param name="value">Per Gateway</param>
                  </list>
                </param>

                <module name="Switcher" layoutPanel="panel_row1_col1">
                  <param name="selectedGroup">$selectedTab$</param>

                  <module name="Search" group="Overall">
                    <param name="search">
`custom_index` sourcetype=cucm_cdr $type$ duration>0 $gateway$
| stats max(duration) as duration by call_id _time
| eventstats avg(duration) as globalAvgDuration
| eval startTime=_time
| eval endTime=startTime+duration
| eval times=mvrange(startTime,endTime,3600)
| mvexpand times
| rename times as _time
| eval date_and_hour = strftime(_time,"%I%p %B %d %Y")
| stats dc(call_id) as calls last(globalAvgDuration) as globalAvgDuration by date_and_hour
| sort - calls
| head 1
| rename calls as busy_hour_count date_and_hour as busy_hour
| eval erlangs=round(busy_hour_count * (globalAvgDuration/3600),2)</param>
                    <module name="ProgressIndicator" />

                    <module name="ResultsValueSetter">
                      <param name="fields">busy_hour busy_hour_count globalAvgDuration erlangs</param>

                      <module name="HTML">
                        <param name="html"><![CDATA[
                          $search.timeRange.label$ the busiest hour is <b>$busy_hour$</b><br>
                          <br>
                          The number of calls during that busy hour is <b>$busy_hour_count$</b><br>
                          <br>
                          The average duration over this period was <b>$globalAvgDuration$ seconds</b><br>
                          <br>
                          And this gives a Busy Hour Traffic value of <b>$erlangs$ Erlangs</b>
                          ]]>
                        </param>
                      </module>
                    </module>

                  </module>

                  <module name="Search" group="Per Gateway">
                    <param name="search">
`custom_index` sourcetype=cucm_cdr $type$ duration>0 $gateway$
$required_extractions$
| stats max(duration) as duration by globalCallID_callId  globalCallID_callManagerId globalCallId_ClusterID _time gateway
| eventstats avg(duration) as avgDuration by gateway
| eval startTime=_time
| eval endTime=startTime+duration
| eval times=mvrange(startTime,endTime,3600)
| mvexpand times
| rename times as _time
| eval date_and_hour = strftime(_time,"%I%p %B %d %Y")
| `get_call_id`
| stats dc(call_id) as calls last(avgDuration) as avgDuration by date_and_hour gateway
| eval avgDuration=round(avgDuration,2)
| sort 0 - gateway calls
                    </param>

                    <module name="CustomBehavior">
                      <param name="customBehavior">displayMessageIfInternalPresent</param>
                    </module>
                    <module name="PostProcess">
                      <param name="search">dedup gateway | sort gateway</param>

                      <module name="Pager">
                        <module name="Multiplexer">
                          <param name="fields">gateway</param>

                          <module name="PostProcess">
                            <param name="search">search gateway="$gateway$"</param>

                            <module name="PostProcess">
                              <param name="search">$postProcess$
                              | head 1
                              | rename calls as busy_hour_count date_and_hour as busy_hour
                              | eval erlangs=round(busy_hour_count * (avgDuration/3600),2)
                              </param>

                              <module name="HTML">
                                <param name="html"><![CDATA[
                                  Gateway/Device <b>$gateway$</b> has busy hour of <b>$results[0].busy_hour$</b> with <b>$results[0].busy_hour_count$</b> calls.  <br>
                                  With average duration of <b>$results[0].avgDuration$ seconds</b> this gives a BHT of $results[0].erlangs$ erlangs.<br>

                                  <br>
                                  ]]>
                                </param>
                                <param name="cssClass">floatedLeft</param>
                              </module>
                            </module>
                            <module name="Pager">
                              <module name="Table" />
                            </module>
                          </module>
                        </module>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</view>
