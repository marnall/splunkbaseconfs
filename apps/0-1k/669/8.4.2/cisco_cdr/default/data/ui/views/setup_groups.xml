                                  <param name="allowSoftSubmit">False</param>
                                  <param name="allowAutoSubmit">False</param>
                                  <module name="CustomBehavior">
                                    <param name="customBehavior">addNewFilterToFilterBar</param>
                                  </module>
                                </module>
                              </module>
                            </module>
                          </module>
                        </module>
                      </module>
                    </module>

                    <module name="ValueSetter">
                      <param name="name">templatedFilters</param>
                      <param name="value">| search $filters$</param>
                      <param name="requiredKeys">filters</param>

                      <module name="Search">
                        <param name="search">| inputlookup $lookupName$ $templatedFilters$ | table $fieldOrder$</param>

                        <module name="CustomBehavior">
                          <param name="customBehavior">changeResultsOffset</param>

                          <module name="Pulldown">
                            <param name="name">results.count</param>
                            <param name="label">Results per page:</param>
                            <param name="float">right</param>
                            <param name="staticOptions">
                              <list><param name="value">10</param></list>
                              <list><param name="value">20</param></list>
                              <list><param name="value">50</param></list>
                              <list><param name="value">100</param></list>
                            </param>

                            <module name="HTML">
                              <param name="html"><![CDATA[
                                <br clear="all" /><h2 style="margin:0px;padding:0px;">$results.count$ rows found.</h2>
                              ]]></param>
                            </module>

                            <module name="Pager">
                              <module name="Table">
                                <param name="customBehavior">editableTable</param>
                              </module>
                              <module name="Pager" />
                            </module>
                          </module>
                        </module>
                      </module>
                    </module>
                  </module>

                  <module name="NullModule" group="add">
                    <module name="HTML">
                      <param name="html"><![CDATA[
                        <p>
                          Enter new extensions one at a time.  Be careful to only click the "Add" button once for each.
                        </p>
                      ]]></param>
                    </module>

                    <module name="Search">
                      <param name="search">
| makeresults
| fields - _time
| eval lookup_fields=split("$inputField$ $lookup_fields$"," ")
| eval output_fields=split("$inputField$ $output_fields$"," ")
| eval keys_and_labels=mvzip(lookup_fields,output_fields)
| fields keys_and_labels
| mvexpand keys_and_labels
| eval pair=split(keys_and_labels, ",")
| eval key=mvindex(pair,0)
| eval label=mvindex(pair,1)
| fields key label
                      </param>


                      <module name="Multiplexer">
                        <param name="fields">key,label</param>

                        <module name="HTML">
                          <param name="html"><![CDATA[
                            <div class="addNewRow">
                              <label>$label$</label>
                              <input type="text" name="$key$" onblur="Sideview.clearMessages()">
                            </div>
                          ]]></param>
                        </module>
                      </module>

                      <module name="HTML">
                        <param name="html"><![CDATA[
                        <br>
                        ]]></param>
                      </module>

                      <module name="Button">
                        <param name="allowSoftSubmit">False</param>
                        <param name="allowAutoSubmit">False</param>
                        <param name="label">Add</param>

                        <module name="Search">
                          <param name="search">replaced at runtime by customBehavior</param>
                          <param name="customBehavior">addNewRow</param>

                          <module name="CustomBehavior">
                            <param name="customBehavior">confirmNewRowAdded</param>
                            <param name="requiresDispatch">True</param>
                          </module>
                        </module>
                      </module>
                    </module>
                  </module>


                  <module name="Search" group="download">
                    <param name="search">| inputlookup $lookupName$ | table $fieldOrder$ *</param>

                    <module name="SearchControls">
                      <param name="sections">export</param>
                    </module>
                  </module>

                  <module name="HTML" group="reupload">
                    <param name="html"><![CDATA[

          <form id="lookupUpdater" method="POST" action="REPLACED_AT_RUNTIME" enctype="multipart/form-data" >
            <p>
              If you wish you can upload a fresh csv to replace the one loaded.
            </p>
            <p>
              Note that the easiest way to do this is to first use the "Download CSV" tab first to
              get the existing csv file, as that file will already have the right columns.
            </p>

            <label class="inputFileLabel">Local csv file:</label>

            <input type="file"   name="lookupFile" />
            <input type="hidden" name="lookupName" />
            <input type="hidden" name="currentView" />
            <!--
            Sideview OEM customers building custom views based on the
            Lookup Updater, or otherwise using the lookup controller,
            can pass the following variable to control the redirect
            after POST'ing to the controller.
            <input type="hidden" name="redirectOverride" value="/app/sideview_utils/framework_intro"/>
            -->


            <input type="hidden" name="splunk_form_key" value="FILLED BY JAVASCRIPT ONSUBMIT" />
            <br>
            <br>


            <fieldset>
              <input type="submit" class="splButton-primary" value="Update" />
            </fieldset>

          </form>
                    ]]></param>
                    <param name="customBehavior">neverReload</param>
                  </module>



                  <module name="HTML" group="download">
                    <param name="html"><![CDATA[
                      <p>
                        To download a copy of the groups lookup as a csv file or to open it in Excel just click the icon below:
                      </p>
                    ]]></param>
                  </module>


                  <module name="NullModule" group="find">

                    <module name="HTML">
                      <param name="html"><![CDATA[
                        <p>
                        This tab helps you find any Extensions/DN's that are not matching any of the numbers you have defined in the groups lookup.  Of course, if you have not yet put anything into the Groups lookup then below you'll just see all of your internal extensions and DN's.
                        </p>
                      ]]></param>
                    </module>

                    <module name="TimePicker">
                      <param name="default">Last 60 minutes</param>

                      <module name="Pulldown">
                        <param name="name">optionalHeadCommand</param>
                        <param name="label">get</param>
                        <param name="template">| head $value$</param>
                        <param name="staticOptions">
                          <list>
                            <param name="label">only the 100 most recent matching call legs</param>
                            <param name="value">100</param>
                          </list>
                          <list>
                            <param name="label">only the 1000 most recent matching call legs</param>
                            <param name="value">1000</param>
                            <param name="selected">True</param>
                          </list>
                          <list>
                            <param name="label">only the 10000 most recent matching call legs</param>
                            <param name="value">10000</param>
                          </list>
                          <list>
                            <param name="label">only the 100000 most recent matching call legs</param>
                            <param name="value">100000</param>
                          </list>
                          <list>
                            <param name="label">all records</param>
                            <param name="value"></param>
                          </list>
                        </param>


                        <module name="Search">
                          <param name="search">
`custom_index` sourcetype=cucm_cdr NOT callingPartyGroup=* NOT originalCalledPartyGroup=* NOT finalCalledPartyGroup=*
$optionalHeadCommand$
| fillnull callingPartyUnicodeLoginUserID originalCalledPartyLoginUserID finalCalledPartyLoginUserID callingPartyName callingPartyGroup callingPartySubgroup originalCalledPartyName originalCalledPartyGroup originalCalledPartySubgroup finalCalledPartyName finalCalledPartyGroup finalCalledPartySubgroup value="(none)"
| fillnull duration value="0"
| eval callingParty=callingPartyNumber + "::" + callingPartyUnicodeLoginUserID + "::" + callingPartyName + "::" + callingPartyGroup + "::" + callingPartySubgroup
| eval originalCalledParty=originalCalledPartyNumber + "::" + originalCalledPartyLoginUserID + "::" + originalCalledPartyName + "::" + originalCalledPartyGroup + "::" + originalCalledPartySubgroup
| eval finalCalledParty=finalCalledPartyNumber + "::" + finalCalledPartyLoginUserID + "::" + finalCalledPartyName + "::" + finalCalledPartyGroup + "::" + finalCalledPartySubgroup
| eval party=case(
  type=="internal",mvappend(callingParty,originalCalledParty,finalCalledParty),
  type=="incoming",mvappend(originalCalledParty,finalCalledParty),
  type="outgoing",callingParty)
| mvexpand party
| eval party=split(party,"::")
| eval number=mvindex(party,0)
| eval loginUserID=mvindex(party,1)
| eval nameGroupSubgroup=mvjoin(mvindex(party,2,4),";;;;")
| stats sum(duration) as duration dc(call_id) as calls values(loginUserID) as loginUserID values(nameGroupSubgroup) as nameGroupSubgroup by number type
| eval party=number + "----" + mvjoin(loginUserID,"::") + "----" + mvjoin(nameGroupSubgroup,"::")
| chart sum(duration) as duration sum(calls) as calls over party by type
| eval party=split(party,"----")
| eval number=mvindex(party,0)
| eval loginUserID=split(mvindex(party,1),"::")
| eval nameGroupSubgroup=split(mvindex(party,2),"::")
| eval nameGroupSubgroup=split(nameGroupSubgroup,";;;;")
| eval name=mvindex(nameGroupSubgroup,0)
| eval group=mvindex(nameGroupSubgroup,1)
| eval subgroup=mvindex(nameGroupSubgroup,2)
| eval nameGroupSubgroup=mvjoin(nameGroupSubgroup,", ")
| search group="(none)" name="(none)"
| stats sum(calls:*) as calls:* sum(duration:*) as duration:* values(loginUserID) as loginUserID values(name) as name values(group) as group values(subgroup) as subgroup values(nameGroupSubgroup) as nameGroupSubgroup by number
| rename "calls: *" as "*" "duration: *" as "*_duration"
| fillnull incoming outgoing internal incoming_duration outgoing_duration internal_duration value="0"
| eval total=incoming+internal+outgoing
| eval total_duration=incoming_duration + outgoing_duration + internal_duration
| eval incoming_duration=if(incoming>0,tostring(incoming_duration,"duration"),null())
| eval outgoing_duration=if(outgoing>0,tostring(outgoing_duration,"duration"),null())
| eval internal_duration=if(internal>0,tostring(internal_duration,"duration"),null())
| eval total_duration=if(total>0,tostring(total_duration,"duration"),null())
| eval incoming=if(incoming==0,null(),incoming)
| eval outgoing=if(outgoing==0,null(),outgoing)
| eval internal=if(internal==0,null(),internal)
| fields number loginUserID incoming outgoing internal total  incoming_duration outgoing_duration internal_duration total_duration
| sort 0 - total
                          </param>



                          <module name="HTML">
                            <param name="html"><![CDATA[
                              <br clear="all" /><h2 style="margin:0px;padding:0px;">$results.count$ internal numbers found that don't match any numbers in the groups lookup.</h2>
                            ]]></param>
                          </module>



                          <module name="ProgressIndicator" />

                          <module name="Pager">
                            <module name="Table" />
                          </module>

                          <pattern name="see_raw_search_syntax"/>
                        </module>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>



  <module name="Search" layoutPanel="panel_row1_col1">
    <param name="search">replaced at runtime by customBehavior</param>
    <param name="customBehavior">receivePushesForRowUpdates</param>


