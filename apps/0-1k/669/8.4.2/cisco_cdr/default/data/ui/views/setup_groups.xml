<view isVisible="false" template="dashboard.html" stylesheet="update_lookup.css,custom.css" customJS="lib/custom_behaviors/setup_pages.js">
  <label>Settings > Groups and Extensions</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="HTML" layoutPanel="viewHeader">
    <param name="html"><![CDATA[
    <h1><a href="home">Home</a> &gt; App Settings &gt; Groups and Extensions</h1>
    ]]></param>
  </module>

  <module name="URLLoader" layoutPanel="panel_row1_col1">
    <param name="keepURLUpdated">True</param>

    <module name="HTML" layoutPanel="viewHeader">
      <param name="html"><![CDATA[
        <div class="error">$error$</div>

        <div class="info">$message$</div>
      ]]></param>
    </module>



    <module name="ValueSetter" layoutPanel="mainSearchControls">
      <param name="arg.lookupName">groups</param>
      <param name="arg.lookupName.rawValue">groups</param>
      <param name="arg.exportFileName">groups.csv</param>
      <param name="arg.inputField">number</param>
      <param name="arg.outputFieldPrefixes">callingParty|originalCalledParty|finalCalledParty</param>
      <!--
      here's how we get the field names for the lookup, given only the information above.

      and we get out of it, via ResultsValueSetter,   two strings.   "number name group subgroup subgroup2"  and "number name group subgroup customzone"

| rest /servicesNS/-/cisco_cdr/data/props/lookups splunk_server=local | search attribute="LOOKUP-groups-*" | fields "lookup.field.output.*" | transpose | rename "row 1" as field1 "row 2" as field2 "row 3" as field3 "row 4" as field4 | where isnotnull(field1) or isnotnull(field2) or isnotnull(field3) or isnotnull(field4) | eval lookup_field=replace(column,"lookup.field.output.","")
| untable lookup_field field output_field
| where field!="column"
| eval output_field=replace(output_field,"callingParty|originalCalledParty|finalCalledParty","") |

| [| makeresults | eval prefix=split("callingParty,originalCalledParty,finalCalledParty",",") | mvexpand | eval query="eval ]

    -->


      <!--
      The following search gives back one row with two fields.
      lookup_fields is the space-separated list of output fields, named by the  names they have in the actual csv.
      output_fields is the space-separated list of the same fields, but named by the names they have in the
      OUTPUT sections of LOOKUP-* keys in props.conf.
      you know,  for kids!
       -->
      <module name="Search">
        <param name="search">
| `get_groups_lookup_fields_with_output_field_names("$outputFieldPrefixes$")`
        </param>

        <module name="ResultsValueSetter">
          <param name="fields">lookup_fields,output_fields</param>

          <module name="ValueSetter">
            <param name="arg.fieldOrder">$inputField$ $lookup_fields$</param>

            <module name="CustomBehavior">
              <param name="customBehavior">reloader</param>

              <module name="Tabs">
                <param name="name">selectedTab</param>
                <param name="staticTabs">
                  <list>
                    <param name="value">about</param>
                    <param name="label">About</param>
                  </list>
                  <list>
                    <param name="value">edit</param>
                    <param name="label">Edit/Delete Extensions/Groups</param>
                  </list>
                  <list>
                    <param name="value">add</param>
                    <param name="label">Add New Extension/Group</param>
                  </list>
                  <list>
                    <param name="value">download</param>
                    <param name="label">Download CSV</param>
                  </list>
                  <list>
                    <param name="value">reupload</param>
                    <param name="label">Upload CSV</param>
                  </list>
                  <list>
                    <param name="value">find</param>
                    <param name="label">Find Extensions to add</param>
                  </list>
                </param>

                <module name="Switcher" layoutPanel="panel_row1_col1">
                  <param name="selectedGroup">$selectedTab$</param>

                  <module name="NullModule" group="about">
                    <module name="HTML">

                      <param name="html"><![CDATA[
                        <p>
                          Using the tabs on this page you can manually set names and groups/departments for any and all of your extensions and DNs.
                        </p>

                        <p>
                          In practice however, the better path is to <a href="https://sideviewapps.com/documentation/cisco-cdr-reporting-analytics-administration-set-up-groups" target="_blank">follow our documentation to have this information pulled from AD nightly</a>.
                        </p>
                        <p>
                          Whichever way you choose, at the end there will be four key fields in each row:
                        </p>
                        <ol>
                          <li>number -- The extension or full DN</li>
                          <li>name -- the name of the person</li>
                          <li>group -- Generally the group or department that they are in, eg "sales"  "it/ops",  or "support"</li>
                          <li>subgroup (optional) -- this can be useful on larger deployments, for
                            instance someone might be in group="sales", but subgroup="Inside Sales West".</li>
                        </ol>

                        <h3>What's the end result?</h3>
                        <ol>
                          <li>In <a href="calls">Investigate &gt; Calls</a> new fields will be avaiable:  name, group, subgroup as well as
                          the more granular fields callingPartyName, originalCalledPartyName, finalCalledPartyName, and so on.</li>

                          <li>In <a href="extensions">Investigate &gt; Extensions</a> you'll be able to filter by name, group and subgroup,
                          as well as see that same information in the results table.</li>

                          <li>In the Chart tab of <a href="calls">Investigate &gt; Calls</a> you'll be able to select these fields as options
                          to build charts and reports.</li>

                          <li>If you have other features you'd like such a tool to have, please email us at
                            <a href="mailto:support@sideviewapps.com">support@sideviewapps.com</a>.</li>
                        </ol>

                        <h2>What if I have more layers than just "group" and "subgroup"</h2>
                        <p>
                          We actually have 3 extra layers hidden in reserve just for the few massive customers out there who need them.
                          Email us at <a href="mailto:support@sideviewapps.com">support@sideviewapps.com</a> to find out how to enable this.
                        </p>

                        <h2>Remember to take backups</h2>
                        <p>
                          By default nothing in the app and nothing in Splunk will be preserving backups of this information, so make sure to take appropriate backup copies yourself.
                        </p>

                      ]]></param>
                    </module>

                    <module name="Button">
                      <param name="label">Next</param>
                      <module name="Redirector">
                        <param name="url">?</param>
                        <param name="arg.selectedTab">edit</param>
                      </module>
                    </module>
                  </module>


                  <!-- One Big Happy Flow Chart START -->
                  <module name="Search" group="about">
                    <param name="search"><![CDATA[
| inputlookup groups
| streamstats count as order
| eval has_wildcard = if(match(number, "\*"), 1, 0)
| eval number_len = len(number)
| eval order = if(has_wildcard=1, (order) + tonumber((99 - 'number_len') . "000000"), order)
| delta order AS orderdiff
| search orderdiff < 0
| stats count
| eval group=if(count>0,"wrong sort order","right sort order")
                    ]]></param>

                    <module name="ResultsValueSetter">
                      <param name="fields">group</param>

                      <module name="Switcher">
                        <param name="selectedGroup">$group$</param>

                        <module name="NullModule" group="wrong sort order">

                          <module name="Search">
                            <param name="search">
| rest /services/authentication/current-context splunk_server=local
| search capabilities=output_file
| stats count
| eval group=if(count>0,"can run outputlookup","cannot run outputlookup")
                            </param>

                            <module name="ResultsValueSetter">
                              <param name="fields">group</param>

                              <module name="Switcher">
                                <param name="selectedGroup">$group$</param>

                                <module name="Search" group="can run outputlookup">
                                  <param name="search">
| inputlookup groups
| streamstats count as order
| eval has_wildcard = if(match(number, "\*"), 1, 0)
| eval number_len = len(number)
| eval order = if(has_wildcard=1, (order) + tonumber((99 - 'number_len') . "000000"), order)
| sort 0 order
| fields number name group subgroup subgroup2 subgroup3 subgroup4
| outputlookup groups create_empty=false override_if_empty=false
                                    </param>
                                  <module name="ProgressIndicator"></module>

                                  <module name="HTML">
                                    <param name="html"><![CDATA[
                                    <div style="border:1px solid #ccc; padding:5px 10px;"><strong style="color:#c00">THE GROUPS LOOKUP WAS FOUND TO BE IN THE WRONG SORT ORDER.</strong>  <br>
                                    However the good news is that we were just able to repair the problem. This error message should go away if you refresh the page and the corresponding health check (see Setup > Run Health Checks) should no longer fail.
                                    </div>
                                    ]]></param>
                                  </module>
                                </module>

                                <module name="HTML" group="cannot run outputlookup">
                                  <param name="html"><![CDATA[
                                  <div style="border:1px solid #ccc; padding:5px 10px;"><strong style="color:#c00">THE SORT ORDER INSIDE THE GROUPS LOOKUP IS WRONG.</strong><br>
                                  Unfortunately your Splunk user account is not able to run the outputlookup command (technically you do not have the "output_file" capability), so to make a long story short this page was unable to fix the problem for you.  Please tell a Splunk Administrator to navigate to this page, and for good measure to also then run the "Setup > Run Health Checks" page for you.
                                  </div>
                                  ]]></param>
                                </module>
                              </module>
                            </module>
                          </module>
                        </module>


                      </module>
                    </module>

                    <!-- One Big Happy Flow Chart END-->

                  </module>



                  <module name="Filters" group="edit">
