      </module>
    </module>


    <module name="NullModule" layoutPanel="panel_row5_col2">
      <module name="HTML">
        <param name="html"><![CDATA[
            <h3>About your data</h3>

        ]]></param>
      </module>

      <module name="TimePicker">
        <param name="default">Last 60 minutes</param>
        <param name="label">Call volume over</param>

        <module name="Search">
          <param name="search"><![CDATA[
|  tstats count as records WHERE `custom_index` GROUPBY sourcetype _time
|  append [
  |  tstats dc(globalCallId_ClusterID) as clusters WHERE `custom_index` GROUPBY sourcetype
]
| stats sparkline(sum(records)) as sparkline sum(records) as records last(clusters) as clusters by sourcetype
| eval pluralize=if(clusters==1,"cluster","clusters")
| eval details=if(clusters>0,clusters . " " . pluralize,null())
| fields - pluralize
| eval records=tostring(records,"commas")
| table sourcetype records details sparkline
| rename sparkline as "records over time"
          ]]></param>

          <module name="Pager">

            <module name="Table"/>

            <module name="Pager" />
          </module>

        </module>
      </module>
    </module>







    <pattern name="explore_new_reports" layoutPanel="panel_row6_col1" />

    <pattern name="explore_fields"  layoutPanel="panel_row6_col2"/>

  </module>

