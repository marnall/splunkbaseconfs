      <module name="HTML">
        <param name="html"><![CDATA[
            <h3>About this app</h3>
        ]]></param>
      </module>

      <pattern name="tutorial_topics">
        <param name="label">Start a tutorial</param>
        <param name="float">left</param>
        <param name="clear">left</param>

        <module name="Button">
          <param name="label">go</param>
          <module name="Redirector">
            <param name="url">tour</param>
            <param name="arg.selectedTab">static</param>
            <param name="arg.staticTutorial">$staticTutorial$</param>
            <param name="popup">True</param>
            <param name="target">tourWindow</param>
            <param name="windowFeatures">popup=true,left=20,top=20,width=600,height=800</param>
          </module>
        </module>
      </pattern>



      <module name="HTML">
        <param name="clear">left</param>
        <param name="html"><![CDATA[



          <p>
            Looking for docs?  Read our <a href="https://sideviewapps.com/documentation/cisco-cdr-reporting-analytics-user-documentation" target="_blank">user documentation</a> or <a href="https://sideviewapps.com/documentation/cisco-cdr-reporting-analytics-extending-the-app" target="_blank">learn about the app's optional lookups</a>.
