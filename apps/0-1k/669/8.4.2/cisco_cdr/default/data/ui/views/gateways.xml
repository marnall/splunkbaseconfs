<view isVisible="false" stylesheet="custom.css" customJS="lib/custom_behaviors/chart.js">
  <label>Gateways/Trunks</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="URLLoader" layoutPanel="viewHeader">
    <param name="keepURLUpdated">True</param>

    <pattern name="display_saved_report_name" />

    <module name="HTML" layoutPanel="viewHeader">
      <param name="html"><![CDATA[
      <h1 class="doNotPrint">Gateways/Trunks</h1>
      ]]></param>
    </module>

    <module name="CustomBehavior">
      <param name="customBehavior">tour_gatewaysPage</param>
    </module>

    <module name="TimePicker" layoutPanel="mainSearchControls">
      <param name="default">Last 24 hours</param>



      <module name="ValueSetter">
        <param name="arg.cachedEarliest">$search.timeRange.earliest$</param>
        <param name="arg.cachedLatest">$search.timeRange.latest$</param>



        <module name="TextField">
          <param name="name">searchterms</param>
          <param name="label">search filters</param>
          <param name="width">334px</param>

          <pattern name="cluster_controls">
            <param name="selectAllOptimization">False</param>

            <module name="Search">
              <param name="search">
| `get_gateways_from_tstats(dest, "$clusterId$")`
| append [
  | `get_gateways_from_tstats(orig, "$clusterId$")`]
| stats count by gateway
| sort 0 + gateway
              </param>

              <module name="CheckboxPulldown">
                <param name="name">gateway</param>
                <param name="label">gateways/trunks</param>
                <param name="template">orig_gateway=$value$ OR dest_gateway=$value$</param>
                <param name="valueField">gateway</param>
                <param name="width">280px</param>
                <param name="selectAllOptimization">omit</param>

                <module name="ArrayValueSetter">
                  <param name="name">gateway_postfilter</param>
                  <param name="array">$gateway.rawValue$</param>
                  <param name="template">gateway="$value$"</param>
                  <param name="separator">+OR+</param>
                  <param name="outerTemplate">( $value$ )</param>


                  <module name="Button">
                    <param name="allowSoftSubmit">True</param>



                    <module name="Search" layoutPanel="resultsHeaderPanel">
                      <param name="search"><![CDATA[
`custom_index` sourcetype=cucm_cdr $clusterGroup$ $clusterId$ $gateway$
| rename comment as "wrong numbers are human error so we dont treat them as failures at all"
| eval call_answerable=if(cause=1,1,call_answerable)
| eval failedCallId=if(call_connected=0 AND call_answerable=0,call_id,null())

| fillnull duration value="0"
| eval {type}_duration=duration
| eval {type}_call_id=call_id
| eval {bh_type}_duration=duration
| eval {bh_type}_call_id=call_id
| eval {callMediaType}_duration=duration
| eval {callMediaType}_call_id=call_id
| eval _workaround_call_id=call_id
| stats dc(failedCallId) as failed_calls dc(incoming_call_id) as incoming dc(outgoing_call_id) as outgoing dc(tandem_call_id) as tandem dc(call_id) as calls sum(incoming_duration) as incoming_duration sum(outgoing_duration) as outgoing_duration sum(tandem_duration) as tandem_duration sum(duration) as total_duration sum(off_hours_duration) as off_hours_duration sum(business_hours_duration) as business_hours_duration dc(business_hours_call_id) as business_hours dc(off_hours_call_id) as off_hours sum(audio_duration) as audio_duration sum(video_duration) as video_duration dc(audio_call_id) as audio dc(video_call_id) as video dc(globalCallID_callManagerId) as subscribers by globalCallId_ClusterID gateway
| rename globalCallId_ClusterID as cluster

| fields cluster gateway calls incoming outgoing tandem total_duration incoming_duration outgoing_duration tandem_duration   business_hours off_hours off_hours_duration business_hours_duration audio video audio_duration video_duration failed_calls subscribers
| eval secretCluster=cluster
| search * $gateway_postfilter$ $searchterms$
| eval failed_call_perc=if(failed_calls=0,"0%",round(100*failed_calls/calls,2)."%")
| `get_durations_for_internal_parties`
| `replace_zeros_with_nulls`
                      ]]></param>

                      <module name="ProgressIndicator" layoutPanel="resultsAreaLeft"></module>

                      <module name="Fields">
                        <param name="availableFields">gateway,cluster,calls,incoming,outgoing,tandem,total_duration,incoming_duration,outgoing_duration,tandem_duration,total_duration_min,incoming_duration_min,outgoing_duration_min,tandem_duration_min,business_hours,off_hours,business_hours_duration,off_hours_duration,audio,video,audio_duration,video_duration,failed_calls,failed_call_perc,subscribers</param>
                        <param name="fields">gateway,cluster,calls,incoming,outgoing,tandem,total_duration,incoming_duration,outgoing_duration,tandem_duration,failed_calls,failed_call_perc</param>
                        <param name="float">right</param>

                        <pattern name="save_create_buttons" />

                        <module name="SearchControls">
                          <param name="sections">jobControls info export print saveMenu</param>
                          <!-- remove the saveResults options because the sid permalinks wont work here. -->
                          <param name="saveMenu">saveSearch</param>
                          <param name="float">right</param>
                        </module>

                        <module name="HTML">
                          <param name="html"><![CDATA[
                            <h3>$results.count$ gateways/trunks found $search.timeRange.label$.</h3>
                          ]]></param>
                        </module>

                        <module name="Pulldown" layoutPanel="pageControls">
                          <param name="name">results.count</param>
                          <param name="label">results per page</param>
                          <param name="float">right</param>
                          <param name="staticOptions">
                            <list><param name="value">10</param></list>
                            <list><param name="value">20</param></list>
                            <list><param name="value">50</param></list>
                            <list><param name="value">100</param></list>
                          </param>





                          <module name="PostProcess">
                            <param name="search"><![CDATA[
| stats dc(secretCluster) as clusters by gateway
| where clusters>1
| stats count
| where count>0
| eval message=if(match("$selectedFields$","cluster"),"","NOTE: You have some gateway names repeated across clusters. This is fine but to help differentiate them in the results below you might want to add the \"cluster\" field using the fields pulldown on the right hand side.")
                              ]]></param>
                            <module name="HTML">
                              <param name="html">
                                $results[0].message$
                              </param>
                            </module>
                          </module>

                          <module name="PostProcess" layoutPanel="resultsAreaLeft">
                            <param name="search">
fields gateway secretCluster $results.fields$
                            </param>

                            <module name="Pager" layoutPanel="pageControls">

                              <module name="Table" layoutPanel="resultsAreaLeft">
                                <param name="hiddenFields">secretCluster</param>

                                <module name="Layer">
                                  <param name="cssClass">menu</param>

                                  <module name="Link">
                                    <param name="cssClass">menuItem</param>
                                    <param name="label">investigate all calls through this gateway</param>

                                    <module name="Redirector">
                                      <param name="url">calls</param>
                                      <param name="arg.clusterId">$clusterId.rawValue$</param>
                                      <param name="arg.clusterGroup">$clusterGroup.rawValue$</param>
                                      <param name="arg.searchterms">gateway="$row.fields.gateway.rawValue$"</param>

                                      <param name="arg.earliest">$search.timeRange.earliest$</param>
                                      <param name="arg.latest">$search.timeRange.latest$</param>
                                    </module>
                                  </module>

                                  <module name="Link">
                                    <param name="cssClass">menuItem</param>
                                    <param name="label">investigate failed calls through this gateway</param>

                                    <module name="Redirector">
                                      <param name="url">calls</param>
                                      <param name="arg.clusterId">$clusterId.rawValue$</param>
                                      <param name="arg.clusterGroup">$clusterGroup.rawValue$</param>
                                      <param name="arg.searchterms">gateway="$row.fields.gateway.rawValue$" call_failed=1</param>

                                      <param name="arg.earliest">$search.timeRange.earliest$</param>
                                      <param name="arg.latest">$search.timeRange.latest$</param>
                                    </module>
                                  </module>

                                  <module name="Link">
                                    <param name="cssClass">menuItem</param>
                                    <param name="label">prevent this device from being treated as a trunk or gateway</param>

                                    <module name="Layer">
                                      <module name="HTML">
                                        <param name="html"><![CDATA[
If your user account has write access to this app, you can can prevent this device from being treated as a trunk or gateway by going to <a href="setup_device_types">App Settings > Device Types</a> and defining a new device type regex that will match this device name and others like it. <br>
<br>You will find more details on that page.
                                        ]]></param>
                                      </module>
                                    </module>
                                  </module>


                                  <module name="Link">
                                    <param name="cssClass">menuItem</param>
                                    <param name="label">view gateway details</param>


                                    <module name="Redirector">
                                      <param name="url">gateway_detail</param>
                                      <!-- If we leave this on, it thinks this is a general report drilldown, it parses the SPL. It notices that this is a gateway report.  it sets the $gateway$ key automatically to be the gateway value from the row we clicked on.  End result is the key we're trying to send over for the detail view's link module to stash away (for breadcrumb link) gets overwritten magically.
                                      -->
                                      <param name="mergeDrilldownKeys">False</param>
                                      <param name="arg.clusterId">$row.fields.secretCluster.rawValue$</param>
                                      <param name="arg.gateway">$row.fields.gateway.rawValue$</param>
                                      <param name="arg.earliest">$search.timeRange.earliest$</param>
                                      <param name="arg.latest">$search.timeRange.latest$</param>

                                      <!--  filing away things for if the user later clicks the breadcrumb link -->
                                      <param name="arg.bc_earliest">$cachedEarliest$</param>
                                      <param name="arg.bc_latest">$cachedLatest$</param>
                                      <param name="arg.bc_gateway">$gateway.rawValue$</param>
                                      <param name="arg.bc_clusterId">$clusterId.rawValue$</param>
                                      <param name="arg.bc_clusterGroup">$clusterGroup.rawValue$</param>
                                    </module>
                                  </module>


                                </module>

                              </module>
                            </module>
                            <pattern name="see_raw_search_syntax" />

                          </module>
                        </module>
                      </module>

                    </module>


                  </module>
                </module>
              </module>
            </module>
          </pattern>
        </module>
      </module>
    </module>
  </module>
</view>
