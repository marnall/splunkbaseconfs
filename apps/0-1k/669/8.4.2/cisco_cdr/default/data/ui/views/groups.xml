<view isVisible="false" stylesheet="custom.css">
  <label>Groups</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="URLLoader" layoutPanel="viewHeader">
    <param name="keepURLUpdated">True</param>

    <pattern name="display_saved_report_name" />

    <module name="HTML" layoutPanel="viewHeader">
      <param name="html"><![CDATA[
      <h1 class="doNotPrint">Groups</h1>
      ]]></param>
    </module>

    <module name="CustomBehavior">
      <param name="customBehavior">tour_groupsPage</param>
    </module>

    <module name="Search">
      <param name="search">
| inputlookup groups.csv | stats count | eval moreThanOneRowInGroupsLookup=if(count>1,"yes","no") | table moreThanOneRowInGroupsLookup
| fields - _time
      </param>

      <module name="ResultsValueSetter">
        <param name="fields">moreThanOneRowInGroupsLookup</param>

        <module name="Search" layoutPanel="mainSearchControls">
          <param name="search">| inputlookup groups | search group!="PLACEHOLDER GROUP" | fillnull subgroup value="EXPLICIT_NULL" | stats count by group subgroup | sort 0 group</param>

          <module name="TimePicker">
            <param name="default">Last 60 minutes</param>

            <module name="CheckboxPulldown">
              <param name="name">group</param>
              <param name="label">group</param>
              <param name="valueField">$name$</param>
              <param name="selectAllOptimization">omit</param>
              <param name="postProcess">stats count by group | eval lower=lower(group) | sort + lower</param>
              <param name="template">(callingPartyGroup="$value$" OR originalCalledPartyGroup="$value$" OR finalCalledPartyGroup="$value$")</param>
              <param name="nullTemplate">(NOT callingPartyGroup=* NOT originalCalledPartyGroup=* NOT finalCalledPartyGroup=* )</param>
              <param name="staticOptions">
                <list>
                  <param name="value"></param>
                  <param name="label">no group</param>
                  <param name="selected">True</param>
                </list>
              </param>

              <module name="ArrayValueSetter">
                <param name="name">genericGroupTerms</param>
                <param name="array">$group.rawValue$</param>
                <param name="template">group="$value$"</param>
                <param name="nullTemplate">NOT group=* OR group="(none)"</param>
                <param name="separator">+OR+</param>
                <param name="outerTemplate">( $value$ )</param>

                <module name="CheckboxPulldown">
                  <param name="name">subgroup</param>
                  <param name="label">subgroup</param>
                  <param name="valueField">$name$</param>
                  <param name="selectAllOptimization">omit</param>
                  <param name="postProcess">search subgroup!="" subgroup!="EXPLICIT_NULL" $genericGroupTerms$ | stats count by subgroup  | eval lower=lower(subgroup) | sort + lower</param>
                  <param name="template">(callingPartySubgroup="$value$" OR originalCalledPartySubgroup="$value$" OR finalCalledPartySubgroup="$value$")</param>
                  <param name="nullTemplate">(NOT callingPartySubgroup=* NOT originalCalledPartySubgroup=* NOT finalCalledPartySubgroup=* )</param>
                  <param name="staticOptions">
                    <list>
                      <param name="value"></param>
                      <param name="label">no subgroup</param>
                      <param name="selected">True</param>
                    </list>
                  </param>

                  <module name="ArrayValueSetter">
                    <param name="name">genericSubgroupTerms</param>
                    <param name="array">$subgroup.rawValue$</param>
                    <param name="template">subgroup="$value$"</param>
                    <param name="nullTemplate">NOT subgroup=*</param>
                    <param name="separator">+OR+</param>
                    <param name="outerTemplate">( $value$ )</param>

                    <module name="TextField">
                      <param name="name">number</param>
                      <param name="label">number</param>
                      <param name="width">150px</param>

                      <module name="TextField">
                        <param name="name">huntPilotDN</param>
                        <param name="label">hunt pilot</param>
                        <param name="width">150px</param>

                        <pattern name="cluster_controls">

                          <module name="CheckboxPulldown">
                            <param name="name">modifiers</param>
                            <param name="label">options</param>
                            <param name="selectedByDefault">False</param>
                            <param name="sticky">True</param>
                            <param name="staticOptions">
                              <list>
                                <param name="value">groupsWithZeroCalls</param>
                                <param name="label">include extensions with zero calls</param>
                              </list>
                              <list>
                                <param name="value">callsWithZeroDuration</param>
                                <param name="label">count calls with zero duration</param>
                              </list>
                            </param>

                            <module name="Button">
                              <param name="allowSoftSubmit">True</param>

                              <module name="CustomBehavior">
                                <param name="customBehavior">createPhoneNumberSearchTerms</param>

                                <module name="CustomBehavior">
                                  <param name="customBehavior">getKeysForModifiers</param>

                                  <module name="Search" layoutPanel="resultsHeaderPanel">
                                    <param name="search"><![CDATA[
`custom_index` sourcetype=cucm_cdr $clusterGroup$ $clusterId$ $group$ $subgroup$ $internalPartyNumberTerms$ $huntPilotSubsearch$ $excludeCallsWithZeroDuration$
| eval {type}_duration=duration
| eval {type}_call_id=call_id
| eval {bh_type}_duration=duration
| eval {bh_type}_call_id=call_id
| eval {callMediaType}_duration=duration
| eval {callMediaType}_call_id=call_id
| `calculate_all_internal_parties`
| lookup groups number as number output name group subgroup
$includeGroupsWithZeroCalls$
| fillnull group value="(none)"
| stats dc(subgroup) as subgroups values(subgroup) as subgroup dc(number) as extensions values(number) as number dc(name) as names dc(loginUserID) as loginUserIDs dc(huntPilotDN) as huntPilotDNs dc(incoming_call_id) as incoming dc(outgoing_call_id) as outgoing dc(internal_call_id) as internal dc(call_id) as calls sum(incoming_duration) as incoming_duration sum(outgoing_duration) as outgoing_duration sum(internal_duration) as internal_duration sum(duration) as total_duration
sum(off_hours_duration) as off_hours_duration sum(business_hours_duration) as business_hours_duration dc(business_hours_call_id) as business_hours dc(off_hours_call_id) as off_hours sum(audio_duration) as audio_duration sum(video_duration) as video_duration dc(audio_call_id) as audio dc(video_call_id) as video by group
| search * $genericNumberTerms$ $genericGroupTerms$ $genericSubgroupTerms$
| eval subgroup=mvjoin(subgroup,", ")
| fields group subgroups subgroup extensions names loginUserIDs huntPilotDNs incoming outgoing internal business_hours off_hours audio video calls incoming_duration outgoing_duration internal_duration business_hours_duration off_hours_duration audio_duration video_duration total_duration
| `get_durations_for_internal_parties`
| `replace_zeros_with_nulls`
| fillnull calls
| sort 0 group
                                    ]]></param>

                                    <module name="Fields">
                                      <param name="availableFields">group,subgroups,extensions,loginUserIDs,huntPilotDNs,names,calls,incoming,outgoing,internal,total_duration,incoming_duration,outgoing_duration,internal_duration,total_duration_min,incoming_duration_min,outgoing_duration_min,internal_duration_min,business_hours,off_hours,business_hours_duration,off_hours_duration,audio,video,audio_duration,video_duration</param>
                                      <param name="fields">group,subgroups,extensions,calls,incoming,outgoing,internal,total_duration,incoming_duration,outgoing_duration,internal_duration</param>
                                      <param name="float">right</param>

                                      <pattern name="save_create_buttons" />
                                      <module name="SearchControls">
                                        <param name="sections">jobControls info export print</param>
                                        <param name="float">right</param>
                                      </module>

                                      <module name="HTML" layoutPanel="resultsHeaderPanel">
                                        <param name="html"><![CDATA[

                                        <h2>$qualifier$ $results.count$ groups found $search.timeRange.label$ </h2>

                                        ]]></param>
                                        <param name="customBehavior">qualifyNumberOfResults</param>
                                      </module>

                                      <module name="Pulldown" layoutPanel="resultsAreaLeft">
                                        <param name="name">results.count</param>
                                        <param name="label">results per page</param>
                                        <param name="float">right</param>
                                        <param name="staticOptions">
                                          <list><param name="value">10</param></list>
                                          <list><param name="value">20</param><param name="selected">True</param></list>
                                          <list><param name="value">50</param></list>
                                          <list><param name="value">100</param></list>
                                          <list><param name="value">200</param></list>
                                        </param>

                                        <module name="CustomBehavior">
                                          <param name="customBehavior">showUserWarningsAndNotices</param>
                                        </module>

                                        <module name="ProgressIndicator" />

                                        <module name="PostProcess">
                                          <param name="search">fields group subgroup $results.fields$ </param>

                                          <module name="Pager">

                                            <module name="Table">
                                              <param name="drilldown">row</param>
                                              <param name="hiddenFields">subgroup</param>

                                              <module name="ValueSetter" group="row.fields.subgroups">
                                                <param name="name">display</param>
                                                <param name="if.$row.fields.subgroups$=0[priority=1]"></param>
                                                <param name="if.$row.fields.subgroups$=1[priority=2]">$row.fields.subgroup$</param>
                                                <param name="if.$row.fields.subgroups$=2[priority=3]">$row.fields.subgroup$</param>
                                                <param name="if.$row.fields.subgroups$=3[priority=4]">$row.fields.subgroup$</param>
                                                <param name="if.$row.fields.subgroups$=4[priority=5]">$row.fields.subgroup$</param>
                                                <param name="if.$row.fields.subgroups$=5[priority=6]">$row.fields.subgroup$</param>

                                                <param name="default"><![CDATA[
                                                <span class="distinctValueCount">($row.fields.subgroups$ subgroups included)</span>
                                                ]]></param>

                                                <module name="HTML">
                                                  <param name="html"><![CDATA[
                                                    $display$
                                                  ]]></param>
                                                </module>
                                              </module>

                                              <module name="Layer">
                                                <param name="cssClass">menu</param>
                                                <!--

                                                  (do later)
                                                  -  go to group detail page

                                                  4) special fourth action for some other rows.
                                                  a) incoming/outgoing/internal/business_hours/off_hours
                                                   - go to investigate calls, with group=foo type=incoming
                                                  b) *duration = go to chart, sum(duration) over time, group=foo
                                                  -->

                                                <module name="ValueSetter">
                                                  <param name="name">groupArgForBrowseExtensions</param>
                                                  <!-- until we drop 7.X we still need these goofy priority flags -->
                                                  <param name="if.$row.fields.group$=(none)[priority=1]"></param>
                                                  <param name="default">$row.fields.group$</param>

                                                  <module name="ValueSetter">
                                                    <param name="name">groupArgForBrowseCalls</param>
                                                    <!-- until we drop 7.X we still need these goofy priority flags -->
                                                    <param name="if.$row.fields.group$=(none)[priority=1]">NOT group=*</param>
                                                    <param name="default">group="$row.fields.group$"</param>

                                                    <module name="Link">
                                                      <param name="cssClass">menuItem</param>
                                                      <param name="label">investigate calls with group="$row.fields.group$"</param>

                                                      <module name="Redirector">
                                                        <param name="url">calls</param>
                                                        <param name="mergeDrilldownKeys">False</param>
                                                        <param name="arg.searchterms">$groupArgForBrowseCalls$</param>
                                                        <param name="arg.clusterId">$clusterId.rawValue$</param>
                                                        <param name="arg.clusterGroup">$clusterGroup.rawValue$</param>

                                                        <param name="arg.number">$row.fields.number$</param>
                                                        <param name="arg.huntPilotDN">$huntPilotDN.rawValue$</param>
                                                        <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                        <param name="arg.latest">$search.timeRange.latest$</param>
                                                      </module>
                                                    </module>

                                                    <module name="Link">
                                                      <param name="cssClass">menuItem</param>
                                                      <param name="label">investigate extensions within group="$row.fields.group$"</param>

                                                      <module name="Redirector">
                                                        <param name="url">extensions</param>
                                                        <param name="mergeDrilldownKeys">False</param>
                                                        <param name="arg.group">$groupArgForBrowseExtensions$</param>
                                                        <param name="arg.subgroup">$subgroup.rawValue$</param>
                                                        <param name="arg.clusterId">$clusterId.rawValue$</param>
                                                        <param name="arg.clusterGroup">$clusterGroup.rawValue$</param>

                                                        <param name="arg.number">$row.fields.number$</param>
                                                        <param name="arg.huntPilotDN">$huntPilotDN.rawValue$</param>
                                                        <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                        <param name="arg.latest">$search.timeRange.latest$</param>
                                                      </module>
                                                    </module>

                                                    <module name="Link">
                                                      <param name="cssClass">menuItem</param>
                                                      <param name="label">view group details</param>

                                                      <module name="Redirector">
                                                        <param name="url">group_detail</param>
                                                        <param name="arg.group">$row.fields.group$</param>
                                                        <param name="arg.clusterId">$clusterId.rawValue$</param>
                                                        <param name="arg.clusterGroup">$clusterGroup.rawValue$</param>
                                                        <param name="arg.earliest">$search.timeRange.earliest$</param>
                                                        <param name="arg.latest">$search.timeRange.latest$</param>

                                                        <!--  things for breadcrumb links -->
                                                        <param name="arg.bc_earliest">$search.timeRange.earliest$</param>
                                                        <param name="arg.bc_latest">$search.timeRange.latest$</param>
                                                        <param name="arg.bc_group">$group.rawValue$</param>
                                                        <param name="arg.bc_number">$number.rawValue$</param>
                                                        <param name="arg.bc_huntPilotDN">$huntPilotDN.rawValue$</param>
                                                        <param name="arg.bc_clusterId">$clusterId.rawValue$</param>
                                                        <param name="arg.bc_clusterGroup">$clusterGroup.rawValue$</param>
                                                      </module>
                                                    </module>



                                                  </module>
                                                </module>
                                              </module>
                                            </module>

                                            <pattern name="see_raw_search_syntax" />

                                          </module>
                                        </module>
                                      </module>
                                    </module>
                                  </module>
                                </module>
                              </module>
                            </module>
                          </module>
                        </pattern>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</view>