<view isVisible="false" template="dashboard.html" stylesheet="custom.css,call_detail.css">
  <label>View call details (CUBE)</label>

  <pattern name="nav" layoutPanel="appHeader" />

  <module name="URLLoader" layoutPanel="mainSearchControls">
    <param name="keepURLUpdated">True</param>

    <module name="Link" layoutPanel="viewHeader">
      <param name="label">Investigate Calls</param>
      <module name="Redirector">
        <param name="url">calls</param>
        <param name="arg.earliest">$bc_earliest$</param>
        <param name="arg.latest">$bc_latest$</param>
        <param name="arg.type">$bc_type$</param>
        <param name="arg.number">$bc_number$</param>
        <param name="arg.numberType">$bc_numberType$</param>
        <param name="arg.searchterms">$bc_searchterms$</param>
        <param name="arg.advancedSearchLanguage">$bc_advancedSearchLanguage$</param>
      </module>
    </module>

    <module name="HTML" layoutPanel="viewHeader">
      <param name="html"><![CDATA[
        <h1>&gt; Call Detail (CUBE)</h1>
        ]]>
      </param>
    </module>

    <module name="TextField">
      <param name="name">call_id</param>
      <param name="label">Call Id</param>
      <param name="template">$name$="$value$"</param>
      <param name="cssClass">callIdTextField</param>

      <module name="ValueSetter">
        <param name="arg.standardFields">_time duration type dnis clid cause_description activity h323_disconnect_description call_id</param>


        <module name="Search">
          <param name="earliest">$search.timeRange.earliest$</param>
          <param name="latest">$search.timeRange.latest$</param>
          <param name="search"><![CDATA[
`custom_index` `cube_sourcetypes` $call_id$ | fieldsummary | fields field count | search count>0
          ]]></param>


          <module name="CustomBehavior" layoutPanel="panel_row1_col1">
            <param name="customBehavior">onlySubmitIfFieldsAreSet</param>
            <param name="arg.requiredKey">call_id.rawValue</param>

            <module name="HTML">
              <param name="html"><![CDATA[
                <div id="viewerPageInstructions" style="display:none;clear:both;">
                <br>
                <br>
                <b>This view is normally reached by clicking a row from the <a href="calls">Investigate Calls</a> page.  <br>
                <br>
                However you can also use this view manually by simply entering a Call Id in the field above and hitting Enter.</b>
                <br>
                <br>
                <br>
                <br>
                </div>
              ]]></param>
            </module>


            <module name="Fields">
              <param name="fields">duration type dnis clid cause_description activity h323_disconnect_description</param>

              <module name="Search">
                <param name="earliest">$search.timeRange.earliest$</param>
                <param name="latest">$search.timeRange.latest$</param>
                <param name="search"><![CDATA[
`custom_index` `cube_sourcetypes` $call_id$
| table _time $results.fields$
| eval duration=tostring(duration,"duration")
                ]]></param>

                <pattern name="see_raw_search_syntax" />

                <module name="ValueSetter">
                  <param name="name">legNoun</param>
                  <param name="if.$results.count$=1">leg</param>
                  <param name="default">legs</param>

                  <module name="HTML">
                    <param name="html"><![CDATA[
                      <h2>Showing $results.count$ $legNoun$ for call id $call_id.rawValue$</h2>
                    ]]></param>
                  </module>
                </module>


                <module name="ProgressIndicator" />

                <module name="Pager">
                  <module name="Table" />
                </module>
              </module>
            </module>
          </module>
        </module>



        <!-- first we get all the calling/called parties -->
        <module name="Search">
          <param name="search">
`custom_index` `cube_sourcetypes` $call_id$
| stats values(dnis) as dnis values(clid) as clid
          </param>


          <!-- now we build a SPL expression to match on those clid
          values, but as either dnis or clid -->
          <module name="PostProcess" layoutPanel="panel_row2_col1">
            <param name="search">
| table clid
| eval dnis=clid
| format "(" "" "OR" "" "OR" ")"
| rename search as clidExpression
            </param>

            <module name="ResultsValueSetter">
              <param name="fields">clidExpression</param>

              <module name="HTML">
                <param name="html"><![CDATA[
                  <h2>Other calls to/from the calling party (or calling parties)</h2>
                  <!--
                  $clidExpression$
                  -->
                ]]></param>
              </module>


              <!-- actually get the "other calls to/from" -->
              <module name="Search">
                <param name="search">
`custom_index` `cube_sourcetypes` $clidExpression$
| fields $standardFields$
| eval duration=tostring(duration,"duration")
| stats min(_time) as _time values(*) as * by call_id
| fields $standardFields$
                </param>

                <!-- except first we use more postProcess to get a field representing the page number that the current call is actually on, so we can load with that page open -->
                <module name="PostProcess">
                  <param name="search">
| fields call_id
| streamstats count current=f
| search $call_id$
| eval count=floor(count/10)*10
| rename count as "results.offset"
                  </param>

                  <!-- use ResultsValueSetter to get that value.
                  (Then the pager will pick it up automatically,
                  assume there is another Pager upstream and
                  obediently set itself to that page.) -->
                  <module name="ResultsValueSetter">
                    <param name="fields">results.offset</param>


                    <!-- one more postprocess. this time we will paint a little field called
                    'rowClass' that for the current-call will have the value 'selected'-->
                    <module name="PostProcess">
                      <param name="search">
                        eval rowClass=if((call_id=="$call_id.rawValue$"),"selected","")
                      </param>

                      <module name="Pager">

                        <module name="Table">
                          <param name="hiddenFields">call_id rowClass detailEarliest detailLatest</param>
                          <param name="rowClass">$row.fields.rowClass$</param>
                        </module>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>
          </module>

          <module name="PostProcess" layoutPanel="panel_row2_col2">
            <param name="search">
| table dnis
| eval clid=dnis
| format "(" "" "OR" "" "OR" ")"
| rename search as dnisExpression
            </param>


            <module name="ResultsValueSetter">
              <param name="fields">dnisExpression</param>

              <module name="HTML">
                <param name="html"><![CDATA[
                  <h2>Other calls to/from the called party (or called parties)</h2>
                  <!--
                  $dnisExpression$
                  -->
                ]]></param>
              </module>


              <module name="Search">
                <param name="search">
`custom_index` `cube_sourcetypes` $dnisExpression$
| fields $standardFields$
| eval duration=tostring(duration,"duration")
| stats min(_time) as _time values(*) as * by call_id
| fields $standardFields$
                </param>

                <module name="PostProcess">
                  <param name="search">
| fields call_id
| streamstats count current=f
| search $call_id$
| eval count=floor(count/10)*10
| rename count as "results.offset"
                  </param>

                  <module name="ResultsValueSetter">
                    <param name="fields">results.offset</param>

                    <module name="PostProcess">
                      <param name="search">
                        eval rowClass=if((call_id=="$call_id.rawValue$"),"selected","")
                      </param>

                      <module name="Pager">

                        <module name="Table">
                          <param name="hiddenFields">call_id rowClass detailEarliest detailLatest</param>
                          <param name="rowClass">$row.fields.rowClass$</param>
                        </module>
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>

      </module>
    </module>
  </module>
</view>
