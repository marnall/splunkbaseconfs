                    <list><param name="label">Add new filter ...</param><param name="value"></param></list>
                  </param>
                  <param name="customBehavior">hideDownstreamModulesUntilFieldSelected</param>

                  <module name="Pulldown">
                    <param name="name">operator</param>
                    <param name="float">left</param>
                    <param name="staticOptions">
                      <list><param name="value">=</param></list>
                      <list><param name="value">&gt;</param></list>
                      <list><param name="value">&lt;</param></list>
                      <list><param name="value">!=</param></list>
                    </param>



                    <module name="Search">
                      <param name="search">| inputlookup $lookupName$ | head 500 | stats count by $field$ | fields - count | sort $field$ | rename $field$ as value</param>


                      <module name="Pulldown">
                        <param name="name">value</param>
                        <param name="valueField">value</param>
                        <param name="float">left</param>
                        <param name="staticOptions">
                          <list><param name="value"></param><param name="label">enter value manually...</param></list>
                        </param>

                        <module name="TextField">
                          <param name="name">value</param>
                          <param name="float">left</param>
                          <param name="customBehavior">activeOnlyIfManualEntrySelected</param>

                          <module name="Button">
                            <param name="label">+</param>
                            <param name="allowSoftSubmit">False</param>
                            <param name="allowAutoSubmit">False</param>
                            <module name="CustomBehavior">
                              <param name="customBehavior">addNewFilterToFilterBar</param>
                            </module>
                          </module>
                        </module>
                      </module>
                    </module>
                  </module>
                </module>
              </module>

              <module name="ValueSetter">
                <param name="name">templatedFilters</param>
                <param name="value">| search $filters$</param>
                <param name="requiredKeys">filters</param>

                <module name="Search">
                  <param name="search">| inputlookup $lookupName$ $templatedFilters$ | table $fieldOrder$</param>

                  <module name="CustomBehavior">
                    <param name="customBehavior">changeResultsOffset</param>
                    <module name="Pulldown">
                      <param name="name">results.count</param>
                      <param name="label">Results per page:</param>
                      <param name="float">right</param>
                      <param name="staticOptions">
                        <list><param name="value">10</param></list>
                        <list><param name="value">20</param></list>
                        <list><param name="value">50</param><param name="selected">selected</param></list>
                        <list><param name="value">100</param></list>
                      </param>

                      <module name="HTML">
                        <param name="html"><![CDATA[
                          <br clear="all" /><h2 style="margin:0px;padding:0px;">$results.count$ rows found.</h2>
                        ]]></param>
                      </module>

                      <module name="Pager">
                        <module name="Table">
                          <param name="customBehavior">editableTable</param>
                        </module>
                        <module name="Pager" />
                      </module>
                    </module>
                  </module>
                </module>
              </module>
            </module>

            <module name="NullModule" group="add">

              <module name="HTML">
                <param name="html"><![CDATA[
                 <p>
                   Enter new thresholds one at a time.  Be careful to only click the "Add" button once for each.
                 </p>
                ]]></param>
              </module>
              <module name="Search">
                <param name="search">| inputlookup $lookupName$ | table $fieldOrder$ | head 1 | transpose | rename column as key "row 1" as value | fields - value</param>


                <module name="Multiplexer">
                  <param name="field">key</param>

                  <module name="HTML">
                    <param name="html"><![CDATA[
                      <div class="addNewRow">
                        <label>$key$</label>
                        <input type="text" name="$key$" onblur="Sideview.clearMessages()">
                      </div>
                    ]]></param>
                  </module>
                </module>
                <module name="HTML">
                  <param name="html"><![CDATA[
                  <br>
                  ]]></param>
                </module>

                <module name="Button">
                  <param name="allowSoftSubmit">False</param>
                  <param name="allowAutoSubmit">False</param>
                  <param name="label">Add</param>

                  <module name="Search">
                    <param name="search">replaced at runtime by customBehavior</param>
                    <param name="customBehavior">addNewRow</param>

                    <module name="CustomBehavior">
                      <param name="customBehavior">confirmNewRowAdded</param>
                      <param name="requiresDispatch">True</param>

                    </module>
                  </module>
                </module>
              </module>
            </module>


            <module name="Search" group="download">
              <param name="search">| inputlookup $lookupName$ | table $fieldOrder$</param>

              <module name="SearchControls">
                <param name="sections">export</param>
                <param name="float">left</param>
              </module>
            </module>


            <module name="HTML" group="reupload">
              <param name="html"><![CDATA[

  <form id="lookupUpdater" method="POST" action="REPLACED_AT_RUNTIME" enctype="multipart/form-data" >
    <p>
      If you wish you can upload a fresh csv to replace the one loaded.
    </p>
    <p>
      Note that the easiest way to do this is to first use the "Download CSV" tab first to get the existing csv file, as that file will already have the right columns.
    </p>
    <p>
      If you get an error that you don't understand, it may concern some non-UTF8 chararacters present in the file.  Common offenders are "non breaking space" characters and "magic quotes" characters inserted by MS word  (Please report it to our support alias though, as we are trying to improve the error messaging).
    </p>
    <label class="inputFileLabel">Local csv file:</label>

    <input type="file"   name="lookupFile" />
    <input type="hidden" name="lookupName" />
    <input type="hidden" name="currentView" />
    <!--
    Sideview OEM customers building custom views based on the
    Lookup Updater, or otherwise using the lookup controller,
    can pass the following variable to control the redirect
    after POST'ing to the controller.
    <input type="hidden" name="redirectOverride" value="/app/sideview_utils/framework_intro"/>
    -->


    <input type="hidden" name="splunk_form_key" value="FILLED BY JAVASCRIPT ONSUBMIT" />
    <br>
    <br>


    <fieldset>
      <input type="submit" class="splButton-primary" value="Update" />
    </fieldset>



  </form>
              ]]></param>
              <param name="customBehavior">neverReload</param>
            </module>

            <module name="HTML" group="download">
              <param name="html"><![CDATA[
                <p>
                  To download a copy of the call_quality_thresholds lookup as a csv file or to open it in Excel just click the icon below:
                </p>
              ]]></param>
            </module>





            <module name="NullModule" group="find">

              <module name="HTML">
                <param name="html"><![CDATA[
                  <p>
                    This tab helps you see whether you do indeed have the problem described in the "About" tab, ie disparate islands of CMR data that each have different quality stats reported, and what exactly they are.
                  </p>
                ]]></param>
              </module>

              <module name="TimePicker">
                <param name="default">Last 60 minutes</param>

                <module name="Pulldown">
                  <param name="name">optionalHeadCommand</param>
                  <param name="staticOptions">
                    <list>
                      <param name="label">search only the 100 most recent matching CMR records</param>
                      <param name="value">100</param>
                    </list>
                    <list>
                      <param name="label">search only the 1000 most recent matching CMR records</param>
                      <param name="value">1000</param>
                      <param name="selected">True</param>
                    </list>
                    <list>
                      <param name="label">search only the 10000 most recent matching CMR records</param>
                      <param name="value">10000</param>
                    </list>
                    <list>
                      <param name="label">search only the 100000 most recent matching CMR records</param>
                      <param name="value">100000</param>
                    </list>
                    <list>
                      <param name="label">all records</param>
                      <param name="value">all</param>
                    </list>
                  </param>
                  <!-- unfortunately we need the "all records" value to have a real value
                  and not "",  in order for links to prepopulate it to the all selection.
                  This ValueSetter is to whack away the token if it's equal to all.-->
                  <module name="ValueSetter">
                    <param name="name">optionalHeadCommand</param>
                    <param name="if.$optionalHeadCommand.rawValue$=all"></param>
                    <param name="default">| head $optionalHeadCommand$</param>

                    <module name="Search">
                      <param name="search">
`custom_index` sourcetype=cucm_cmr
$optionalHeadCommand$
| `get_quality`
| fillnull quality value="NONE"
| table numberPacketsLost numberPacketsSent numberPacketsReceived jitter latency MLQK SCS CS
| eval withMLQK=if(isnull(MLQK),0,1)
| eval withOldSchool=if(isnull(jitter),0,1)
| eval withNewSchool=if(isnull(SCS),0,1)
| stats count as total sum(withMLQK) as withMLQK sum(withOldSchool) as withOldSchool sum(withNewSchool) as withNewSchool
| eval MLQKPerc=if(withMLQK>0, tostring(round(100*withMLQK/total,2)) + "%","0%")
| eval newSchoolPerc=if(withNewSchool>0, tostring(round(100*withNewSchool/total,2)) + "%","0%")
| eval oldSchoolPerc=if(withOldSchool>0, tostring(round(100*withOldSchool/total,2)) + "%","0%")
| fields MLQKPerc newSchoolPerc oldSchoolPerc
| rename MLQKPerc as "percent with MLQK",  newSchoolPerc as "percent with CS and SCS", oldSchoolPerc as "percent with jitter, packetloss and latency"
| transpose
| rename "column" as "group" "row 1" as percent
                      </param>


                      <module name="Pager">
                        <module name="Table" />
                        <module name="Pager" />
                      </module>



                      <module name="Search">
                        <param name="search">
`custom_index` sourcetype=cucm_cmr
$optionalHeadCommand$
| `get_quality`
| fillnull quality value="NONE"
| table _time numberPacketsLost numberPacketsSent numberPacketsReceived jitter latency MLQK SCS CS
| eval withMLQK=if(isnull(MLQK),0,1)
| eval withOldSchool=if(isnull(jitter),0,1)
| eval withNewSchool=if(isnull(SCS),0,1)
| eval type=case(
withMLQK==1 AND withOldSchool==1 AND withNewSchool==1,"all 3 -- MLQK + Jitter/latency/packetloss + CS/SCS",
withMLQK==1 AND withOldSchool==1 AND withNewSchool==0,"MLQK + Jitter/latency/packetloss",
withMLQK==1 AND withOldSchool==0 AND withNewSchool==1,"MLQK + CS/SCS",
withMLQK==0 AND withOldSchool==1 AND withNewSchool==1,"Jitter/latency/packetloss  + CS/SCS",
withMLQK==1 AND withOldSchool==0 AND withNewSchool==0,"only MLQK",
withMLQK==0 AND withOldSchool==1 AND withNewSchool==0,"only jitter/latency/packetloss",
withMLQK==0 AND withOldSchool==0 AND withNewSchool==1,"only CS/SCS",
withMLQK==0 AND withOldSchool==0 AND withNewSchool==0,"!!! CMR has no MLQK, no jitter, no SCS"
)
| timechart count by type
                        </param>

                        <module name="ValueSetter">
                          <param name="arg.charting.chart.stackMode">stacked</param>

                          <module name="Chart" />

                          <pattern name="see_raw_search_syntax"/>
                        </module>
                      </module>







                    </module>
                  </module>
                </module>
              </module>
            </module>

            <module name="NullModule" group="reset">
              <module name="HTML">
                <param name="html"><![CDATA[
                  <p>
                    If you would like to discard your current thresholds completely and reset to the default thresholds that ship in the app, click the button below.
                  </p>
                  <p>
                    NOTE: Before doing this it is strongly recommended that you take a manual backup of your current thresholds by using the "download csv" tab.
                  </p>
                ]]></param>
              </module>

              <module name="Button">
                <param name="label">Reset quality thresholds to default</param>
                <param name="allowAutoSubmit">False</param>

                <module name="Search">
                  <param name="search">
| inputlookup call_quality_thresholds_default | outputlookup call_quality_thresholds
                  </param>

                  <module name="ProgressIndicator"/>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>

