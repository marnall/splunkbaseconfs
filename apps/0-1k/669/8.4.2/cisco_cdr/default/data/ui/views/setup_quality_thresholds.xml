    <module name="HTML">
      <param name="html"><![CDATA[
        $search$
      ]]></param>
    </module>
    -->
  </module>


  <module name="Search" layoutPanel="panel_row1_col1">
    <param name="search">replaced at runtime by customBehavior</param>
    <param name="customBehavior">receivePushesForRowDeletes</param>

    <module name="ProgressIndicator"></module>

    <module name="CustomBehavior">
      <param name="customBehavior">reloadEditedLookup</param>
    </module>
    <!--
    <module name="HTML">
      <param name="html"><![CDATA[
        $search$
      ]]></param>
    </module>
    -->
  </module>

</view>