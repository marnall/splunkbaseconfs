<module name="Pulldown">
  <param name="name">numberType</param>
  <param name="label">find</param>
  <param name="cssClass">abutRight</param>
  <param name="staticOptions">
    <list>
      <param name="label">calls to/from</param>
      <param name="value">all</param>
    </list>
    <list>
      <param name="label">calls from</param>
      <param name="value">callingParty</param>
    </list>
    <list>
      <param name="label">calls to</param>
      <param name="value">calledParty</param>
    </list>
  </param>

  <module name="TextField">
    <param name="name">number</param>
    <param name="customBehavior">inlineNumberLabel</param>
    <param name="default">enter number(s)</param>
    <param name="cssClass">abutLeft</param>

    <module name="TimePicker">
      <param name="default">Last 24 hours</param>
      <param name="label">within</param>

      <module name="ValueSetter">
        <param name="arg.cachedEarliest">$search.timeRange.earliest$</param>
        <param name="arg.cachedLatest">$search.timeRange.latest$</param>

        <module name="Search">
          <param name="search"><![CDATA[
| inputlookup data_types
| stats list(*) as * by data_type
| fillnull label app sourcetypes object_ids detail_view streaming_extractions value=""
| fields data_type label app sourcetypes object_ids detail_view streaming_extractions
          ]]></param>

          <module name="CheckboxPulldown">
            <param name="name">data_type</param>
            <param name="sticky">True</param>
            <param name="label">through</param>
            <param name="template">data_type="$value$"</param>
            <param name="valueField">data_type</param>
            <param name="labelField">label</param>
            <param name="allSelectedMessage">any system</param>
            <!-- TODO - replace with the hideIfOnlyOneOption param someday when Canary 2.1.1 is much old enough to be out of our supported window. -->
            <param name="customBehavior">hideIfOnlyOneOption</param>

            <module name="PostProcess">
              <param name="search">
search $data_type$
| stats list(data_type) as data_type list(*) as data_type.*
</param>

              <module name="ResultsValueSetter">
                <param name="fields">data_type data_type.label data_type.app, data_type.sourcetypes, data_type.object_ids, data_type.detail_view, data_type.streaming_extractions</param>

                <module name="CustomBehavior">
                  <param name="customBehavior">outputDataTypeKeys</param>

                  <module name="CheckboxPulldown">
                    <param name="name">type</param>
                    <param name="label">call types</param>
                    <param name="template">type="$value$"</param>
                    <param name="selectAllOptimization">omit</param>
                    <param name="staticOptions">
                      <list>
                        <param name="value">incoming</param>
                      </list>
                      <list>
                        <param name="value">outgoing</param>
                      </list>
                      <list>
                        <param name="value">internal</param>
                      </list>
                      <list>
                        <param name="value">tandem</param>
                      </list>
                    </param>

                    <insertionPoint />

                  </module>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</module>