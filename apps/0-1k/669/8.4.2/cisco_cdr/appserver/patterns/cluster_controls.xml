<module name="Search">
  <param name="search">| `get_clusters` | rename group as clusterGroup</param>

  <module name="PostProcess">
    <param name="search">stats count by clusterGroup</param>

    <module name="CheckboxPulldown">
      <param name="name">clusterGroup</param>
      <param name="label">cluster group</param>
      <param name="sticky">True</param>
      <param name="template">clusterGroup="$value$"</param>
      <param name="outerTemplate">$value$</param>
      <param name="valueField">$name$</param>
      <!-- TODO - replace MOST of this CB functionality with the hideIfOnlyOneOption param someday when Canary 2.1.1 is much old enough to be out of our supported window. -->
      <param name="customBehavior">hideIfOnlyOneOption</param>
      <param name="selectAllOptimization">omit</param>

      <module name="PostProcess">
        <param name="search">search * $clusterGroup$</param>

        <module name="CheckboxPulldown">
          <param name="name">clusterId</param>
          <param name="label">cluster</param>
          <param name="sticky">True</param>
          <param name="template">globalCallId_ClusterID=$value$</param>
          <param name="valueField">clusterId</param>
          <param name="labelField">label</param>
          <!-- TODO - replace MOST of this CB functionality with the hideIfOnlyOneOption param someday when Canary 2.1.1 is much old enough to be out of our supported window. -->
          <param name="customBehavior">hideIfOnlyOneOption</param>
          <param name="selectAllOptimization"><outerparam name="selectAllOptimization" default="omit" /></param>

          <insertionPoint />

        </module>
      </module>
    </module>
  </module>
</module>
