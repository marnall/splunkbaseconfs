              <param name="cssClass">menuItem</param>
              <param name="label">edit report (sideview ui)</param>
              <module name="Layer">

                <module name="Search">
                  <param name="search"><![CDATA[
      | rest $row.fields.uri$ splunk_server=local
      | rename eai:acl.sharing as sharing eai:acl.app as app author as owner title as name is_scheduled as scheduled request.ui_dispatch_view as page
      | eval scheduled=if(is_scheduled==1,"yes",null())
      | eval updated_epoch=strptime(updated,"%Y-%m-%dT%H:%M:%S")
