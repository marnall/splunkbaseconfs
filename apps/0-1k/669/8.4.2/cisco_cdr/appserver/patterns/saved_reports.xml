  <module name="Link">
    <param name="label">&#187; view and edit saved reports in Splunk Manager</param>

    <module name="Redirector">
      <param name="url">../../../../../manager/cisco_cdr/saved/searches</param>
      <param name="arg.app">cisco_cdr</param>
      <param name="arg.count">25</param>
    </module>
  </module>



</module>