<module name="CustomBehavior">
  <module name="HTML">
    <param name="cssClass">showIfSomeDataIndexed</param>
    <param name="clear">left</param>
    <param name="html"><![CDATA[
      <h3>License summary</h3>

      Sideview license:

      <span class="TrialVersionOnly">
        You are using a <a href="https://sideviewapps.com/documentation/sideview-trial-internal-use-license-agreement" target="_blank">trial license</a> which will expire <span class="licenseExpirationDate"></span>.
      </span>

      <span class="FullVersionPerpetualOnly">
        Your support and maintenance expires on <span class="supportExpirationDate"></span>.
      </span>

      <span class="FullVersionTermOnly">
        Your license and support expires on <span class="licenseExpirationDate"></span>.
      </span>
    ]]></param>
  </module>

  <module name="Search">
    <param name="search"><![CDATA[
| `get_splunk_license_status_and_expiration`
| eval linkClass=if(expires_in_days<14,"checklistConfSeverity3","")
    ]]></param>

    <module name="HTML">
      <param name="cssClass">showIfSomeDataIndexed</param>
      <param name="clear">left</param>
      <param name="html"><![CDATA[

        <br>
          <span class="$results[0].linkClass$" style="padding-left:0px;margin-left:0px;">
            Splunk license: $results[0].message$</span>
        <br>
        <br>

      ]]></param>
    </module>
  </module>
</module>
