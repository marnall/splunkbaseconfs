<module name="Search">
  <param name="search"><outerparam name="search" /></param>

  <module name="ValueSetter">
    <param name="arg.charting.chart"><outerparam name="chartType" default="column" /></param>
    <param name="arg.charting.chart.stackMode">stacked</param>
    <param name="arg.charting.chart.nullValueMode">connect</param>
    <param name="arg.selectedTab">Chart</param>
    <param name="arg.drilldownTarget">calls</param>
    <param name="arg.xField"><outerparam name="xField" default="_time" /></param>
    <param name="arg.stat"><outerparam name="stat" /></param>
    <param name="arg.yField"><outerparam name="yField" /></param>
    <param name="arg.zField"><outerparam name="zField" /></param>
    <param name="arg.searchterms"><outerparam name="searchterms" default="" /></param>


    <module name="Button">
      <param name="label">Customize</param>
      <param name="float">right</param>
      <module name="Redirector">
        <param name="url">calls</param>

        <param name="arg.mode">chart</param>
        <param name="arg.xField">$xField$</param>
        <param name="arg.stat">$stat$</param>
        <param name="arg.yField">$yField$</param>
        <param name="arg.zField">$zField$</param>
        <param name="arg.searchterms">$searchterms$</param>
        <param name="arg.advancedSearchLanguage">$advancedSearchLanguage.rawValue$</param>
        <param name="arg.charting.chart">$charting.chart$</param>

        <param name="arg.earliest">$search.timeRange.earliest$</param>
        <param name="arg.latest">$search.timeRange.latest$</param>
      </module>
    </module>

    <module name="HTML">
      <param name="html"><outerparam name="title" /></param>
    </module>

    <module name="Chart">
      <param name="enableResize">False</param>

      <module name="Redirector">
        <param name="url">calls</param>
        <param name="arg.earliest">$search.timeRange.earliest$</param>
        <param name="arg.latest">$search.timeRange.latest$</param>
        <param name="arg.numberType">all</param>
        <param name="arg.searchterms">$chart.searchTerms$ $searchterms$</param>
      </module>

    </module>
  </module>
</module>