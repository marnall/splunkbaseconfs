            <param name="field">Clients</param>
            <param name="classField">range</param>
            <param name="afterLabel">Clients</param>
            <param name="format">count</param>
          </module>
        </module>
        <module name="HiddenPostProcess" layoutPanel="panel_row3_col1_grp3" group="Client Stats" autoRun="True">
          <param name="search">eval host=lower(vm_name) | join max=0 host [ search `xendesktop_index` `xd_clientdetail_sourcetype` | `get_ica_devicetype` | eval host=lower(host) | stats count by host VDAClientID DeviceType] | stats dc(DeviceType) as Devices | eval range="session"</param>
          <module name="SingleValue">
