<view autoCancelInterval="90" isPersistable="true" isSticky="true" isVisible="true" objectMode="viewconf" onunloadCancelJobs="true" stylesheet="dashboard2.css" template="dashboard.html">
  <label>Security Center</label>
  <module name="AccountBar" layoutPanel="appHeader" />
  <module name="AppBar" layoutPanel="navigationHeader" />
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="actionsMenuFilter">dashboard</param>
  </module>
  <module name="GenericHeader" layoutPanel="panel_row1_col1">
    <param name="label">Windows Security Overview</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text">This dashboard provides a snapshot of Login and Logoff events in your virtual desktop deployment. Adjust the time range for this report by changing the time-range picker. You can filter this view by entering values in the fields below and pressing enter.</param>
  </module>
  <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
    <param name="searchWhenChanged">True</param>
    <param name="selected">Last 24 Hours</param>
    <module name="ExtendedFieldSearch" layoutPanel="panel_row2_col1_grp1">
      <param name="replacementMap">
        <param name="arg">
          <param name="HostingServerName" />
        </param>
      </param>
      <param name="field">HostingServerName</param>
      <param name="intention">
        <param name="name">stringreplace</param>
        <param name="arg">
          <param name="HostingServerName">
            <param name="prefix">HostingServerName="</param>
            <param name="fillOnEmpty">false</param>
            <param name="suffix">"</param>
          </param>
        </param>
      </param>
      <param name="label">Host Machine Server:</param>
      <module name="ExtendedFieldSearch" layoutPanel="panel_row2_col1_grp2">
        <param name="replacementMap">
          <param name="arg">
            <param name="vm_name" />
          </param>
        </param>
        <param name="field">CatalogName</param>
        <param name="intention">
          <param name="name">stringreplace</param>
          <param name="arg">
            <param name="CatalogName">
              <param name="prefix">CatalogName="</param>
              <param name="fillOnEmpty">false</param>
              <param name="suffix">"</param>
            </param>
          </param>
        </param>
        <param name="label">Desktop Catalog:</param>
        <module name="ExtendedFieldSearch" layoutPanel="panel_row2_col1_grp3">
          <param name="replacementMap">
            <param name="arg">
              <param name="vm_name" />
            </param>
          </param>
          <param name="field">vm_name</param>
          <param name="intention">
            <param name="name">stringreplace</param>
            <param name="arg">
              <param name="vm_name">
                <param name="prefix">vm_name="*</param>
                <param name="fillOnEmpty">false</param>
                <param name="suffix">*"</param>
              </param>
            </param>
          </param>
          <param name="label">VM Name:</param>
          <module name="HiddenSearch" layoutPanel="panel_row4_col1" autoRun="True">
            <param name="search">index=winevents sourcetype="WinEventLog:Security" EventCode=529 OR EventCode=529 OR EventCode=530 OR EventCode=531 OR EventCode=532 OR EventCode=533 OR EventCode=534 OR EventCode=535 OR EventCode=539 OR EventCode=4625 | stats count by host Account_Name</param>
            <module name="JobProgressIndicator" />
            <module name="HiddenPostProcess" layoutPanel="panel_row4_col1" group="Failed Login by Host" autoRun="True">
              <param name="search">| stats sum(count) as count by host | head 15</param>
              <param name="groupLabel">Failed Login bty Host</param>
              <module name="HiddenChartFormatter">
                <param name="chart">pie</param>
                <module name="FlashChart">
                  <param name="height">200px</param>
                </module>
              </module>
            </module>
            <module name="HiddenPostProcess" layoutPanel="panel_row4_col2" group="Failed Logins" autoRun="True">
              <param name="search">|stats sum(count) as count by host Account_Name</param>
              <param name="groupLabel">Failed Logins</param>
              <module name="SimpleResultsTable">
                <param name="drilldown">row</param>
                <param name="entityName">results</param>
                <param name="displayRowNumbers">False</param>
              </module>
              <module name="ViewRedirectorLink">
                <param name="viewTarget">flashtimeline</param>
                <param name="label">View Report Details</param>
              </module>
            </module>
            <module name="HiddenPostProcess" layoutPanel="panel_row4_col3" group="Failed Login by User" autoRun="True">
              <param name="search">| stats sum(count) as count by Account_Name | head 15</param>
              <param name="groupLabel">Failed Login by User</param>
              <module name="HiddenChartFormatter">
                <param name="chart">pie</param>
                <module name="FlashChart">
                  <param name="height">200px</param>
                </module>
              </module>
            </module>
          </module>
          <module name="HiddenSearch" layoutPanel="panel_row5_col1" autoRun="True">
            <param name="search">index=winevents Type="Success Audit" Success Audit sourcetype="WinEventLog:Security" (528 OR 540) (EventCode=528 OR EventCode=540) | fields - _raw | fields + host User_Name | stats count by host User_Name</param>
            <module name="JobProgressIndicator" />
            <module name="HiddenPostProcess" layoutPanel="panel_row5_col1" group="Successful Login by Host" autoRun="True">
              <param name="search">| stats sum(count) as count by host | head 15</param>
              <param name="groupLabel">Failed Login bty Host</param>
              <module name="HiddenChartFormatter">
                <param name="chart">pie</param>
                <module name="FlashChart">
                  <param name="height">200px</param>
                </module>
              </module>
            </module>
            <module name="HiddenPostProcess" layoutPanel="panel_row5_col2" group="Successful Logins" autoRun="True">
              <param name="search">|stats sum(count) as count by host User_Name</param>
              <param name="groupLabel">Failed Logins</param>
              <module name="SimpleResultsTable">
                <param name="drilldown">row</param>
                <param name="entityName">results</param>
                <param name="displayRowNumbers">False</param>
              </module>
              <module name="ViewRedirectorLink">
                <param name="viewTarget">flashtimeline</param>
                <param name="label">View Report Details</param>
              </module>
            </module>
            <module name="HiddenPostProcess" layoutPanel="panel_row5_col3" group="Successful Login by User" autoRun="True">
              <param name="search">| stats sum(count) as count by User_Name | head 15</param>
              <param name="groupLabel">Failed Login by User</param>
              <module name="HiddenChartFormatter">
                <param name="chart">pie</param>
                <module name="FlashChart">
                  <param name="height">200px</param>
                </module>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</view>
