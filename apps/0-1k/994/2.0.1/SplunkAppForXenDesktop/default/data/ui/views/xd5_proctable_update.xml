<view template="dashboard.html" stylesheet="dashboard2.css">
  <label>Update Process Lookup Table</label>
  <module name="AccountBar" layoutPanel="appHeader" />
  <module name="AppBar" layoutPanel="navigationHeader" />
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="actionsMenuFilter">dashboard</param>
  </module>
  <!--
        Global index summary counts
    -->
  <module name="GenericHeader" layoutPanel="panel_row1_col1">
    <param name="label">Update Process Lookup Table</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text">This view manually updates your Process Table lookup file to provide process name to software package mapping. Adjust the time range to pull information from further back in time for the update.</param>
  </module>
  <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
    <param name="selected">Last 24 Hours</param>
    <param name="searchWhenChanged">True</param>
    <module name="HiddenSearch" layoutPanel="panel_row1_col1" autoRun="True">
      <param name="search">index="winevents" sourcetype="WMI:ProcessDetails" Product!="" | inputlookup process_table append=t | rename Product as Application | table Application process_name Path | dedup Application process_name | outputlookup process_table</param>
      <module name="ViewRedirectorLink" layoutPanel="panel_row1_col1">
        <param name="viewTarget">flashtimeline</param>
        <param name="label">View Full Report</param>
      </module>
      <module name="JobProgressIndicator"></module>
      <module name="HiddenPostProcess" layoutPanel="panel_row3_col1" group="Virtual Desktop Lookup Details" autoRun="True">
        <param name="search">|table Application process_name</param>
        <module name="SimpleResultsTable" layoutPanel="panel_row3_col1">
          <param name="displayMenu">true</param>
          <param name="count">100</param>
          <param name="drilldown">all</param>
          <param name="entityName">results</param>
          <param name="displayRowNumbers">False</param>
          <!--    <module name="HiddenSearch">
<param name="search">`perfmon_brief` $vm_name$ |  `perfmon_desktop_lookup` | rename Value as value |  stats count by value counter object vm_name </param>
                  <module name="ConvertToIntention">
                    <param name="intention">
                      <param name="name">stringreplace</param>
                      <param name="arg">
                        <param name="vm_name">
                          <param name="prefix">vm_name=</param>
                          <param name="fillOnEmpty">True</param>
                          <param name="value">$click.value$</param>
                        </param>
                      </param>
                    </param>
                    <module name="ViewRedirector">
                      <param name="viewTarget">perf_overview_drilldown</param>
                    </module>
                  </module>
                </module> -->
        </module>
      </module>
    </module>
  </module>
</view>
