<form version="1.1">
    <label>Classloading</label>
    <fieldset autoRun="true">
        <input type="dropdown" token="host">
            <label>Choose host</label>
            <prefix>host="</prefix>
            <suffix>"</suffix>
            <choice value="*">All</choice>
            <default>*</default>
            <fieldForValue>host</fieldForValue>
            <fieldForLabel>host</fieldForLabel>
            <search>
                <query>
                | metadata type=hosts index=main | dedup host | table host
                </query> 
                <earliest>-1d@d</earliest>
                <latest>now</latest>
            </search>
           
        </input>
        <input type="dropdown" token="jvmDescription">
            <label>Choose JVM Description</label>
            <prefix>jvmDescription="</prefix>
            <suffix>"</suffix>
            <choice value="*">All</choice>
            <default>*</default>
            <fieldForValue>jvmDescription</fieldForValue>
            <fieldForLabel>jvmDescription</fieldForLabel>
            <search>
                <query>
                index=main sourcetype=jmx $host$ | dedup jvmDescription | table jvmDescription
                </query>
                <earliest>-1d@d</earliest>
                <latest>now</latest>
            </search>
            
        </input>
        <input type="time">
            <default>Last 4 hours</default>
        </input>
    </fieldset>
    <row>
        <chart>
            <title>Classloading by JVM and Host</title>
            <search>
                <query>
                index=main sourcetype=jmx $host$ $jvmDescription$ mbean_domain="java.lang" mbean_property_type="ClassLoading" | chart first(total) as "Total" first(current) as "Current" first(unloaded) as "Unloaded" by host jvmDescription
            </query>
           </search>
            <option name="charting.chart">column</option>
            <option name="charting.axisTitleX.text">Host</option>
            <option name="charting.axisTitleY.text">Class Count</option>
        </chart>
    </row>
</form>
