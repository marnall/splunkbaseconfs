<jmxpoller>
  
<formatter className="com.dtdsoftware.splunk.formatter.JSONMBeanFormatter" />

<!-- set your JMX Remote host/port accordingly -->

<jmxserver host="localhost" jvmDescription="mytomcat" jmxport="9000">


<mbean domain="Catalina" properties="type=GlobalRequestProcessor,name=&quot;http-nio-8080&quot;">

<attribute name="requestCount" outputname="requestCount"/>

</mbean>

<mbean domain="Catalina" properties="type=Connector,port=8080">

<attribute name="maxPostSize" outputname="maxPostSize"/>

</mbean>

<mbean domain="Catalina" properties="type=SocketProperties,name=&quot;http-nio-8080&quot;">

<attribute name="appReadBufSize" outputname="appReadBufSize"/>
<attribute name="appWriteBufSize" outputname="appWriteBufSize"/>
<attribute name="bufferPool" outputname="bufferPool"/>
<attribute name="bufferPoolSize" outputname="bufferPoolSize"/>
<attribute name="directBuffer" outputname="directBuffer"/>
<attribute name="directBufferPool" outputname="directBufferPool"/>
<attribute name="directSslBuffer" outputname="directSslBuffer"/>
<attribute name="eventCache" outputname="eventCache"/>
<attribute name="modelerType" outputname="modelerType"/>
<attribute name="processorCache" outputname="processorCache"/>
<attribute name="soLingerOn" outputname="soLingerOn"/>
<attribute name="soLingerTime" outputname="soLingerTime"/>
<attribute name="soTimeout" outputname="soTimeout"/>
<attribute name="tcpNoDelay" outputname="tcpNoDelay"/>
<attribute name="timeoutInterval" outputname="timeoutInterval"/>
<attribute name="unlockTimeout" outputname="unlockTimeout"/>

</mbean>


</jmxserver>

</jmxpoller>