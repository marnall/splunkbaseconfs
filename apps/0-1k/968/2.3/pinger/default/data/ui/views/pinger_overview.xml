<form>
  <label>Pinger Overview</label>
  <fieldset autoRun="true">
    <input type="dropdown" token="selSite" submitButton="false">
      <label>Site</label>
      <choice value="*">All Sites</choice>
      <populatingSearch fieldForValue="site" fieldForLabel="site">
        <![CDATA[| inputlookup pinger_sites]]>
      </populatingSearch>
      <default>*</default>
      <seed>*</seed>
    </input>
    <input type="dropdown" token="selProd" submitButton="false">
      <label>Production</label>
      <choice value="1">Yes</choice>
      <choice value="0">No</choice>
      <choice value="*">All</choice>
      <default>1</default>
      <seed>1</seed>
    </input>
    <input type="dropdown" token="selExt" submitButton="false">
      <label>Visibility</label>
      <choice value="1">External</choice>
      <choice value="0">Internal</choice>
      <choice value="*">All</choice>
      <default>1</default>
      <seed>1</seed>
    </input>                                          
    <input type="time">
      <label>Time Range</label>
      <default>Last 24 Hours</default>
    </input>
  </fieldset>
  <row>
      <chart>
        <title>General Availability (Percent)</title>
        <searchTemplate>
           eventtype=pinger:heartbeat site="$selSite$" ext=$selExt$ prod=$selProd$ 
           | eval isUp = if(status==200,1,0)
           | stats avg(isUp) as numUp
           | eval upPct = round(numUp*100,4)
           | fields upPct
        </searchTemplate>
        <option name="charting.chart">radialGauge</option>
        <option name="charting.chart.nullValueMode">gaps</option>
        <option name="charting.chart.rangeValues">[95,97,99,100]</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.gaugeColors">[0xbf3030,0xffe800,0x84e900]</option>
        <option name="charting.layout.splitSeries">false</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.secondaryAxis.maximumNumber">""</option>
        <option name="charting.secondaryAxis.minimumNumber">""</option>
        <option name="charting.secondaryAxis.scale">""</option>
      </chart>
    <chart>
      <title>Errors</title>
      <searchTemplate>eventtype=pinger:heartbeat site="$selSite$" status!=200 ext=$selExt$ prod=$selProd$
       | timechart count(status) as "Errors" by location</searchTemplate>
      <option name="charting.chart">column</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.axisTitleX.text">Time</option>
      <option name="charting.axisTitleY.text">Errors</option>
    </chart>
  </row>
  <row>
    <chart>
      <title>Average DNS Resolution Time</title>
      <searchTemplate>eventtype=pinger:heartbeat site="$selSite$" ext=$selExt$ prod=$selProd$
      | eval mdns = dns * 1000
      | timechart avg(mdns) by location</searchTemplate>
      <option name="charting.chart">area</option>
      <option name="charting.axisTitleX.text">Timeframe</option>
      <option name="charting.axisTitleY.text">Time (ms)</option>
    </chart>
    <chart>
      <title>Average Connection Time</title>
      <searchTemplate>eventtype=pinger:heartbeat site="$selSite$" ext=$selExt$ prod=$selProd$
      | eval mconnect = connect_time * 1000
      | timechart avg(mconnect) by location</searchTemplate>
      <option name="charting.chart">area</option>
      <option name="charting.axisTitleX.text">Timeframe</option>
      <option name="charting.axisTitleY.text">Time (ms)</option>
    </chart>
    <chart>
      <title>Average Response Time</title>
      <searchTemplate>eventtype=pinger:heartbeat site="$selSite$" ext=$selExt$ prod=$selProd$
      | eval mreq = request_time * 1000
      | timechart avg(mreq) by location</searchTemplate>
      <option name="charting.chart">area</option>
      <option name="charting.axisTitleX.text">Timeframe</option>
      <option name="charting.axisTitleY.text">Time (ms)</option>
    </chart>
  </row>
  <row>
    <chart>
      <title>Error Rates</title>
      <searchTemplate>eventtype=pinger:heartbeat site="$selSite$" ext=$selExt$ prod=$selProd$
      | lookup pinger_errors code as status OUTPUTNEW description
      | search description="*"
      | timechart count by description</searchTemplate>
      <option name="charting.chart">line</option>
      <option name="charting.axisTitleX.text">Timeframe</option>
      <option name="charting.axisTitleY.text">Error Count</option>
    </chart>
  </row>
</form>
