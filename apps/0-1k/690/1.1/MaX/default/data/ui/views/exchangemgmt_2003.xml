<view template="dashboard.html">
  <label>Exchange Server Management Summary</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
  <module name="AppBar" layoutPanel="navigationHeader"/>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  
    <module name="SearchBar" layoutPanel="splSearchControls-inline">
        <param name="useAssistant">true</param>
        <param name="useTypeahead">true</param>
        <param name="useOwnSubmitButton">False</param>
        <module name="TimeRangePicker">
            <param name="selected">All time</param>
            <module name="SubmitButton">
                <param name="allowSoftSubmit">True</param>
                <module name="ViewRedirector" layoutPanel="mainSearchControls">
                    <param name="viewTarget">flashtimeline</param>
                </module>
            </module>
        </module>
    </module>
    
  <module name="ServerSideInclude" layoutPanel="panel_row1_col1" group="Using Splunk for Exchange Server Management">
        <param name="src">exchangemgmt.html</param>
  </module>
  
  <module name="HiddenSavedSearch" layoutPanel="panel_row2_col1" group="Mail Size Flow" autoRun="True">
    <param name="savedSearch">ExchangeSrv Mail Size Flow</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">line</param>
      <param name="primaryAxisTitle.text">Time</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>
    
   
  <module name="HiddenSavedSearch" layoutPanel="panel_row3_col1" group="Recipient Mail Size timechart" autoRun="True">
    <param name="savedSearch">ExchangeSrv Recipient Maile Size timechart</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">column</param>
      <param name="primaryAxisTitle.text">Time</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row3_col2" group="Sender Mail Size timechart" autoRun="True">
    <param name="savedSearch">ExchangeSrv Sender Mail Size timechart</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">column</param>
      <param name="primaryAxisTitle.text">Time</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row4_col1" group="Mail in queqe count by size timechart" autoRun="True">
    <param name="savedSearch">ExchangeSrv Mail in queue count by size timechart</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">line</param>
      <param name="primaryAxisTitle.text">Time</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row4_col2" group="Mail in queue timechart" autoRun="True">
    <param name="savedSearch">ExchangeSrv Mail in queue timechart</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">line</param>
      <param name="primaryAxisTitle.text">Time</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>
</view>
