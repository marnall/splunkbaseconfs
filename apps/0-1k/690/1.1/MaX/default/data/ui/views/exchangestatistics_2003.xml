<view template="dashboard.html">
  <label>Exchange Server Management Statistics</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
  <module name="AppBar" layoutPanel="navigationHeader"/>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  
    <module name="SearchBar" layoutPanel="splSearchControls-inline">
        <param name="useAssistant">true</param>
        <param name="useTypeahead">true</param>
        <param name="useOwnSubmitButton">False</param>
        <module name="TimeRangePicker">
            <param name="selected">All time</param>
            <module name="SubmitButton">
                <param name="allowSoftSubmit">True</param>
                <module name="ViewRedirector" layoutPanel="mainSearchControls">
                    <param name="viewTarget">flashtimeline</param>
                </module>
            </module>
        </module>
    </module>
    
  <module name="ServerSideInclude" layoutPanel="panel_row1_col1" group="Using Splunk for Exchange Server Statics">
        <param name="src">exchangestatistics.html</param>
  </module>     
   
  <module name="HiddenSavedSearch" layoutPanel="panel_row2_col1" group="Top Recipients" autoRun="True">
    <param name="savedSearch">ExchangeSrv Top Recipients</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">pie</param>
      <param name="chart.nullValueMode">gaps</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row2_col2" group="Top Senders" autoRun="True">
    <param name="savedSearch">ExchangeSrv Top Senders</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">pie</param>
      <param name="primaryAxisTitle.text">Time</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row3_col1" group="Top Recipients by size" autoRun="True">
    <param name="savedSearch">ExchangeSrv Top Recipients by total mail size</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">bar</param>
      <param name="primaryAxisTitle.text">Recipient Address</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row3_col2" group="Top Senders by size" autoRun="True">
    <param name="savedSearch">ExchangeSrv Top Senders by total mail size</param>
    <param name="useHistory">None</param>
    <module name="HiddenChartFormatter">
      <param name="chart">bar</param>
      <param name="primaryAxisTitle.text">Sender Address</param>
      <module name="FlashChart">
      </module>
    </module>
  </module>
</view>
