<view template="dashboard.html">
  <label>Exchange Server Management Summary</label>

  <module name="AccountBar" layoutPanel="appHeader"/>

  <module name="AppBar" layoutPanel="navigationHeader"/>

  <module name="Message" layoutPanel="messaging">
    <param name="clearOnJobDispatch">False</param>
    <param name="filter">*</param>
    <param name="maxSize">10</param>
  </module>

  <module name="SearchBar" layoutPanel="splSearchControls-inline">
    <param name="useAssistant">True </param>
    <param name="useTypeahead">True</param>
    <param name="useOwnSubmitButton">False</param>
 
    <module name="TimeRangePicker">
      <param name="default">True</param>

      <module name="SubmitButton">
        <param name="allowSoftSubmit">True</param>

        <module name="ViewRedirector" layoutPanel="viewHeader">
          <param name="viewTarget">flashtimeline</param>
        </module>

      </module>

    </module>

  </module>
  <module name="ServerSideInclude" layoutPanel="panel_row1_col1" group="Mails Traffic Light">
    <param name="src">MailsTrafficLight.html</param>

    <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1_grp1" autoRun="True">
        <param name="savedSearch">Exchange2007 BADMAIL count</param>
        <param name="useHistory">None</param>
     
        <module name="SingleValue">
          <param name="field">count</param>
          <param name="classField">range</param>
          <param name="afterLabel">BADMAIL</param>
          <param name="linkFields">result</param>
          <param name="linkSearch">sourcetype="exchangelog2007" event_id="BADMAIL"</param>        
          <param name="linkView">flashtimeline </param>
        </module>

    </module>

    <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1_grp2" autoRun="True">
      <param name="savedSearch">Exchange2007 FAILMAIL count</param>
      <param name="useHistory">None</param>

      <module name="SingleValue">
        <param name="field">count</param>
        <param name="classField">range</param>
        <param name="afterLabel">FAILMAIL</param>
        <param name="linkFields">result</param>
        <param name="linkSearch">sourcetype="exchangelog2007" event_id="FAIL"</param>
        <param name="linkView">flashtimeline</param>
      </module>

    </module>

    <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1_grp3" autoRun="True">
      <param name="savedSearch">Exchange2007 DUPLICATEDELIVER count</param>
      <param name="useHistory">None</param>

      <module name="SingleValue">
        <param name="field">count</param>
        <param name="classField">range</param>
        <param name="afterLabel">DUPLICATE DELIVER</param>
        <param name="linkFields">result</param>
        <param name="linkSearch">sourcetype="exchangelog2007" event_id="DUPLICATEDELIVER"</param>
        <param name="linkView">flashtimeline</param>
      </module>

    </module>

    <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1_grp4" autoRun="True">
      <param name="savedSearch">Exchange2007 DEFER count</param>
      <param name="useHistory">None</param>

      <module name="SingleValue">
        <param name="field">count</param>
        <param name="classField">range</param>
        <param name="afterLabel">DEFER</param>
        <param name="linkFields">result</param>
        <param name="linkSearch">sourcetype="exchangelog2007" event_id="DEFER"</param>
        <param name="linkView">flashtimelune</param>
      </module>

    </module>

  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row2_col1" group="Fail mails source components" autoRun="True">
    <param name="savedSearch">Exchange2007 FAILMAIL Source Component</param>
    <param name="useHistory">None</param>

    <module name="HiddenChartFormatter">
      <param name="chart">pie</param>
      <param name="primaryAxisTitle.text">components</param>
      <param name="secondaryAxisTitle.text">Fail counts</param>
      <param name="legend.placement">right</param>

      <module name="FlashChart">

        <module name="ConvertToDrilldownSearch">

          <module name="ViewRedirector">
            <param name="viewTarget">flashtimeline</param>
          </module>

        </module>

      </module>

    </module>

  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row3_col1" group="Duplicat deliver mails recipients" autoRun="True">
    <param name="savedSearch">Exchange2007 DuplicateDeliver Mails Recipient</param>
    <param name="useHistory">None</param>

    <module name="FlashChart">

      <module name="ConvertToDrilldownSearch">

        <module name="ViewRedirector">
          <param name="viewTarget">flashtimeline</param>
        </module>

      </module>

    </module>

    <module name="HiddenChartFormatter">
      <param name="chart">column</param>
      <param name="primaryAxisTitle.text">Recipeints</param>
      <param name="secondaryAxisTitle.text">Fail counts</param>
      <param name="legend.placement">right</param>
    </module>


  </module>  

</view>
