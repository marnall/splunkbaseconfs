<view template="dashboard.html">
  <label>Exchange Server Management Statistics</label>

  <module name="AccountBar" layoutPanel="appHeader"/>

  <module name="AppBar" layoutPanel="navigationHeader"/>

  <module name="Message" layoutPanel="messaging">
    <param name="clearOnJobDispatch">False</param>
    <param name="filter">*</param>
    <param name="maxSize">10</param>
  </module>

  <module name="SearchBar" layoutPanel="splSearchControls-inline">
    <param name="useAssistant">True </param>
    <param name="useTypeahead">True</param>
    <param name="useOwnSubmitButton">False</param>
 
    <module name="TimeRangePicker">
      <param name="default">True</param>

      <module name="SubmitButton">
        <param name="allowSoftSubmit">True</param>

        <module name="ViewRedirector" layoutPanel="viewHeader">
          <param name="viewTarget">flashtimeline</param>
        </module>

      </module>

    </module>

  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1" group="Send mail time chart" autoRun="True" >
      <param name="savedSearch">Exchange2007 send mail count timechart</param>
      <param name="useHistory">None</param>
     
      <module name="HiddenChartFormatter">
        <param name="chart">line</param>
        <param name="primaryAxisTitle.text">Time</param>
        <param name="secondaryAxisTitle.text">emails amount</param>
        <param name="legend.placement">right</param> 

        <module name="FlashChart">

          <module name="ConvertToDrilldownSearch">

            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param> 
            </module>

          </module>

        </module>

    </module>

  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row2_col1" group="Exchange 2007 Server Top Senders" autoRun="True">
    <param name="savedSearch">Exchange2007 Top Senders</param>
    <param name="useHistory">None</param>
    
    <module name="HiddenChartFormatter">
      <param name="chart">pie</param>
    
      <module name="FlashChart">
        <module name="ConvertToDrilldownSearch">
          <module name="ViewRedirector">
            <param name="viewTarget">flashtimeline</param>
          </module>
        </module>
      </module>
    </module>
  </module>


  <module name="HiddenSavedSearch" layoutPanel="panel_row2_col2" group="Exchange 2007 Server Top Recipeints" autoRun="True">
    <param name="savedSearch">Exchange2007 Top Recipients</param>
    <param name="useHistory">None</param>

    <module name="HiddenChartFormatter">
      <param name="chart">pie</param>
      <param name="primaryAxisTitle.text">Recipients</param>
      <param name="secondaryAxisTitle.text">emails amount</param>
      <param name="legend.placement">right</param>

      <module name="FlashChart">

        <module name="ConvertToDrilldownSearch">

          <module name="ViewRedirector">
            <param name="viewTarget">flashtimeline</param>
          </module>

        </module>

      </module>

    </module>

  </module>

  <module name="HiddenSavedSearch" layoutPanel="panel_row3_col1" group="Top Senders by Total Mails Size" autoRun="True">
    <param name="savedSearch">Exchange2007 Top Senders by Total Mails Size</param>
    <param name="useHistory">None</param>

    <module name="HiddenChartFormatter">
      <param name="chart">pie</param>
      <param name="primaryAxisTitle.text">Total Mail Size (MB)</param>
      <param name="secondaryAxisTitle.text">User Account</param>
      <param name="legend.placement">right</param>

      <module name="FlashChart">
        <module name="ConvertToDrilldownSearch">
          <module name="ViewRedirector">
            <param name="viewTarget">flashtimeline</param>
          </module>
        </module>
      </module>

    </module>

  </module>



  <module name="HiddenSavedSearch" layoutPanel="panel_row3_col2" group="Top Recipeints by Total Mail Size" autoRun="True">
    <param name="savedSearch">Exchange2007 Top Recipients by Total Mails Size</param>
    <param name="useHistory">None</param>

    <module name="HiddenChartFormatter">
      <param name="chart">pie</param>
      <param name="primaryAxisTitle.text">Total Mail Size (MB)</param>
      <param name="secondaryAxisTitle.text">User Account</param>
      <param name="legend.placement">right</param>

      <module name="FlashChart">
        <module name="ConvertToDrilldownSearch">
          <module name="ViewRedirector">
            <param name="viewTarget">flashtimeline</param>
          </module>
        </module>
      </module>

    </module>

  </module>


</view>
