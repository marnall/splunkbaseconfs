<form class="formsearch">
   <label>Relational Analysis</label>
    <fieldset>

    <input type="dropdown" token="Sender" searchWhenChanged="true">

      <label>Selected Sender:</label>

      <default>ALL Senders(*)</default>

      <populatingSearch fieldForValue="Sender" fieldForLabel="Sender"><![CDATA[sourcetype=exchangelog2003 AND EventID=1019 | rex "(?i)^\s*(?:[^#\t]*\t){19}(?P<Sender>[^\t]*)" | stats count by Sender]]></populatingSearch>

      <choice value="*">ALL Senders(*)</choice>

    </input>
	
	    <input type="dropdown" token="Recipient" searchWhenChanged="true">

      <label>Selected Recipient:</label>

      <default>ALL Recipient(*)</default>

      <populatingSearch fieldForValue="Recipient" fieldForLabel="Recipient"><![CDATA[sourcetype=exchangelog2003 EventID=1019 | rex "(?i)^\s*(?:[^#\t]*\t){7}(?P<Recipient>[^\t]*)" | stats count by Recipient]]></populatingSearch>

      <choice value="*">ALL Recipient(*)</choice>

    </input>

  </fieldset>



  <row>

      <table>

          <title>Sender(s) AND Recipeint(s)</title>

          <searchTemplate>sourcetype="exchangelog2003" EventID=1019  Sender=$Sender$ Recipient=$Recipient$ | fields + Subject, Sender, Recipient</searchTemplate>

          <option name="count">20</option>


      </table>

  </row>
  
  <row>  
        <table>

          <title>Gossip</title>

          <searchTemplate>sourcetype="exchangelog2003" AND EventID=1019 Sender=$Sender$ | stats count by Subject  | fields Subject, count</searchTemplate>

          <option name="count">20</option>


      </table>

  </row>

