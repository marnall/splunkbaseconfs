<form class="formsearch">
  <label>Attackers Stats</label>

  <fieldset>
       <input type="dropdown" token="hostname" searchWhenChanged="true">
          <label>BIG-IP Hostname:</label>
          <default>*</default>
          <populatingSearch fieldForValue="hostname" fieldForLabel="hostname"> sourcetype="asm_log" dos_attack_name != "" | stats count by hostname </populatingSearch>
          <choice value="*">all</choice>
       </input>

       <input type="dropdown" token="context_name" searchWhenChanged="true">
          <label>Context Name:</label>
          <populatingSearch fieldForValue="context_name" fieldForLabel="context_name"> sourcetype="asm_log" dos_attack_name != "" | stats count by context_name </populatingSearch>
          <choice value="*">all</choice>
       </input>

        <input type="time" searchWhenChanged="true"/>
  </fieldset>

  <row>
    <html><center><h1>Attackers - DoS</h1></center></html>
  </row>

  <row>
      <chart>
          <title>Time Distribution of Dropped Requests by Attack ID (total)</title>
          <searchTemplate>sourcetype="asm_log" dos_attack_name != "" context_name=$context_name$ `Anomalies_ip_count_time_distribution($hostname$)`</searchTemplate>
          <option name="charting.chart">column</option>
          <option name="charting.secondaryAxisTitle.text">Count</option>
      </chart>
  </row>
  <row>
      <chart>
          <title>Attacking Countries (total)</title>
          <searchTemplate>sourcetype="asm_log" dos_attack_name != "" context_name=$context_name$ `Anomalies_attacking_countries_total($hostname$)`</searchTemplate>
          <option name="charting.chart">pie</option>
      </chart>
      <chart>
          <title>Attacking Countries by Attack ID (total)</title>
          <searchTemplate>sourcetype="asm_log" dos_attack_name != "" context_name=$context_name$ `Anomalies_attacking_countries_per_attack_id($hostname$)`</searchTemplate>
          <option name="charting.chart">bar</option>
          <option name="charting.secondaryAxisTitle.text">Dropped Requests Count</option>

      </chart>
  </row>
  <row>
      <chart>
          <title>Attacking IPs (total)</title>
          <searchTemplate>sourcetype="asm_log" dos_attack_name != "" context_name=$context_name$ `Anomalies_attacking_IPs_total($hostname$)`</searchTemplate>
          <option name="charting.chart">pie</option>
      </chart>
      <chart>
          <title>Attacking IPs by Attack ID (total)</title>
          <searchTemplate>sourcetype="asm_log" dos_attack_name != "" context_name=$context_name$ `Anomalies_attacking_IPs_per_attack_id($hostname$)`</searchTemplate>
          <option name="charting.chart">bar</option>
          <option name="charting.secondaryAxisTitle.text">Dropped Requests Count</option>
      </chart>
  </row>
  <row>
      <table>
          <title>Dropped Requests Count by IPs (total)</title>
          <searchTemplate>sourcetype="asm_log" dos_attack_name != "" context_name=$context_name$ `Anomalies_ip_to_country($hostname$)`</searchTemplate>
      </table>
  </row>


</form>