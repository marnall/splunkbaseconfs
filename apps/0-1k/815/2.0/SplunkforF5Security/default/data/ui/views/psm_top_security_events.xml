<form class="formsearch">
  <label>Top Security Events</label>

  <fieldset>
       <input type="dropdown" token="hostname" searchWhenChanged="true">
          <label>BIG-IP Hostname:</label>
          <default>*</default>
          <populatingSearch fieldForValue="hostname" fieldForLabel="hostname"> sourcetype = psm_log http_protocol_indication=HTTP OR http_protocol_indication=HTTPS | stats count by hostname</populatingSearch>
                  <choice value="*">all</choice>
       </input>
       <input type="dropdown" token="context_name" searchWhenChanged="true">
          <label>Context Name:</label>
          <default>*</default>
          <populatingSearch fieldForValue="context_name" fieldForLabel="context_name"> sourcetype = psm_log http_protocol_indication=HTTP OR http_protocol_indication=HTTPS | stats count by context_name</populatingSearch>
                  <choice value="*">all</choice>
       </input>

        <input type="time" searchWhenChanged="true"/>
  </fieldset>


  <row>
    <html><center><h1>Top Security Events - PSM HTTP</h1></center></html>
  </row>

  <row>
      <chart>
          <title>Top Violations</title>
          <searchTemplate>sourcetype="psm_log" context_name=$context_name$ http_protocol_indication=HTTP OR http_protocol_indication=HTTPS `Top_violations_by_webapp_and_device($hostname$)`</searchTemplate>
          <option name="charting.chart">pie</option>
      </chart>
      <chart>
          <title>Top Attack Signatures</title>
          <searchTemplate>sourcetype="psm_log" context_name=$context_name$ http_protocol_indication=HTTP OR http_protocol_indication=HTTPS `Top_signatures($hostname$)`</searchTemplate>
          <option name="charting.chart">pie</option>
      </chart>

  </row>

</form>
