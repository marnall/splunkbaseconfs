
# Application-level permissions

[]
access = read : [ * ], write : [ admin, power ]

### EVENT TYPES

[eventtypes]
export = system


### PROPS

[props]
export = system


### TRANSFORMS

[transforms]
export = system


### VIEWSTATES: even normal users should be able to create shared viewstates

[viewstates]
access = read : [ * ], write : [ * ]
export = system

[app/ui]
version = 4.2
owner = nobody

[nav/default]
version = 4.2
owner = nobody

[savedsearches/baseball%20-%20Baseball%20America%20Headlines]
version = 4.2
owner = nobody

[savedsearches/baseball%20-%20mlb%20headlines]
version = 4.2
owner = nobody
export = none
access = read : [ * ]

[views/baseball_dashboard]
version = 4.2
owner = nobody

[workflow_actions/get_article]
version = 4.2
owner = nobody
export = none
access = read : [ * ], write : [ admin ]

