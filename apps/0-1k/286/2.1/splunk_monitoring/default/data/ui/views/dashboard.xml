<view template="dashboard.html" stylesheet="dashboard.css">
  <label>Splunk Monitoring</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
  <module name="AppBar" layoutPanel="navigationHeader"/>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="actionsMenuFilter">dashboard</param>
  </module>

  <!-- About The Splunk Monitoring Application-->
  <module name="StaticContentSample" layoutPanel="panel_row1_col1" group="About The Splunk Monitoring Application">
    <param name="text">The Splunk Monitoring Application performs the following actions:
    <![CDATA[<ul><li>Creates a new "splunk_monitoring" index to store it's data.</li><li>Runs a scripted input every hour (interval can be changed in inputs.conf).</li><li>Script in bin directory examines the contents of $SPLUNK_HOME/etc/system/local/tags.conf file and runs a nmap to test each host's status.</li><li>Provides a "Splunk Monitoring" dashboard to display the status of all hosts monitored.</li></ul>]]>
    Requirements:
    <![CDATA[<ul><li>Tested under Splunk 5.0, build 140868.</li><li>Correct path to "nmap" executable in "bin/splunk_port_monitor.sh".</li><li>Correct path to tags.conf file in "bin/splunk_port_monitor.sh".</li><li>Correct path to "bin/splunk_port_monitor.sh" in inputs.conf file.</li></ul>]]>
    </param>
  </module>

  <!-- Overall Splunk Agent Status -->
  <module name="StaticContentSample" layoutPanel="panel_row2_col1" group="Overall Splunk Agent Status">
    <param name="text">This lists a summary of the status of Splunk agents.</param>
  </module>
  <module name="HiddenSearch" layoutPanel="panel_row2_col1_grp1" autoRun="true">
    <param name="search">index="splunk_monitoring" earliest=-1h | dedup server | top status</param>
    <module name="SimpleResultsHeader">
        <param name="entityName">results</param>
        <param name="headerFormat">Status Types: (%(count)s)</param>
    </module>
  </module>
  <module name="Sorter" layoutPanel="panel_row2_col1_grp1">
    <param name="sortKey">status</param>
    <param name="sortDir">desc</param>
    <param name="fields">
      <list>
        <param name="label">Status</param>
        <param name="value">status</param>
      </list>
      <list>
        <param name="label">Count</param>
        <param name="value">count</param>
      </list>
      <list>
        <param name="label">Percent</param>
        <param name="value">percent</param>
      </list>
    </param>
  <module name="Paginator" >
     <param name="count">10</param>
     <param name="entityName">settings</param>
     <param name="maxPages">10</param>
     <module name="SearchLinkLister">
       <param name="settingToCreate">list4</param>
       <param name="search">index="splunk_monitoring" earliest=-1h | dedup server | top status</param>
       <param name="searchFieldsToDisplay">
      <list>
        <param name="label">status</param>
        <param name="value">status</param>
      </list>
      <list>
        <param name="label">count</param>
        <param name="value">count</param>
      </list>
      <list>
        <param name="label">percent</param>
        <param name="value">percent</param>
      </list>
       </param>
         <module name="ConvertToIntention">
           <param name="settingToConvert">list4</param>
           <param name="intention">
             <param name="name">addterm</param>
             <param name="arg">
               <param name="status">$target$</param>
             </param>
           </param>
           <module name="ViewRedirector">
             <param name="viewTarget">flashtimeline</param>
           </module>
         </module>
       </module>
     </module>
  </module>


