<view template="dashboard.html">
	<label>Appliance Overview</label>
	<module name="AccountBar" layoutPanel="appHeader" />
	<module name="AppBar" layoutPanel="navigationHeader" />
	<module name="Message" layoutPanel="messaging">
		<param name="filter">*</param>
		<param name="clearOnJobDispatch">False</param>
		<param name="maxSize">1</param>
	</module>
	<module name="TitleBar" layoutPanel="viewHeader">
		<param name="showActionsMenu">False</param>
	</module>

	<module name="StaticContentSample" layoutPanel="panel_row1_col1">
		<param name="text">
			This dashboard provides visibility into your Netscaler Appliances across the Enterprise.
			You can adjust the time range of this report by selecting your desired time using the picker below.
		</param>
	</module>

	<module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="true">
		<param name="selected">Last 24 Hours</param>
		<param name="searchWhenChanged">true</param>

		<!-- Top Traffic Appliances -->
		<module name="HiddenSearch" layoutPanel="panel_row3_col1" autoRun="True">
			<!--<param name="search">`ns` | chart sum(total_bytes_recv) as "BYTES_RECV", sum(total_bytes_send) as "BYTES_SENT"  by host | eval MBYTES_RECV = BYTES_RECV/1000000 | eval MBYTES_SENT = BYTES_SENT/1000000 | fields host, MBYTES_RECV, MBYTES_SENT | rename host as "Appliance (host)", MBYTES_RECV as "Megabytes Received" MBYTES_SENT as "Megabytes Sent"</param>-->
			<param name="search">`ns` | chart sum(total_bytes_recv) as "Bytes Received", sum(total_bytes_send) as "Bytes Sent" by host | rename host as "Appliance"</param>
			<module name="JobProgressIndicator" />
			<module name="HiddenChartFormatter">
				<param name="chartTitle">Top Appliances by Traffic</param>
				<param name="chart">bar</param>
				<param name="chart.stackMode">stacked</param>
				<param name="legend.placement">bottom</param>
				<module name="JSChart">
					<param name="width">100%</param>
					<param name="height">250px</param>
					<module name="ConvertToDrilldownSearch">
						<module name="ViewRedirector">
							<param name="viewTarget">flashtimeline</param>
						</module>
					</module>
				</module>
			</module>
		</module> <!-- end HiddenSearch -->
			
		<module name="HiddenSearch" layoutPanel="panel_row2_col1" group="Appliances Reporting Syslog" autoRun="True">
      <param name="search">`ns`| dedup host | stats count</param>
      <module name="JobProgressIndicator" />
      <module name="SingleValue">
        <param name="field">count</param>
        <param name="afterLabel">Syslog</param>
        <param name="format">count</param>
        <param name="linkFields">result,afterLabel</param>
        <param name="linkSearch">`ns`| dedup host | table host, index, source, sourcetype</param>
        <param name="linkView">flashtimeline</param>
      </module>
    </module>
    <module name="HiddenSearch" layoutPanel="panel_row2_col2" group="Appliances Reporting Appflow" autoRun="True">
      <param name="search">`ns_appflow`| dedup Address | stats count</param>
      <module name="JobProgressIndicator" />
      <module name="SingleValue">
        <param name="field">count</param>
        <param name="afterLabel">Appflow</param>
        <param name="format">count</param>
        <param name="linkFields">result,afterLabel</param>
        <param name="linkSearch">`ns_appflow`| dedup Address | table Address, index, source, sourcetype</param>
        <param name="linkView">flashtimeline</param>
      </module>
    </module>
		
		<!-- Top Appliances With Security Violations -->
		<module name="HiddenSearch" layoutPanel="panel_row3_col2" autoRun="True">
			<param name="search">`ns` log_type="APPFW" | rename host as "Appliance" | chart count(violation) by Appliance,violation</param>
			<module name="JobProgressIndicator" />
			<module name="HiddenChartFormatter">
				<param name="chartTitle">Top Appliances with App Firewall Violations</param>
				<param name="chart">bar</param>
				<param name="chart.stackMode">stacked</param>
				<param name="legend.placement">bottom</param>
				<module name="JSChart">
					<param name="width">100%</param>
					<param name="height">250px</param>
					<module name="ConvertToDrilldownSearch">
						<module name="ViewRedirector">
							<param name="viewTarget">flashtimeline</param>
						</module>
					</module>
				</module>
			</module>
		</module> <!-- end HiddenSearch -->

    <!-- Top Appliances With Admin Activity -->
		<module name="HiddenSearch" layoutPanel="panel_row3_col3" autoRun="True">
			<param name="search">`ns_ui`| stats count by host | rename count as "Admin Activities", host as "Appliance"</param>
			<module name="JobProgressIndicator" />
			<module name="HiddenChartFormatter">
				<param name="chartTitle">Top Appliances with Admin Activity</param>
				<param name="chart">bar</param>
				<param name="chart.stackMode">stacked</param>
				<param name="legend.placement">bottom</param>
				<module name="JSChart">
					<param name="width">100%</param>
					<param name="height">250px</param>
					<module name="ConvertToDrilldownSearch">
						<module name="ViewRedirector">
							<param name="viewTarget">flashtimeline</param>
						</module>
					</module>
				</module>
			</module>
		</module> <!-- end HiddenSearch -->
		
		
    <!-- Bytes Received -->
    <module name="HiddenSearch" layoutPanel="panel_row4_col1" autoRun="true" group="Bytes Received per Appliance">
      <param name="search">`ns` | timechart sum(total_bytes_recv) AS "Total Bytes Received" by host</param>
      <param name="groupLabel">Bytes Received Per Appliance</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	      <param name="chart">line</param>
	      <param name="chart.stackMode">none</param>
	      <param name="primaryAxisTitle.text">Time</param>
	      <param name="secondaryAxisTitle.text">Bytes</param>
	      <param name="legend.placement">bottom</param>
	      <module name="JSChart">
	        <param name="width">100%</param>
	        <param name="height">250px</param>
	          <module name="ConvertToDrilldownSearch">
	            <module name="ViewRedirector">
	              <param name="viewTarget">flashtimeline</param>
	            </module>
	          </module>
	      </module>
      </module>
    </module> <!-- end HiddenSearch -->
    
    <!-- Bytes Sent -->
    <module name="HiddenSearch" layoutPanel="panel_row5_col1" autoRun="true" group="Bytes Sent per Appliance">
      <param name="search">`ns` | timechart sum(total_bytes_send) AS "Total Bytes Sent" by host</param>
      <param name="groupLabel">Bytes Sent Per Appliance</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	      <param name="chart">line</param>
	      <param name="chart.stackMode">none</param>
	      <param name="primaryAxisTitle.text">Time</param>
	      <param name="secondaryAxisTitle.text">Bytes</param>
	      <param name="legend.placement">bottom</param>
	      <module name="JSChart">
	        <param name="width">100%</param>
	        <param name="height">250px</param>
	          <module name="ConvertToDrilldownSearch">
	            <module name="ViewRedirector">
	              <param name="viewTarget">flashtimeline</param>
	            </module>
	          </module>
	      </module>
      </module>
    </module> <!-- end HiddenSearch -->

		
	</module> <!-- end TimeRangePicker -->
</view>
