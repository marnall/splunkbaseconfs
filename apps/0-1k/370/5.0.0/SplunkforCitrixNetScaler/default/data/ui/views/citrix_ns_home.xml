<form>
  <label>NetScaler Overview</label>
  <description>
    This dashboard provides visibility into your NetScaler data.
    You can adjust the time range of this report by selecting your desired time using the picker below.
  </description>
  
  <fieldset autoRun="true">
    
    <input type="time">
      <label>Time Range:</label>
      <default>Last 24 hours</default>
    </input>
    
  </fieldset>
  
  <row>
    <chart>
      <title>NetScaler Events Over Time</title>
      <searchString>
	eventtype=netscaler | timechart count by log_type usenull=f
      </searchString>
      <option name="charting.chart">column</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.legend.placement">bottom</option>
      
      <drilldown>
        <link>
          <![CDATA[
            /app/SplunkforCitrixNetScaler/user_activity?earliest=$earliest$&latest=$latest$&form.FarmName=$row.FarmName$
          ]]>
         </link>
     </drilldown>
      
    </chart>
  </row>
  
  <row>
    <chart>
      <title>Events by Source IP</title>
      <searchString>
	eventtype=netscaler | top src_ip showperc=f
      </searchString>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    
    <chart>
      <title>Events by Destination IP</title>
      <searchString>
	eventtype=netscaler | top dst_ip showperc=f
      </searchString>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    
    <chart>
      <title>Events by User</title>
      <searchString>
	eventtype=netscaler | top user showperc=f
      </searchString>
      <option name="charting.chart">bar</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    
  </row>
  
  <row>
    <chart>
      <title>Bytes Received Per Appliance</title>
      <searchString>
	eventtype=netscaler | timechart sum(total_bytes_recv) AS "Total Bytes Received"
      </searchString>
      <option name="charting.chart">column</option>
      <option name="charting.chart.stackMode">none</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    
    <chart>
      <title>Bytes Sent Per Appliance</title>
      <searchString>
	eventtype=netscaler | timechart sum(total_bytes_send) AS "Total Bytes Sent"
      </searchString>
      <option name="charting.chart">column</option>
      <option name="charting.chart.stackMode">none</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
  </row>
    
</form>
