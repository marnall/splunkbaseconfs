<view template="dashboard.html" stylesheet="dashboard2.css">
  <label>VPN Overview</label>
  <module name="AccountBar" layoutPanel="appHeader" />
  <module name="AppBar" layoutPanel="navigationHeader" />
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="actionsMenuFilter">dashboard</param>
  </module>
  <!--
        Global index summary counts
    -->
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text">You can adjust the time range of the reports by selecting your desired time using the picker below.</param>
  </module>
  <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
    <param name="selected">Last 7 days</param>
    <param name="searchWhenChanged">True</param>
    <module name="HiddenSearch" layoutPanel="panel_row1_col1" autoRun="True">
      <param name="search">`ns_sslvpn` | stats count by host src_ip log_type msg_description msg_type total_bytes_send total_bytes_recv user vserver destination _time</param>
      <module name="ViewRedirectorLink">
        <param name="viewTarget">flashtimeline</param>
        <param name="label">View Full Report</param>
      </module>
  
    <module name="JobProgressIndicator"></module>
    <module name="HiddenPostProcess" layoutPanel="panel_row1_col1">
      <param name="search">timechart sum(count) as count by msg_type</param>
      <module name="HiddenChartFormatter">
        <param name="chartTitle">VPN Events Over Time</param>
        <param name="chart">area</param>
        <param name="chart.stackMode">stacked</param>
        <param name="primaryAxisTitle.text">time</param>
        <param name="secondaryAxisTitle.text">Events</param>
        <param name="legend.placement">bottom</param>
        <module name="JSChart">
          <param name="width">100%</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
    <module name="HiddenPostProcess" layoutPanel="panel_row2_col1">
      <param name="search">stats sum(count) as count by destination | head 10</param>
      <module name="HiddenChartFormatter">
        <param name="chartTitle">Connections by URI</param>
        <param name="chart">pie</param>
        <param name="legend.placement">bottom</param>
        <module name="JSChart">
          <param name="width">100%</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
    <module name="HiddenPostProcess" layoutPanel="panel_row2_col2">
      <param name="search">stats sum(count) as count by host | head 10</param>
      <module name="SimpleResultsTable">
        <param name="drilldown">row</param>
        <param name="entityName">results</param>
        <param name="displayRowNumbers">False</param>
        <module name="ConvertToDrilldownSearch">
          <module name="ViewRedirector">
            <param name="viewTarget">flashtimeline</param>
          </module>
        </module>
      </module>
    </module>
    <module name="HiddenPostProcess" layoutPanel="panel_row2_col3">
      <param name="search">stats sum(count) as count by user | head 10</param>
      <module name="HiddenChartFormatter">
        <param name="chartTitle">Connections by User</param>
        <param name="chart">pie</param>
        <param name="legend.placement">bottom</param>
        <module name="JSChart">
          <param name="width">100%</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
    <module name="HiddenPostProcess" layoutPanel="panel_row3_col1">
      <param name="search">stats sum(count) as count by vserver| head 10</param>
      <module name="HiddenChartFormatter">
        <param name="chartTitle">Connections by Vserver</param>
        <param name="chart">pie</param>
        <param name="legend.placement">bottom</param>
        <module name="JSChart">
          <param name="width">100%</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
    <module name="HiddenPostProcess" layoutPanel="panel_row3_col2">
      <param name="search">stats sum(count) as count by msg_type | head 10</param>
      <module name="HiddenChartFormatter">
        <param name="chartTitle">VPN Event Types</param>
        <param name="chart">bar</param>
        <param name="legend.placement">bottom</param>
        <module name="JSChart">
          <param name="width">100%</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
    <module name="HiddenPostProcess" layoutPanel="panel_row4_col1">
      <param name="search">timechart sum(total_bytes_recv) by user</param>
      <module name="HiddenChartFormatter">
        <param name="chartTitle">Bytes Recieved Over Time by User</param>
        <param name="chart">column</param>
        <param name="chart.stackMode">stacked</param>
        <param name="legend.placement">bottom</param>
        <module name="JSChart">
          <param name="width">100%</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
    <module name="HiddenPostProcess" layoutPanel="panel_row4_col2">
      <param name="search">timechart sum(total_bytes_send) by user</param>
      <module name="HiddenChartFormatter">
        <param name="chartTitle">Bytes Transfered Over Time by User</param>
        <param name="chart">column</param>
        <param name="chart.stackMode">stacked</param>
        <param name="legend.placement">bottom</param>
        <module name="JSChart">
          <param name="height">250px</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
  </module>
</view>
