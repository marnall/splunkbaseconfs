<view template="dashboard.html">
    <label>AppFlow Security</label>
    <module name="AccountBar" layoutPanel="appHeader" />
    <module name="AppBar" layoutPanel="navigationHeader" />
    <module name="Message" layoutPanel="messaging">
        <param name="filter">*</param>
        <param name="clearOnJobDispatch">False</param>
        <param name="maxSize">1</param>
    </module>
    <module name="TitleBar" layoutPanel="navigationHeader">
        <param name="actionsMenuFilter">dashboard</param>
    </module>
    
    <module name="GenericHeader" layoutPanel="panel_row1_col1">
        <param name="label">Connection Count</param>
    </module>
    <module name="StaticContentSample" layoutPanel="panel_row1_col1">
        <param name="text">You can adjust the time range of the connection count reports
        by selecting your desired time using the picker below.</param>
    </module>
    <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="true">
        <param name="selected">Last 24 hours</param>
        <param name="searchWhenChanged">True</param>
        
        <!-- Connection Count by Destination Server -->
        <module name="HiddenSavedSearch" autoRun="true">
            <param name="savedSearch">connection count by dest server</param>
            <module name="JobProgressIndicator" />
            <module name="HiddenChartFormatter">
                <param name="chart">line</param>
                <param name="chartTitle">Connection Count by Destination Server</param>
                <param name="primaryAxisTitle.text">Time</param>
                <param name="secondaryAxisTitle.text">Count</param>
                <module name="JSChart">
                    <param name="width">100%</param>
                    <param name="height">250px</param>
                    <module name="ConvertToDrilldownSearch">
                        <module name="ViewRedirector">
                            <param name="viewTarget">flashtimeline</param>
                        </module>
                    </module>
                </module>
            </module>
        </module>
        
        <!-- Connection Count by Source IP -->
        <module name="HiddenSavedSearch" autoRun="true">
            <param name="savedSearch">connection count by src ip</param>
            <module name="JobProgressIndicator" />
            <module name="HiddenChartFormatter">
                <param name="chart">line</param>
                <param name="chartTitle">Connection Count by Source IP</param>
                <param name="primaryAxisTitle.text">Time</param>
                <param name="secondaryAxisTitle.text">Count</param>
                <module name="JSChart">
                    <param name="width">100%</param>
                    <param name="height">250px</param>
                    <module name="ConvertToDrilldownSearch">
                        <module name="ViewRedirector">
                            <param name="viewTarget">flashtimeline</param>
                        </module>
                    </module>
                </module>
            </module>
        </module>
    </module> <!-- end TimeRangePicker -->
    
    <module name="GenericHeader" layoutPanel="panel_row2_col1">
        <param name="label">Slow POST Attack</param>
    </module>
    <module name="StaticContentSample" layoutPanel="panel_row2_col1">
        <param name="text">The Slow POST Table and Timechart show you only hosts
        that are sending really low number of bytes per minute (less than 600 bytes).
        You can adjust the time range of the slow POST attack reports
        by selecting your desired time using the picker below.</param>
    </module>
    
    <module name="TimeRangePicker" layoutPanel="panel_row2_col1" autoRun="true">
        <param name="selected">1 minute window</param>
        <param name="searchWhenChanged">True</param>
        
        <!-- Slow POST Table -->
        <module name="HiddenSavedSearch" autoRun="true">
            <param name="savedSearch">slow post</param>
            <module name="JobProgressIndicator" />
            <module name="GenericHeader">
                <param name="label">Slow POST Table</param>
            </module>
            <module name="Paginator">
                <param name="entityName">results</param>
                <module name="SimpleResultsTable">
                    <param name="entityName">results</param>
                    <param name="drilldown">row</param>
                    <module name="ViewRedirector">
                        <param name="viewTarget">flashtimeline</param>
                        <param name="popup">true</param>
                    </module>
                </module>
            </module>
        </module>
        
        <!-- Slow POST Timechart -->
        <module name="HiddenSavedSearch" autoRun="true">
            <param name="savedSearch">slow post 2</param>
            <module name="JobProgressIndicator" />
            <module name="HiddenChartFormatter">
                <param name="chart">column</param>
                <param name="chartTitle">Slow POST Timechart</param>
                <param name="primaryAxisTitle.text">Time</param>
                <param name="secondaryAxisTitle.text">Bytes</param>
                <module name="JSChart">
                    <param name="width">100%</param>
                    <param name="height">250px</param>
                    <module name="ConvertToDrilldownSearch">
                        <module name="ViewRedirector">
                            <param name="viewTarget">flashtimeline</param>
                        </module>
                    </module>
                </module>
            </module>
        </module>
        
    </module> <!-- end TimeRangePicker -->
    
</view>