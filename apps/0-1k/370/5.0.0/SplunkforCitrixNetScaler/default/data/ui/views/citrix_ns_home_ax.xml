<view template="dashboard.html">
  <label>NetScaler Overview</label>
  <module name="AccountBar" layoutPanel="appHeader" />
  <module name="AppBar" layoutPanel="navigationHeader" />
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="showActionsMenu">False</param>
  </module>
  
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text">This dashboard provides visibility into your NetScaler data.
    You can adjust the time range of this report by selecting your desired time using
    the picker below.</param>
  </module>
  
  <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="true">
    <param name="selected">Last 24 Hours</param>
    <param name="searchWhenChanged">true</param>
    
    
    <!-- NetScaler Events Over Time -->
    <module name="HiddenSearch" layoutPanel="panel_row2_col1" autoRun="True">
      <param name="search">`ns` | timechart count by log_type</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	<param name="chartTitle">NetScaler Events Over Time</param>
	<param name="chart">column</param>
	<param name="chart.stackMode">stacked</param>
	<param name="primaryAxisTitle.text">Time</param>
	<param name="secondaryAxisTitle.text">Events</param>
	<param name="legend.placement">bottom</param>
	<module name="JSChart">
	  <param name="width">100%</param>
	  <param name="height">250px</param>
	  <module name="ConvertToDrilldownSearch">
	    <module name="ViewRedirector">
	      <param name="viewTarget">flashtimeline</param>
	    </module>
	  </module>
	</module>
      </module>
    </module> <!-- end HiddenSearch -->
    
    <!-- Events by Source IP -->
    <module name="HiddenSearch" layoutPanel="panel_row3_col1" autoRun="True">
      <param name="search">`ns` | top src_ip showperc=f</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	<param name="chartTitle">Events by Source IP</param>
	<param name="chart">pie</param>
	<param name="legend.placement">bottom</param>
	<module name="JSChart">
	  <param name="width">100%</param>
	  <param name="height">250px</param>
	  <module name="ConvertToDrilldownSearch">
	    <module name="ViewRedirector">
	      <param name="viewTarget">flashtimeline</param>
	    </module>
	  </module>
	</module>
      </module>
    </module> <!-- end HiddenSearch -->
    
    <!-- Events by Destination IP -->
    <module name="HiddenSearch" layoutPanel="panel_row3_col2" autoRun="True">
      <param name="search">`ns` | top dst_ip showperc=f</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	<param name="chartTitle">Events by Destination IP</param>
	<param name="chart">pie</param>
	<param name="legend.placement">bottom</param>
	<module name="JSChart">
	  <param name="width">100%</param>
	  <param name="height">250px</param>
	  <module name="ConvertToDrilldownSearch">
	    <module name="ViewRedirector">
	      <param name="viewTarget">flashtimeline</param>
	    </module>
	  </module>
	</module>
      </module>
    </module> <!-- end HiddenSearch -->

    <!-- Events by User -->
    <module name="HiddenSearch" layoutPanel="panel_row3_col3" autoRun="True">
      <param name="search">`ns` | top user showperc=f</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	<param name="chartTitle">Events by User</param>
	<param name="chart">bar</param>
	<param name="chart.stackMode">stacked</param>
	<param name="primaryAxisTitle.text">Time</param>
	<param name="secondaryAxisTitle.text">Events</param>
	<param name="legend.placement">bottom</param>
	<module name="JSChart">
	  <param name="width">100%</param>
	  <param name="height">250px</param>
	  <module name="ConvertToDrilldownSearch">
	    <module name="ViewRedirector">
	      <param name="viewTarget">flashtimeline</param>
	    </module>
	  </module>
	</module>
      </module>
    </module> <!-- end HiddenSearch -->

    <!-- Bytes Received -->
    <module name="HiddenSearch" layoutPanel="panel_row4_col1" autoRun="true" group="Bytes Received">
      <param name="search">`ns` | timechart sum(total_bytes_recv) AS "Total Bytes Received"</param>
      <param name="groupLabel">Bytes Received Per Appliance</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	      <param name="chart">column</param>
	      <param name="chart.stackMode">none</param>
	      <param name="primaryAxisTitle.text">Time</param>
	      <param name="secondaryAxisTitle.text">Bytes</param>
	      <param name="legend.placement">bottom</param>
	      <module name="JSChart">
	        <param name="width">100%</param>
	        <param name="height">250px</param>
	          <module name="ConvertToDrilldownSearch">
	            <module name="ViewRedirector">
	              <param name="viewTarget">flashtimeline</param>
	            </module>
	          </module>
	      </module>
      </module>
    </module> <!-- end HiddenSearch -->
    
    <!-- Bytes Sent -->
    <module name="HiddenSearch" layoutPanel="panel_row4_col2" autoRun="true" group="Bytes Sent">
      <param name="search">`ns` | timechart sum(total_bytes_send) AS "Total Bytes Sent"</param>
      <param name="groupLabel">Bytes Sent Per Appliance</param>
      <module name="JobProgressIndicator" />
      <module name="HiddenChartFormatter">
	      <param name="chart">column</param>
	      <param name="chart.stackMode">none</param>
	      <param name="primaryAxisTitle.text">Time</param>
	      <param name="secondaryAxisTitle.text">Bytes</param>
	      <param name="legend.placement">bottom</param>
	      <module name="JSChart">
	        <param name="width">100%</param>
	        <param name="height">250px</param>
	          <module name="ConvertToDrilldownSearch">
	            <module name="ViewRedirector">
	              <param name="viewTarget">flashtimeline</param>
	            </module>
	          </module>
	      </module>
      </module>
    </module> <!-- end HiddenSearch -->
  </module> <!-- end TimeRangePicker -->
</view>
