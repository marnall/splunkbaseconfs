<view template="dashboard.html" stylesheet="dashboard2.css">
  <label>System Console</label>
  <module name="AccountBar" layoutPanel="appHeader" />
  <module name="AppBar" layoutPanel="navigationHeader" />
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="actionsMenuFilter">dashboard</param>
  </module>
  <!--
        Global index summary counts
    -->
  <module name="GenericHeader" layoutPanel="panel_row1_col1">
    <param name="label">System Console</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text">System overview</param>
  </module>
  <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
    <param name="selected">Last 7 days</param>
    <param name="searchWhenChanged">True</param>
    <module name="HiddenSearch" layoutPanel="panel_row1_col1" autoRun="True">
      <param name="search">`ns_ui`| stats count by command src_ip host msg_description log_type msg_format user status _time</param>
      <module name="ViewRedirectorLink">
        <param name="viewTarget">flashtimeline</param>
        <param name="label">View Full Report</param>
      </module>
      <module name="JobProgressIndicator"></module>
      <module name="HiddenPostProcess" layoutPanel="panel_row1_col1">
        <param name="search">stats sum(count) as count by host</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Events by Device</param>
          <param name="chart">bar</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
            <param name="height">250px</param>
            <module name="ConvertToDrilldownSearch">
              <module name="ViewRedirector">
                <param name="viewTarget">flashtimeline</param>
              </module>
            </module>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row1_col2">
        <param name="search">stats sum(count) as count by user</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Admin Events by User</param>
          <param name="chart">pie</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
            <param name="height">250px</param>
            <module name="ConvertToDrilldownSearch">
              <module name="ViewRedirector">
                <param name="viewTarget">flashtimeline</param>
              </module>
            </module>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row2_col1">
        <param name="search">stats list(status) as status values(command) as commands by user _time</param>
        <module name="SimpleResultsTable">
          <param name="drilldown">row</param>
          <param name="entityName">results</param>
          <param name="displayRowNumbers">False</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</view>
