<view template="dashboard.html" stylesheet="dashboard2.css">
  <label>WebApp Firewall Dashboard</label>
  <module name="AccountBar" layoutPanel="appHeader" />
  <module name="AppBar" layoutPanel="navigationHeader" />
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="actionsMenuFilter">dashboard</param>
  </module>
  <!--
        Global index summary counts
    -->
  <module name="GenericHeader" layoutPanel="panel_row1_col1">
    <param name="label">WebApp Firewall Dashboard</param>
  </module>
  <module name="StaticContentSample" layoutPanel="panel_row1_col1">
    <param name="text">Webapp firewall overview dashboard</param>
  </module>
  <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="True">
    <param name="selected">Last 7 days</param>
    <param name="searchWhenChanged">True</param>
    <module name="HiddenSavedSearch" layoutPanel="panel_row1_col1" autoRun="True">
      <param name="savedSearch">Citrix NetScaler - APPFW - DataCube</param>
      <module name="ViewRedirectorLink">
        <param name="viewTarget">flashtimeline</param>
        <param name="label">View Full Report</param>
      </module>
    </module>
    <module name="HiddenSearch" layoutPanel="panel_row1_col1" autoRun="True">
      <param name="search">`ns_appfw`| stats count by violation src_ip url host profile msg msg_description log_type msg_format action _time</param>
      <module name="JobProgressIndicator"></module>
      <module name="HiddenPostProcess" layoutPanel="panel_row1_col1">
        <param name="search">timechart sum(count) as count by violation</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Violations Over Time By Type</param>
          <param name="chart">area</param>
          <param name="chart.stackMode">stacked</param>
          <param name="primaryAxisTitle.text">time</param>
          <param name="secondaryAxisTitle.text">Events</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row2_col1">
        <param name="search">stats sum(count) as count by host</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Violation by Host</param>
          <param name="chart">pie</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
            <module name="ConvertToDrilldownSearch">
              <module name="ViewRedirector">
                <param name="viewTarget">flashtimeline</param>
              </module>
            </module>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row2_col2">
        <param name="search">eval url = substr(url,0,50) | stats sum(count) as count by url | head 20</param>
        <module name="SimpleResultsTable">
          <param name="drilldown">row</param>
          <param name="entityName">results</param>
          <param name="displayRowNumbers">False</param>
          <module name="ConvertToDrilldownSearch">
            <module name="ViewRedirector">
              <param name="viewTarget">flashtimeline</param>
            </module>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row2_col3">
        <param name="search">stats sum(count) as count by violation</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Violations by Type</param>
          <param name="chart">pie</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
            <module name="ConvertToDrilldownSearch">
              <module name="ViewRedirector">
                <param name="viewTarget">flashtimeline</param>
              </module>
            </module>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row3_col1">
        <param name="search">stats sum(count) as count by profile</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Violations by Profile</param>
          <param name="chart">pie</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
            <param name="height">250px</param>
            <module name="ConvertToDrilldownSearch">
              <module name="ViewRedirector">
                <param name="viewTarget">flashtimeline</param>
              </module>
            </module>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row3_col2">
        <param name="search">stats sum(count) as count by src_ip | head 20</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Violations by Client IP</param>
          <param name="chart">bar</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
            <module name="ConvertToDrilldownSearch">
              <module name="ViewRedirector">
                <param name="viewTarget">flashtimeline</param>
              </module>
            </module>
          </module>
        </module>
      </module>
      <module name="HiddenPostProcess" layoutPanel="panel_row3_col3">
        <param name="search">stats sum(count) as count by action</param>
        <module name="HiddenChartFormatter">
          <param name="chartTitle">Firewall Actions</param>
          <param name="chart">pie</param>
          <param name="legend.placement">bottom</param>
          <module name="JSChart">
            <param name="width">100%</param>
            <module name="ConvertToDrilldownSearch">
              <module name="ViewRedirector">
                <param name="viewTarget">flashtimeline</param>
              </module>
            </module>
          </module>
        </module>
      </module>
    </module>
  </module>
</view>
