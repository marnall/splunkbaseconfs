<view template="dashboard.html">
    <label>AppFlow Overview</label>
    <module name="AccountBar" layoutPanel="appHeader"/>
    <module name="AppBar" layoutPanel="navigationHeader"/>
    <module name="Message" layoutPanel="messaging">
        <param name="filter">*</param>
        <param name="clearOnJobDispatch">False</param>
        <param name="maxSize">1</param>
    </module>
    
    <module name="TitleBar" layoutPanel="navigationHeader">
        <param name="actionsMenuFilter">dashboard</param>
    </module>

    <module name="StaticContentSample" layoutPanel="panel_row1_col1">
        <param name="text">You can adjust the time range of the reports
        by selecting your desired time using the picker below.</param>
    </module>

    <module name="TimeRangePicker" layoutPanel="panel_row1_col1" autoRun="true">
        <param name="selected">All time</param>
        <param name="searchWhenChanged">true</param>
        
        <module name="HiddenSavedSearch" autoRun="true">
            <param name="savedSearch">AppFlow DataCube</param>
            
            <!-- Top 10 Browsers -->
            <module name="HiddenPostProcess" layoutPanel="panel_row2_col1" autoRun="true" group="Top 10 HTTP Browsers">
                <param name="search">search httpUserAgent!="" httpUserAgent!="0" 
| rex field=httpUserAgent "((?&lt;browser_ff&gt;Firefox\S+)|(?&lt;browser_ie&gt;MSIE [\d\.]+)|(?&lt;browser_opera&gt;Opera)|(?&lt;browser_chrome&gt;Chrome)|(?&lt;browser_PNA&gt;PNAMAIN.EXE)|(?&lt;browser_safari&gt;Safari)|(?&lt;browser_java&gt;Java\S+)|(?&lt;browser_nagios&gt;nagios\S+)|(?&lt;browser_nessus&gt;[Nn][Ee][Ss][Ss][Uu][Ss])|(?&lt;browser_apache&gt;Apache\S+))"
| eval browser_none=if(httpUserAgent =="-","None","")
| fillnull value="" browser_ff browser_ie browser_chrome browser_safari browser_opera browser_java browser_nagios browser_nessus browser_apache browser_PNA
| eval browser = browser_ff.browser_ie.browser_chrome.browser_safari.browser_opera.browser_java.browser_nagios.browser_nessus.browser_apache.browser_PNA
| replace "" with "Other/Unknown" in browser
| top 10 browser
                </param>
                <module name="JobProgressIndicator" />
                <module name="HiddenChartFormatter">
                    <param name="chart">pie</param>
                    <module name="JSChart">
                        <module name="ConvertToDrilldownSearch">
                            <module name="ViewRedirector">
                                <param name="viewTarget">flashtimeline</param>
                            </module>
                        </module>
                    </module>
                </module>
            </module>

            <!-- Top 10 netscalerHttpReqUrl -->
            <module name="HiddenPostProcess" layoutPanel="panel_row2_col2" autoRun="true" group="Top 10 Request URL">
                <param name="search">search netscalerHttpReqUrl!="" netscalerHttpReqUrl!="0" netscalerHttpReqUrl!="*jpg" netscalerHttpReqUrl!="*png" netscalerHttpReqUrl!="*.css" netscalerHttpReqUrl!="*gif" netscalerHttpReqUrl!="*.js" | top limit=10 httpRequestUrlPath | eval percent=round(percent,2)</param>
                <module name="JobProgressIndicator" />
                    <module name="SimpleResultsTable">
                        <param name="entityName">results</param>
                        <param name="drilldown">row</param>
                        <module name="ViewRedirector">
                            <param name="viewTarget">flashtimeline</param>
                            <param name="popup">true</param>
                        </module>
                    </module>
            </module>
            
            <!-- # of transactions and flows per observation ID -->
            <module name="HiddenSavedSearch" layoutPanel="panel_row3_col1" autoRun="true" group="No. of Transactions and Flows per Observation ID">
                <param name="savedSearch">Transaction and Flow per Observation ID</param>
                <module name="JobProgressIndicator" />
                <module name="SimpleResultsTable">
                    <param name="drilldown">row</param>
                    <module name="ConvertToDrilldownSearch">
                        <module name="ViewRedirector">
                            <param name="viewTarget">flashtimeline</param>
                            <param name="popup">true</param>
                        </module>
                    </module>
                </module>
            </module>
            
            <!-- Top 10 Dst IP -->
            <module name="HiddenPostProcess" layoutPanel="panel_row5_col1" autoRun="true" group="Top 10 Dst IP">
                <param name="search">top limit=10 destinationIPv4Address | fields - percent</param>
                <module name="JobProgressIndicator" />
                <module name="HiddenChartFormatter">
                    <param name="chart">bar</param>
                    <module name="JSChart">
                        <module name="ConvertToDrilldownSearch">
                            <module name="ViewRedirector">
                                <param name="viewTarget">flashtimeline</param>
                            </module>
                        </module>
                    </module>
                </module>
            </module>
            
            <!-- Top 10 Dst Port -->
            <module name="HiddenPostProcess" layoutPanel="panel_row5_col2" autoRun="true" group="Top 10 Dst Port">
                <param name="search">top limit=10 tcpDestinationPort | fields - percent</param>
                <module name="JobProgressIndicator" />
                <module name="HiddenChartFormatter">
                    <param name="chart">bar</param>
                    <module name="JSChart">
                        <module name="ConvertToDrilldownSearch">
                            <module name="ViewRedirector">
                                <param name="viewTarget">flashtimeline</param>
                            </module>
                        </module>
                    </module>
                </module>
            </module>
            
            <!-- Top 10 Src IP -->
            <module name="HiddenPostProcess" layoutPanel="panel_row6_col1" autoRun="true" group="Top 10 Src IP">
                <param name="search">top limit=10 sourceIPv4Address | fields - percent</param>
                <module name="JobProgressIndicator" />
                <module name="HiddenChartFormatter">
                    <param name="chart">bar</param>
                    <module name="JSChart">
                        <module name="ConvertToDrilldownSearch">
                            <module name="ViewRedirector">
                                <param name="viewTarget">flashtimeline</param>
                            </module>
                        </module>
                    </module>
                </module>
            </module>
            
            <!-- Top 10 Src Port -->
            <module name="HiddenPostProcess" layoutPanel="panel_row6_col2" autoRun="true" group="Top 10 Src Port">
                <param name="search">top limit=10 tcpSourcePort | fields - percent</param>
                <module name="JobProgressIndicator" />
                <module name="HiddenChartFormatter">
                    <param name="chart">bar</param>
                    <module name="JSChart">
                        <module name="ConvertToDrilldownSearch">
                            <module name="ViewRedirector">
                                <param name="viewTarget">flashtimeline</param>
                            </module>
                        </module>
                    </module>
                </module>
            </module>    
        </module> <!-- end HiddenSavedSearch -->
        
	<module name="HiddenSearch" layoutPanel="panel_row4_col1" autoRun="true" group="Avgerage Transaction Time">
            <param name="search"> `ns_appflow` | eval transactionTime=abs(flowEndMicroSeconds-flowStartMicroSeconds) | timechart avg(transactionTime) AS AvgTransactionTime by Address</param>
            <module name="JobProgressIndicator" />
            <module name="HiddenChartFormatter">
                <param name="primaryAxisTitle.text">Time</param>
                <param name="secondaryAxisTitle.text">MicoSeconds</param>
                <param name="chart">area</param>
                <module name="JSChart">
                    <module name="ConvertToDrilldownSearch">
                        <module name="ViewRedirector">
                            <param name="viewTarget">flashtimeline</param>
                        </module>
                    </module>
                </module>
            </module>
        </module>    

    </module> <!-- end TimeRangePicker -->
</view>

