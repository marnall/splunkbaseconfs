<form>
  <label>Load Balancing Dashboard</label>
  
  <fieldset autoRun="true">
    
    <input type="text" token="dst_ip">
      <label>Destination IP</label>
      <default></default>
      <prefix>dst_ip="</prefix>
      <suffix>"</suffix>
    </input>
    
    <input type="text" token="dst_port">
      <label>Destination Port</label>
      <default></default>
      <prefix>dst_port="</prefix>
      <suffix>"</suffix>
    </input>
    
    <input type="text" token="src_ip">
      <label>Source IP</label>
      <default></default>
      <prefix>src_ip="</prefix>
      <suffix>"</suffix>
    </input>
    
    <input type="time">
      <label>Time Range:</label>
      <default>Last 24 hours</default>
    </input>

  </fieldset>
  
  <row>
    <chart>
      <title>Total Megabytes</title>
      <searchTemplate>eventtype=netscaler TCP $dst_ip$ $dst_port$ $src_ip$ | bin _time span=5m | eval tbrmb=total_bytes_recv/(1024*1024)| eval tbsmb=total_bytes_send/(1024*1024) | timechart sum(tbrmb) as Megabytes_received sum(tbsmb) as Megabytes_sent</searchTemplate>
      <option name="charting.chart">area</option>
      <option name="charting.legend.placement">bottom</option>
      <option name="charting.primaryAxisTitle.text">Time</option>
      <option name="charting.secondaryAxisTitle.text">MegaBytes</option>
    </chart>
  </row>

  <row>
    <chart>
      <title>Top Destination IP</title>
      <searchTemplate>eventtype=netscaler TCP $dst_ip$ $dst_port$ $src_ip$ | top dst_ip</searchTemplate>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    <chart>
      <title>Top Destination Port</title>
      <searchTemplate>eventtype=netscaler TCP $dst_ip$ $dst_port$ $src_ip$ | top dst_port</searchTemplate>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    <chart>
      <title>Top Source IP</title>
      <searchTemplate>eventtype=netscaler TCP $dst_ip$ $dst_port$ $src_ip$ | top src_ip</searchTemplate>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
  </row>
</form>


