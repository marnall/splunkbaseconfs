<form>
	<label>AppFlow Security</label>
  
	<fieldset autoRun="true">
    
		<input type="time">
		  <label>Time Range:</label>
		  <default>Last 24 hours</default>
		</input>
    
	</fieldset>
        
        <row>
            <chart>
                <title>Connection Count by Destination Server</title>
                <searchName>connection count by dest server</searchName>
                <earliestTime>$earliest$</earliestTime>
                <latestTime>$latest$</latestTime>
                <option name="charting.chart">line</option>
            </chart>
        </row>
        
        <row>
            <chart>
                <title>Connection Count by Source IP</title>
                <searchName>connection count by src ip</searchName>
                <earliestTime>$earliest$</earliestTime>
                <latestTime>$latest$</latestTime>
                <option name="charting.chart">line</option>
            </chart>
        </row>
        
        <row grouping="3">
            <panel>
                <input type="time" token="tr_SP">
                    <label>Time Range for Slow POST:</label>
                    <default>Last 24 hours</default>
                </input>
                <html>
                    The Slow POST Table and Timechart show you only hosts
                    that are sending really low number of bytes per minute (less than 600 bytes).
                    You can adjust the time range of the slow POST attack reports
                    by selecting your desired time using the picker below.
                </html>
                <table>
                    <title>Slow POST Table</title>
                    <searchName>slow post</searchName>
                    <earliestTime>$tr_SP.earliest$</earliestTime>
                    <latestTime>$tr_SP.latest$</latestTime>
                </table>
                
                <chart>
                    <title>Connection Count by Source IP</title>
                    <searchName>slow post 2</searchName>
                    <earliestTime>$tr_SP.earliest$</earliestTime>
                    <latestTime>$tr_SP.latest$</latestTime>
                    <option name="charting.chart">column</option>
                </chart>
            </panel>
        </row>
</form>