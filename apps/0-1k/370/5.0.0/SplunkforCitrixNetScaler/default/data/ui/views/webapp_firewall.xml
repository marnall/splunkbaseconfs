<form>
  <label>WebApp Firewall Dashboard</label>
  
  <fieldset autoRun="true">
  
      <input type="time">
          <label>Time Range:</label>
          <default>Last 7 days</default>
      </input>
  
  </fieldset>
  
  <row>
    <chart>
      <title>Violations Over Time By Type</title>
      <searchString>
        eventtype=netscaler_app_fw |
        stats count by violation src_ip url host profile msg msg_description log_type msg_format action _time
        | timechart count by violation
      </searchString>
      <option name="charting.chart">area</option>
      <option name="charting.chart.stackMode">stacked</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
  </row>
  
  <row>
    <chart>
      <title>Violations by Host</title>
      <searchString>
        eventtype=netscaler_app_fw
        | stats count by host
      </searchString>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    
    <table>
      <searchString>
        eventtype=netscaler_app_fw
        | eval url = substr(url,0,50)
        | stats count by url
        | head 20
      </searchString>
    </table>
    
    <chart>
      <title>Violations by Type</title>
      <searchString>
        eventtype=netscaler_app_fw
        | stats count by violation
      </searchString>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
  </row>
  
  <row>
    <chart>
      <title>Violations by Profile</title>
      <searchString>
        eventtype=netscaler_app_fw
        | stats count by profile
      </searchString>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    
    <chart>
      <title>Violations by Client IP</title>
      <searchString>
        eventtype=netscaler_app_fw
        | stats count by src_ip
        | head 20
      </searchString>
      <option name="charting.chart">bar</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
    
    <chart>
      <title>Firewall Actions</title>
      <searchString>
        eventtype=netscaler_app_fw
        | stats count by action
      </searchString>
      <option name="charting.chart">pie</option>
      <option name="charting.legend.placement">bottom</option>
    </chart>
  </row>
  
</form>