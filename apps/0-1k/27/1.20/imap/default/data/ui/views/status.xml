<view>
  <label>Mail Status</label>
  <module name="AccountBar" layoutPanel="appHeader"/>
  <module name="AppBar" layoutPanel="navigationHeader"/>
  <module name="Message" layoutPanel="messaging">
    <param name="filter">*</param>
    <param name="clearOnJobDispatch">False</param>
    <param name="maxSize">1</param>
  </module>
  <module name="TitleBar" layoutPanel="viewHeader">
    <param name="actionsMenuFilter">dashboard</param>
  </module>
  <module name="SearchBar" layoutPanel="splSearchControls-inline">
    <param name="useAssistant">true</param>
    <param name="useTypeahead">true</param>
    <param name="q">index=mail</param>
    <param name="useOwnSubmitButton">False</param>
    <module name="TimeRangePicker">
      <param name="selected">All time</param>
      <module name="SubmitButton">
        <param name="allowSoftSubmit">True</param>
        <module name="ViewRedirector" layoutPanel="mainSearchControls">
          <param name="viewTarget">flashtimeline</param>
        </module>
      </module>
    </module>
  </module>

  <module name="HiddenSavedSearch" layoutPanel="resultsAreaLeft"  group="Rate of incoming messages last 24hrs" autoRun="True">
	<param name="savedSearch">IMAP-messagesLastHour</param>  
	<module name="ResultsHeader">  
	  <param name="entityName">results</param>
	  <param name="entityLabel">messages last 60 minutes</param>
	</module>
	<module name="HiddenChartFormatter">
	  <param name="chart">line</param>
	  <!-- param name="chartTitle"></param -->
	  <param name="primaryAxisTitle.text">time</param>
	  <module name="FlashChart">
		<param name="width">100%</param>
		<param name="height">400px</param>
	  </module>
	</module>
  </module>
  <module name="HiddenSavedSearch" layoutPanel="resultsAreaRight"  group="Top Senders in Last 24 Hours" autoRun="True">
	<param name="savedSearch">IMAP-topFromLast1000</param>  
	<module name="ResultsHeader">  
	  <param name="entityName">results</param>
	  <param name="entityLabel">Top Senders</param>
	</module>
	<module name="HiddenChartFormatter">
	  <param name="chart">bar</param>
	  <!-- param name="chartTitle">activity types over time.</param -->
	  <param name="primaryAxisTitle.text">time</param>i
	  <module name="FlashChart">
		<param name="width">100%</param>
		<param name="height">400px</param>
	  </module>
	</module>
</module>
</view>
