<form version="1.1" onunloadCancelJobs="True" script="search_rerun.js, table_formatting.js">
    <label>Palo Alto Networks Top Applications (DEPRECATED)</label>
    <fieldset autoRun="True">
        <input type="dropdown" token="nfo_hostname" searchWhenChanged="false">
            <label>NFO hostnames</label>
            <default>*</default>
            <search>
                <query>| `populate_nfo_hostnames`</query>
            </search>
            <fieldForLabel>nfo_hostname</fieldForLabel>
            <fieldForValue>nfo_hostname</fieldForValue>
        </input>
        <input type="dropdown" token="exp_group" searchWhenChanged="false">
            <label>Device group</label>
            <default>*</default>
            <search>
                <query>| `populate_exporter_group_list_by_nfo_hostname($nfo_hostname$)`</query>
            </search>
            <fieldForLabel>exp_group</fieldForLabel>
            <fieldForValue>exp_group</fieldForValue>
        </input>
        <input type="dropdown" token="exp_ip" searchWhenChanged="false">
            <label>Device</label>
            <default>*</default>
            <choice value="*">*</choice>
            <search>
                <query>| `populate_exporter_list_by_nfo_hostname($exp_group$,$nfo_hostname$)`</query>
            </search>
            <fieldForLabel>name</fieldForLabel>
            <fieldForValue>exp_ip</fieldForValue>
        </input>
        <input type="text" token="advanced_filter" id="adv_input" searchWhenChanged="False">
            <label>Advanced Filter</label>
            <default>*</default>
        </input>
        <input type="time" searchWhenChanged="false">
            <label>Time Range</label>
            <default>Last 60 minutes</default>
        </input>
    </fieldset>
    <search>
        <query>`netflow_search_rule_20034`  | `set_span`</query>
        <earliest>$earliest$</earliest>
        <latest>$latest$</latest>
        <done>
            <condition match="'job.resultCount' > 0">
                <set token="show_content">true</set>
                <set token="span_token">$result.span$</set>
                <set token="span_int">$result.span_int$</set>
                <set token="range">$result.range$</set>
                <set token="earliest_token">$result.all_time_earliest$</set>
                <set token="latest_token">$result.all_time_latest$</set>
                <unset token="show_hint"/>
            </condition>
            <condition>
                <unset token="show_content"></unset>
                <set token="show_hint">true</set>
            </condition>
        </done>
    </search>
    <search>
        <query>| inputlookup visualisation.parameters_lookup | transpose header_field=param</query>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
        <done>
            <condition>
                <set token="charting.chart_value">$result.charting.chart$</set>
                <set token="charting.chart.stackMode_value">$result.charting.chart.stackMode$</set>
            </condition>
        </done>
    </search>
    <row depends="$show_content$">
        <panel>
            <chart>
                <title>Top Applications</title>
                <search>
                    <query>
                        `netflow_search_rule_20034` $advanced_filter$
                        | lookup `is_local_lookup` exporters_devices_lookup nfo_hostname exp_ip OUTPUT device_group AS exp_group 
                        | search exp_group="$exp_group$" exp_ip="$exp_ip$" nfo_hostname="$nfo_hostname$"
                        | `per_second_chart(sum(bytes) by app,"$span_token$",$span_int$)`
                    </query>
                    <earliest>$earliest_token$</earliest>
                    <latest>$latest_token$</latest>
                </search>
                <option name="charting.chart">$charting.chart_value$</option>
                <option name="charting.chart.nullValueMode">zero</option>
                <option name="charting.axisTitleX.text">Time</option>
                <option name="charting.axisTitleY.text">Mbps</option>
                <option name="charting.legend.placement">right</option>
                <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
                <option name="charting.drilldown">none</option>
                <option name="height">200</option>
                <selection>
                    <set token="selection.earliest">$start$</set>
                    <set token="selection.latest">$end$</set>
                </selection>
            </chart>
            <table>
            <search>
                <query>
                    `netflow_search_rule_20034` $advanced_filter$
                    | lookup `is_local_lookup` exporters_devices_lookup nfo_hostname exp_ip OUTPUT device_group AS exp_group
                    | search exp_group="$exp_group$" exp_ip="$exp_ip$" nfo_hostname="$nfo_hostname$"
                    | stats sum(created_count) as sum_created_count, sum(bytes) as sum_bytes by app
                    | sort - sum_bytes
                    | head 100 
                    | eval sum_bytes=sum_bytes/1024/1024
                    | `commas_formatting(Created flows, sum_created_count)`
                    | `commas_formatting(MB, sum_bytes,2)`
                    | table app "Created flows" "MB"
                    | rename app as "Application" 
                </query>
                <earliest>$selection.earliest$</earliest>
                <latest>$selection.latest$</latest>
            </search>
            <option name="count">10</option>
            <option name="showPager">true</option>
            <option name="drilldown">none</option>
        </table>
      </panel>  
    </row>
    <row depends="$show_hint$">
        <panel>
            <html>
                <p>You see this message because there is <b>no data</b> for the selected Time Range or the <a href="/app/netflow/setup_dashboard/" target="_blank">App Setup</a> is not completed.</p>
                <p>This dashboard is populated by <b>NetFlow Optimizer</b> (NFO) Logic Module <b>“10034: Bandwidth Consumption per Application for Palo Alto Networks”</b> (syslogs with nfc_id=20034). This Module utilizes Palo Alto Networks NetFlow v9 reporting and provides a list of most active applications by traffic. Most active applications are reported by Network Device over a time interval. The number of reported top most active applications (N) and the observation interval (T, sec) are configurable. This Module is packaged in <b>NFO “Palo Alto Networks” Module Set</b>.</p>
                <p>Please either change the Time Range or make sure that this NFO Logic Module is enabled. See <a href="/app/netflow/configuration/" target="_blank">NSO Configuration</a> for more details.</p>
            </html>
        </panel>
    </row>
</form>