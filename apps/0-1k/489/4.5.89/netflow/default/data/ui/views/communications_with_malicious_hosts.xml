<form version="1.1" onunloadCancelJobs="True" script="search_rerun.js, table_formatting.js" stylesheet="inputs_layout.css">
  <label>Communications with Malicious Hosts</label>
  <search>
    <query>`netflow_search_rule_20062` | `set_span`</query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
    <done>
      <condition match="'job.resultCount' &gt; 0">
        <set token="show_content">true</set>
        <set token="span_token">$result.span$</set>
        <set token="span_int">$result.span_int$</set>
        <set token="range">$result.range$</set>
        <set token="earliest_token">$result.all_time_earliest$</set>
        <set token="latest_token">$result.all_time_latest$</set>
        <unset token="show_hint"></unset>
        <unset token="search_done"></unset>
      </condition>
      <condition>
        <unset token="show_content"></unset>
        <set token="show_hint">true</set>
      </condition>
    </done>
  </search>
  <search>
    <query>| inputlookup visualisation.parameters_lookup | transpose header_field=param</query>
    <earliest>-24h@h</earliest>
    <latest>now</latest>
    <done>
      <condition>
        <set token="charting.chart_value">$result.charting.chart$</set>
        <set token="charting.chart.stackMode_value">$result.charting.chart.stackMode$</set>
      </condition>
    </done>
  </search>
  <search id="baseSearch">
    <query>
          `netflow_index` nfc_id="20062" ( direction="inbound" OR direction="outbound" ) reputation
          | lookup `is_local_lookup` exporters_devices_lookup nfo_hostname exp_ip OUTPUT device_group AS exp_group
          | search  exp_group="$exp_group$" (src_ip="$src_ip$" OR src_host="$src_ip$") $advanced_filter$
            (dest_ip="$dest_ip$" OR dest_host="$dest_ip$")
            src_port="$src_port$" dest_port="$dest_port$" 
          | fillnull value="" transport threat_list_name reputation
          | search transport="$protocol_name$"
          | bin _time $span_token$ 
          | stats sum(flow_count) as sum_flow_count sum(bytes_in) as sum_bytes_in sum(bytes_out) as sum_bytes_out
            by nfo_hostname exp_ip action direction src_ip dest_ip threat_list_name reputation _time
    </query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
  </search>
  <fieldset autoRun="True">
    <input type="dropdown" token="nfo_hostname" searchWhenChanged="false">
      <label>NFO hostnames</label>
      <default>*</default>
      <search>
        <query>| `populate_nfo_hostnames`</query>
      </search>
      <fieldForLabel>nfo_hostname</fieldForLabel>
      <fieldForValue>nfo_hostname</fieldForValue>
    </input>
    <input type="dropdown" token="exp_group" searchWhenChanged="false">
      <label>Device group</label>
      <default>*</default>
      <search>
        <query>| `populate_exporter_group_list_by_nfo_hostname($nfo_hostname$)`</query>
      </search>
      <fieldForLabel>exp_group</fieldForLabel>
      <fieldForValue>exp_group</fieldForValue>
    </input>
    <input type="dropdown" token="exp_ip" searchWhenChanged="false">
      <label>Device</label>
      <default>*</default>
      <choice value="*">*</choice>
      <search>
        <query>| `populate_exporter_list_by_nfo_hostname($exp_group$,$nfo_hostname$)`</query>
      </search>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>exp_ip</fieldForValue>
    </input>
    <input type="text" token="src_ip" id="src_input" searchWhenChanged="False">
      <label>Source IP/mask</label>
      <default>*</default>
    </input>
    <input type="text" token="src_port" id="src_port_input" searchWhenChanged="False">
      <label>Src. Port</label>
      <default>*</default>
    </input>
    <input type="text" token="dest_ip" id="dest_input" searchWhenChanged="False">
      <label>Dest. IP/mask</label>
      <default>*</default>
    </input>
    <input type="text" token="dest_port" id="dest_port_input" searchWhenChanged="False">
      <label>Dest. Port</label>
      <default>*</default>
    </input>
    <input type="text" token="protocol_name" id="protocol_input" searchWhenChanged="False">
      <label>Protocol</label>
      <default>*</default>
    </input>
    <input type="text" token="advanced_filter" id="adv_input" searchWhenChanged="False">
      <label>Advanced Filter</label>
      <default>*</default>
    </input>
    <input type="time" searchWhenChanged="False">
      <label>Time Range</label>
      <default>Last 24 hours</default>
    </input>
  </fieldset>
  <row depends="$show_content$">
    <panel>
      <single>
        <title>Inbound Accepted</title>
        <search base="baseSearch">
        <query>
          | search direction="inbound" action="allowed"
          | stats sum(sum_flow_count) as Flows
        </query>
        </search>
        <option name="trendColorInterpretation">standard</option>
        <option name="trendDisplayMode">absolute</option>
        <option name="trendInterval">-24h</option>
        <option name="colorBy">trend</option>
        <option name="colorMode">none</option>
        <option name="numberPrecision">0</option>
        <option name="showTrendIndicator">0</option>
        <option name="showSparkline">0</option>
        <option name="useColors">1</option>
        <option name="useThousandSeparators">1</option>
        <option name="drilldown">none</option>
        <option name="unit"></option>
        <option name="unitPosition">before</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Outbound Accepted</title>
        <search base="baseSearch">
          <query>
          | search direction="outbound" action="allowed"
          | stats sum(sum_flow_count) as Flows
        </query>
        </search>
        <option name="trendColorInterpretation">standard</option>
        <option name="trendDisplayMode">absolute</option>
        <option name="trendInterval">-24h</option>
        <option name="colorBy">trend</option>
        <option name="colorMode">none</option>
        <option name="numberPrecision">0</option>
        <option name="showTrendIndicator">0</option>
        <option name="showSparkline">0</option>
        <option name="useColors">1</option>
        <option name="useThousandSeparators">1</option>
        <option name="drilldown">none</option>
        <option name="unit"></option>
        <option name="unitPosition">before</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Inbound Rejected</title>
        <search base="baseSearch">
          <query>
          | search direction="inbound" action="blocked"
          | stats sum(sum_flow_count) as Flows
        </query>
        </search>
        <option name="trendColorInterpretation">standard</option>
        <option name="trendDisplayMode">absolute</option>
        <option name="trendInterval">-24h</option>
        <option name="colorBy">trend</option>
        <option name="colorMode">none</option>
        <option name="numberPrecision">0</option>
        <option name="showTrendIndicator">0</option>
        <option name="showSparkline">0</option>
        <option name="useColors">1</option>
        <option name="useThousandSeparators">1</option>
        <option name="drilldown">none</option>
        <option name="unit"></option>
        <option name="unitPosition">before</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Outbound Rejected</title>
        <search base="baseSearch">
          <query>
          | search direction="outbound" action="blocked"
          | stats sum(sum_flow_count) as Flows
        </query>
        </search>
        <option name="trendColorInterpretation">standard</option>
        <option name="trendDisplayMode">absolute</option>
        <option name="trendInterval">-24h</option>
        <option name="colorBy">trend</option>
        <option name="colorMode">none</option>
        <option name="numberPrecision">0</option>
        <option name="showTrendIndicator">0</option>
        <option name="showSparkline">0</option>
        <option name="useColors">1</option>
        <option name="useThousandSeparators">1</option>
        <option name="drilldown">none</option>
        <option name="unit"></option>
        <option name="unitPosition">before</option>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Inbound Accepted</title>
        <search base="baseSearch">
          <query>
          | search direction="inbound" action="allowed"
          | timechart sum(sum_flow_count) as Flows
          </query>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Flows</option>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">140</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Outbound Accepted</title>
        <search base="baseSearch">
          <query>
          | search direction="outbound" action="allowed"
          | timechart sum(sum_flow_count) as Flows
          </query>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Flows</option>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">140</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Inbound Rejected</title>
        <search base="baseSearch">
          <query>
          | search direction="inbound" action="blocked"
          | timechart sum(sum_flow_count) as Flows
          </query>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Flows</option>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">140</option>
      </chart>
    </panel>
    <panel>
      <chart>
        <title>Outbound Rejected</title>
        <search base="baseSearch">
          <query>
          | search direction="outbound" action="blocked"
          | timechart sum(sum_flow_count) as Flows
          </query>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Flows</option>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">140</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <table id="table_1_1">
        <title>Inbound Accepted</title>
        <search base="baseSearch">
          <query>
            | search direction="inbound" action="allowed"
            | eval Threat = reputation."(".threat_list_name.")"
            | eval host_pair = src_ip." - ".dest_ip
            | stats sum(sum_flow_count) as Flows, sum(sum_bytes_out) as Bytes_Sent, sum(sum_bytes_in) as Bytes_Rcvd by host_pair, Threat 
            | table host_pair Threat Flows Bytes_Sent Bytes_Rcvd
            | rename host_pair as Attacker-Victim
            | sort 10 -Flows 
          </query>
        </search>
        <option name="count">10</option>
        <option name="showPager">true</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
    <panel>
      <table id="table_1_2">
        <title>Inbound Rejected</title>
        <search base="baseSearch">
          <query>
            | search direction="inbound" action="blocked"
            | eval Threat = reputation."(".threat_list_name.")"
            | eval host_pair = src_ip." - ".dest_ip
            | stats sum(sum_flow_count) as Flows, sum(sum_bytes_out) as Bytes_Sent, sum(sum_bytes_in) as Bytes_Rcvd by host_pair, Threat 
            | table host_pair Threat Flows Bytes_Sent Bytes_Rcvd
            | rename host_pair as Attacker-Victim
            | sort 10 -Flows 
          </query>
        </search>
        <option name="count">10</option>
        <option name="showPager">true</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table id="table_2_1">
        <title>Outbound Accepted</title>
        <search base="baseSearch">
          <query>
            | search direction="outbound" action="allowed"
            | eval Threat = reputation."(".threat_list_name.")"
            | eval host_pair = src_ip." - ".dest_ip
            | stats sum(sum_flow_count) as Flows, sum(sum_bytes_out) as Bytes_Sent, sum(sum_bytes_in) as Bytes_Rcvd by host_pair, Threat 
            | table host_pair Threat Flows Bytes_Sent Bytes_Rcvd
            | rename host_pair as Local-External
            | sort 10 -Flows 
          </query>
        </search>
        <option name="count">10</option>
        <option name="showPager">true</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
    <panel>
      <table id="table_2_2">
        <title>Outbound Rejected</title>
        <search base="baseSearch">
          <query>
            | search direction="outbound" action="blocked"
