<form version="1.1" onunloadCancelJobs="True" script="search_rerun.js" stylesheet="inputs_layout.css">
  <label>Traffic Overview Network Conversations</label>
  <fieldset autoRun="True">
    <input type="dropdown" token="nfo_hostname" searchWhenChanged="false">
      <label>NFO hostnames</label>
      <default>*</default>
      <search>
        <query>| `populate_nfo_hostnames`</query>
      </search>
      <fieldForLabel>nfo_hostname</fieldForLabel>
      <fieldForValue>nfo_hostname</fieldForValue>
    </input>
    <input type="dropdown" token="exp_group" searchWhenChanged="false">
      <label>Device group</label>
      <default>*</default>
      <search>
        <query>| `populate_exporter_group_list_by_nfo_hostname($nfo_hostname$)`</query>
      </search>
      <fieldForLabel>exp_group</fieldForLabel>
      <fieldForValue>exp_group</fieldForValue>
    </input>
    <input type="dropdown" token="exp_ip" searchWhenChanged="false">
      <label>Device</label>
      <default>*</default>
      <choice value="*">*</choice>
      <search>
        <query>| `populate_exporter_list_by_nfo_hostname($exp_group$,$nfo_hostname$)`</query>
      </search>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>exp_ip</fieldForValue>
    </input>
    <input type="time" searchWhenChanged="False">
      <label>Time Range</label>
      <default>Last 60 minutes</default>
    </input>
  </fieldset>
  <search>
    <query>`netflow_search_rule_20062`  | `set_span`</query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
    <done>
      <condition match="'job.resultCount' &gt; 0">
        <set token="show_content">true</set>
        <set token="span_token">$result.span$</set>
        <set token="span_int">$result.span_int$</set>
        <set token="range">$result.range$</set>
        <set token="earliest_token">$result.all_time_earliest$</set>
        <set token="latest_token">$result.all_time_latest$</set>
        <unset token="show_hint"></unset>
      </condition>
      <condition>
        <unset token="show_content"></unset>
        <set token="show_hint">true</set>
      </condition>
    </done>
  </search>
  <search id="baseSearch">
    <query>
      `netflow_search_rule_20062`    
        | fillnull value=0 bytes_out
        | lookup `is_local_lookup` exporters_devices_lookup nfo_hostname exp_ip OUTPUT device_group AS exp_group
        | search exp_group="$exp_group$" exp_ip="$exp_ip$" nfo_hostname="$nfo_hostname$"
        | `dedup_timechart_events`
        | bucket _time $span_token$
        | fillnull value="" transport, threat_list_name, app_id, idp
        | fillnull value="unknown" app_name username
        | `get_exporter_name(exp_ip_name)`
        | `format_ip_column(src_ip_string, src_ip, src_host)`
        | `format_ip_column(dest_ip_string, dest_ip, dest_host)`
        | strcat src_ip_string " - " dest_ip_string host_pair
        | eval app_port=if(((src_port&lt;dest_port AND src_port!=0) OR dest_port==0),src_port,dest_port)
        | eval bytes = bytes_in + bytes_out
        | stats sum(bytes) as sumbytes by host_pair,app_port,transport,exp_ip_name,direction,threat_list_name,app_id,app_name,idp,username,_time
        | eval summbits= sumbytes*8/($span_int$*1000000)  
        | `format_port_column(dest_port_string, app_port)`
    </query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
  </search>
  <search>
    <query>| inputlookup visualisation.parameters_lookup | transpose header_field=param</query>
    <earliest>-24h@h</earliest>
    <latest>now</latest>
    <done>
      <condition>
        <set token="charting.chart_value">$result.charting.chart$</set>
        <set token="charting.chart.stackMode_value">$result.charting.chart.stackMode$</set>
      </condition>
    </done>
  </search>
  <row depends="$show_content$">
    <panel>
      <html>
        <p>
          <b>Top Traffic by Network Conversation</b> <a href="$url1$" target="_blank">Pan-and-zoom and click here to see details</a>
        </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | timechart limit=10 $span_token$ sum(summbits) by host_pair useother="f"  
          </query>
        </search>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Mbps</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="height">208</option>
        <selection>
          <set token="selection_earliest">$start$</set>
          <set token="selection_latest">$end$</set>
          <set token="url1">
            <![CDATA[ 
                            /app/netflow/network_conversations_bi?earliest=$selection_earliest$&latest=$selection_latest$&form.nfo_hostname=$nfo_hostname$&form.exp_group=$exp_group$&form.exp_ip=$exp_ip$
                        ]]>
          </set>
        </selection>
      </chart>
    </panel>
    <panel>
      <html>
        <p>
          <b>Top Devices by Concurrent Network Conversations</b> <a href="$url2$" target="_blank">Pan-and-zoom and click here to see details</a>
        </p>
      </html>
      <chart>
        <search>
          <query>
            `netflow_search_rule_20062` exp_ip="$exp_ip$" nfo_hostname="$nfo_hostname$"   
             | lookup `is_local_lookup` exporters_devices_lookup nfo_hostname exp_ip OUTPUT device_group AS exp_group
             | search exp_group="$exp_group$" 
             | `dedup_timechart_events`
             | bucket _time span=30s
             | stats count as sessions_tint by exp_ip nfo_hostname _time
             | `get_exporter_name(exp_ip_name)`
             | timechart $span_token$ avg(sessions_tint) by exp_ip_name
          </query>
        </search>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">sessions</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="height">208</option>
        <selection>
          <set token="selection_earliest">$start$</set>
          <set token="selection_latest">$end$</set>
          <set token="url2">
            <![CDATA[ 
                            /app/netflow/network_conversations_concurrent_connections?earliest=$selection_earliest$&latest=$selection_latest$&form.nfo_hostname=$nfo_hostname$&form.exp_group=$exp_group$&form.exp_ip=$exp_ip$
                        ]]>
          </set>
        </selection>
      </chart>
    </panel>
  </row>
  <row depends="$show_content$">
    <panel>
      <html>
        <p>
          <b>Top Traffic by Port and Protocol</b> <a href="$url3$" target="_blank">Pan-and-zoom and click here to see details</a> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | timechart limit=10 $span_token$ sum(summbits) by dest_port_string useother="f"
          </query>
        </search>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Mbps</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="height">208</option>
        <selection>
          <set token="selection_earliest">$start$</set>
          <set token="selection_latest">$end$</set>
          <set token="url3">
            <![CDATA[ 
                            /app/netflow/network_conversations_by_protocol_and_port?earliest=$selection_earliest$&latest=$selection_latest$&form.nfo_hostname=$nfo_hostname$&form.exp_group=$exp_group$&form.exp_ip=$exp_ip$
                        ]]>
          </set>
        </selection>
      </chart>
    </panel>
    <panel>
      <html>
        <p>
          <b>Security: Communications with Bad Actors: Inbound/Outbound</b> <a href="$url4$" target="_blank">Pan-and-zoom and click here to see details</a> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search threat_list_name!=""
            | timechart limit=10 $span_token$ sum(summbits) by direction useother="f" 
          </query>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Mbps</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="height">200</option>
        <selection>
          <set token="selection_earliest">$start$</set>
          <set token="selection_latest">$end$</set>
          <set token="url4">
            <![CDATA[ 
                            /app/netflow/network_conversations_cyber_threats?earliest=$selection_earliest$&latest=$selection_latest$&form.nfo_hostname=$nfo_hostname$&form.exp_group=$exp_group$&form.exp_ip=$exp_ip$
                        ]]>
          </set>
        </selection>
      </chart>
    </panel>
  </row>
  <row depends="$show_content$">
    <panel>
      <html>
        <p>
          <b>Top Applications by Traffic</b> <a href="$url5$" target="_blank">Pan-and-zoom and click here to see details</a> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search app_name!="unknown"
            | strcat app_name " (" app_id "/" app_port ")"  app_string
            | timechart limit=10 $span_token$ sum(summbits) by app_string useother="f"
          </query>
        </search>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Mbps</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="height">208</option>
        <selection>
          <set token="selection_earliest">$start$</set>
          <set token="selection_latest">$end$</set>
          <set token="url5">
            <![CDATA[ 
                            /app/netflow/network_conversations_apps?earliest=$selection_earliest$&latest=$selection_latest$&form.nfo_hostname=$nfo_hostname$&form.exp_group=$exp_group$&form.exp_ip=$exp_ip$
                        ]]>
          </set>
        </selection>
      </chart>
    </panel>
    <panel>
      <html>
        <p>
          <b>Top Users by Traffic</b> <a href="$url6$" target="_blank">Pan-and-zoom and click here to see details</a> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search username!="unknown"
            | strcat username " (" idp ")"  user_string             
            | timechart limit=10 $span_token$ sum(summbits) by user_string useother="f"
          </query>
        </search>
        <option name="charting.chart">$charting.chart_value$</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Mbps</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.chart.stackMode">$charting.chart.stackMode_value$</option>
        <option name="charting.drilldown">none</option>
        <option name="height">208</option>
        <selection>
          <set token="selection_earliest">$start$</set>
          <set token="selection_latest">$end$</set>
          <set token="url6">
            <![CDATA[ 
                            /app/netflow/network_conversations_users?earliest=$selection_earliest$&latest=$selection_latest$&form.nfo_hostname=$nfo_hostname$&form.exp_group=$exp_group$&form.exp_ip=$exp_ip$
                        ]]>
          </set>
        </selection>
      </chart>
    </panel>
  </row>
  <row depends="$show_hint$">
    <panel>
      <html>
        <p>You see this message because there is <b>no data</b> for the selected Time Range or the <a href="/app/netflow/setup_dashboard/" target="_blank">App Setup</a> is not completed.</p>
        <p>This dashboard is populated by <b>NetFlow Optimizer</b> (NFO) Logic Module <b>â€ś10062: Network Conversationsâ€ť</b> (syslogs with nfc_id=20062). This Module identifies and reports hosts with the most traffic (optionally all hosts). It consolidates NetFlow records over a period of time (Data Collection Interval) which all have the same combination of the following fields: Source IP address, Destination IP address, Source port number, Destination port number, Layer 3 protocol. For bidirectional flows the Module stitches request-reply flows inverting source and destination for flows in the opposite direction. It reports consolidated flows separating bytes/packets sent and bytes/packets received.</p>
        <p>Please either change the Time Range or make sure that this NFO Logic Module is enabled. See <a href="/app/netflow/configuration/" target="_blank">NSO Configuration</a> for more details.</p>
      </html>
    </panel>
  </row>
</form>