<form version="1.1" onunloadCancelJobs="True" script="search_rerun.js" stylesheet="inputs_layout.css">
  <label>Azure Traffic Overview Accepts-Rejects (DEPRECATED)</label>
  <fieldset autoRun="True">
    <input type="dropdown" token="nfo_hostname" searchWhenChanged="false">
      <label>NFO hostnames</label>
      <default>*</default>
      <search>
        <query>| `populate_nfo_hostnames`</query>
      </search>
      <fieldForLabel>nfo_hostname</fieldForLabel>
      <fieldForValue>nfo_hostname</fieldForValue>
    </input>
    <input type="dropdown" token="exp_ip" searchWhenChanged="false">
      <label>Exporter (Virtual Network)</label>
      <default>*</default>
      <choice value="*">*</choice>
      <search>
        <query>| `populate_nsg_list_by_nfo_hostname($nfo_hostname$)`</query>
      </search>
      <fieldForLabel>exp_nsg_name</fieldForLabel>
      <fieldForValue>exp_ip</fieldForValue>
    </input>
<!--
    <input type="dropdown" token="direction" searchWhenChanged="false">
      <label>Direction</label>
      <choice value="inbound">Inbound</choice>
      <choice value="outbound">Outbound</choice>
      <default>inbound</default>
      <initialValue>inbound</initialValue>
    </input>
-->
    <input type="time" searchWhenChanged="False">
      <label>Time Range</label>
      <default>Last 60 minutes</default>
    </input>
  </fieldset>
  <search>
    <query>`netflow_search_rule_20467`  | `set_span`</query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
    <done>
      <condition match="'job.resultCount' &gt; 0">
        <set token="show_content">true</set>
        <set token="span_token">$result.span$</set>
        <set token="span_int">$result.span_int$</set>
        <set token="range">$result.range$</set>
        <set token="earliest_token">$result.all_time_earliest$</set>
        <set token="latest_token">$result.all_time_latest$</set>
        <unset token="show_hint"></unset>
      </condition>
      <condition>
        <unset token="show_content"></unset>
        <set token="show_hint">true</set>
      </condition>
    </done>
  </search>
  <search id="baseSearch">
    <query>
			`netflow_search_rule_20467`
			| search nfo_hostname="$nfo_hostname$" exp_ip="$exp_ip$"
			| `dedup_timechart_events`
			| fillnull value="" src_vm_name src_vnet_name dest_vm_name dest_vnet_name transport
<!-- use these lines to include DNS name
			| eval src_host = src_vm_name ."/". src_host
			| eval dest_host = dest_vm_name ."/". dest_host
-->  
			| eval src_host = src_vm_name
			| eval dest_host = dest_vm_name
			| `format_ip_column(src_vm, src_ip, src_host)`
			| `format_ip_column(dest_vm, dest_ip, dest_host)`
			| eval app_port=if(((src_port&lt;dest_port AND src_port!=0) OR dest_port==0),src_port,dest_port)
			| stats sum(bytes) as sumbytes by nfo_hostname,exp_ip,src_vm,dest_vm,app_port,transport,decision,direction
			| `format_port_column(dest_port_string, app_port)`
		</query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
  </search>
  <row depends="$show_content$">
    <panel>
      <html>
          <p><b>Top 10 ACCEPTED Inbound Source - Destination</b> <a href="$url1$" target="_blank">Click for details</a> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search direction=inbound decision="A"
            | strcat src_vm " - " dest_vm host_pair 
            | eval MB = sumbytes / 1024 / 1024
            | chart sum(MB) as TrafficMB by host_pair | sort - TrafficMB | head 10
