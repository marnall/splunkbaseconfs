        <panel>
            <chart>
                <title>Internal: Top Subnets</title>
                <search base="baseSearch_20067">
                    <query>
                        | lookup `is_local_lookup` exporters_devices_lookup nfo_hostname exp_ip OUTPUT device_group AS exp_group
                        | search exp_group="$exp_group$" exp_ip="$exp_ip$" nfo_hostname="$nfo_hostname$"
                        | dedup src_ip dest_ip src_port dest_port protocol input_snmp  _time
                        | lookup `is_local_lookup` my_subnets_lookup subnet AS src_ip OUTPUT description AS src_subnet, level_1 AS src_level_1, level_2 AS src_level_2, level_3 AS src_level_3, level_4 AS src_level_4
                        | lookup `is_local_lookup` my_subnets_lookup subnet AS dest_ip OUTPUT description AS dest_subnet, level_1 AS dest_level_1, level_2 AS dest_level_2, level_3 AS dest_level_3, level_4 AS dest_level_4 
                        | search (src_level_1=$level_1|s$ src_level_2=$level_2|s$ src_level_3=$level_3|s$ src_level_4=$level_4|s$) OR (dest_level_1=$level_1|s$ dest_level_2=$level_2|s$ dest_level_3=$level_3|s$ dest_level_4=$level_4|s$) AND (src_subnet != "external" AND dest_subnet !="external")
                        | `sampling(bytes)`
                        | eval MB = bytes / 1024 / 1024 
                        | eval src_dest_subnet = src_subnet." -&gt; ".dest_subnet
                        | stats sum(MB) as TrafficMB by src_dest_subnet
                        | sort - TrafficMB 
                        | head 10 
                        | eval TrafficMB=round(TrafficMB ,2)
