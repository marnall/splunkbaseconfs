<form version="1.1" refresh="0" stylesheet="inputs_layout.css">
    <label>Traffic Analyzer and Planning (based on my-subnets.csv lookup)</label>
    <search id="baseSearch_20067">
        <query>`netflow_search_rule_20067` 
            |  stats count values(protocol) AS protocol sum(bytes) AS bytes by _time exp_ip nfo_hostname src_ip dest_ip dest_port src_port input_snmp
        </query>
        <earliest>$tok_time.earliest$</earliest>
        <latest>$tok_time.latest$</latest>
        <done>
            <condition match="'job.resultCount' > 0">
                <set token="show_content">true</set>
                <unset token="show_hint_20067"></unset>
            </condition>
            <condition>
                <unset token="show_content"></unset>
                <set token="show_hint_20067">true</set>
            </condition>
        </done>
    </search>
    <search id="baseSearch_subnet_lookup">
        <query>| inputlookup my_subnets_lookup 
           | fillnull
           | where level_1 != "*"
           | stats count by level_1 level_2 level_3 level_4
        </query>
        <earliest>$tok_time.earliest$</earliest>
        <latest>$tok_time.latest$</latest>
        <done>
            <condition match="'job.resultCount' > 0">
                <set token="show_content">true</set>
                <unset token="show_hint_lookup"></unset>
            </condition>
            <condition>
                <unset token="show_content"></unset>
                <set token="show_hint_lookup">true</set>
            </condition>
        </done>
    </search>
    <fieldset autoRun="true" submitButton="true">
        <input type="dropdown" token="nfo_hostname" searchWhenChanged="false">
            <label>NFO hostnames</label>
            <default>*</default>
            <search>
                <query>| `populate_nfo_hostnames`</query>
            </search>
            <fieldForLabel>nfo_hostname</fieldForLabel>
            <fieldForValue>nfo_hostname</fieldForValue>
            <change>
                <set token="exp_group">*</set>
                <set token="exp_ip">*</set>
                <set token="level_1">*</set>
                <set token="level_2">*</set>
                <set token="level_3">*</set>
                <set token="level_4">*</set>
                <set token="form.exp_ip">*</set>
                <set token="form.level_1">*</set>
                <set token="form.level_2">*</set>
                <set token="form.level_3">*</set>
                <set token="form.level_4">*</set>
            </change>
        </input>
        <input type="dropdown" token="exp_group" searchWhenChanged="false">
            <label>Device group</label>
            <default>*</default>
            <search>
                <query>| `populate_exporter_group_list_by_nfo_hostname($nfo_hostname$)`</query>
            </search>
            <fieldForLabel>exp_group</fieldForLabel>
            <fieldForValue>exp_group</fieldForValue>
            <change>
                <set token="exp_ip">*</set>
                <set token="level_1">*</set>
                <set token="level_2">*</set>
                <set token="level_3">*</set>
                <set token="level_4">*</set>
                <set token="form.exp_ip">*</set>
                <set token="form.level_1">*</set>
                <set token="form.level_2">*</set>
                <set token="form.level_3">*</set>
                <set token="form.level_4">*</set>
            </change>
        </input>
        <input type="dropdown" token="exp_ip" searchWhenChanged="false">
            <label>Device</label>
            <default>*</default>
            <choice value="*">*</choice>
            <search>
                <query>| `populate_exporter_list_by_nfo_hostname($exp_group$,$nfo_hostname$)`</query>
            </search>
            <fieldForLabel>name</fieldForLabel>
            <fieldForValue>exp_ip</fieldForValue>
            <change>
                <set token="level_1">*</set>
                <set token="level_2">*</set>
                <set token="level_3">*</set>
                <set token="level_4">*</set>
                <set token="form.level_1">*</set>
                <set token="form.level_2">*</set>
                <set token="form.level_3">*</set>
                <set token="form.level_4">*</set>
            </change>
        </input>
        <input type="dropdown" token="level_1" searchWhenChanged="false">
            <label>Level 1</label>
            <default>*</default>
            <choice value="*">*</choice>
            <fieldForLabel>level_1</fieldForLabel>
            <fieldForValue>level_1</fieldForValue>
            <change>
                <set token="level_2">*</set>
                <set token="level_3">*</set>
                <set token="level_4">*</set>
                <set token="form.level_2">*</set>
                <set token="form.level_3">*</set>
                <set token="form.level_4">*</set>
            </change>
            <search base="baseSearch_subnet_lookup">
                <query>| fields level_1 
                       | dedup level_1 
                       | where level_1!="0" 
                       | sort + level_1
                </query>
            </search>
        </input>
        <input type="dropdown" token="level_2" searchWhenChanged="false">
            <label>Level 2</label>
            <default>*</default>
            <choice value="*">*</choice>
            <fieldForLabel>level_2</fieldForLabel>
            <fieldForValue>level_2</fieldForValue>
            <change>
                <set token="level_3">*</set>
                <set token="level_4">*</set>
                <set token="form.level_3">*</set>
                <set token="form.level_4">*</set>
            </change>
            <search base="baseSearch_subnet_lookup">
                <query>| search level_1=$level_1|s$ 
                       | fields level_2 
                       | dedup level_2 
                       | where level_2!="0" 
                       | sort + level_2
                </query>
            </search>
        </input>
        <input type="dropdown" token="level_3" searchWhenChanged="false">
            <label>Level 3</label>
            <default>*</default>
            <choice value="*">*</choice>
            <fieldForLabel>level_3</fieldForLabel>
            <fieldForValue>level_3</fieldForValue>
            <change>
                <set token="level_4">*</set>
                <set token="form.level_4">*</set>
            </change>
            <search base="baseSearch_subnet_lookup">
                <query>| search level_1=$level_1|s$  level_2=$level_2|s$ 
                       | fields level_3 
                       | dedup level_3 
                       | where level_3!="0" 
                       | sort + level_3
                </query>
            </search>
        </input>
        <input type="dropdown" token="level_4" searchWhenChanged="false">
            <label>Level 4</label>
            <default>*</default>
            <choice value="*">*</choice>
            <fieldForLabel>level_4</fieldForLabel>
            <fieldForValue>level_4</fieldForValue>
            <search base="baseSearch_subnet_lookup">
                <query>| search level_1=$level_1|s$  level_2=$level_2|s$ level_3=$level_3|s$ 
                       | fields level_4 
                       | dedup level_4 
                       | where level_4!="0" 
                       | sort + level_4
                </query>
            </search>
        </input>
        <input type="time" token="tok_time" searchWhenChanged="false">
            <label>Time Range</label>
            <default>
                <earliest>-60m@m</earliest>
                <latest>now</latest>
            </default>
        </input>
    </fieldset>
    <row depends="$show_content$">
        <panel>
            <chart>
                <title>East-West (Internal) / North-South (External)</title>
                <search base="baseSearch_20067">
                    <query>
                        | lookup `is_local_lookup` exporters_devices_lookup nfo_hostname exp_ip OUTPUT device_group AS exp_group
                        | search exp_group="$exp_group$" exp_ip="$exp_ip$" nfo_hostname="$nfo_hostname$"
                        | dedup src_ip dest_ip src_port dest_port protocol input_snmp  _time
                        | lookup `is_local_lookup` my_subnets_lookup subnet AS src_ip OUTPUT description AS src_subnet, level_1 AS src_level_1, level_2 AS src_level_2, level_3 AS src_level_3, level_4 AS src_level_4
                        | lookup `is_local_lookup` my_subnets_lookup subnet AS dest_ip OUTPUT description AS dest_subnet, level_1 AS dest_level_1, level_2 AS dest_level_2, level_3 AS dest_level_3, level_4 AS dest_level_4 
                        | search (src_level_1=$level_1|s$ src_level_2=$level_2|s$ src_level_3=$level_3|s$ src_level_4=$level_4|s$) OR (dest_level_1=$level_1|s$ dest_level_2=$level_2|s$ dest_level_3=$level_3|s$ dest_level_4=$level_4|s$)
                        | eval srcdesttype = if((src_subnet!="external" AND dest_subnet!="external"),"East-West","North-South")
                        | `sampling(bytes)`
                        | eval MB = bytes / 1024 / 1024
                        | stats sum(MB) as TrafficMB by srcdesttype
                        | eval TrafficMB=round(TrafficMB ,2)
                    </query>
                </search>
                <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
                <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
                <option name="charting.axisTitleX.visibility">visible</option>
                <option name="charting.axisTitleY.visibility">visible</option>
                <option name="charting.axisTitleY2.visibility">visible</option>
                <option name="charting.axisX.scale">linear</option>
                <option name="charting.axisY.scale">linear</option>
                <option name="charting.axisY2.enabled">0</option>
                <option name="charting.axisY2.scale">inherit</option>
                <option name="charting.chart">pie</option>
                <option name="charting.chart.bubbleMaximumSize">50</option>
                <option name="charting.chart.bubbleMinimumSize">10</option>
                <option name="charting.chart.bubbleSizeBy">area</option>
                <option name="charting.chart.nullValueMode">gaps</option>
                <option name="charting.chart.showDataLabels">none</option>
                <option name="charting.chart.showPercent">1</option>
                <option name="charting.chart.sliceCollapsingThreshold">0.1</option>
                <option name="charting.chart.stackMode">default</option>
