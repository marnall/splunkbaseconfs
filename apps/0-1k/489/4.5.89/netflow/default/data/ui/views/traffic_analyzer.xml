                        | search ((src_level_1=$level_1|s$ src_level_2=$level_2|s$ src_level_3=$level_3|s$ src_level_4=$level_4|s$) OR (dest_level_1=$level_1|s$ dest_level_2=$level_2|s$ dest_level_3=$level_3|s$ dest_level_4=$level_4|s$)) AND (src_subnet != "external" AND dest_subnet != "external")
                        | eval switchedrouted = if((src_subnet = dest_subnet),"Switched","Routed")
