<form version="1.1" onunloadCancelJobs="True" script="search_rerun.js" stylesheet="inputs_layout.css">
  <label>Network Conversations Accepts-Rejects</label>
  <fieldset autoRun="True">
    <input type="dropdown" token="nfo_hostname" searchWhenChanged="false">
      <label>NFO hostnames</label>
      <default>*</default>
      <search>
        <query>| `populate_nfo_hostnames`</query>
      </search>
      <fieldForLabel>nfo_hostname</fieldForLabel>
      <fieldForValue>nfo_hostname</fieldForValue>
    </input>
    <input type="dropdown" token="exp_group" searchWhenChanged="false">
      <label>Device group</label>
      <default>*</default>
      <search>
        <query>| `populate_exporter_group_list_by_nfo_hostname($nfo_hostname$)`</query>
      </search>
      <fieldForLabel>exp_group</fieldForLabel>
      <fieldForValue>exp_group</fieldForValue>
    </input>
    <input type="dropdown" token="exp_ip" searchWhenChanged="false">
      <label>Device / Virtual Network</label>
      <default>*</default>
      <choice value="*">*</choice>
      <search>
        <query>| `populate_exporter_list_by_nfo_hostname($exp_group$,$nfo_hostname$)`</query>
      </search>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>exp_ip</fieldForValue>
    </input>
    <input type="time" searchWhenChanged="False">
      <label>Time Range</label>
      <default>Last 60 minutes</default>
    </input>
  </fieldset>
  <search>
    <query>`netflow_search_rule_20062`  | `set_span`</query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
    <done>
      <condition match="'job.resultCount' &gt; 0">
        <set token="show_content">true</set>
        <set token="span_token">$result.span$</set>
        <set token="span_int">$result.span_int$</set>
        <set token="range">$result.range$</set>
        <set token="earliest_token">$result.all_time_earliest$</set>
        <set token="latest_token">$result.all_time_latest$</set>
        <unset token="show_hint"></unset>
      </condition>
      <condition>
        <unset token="show_content"></unset>
        <set token="show_hint">true</set>
      </condition>
    </done>
  </search>
  <search id="baseSearch">
    <query>
        `netflow_search_rule_20062`
        | search nfo_hostname="$nfo_hostname$" exp_ip="$exp_ip$"
        | fillnull value=0 bytes_out packets_out
        | `dedup_timechart_events`
        | eventstats latest(src_host) as l_src_host by nfo_hostname exp_ip src_ip
        | eventstats latest(dest_host) as l_dest_host by nfo_hostname exp_ip dest_ip
        | `format_ip_column(src_ip_string, src_ip, l_src_host)`
        | `format_ip_column(dest_ip_string, dest_ip, l_dest_host)`
        | strcat src_ip_string " - " dest_ip_string host_pair
        | eval app_port=if(((src_port&lt;dest_port AND src_port!=0) OR dest_port==0),src_port,dest_port)
        | eval exp_ip_network_conversation=nfo_hostname."#".exp_ip."#".host_pair."#".app_port."#".flow_type."#".transport
        | stats sum(bytes_out) as outbytes 
          sum(bytes_in) as inbytes 
          sum(packets_out) as outpackets 
          sum(packets_in) as inpackets 
          sum(flow_count) as Connections 
            by nfo_hostname exp_ip_network_conversation action
        | eval temp=split(exp_ip_network_conversation,"#")
        | eval nfo_hostname=mvindex(temp,0) 
        | eval exp_ip=mvindex(temp,1) 
        | eval host_pair=mvindex(temp,2)
        | eval app_port=mvindex(temp,3)
        | eval flow_type=mvindex(temp,4)
        | eval transport=mvindex(temp,5)
        | `format_port_column(dest_port_string, app_port)`
    </query>
    <earliest>$earliest$</earliest>
    <latest>$latest$</latest>
  </search>
  <row depends="$show_content$">
    <panel>
      <html>
          <p>
          <b>Top 10 ACCEPTED Network Converations by Traffic Volume</b> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search action="allowed"
            | eval MB = (inbytes + outbytes) / 1024 / 1024
            | chart sum(MB) as TrafficMB by host_pair | sort - TrafficMB | head 10
            | eval TrafficMB=round(TrafficMB ,2)
          </query>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.visibility">visible</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">gaps</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.showPercent">1</option>
        <option name="charting.chart.sliceCollapsingThreshold">0</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">200</option>
      </chart>
    </panel>
    <panel>
      <html>
          <p>
          <b>Top 10 REJECTED Network Converations by Flow Count</b> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search action="blocked"
            | chart sum(Connections) as Connections by host_pair | sort - Connections | head 10
          </query>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.visibility">visible</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">gaps</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.showPercent">1</option>
        <option name="charting.chart.sliceCollapsingThreshold">0</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">200</option>
      </chart>
    </panel>
  </row>
  <row depends="$show_content$">
    <panel>
      <html>
          <p>
          <b>Top 10 ACCEPTED Application Ports by Traffic Volume</b></p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search action="allowed"
            | eval MB = (inbytes + outbytes) / 1024 / 1024
            | chart sum(MB) as TrafficMB by dest_port_string | sort - TrafficMB | head 10
            | eval TrafficMB=round(TrafficMB ,2)
          </query>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.visibility">visible</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">gaps</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.showPercent">1</option>
        <option name="charting.chart.sliceCollapsingThreshold">0</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">200</option>
      </chart>
    </panel>
    <panel>
      <html>
          <p>
          <b>Top 10 REJECTED Application Ports by Flow Count</b> </p>
      </html>
      <chart>
        <search base="baseSearch">
          <query>
            | search action="blocked"
            | chart sum(Connections) as Connections by dest_port_string | sort - Connections | head 10
          </query>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.visibility">visible</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">pie</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">gaps</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.showPercent">1</option>
        <option name="charting.chart.sliceCollapsingThreshold">0</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.placement">right</option>
        <option name="height">200</option>
      </chart>
    </panel>
  </row>
  <row depends="$show_hint$">
    <panel>
      <html>
        <p>You see this message because there is <b>no data</b> for the selected Time Range or the <a href="/app/netflow/setup_dashboard/" target="_blank">App Setup</a> is not completed.</p>
        <p>This dashboard is populated by <b>NetFlow Optimizer</b> (NFO) Logic Module <b>“10062: Network Conversations”</b> (syslogs with nfc_id=20062). This Module identifies and reports hosts with the most traffic (optionally all hosts). It consolidates NetFlow records over a period of time (Data Collection Interval) which all have the same combination of the following fields: Source IP address, Destination IP address, Source port number, Destination port number, Layer 3 protocol. For bidirectional flows the Module stitches request-reply flows inverting source and destination for flows in the opposite direction. It reports consolidated flows separating bytes/packets sent and bytes/packets received.</p>
        <p>Please either change the Time Range or make sure that this NFO Logic Module is enabled. See <a href="/app/netflow/configuration/" target="_blank">NSO Configuration</a> for more details.</p>
      </html>
    </panel>
  </row>
</form>