<form>
 <label>User Activity</label>

 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="true">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>User Activity</center></h1></html>
 </row>

 <row>
  <table>
   <searchName>Successful Actions</searchName>
   <title>Successful Actions</title>
   <option name="showPager">true</option>
  </table>
  <table>
   <searchName>Failed Actions</searchName>
   <title>Failed Actions</title>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Successful Reasons</searchName>
   <title>Successful Action Reasons</title>
   <option name="showPager">true</option>
  </table>
  <table>
   <searchName>Failure Reasons</searchName>
   <title>Failed Action Reasons</title>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Login Failures by User</searchName>
   <title>Login Failures by User</title>
   <option name="showPager">true</option>
  </table>
  <table>
   <searchName>After Hours Admin Events</searchName>
   <title>After Hours (&lt;9am and &gt;5pm) Admin Events</title>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>System Actions</searchName>
   <title>System Level Actions</title>
   <option name="showPager">true</option>
  </table>
  <table>
   <searchName>Runtime Actions</searchName>
   <title>Runtime Level Actions</title>
   <option name="showPager">true</option>
  </table>
  <table>
   <searchName>Admin Actions</searchName>
   <title>Admin Level Actions</title>
   <option name="showPager">true</option>
  </table>
 </row>

</form>
