<form>
 <label>Network Activity</label>

 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="true">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>Network Activity</center></h1></html>
 </row>

 <row>
  <chart>
   <searchName>Received KBytes by Interface</searchName>
   <title>Received KBytes by Interface</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
  <chart>
   <searchName>Transmitted KBytes by Interface</searchName>
   <title>Transmitted KBytes by Interface</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
 </row>

 <row>
  <chart>
   <searchName>Inbound Packets by Interface</searchName>
   <title>Total Inbound Packets by Interface</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
  <chart>
   <searchName>Outbound Packets by Interface</searchName>
   <title>Total Outbound Packets by Interface</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
 </row>

 <row>
  <chart>
   <searchName>TCP Segments</searchName>
   <title>Total TCP In/Out Segments</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
  <chart>
   <searchName>UDP Datagrams</searchName>
   <title>Total UDP In/Out Datagrams</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
 </row>

 <row>
  <chart>
   <searchName>TCP Connection Count</searchName>
   <title>Total TCP Active/Passive Connections Opened</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
  <chart>
   <searchName>TCP and UDP Error Count</searchName>
   <title>Total TCP and UDP Error Counts</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
 </row>

 <row>
  <chart>
   <searchName>ICMP Messages</searchName>
   <title>ICMP In/Out Messages</title>
   <option name="charting.chart">area</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
  <chart>
   <searchName>ICMP Inbound Echos</searchName>
   <title>ICMP Inbound Echos</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
 </row>

 <row>
  <chart>
   <searchName>ICMP Destination Unreachables</searchName>
   <title>ICMP In/Out Destination Unreachables</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
  </chart>
 </row>

</form>
