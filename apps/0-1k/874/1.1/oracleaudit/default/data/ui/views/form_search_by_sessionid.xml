<form>
    <label>Search by Oracle Session ID</label>

    <searchTemplate>$sessionid$</searchTemplate>

    <fieldset>
        <input type="text" token="sessionid">
            <label>Enter the Oracle Session ID</label>
            <prefix>index="oracleaudit" SESSIONID=</prefix>
        </input>
        <input type="time">
            <default>Last 24 hours</default>
        </input>
    </fieldset>

    <row>
      <!-- output the results as a 50 row events view -->
      <event>
            <title>Events</title>
            <option name="count">50</option>
      </event>
  </row>
</form>
