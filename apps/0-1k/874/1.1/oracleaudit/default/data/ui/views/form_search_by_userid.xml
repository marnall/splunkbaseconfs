<form>
    <label>Search by DB User</label>

    <searchTemplate>$userid$</searchTemplate>

    <fieldset>
        <input type="text" token="userid">
            <label>Enter the DB Username</label>
            <prefix>index="oracleaudit" USERID=</prefix>
        </input>
        <input type="time">
            <default>Last 24 hours</default>
        </input>
    </fieldset>

    <row>
      <!-- output the results as a 50 row events view -->
      <event>
            <title>Events</title>
            <option name="count">50</option>
      </event>
  </row>
</form>
