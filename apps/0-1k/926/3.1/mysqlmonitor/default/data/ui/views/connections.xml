<form class="formsearch">
  <label>Connections</label>

  <fieldset>
    <input type="dropdown" token="host" searchWhenChanged="false">
      <populatingSearch fieldForValue="value" fieldForLabel="label">| metadata type=hosts index=mysql | eval label=host | eval value=host | sort host desc | inputlookup append=t dbgroups.csv | reverse</populatingSearch>
    </input>
    <input type="time" searchWhenChanged="false"/>
  </fieldset>
  
  <row>
    <chart>
    	<title>Number of connections</title>
    	<searchTemplate>`connections_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Connections/s</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Aborted clients</title>
    	<searchTemplate>`aborted_clients_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Aborted clients/s</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Aborted connections</title>
    	<searchTemplate>`aborted_connects_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Aborted connections/s</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
</form>

