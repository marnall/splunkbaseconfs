<form class="formsearch">
  <label>Threads</label>

  <fieldset>
    <input type="dropdown" token="host" searchWhenChanged="false">
      <populatingSearch fieldForValue="value" fieldForLabel="label">| metadata type=hosts index=mysql | eval label=host | eval value=host | sort host desc | inputlookup append=t dbgroups.csv | reverse</populatingSearch>
    </input>
    <input type="time" searchWhenChanged="false"/>
  </fieldset>

  <row>
    <chart>
    	<title>Thread saturation</title>
    	<searchTemplate>`thread_saturation_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Saturation %</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Threads running</title>
    	<searchTemplate>`threads_running_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Threads</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
</form>

