<form class="formsearch">
  <label>InnoDB Buffer pool</label>

  <fieldset>
    <input type="dropdown" token="host" searchWhenChanged="false">
      <populatingSearch fieldForValue="value" fieldForLabel="label">| metadata type=hosts index=mysql | eval label=host | eval value=host | sort host desc | inputlookup append=t dbgroups.csv | reverse</populatingSearch>
    </input>
    <input type="time" searchWhenChanged="false"/>
  </fieldset>

  <row>
    <chart>
    	<title>Pages dirty</title>
    	<searchTemplate>`innodb_buffer_pool_pages_dirty_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
	<option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Dirty pages</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Pages flushed</title>
    	<searchTemplate>`innodb_buffer_pool_pages_flushed_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
	<option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Flushed pages</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Buffer pool miss rate</title>
    	<searchTemplate>`innodb_buffer_pool_miss_rate_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
	<option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Miss % (log)</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
	<option name="charting.axisY.scale">log</option>
    </chart>
  </row>

</form>

