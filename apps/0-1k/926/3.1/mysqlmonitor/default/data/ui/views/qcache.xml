<form class="formsearch">
  <label>Query Cache</label>

  <fieldset>
    <input type="dropdown" token="host" searchWhenChanged="false">
      <populatingSearch fieldForValue="value" fieldForLabel="label">| metadata type=hosts index=mysql | eval label=host | eval value=host | sort host desc | inputlookup append=t dbgroups.csv | reverse</populatingSearch>
    </input>
    <input type="time" searchWhenChanged="false"/>
  </fieldset>

  <row>
    <chart>
    	<title>Query Cache Hits</title>
    	<searchTemplate>`query_cache_total_hits_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Hits/s</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Query Cache Hit Ratio</title>
    	<searchTemplate>`query_cache_hit_ratio_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Hit Ratio</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Free Space</title>
    	<searchTemplate>`query_cache_free_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Free MB</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Low Memory Prunes</title>
    	<searchTemplate>`query_cache_lowmem_prunes_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Prunes/s</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
</form>

