<form class="formsearch">
  <label>Host overview</label>

  <fieldset>
    <input type="dropdown" token="host" searchWhenChanged="false">
      <populatingSearch fieldForValue="value" fieldForLabel="label">| metadata type=hosts index=mysql | eval label=host | eval value=host</populatingSearch>
    </input>
    <input type="time" searchWhenChanged="false"/>
  </fieldset>

  <row>
    <chart>
    	<title>Queries</title>
    	<searchTemplate>`queries_overview_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
	<option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Queries/s</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
    <chart>
    	<title>Transactions</title>
    	<searchTemplate>`transactions_overview_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
	<option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Transactions/s</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
  </row>
  <row>
    <chart>
    	<title>Buffer pool</title>
    	<searchTemplate>`buffer_pool_overview_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
	<option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Pages</option>
	<option name="charting.legend.labelStyle.maximumWidth">500</option>
    </chart>
    <chart>
    	<title>Threads running</title>
    	<searchTemplate>`threads_running_by_host($host$)`</searchTemplate>
    	<option name="charting.chart">line</option>
	<option name="charting.chart.nullValueMode">connect</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.primaryAxisTitle.text">Time</option>
    	<option name="charting.secondaryAxisTitle.text">Threads</option>
	<option name="charting.legend.visible">false</option>
    </chart>
  </row>
</form>

