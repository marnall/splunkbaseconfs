<form>
 <label>Allowed Web Activity by User</label>

 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="true">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>Allowed Web Activity by Users</center></h1></html>
 </row>

 <row>
  <table>
   <searchName>Users by Requests</searchName>
   <title>Users by # of Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Categories by Request</searchName>
   <title>Categories by # of Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Categories by User</searchName>
   <title>Top Category per User</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Content Types</searchName>
   <title>Top Content Types</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Source IPs By Requests</searchName>
   <title>Source IPs by # of Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Dest IPs by Requests</searchName>
   <title>Dest IPs by # of Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

</form>
