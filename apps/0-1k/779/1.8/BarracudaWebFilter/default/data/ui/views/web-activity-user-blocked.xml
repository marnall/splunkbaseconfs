<form>
 <label>Blocked Web Activity by User</label>

 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="true">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>Blocked Web Activity by Users</center></h1></html>
 </row>

 <row>
  <table>
   <searchName>Blocked Users By Requests</searchName>
   <title>Users by # of Blocked Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Blocked Categories by Request</searchName>
   <title>Categories by # of Blocked Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Blocked Categories by User</searchName>
   <title>Top Blocked Category per User</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Blocked Content Types</searchName>
   <title>Top Blocked Content Types</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Blocked Source IPs By Requests</searchName>
   <title>Source IPs by # of Blocked Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Blocked Dest IPs by Requests</searchName>
   <title>Dest IPs by # of Blocked Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

</form>
