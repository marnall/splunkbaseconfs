<form>
 <label>Infection Activity</label>

 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="false">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>Infection Activity</center></h1></html>
 </row>

 <row>
  <table>
   <searchName>Users by Spyware Type</searchName>
   <title>Top Users by Spyware Type</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Domains by Spyware Type</searchName>
   <title>Top Domains by Spyware Type</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Spyware Types</searchName>
   <title>Top Spyware Types</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Source IPs by Spyware Type</searchName>
   <title>Top Source IPs by Spyware Type</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

</form>
