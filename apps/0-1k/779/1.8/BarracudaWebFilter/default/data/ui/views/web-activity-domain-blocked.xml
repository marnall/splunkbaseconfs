<form>
 <label>Blocked Web Activity by Domain</label>

 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="true">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>Blocked Web Activity by Domain</center></h1></html>
 </row>

 <row>
  <table>
   <searchName>Blocked Domains by Request</searchName>
   <title>Domains by # of Requests</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Blocked Domains by User</searchName>
   <title>Top Domain Accessed per User</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Blocked Domains by Content Type</searchName>
   <title>Top Blocked Content Type by Domain</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Blocked Domains by Category</searchName>
   <title>Top Blocked Categories by Domain</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

</form>
