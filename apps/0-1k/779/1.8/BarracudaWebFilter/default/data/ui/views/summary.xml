<form>
 <label>Summary</label>
  
 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="true">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>Web Filter Summary</center></h1></html>
 </row>

 <row>
  <table>
   <searchName>Blocked Users By Requests</searchName>
   <title>Top 10 Blocked Users</title>
   <option name="count">10</option>
   <option name="showPager">false</option>
  </table>
  <table>
   <searchName>Users by Requests</searchName>
   <title>Top 10 Users by Allowed Requests</title>
   <option name="count">10</option>
   <option name="showPager">false</option>
  </table>
  <table>
   <searchName>Spyware Types</searchName>
   <title>Top 10 Spyware Types</title>
   <option name="count">10</option>
   <option name="showPager">false</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Blocked Domains by Request</searchName>
   <title>Top 10 Blocked Domains</title>
   <option name="count">10</option>
   <option name="showPager">false</option>
  </table>
  <table>
   <searchName>Domains by Request</searchName>
   <title>Top 10 Allowed Domains</title>
   <option name="count">10</option>
   <option name="showPager">false</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Blocked Categories by Request</searchName>
   <title>Top 10 Blocked Categories</title>
   <option name="count">10</option>
   <option name="showPager">false</option>
  </table>
  <table>
   <searchName>Categories by Request</searchName>
   <title>Top 10 Allowed Categories</title>
   <option name="count">10</option>
   <option name="showPager">false</option>
  </table>
 </row>

</form>
