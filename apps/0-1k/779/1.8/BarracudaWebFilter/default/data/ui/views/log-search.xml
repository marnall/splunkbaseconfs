<form>

 <searchTemplate>sourcetype=barracuda src_ip=$srcip$ login_id=$username$ dst_url=*$destination$* matched_category=*$category$* action_type=$actiontype$ | eval actiontaken=case(action_type == 0, "ALLOWED", action_type == 1, "BLOCKED") | table _time, actiontaken, src_ip, login_id, matched_category, dst_url | convert ctime(_time) | rename _time AS "Date/Time", src_ip AS "Source IP", login_id AS "Username", dst_url AS "Destination", matched_category AS "Category", actiontaken AS "Action"</searchTemplate>

 <label>Log Search</label>

 <row>
  <html><center><h3>Custom search results can be found in the table below.  For an understanding of the Log Categories please <a href="log-categories" target="_blank">click here.</a></h3></center></html>
 </row>

 <fieldset autoRun="true">
  <input type="dropdown" token="username" searchWhenChanged="false">
   <label>Username:</label>
   <choice>*</choice>
   <populatingSearch fieldForValue="login_id" fieldForLabel="login_id">
    <![CDATA[sourcetype=barracuda (login_id!=NULL AND login_id!="-") earliest=-12h@h latest=now | fields login_id | dedup login_id | stats count by login_id]]>
   </populatingSearch>
   <default>*</default>
  </input>

  <input type="dropdown" token="srcip" searchWhenChanged="false">
   <label>Source IP:</label>
   <choice>*</choice>
   <populatingSearch fieldForValue="src_ip" fieldForLabel="src_ip">
    <![CDATA[sourcetype=barracuda (src_ip!=NULL AND src_ip!="-") earliest=-12h@h latest=now | fields src_ip | dedup src_ip | stats count by src_ip]]>
   </populatingSearch>
   <default>*</default>
  </input>

  <input type="text" token="destination" searchWhenChanged="false">
   <label>Destination URL:</label>
   <default>*</default>
  </input>

  <input type="dropdown" token="actiontype" searchWhenChanged="false">
   <label>Action:</label>
   <choice>*</choice>
   <choice value="0">Allowed</choice>
   <choice value="1">Blocked</choice>
   <default>*</default>
  </input>

  <input type="dropdown" token="category" searchWhenChanged="false">
