<form>
 <label>Bandwidth Usage</label>

 <fieldset autoRun="true">
  <input type="time" searchWhenChanged="true">
   <default>Last 60 minutes</default>
  </input>
 </fieldset>

 <row>
  <html><h1><center>Bandwidth Usage</center></h1></html>
 </row>

 <row>
  <chart>
   <searchString>sourcetype=barracuda earliest=-7d@d latest=now | eval bandwidth=round((request_size/1024)/1024,2) | timechart sum(bandwidth)</searchString>
   <title>Weekly Bandwidth Usage</title>
   <option name="charting.chart">line</option>
   <option name="charting.primaryAxisTitle.text">Date and Time</option>
   <option name="charting.secondaryAxisTitle.text">Bandwidth (MB)</option>
   <option name="charting.legend.placement">none</option>
  </chart>
 </row>

 <row>
  <table>
   <searchName>Bandwidth by User</searchName>
   <title>Users by Bandwidth Consumed</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Bandwidth by Content Type</searchName>
   <title>Content Type by Bandwidth Consumed</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Bandwidth by Domain</searchName>
   <title>Domains by Bandwidth Consumed</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <table>
   <searchName>Bandwidth by Source IP</searchName>
   <title>Source IP by Bandwidth Consumed</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>

  <table>
   <searchName>Bandwidth by Dest IP</searchName>
   <title>Dest IP by Bandwidth Consumed</title>
   <option name="count">10</option>
   <option name="showPager">true</option>
  </table>
 </row>

 <row>
  <chart>
   <searchName>Bandwidth by Hour of Day</searchName>
   <title>Bandwidth Consumed by Hour of Day</title>
   <option name="charting.chart">column</option>
   <option name="charting.legend.placement">none</option>
   <option name="charting.axisTitleX.text">Hour of Day</option>
   <option name="charting.axisTitleY.text">Bandwidth (MB)</option>
  </chart>

  <chart>
   <searchString>sourcetype=barracuda earliest=-7d@d latest=now | bucket _time span=24h | `calc_bandwidth_MB(chart, date_wday)`</searchString>
   <title>Bandwidth Consumed by Day of Week (Last 7 Days)</title>
   <option name="charting.chart">column</option>
   <option name="charting.legend.placement">none</option>
   <option name="charting.axisTitleX.text">Day of Week</option>
   <option name="charting.axisTitleY.text">Bandwidth (MB)</option>
  </chart>
 </row>

</form>
